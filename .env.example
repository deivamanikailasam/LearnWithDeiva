# Optional — enables login + cloud sync of progress/bookmarks via Supabase.
# Leave unset and the app works fully using localStorage only.
#
# Get these from your Supabase project: Settings → API.
# The anon key is a PUBLIC key (safe to ship to the browser); Row Level
# Security protects the data. Never put the service_role key here.
#
# For local dev: copy this file to ".env" and fill in the values.
# For GitHub Pages: add them as repo Variables/Secrets and pass them in the
# deploy workflow (see .github/workflows/deploy.yml).

VITE_SUPABASE_URL=https://bhhcjoxpfmxocdyipsgj.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_lLsxUvaSiTJGcWq4vwp8NQ_pnzaA5oq

# Optional — comma-separated list of social login buttons to show in the sign-in
# modal. ONLY list providers you have actually enabled in Supabase
# (Authentication → Providers), otherwise users get a "provider is not enabled"
# error. Leave unset/empty to hide all social buttons (email + magic link still
# work). Supported values: google, github
# Example: VITE_OAUTH_PROVIDERS=google,github
VITE_OAUTH_PROVIDERS=google
