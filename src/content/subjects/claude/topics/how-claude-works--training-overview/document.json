{"format":"tiptap/v1","updatedAt":"2026-06-20T04:43:18.828Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"How Claude learns:"}]},{"type":"paragraph","content":[{"type":"text","text":"Claude’s “knowledge” comes from "},{"type":"text","marks":[{"type":"bold"}],"text":"training"},{"type":"text","text":" on huge amounts of text."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Stage 1: Pre-training (learning from raw text)"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Claude reads "},{"type":"text","marks":[{"type":"bold"}],"text":"trillions of tokens"},{"type":"text","text":" from books, websites, articles, code, etc."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"It tries to predict the next token in each sentence."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Every time it’s wrong, it adjusts its internal numbers (parameters) slightly to get closer."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Over time, it learns:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Grammar"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Facts about the world"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Common reasoning patterns"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"How to follow simple instructions implicitly"}]}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"This is "},{"type":"text","marks":[{"type":"bold"}],"text":"unsupervised"},{"type":"text","text":": no human labels, just raw text."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Stage 2: Supervised fine-tuning (learning to be helpful)"}]},{"type":"paragraph","content":[{"type":"text","text":"After pre-training, Claude is trained on "},{"type":"text","marks":[{"type":"bold"}],"text":"curated conversations"},{"type":"text","text":":"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Human-written prompts (questions, requests)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Good assistant-like responses"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"This teaches Claude to:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Follow instructions"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Stay conversational"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Be more helpful and structured"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Stage 3: Alignment (learning to be safe and honest)"}]},{"type":"paragraph","content":[{"type":"text","text":"Claude is further trained to align with human values using techniques like:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"RLHF"},{"type":"text","text":" (Reinforcement Learning from Human Feedback): humans rate outputs, and Claude learns to prefer good ones."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Constitutional AI"},{"type":"text","text":" (Anthropic’s method): Claude uses a written “constitution” of principles to critique and improve its own outputs, then learns to follow those principles."}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"This makes Claude more:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Helpful"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Honest"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Harmless (safe)"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"4. What Claude "},{"type":"text","marks":[{"type":"bold"},{"type":"italic"}],"text":"doesn’t"},{"type":"text","marks":[{"type":"bold"}],"text":" have (important limitations)"}]},{"type":"paragraph","content":[{"type":"text","text":"Even though Claude seems smart, it’s important to remember:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"No true understanding"},{"type":"text","text":": It doesn’t “know” things like humans do; it recognizes patterns."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"No consciousness"},{"type":"text","text":": It has no feelings, beliefs, or self."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Static knowledge"},{"type":"text","text":": Its knowledge is fixed from training; it doesn’t learn from your conversation or access real-time info unless you give it tools."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Can be wrong"},{"type":"text","text":": It can confidently say false things (hallucinations), especially on topics it didn’t see well in training."}]}]}]},{"type":"paragraph"}]}}
