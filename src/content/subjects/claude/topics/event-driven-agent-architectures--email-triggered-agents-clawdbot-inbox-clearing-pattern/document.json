ull,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Enterprise customer requests"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Demo request"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Product demonstrations"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Security"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Security concerns"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Spam"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Unwanted emails"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How It Works: Step-by-Step"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 1: Email Collection"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Gmail inbox / AgentMail inbox\n    ↓\nPub/Sub webhook triggers Clawdbot"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Option 1"},{"type":"text","text":": Use your personal Gmail with Pub/Sub\n"},{"type":"text","marks":[{"type":"bold"}],"text":"Option 2"},{"type":"text","text":": Give Clawdbot dedicated AgentMail inbox (recommended for security)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 2: Batch Labeling"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"One of them was I told it to read all the emails we receive at Orai to their ORI support and I told it to start triaging and it went through everything.\nIt came up with a few email categories on what to organize it in.\nAnd then it actually did it.\nSo, it added triage labels to all of them.\nSo, billing, refund, cancellations, bug, feedback, enterprise, demo request, security, ops, and spam."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Result"},{"type":"text","text":": 400 emails automatically organized"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 3: Deep Reading (Not Just Subject Lines)"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"And then I noticed that when I went into the feedback, many of those emails were actually in some of the other categories.\nSo I went back and I said, \"Hey, look at the stuff and re-triaged.\"\nSo it was just looking at the subject heading and I told it to read the body as well.\nSo it read the body of the emails and then lo and behold reclassified from feedback.\nIt found 31 more threads that were like refund, cancellations."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key insight"},{"type":"text","text":": Read the actual email body, not just subject lines, for accurate classification"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 4: Response Drafting"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Agent generates draft responses for human review"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best practice"},{"type":"text","text":": Human reviews and sends drafts, not auto-send"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 5: Daily Summary"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"AI agent generates daily morning summary for managers, highlighting emails that require attention"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Saved 4 hours"},{"type":"text","text":" of manual triage time\n- Keep everything in Inbox until resolved"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Implementation Guide"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Method 1: Using AgentMail (Recommended)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Create Account"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Create account at console.agentmail.to\n# Generate API key in dashboard"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Install SDK"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"pip install agentmail python-dotenv\nexport AGENTMAIL_API_KEY=your_key_here"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. Set Up Webhooks"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Register webhook endpoint\nwebhook = client.webhooks.create(\n    path=\"/agentmail\",\n    events=[\"message.created\"]\n)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"4. Install Clawdbot Skills"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"openclaw install gmail-pubsub email-classifier response-draftzer"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Method 2: Using Personal Gmail"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Enable Gmail Pub/Sub"},{"type":"text","text":":\n- Navigate to Gmail API Console\n- Enable Pub/Sub for inbox\n- Create webhook endpoint"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Install Clawdbot"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"openclaw install gmail-pubsub skill"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. Configure"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"skills\": {\n    \"gmail\": {\n      \"email\": \"your-email@gmail.com\",\n      \"classify\": true,\n      \"draftResponses\": true,\n      \"dailySummary\": true\n    }\n  }\n}"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Safety & Security: Critical Warnings"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"⚠️ The Email Deletion Incident"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Meta security researcher's AI agent accidentally deleted her emails"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Summer Yue instructed OpenClaw: \"Check inbox, suggest what you would archive or delete, don't act until I tell you to.\"\n    ↓\nPersonal inbox was too large → triggered compaction\n    ↓\nCompaction lost original instruction\n    ↓\nAgent speed-deleted entire inbox"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What happened"},{"type":"text","text":":\n- \"humbles like telling OpenClaw 'confirm before' and it speed deleting your inbox\"\n- \"Inbox too large and initiated compaction process, which caused it to disregard original instructions\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Correct Approach: Approval Gates"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Irreversible actions must pass an approval gate BEFORE they run, not rely on stop mechanism afterward"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"1. Log every destructive action intent before execution\n    ↓\n2. Insert clear approval checkpoint for any irreversible operation\n    ↓\n3. Treat 'stop' as command to halt NEXT action, not to undo one already in progress"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"The effective solution"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"(1) Log every destructive action intent before execution\n(2) Insert clear approval checkpoint for any irreversible operation\n(3) Treat 'stop' as command to halt NEXT action, not undo one already in progress"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Defense Layers"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Layer"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Implementation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Allowlist"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Only process known senders (recommended)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Isolated session"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Review untrusted emails before acting"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. Untrusted markers"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Flag email content as untrusted input in prompts"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"4. Agent training"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"System prompts treat email requests as suggestions, not commands"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Allowlist Filter Example"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ~/.clawdbot/hooks/email-allowlist.ts\nconst ALLOWLIST = [\n  'you@personal.com',      // Your personal email\n  'trusted@service.com',   // Any trusted services\n];\n\nexport default function(payload: any) {\n  const from = payload.message?.from?.[0]?.email;\n  \n  // Block if no sender or not in allowlist\n  if (!from || !ALLOWLIST.includes(from.toLowerCase())) {\n    console.log(`[email-filter] ❌ Blocked email from: ${from || 'unknown'}`);\n    return null; // Drop webhook\n  }\n  \n  console.log(`[email-filter] ✅ Allowed email from: ${from}`);\n  return {\n    action: 'wake',\n    text: `📬 Email from ${from}:\\n\\n${payload.message.subject}\\n\\n${payload.message.text}`,\n    deliver: true,\n    channel: 'slack',\n    to: 'channel:YOUR_CHANNEL_ID'\n  };\n}"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Expected Behavior"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"When email arrives:\n1. Clawdbot reads email (subject + body)\n2. Classifies category (urgent, action required, feedback, spam)\n3. Adds triage label (Billing, Bug, Sales, Ops, etc.)\n4. Drafts response for human review\n5. Generates daily summary highlighting emails requiring attention\n6. Keeps everything in Inbox until resolved"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Workflow Best Practices"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Practice"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Why"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Keep emails in Inbox until resolved"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Don't delete/archives until action complete"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Read body, not just subject"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"More accurate classification (e.g., feedback emails that are actually billing)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Re-triage if categories wrong"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Review and re-classify as needed"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use allowlist for security"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Only process known senders"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Require approval for deletions"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Never auto-delete without confirmation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Draft, don't auto-send"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Human reviews and sends drafts"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of this pattern like "},{"type":"text","marks":[{"type":"bold"}],"text":"a smart mailroom assistant"},{"type":"text","text":": emails arrive at the door (inbox), the assistant (Clawdbot) sorts them into labeled bins (categories), writes draft replies for you to review, and gives you a daily summary of what needs attention. But the assistant never throws away anything without your approval — it's your inbox, not theirs."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Pattern: Email → Gmail Pub/Sub → Clawdbot → Classify + Draft Response → Zero Inbox"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Uses OpenClaw with Gmail Pub/Sub skills to read emails, draft responses, manage zero-inbox"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Classifies by sender, subject, content: urgent, action required, for reference, spam"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Label system: Billing / Cancellation / Bugs / Sales / Ops / Feedback / Enterprise / Demo / Security / Spam"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Read email body, not just subject"},{"type":"text","text":" — more accurate classification (found 31 misclassified emails)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Critical security"},{"type":"text","text":": Give Clawdbot its own dedicated inbox (AgentMail), separate from personal email"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Critical safety"},{"type":"text","text":": Irreversible actions need approval gate BEFORE execution, not stop after"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Compaction danger"},{"type":"text","text":": Large inboxes trigger compaction, which can lose original \"don't act\" instructions"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Defense layers: Allowlist trusted senders, isolated session for review, untrusted markers, agent training"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Benefits: Saved 4 hours of manual triage, daily summary for managers, keeps inbox organized"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Irreversible actions (delete, archive) must pass approval gate before they run — the blast-radius problem is architectural, not conversational. Always log destructive intent, get approval checkpoint, and treat 'stop' as halt next action only."}]}]}}
