ext","text":":"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Install Python SDK\npip install agentmail python-dotenv\n\n# Set environment variable\nexport AGENTMAIL_API_KEY=your_key_here"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Agent Layer: OpenClaw/Clawdbot"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Capabilities"},{"type":"text","text":":\n- Read emails via Gmail Pub/Sub skills\n- Classify by sender, subject, and content analysis\n- Generate daily morning summary for managers\n- Draft responses for human review\n- Manage zero-inbox through triggered actions"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Classification System"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Label categories used in practice"},{"type":"text","text":":"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Category"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Example"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Billing"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Payment issues, refunds"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cancellation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"c