{"format":"tiptap/v1","updatedAt":"2026-06-22T04:21:40.724Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Based on the official Claude API documentation and Anthropic's \"Building Effective AI Agents\" research, "},{"type":"text","marks":[{"type":"bold"}],"text":"\"Tools\""},{"type":"text","text":" are what "},{"type":"text","marks":[{"type":"bold"}],"text":"separate an agent from a chatbot"},{"type":"text","text":" — they enable Claude to interact with external services, APIs, and perform real actions in the world rather than just describing them."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","text":"Tools are "},{"type":"text","marks":[{"type":"bold"}],"text":"capabilities given to Claude via the Anthropic API"},{"type":"text","text":" that allow it to take actions: read/write files, execute commands, search the web, call APIs, query databases, and interact with third-party services."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Built-in Tools in Claude Managed Agents"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tool"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Name"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Description"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"bash"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Bash"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Execute bash commands in a shell session"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"read"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Read"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Read a file from the local filesystem"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"write"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Write"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Write a file to the local filesystem"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"edit"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Edit"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Perform string replacement in a file"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"glob"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Glob"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Fast file pattern matching using glob patterns"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"grep"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Grep"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Text search using regex patterns"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"web_fetch"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Web fetch"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Fetch content from a URL"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"web_search"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Web search"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Search the web for information"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How Tool Use Works"}]},{"type":"paragraph","content":[{"type":"text","text":"The tool call cycle follows a precise pattern:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"You define the tool"},{"type":"text","text":" — Specify what operations are available and what they return using JSON Schema"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Request is sent"},{"type":"text","text":" — Send user message with a "},{"type":"text","marks":[{"type":"code"}],"text":"tools"},{"type":"text","text":" array in the API request"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude responds with tool_use"},{"type":"text","text":" — If Claude plans to invoke a tool, it includes a "},{"type":"text","marks":[{"type":"code"}],"text":"tool_use"},{"type":"text","text":" block with:"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- Tool name - Unique "},{"type":"text","marks":[{"type":"code"}],"text":"id"},{"type":"text","text":" - Structured "},{"type":"text","marks":[{"type":"code"}],"text":"input"},{"type":"text","text":"\n4. "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"stop_reason: \"tool_use\""},{"type":"text","text":" — Response stops here, awaiting tool execution\n5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Your code executes the tool"},{"type":"text","text":" — The application/client runs the actual operation\n6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Result flows back"},{"type":"text","text":" — Send result as "},{"type":"text","marks":[{"type":"code"}],"text":"tool_result"},{"type":"text","text":" block with matching "},{"type":"text","marks":[{"type":"code"}],"text":"tool_use_id"},{"type":"text","text":"\n7. "},{"type":"text","marks":[{"type":"bold"}],"text":"Claude sees the result"},{"type":"text","text":" — Model uses the result to continue the task or decide next step"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Model → tool_use request → Client executes → tool_result back → Model reasons again"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Critical insight"},{"type":"text","text":": The model "},{"type":"text","marks":[{"type":"bold"}],"text":"never executes anything on its own"},{"type":"text","text":". It emits a structured request, your code runs the operation, and the result flows back into the conversation."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why Tools Matter"}]},{"type":"paragraph","content":[{"type":"text","text":"Tools are fundamental because:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Reason"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Explanation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Separate agent from chatbot"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tools enable Claude to take actions in the world rather than just describing them"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Enable external integrations"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tools represent the interface between the agentic system and external APIs, databases, services"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude selects tools autonomously"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Models can actively use capabilities—generating search queries, selecting appropriate tools, determining what to retain"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Support native tool use"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Claude's architecture supports structured tool invocation, interleaving tool use and reasoning as first-class"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Tool Definition Best Practices"}]},{"type":"paragraph","content":[{"type":"text","text":"Tool definitions should receive "},{"type":"text","marks":[{"type":"bold"}],"text":"as much prompt engineering attention as your overall prompts"},{"type":"text","text":":"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use JSON Schema format"},{"type":"text","text":" — Define input_schema with descriptions for parameters"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Include nested objects, arrays, optional fields"},{"type":"text","text":" — Make it resemble real-world tools"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Write clear descriptions"},{"type":"text","text":" — Help the reasoning layer understand when and how to use each tool"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Specify exact structure"},{"type":"text","text":" — Define the contract: what operations are available and what they return"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Custom Tools"}]},{"type":"paragraph","content":[{"type":"text","text":"In addition to built-in tools, you can define "},{"type":"text","marks":[{"type":"bold"}],"text":"custom tools"},{"type":"text","text":":"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Analogous to user-defined client tools"},{"type":"text","text":" in the Messages API"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Extend Claude's capabilities"},{"type":"text","text":" to perform wider variety of tasks"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Define the contract"},{"type":"text","text":" — You specify operations/returns; Claude determines when/how to call them"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Agent invokes through session"},{"type":"text","text":" — Once defined, the agent invokes tools across the session"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of tools as the "},{"type":"text","marks":[{"type":"bold"}],"text":"\"hands\" of the agent"},{"type":"text","text":" — the Model is the brain that decides what to do, but tools are what actually execute the work. Like giving a developer access to a terminal, file editor, and database: they can think (Model) and do (Tools)."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Tools enable Claude to interact with external services and APIs via JSON Schema definitions"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Tools separate agents from chatbots by enabling real actions, not just text responses"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"The model never executes tools itself — it emits requests; your code runs operations"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Claude supports native tool use with interleaved reasoning and tool calls as first-class capability"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Built-in tools include: bash, read, write, edit, glob, grep, web_fetch, web_search"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Custom tools extend capabilities beyond built-ins, defining contracts for operations"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Tool definitions deserve as much prompt engineering attention as overall prompts"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Loop terminates when "},{"type":"text","marks":[{"type":"code"}],"text":"stop_reason"},{"type":"text","text":" is not "},{"type":"text","marks":[{"type":"code"}],"text":"tool_use"},{"type":"text","text":" (e.g., "},{"type":"text","marks":[{"type":"code"}],"text":"end_turn"},{"type":"text","text":")"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Tools are one of the core augmentations (retrieval, tools, memory) that turn an LLM into an agentic system."}]}]}}
