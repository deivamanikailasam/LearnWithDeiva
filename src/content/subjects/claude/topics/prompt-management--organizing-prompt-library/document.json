":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Warnings"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Complete entry example:"}]},{"type":"codeBlock","attrs":{"language":"markdown"},"content":[{"type":"text","text":"# Email Newsletter Generator\n\n**Prompt:**\nWrite a {newsletter_type} email newsletter for {audience}.\nInclude:\n- 3 key highlights\n- 1 actionable tip\n- Link to read more\n\n**Tone:** {tone}\n**Length:** {word_count} words\n\n**Intended Use Case:**\nWeekly company updates, product launches, team announcements\n\n**Example Output:**\nSubject: 🚀 New Features This Week!\n\nHi Team,\nHere's what we shipped this week:\n1. Added dark mode to dashboard\n2. Improved API response time by 40%\n3. Launched mobile app beta\n\n💡 Actionable Tip: Try the new dark mode and share your feedback!\n\nRead more: [link]\n\n**Do's:**\n- Keep it concise (under 200 words)\n- Use emojis for visual interest\n- Include clear CTAs\n\n**Don'ts:**\n- Don't overload with too many updates\n- Don't use jargon without explanation\n- Don't forget to personalize"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Context Blocks (Separate Sections)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"These swappable sections provide important details like brand descriptions, tone guidelines, and audience characteristics.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Implementation:"}]},{"type":"codeBlock","attrs":{"language":"markdown"},"content":[{"type":"text","text":"# Prompt with Context Block\n\n**Prompt:**\nAnalyze this data using:\n{{CONTEXT_BLOCK}}\n\n**Instructions:**\n- Identify trends\n- Spot anomalies\n- Generate insights\n\n{{CONTEXT_BLOCK}} = [placeholder for context]\n\n---\n\n## Context Block Library (Separate Section)\n\n**Brand Description:**\nTech startup focused on AI automation for enterprises\n\n**Tone Guidelines:**\nProfessional but accessible, no jargon without explanation\n\n**Audience Characteristics:**\nTechnical managers, 1-5 years experience, decision-makers\n\n**Color-coding:** Use color to indicate where context block plugs in [web:444]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Reusable"},{"type":"text","text":" — Same context across multiple prompts\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Swappable"},{"type":"text","text":" — Change context without rewriting prompt\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Consistent"},{"type":"text","text":" — Standard brand/tone/audience"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prompt Playbooks (Multi-Step Tasks)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Tasks = Outcomes. Each entry represents a desired outcome, just like a to-do list item, and might include several steps or prompts within it.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Playbook structure:"}]},{"type":"codeBlock","attrs":{"language":"markdown"},"content":[{"type":"text","text":"# Marketing: Create Product Launch Campaign\n\n**Outcome:** Complete marketing campaign for new product\n\n**Steps:**\n1. **Research Phase**\n   - Prompt: \"Analyze target audience for {product_type}\"\n   - Prompt: \"Identify key competitors in {market}\"\n\n2. **Content Phase**\n   - Prompt: \"Write product description for {product_name}\"\n   - Prompt: \"Create social media posts for launch\"\n\n3. **Execution Phase**\n   - Prompt: \"Generate email sequence for launch\"\n   - Prompt: \"Design ad copy variations\"\n\n**Total Prompts:** 6\n**Estimated Time:** 2-3 hours\n**Complexity:** Advanced"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Outcome-based"},{"type":"text","text":" — Aligns with workflows\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Multi-step"},{"type":"text","text":" — Complete task, not single prompt\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Scalable"},{"type":"text","text":" — Scale best practices across team"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Storage Tools"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tool Comparison"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tool"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Best For"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Features"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Pros"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Cons"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Notion"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Teams, structured databa