 a strict "},{"type":"text","marks":[{"type":"bold"}],"text":"prefix hierarchy"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"tools → system → messages"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Invalidation rules:"},{"type":"text","text":"\n- Change "},{"type":"text","marks":[{"type":"bold"}],"text":"tools"},{"type":"text","text":" → invalidates entire cache (tools + system + messages)\n- Change "},{"type":"text","marks":[{"type":"bold"}],"text":"system"},{"type":"text","text":" → invalidates system + messages\n- Change "},{"type":"text","marks":[{"type":"bold"}],"text":"messages"},{"type":"text","text":" → invalidates only messages cache"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Practical Examples by Block Type"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Caching Tools"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"tools = [\n    {\n        \"name\": \"get_weather\",\n        \"description\": \"Get current weather\",\n        \"input_schema\": {...}\n    },\n    {\n        \"name\": \"search_web\",\n        \"description\": \"Search the web\",\n        \"input_schema\": {...},\n        \"cache_control\": {\"type\": \"ephemeral\"}  # ✅ Breakpoint on last tool\n    }\n]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Result:"},{"type":"text","text":" Caches entire tool-definitions prefix from first tool through the marked breakpoint."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Caching System Messages"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"response = client.messages.create(\n    model=\"claude-3-5-sonnet-20241022\",\n    system=[\n        {\n            \"type\": \"text\",\n            \"text\": \"You are a helpful assistant specializing in literature analysis.\",\n            \"cache_control\": {\"type\": \"ephemeral\"}  # ✅ Breakpoint on system\n        }\n    ],\n    messages=[\n        {\"role\": \"user\", \"content\": \"What is the title?\"}\n    ]\n)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why:"},{"type":"text","text":" System message is part of static prefix, reused across all conversation turns."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Caching Large Documents"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"response = client.messages.create(\n    model=\"claude-3-5-sonnet-20241022\",\n    messages=[\n        {\n            \"role\": \"user\",\n            \"content\": [\n                {\n                    \"type\": \"text\",\n                    \"text\": large_book_text,  # ✅ 100K+ token document\n                    \"cache_control\": {\"type\": \"ephemeral\"}\n                },\n                {\n                    \"type\": \"text\",\n                    \"text\": \"What is the title of this novel?\"\n                }\n            ]\n        }\n    ]\n)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Result:"},{"type":"text","text":" 100K-token document cached, reused across multiple queries."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Caching Images"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"response = client.messages.create(\n    model=\"claude-3-5-sonnet-20241022\",\n    messages=[\n        {\n            \"role\": \"user\",\n            \"content\": [\n                {\n                    \"type\": \"image\",\n                    \"source\": {...},\n                    \"cache_control\": {\"type\": \"ephemeral\"}  # ✅ Image content block\n                },\n                {\n                    \"type\": \"text\",\n                    \"text\": \"What objects are in this image?\"\n                }\n            ]\n        }\n    ]\n)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. Caching Tool Use & Results"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"messages = [\n    {\n        \"role\": \"user\",\n        \"content\": \"What's the weather in NYC?\"\n    },\n    {\n        \"role\": \"assistant\",\n        \"content\": [\n            {\n                \"type\": \"tool_use\",\n                \"id\": \"tool_1\",\n                \"name\": \"get_weather\",\n                \"input\": {\"city\": \"NYC\"},\n                \"cache_control\": {\"type\": \"ephemeral\"}  # ✅ Tool use block\n            }\n        ]\n    },\n    {\n        \"role\": \"user\",\n        \"content\": [\n            {\n                \"type\": \"tool_result\",\n                \"tool_use_id\": \"tool_1\",\n                \"content\": \"Weather: 22°C, sunny\",\n                \"cache_control\": {\"type\": \"ephemeral\"}  # ✅ Tool result block\n            }\n        ]\n    }\n]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Multi-Turn Breakpoint Strategy"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Optimal Placement for Each Block Type"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Block"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Placement"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Why"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colsp