,"content":[{"type":"text","text":"Multi-Document Workflow Example"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Upload multiple research papers\npapers = []\nfor paper_file in [\"paper1.pdf\", \"paper2.pdf\", \"paper3.pdf\"]:\n    uploaded = client.beta.files.upload(\n        file=(paper_file, open(paper_file, \"rb\"), \"application/pdf\")\n    )\n    papers.append(uploaded.id)\n\n# Ask cross-document questions\nresponse = client.beta.messages.create(\n    model=\"claude-opus-4-8\",\n    messages=[{\n        \"role\": \"user\",\n        \"content\": [\n            {\"type\": \"text\", \"text\": \"Compare the methodologies across all three papers\"},\n            {\"type\": \"document\", \"source\": {\"type\": \"file\", \"file_id\": papers[0]}},\n            {\"type\": \"document\", \"source\": {\"type\": \"file\", \"file_id\": papers [devpost](https://devpost.com/software/docuask-an-ai-powered-document-q-a-assistant)}},\n            {\"type\": \"document\", \"source\": {\"type\": \"file\", \"file_id\": papers [meteoraweb](https://meteoraweb.com/en/intelligenza-artificiale/claude-for-long-form-writing-and-document-analysis-a-practical-guide)}}\n        ]\n    }]\n)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Result:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Paper 1: Randomized controlled trial (n=500) [p. 45]\nPaper 2: Observational cohort study (n=1200) [p. 78]\nPaper 3: Meta-analysis of 15 studies [p. 12]\n\nKey differences:\n- Sample sizes vary significantly\n- Methodologies address different research questions\n- Paper 3 provides broader evidence base"}]},{"type":"paragraph"}]}}
