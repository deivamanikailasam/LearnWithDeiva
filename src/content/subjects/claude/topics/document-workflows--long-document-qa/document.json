bleCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multi-thousand pages"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PDF-specific limits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Max 100 pages"},{"type":"text","text":" for visual analysis (charts, diagrams, graphics)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Higher page count"},{"type":"text","text":" for text-only PDFs via extended context window\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"32 MB"},{"type":"text","text":" max request size (API)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Recommendation:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"We recommend not exceeding 80 pages per session for precise analysis.\""}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How Long Document Q&A Works"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Processing Pipeline"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"1. Upload PDF/DOCX/TXT → Claude extracts text + converts pages to images\n2. Claude reads entire document → Maintains full context in memory\n3. You ask question → Claude searches for relevant sections\n4. Claude retrieves answer → Sources from specific text locations\n5. Output with citations → Shows page numbers for verification"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key capabilities:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Advanced reasoning"},{"type":"text","text":" — summarize, synthesize, analyze with precision\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Integrated PDF support"},{"type":"text","text":" — no manual parsing needed\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Large context window"},{"type":"text","text":" — preserves document coherence"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Step-by-Step Workflow"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Upload the Document Right"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Web Interface:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"1. Open claude.ai\n2. Drag and drop file directly into chat\n3. OR click upload button → select document\n4. PDF, DOCX, TXT, images with text (OCR) accepted"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"API Method:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\n# Upload PDF\nuploaded = client.beta.files.upload(\n    file=(\n        \"research_paper.pdf\",\n        open(\"research_paper.pdf\", \"rb\"),\n        \"application/pdf\"\n    )\n)\n\n# Reference in Q&A\nresponse = client.beta.messages.create(\n    model=\"claude-opus-4-8\",\n    max_tokens=16000,\n    messages=[{\n        \"role\": \"user\",\n        \"content\": [\n            {\"type\": \"text\", \"text\": \"Summarize the methodology\"},\n            {\n                \"type\": \"document\",\n                \"source\": {\"type\": \"file\", \"file_id\": uploaded.id}\n            }\n        ]\n    }]\n)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"For very long documents (>100 pages):"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Beyond 100 pages, it's better to split into logical sections and process them separately.\""}]}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Split 500-page document into 5 × 100-page chunks\nchunks = split_pdf_into_chunks(\"paper.pdf\", chunk_size=100)\n\n# Upload each chunk\nfor i, chunk in enumerate(chunks):\n    uploaded = client.beta.files.upload(\n        file=(f\"chunk_{i}.pdf\", chunk, \"application/pdf\")\n    )\n    file_ids.append(uploaded.id)\n\n# Process all chunks together\nresponse = client.messages.create(\n    messages=[{\n        \"content\": [\n            {\"type\": \"text\", \"text\": \"Summarize the entire paper\"},\n            {\"type\": \"document\", \"source\": {\"type\": \"file\", \"file_id\": file_ids[0]}},\n            {\"type\": \"document\", \"source\": {\"type\": \"file\", \"file_id\": file_ids [devpost](https://devpost.com/software/docuask-an-ai-powered-document-q-a-assistant)}},\n            # ... all chunks\n        ]\n    }]\n)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Write a Structured Prompt for Analysis"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Essential elements:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"1. CONTEXT: What the document is and why you're analyzing it\n2. SPECIFIC TASK: What Claude must do (extract theses, find data, compare)\n3. OUTPUT FORMAT: Table, bullet list, flowing text, length"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example prompt:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"CONTEXT: This is a 200-page research paper on climate science\nTASK: Extract the 5 most important emerging trends with concrete examples\nOUTPUT: Bullet list with trend name, explanation, and example from paper"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Ask Specific Questions"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Question Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Example"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Summary"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"Provide a concise overall summary with key points from each section\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Specific data"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"What are the key findings, deadlines, action items, financial numbers?\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Detailed explanation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"Explain section 3.2 and clarify difficult concepts\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Comparison"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"Compare ideas in Chapter 2 vs Chapter 4\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Extraction"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"Extract all important quotes and their page numbers\""}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Complete summary prompt:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Read all sections and provide:\n1. A concise overall summary\n2. Key points from each major section/chapter\n3. Main arguments, insights, or findings\n4. Important data, patterns, or conclusions\n\nPresent output in clear headings and bullet points.\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Enable Citations for Verification"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Request citations:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Enable citations when requesting key insights to ensure traceable, source-based outputs.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Citation format:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"The methodology uses a randomized controlled trial design [p. 45].\nKey findings show 25% improvement in outcomes [pp. 78-82]."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits:"},{"type":"text","text":"\n- Shows exact page numbers\n- Enables source verification\n- Reduces hallucination risk"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. Iterate and Review"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Follow-up questions:"}]},