ext","text":"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Server Tools (Claude Executes)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Where Code Runs"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Examples"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Server tools"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Anthropic's infrastructure"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"web_search"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"code_execution"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"web_fetch"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"tool_search"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Behavior"},{"type":"text","text":": You see results directly without handling execution."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Built-in Tools (Agent SDK)"}]},{"type":"paragraph","content":[{"type":"text","text":"The Agent SDK includes built-in tools ready to use immediately:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tool"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Description"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Read"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Read files from filesystem"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Write"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Write files to filesystem"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Bash"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Execute shell commands"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"WebSearch"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Search the web for information"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Usage"},{"type":"text","text":": \"Built-in tools like Read, Write, Bash, and WebSearch are ready to use immediately — you just include them in "},{"type":"text","marks":[{"type":"code"}],"text":"allowed_tools"},{"type":"text","text":"\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How to Define Tools"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 1: Create JSON Schema"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Tool definition example\n{\n  name: \"create_greeting\",\n  description: \"Create a personalized greeting for a user\",\n  input_schema: {\n    type: \"object\",\n    properties: {\n      name: {\n        type: \"string\",\n        description: \"The user's name\"\n      }\n    },\n    required: [\"name\"]\n  }\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key properties"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"name"},{"type":"text","text":": Tool identifier\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"description"},{"type":"text","text":": What the tool does (Claude uses this to decide when to call)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"input_schema"},{"type":"text","text":": JSON schema for parameters"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 2: Add to Tool List"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Python: Include in allowed_tools\nagent = Agent(allowed_tools=[\"read\", \"write\", \"bash\", \"web_search\"])"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// TypeScript: Include in tool configuration\nconst agent = new Agent({\n  allowedTools: [\"read\", \"write\", \"bash\", \"web_search\"]\n});"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Essential Practices"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Write Effective Descriptions"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude uses tool descriptions to decide when to call"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Good description\n{\n  name: \"query_database\",\n  description: \"Query customer data from the database to retrieve order history, account status, and preferences\",\n  // ...\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why"},{"type":"text","text":": \"Claude decides when to call a tool when the request maps to that tool's described capability\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Add "},{"type":"text","marks":[{"type":"code"}],"text":"strict: true"},{"type":"text","text":" for Schema Validation"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"{\n  name: \"create_greeting\",\n  description: \"Create a personalized greeting\",\n  strict: true,  // Ensures tool calls match schema exactly\n  input_schema: { ... }\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Purpose"},{"type":"text","text":": \"Add "},{"type":"text","marks":[{"type":"code"}],"text":"strict: true"},{"type":"text","text":" to your tool definitions to ensure Claude's tool calls always match your schema exactly\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Control When Claude Calls Tools"}]},{"type":"paragraph","content":[{"type":"text","text":"Override Claude's default behavior through system prompts:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Instruction"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Effect"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"\"Use the tools to investigate before responding.\""}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Measurably increases tool use"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"\"Always call a tool first before responding.\""}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Pushes further (harder requirement)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"\"Use your judgment about whether to call a tool or respond directly.\""}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Keeps triggering behavior conservative"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Default behavior"},{"type":"text","text":": With "},{"type":"text","marks":[{"type":"code"}],"text":"tool_choice: {\"type\": \"auto\"}"},{"type":"text","text":", Claude decides on each turn whether to call a tool or respond directly."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Custom Tools via MCP"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Model Context Protocol (MCP)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Add tools beyond coding-related ones"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// MCP tools for non-coding purposes\n// Examples:\n// - Sending/reading emails\n// - Updating a CRM\n// - Calling APIs"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Process"},{"type":"text","text":": \"Develop new non-coding tools via the MCP (this is crucial)\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Tool Use Flow"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Complete Lifecycle"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"1. Define tools (JSON schema)\n    ↓\n2. Include in allowed_tools\n    ↓\n3. Claude receives user request\n    ↓\n4. Claude decides: tool or direct response?\n    ↓\n5a. Tool decision: Return tool_use block\n    ↓\n6. Your code executes tool\n    ↓\n7. Send back tool_result\n    ↓\n8. Claude continues with result\n5b. Direct response: Return text response"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Pricing"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Token Costs"}]},{"type":"paragraph","content":[{"type":"text","text":"Tool use tokens come from:\n- "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tools"},{"type":"text","marks":[{"type":"bold"}],"text":" parameter"},{"type":"text","text":": Tool names, descriptions, and schemas\n- "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_use"},{"type":"text","marks":[{"type":"bold"}],"text":" blocks"},{"type":"text","text":": In requests and responses\n- "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_result"},{"type":"text","marks":[{"type":"bold"}],"text":" blocks"},{"type":"text","text":": In requests"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Additional tokens"},{"type":"text","text":": \"The number of tool use tokens required for each model are listed below (excluding the additional tokens listed above)\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of defining tools like "},{"type":"text","marks":[{"type":"bold"}],"text":"writing a menu for a restaurant"},{"type":"text","text":": you describe what dishes (tools) are available, what ingredients they need (parameters), and what they produce (results). The customer (Claude) reads the menu, decides what they want based on their request (user's needs), orders the dish (tool_use), the kitchen prepares it (your code executes), and brings it back (tool_result). The menu description is critical — if it's vague, customers won't know what to order."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Tool definition = specifying JSON schemas describing what tools can do"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Claude decides when to call based on user request + tool description"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Two types: Client tools (you execute) vs Server tools (Claude executes)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Built-in tools: Read, Write, Bash, WebSearch — include in "},{"type":"text","marks":[{"type":"code"}],"text":"allowed_tools"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Custom tools via MCP: emails, CRM, APIs (non-coding purposes)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"JSON schema: name, description (critical!), input_schema"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Add "},{"type":"text","marks":[{"type":"code"}],"text":"strict: true"},{"type":"text","text":" to ensure tool calls match schema exactly"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"System prompts control tool use: \"Use tools to investigate\" increases tool use"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Default: "},{"type":"text","marks":[{"type":"code"}],"text":"tool_choice: {\"type\": \"auto\"}"},{"type":"text","text":" — Claude decides each turn"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Tool use tokens: tools parameter + tool_use blocks + tool_result blocks"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"\"You define tools as JSON schemas, Claude signals when it wants to call one, and your code executes the call and returns the result. The key is that Claude makes the decision about when to use tools based on the user's request and the tool's description\"."}]}]}}
