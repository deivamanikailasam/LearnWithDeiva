{
  "format": "tiptap/v1",
  "doc": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "text": "Structured concurrency is the property that every coroutine is a child of a scope, and a scope is cancelled only after all its children complete. For Claude streaming in Android, this means the network request, the token accumulation, and the UI update are all nested under " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "viewModelScope" },
          { "type": "text", "text": " — and cancelling that scope (when the ViewModel is cleared) automatically cancels the in-flight SSE connection. Getting this right requires understanding how " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "Job" },
          { "type": "text", "text": " references work, how " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "CancellationException" },
          { "type": "text", "text": " propagates, and when to use " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "withTimeout" },
          { "type": "text", "text": " vs cooperative cancellation points." }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Scope Hierarchy and Cancellation Chain" }]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Structured concurrency diagram: viewModelScope containing streamJob, cancellation propagation chain from User Stop through streamJob.cancel() → collect block → callbackFlow awaitClose → OkHttp SSE",
          "title": "Structured Concurrency for Cancellable Claude Calls"
        }
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "viewModelScope and ViewModel Lifecycle" }]
      },
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "marks": [{ "type": "code" }], "text": "viewModelScope" },
          { "type": "text", "text": " is a " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "CoroutineScope" },
          { "type": "text", "text": " backed by " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "SupervisorJob() + Dispatchers.Main.immediate" },
          { "type": "text", "text": ". It is created by the Jetpack " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "ViewModel" },
          { "type": "text", "text": " base class and cancelled when " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "ViewModel.onCleared()" },
          { "type": "text", "text": " is called — which happens when the Activity or Fragment is finished (not on rotation). This means:" }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "text": "Any coroutine launched in " },
                  { "type": "text", "marks": [{ "type": "code" }], "text": "viewModelScope" },
                  { "type": "text", "text": " is automatically cancelled when the user permanently navigates away. You do not need a custom " },
                  { "type": "text", "marks": [{ "type": "code" }], "text": "onCleared()" },
                  { "type": "text", "text": " override to cancel the stream." }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "text": "Rotation does NOT cancel the scope. The ViewModel survives configuration changes, so an in-progress Claude stream continues across rotation — the new Activity simply re-collects " },
                  { "type": "text", "marks": [{ "type": "code" }], "text": "uiState" },
                  { "type": "text", "text": " from the ViewModel's " },
                  { "type": "text", "marks": [{ "type": "code" }], "text": "StateFlow" },
                  { "type": "text", "text": "." }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "text": "The " },
                  { "type": "text", "marks": [{ "type": "code" }], "text": "SupervisorJob" },
                  { "type": "text", "text": " inside " },
                  { "type": "text", "marks": [{ "type": "code" }], "text": "viewModelScope" },
                  { "type": "text", "text": " means that if one coroutine fails with a non-cancellation exception, other coroutines in the scope are not cancelled. A failed streaming call does not kill a concurrent analytics coroutine." }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Tracking the Stream Job" }]
      },
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "text": "To allow manual cancellation (user presses Stop, or a new message is sent before the previous one finishes), store the returned " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "Job" },
          { "type": "text", "text": " from " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "launch { }" },
          { "type": "text", "text": " in a nullable field and cancel it before starting a new one:" }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "kotlin" },
        "content": [
          {
            "type": "text",
            "text": "class ChatViewModel(private val repository: ClaudeRepository) : ViewModel() {\n\n    private val _uiState = MutableStateFlow(ChatUiState())\n    val uiState: StateFlow<ChatUiState> = _uiState.asStateFlow()\n\n    private var streamJob: Job? = null  // tracks the active streaming coroutine\n\n    fun sendMessage(userText: String) {\n        // Cancel any in-flight stream before starting a new one\n        streamJob?.cancel()\n\n        val userMsg = Message.User(userText)\n        _uiState.update { it.copy(\n            messages = it.messages + userMsg,\n            streamingText = \"\",\n            isStreaming = true,\n            error = null\n        )}\n\n        streamJob = viewModelScope.launch {\n            repository.streamMessage(userText).collect { event ->\n                when (event) {\n                    is ClaudeStreamEvent.Token -> _uiState.update {\n                        it.copy(streamingText = it.streamingText + event.text)\n                    }\n                    is ClaudeStreamEvent.StreamEnd -> {\n                        _uiState.update { state ->\n                            val assistantMsg = Message.Assistant(state.streamingText)\n                            state.copy(\n                                messages = state.messages + assistantMsg,\n                                streamingText = \"\",\n                                isStreaming = false\n                            )\n                        }\n                    }\n                    is ClaudeStreamEvent.Error -> _uiState.update {\n                        it.copy(error = event.message, isStreaming = false)\n                    }\n                }\n            }\n        }\n    }\n\n    fun stopStreaming() {\n        streamJob?.cancel()\n        _uiState.update { it.copy(isStreaming = false) }\n    }\n}"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              { "type": "text", "marks": [{ "type": "bold" }], "text": "cancel() does not await completion." },
              { "type": "text", "text": " It schedules cancellation but the coroutine may still be executing its " },
              { "type": "text", "marks": [{ "type": "code" }], "text": "finally" },
              { "type": "text", "text": " blocks when the next coroutine starts. If teardown order matters, follow " },
              { "type": "text", "marks": [{ "type": "code" }], "text": "cancel()" },
              { "type": "text", "text": " with " },
              { "type": "text", "marks": [{ "type": "code" }], "text": "join()" },
              { "type": "text", "text": " inside a suspending function, or use " },
              { "type": "text", "marks": [{ "type": "code" }], "text": "cancelAndJoin()" },
              { "type": "text", "text": "." }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "How CancellationException Propagates" }]
      },
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "text": "When " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "streamJob.cancel()" },
          { "type": "text", "text": " is called, the coroutines runtime marks the " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "Job" },
          { "type": "text", "text": " as cancelling. The next time the coroutine reaches a suspension point — " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "emit()" },
          { "type": "text", "text": ", " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "delay()" },
          { "type": "text", "text": ", " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "yield()" },
          { "type": "text", "text": ", or any other suspending call — it throws " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "CancellationException" },
          { "type": "text", "text": ". This unwinds the coroutine stack, running all " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "finally" },
          { "type": "text", "text": " blocks along the way." }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "text": "In the Flow chain, " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "CancellationException" },
          { "type": "text", "text": " propagates through the collect operator into the " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "callbackFlow" },
          { "type": "text", "text": " body, which triggers " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "awaitClose" },
          { "type": "text", "text": ". The " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "awaitClose" },
          { "type": "text", "text": " lambda calls " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "eventSource.cancel()" },
          { "type": "text", "text": ", closing the OkHttp connection. " },
          { "type": "text", "marks": [{ "type": "bold" }], "text": "This is why " },
          { "type": "text", "marks": [{ "type": "code", "bold": true }], "text": "awaitClose" },
          { "type": "text", "marks": [{ "type": "bold" }], "text": " is mandatory" },
          { "type": "text", "text": " — it is the cleanup hook that runs on cancellation." }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "marks": [{ "type": "bold" }], "text": "Critical rule:" },
          { "type": "text", "text": " Never catch " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "CancellationException" },
          { "type": "text", "text": " and swallow it. A broad " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "catch (e: Exception) { log(e) }" },
          { "type": "text", "text": " that does not rethrow cancellation will prevent the coroutine from terminating, leaking the network connection:" }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "kotlin" },
        "content": [
          {
            "type": "text",
            "text": "// WRONG: swallows CancellationException — coroutine never terminates cleanly\nviewModelScope.launch {\n    try {\n        repository.streamMessage(text).collect { /* … */ }\n    } catch (e: Exception) {\n        // CancellationException extends Exception — this catches it too!\n        _uiState.update { it.copy(error = e.message) }  // spurious error shown to user\n    }\n}\n\n// CORRECT: rethrow cancellation; only handle real errors\nviewModelScope.launch {\n    try {\n        repository.streamMessage(text).collect { /* … */ }\n    } catch (e: CancellationException) {\n        throw e  // let the coroutine machinery finish its teardown\n    } catch (e: Exception) {\n        _uiState.update { it.copy(error = e.message, isStreaming = false) }\n    }\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Cooperative Cancellation Checkpoints" }]
      },
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "text": "All standard suspending functions (including " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "delay" },
          { "type": "text", "text": ", " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "emit" },
          { "type": "text", "text": ", " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "send" },
          { "type": "text", "text": ") are cancellation points. If your coroutine does CPU-heavy work in a tight loop without suspending — say, processing a large JSON batch before emitting — it must manually check for cancellation:" }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "kotlin" },
        "content": [
          {
            "type": "text",
            "text": "import kotlinx.coroutines.ensureActive\nimport kotlinx.coroutines.yield\nimport kotlinx.coroutines.isActive\n\n// Option 1: ensureActive() — throws CancellationException if Job is cancelled\nviewModelScope.launch {\n    for (chunk in largeChunks) {\n        ensureActive()  // cancellation check without yielding the thread\n        process(chunk)\n    }\n}\n\n// Option 2: yield() — checks cancellation AND lets other coroutines run\nviewModelScope.launch {\n    for (chunk in largeChunks) {\n        yield()  // cooperative suspend point + cancellation check\n        process(chunk)\n    }\n}\n\n// Option 3: isActive — for conditional logic, not recommended as sole guard\nviewModelScope.launch {\n    for (chunk in largeChunks) {\n        if (!isActive) return@launch  // exits without throwing — misses finally blocks!\n        process(chunk)\n    }\n}"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "text": "For Claude streaming, this is rarely needed: the Flow's " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "emit()" },
          { "type": "text", "text": " is itself a suspension point that checks cancellation on every token. Heavy post-processing in the " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "collect" },
          { "type": "text", "text": " block (Markdown parsing, database writes) should call " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "ensureActive()" },
          { "type": "text", "text": " at the start to make it responsive to cancellation." }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Timeout-Bounded Claude Requests" }]
      },
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "marks": [{ "type": "code" }], "text": "withTimeout" },
          { "type": "text", "text": " wraps a suspend block and throws " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "TimeoutCancellationException" },
          { "type": "text", "text": " (a subclass of " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "CancellationException" },
          { "type": "text", "text": ") if the block does not complete within the deadline. Use it to ensure Claude calls do not hang indefinitely if the server stalls after starting an SSE response:" }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "kotlin" },
        "content": [
          {
            "type": "text",
            "text": "streamJob = viewModelScope.launch {\n    try {\n        withTimeout(60_000L) {  // 60 seconds total budget\n            repository.streamMessage(text).collect { event ->\n                when (event) {\n                    is ClaudeStreamEvent.Token -> _uiState.update {\n                        it.copy(streamingText = it.streamingText + event.text)\n                    }\n                    is ClaudeStreamEvent.StreamEnd -> finaliseMessage()\n                    is ClaudeStreamEvent.Error -> _uiState.update {\n                        it.copy(error = event.message, isStreaming = false)\n                    }\n                }\n            }\n        }\n    } catch (e: TimeoutCancellationException) {\n        // Timed out — show partial response or an error\n        _uiState.update { it.copy(\n            error = \"Response timed out after 60 seconds\",\n            isStreaming = false\n        )}\n    } catch (e: CancellationException) {\n        throw e  // user cancelled — propagate\n    } catch (e: Exception) {\n        _uiState.update { it.copy(error = e.message, isStreaming = false) }\n    }\n}"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "marks": [{ "type": "code" }], "text": "withTimeoutOrNull" },
          { "type": "text", "text": " is the non-throwing alternative — it returns " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "null" },
          { "type": "text", "text": " on timeout instead of throwing. However, for long-running streams it is harder to differentiate normal completion from timeout in the return value. Prefer " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "withTimeout" },
          { "type": "text", "text": " and catch " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "TimeoutCancellationException" },
          { "type": "text", "text": " explicitly." }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "coroutineScope vs supervisorScope for Pre-flight Checks" }]
      },
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "text": "Sometimes you want to run a pre-flight check concurrently with starting the stream — for example, validate the context window budget or check a cached session token before the SSE connection is established. " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "supervisorScope" },
          { "type": "text", "text": " lets each child fail independently:" }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "kotlin" },
        "content": [
          {
            "type": "text",
            "text": "streamJob = viewModelScope.launch {\n    // supervisorScope: token check failure does NOT cancel the stream\n    supervisorScope {\n        val tokenCheck = async {\n            try {\n                repository.validateTokenBudget()\n            } catch (e: Exception) {\n                _uiState.update { it.copy(warning = \"Token budget low\") }\n                // does not throw — supervisorScope children are independent\n            }\n        }\n\n        val streamDeferred = async {\n            repository.streamMessage(text).collect { event ->\n                when (event) {\n                    is ClaudeStreamEvent.Token -> _uiState.update {\n                        it.copy(streamingText = it.streamingText + event.text)\n                    }\n                    is ClaudeStreamEvent.StreamEnd -> finaliseMessage()\n                    is ClaudeStreamEvent.Error -> _uiState.update {\n                        it.copy(error = event.message, isStreaming = false)\n                    }\n                }\n            }\n        }\n\n        // Token check runs concurrently with stream start.\n        // supervisorScope waits for both to complete (or fail).\n        tokenCheck.await()\n        streamDeferred.await()\n    }\n}"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "text": "With plain " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "coroutineScope { }" },
          { "type": "text", "text": " instead, an exception from " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "tokenCheck" },
          { "type": "text", "text": " would cancel " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "streamDeferred" },
          { "type": "text", "text": " as well — useful when the check is a hard prerequisite (bad auth token = abort), but wrong when the check is advisory." }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Resource Cleanup with finally" }]
      },
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "text": "Kotlin " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "finally" },
          { "type": "text", "text": " blocks run even when a coroutine is cancelled. This makes them the right place for cleanup that must happen regardless of outcome — resetting loading state, closing file handles, logging the end of a session:" }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "kotlin" },
        "content": [
          {
            "type": "text",
            "text": "streamJob = viewModelScope.launch {\n    try {\n        repository.streamMessage(text).collect { event ->\n            when (event) {\n                is ClaudeStreamEvent.Token -> /* accumulate */\n                is ClaudeStreamEvent.StreamEnd -> /* commit */\n                is ClaudeStreamEvent.Error -> /* set error */\n            }\n        }\n    } finally {\n        // Runs on normal completion, exception, AND cancellation\n        _uiState.update { it.copy(isStreaming = false) }\n        analyticsLogger.logStreamEnd(sessionId)  // non-suspending, safe here\n    }\n}"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              { "type": "text", "marks": [{ "type": "bold" }], "text": "Suspend calls in finally blocks:" },
              { "type": "text", "text": " A " },
              { "type": "text", "marks": [{ "type": "code" }], "text": "finally" },
              { "type": "text", "text": " block executing during cancellation runs in a context where the Job is already cancelled. Suspending functions called from it will immediately throw " },
              { "type": "text", "marks": [{ "type": "code" }], "text": "CancellationException" },
              { "type": "text", "text": " again. Wrap any cleanup suspend call with " },
              { "type": "text", "marks": [{ "type": "code" }], "text": "withContext(NonCancellable) { … }" },
              { "type": "text", "text": " to allow it to run to completion." }
            ]
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "kotlin" },
        "content": [
          {
            "type": "text",
            "text": "import kotlinx.coroutines.NonCancellable\nimport kotlinx.coroutines.withContext\n\nstreamJob = viewModelScope.launch {\n    try {\n        repository.streamMessage(text).collect { /* … */ }\n    } finally {\n        // NonCancellable lets this suspend call complete even during cancellation\n        withContext(NonCancellable) {\n            sessionRepository.savePartialResponse(sessionId, _uiState.value.streamingText)\n        }\n        _uiState.update { it.copy(isStreaming = false) }\n    }\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Testing Cancellation" }]
      },
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "text": "Use " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "runTest" },
          { "type": "text", "text": " from " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "kotlinx-coroutines-test" },
          { "type": "text", "text": " to verify that cancelling the stream job cleans up state correctly, and that a second " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "sendMessage()" },
          { "type": "text", "text": " call cancels the first:" }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "kotlin" },
        "content": [
          {
            "type": "text",
            "text": "import app.cash.turbine.test\nimport kotlinx.coroutines.ExperimentalCoroutinesApi\nimport kotlinx.coroutines.test.runTest\nimport kotlinx.coroutines.test.StandardTestDispatcher\n\n@OptIn(ExperimentalCoroutinesApi::class)\nclass ChatViewModelCancellationTest {\n\n    private val testDispatcher = StandardTestDispatcher()\n\n    @Test\n    fun `stopStreaming resets isStreaming to false`() = runTest(testDispatcher) {\n        val events = mutableListOf(\n            ClaudeStreamEvent.Token(\"Hello\"),\n            ClaudeStreamEvent.Token(\", world\")\n        )\n        val repository = FakeClaudeRepository(events)  // never emits StreamEnd\n        val viewModel = ChatViewModel(repository)\n\n        viewModel.uiState.test {\n            viewModel.sendMessage(\"Hi\")\n            testDispatcher.scheduler.advanceUntilIdle()\n\n            // Stop before StreamEnd\n            viewModel.stopStreaming()\n            testDispatcher.scheduler.advanceUntilIdle()\n\n            val finalState = awaitItem()\n            assertFalse(finalState.isStreaming)\n            cancelAndIgnoreRemainingEvents()\n        }\n    }\n\n    @Test\n    fun `second sendMessage cancels first stream`() = runTest(testDispatcher) {\n        val repository = FakeClaudeRepository(emptyList())  // infinite stream (no StreamEnd)\n        val viewModel = ChatViewModel(repository)\n\n        viewModel.sendMessage(\"First\")\n        testDispatcher.scheduler.advanceUntilIdle()\n        val firstJob = viewModel.streamJob  // expose for testing\n\n        viewModel.sendMessage(\"Second\")\n        testDispatcher.scheduler.advanceUntilIdle()\n\n        assertTrue(firstJob?.isCancelled == true)\n    }\n}"
          }
        ]
      },
      {
        "type": "heading",
