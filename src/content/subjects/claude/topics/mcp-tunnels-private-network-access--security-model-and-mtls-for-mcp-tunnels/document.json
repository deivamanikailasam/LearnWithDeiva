{"format":"tiptap/v1","updatedAt":"2026-06-22T10:54:11.055Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Security model and mTLS for MCP tunnels"},{"type":"text","text":" combines "},{"type":"text","marks":[{"type":"bold"}],"text":"outbound-only connectivity"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"bold"}],"text":"end-to-end encryption"},{"type":"text","text":", and "},{"type":"text","marks":[{"type":"bold"}],"text":"IP validation"},{"type":"text","text":" as the tunnel's transport security defaults, while "},{"type":"text","marks":[{"type":"bold"}],"text":"mTLS (mutual TLS)"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"bold"}],"text":"OAuth"},{"type":"text","text":" are layered on top for defense-in-depth. The tunnel itself provides encrypted transport (TLS to the edge, re-encrypted to the AI provider), but it's "},{"type":"text","marks":[{"type":"bold"}],"text":"not a complete access control solution"},{"type":"text","text":"вҖ”you must require OAuth on every MCP server and enforce client certificates via mTLS if you want to cryptographically verify both the client and server identities at every step."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Security model"}]},{"type":"paragraph","content":[{"type":"text","text":"The MCP tunnel architecture provides strong "},{"type":"text","marks":[{"type":"bold"}],"text":"transport security defaults"},{"type":"text","text":":"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Property"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"What it does"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Outbound-only connectivity"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No inbound firewall ports; firewall sees only normal outbound HTTPS traffic"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"End-to-end encryption"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"TLS to Cloudflare edge + re-encrypted transport to Anthropic/OpenAI"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"IP validation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Proxy's "},{"type":"text","marks":[{"type":"code"}],"text":"upstream.allowed_ips"},{"type":"text","text":" restricts MCP servers to smallest CIDR ranges (SSRF defense)"}]}]}]}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"tunnel-gateway вҶ’ Cloudflare Edge: TLS (Cloudflare-managed)\nCloudflare Edge вҶ’ Anthropic: Re-encrypted transport"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key security property"},{"type":"text","text":": The tunnel provides "},{"type":"text","marks":[{"type":"bold"}],"text":"transport authentication"},{"type":"text","text":" (who can connect through the tunnel), but not "},{"type":"text","marks":[{"type":"bold"}],"text":"data-layer authorization"},{"type":"text","text":" (what actions are allowed). You need OAuth on the MCP server for that."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"mTLS (mutual TLS)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"mTLS"},{"type":"text","text":" is "},{"type":"text","marks":[{"type":"bold"}],"text":"mutual authentication"},{"type":"text","text":" where both the client and server present certificates to prove their identities:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Standard TLS"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"mTLS"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Server proves identity to client"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Server proves identity to client"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Client does NOT prove identity"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Client ALSO proves identity to server"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"One-way authentication"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Two-way (mutual) authentication"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"[docs.progress](https://docs.progress.com/bundle/openedge-mcp-server/page/TLS-and-mTLS-for-secure-communication.html)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How mTLS works"},{"type":"text","text":":\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Organization acts as CA"},{"type":"text","text":": Creates a root certificate (self-signed).\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Client and server certificates"},{"type":"text","text":": Both signed by the root certificate.\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Mutual verification"},{"type":"text","text":": - Server verifies client's certificate (client must have valid private key). - Client verifies server's certificate (server must have valid private key).\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Both sides authenticate"},{"type":"text","text":": Using their public/private key pairs."}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ  Client (Claude agent via tunnel)                        в”Ӯ\nв”Ӯ  вҖў Has client certificate + private key                  в”Ӯ\nв”Ӯ  вҖў Presents certificate to server                        в”Ӯ\nв”Ӯ  вҖў Verifies server's certificate                         в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n         вҶ“\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ  Server (Private MCP server)                              в”Ӯ\nв”Ӯ  вҖў Has server certificate + private key                  в”Ӯ\nв”Ӯ  вҖў Presents certificate to client                        в”Ӯ\nв”Ӯ  вҖў Verifies client's certificate                         в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Cryptographic identity"},{"type":"text","text":": Both sides prove they're who they claim to be.\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Zero Trust"},{"type":"text","text":": No user/device/traffic trusted by default; all verified via certificates.\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Prevents fake servers"},{"type":"text","text":": Client refuses to send data if server certificate doesn't match.\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Prevents fake clients"},{"type":"text","text":": Server rejects connections without valid client certificate."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why mTLS matters for MCP tunnels"}]},{"type":"paragraph","content":[{"type":"text","text":"Without mTLS:\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Only server authenticated"},{"type":"text","text":": Client trusts the server, but server doesn't verify the client.\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Compromised tunnel"},{"type":"text","text":": If tunnel token is stolen, attacker can connect as any client.\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"No identity binding"},{"type":"text","text":": Can't cryptographically tie requests to specific identities."}]},{"type":"paragraph","content":[{"type":"text","text":"With mTLS:\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Both sides authenticated"},{"type":"text","text":": Client and server both prove identities.\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Identity binding"},{"type":"text","text":": Requests are tied to specific client certificates.\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Defense-in-depth"},{"type":"text","text":": Even if tunnel token is compromised, attacker needs client certificate."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best practices (from Anthropic docs)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Practice"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Why"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Require OAuth on every MCP server"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Defense-in-depth on top of tunnel's transport authentication; enables user-level authorization at data layer"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Enable SSO for your organization"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tunnels, federation rules, service accounts managed in Claude Console; enforces identity provider's session controls"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Restrict "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"upstream.allowed_ips"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use smallest CIDR ranges covering MCP servers; proxy's primary SSRF defense"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Monitor logs"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Alert on warnings, errors, unusual traffic patterns from tunnel stack"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rotate credentials regularly"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Rotate server certificate and tunnel token on schedule; immediately if compromise suspected"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Keep images updated"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Track new proxy releases; pin by SHA-256 digest"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Limit network reach"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Proxy/cloudflared only reach destinations in network requirements; use NetworkPolicy or host firewall"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Limit MCP server scope"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Each server exposes only tools/data required for its purpose"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Protect credentials at rest"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Apply secrets-management practices to private keys and tunnel tokens"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Responding to a suspected breach"}]},{"type":"paragraph","content":[{"type":"text","text":"If tunnel token, TLS keys, or proxy host is compromised:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Stop the tunnel stack"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Detach upstream MCP servers"},{"type":"text","text":": Remove from Managed Agent sessions; stop passing URLs in "},{"type":"text","marks":[{"type":"code"}],"text":"mcp_servers"},{"type":"text","text":" block"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Archive the tunnel"},{"type":"text","text":": Invalidates tunnel token and detaches domain (Console вҶ’ MCP tunnels вҶ’ Archive)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Contact Anthropic"},{"type":"text","text":": Report to support"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rotate downstream credentials"},{"type":"text","text":": Re-provision fresh tunnel; rotate OAuth tokens"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Review logs before restoring"},{"type":"text","text":": Inspect proxy, cloudflared, MCP server logs for compromise window"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"mTLS + OAuth combination"}]},{"type":"paragraph","content":[{"type":"text","text":"For "},{"type":"text","marks":[{"type":"bold"}],"text":"complete security"},{"type":"text","text":", combine "},{"type":"text","marks":[{"type":"bold"}],"text":"mTLS (transport)"},{"type":"text","text":" with "},{"type":"text","marks":[{"type":"bold"}],"text":"OAuth (data layer)"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ  Human Identity (Biscuit token)                          в”Ӯ\nв”Ӯ  вҖў Establishes who can access data (user authentication) в”Ӯ\nв”Ӯ  вҖў Extended with attenuation blocks (claims)             в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n         вҶ“\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ  System Identity (mTLS certificate)                      в”Ӯ\nв”Ӯ  вҖў Establishes where/how data can flow (system auth)     в”Ӯ\nв”Ӯ  вҖў Client certificate + server certificate verification  в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n         вҶ“\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ  Data Layer (OAuth)                                      в”Ӯ\nв”Ӯ  вҖў User-level authorization at data layer                в”Ӯ\nв”Ӯ  вҖў Row-Level Security (RLS) in PostgreSQL                в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key idea"},{"type":"text","text":": Human identity establishes "},{"type":"text","marks":[{"type":"bold"}],"text":"who"},{"type":"text","text":" is allowed to access data, but non-human identity establishes "},{"type":"text","marks":[{"type":"bold"}],"text":"where and how"},{"type":"text","text":" that data can safely flow. Without both, MCP security is incomplete."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"MCP tunnel security = "},{"type":"text","marks":[{"type":"bold"}],"text":"outbound-only + end-to-end encryption + IP validation"},{"type":"text","text":" (transport security)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"mTLS"},{"type":"text","text":" = "},{"type":"text","marks":[{"type":"bold"}],"text":"mutual authentication"},{"type":"text","text":" where both client and server present certificates"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"OAuth on MCP server"},{"type":"text","text":" = defense-in-depth for data-layer authorization (separate from tunnel)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Complete security"},{"type":"text","text":" = mTLS (transport identity) + OAuth (data authorization) + human identity (biscuit tokens)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Tunnel is "},{"type":"text","marks":[{"type":"bold"}],"text":"transport security, not access control"},{"type":"text","text":": You still need OAuth/scoped credentials on the MCP server itself."}]}]}]},{"type":"paragraph"}]}}
