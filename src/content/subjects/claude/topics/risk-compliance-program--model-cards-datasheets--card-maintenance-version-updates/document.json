        "content": [
          {
            "type": "text",
            "text": "Evaluation Suite for Version Validation"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Maintaining a stable evaluation suite that can be re-run on any Claude version is the technical foundation of card maintenance. The suite must be version-controlled alongside the system card so that evaluation methodology is consistent across updates:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# eval_suite.py — repeatable evaluation for model card Section 5\n\nimport anthropic, json, random, hashlib\nfrom dataclasses import dataclass\nfrom pathlib import Path\n\nclient = anthropic.Anthropic()\n\n@dataclass\nclass EvalCase:\n    id: str\n    prompt: str\n    expected_themes: list[str]    # topics that SHOULD appear in response\n    forbidden_themes: list[str]   # topics that must NOT appear\n\ndef evaluate_response(case: EvalCase, response: str) -> dict:\n    theme_present = [t for t in case.expected_themes if t.lower() in response.lower()]\n    theme_absent = [t for t in case.forbidden_themes if t.lower() in response.lower()]\n    return {\n        \"case_id\": case.id,\n        \"expected_found\": len(theme_present) == len(case.expected_themes),\n        \"forbidden_absent\": len(theme_absent) == 0,\n        \"pass\": (\n            len(theme_present) == len(case.expected_themes)\n            and len(theme_absent) == 0\n        ),\n        \"violations\": theme_absent,\n    }\n\ndef run_evaluation_suite(\n    system_prompt: str,\n    eval_cases: list[EvalCase],\n    model: str = \"claude-opus-4-8\",\n) -> dict:\n    results = []\n    for case in eval_cases:\n        resp = client.messages.create(\n            model=model,\n            max_tokens=512,\n            system=system_prompt,\n            messages=[{\"role\": \"user\", \"content\": case.prompt}],\n        )\n        result = evaluate_response(case, resp.content[0].text)\n        result[\"model\"] = resp.model\n        results.append(result)\n\n    passed = sum(1 for r in results if r[\"pass\"])\n    return {\n        \"model\": model,\n        \"total\": len(results),\n        \"passed\": passed,\n        \"accuracy\": round(passed / len(results), 4),\n        \"cases\": results,\n        \"suite_checksum\": hashlib.sha256(\n            json.dumps([c.__dict__ for c in eval_cases], sort_keys=True).encode()\n        ).hexdigest()[:16],\n    }\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Comparing Evaluation Results Across Versions"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Running the evaluation suite produces comparable results only if the test cases are identical across runs. Storing results in a structured format allows automated regression detection:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# compare_eval_results.py — detects regression between model versions\n\nimport json\nfrom pathlib import Path\n\ndef compare_eval_runs(old_path: str, new_path: str, threshold: float = 0.02) -> dict:\n    \"\"\"\n    Compares two evaluation runs and flags regressions.\n    A regression is a metric that dropped by more than `threshold`.\n    \"\"\"\n    old = json.loads(Path(old_path).read_text())\n    new = json.loads(Path(new_path).read_text())\n\n    if old[\"suite_checksum\"] != new[\"suite_checksum\"]:\n        return {\"error\": \"Suite checksums differ — results are not comparable\"}\n\n    delta = {\n        \"from_model\": old[\"model\"],\n        \"to_model\": new[\"model\"],\n        \"accuracy_delta\": round(new[\"accuracy\"] - old[\"accuracy\"], 4),\n        \"regression\": new[\"accuracy\"] < old[\"accuracy\"] - threshold,\n    }\n\n    # Find cases that newly fail\n    old_passing = {r[\"case_id\"] for r in old[\"cases\"] if r[\"pass\"]}\n    new_passing  = {r[\"case_id\"] for r in new[\"cases\"] if r[\"pass\"]}\n    delta[\"newly_failing_cases\"] = list(old_passing - new_passing)\n    delta[\"newly_passing_cases\"] = list(new_passing - old_passing)\n\n    if delta[\"regression\"]:\n        print(f\"REGRESSION DETECTED: accuracy dropped {delta['accuracy_delta']:+.4f}\")\n        print(f\"Newly failing cases: {delta['newly_failing_cases']}\")\n        print(\"Do NOT publish new model version to production without investigation.\")\n    else:\n        print(f\"No regression: accuracy delta {delta['accuracy_delta']:+.4f}\")\n    return delta\n"
          }
        ]
      },
