        "content": [
          {
            "type": "text",
            "text": "# system-card.yaml — change log (append-only; most recent first)\nchange_log:\n  - version: \"3.0\"\n    date: \"2026-06-30\"\n    changed_by: \"ml-ops@example.com\"\n    approved_by: \"cx-platform@example.com\"\n    model_change: \"claude-opus-4-7 → claude-opus-4-8\"\n    change_type: \"major\"\n    sections_updated: [1, 4, 5]\n    summary: >\n      Upgraded to claude-opus-4-8. Re-ran full evaluation suite (1,000 cases).\n      Accuracy improved from 94.2% to 96.1%. Hallucination rate unchanged at 0.3%.\n      Bias score unchanged at 0.04. Section 4 limitation L2 updated: new model\n      has improved date awareness but still lacks real-time product DB access.\n    customer_notification_required: false\n    regulatory_notification_required: false\n\n  - version: \"2.1\"\n    date: \"2026-03-15\"\n    changed_by: \"security@example.com\"\n    approved_by: \"cx-platform@example.com\"\n    model_change: null\n    change_type: \"system-prompt\"\n    sections_updated: [2, 4]\n    summary: >\n      Added injection-resistance instructions to system prompt following RT-001\n      red team finding. Section 4 updated to reflect RT-001 as mitigated.\n    customer_notification_required: false\n    regulatory_notification_required: false\n\n  - version: \"2.0\"\n    date: \"2026-01-15\"\n    changed_by: \"ml-ops@example.com\"\n    approved_by: \"cx-platform@example.com\"\n    model_change: \"claude-3-5-sonnet → claude-opus-4-7\"\n    change_type: \"major\"\n    sections_updated: [1, 4, 5, 6]\n    summary: >\n      Major version upgrade. Full re-evaluation conducted. Red team re-run.\n      Human oversight section 6 updated to reflect new agent UI review flow.\n    customer_notification_required: true\n    customer_notification_sent: \"2026-01-10\"\n    regulatory_notification_required: false\n"
          }
        ]
