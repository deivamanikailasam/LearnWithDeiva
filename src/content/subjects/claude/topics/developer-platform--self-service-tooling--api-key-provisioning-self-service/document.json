      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Provisioning API"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The self-service API is a thin FastAPI service deployed in the platform team's account. It authenticates callers via OIDC, validates the request tier, creates resources in Anthropic's Workspaces API, stores the key, and records the quota."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# provisioning/api.py\nimport os, secrets as pysecrets\nfrom fastapi import FastAPI, Depends, HTTPException\nfrom pydantic import BaseModel, Field\nfrom acme_auth.fastapi import get_current_user_claims\nimport anthropic, boto3\n\napp = FastAPI(title=\"Claude Provisioning Service\")\n\n_anthropic_admin = anthropic.Anthropic(api_key=os.environ[\"ANTHROPIC_ADMIN_KEY\"])\n_sm = boto3.client(\"secretsmanager\")\n_ddb = boto3.resource(\"dynamodb\").Table(os.environ[\"QUOTA_TABLE\"])\n\n\nclass ProvisionRequest(BaseModel):\n    service_name: str = Field(..., pattern=r\"^[a-z][a-z0-9-]{2,39}$\")\n    team_name: str\n    tier: str = Field(..., pattern=r\"^(sandbox|development|production|high-volume)$\")\n    justification: str = Field(\"\", max_length=500)\n\n\nTIER_BUDGETS = {\n    \"sandbox\":     500_000,\n    \"development\": 5_000_000,\n    \"production\":  50_000_000,\n    \"high-volume\": None,   # requires manual quota after approval\n}\n\nINSTANT_TIERS = {\"sandbox\", \"development\"}\n\n\n@app.post(\"/provision\")\nasync def provision(\n    req: ProvisionRequest,\n    claims: dict = Depends(get_current_user_claims),\n):\n    caller_email = claims[\"email\"]\n\n    # Idempotency: check if already provisioned\n    existing = _ddb.get_item(Key={\"service_name\": req.service_name})\n    if \"Item\" in existing:\n        raise HTTPException(400, f\"{req.service_name} is already provisioned\")\n\n    if req.tier not in INSTANT_TIERS:\n        # Requires approval — create a pending request and return\n        approval_id = _create_approval_request(req, caller_email)\n        return {\"status\": \"pending_approval\", \"approval_id\": approval_id}\n\n    # Instant provisioning\n    api_key = _create_api_key(req.service_name, req.team_name)\n    _store_secret(req.service_name, api_key)\n    _record_quota(req.service_name, req.team_name, TIER_BUDGETS[req.tier], caller_email)\n    _notify_caller(caller_email, req.service_name, req.tier)\n\n    return {\n        \"status\": \"provisioned\",\n        \"secret_name\": f\"claude/{req.service_name}/api-key\",\n        \"monthly_token_budget\": TIER_BUDGETS[req.tier],\n    }\n\n\ndef _create_api_key(service_name: str, team_name: str) -> str:\n    workspace = _anthropic_admin.beta.workspaces.create(\n        name=f\"{team_name}-{service_name}\",\n    )\n    key = _anthropic_admin.beta.api_keys.create(\n        workspace_id=workspace.id,\n        name=f\"{service_name}-key\",\n    )\n    return key.raw_key   # only available on creation\n\n\ndef _store_secret(service_name: str, api_key: str) -> None:\n    secret_name = f\"claude/{service_name}/api-key\"\n    _sm.create_secret(\n        Name=secret_name,\n        SecretString=f'{{\"ANTHROPIC_API_KEY\": \"{api_key}\"}}',\n        Tags=[{\"Key\": \"service\", \"Value\": service_name}],\n    )\n    # Enable automatic rotation every 90 days\n    _sm.rotate_secret(SecretId=secret_name, RotationRules={\"AutomaticallyAfterDays\": 90})\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "CLI Interface"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Developers who prefer a terminal workflow can use the platform CLI instead of the IDP portal. The CLI is distributed via the internal package registry as "
          },
          {
            "type": "text",
            "text": "acme-cli",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": "."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "bash"
        },
        "content": [
          {
            "type": "text",
            "text": "# Install once\npip install acme-cli --index-url https://pypi.internal.acme.com/simple/\n\n# Authenticate (opens browser OIDC flow)\nacme login\n\n# Request a sandbox API key for a new service\nacme claude provision \\\n  --service my-new-service \\\n  --team data-platform \\\n  --tier sandbox\n\n# Output:\n# ✓ Provisioning my-new-service (tier: sandbox)\n# ✓ Workspace created in Anthropic console\n# ✓ API key stored at: claude/my-new-service/api-key\n# ✓ Monthly token budget: 500,000 input tokens\n#\n# To use the key in your service:\n#   export ANTHROPIC_SECRET_NAME=claude/my-new-service/api-key\n#   from config.secrets import get_anthropic_key\n\n# Check current quota usage\nacme claude quota --service my-new-service\n\n# Request a production quota upgrade\nacme claude provision \\\n  --service my-new-service \\\n  --team data-platform \\\n  --tier production \\\n  --justification \"Launching invoice extractor to 5k customers in Q3\"\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Quota Enforcement"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The quota store records each service's monthly token budget and cumulative usage. The internal Claude SDK wrapper checks the quota before each call and rejects requests that would exceed it. Enforcement happens in the client — not at the API level — so there is no additional round-trip."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# quota/enforcer.py\nimport boto3, time\nfrom decimal import Decimal\n\n_ddb = boto3.resource(\"dynamodb\").Table(\"claude-quotas\")\n\n\ndef check_and_record(service_name: str, estimated_input_tokens: int) -> None:\n    \"\"\"Raise QuotaExceeded if the service would exceed its monthly budget.\"\"\"\n    now_month = time.strftime(\"%Y-%m\")\n    item = _ddb.get_item(Key={\"service_name\": service_name}).get(\"Item\", {})\n    budget = int(item.get(\"monthly_budget\", 0))\n    used = int(item.get(f\"used_{now_month}\", 0))\n    if used + estimated_input_tokens > budget:\n        raise QuotaExceeded(\n            f\"{service_name}: {used + estimated_input_tokens:,} would exceed \"\n            f\"monthly budget of {budget:,} tokens\"\n        )\n    # Atomic increment\n    _ddb.update_item(\n        Key={\"service_name\": service_name},\n        UpdateExpression=\"ADD #col :n\",\n        ExpressionAttributeNames={\"#col\": f\"used_{now_month}\"},\n        ExpressionAttributeValues={\":n\": Decimal(estimated_input_tokens)},\n    )\n\n\nclass QuotaExceeded(RuntimeError):\n    pass\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Key Rotation"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "API keys are rotated automatically every 90 days via AWS Secrets Manager's rotation mechanism. The rotation Lambda creates a new key in the Anthropic Workspaces API, updates the secret, and then deletes the old key after a 24-hour overlap window to allow in-flight requests to complete."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# rotation/lambda_handler.py — deployed by the platform team\nimport boto3, os, anthropic, json\n\n_sm = boto3.client(\"secretsmanager\")\n_anthropic_admin = anthropic.Anthropic(api_key=os.environ[\"ANTHROPIC_ADMIN_KEY\"])\n\n\ndef handler(event, context):\n    secret_id = event[\"SecretId\"]\n    step = event[\"Step\"]\n    token = event[\"ClientRequestToken\"]\n\n    if step == \"createSecret\":\n        # Create new key in the same workspace\n        current = json.loads(_sm.get_secret_value(SecretId=secret_id)[\"SecretString\"])\n        workspace_id = current[\"workspace_id\"]\n        new_key = _anthropic_admin.beta.api_keys.create(\n            workspace_id=workspace_id, name=\"rotated-key\"\n        )\n        _sm.put_secret_value(\n            SecretId=secret_id,\n            ClientRequestToken=token,\n            VersionStages=[\"AWSPENDING\"],\n            SecretString=json.dumps({\n                \"ANTHROPIC_API_KEY\": new_key.raw_key,\n                \"workspace_id\": workspace_id,\n                \"old_key_id\": current.get(\"key_id\"),\n            }),\n        )\n\n    elif step == \"finishSecret\":\n        _sm.update_secret_version_stage(\n            SecretId=secret_id,\n            VersionStage=\"AWSCURRENT\",\n            MoveToVersionId=token,\n        )\n\n    elif step == \"testSecret\":\n        # Validate new key works before finalising\n        pending = json.loads(_sm.get_secret_value(\n            SecretId=secret_id, VersionStage=\"AWSPENDING\")[\"SecretString\"])\n        client = anthropic.Anthropic(api_key=pending[\"ANTHROPIC_API_KEY\"])\n        client.messages.create(\n            model=\"claude-haiku-4-5-20251001\", max_tokens=1,\n            messages=[{\"role\": \"user\", \"content\": \"ping\"}])\n\n    elif step == \"setSecret\":\n        pass   # Secrets Manager handles version promotion\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Cost Visibility"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The IDP portal includes a per-service cost dashboard that shows token usage by day, model, and team. Data is populated by a nightly job that reads usage from Anthropic's usage API and writes it to the quota DynamoDB table."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# scripts/sync_usage.py — runs nightly\nimport anthropic, boto3, json\nfrom decimal import Decimal\n\n_anthropic_admin = anthropic.Anthropic(api_key=os.environ[\"ANTHROPIC_ADMIN_KEY\"])\n_ddb = boto3.resource(\"dynamodb\").Table(\"claude-quotas\")\n\n\ndef sync_daily_usage(date_str: str) -> None:\n    \"\"\"Pull usage from Anthropic Workspaces API and write to DynamoDB.\"\"\"\n    workspaces = list(_anthropic_admin.beta.workspaces.list())\n    for workspace in workspaces:\n        usage = _anthropic_admin.beta.usage.get(\n            workspace_id=workspace.id,\n            start_date=date_str,\n            end_date=date_str,\n        )\n        service_name = workspace.name.split(\"-\", 1)[-1]  # strip team prefix\n        _ddb.update_item(\n            Key={\"service_name\": service_name},\n            UpdateExpression=\"ADD #d :tokens SET last_sync = :ds\",\n            ExpressionAttributeNames={\"#d\": f\"daily_{date_str}\"},\n            ExpressionAttributeValues={\n                \":tokens\": Decimal(usage.total_input_tokens),\n                \":ds\": date_str,\n            },\n        )\n"
          }
        ]
      },
