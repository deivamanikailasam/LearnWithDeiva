{"format":"tiptap/v1","updatedAt":"2026-06-21T13:36:02.616Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prompt caching"},{"type":"text","text":" saves parts of your prompt so Claude doesn't have to reprocess them every API call. Instead of rebuilding the model's internal \"attention states\" (how words connect) from scratch each time, cached sections are reused—making responses "},{"type":"text","marks":[{"type":"bold"}],"text":"faster (>2x latency reduction)"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"bold"}],"text":"cheaper (up to 90% cost reduction)"},{"type":"text","text":"."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How It Works"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Without caching:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"API Call 1: Prompt → Build attention map → Response\nAPI Call 2: Same Prompt → Build attention map AGAIN → Response"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"With caching:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"API Call 1: Prompt → Build attention map → Cache stored → Response\nAPI Call 2: Same Prompt → Use cached map → Response (no recalculation)"}]},{"type":"paragraph","content":[{"type":"text","text":"The system checks if a cached version exists. If yes, it's reused. If not, the full prompt is processed and stored."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why It Matters"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Benefit"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null