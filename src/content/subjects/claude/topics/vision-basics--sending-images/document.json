{"format":"tiptap/v1","updatedAt":"2026-06-21T16:48:08.043Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"To send images to Claude in its vision capabilities, you "},{"type":"text","marks":[{"type":"bold"}],"text":"optionally include images inside the user message"},{"type":"text","text":" when sending a request to the API. Claude then analyzes those images to answer questions about their content, compare multiple images, count objects, extract text via OCR, or perform visual reasoning tasks."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What it is"}]},{"type":"paragraph","content":[{"type":"text","text":"\"Sending Images in Vision Basics\" is the foundational step in using Claude's vision capabilities. It refers to the process of attaching image files to your prompt/message so Claude can \"see\" and understand visual content."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why it matters"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Enables "},{"type":"text","marks":[{"type":"bold"}],"text":"visual understanding"},{"type":"text","text":" without manual text descriptions"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Powers use cases like document analysis, product recognition, UI bug diagnosis, chart interpretation, and code extraction from screenshots"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Allows Claude to handle "},{"type":"text","marks":[{"type":"bold"}],"text":"complex visual tasks"},{"type":"text","text":" that would be impossible with text alone"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How it works (API)"}]},{"type":"paragraph","content":[{"type":"text","text":"When using the Claude API:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Include images in the message"},{"type":"text","text":": Images are added as part of the user message payload alongside your text prompt"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Image format"},{"type":"text","text":": Upload images like you would normally (base64-encoded or via URL, depending on API implementation)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Token cost"},{"type":"text","text":": Each image consumes tokens—you're charged based on an equation that considers image size/dimensions"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Technical constraints"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Constraint"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Limit"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Max images per request"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Up to "},{"type":"text","marks":[{"type":"bold"}],"text":"100 images"},{"type":"text","text":" across all messages in a single request"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Size limits"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Individual image size, height, and width have limitations"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Token usage"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Images count toward your token budget"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How to send images (different interfaces)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude Code CLI (command-line):"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Alt + V shortcut"},{"type":"text","text":" (Windows): Paste clipboard screenshots directly\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Command + V"},{"type":"text","text":" (Mac): Paste from clipboard\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Drag and drop"},{"type":"text","text":": Drop local image files directly into the PowerShell/terminal window"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude Desktop/Web:"},{"type":"text","text":"\n- Drag and drop images into the prompt interface\n- Images appear with a preview before sending"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Best practices"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Place all images first"},{"type":"text","text":" in your message before text—Claude processes content sequentially, so giving it complete visual context upfront improves performance"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Be specific about what you want Claude to do: describe, compare, count, extract text, etc."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"For multi-image tasks, ensure images are logically ordered for the task"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example use case"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"User message:\n[Image: screenshot of CSS bug]\n\"Can you identify what's causing this layout issue and suggest a fix?\""}]},{"type":"paragraph","content":[{"type":"text","text":"Claude analyzes the screenshot, identifies the visual problem, and provides code corrections."}]}]}}
