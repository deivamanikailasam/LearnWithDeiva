ts Matter"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Token costs"},{"type":"text","text":": Claude's token usage depends primarily on "},{"type":"text","marks":[{"type":"bold"}],"text":"pixel size"},{"type":"text","text":" (not file size in bytes). Grayscale or converting to PNG can reduce token consumption."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Quality vs. accuracy"},{"type":"text","text":": - Images smaller than 1000×1000 may reduce analysis accuracy\n- Excessively large images (>8000×8000) won't work and must be downscaled\n- For OCR (text extraction), higher resolution is critical—characters need enough pixels to distinguish"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Format Selection Guidelines"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Case"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Recommended Format"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Screenshots, UI mocks"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PNG"},{"type":"text","text":" (lossless, clear text)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Photographs, photos"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"JPEG"},{"type":"text","text":" (good compression)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Charts, diagrams with text"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PNG"},{"type":"text","text":" (sharp edges)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Animated images"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"GIF"},{"type":"text","text":" (first frame only processed)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Web-based images"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"WebP"},{"type":"text","text":" (modern standard)"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Important Notes"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Animated GIFs"},{"type":"text","text":": Only the "},{"type":"text","marks":[{"type":"bold"}],"text":"first frame"},{"type":"text","text":" is processed"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Lossy formats"},{"type":"text","text":" (JPEG, GIF): Reducing file size may degrade quality and reduce vision accuracy"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Token calculation"},{"type":"text","text":": Based on pixel dimensions (height × width), not MB file size"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multiple images"},{"type":"text","text":": Each image in a multi-image request has a stricter 2000px limit per dimension"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example: Converting for Optimal Results"}]},{"type":"paragraph","content":[{"type":"text","text":"If you have a large PNG screenshot that's too big:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Convert to grayscale PNG to reduce tokens\n# Pixel count stays same, but file size decreases\nfrom PIL import Image\nimg = Image.open('screenshot.png')\ngrayscale = img.convert('L')  # Grayscale\ngrayscale.save('screenshot_gray.png')"}]},{"type":"paragraph","content":[{"type":"text","text":"This significantly decreases file size while maintaining OCR accuracy."}]}]}}
