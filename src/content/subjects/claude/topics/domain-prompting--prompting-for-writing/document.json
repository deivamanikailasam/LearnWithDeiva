{"format":"tiptap/v1","updatedAt":"2026-06-21T01:08:06.175Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prompting for writing"},{"type":"text","text":" requires specifying the genre, style, or tone; providing key elements like characters, setting, and conflict; setting constraints such as word count or specific requirements; and encouraging unique or unexpected elements."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Core Structure for Writing Prompts"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Essential Components"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Effective writing prompts contain key elements to guide the output:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Role and tone:"},{"type":"text","text":" Act as a specific type of writer\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Setting and characters:"},{"type":"text","text":" Provide minimal prompts for model to fill in\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Plot beats:"},{"type":"text","text":" Ask for structural elements\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Stylistic constraints:"},{"type":"text","text":" Word count, POV, sensory details\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Revision steps:"},{"type":"text","text":" Rewrite with more tension, provide alternatives"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key goals:"},{"type":"text","text":" Originality, voice consistency, emotional impact"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Role and Tone"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Role and tone: 'Act as a horror novelist.'\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"You are a professional travel blogger writing for a young adult audience.\nYour tone should be:\n- Enthusiastic and engaging\n- Personal and relatable\n- Informative but not overwhelming\n- Inspiring to readers who want to travel"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Common roles:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Novelist"},{"type":"text","text":" — Fiction, genre-specific\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Blogger"},{"type":"text","text":" — Informal, engaging\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Journalist"},{"type":"text","text":" — Objective, factual\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Copywriter"},{"type":"text","text":" — Persuasive, marketing\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Academic"},{"type":"text","text":" — Formal, analytical\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Editor"},{"type":"text","text":" — Critical, refining"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Genre, Style, and Audience"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Specify the genre, style, or tone\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Write an opening paragraph for a:\n- Genre: Young adult sci-fi novel\n- Setting: Colonized Mars\n- Focus: Protagonist's first day at Martian high school\n- Style: Descriptive, immersive, character-driven\n- Audience: Young adults (14-18 years)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key elements:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Genre"},{"type":"text","text":" — Fiction, non-fiction, sci-fi, mystery\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Style"},{"type":"text","text":" — Descriptive, minimal, lyrical, crisp\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Audience"},{"type":"text","text":" — Age range, expertise level"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. Setting and Characters"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Provide key elements (e.g., characters, setting, conflict)\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Characters:\n- Protagonist: Maya Chen, 16, Colombian-American, aspiring chef\n- Setting: Busy restaurant kitchen in Chicago, 2024\n- Conflict: Maya must prove herself to a ruthless head chef while hiding her family's financial struggles\n\nBackground:\n- Maya's family restaurant failed last year\n- She's working part-time at this upscale restaurant\n- Her dream is to become a professional chef"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key elements:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Characters"},{"type":"text","text":" — Names, backgrounds, motivations\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Setting"},{"type":"text","text":" — Location, time period, atmosphere\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Conflict"},{"type":"text","text":" — Problem, obstacle, tension"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"4. Plot Beats and Structure"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Plot beats: Ask for inciting incident, rising action, climax\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Write a short story with the following structure:\n1. Inciting incident: Maya accidentally burns a sauce during dinner service\n2. Rising action: Chef threatens to fire her; she must work extra shifts to make up for it\n3. Climax: Maya discovers a secret recipe that could save the restaurant\n4. Resolution: Chef recognizes her talent; she gets a full-time position"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Common structures:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"3-act"},{"type":"text","text":" — Setup, conflict, resolution\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"5-act"},{"type":"text","text":" — Exposition, rising, climax, falling, resolution\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Hero's journey"},{"type":"text","text":" — Departure, trials, return\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Inverted pyramid"},{"type":"text","text":" — Key info first, details follow"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"5. Stylistic Constraints"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Set constraints (e.g., word count, specific words to include)\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Constraints:\n- Word count: 500-700 words\n- Point of view: First person (Maya's perspective)\n- Include sensory details: smell of garlic, heat of the stove, sound of clattering plates\n- Include at least 3 metaphors or similes\n- No dialogue\n- End with a hopeful note"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Types:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Word count"},{"type":"text","text":" — Exact or range\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"POV"},{"type":"text","text":" — First, second, third\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Sentence length"},{"type":"text","text":" — Short, varied, complex\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Specific elements"},{"type":"text","text":" — Words, phrases, details"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"6. Revision Steps"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Revision steps: 'Then rewrite with more tension,' or 'Provide three alternative endings.'\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"After writing the initial draft:\n1. Rewrite with more tension and urgency\n2. Add more sensory details about the kitchen\n3. Provide three alternative endings\n4. Choose the best ending and explain why"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Iterative improvement"},{"type":"text","text":" — Refine over time\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Multiple options"},{"type":"text","text":" — Compare alternatives\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Critical thinking"},{"type":"text","text":" — Evaluate choices"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Writing Prompt Templates"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template 1: Blog Post"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"You are a professional tech blogger writing for startup founders.\n\nTask: Write a blog post about the importance of test-driven development.\n\nContext:\n- Audience: Startup founders, product managers\n- Tone: Professional but approachable\n- Style: Clear, actionable, data-backed\n\nRequirements:\n1. Word count: 800-1000 words\n2. Include an engaging headline\n3. Use the inverted pyramid structure (key point first)\n4. Include 3-5 practical tips\n5. Add a conclusion with a call-to-action\n6. Include 2-3 relevant statistics or examples\n7. Use subheadings for sections\n\nOutput: Complete blog post with headline, body, and conclusion."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template 2: Short Story"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"You are a literary fiction writer.\n\nTask: Write a short story about loss and redemption.\n\nCharacters:\n- Protagonist: Elias, 68, retired teacher\n- Setting: Small coastal town, Maine, winter\n- Conflict: Elias must confront his estranged daughter after his wife's death\n\nPlot beats:\n1. Inciting incident: Elias receives a letter from his daughter\n2. Rising action: He prepares to meet her; reflects on past mistakes\n3. Climax: The confrontation at the coffee shop\n4. Resolution: A tentative reconciliation begins\n\nConstraints:\n- Word count: 1,200-1,500 words\n- POV: Third person limited (Elias's perspective)\n- Include sensory details: smell of salt, cold wind, sound of church bells\n- Use metaphor or simile at least twice\n- End with hope, not despair"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template 3: Email"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"You are a professional copywriter.\n\nTask: Write a sales email promoting a new software product.\n\nProduct: \"TaskFlow\" - project management software for teams\nAudience: Small business owners (5-20 employees)\nTone: Professional but friendly\nStyle: Persuasive, benefit-focused\n\nRequirements:\n1. Subject line: Under 10 words, catchy, includes benefit\n2. Opening: State the problem (inefficient project management)\n3. Body: Introduce TaskFlow and 3 key benefits\n4. Call-to-action: Clear, specific, with link\n5. Length: 150-200 words\n6. Include 1-2 statistics or data points\n7. End with a personal touch\n\nOutput: Complete email with subject line and body."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template 4: Academic Essay"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"You are an academic researcher in environmental science.\n\nTask: Write an essay on climate change impacts on coastal cities.\n\nScope:\n- Date range: Research from 2015-2024\n- Geographic focus: Major coastal cities (NYC, Mumbai, Shanghai)\n- Subfield: Urban planning and adaptation strategies\n\nRequirements:\n1. Word count: 1,500-2,000 words\n2. Format: APA style with citations\n3. Include executive summary (100 words)\n4. Structure: Introduction, literature review, analysis, conclusion\n5. Include at least 8 citations from peer-reviewed sources\n6. Provide 3-5 actionable recommendations\n7. Use academic tone, avoid jargon\n\nOutput: Complete essay with citations and references."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template 5: Social Media Post"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"You are a social media strategist for a fitness brand.\n\nTask: Write a Instagram post promoting a new workout program.\n\nProduct: \"30-Day Summer Shred\" - home workout program\nAudience: Women 25-40, fitness beginners to intermediate\nTone: Energetic, encouraging, motivational\nStyle: Visual, emoji-friendly, shareable\n\nRequirements:\n1. Caption: 100-150 words\n2. Include 3-5 emojis (fitness-related)\n3. Include 1-2 hashtags (#SummerShred, #HomeWorkout)\n4. Use short, punchy sentences\n5. Include a call-to-action (link in bio)\n6. End with an encouraging quote\n7. Add 3-5 image suggestions for the post\n\nOutput: Complete caption with emojis and hashtags."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template 6: Creative Writing (Speculative)"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"You are a speculative fiction writer.\n\nTask: Write the opening scene for a sci-fi novel.\n\nSetting:\n- Year: 2147\n- Location: Orbital station \"Aether\"\n- Atmosphere: Tense, mysterious, high-stakes\n\nCharacters:\n- Protagonist: Dr. Aris Thorne, 42, xenobiologist\n- Situation: Aris discovers an unknown organism in the station's lab\n\nPlot structure:\n1. Opening: Aris enters the lab, notices anomaly\n2. Rising tension: Organism reacts to presence\n3. Climax: Organism communicates in unexpected way\n4. Ending: Aris realizes this changes everything\n\nConstraints:\n- Word count: 600-800 words\n- POV: First person (Aris)\n- Include sensory details: smell of sterile air, hum of machinery, cold metal\n- Use at least 2 metaphors\n- No dialogue\n- End with a revelation\n\nOutput: Opening scene with cliffhanger."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Advanced Techniques"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Technique 1: Show, Don't Tell (Examples)"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Providing examples of desired outputs can significantly improve the quality of LLM responses.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Write a product description for a coffee maker.\n\nExample 1 (good):\n\"Brew perfect coffee every morning with our precision temperature control. The aroma fills your kitchen as the rich, smooth coffee pours into your cup. Wake up to happiness.\"\n\nExample 2 (bad - avoid):\n\"This coffee maker is good. It makes coffee. You should buy it.\"\n\nNow write a product description following Example 1's style."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Pattern learning"},{"type":"text","text":" — Model internalizes\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Style consistency"},{"type":"text","text":" — Coherent output\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Quality improvement"},{"type":"text","text":" — Better results"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Technique 2: Chain-of-Thought for Storytelling"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"For complex writing tasks, ask the LLM to explain its approach first.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Before writing the story:\n1. Explain your character's motivation\n2. Describe the setting's atmosphere\n3. Outline the emotional arc\n4. Identify key themes\n\nThen write the story incorporating these elements."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Technique 3: Domain-Specific Vocabulary"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Integrate industry jargon and terminology into your prompts to guide the LLM towards domain-relevant knowledge.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"You are a medical journalist.\n\nWrite an article about a new cancer treatment.\n\nInclude medical terminology:\n- Chemotherapy\n- Tumor markers\n- Clinical trials\n- Adverse effects\n- Remission rates\n\nUse accessible language for general audience but maintain accuracy."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Technique 4: Prompt Chaining"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Break down complex tasks into smaller steps and chain prompts together.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example flow:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Step 1: Generate story outline\n→ Output: 3-act structure with key points\n\nStep 2: Write first draft\n→ Input: Outline from Step 1\n→ Output: Complete story\n\nStep 3: Edit for tone\n→ Input: Draft from Step 2\n→ Output: Refined version\n\nStep 4: Create title options\n→ Input: Refined story from Step 3\n→ Output: 5-7 title suggestions"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Technique 5: Interactive Refinement"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Engage in a dialogue with the LLM, refining your prompts based on its initial responses.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Process:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Generate"},{"type":"text","text":" — Initial draft\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Review"},{"type":"text","text":" — Identify issues\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Refine"},{"type":"text","text":" — Adjust prompt\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Repeat"},{"type":"text","text":" — Until satisfied"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Technique 6: Meta-Cognitive Scaffolding"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Combine patterns: Wrap domain prompts in chain-of-thought or meta-cognitive scaffolds for deeper reasoning.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Before writing, think through:\n1. Who is my audience and what do they care about?\n2. What is the key message I want to convey?\n3. What tone will resonate best?\n4. What structure will make this most compelling?\n\nThen write the piece incorporating these insights."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices for Writing Prompts"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Be Explicit and Specific"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Be explicit: The more you define role, format, and constraints, the less 'hallucination.'\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Do:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Define role"},{"type":"text","text":" — Writer type, expertise\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Specify format"},{"type":"text","text":" — Structure, length\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Set constraints"},{"type":"text","text":" — Word count, style"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Don't:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Vague"},{"type":"text","text":" — \"Write something\"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Ambiguous"},{"type":"text","text":" — \"Make it good\"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Missing"},{"type":"text","text":" — No audience/tone"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Use Examples"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Use examples: Few-shot examples in your domain help models internalize conventions.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Pattern recognition"},{"type":"text","text":" — Significantly improves\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Style consistency"},{"type":"text","text":" — Coherent output\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Quality"},{"type":"text","text":" — Better results"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. Iterate and Refine"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Iterate and refine: Test your prompt, review output, then tweak context or constraints.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Process:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Test"},{"type":"text","text":" — Generate first draft\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Review"},{"type":"text","text":" — Identify issues\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Tweak"},{"type":"text","text":" — Adjust context/constraints\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Repeat"},{"type":"text","text":" — Until satisfied"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"4. Provide Context"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Clarity and Specificity: Prompts should be clear, concise, and unambiguous. Provide sufficient context for the LLM to understand your request.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Include:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Background"},{"type":"text","text":" — Why writing this\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Audience"},{"type":"text","text":" — Who will read\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Purpose"},{"type":"text","text":" — What it achieves"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"5. Structure Input"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Input Formatting: Structure your input in a way that's easily digestible by the LLM. Use bullet points, headings, or code snippets as appropriate.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Format:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Bullet points"},{"type":"text","text":" — Clear requirements\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Headings"},{"type":"text","text":" — Organized sections\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Numbered lists"},{"type":"text","text":" — Process steps"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"6. Evaluate and Iterate"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Evaluation and Iteration: Continuously evaluate the quality of LLM outputs and refine your prompts based on feedback and desired outcomes.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Metrics:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Quality"},{"type":"text","text":" — Does it meet standards?\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Relevance"},{"type":"text","text":" — Is it on topic?\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Tone"},{"type":"text","text":" — Matches audience?"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"7. Specify Task Definition"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Task Definition: Explicitly state the desired task or output.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Examples:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Bad:"},{"type":"text","text":" \"Write about dogs\"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Good:"},{"type":"text","text":" \"Generate a 200-word factual description of Golden Retrievers\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"8. Combine Patterns"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Combine patterns: Wrap domain prompts in chain-of-thought or meta-cognitive scaffolds for deeper reasoning.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Techniques to combine:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Chain-of-thought"},{"type":"text","text":" — Step-by-step reasoning\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Meta-cognitive"},{"type":"text","text":" — Self-reflection\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Domain-specific"},{"type":"text","text":" — Industry vocabulary"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Summary"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prompting for writing"},{"type":"text","text":" requires genre, style, tone specification; key elements (characters, setting, conflict); constraints (word count, POV); and revision steps for originality, voice consistency, and emotional impact:"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key goals:"},{"type":"text","text":" Originality, voice consistency, emotional impact"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"6 essential components:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Role and tone"},{"type":"text","text":" — Writer type, voice\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Genre, style, audience"},{"type":"text","text":" — Type, format, readers\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Setting and characters"},{"type":"text","text":" — Location, personas, conflict\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Plot beats and structure"},{"type":"text","text":" — Narrative flow\n5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Stylistic constraints"},{"type":"text","text":" — Word count, POV, details\n6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Revision steps"},{"type":"text","text":" — Iterative improvement"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"6 writing prompt templates:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Blog post"},{"type":"text","text":" — Inverted pyramid, actionable tips\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Short story"},{"type":"text","text":" — Character-driven, atmospheric\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Email"},{"type":"text","text":" — Persuasive, benefit-focused\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Academic essay"},{"type":"text","text":" — APA citations, literature review\n5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Social media post"},{"type":"text","text":" — Emoji-friendly, shareable\n6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Creative writing (speculative)"},{"type":"text","text":" — Sci-fi, cliffhanger"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"6 advanced techniques:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Show, don't tell"},{"type":"text","text":" — Examples improve quality\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Chain-of-thought"},{"type":"text","text":" — Explain approach first\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Domain-specific vocabulary"},{"type":"text","text":" — Industry jargon\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Prompt chaining"},{"type":"text","text":" — Multi-step workflow\n5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Interactive refinement"},{"type":"text","text":" — Dialogue-based\n6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Meta-cognitive scaffolding"},{"type":"text","text":" — Self-reflection"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"7 best practices:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Be explicit and specific"},{"type":"text","text":" — Define role, format, constraints\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Use examples"},{"type":"text","text":" — Few-shot patterns\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Iterate and refine"},{"type":"text","text":" — Test, review, tweak\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Provide context"},{"type":"text","text":" — Background, audience, purpose\n5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Structure input"},{"type":"text","text":" — Bullets, headings, lists\n6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Evaluate and iterate"},{"type":"text","text":" — Continuous improvement\n7. "},{"type":"text","marks":[{"type":"bold"}],"text":"Specify task definition"},{"type":"text","text":" — Clear, unambiguous\n8. "},{"type":"text","marks":[{"type":"bold"}],"text":"Combine patterns"},{"type":"text","text":" — Chain-of-thought, meta-cognitive"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"By speaking the model's 'domain dialect,' you'll get answers that are precise, relevant, and immediately actionable no matter the field.\""}]}]}}
