":"Context size—not model selection—is the single largest determinant of your API bill"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Baseline Overhead Nobody Talks About"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Startup Token Consumption"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Fresh Claude Code session (before first prompt):\n  ├── System prompts:      ~2,000 tokens\n  ├── CLAUDE.md:           ~300 tokens\n  ├── Context files:       ~1,000 tokens\n  ├── MCP tool schemas:    ~4,000 tokens\n  ├── Loaded skills:       ~1,000 tokens\n  └── TOTAL:               8,000+ tokens  (62,000 in heavier setups)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Impact"},{"type":"text","text":": That's "},{"type":"text","marks":[{"type":"bold"}],"text":"6.2% of a 1M window"},{"type":"text","text":" spent before work begins"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Adaptive/Optimized Thinking Budget"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Extended Thinking Mechanics"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# When using extended thinking:\n# ┌──────────────────────────────────────────┐\n# │  max_tokens = 8,000 (total output budget) │\n# │  ├── thinking_tokens = 2,000 (adaptive)   │\n# │  └── response_tokens = 6,000               │\n# └──────────────────────────────────────────┘\n\n# Both counting toward context window:\ninput_tokens + thinking_tokens + response_tokens ≤ 200k/1M"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key points"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Thinking budget tokens"},{"type":"text","text":" are a subset of "},{"type":"text","marks":[{"type":"code"}],"text":"max_tokens"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Billed as output tokens"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Count toward rate limits"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"With adaptive thinking"},{"type":"text","text":", Claude dynamically decides allocation, so actual usage may vary per request"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Context Awareness: Claude 4.5's Real-Time Budget Tracking"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Claude knows:\ncontext_window_capacity = 200k or 1M tokens\ncurrent_usage = input_tokens + output_tokens\nremaining_budget = context_window_capacity - current_usage\n\n# After each tool call:\nremaining_budget = update_remaining_capacity()\n\n# Claude uses this to:\n- Pace itself on long tasks\n- Decide how much capacity remains for work\n- Dig deeper vs. wrap up\n- Navigate around limits (not just hit the wall)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Long-running agent sessions"},{"type":"text","text":": Sustained focus without unexpected truncation\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Multi-context-window workflows"},{"type":"text","text":": State transitions matter\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Complex tasks"},{"type":"text","text":": Careful token management"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Practical Budgeting Strategy"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Three-Phase Budget Allocation (Claude Code)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Phase"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Token Budget"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Activities"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Cost Profile"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Discovery"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"20–30%"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Read calls, Grep searches, Glob patterns"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"High input token cost"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Implementation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"40–50%"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Edit calls, Write operations, Bash commands"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Moderate token cost"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Verification"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"20–30%"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Test runs, build checks, linting"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Variable cost"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example Bug Fix Session (Target: 60K tokens)"}]},{"type":"codeBlock","attrs":{"language":"markdown"},"content":[{"type":"text","text":"# Session budget for focused bug fix\n# Total: 60,000 tokens (~$0.18 at Sonnet 4.6)\n\ndiscovery:\n  budget: 15,000 tokens (25%)\n  activities:\n    - Read failing test: ~1,500 tokens\n    - Read implementation file: ~2,000 tokens\n    - Read related types/interfaces: ~1,000 tokens\n    - Grep for usage patterns: ~500 tokens\n    - CLAUDE.md context: ~300 tokens\n  total_estimate: 5,300 tokens\n  remaining_buffer: 9,700 tokens\n\nimplementation:\n  budget: 30,000 tokens (50%)\n  activities:\n    - Analyze root cause: ~5,000 tokens\n    - Edit implementation file: ~1,500 tokens\n    - Update related files: ~3,000 tokens\n  total_estimate: 9,500 tokens\n\nverification:\n  budget: 15,000 tokens (25%)\n  activities:\n    - Run failing test: ~2,000 tokens\n    - Run full test suite: ~3,000 tokens\n    - Lint check: ~1,000 tokens\n  total_estimate: 6,000 tokens"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Budgeting can reduce total session costs by 30–50%"},{"type":"text","text":" by eliminating restarts and redundant discovery"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Input Dominates Total Cost Despite Lower Rate"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Output: 4–5× higher per token\nInput: 70–90% of total spend (due to volume)\n\nReason: Tool outputs (file reads, grep, test logs)\n        count as INPUT on the next turn"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Context Size Is Your Biggest Cost Lever"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"50K context:  $0.300 per request\n200K context: $1.050 per request\n500K context: $2.550 per request\n\n200× variance in input cost"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Don't Waste Budget on \"Be Concise\""}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Tell Claude to be concise\" → saves 5–10%\nManaging what enters context → saves 50–70%"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Budgeting Prevents Mid-Session Overflows"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Discovery consumes 80% of window\n→ No room for implementation\n→ Costly restarts and redundant discovery\n\nStructured budget → 30–50% cost reduction"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Quick Reference: Input vs Output"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Question"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Answer"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Are input and output separate budgets?"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No—unified buffer where both count toward same limit"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Which costs more per token?"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Output: 4–5× higher"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Which dominates total spend?"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Input: 70–90% of bill"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What's the biggest cost driver?"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Context size—not model choice"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Do thinking tokens count?"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Yes—billed as output, count toward rate limits"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How much does context growth cost?"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"200× variance from 5K to 1M tokens"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best savings strategy?"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Manage what enters context (not \"be concise\")"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Understanding input vs output budgeting is essential for managing costs, avoiding mid-session overflows, and optimizing your Claude usage efficiently."}]}]}}
