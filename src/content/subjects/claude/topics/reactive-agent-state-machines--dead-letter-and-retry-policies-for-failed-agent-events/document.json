{"format":"tiptap/v1","updatedAt":"2026-06-22T04:47:37.533Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Based on the official documentation and industry best practices for event-driven agent architectures, "},{"type":"text","marks":[{"type":"bold"}],"text":"\"Dead letter and retry policies for failed agent events\""},{"type":"text","text":" is the mechanism that "},{"type":"text","marks":[{"type":"bold"}],"text":"handles failures gracefully by retrying transient errors with backoff strategies, then moving permanently failed events to a Dead Letter Queue (DLQ) for inspection and manual recovery"},{"type":"text","text":" — preventing failed events from blocking the entire workflow."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","text":"The pattern combines "},{"type":"text","marks":[{"type":"bold"}],"text":"two complementary mechanisms"},{"type":"text","text":":"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Mechanism"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Purpose"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Retry Policy"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Automatically retry failed events with exponential backoff for transient failures"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Dead Letter Queue (DLQ)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Capture messages that fail after exhausting retries for later inspection"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Typical DLQ Flow"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"1. Consumer attempts to process message\n    ↓\n2. Processing fails (serialization error / validation error / downstream service unavailable)\n    ↓\n3. System retries according to configured retry policy (3-5 attempts with exponential backoff)\n    ↓\n4. After exhausting retries → route to DLQ\n    ↓\n5. Original consumer continues processing subsequent messages\n    ↓\n6. Operations teams investigate DLQ messages and determine remediation"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Retry Policies"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Types of Retry Policies"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Policy"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"How It Works"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"When to Use"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Backoff Retry"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Up to 3 retries; 10-20 seconds random interval between retries"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Minor transient failures"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Exponential Decay Retry"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Up to 176 retries; intervals: 1s → 2s → 4s → 8s →... → 512s (max)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Severe transient failures requiring many retries"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Total retry time"},{"type":"text","text":": 1 day maximum for exponential decay"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Configuration Example"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"# Symfony Messenger retry configuration\nframework:\n  messenger:\n    failure_transport: failed\n    transports:\n      async:\n        dsn: '%env(MESSENGER_TRANSPORT_DSN)%'\n        retry_strategy:\n          max_retries: 5          # Five retries\n          delay: 2000             # Start at 2 seconds\n          multiplier: 2           # Exponential: 2s → 4s → 8s → 16s → 32s\n          max_delay: 30000        # Cap at 30 seconds"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Result"},{"type":"text","text":": \"Five retries with exponential backoff handles most transient failures\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Failure Classification"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Retry (Transient Failures)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Failure Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Examples"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Strategy"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Transient"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Network timeouts, downstream service temporarily unavailable, rate limit exceeded"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Retry 3-5 times with exponential backoff before moving to DLQ"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Characteristics"},{"type":"text","text":":\n- Self-correcting (will likely succeed if retried)\n- Temporary condition\n- Not caused by invalid data"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When NOT to Retry (Persistent Failures)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Failure Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Examples"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Strategy"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Persistent"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Invalid JSON schema, malformed data, constraint violations, unsupported message version"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Route to DLQ immediately without retries"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Characteristics"},{"type":"text","text":":\n- Will not succeed on retry (same error)\n- Causes data corruption or financial loss if repeated\n- Requires manual intervention"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Error Handling Strategies"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Classify Failures → Apply Targeted Strategies"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"1. Implement failure classification:\n   Categorize agent failures into retryable and non-retryable types at the point of failure\n    ↓\n2. Configure retry with exponential backoff and full jitter:\n   Use failure-type-specific retry counts so strategy matches failure mode\n    ↓\n3. Enforce retry budgets through AgentCore Policy:\n   Cap retries within single agent execution + global circuit-breaker across concurrent executions\n    ↓\n4. Build self-healing workflows for common patterns:\n   Prompt refinement, tool substitution, context reconstruction as targeted recovery paths\n    ↓\n5. Log recovery actions for analysis:\n   Capture retry counts, strategies, and outcomes"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key principle"},{"type":"text","text":": \"Uniform retry wastes effort on non-retryable failures and creates thundering herds on transient ones. Classifying failures by type and applying targeted strategies keeps availability high without manual intervention\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Retry Strategies by Failure Type"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Failure Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Retry Count"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Strategy"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Transient errors"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aggressive retry"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Exponential backoff with full jitter"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rate limiting"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Conservative retry"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Longer intervals between retries"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Non-retryable"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No retry"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Fallback or escalation to human review"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Exponential Backoff with Jitter"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why Use Jitter"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Exponential backoff with full jitter spreads retry attempts across time, avoiding the thundering herd that fixed-interval retries produce during widespread failures\""},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fixed-interval vs. Jittered"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Fixed-interval (bad):\n  Retry 1: 2s → Retry 2: 4s → Retry 3: 8s\n  → All agents retry at same time = thundering herd\n\nFull jitter (good):\n  Retry 1: 1-3s → Retry 2: 2-6s → Retry 3: 4-12s\n  → Randomized delays prevent synchronized retries"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Implementation"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import random\nimport time\n\ndef exponential_backoff_with_jitter(attempt, base_delay=1, max_delay=30000):\n    \"\"\"Exponential backoff with full jitter\"\"\"\n    # Calculate exponential delay: base_delay * 2^attempt\n    delay = base_delay * (2 ** attempt)\n    \n    # Add full jitter: random delay between 0 and delay\n    jittered_delay = random.uniform(0, delay)\n    \n    # Cap at max_delay\n    actual_delay = min(jittered_delay, max_delay)\n    \n    time.sleep(actual_delay)\n    return actual_delay"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Retry Budgets & Circuit Breakers"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Two Levels of Budgeting"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Level 1: Per-invocation budget\n  - Use Amazon Bedrock AgentCore Policy to cap retries within single agent execution\n    ↓\nLevel 2: Global budget\n  - Shared circuit-breaker backed by low-latency store (DynamoDB/ElastiCache)\n  - Tracks cumulative retry counts across concurrent executions\n  - AgentCore Policy evaluates circuit-breaker state, rejecting new retries when exhausted"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Purpose"},{"type":"text","text":": \"Enforce retry budgets to help prevent retry storms during widespread failures\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Dead Letter Queue (DLQ)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"A Dead Letter Queue is a designated location where messages that cannot be processed successfully are sent for later inspection and handling"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Core idea"},{"type":"text","text":": When a message fails after defined retry attempts, move it to DLQ and continue processing other messages."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When Messages Go to DLQ"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Action"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Exhausted retries"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Message fails after max retries → route to DLQ"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Persistent failures"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Invalid schema/malformed data → route to DLQ immediately (no retries)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Configuration"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"DLQ enabled at task level (disabled by default)"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What Happens After DLQ"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"After message reaches DLQ:\n    ↓\n1. Identify failure cause:\n   Check task logs and raw message data in DLQ\n   Determine: downstream service error / invalid format / permission issue\n    ↓\n2. Resolve root cause:\n   Restore downstream service / correct message format / update permissions\n    ↓\n3. Reprocess message:\n   Consume from DLQ and resend to original target, or process through alternative path"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"State Machine Integration"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Adding Timeout/Dead-letter States"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Minimal blueprint for state machines:\n- Intake → Plan (30s timeout) → Act (tool calls; max 2 retries) → Verify (quality gate) →\n  - if pass → Complete\n  - if fail → Escalate (human-in-the-loop) or loop back to Plan with revised constraints\n- Any state → Timeout → Recover or Dead-letter with audit log"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key states"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Timeout"},{"type":"text","text":": Any state → Timeout → Recover or Dead-letter\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Dead-letter"},{"type":"text","text":": Capture failed events with audit log\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Escalate"},{"type":"text","text":": Human-in-the-loop for unrecoverable failures"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Implementation Checklist"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Retry Configuration"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Setting"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Recommended Value"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Max retries"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"3-5 for transient failures"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Initial delay"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"1-2 seconds"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multiplier"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"2 (exponential)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Max delay"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"30-60 seconds"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Jitter"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Full jitter (0 to delay)"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"DLQ Configuration"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Setting"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Recommended Value"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Enable DLQ"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"At task level (default: disabled)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fault tolerance"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Allow fault tolerance (event processing continues even if message fails after retries)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Retention"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Inspect and reprocess manually"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Best Practices"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Practice"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Why"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Design persistence to be idempotent"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Safe retries (upserts, unique keys)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Always set max retry limit"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Avoid infinite loops"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Store minimal retry state in context"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Track attempt count, correlation IDs"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Log recovery actions"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Analyze retry counts, strategies, outcomes"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of retry policies and DLQ like "},{"type":"text","marks":[{"type":"bold"}],"text":"a restaurant kitchen with a \"fix-it\" station and a \"trash\" bin"},{"type":"text","text":": when an order comes in (message), the cook tries to make it. If it fails (burnt), they might try again a few times with a short rest (exponential backoff with jitter). If it keeps failing, they throw it in the trash bin (DLQ) and open the next order (continue processing). The manager (operations team) later checks the trash bin to see what went wrong and fix the root cause."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Retry policy: automatically retry failed events with exponential backoff for transient failures"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"DLQ: capture messages that fail after exhausting retries for later inspection"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Retry types: Backoff (10-20s, 3 retries) vs Exponential decay (1s → 512s, 176 retries, 1 day max)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Transient failures: retry 3-5 times with exponential backoff; persistent failures: route to DLQ immediately"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Exponential backoff with full jitter spreads retry attempts across time, avoiding thundering herd\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Default retry config: 5 retries, 2s delay, 2x multiplier, 30s max delay"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"DLQ is disabled by default; enable at task level to capture failed messages"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"After DLQ: identify failure → resolve root cause → reprocess message"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"State machine states: Timeout → Recover or Dead-letter with audit log"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Two budget levels: per-invocation cap + global circuit-breaker across concurrent executions"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Design persistence idempotent (upserts, unique keys) so retries are safe"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Always set max retry limit to avoid infinite loops"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Log recovery actions: capture retry counts, strategies, outcomes"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Uniform retry wastes effort on non-retryable failures and creates thundering herds on transient ones; classifying failures by type and applying targeted strategies keeps availability high without manual intervention."}]}]}}
