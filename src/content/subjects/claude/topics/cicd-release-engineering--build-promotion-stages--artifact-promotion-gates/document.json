          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Rollback: When a Gate Fails Post-Deploy"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Rollback is the promotion of the previous artifact, not an undo of the current one. Because artifacts are immutable and every previous build has its own manifest, rollback is deterministic:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# scripts/rollback.py\n\"\"\"Roll back to the previously promoted artifact.\"\"\"\nimport json, pathlib, subprocess\n\nMANIFEST_HISTORY = pathlib.Path(\"manifests/\")   # one file per build, named by SHA\n\ndef get_previous_manifest(current_sha: str) -> dict | None:\n    \"\"\"Find the most recent manifest that is NOT the current build.\"\"\"\n    manifests = sorted(MANIFEST_HISTORY.glob(\"*.json\"), key=lambda p: p.stat().st_mtime)\n    for m in reversed(manifests):\n        data = json.loads(m.read_text())\n        if data.get(\"build_sha\") != current_sha and data.get(\"gates_passed\"):\n            return data\n    return None\n\ndef rollback_environment(env: str, kubeconfig: str, current_sha: str):\n    previous = get_previous_manifest(current_sha)\n    if not previous:\n        raise RuntimeError(\"No valid previous manifest found \u2014 cannot roll back\")\n\n    image = previous[\"image_digest\"]\n    print(f\"Rolling back {env} to {image[:30]}... (build {previous['build_sha'][:8]})\")\n\n    subprocess.run(\n        [\"kubectl\", \"set\", \"image\", f\"deployment/claude-app\", f\"app={image}\", \"-n\", env],\n        env={\"KUBECONFIG\": kubeconfig},\n        check=True,\n    )\n    subprocess.run(\n        [\"kubectl\", \"rollout\", \"status\", \"deployment/claude-app\", \"-n\", env, \"--timeout=120s\"],\n        env={\"KUBECONFIG\": kubeconfig},\n        check=True,\n    )\n    print(f\"Rollback complete. Previous prompt_hash: {previous['prompt_hash']}\")\n"
          }
        ]
      },
