{"format":"tiptap/v1","updatedAt":"2026-06-20T13:22:43.764Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"bold"}],"text":"output format"},{"type":"text","text":" (also called "},{"type":"text","marks":[{"type":"bold"}],"text":"output indicator"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"bold"}],"text":"output directive"},{"type":"text","text":") specifies the type, structure, length, and medium of the response you want the model to generate. It tells the model exactly how to present its answer."}]},{"type":"paragraph","content":[{"type":"text","text":"Without format specification, you rely on the AI's default choices, which may not match your needs. Explicit formatting removes ambiguity and ensures you get exactly the structure you need."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"What output format controls"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Structure Control"}]},{"type":"paragraph","content":[{"type":"text","text":"Specify how the content should be organized:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Use bullet points\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Numbered steps (1, 2, 3)\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Paragraph form\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Table format\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Code block for examples\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"H2 headings for sections\""}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Format your response as:\n- Bullet points starting with dashes (-)\n- Each under 20 words"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Data Formats"}]},{"type":"paragraph","content":[{"type":"text","text":"Specify technical data structures:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"JSON"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"{\"key\": \"value\"}"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"CSV"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"name,email,phone"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Markdown table"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"| Column 1 | Column 2 |"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"XML"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"<tag>content</tag>"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"YAML"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"key: value"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"HTML"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"<div>content</div>"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Return valid JSON only, no explanation:\n{\n  \"category\": \"<one_of: Billing | Bug | Feature | Other>\",\n  \"reason\": \"<short explanation>\"\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. List Formats"}]},{"type":"paragraph","content":[{"type":"text","text":"Specify list styles:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Bullet points\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Numbered list (1, 2, 3)\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Checklist with [] boxes\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"One-liner per point\""}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Provide the summary as a list of bullet points, each starting with a dash (-)."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"4. Length Control"}]},{"type":"paragraph","content":[{"type":"text","text":"Control how much the model writes:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Maximum 100 words\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Exactly 3 sentences\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Brief\" vs \"Comprehensive\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"One-liner\" vs \"Detailed explanation\""}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Write a 3-paragraph email.\nEach paragraph should be 2-3 sentences.\nTotal under 150 words."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"5. Style Control"}]},{"type":"paragraph","content":[{"type":"text","text":"Specify presentation style:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Plain text only\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Markdown formatting\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"No headers\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Include emojis\""}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Format: Markdown with H2 headings for sections and bullet points for lists."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"6. Tone and Format"}]},{"type":"paragraph","content":[{"type":"text","text":"Specify both style and structure:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Write in second person, present tense\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Plain language, no jargon\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Professional but friendly tone\""}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Write in second person, present tense.\nUse a friendly but professional tone."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Common output format patterns"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern 1: JSON format"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Respond in this exact JSON format:\n{\n  \"category\": \"<one_of: Billing | Bug | Feature | Other>\",\n  \"reason\": \"<short explanation>\",\n  \"confidence\": \"<high | medium | low>\"\n}\n\nDo not output markdown code blocks."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why it works:"},{"type":"text","text":" JSON is machine-readable and easy to parse programmatically. Many modern models have a specific \"JSON mode,\" but you can enforce this via prompting even in models that don't support it natively."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern 2: Bullet points"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Provide the summary as a list of bullet points, each starting with a dash (-).\nEach bullet should be under 20 words.\nMaximum 5 bullets."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why it works:"},{"type":"text","text":" Bullet points are concise and easy to read. They're great for summaries, lists, and step-by-step explanations."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern 3: Markdown table"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Format your response as a Markdown table with columns:\n| Feature | Category | Priority |\n|---------|----------|----------|\n| ...     | ...      | ...      |\n\nInclude at least 5 rows."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why it works:"},{"type":"text","text":" Markdown tables are the native language of LLMs and great for readability. Explicitly ask for headers, bolding, or tables."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern 4: Numbered steps"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Provide step-by-step instructions:\n1. First step\n2. Second step\n3. Third step\n\nEach step should be one sentence."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why it works:"},{"type":"text","text":" Numbered lists are perfect for processes, tutorials, and sequential instructions."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern 5: Explicit structure with headings"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Write an overview of climate change, formatted as a series of questions and answers.\nEach Q&A should be separated by a horizontal line.\n\nUse the format:\n## Question 1: What is climate change?\nAnswer: [your answer]\n\n---\n\n## Question 2: Why does it matter?\nAnswer: [your answer]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why it works:"},{"type":"text","text":" Explicit structure with specific headings provides a clear structure for the output."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern 6: SWOT analysis with custom format"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Provide a SWOT analysis for Tesla, Inc.\nUse the format:\nStrengths: [List strengths separated by commas]\nWeaknesses: [List weaknesses separated by commas]\nOpportunities: [List opportunities separated by commas]\nThreats: [List threats separated by commas]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why it works:"},{"type":"text","text":" Conditional instructions allow you to include or exclude types of data and specify separate segments marked in specific ways."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern 7: Issue report with severity"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"For each issue found, format your response as:\n- **Severity**: Critical / High / Medium / Low\n- **Location**: file:line\n- **Issue**: one sentence\n- **Fix**: one sentence"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why it works:"},{"type":"text","text":" This creates a structured, consistent format for technical reviews."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern 8: XML tags"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"All output parts should be enclosed in XML tags:\n<analysis>\nYour analysis here\n</analysis>\n\n<recommendation>\nYour recommendation here\n</recommendation>"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why it works:"},{"type":"text","text":" XML/HTML is useful for tagging parts of the response for easier parsing with Regex later."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best practices for output format"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Be explicit and specific"}]},{"type":"paragraph","content":[{"type":"text","text":"Don't say: \"Format it nicely.\""},{"type":"hardBreak"},{"type":"text","text":"Say: \"Return valid JSON with fields: category, reason, confidence. Do not output markdown code blocks.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why:"},{"type":"text","text":" Explicit formatting removes ambiguity and ensures you get exactly the structure you need."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Use delimiters"}]},{"type":"paragraph","content":[{"type":"text","text":"Clearly separate different parts of the prompt:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"\"\"\""},{"type":"text","text":" (Triple quotes)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"---"},{"type":"text","text":" (Triple dashes)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"<tag> </tag>"},{"type":"text","text":" (XML tags)"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"<output_format>\nReturn JSON with fields: { category, reason }\n</output_format>"}]},{"type":"paragraph","content":[{"type":"text","text":"Delimiters help the model distinguish between instructions, input data, and examples."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. Put formatting constraints in the system message"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best Practice:"},{"type":"text","text":" Put persistent rules, persona, and output formatting constraints in the System Message. Put the specific task input in the User Message."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"system\": \"You are a professional financial analyst. Always respond in 3 bullet points. Each under 25 words.\",\n  \"user\": \"Summarize the following Q3 earnings report: {{document_content}}\"\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"4. Copy the format, style, or tone of given text"}]},{"type":"paragraph","content":[{"type":"text","text":"This is called "},{"type":"text","marks":[{"type":"bold"}],"text":"\"style imitation\""},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"bold"}],"text":"\"style transfer.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Write a poem about nature, but format it using custom tags like:\n<line> for each line\n<stanza> for each stanza"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"5. Show, don't just tell"}]},{"type":"paragraph","content":[{"type":"text","text":"Provide a sample text for the model to mimic. This is often more effective than just describing the format."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Here's the format I want:\n\n{\n  \"name\": \"John Smith\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"555-1234\"\n}\n\nNow extract fields from this text:\n\"Reach out to Mike Brown at mike.b@email.com. Phone: 555-9012\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"6. Use conditional instructions"}]},{"type":"paragraph","content":[{"type":"text","text":"Specify optional sections or include/exclude types of data."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"If the category is \"Bug\", include a \"severity\" field.\nIf the category is \"Feature\", include a \"priority\" field.\nOtherwise, omit those fields."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output format examples in practice"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 1: Email classification"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Task: Label customer emails into one of four categories: Billing, Bug, Feature, or Other.\n\nOutput Format:\nReturn valid JSON only, no explanation:\n{\n  \"category\": \"<one_of: Billing | Bug | Feature | Other>\",\n  \"reason\": \"<short explanation, max 25 words>\"\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 2: Code review"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"For each issue found:\n- Format as a bullet point\n- Use this structure:\n  **Severity**: Critical / High / Medium / Low\n  **Location**: file:line\n  **Issue**: one sentence\n  **Fix**: one sentence\n\nMaximum 5 issues."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 3: Marketing ideas"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"List 5 ideas for starting a dog-walking business.\n\nFormat:\n- Bullet points starting with dashes (-)\n- Each under 20 words\n- No numbers\n- Plain text only, no markdown"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 4: Step-by-step guide"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Provide step-by-step instructions for setting up a PostgreSQL database.\n\nFormat:\n1. Numbered list (1, 2, 3...)\n2. Each step is one sentence\n3. Maximum 10 steps\n4. Use code blocks for commands"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Summary"}]},{"type":"paragraph","content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"bold"}],"text":"output format"},{"type":"text","text":" specifies exactly how the model should present its response. It controls:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":"left"},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":"left"},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it specifies"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":"left"},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Structure"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Organization style"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Bullet points, numbered steps, table"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Data format"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Technical structure"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"JSON, CSV, XML, Markdown table"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"List format"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"List style"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Bullets, numbered, checklist"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Length"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"How much to write"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"3 sentences\", \"max 100 words\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Style"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Presentation style"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Plain text, Markdown, emojis"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tone"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Writing style"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Second person, present tense"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best practices:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Be explicit and specific"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use delimiters to separate sections"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Put persistent constraints in system message"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Show examples (don't just tell)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use conditional instructions for flexibility"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Controlling output format explicitly ensures you get exactly the structure you need and removes ambiguity about how the model should respond."}]}]}}
