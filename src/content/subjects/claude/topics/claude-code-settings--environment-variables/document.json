{"format":"tiptap/v1","updatedAt":"2026-06-22T12:16:14.303Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Environment variables"},{"type":"text","text":" are runtime configuration values that live outside your code and let Claude Code know things like which account to use, which model to run, and how to connect to services. They are especially useful for secrets and deployment-specific settings because they keep sensitive values out of your source files.[]"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What they control"}]},{"type":"paragraph","content":[{"type":"text","text":"In Claude Code, environment variables commonly handle:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Authentication"},{"type":"text","text":", such as API keys and auth tokens.[]"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Model selection"},{"type":"text","text":", such as the default model or model aliases for different task types.[]"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cloud integrations"},{"type":"text","text":", such as alternative API endpoints or provider-specific access.[]"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Runtime behavior"},{"type":"text","text":", such as timeouts, telemetry, output limits, and shell-related settings.[]"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why they matter"}]},{"type":"paragraph","content":[{"type":"text","text":"They let you change Claude Code’s behavior without editing application code or rewriting settings files each time. That makes them ideal for:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Keeping secrets private."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Using different setups across laptops, CI, and production-like environments."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Switching providers or models quickly."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Tuning performance and safety settings per environment.[]"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How they are usually set"}]},{"type":"paragraph","content":[{"type":"text","text":"They can be defined in a few places:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Your shell session"},{"type":"text","text":" for a single terminal window."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"A shell profile"},{"type":"text","text":" for persistent personal settings."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"A project"},{"type":"text","marks":[{"type":"code"}],"text":".env"},{"type":"text","marks":[{"type":"bold"}],"text":" file"},{"type":"text","text":" for repository-specific configuration."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"A settings file’s "},{"type":"text","marks":[{"type":"code"}],"text":"env"},{"type":"text","marks":[{"type":"bold"}],"text":" section"},{"type":"text","text":" for Claude Code-managed configuration.[]"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"A useful mental model is that shell-level values are immediate, while project or settings-file values are shared and repeatable across sessions.[]"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common examples"}]},{"type":"paragraph","content":[{"type":"text","text":"Typical variables include:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"ANTHROPIC_API_KEY"},{"type":"text","text":" for API authentication.[]"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"ANTHROPIC_AUTH_TOKEN"},{"type":"text","text":" for bearer-token style auth.[]"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"ANTHROPIC_BASE_URL"},{"type":"text","text":" for custom endpoints or proxies.[]"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"ANTHROPIC_MODEL"},{"type":"text","text":" for the default model.[]"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"DISABLE_TELEMETRY"},{"type":"text","text":" for turning off telemetry.[]"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best practices"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Put secrets in environment variables, not in source code."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Prefer project-scoped configuration for repo-specific behavior."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use shell variables for temporary experiments."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Keep the model and auth settings explicit when working across multiple environments.[]"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of environment variables as "},{"type":"text","marks":[{"type":"bold"}],"text":"sticky notes for the runtime"},{"type":"text","text":": they tell Claude Code what to use and how to behave before it starts, without changing the code itself.[]"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Environment variables configure Claude Code at runtime.[]"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"They are commonly used for auth, models, endpoints, and timeouts.[]"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"They help keep secrets out of code and make setups portable.[]"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"They can be set in the shell,"},{"type":"text","marks":[{"type":"code"}],"text":".env"},{"type":"text","text":" files, or Claude Code settings.[]"}]}]}]},{"type":"paragraph"}]}}
