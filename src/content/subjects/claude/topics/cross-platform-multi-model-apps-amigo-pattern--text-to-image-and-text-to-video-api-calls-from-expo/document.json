    "content": [
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Text-to-Image and Text-to-Video API Calls from Expo"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Claude's text understanding can be combined with image and video generation APIs to build creative mobile apps. The pattern is a pipeline: Claude refines the user's vague idea into a detailed, model-optimized prompt; the image or video API generates the media; Expo's file-system and media libraries download and display it. Text-to-image results are synchronous (a URL arrives in seconds); text-to-video is asynchronous (a job ID arrives immediately, the video ready in minutes)."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Text-to-image pipeline: Claude enhances prompt \u2192 DALL\u00b7E generates \u2192 download to local URI \u2192 display/save. Text-to-video uses a polling loop until status is done.",
          "title": "Text-to-image and text-to-video pipeline in Expo"
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Part 1: Text-to-Image with DALL\u00b7E 3"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "DALL\u00b7E 3 is available through the OpenAI API and produces high-quality 1024\u00d71024 or 1792\u00d71024 images from a text prompt. The most effective mobile pattern is to use Claude to rewrite the user's short idea into a rich, descriptive DALL\u00b7E prompt before sending it to the image API."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Step 1: Enhance the Prompt with Claude"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import Anthropic from '@anthropic-ai/sdk';\n\nconst claude = new Anthropic({ apiKey: process.env.EXPO_PUBLIC_ANTHROPIC_KEY! });\n\nexport async function enhanceImagePrompt(userIdea: string): Promise<string> {\n  const msg = await claude.messages.create({\n    model: 'claude-opus-4-8',\n    max_tokens: 200,\n    system:\n      'You are a DALL\u00b7E prompt engineer. Rewrite the user idea into a ' +\n      'single rich descriptive sentence under 200 characters: vivid subject, ' +\n      'style, lighting, and mood. Output only the prompt, no explanation.',\n    messages: [{ role: 'user', content: userIdea }],\n  });\n  return msg.content[0].type === 'text' ? msg.content[0].text : userIdea;\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Step 2: Generate the Image"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import OpenAI from 'openai';\n\nconst openai = new OpenAI({ apiKey: process.env.EXPO_PUBLIC_OPENAI_KEY! });\n\nexport async function generateImage(prompt: string): Promise<string> {\n  const response = await openai.images.generate({\n    model: 'dall-e-3',\n    prompt,\n    n: 1,\n    size: '1024x1024',\n    quality: 'hd',\n    style: 'vivid',      // 'vivid' or 'natural'\n  });\n  const url = response.data[0].url;\n  if (!url) throw new Error('No image URL returned');\n  return url;   // HTTPS URL, valid for ~60 minutes\n}"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "marks": [
                  {
                    "type": "bold"
                  }
                ],
                "text": "URL expiry: "
              },
              {
                "type": "text",
                "text": "DALL\u00b7E 3 URLs expire after approximately 60 minutes. Download the image to the device immediately after generation. Do not store the URL in a database and expect to serve it later."
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Step 3: Download and Display"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Use "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "expo-file-system"
          },
          {
            "type": "text",
            "text": " to download the image to the device cache, then display it via "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "Image"
          },
          {
            "type": "text",
            "text": " with the local URI:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "bash"
        },
        "content": [
          {
            "type": "text",
            "text": "npx expo install expo-file-system expo-media-library"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import * as FileSystem from 'expo-file-system';\n\nexport async function downloadImage(remoteUrl: string): Promise<string> {\n  // Use a unique filename to avoid collisions\n  const filename = `dalle_${Date.now()}.png`;\n  const localUri = FileSystem.cacheDirectory + filename;\n\n  const result = await FileSystem.downloadAsync(remoteUrl, localUri);\n  if (result.status !== 200) {\n    throw new Error(`Download failed: ${result.status}`);\n  }\n  return result.uri;   // file:///...path/to/dalle_12345.png\n}"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "tsx"
        },
        "content": [
          {
            "type": "text",
            "text": "import { useState } from 'react';\nimport { View, TextInput, Pressable, Image, Text, ActivityIndicator, StyleSheet } from 'react-native';\nimport { enhanceImagePrompt } from './enhancePrompt';\nimport { generateImage } from './generateImage';\nimport { downloadImage } from './downloadImage';\n\nexport default function TextToImageScreen() {\n  const [idea, setIdea] = useState('');\n  const [localUri, setLocalUri] = useState<string | null>(null);\n  const [loading, setLoading] = useState(false);\n  const [phase, setPhase] = useState('');\n\n  async function handleGenerate() {\n    setLoading(true);\n    try {\n      setPhase('Enhancing prompt with Claude...');\n      const prompt = await enhanceImagePrompt(idea);\n\n      setPhase('Generating image with DALL\u00b7E 3...');\n      const remoteUrl = await generateImage(prompt);\n\n      setPhase('Downloading...');\n      const uri = await downloadImage(remoteUrl);\n      setLocalUri(uri);\n    } finally {\n      setLoading(false);\n      setPhase('');\n    }\n  }\n\n  return (\n    <View style={styles.container}>\n      <TextInput\n        style={styles.input}\n        value={idea}\n        onChangeText={setIdea}\n        placeholder=\"Describe an image idea...\"\n      />\n      <Pressable style={styles.button} onPress={handleGenerate} disabled={loading}>\n        <Text style={styles.buttonText}>{loading ? phase : 'Generate'}</Text>\n      </Pressable>\n      {loading && <ActivityIndicator size=\"large\" style={{ marginTop: 20 }} />}\n      {localUri && (\n        <Image source={{ uri: localUri }} style={styles.image} resizeMode=\"contain\" />\n      )}\n    </View>\n  );\n}\n\nconst styles = StyleSheet.create({\n  container: { flex: 1, padding: 20, backgroundColor: '#f9fafb' },\n  input: { borderWidth: 1, borderColor: '#d1d5db', borderRadius: 8, padding: 12, marginBottom: 12, fontSize: 15 },\n  button: { backgroundColor: '#6366f1', borderRadius: 8, padding: 14, alignItems: 'center' },\n  buttonText: { color: '#fff', fontWeight: '700', fontSize: 15 },\n  image: { width: '100%', aspectRatio: 1, marginTop: 20, borderRadius: 12 },\n});"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Saving to the Camera Roll"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import * as MediaLibrary from 'expo-media-library';\n\nexport async function saveImageToGallery(localUri: string): Promise<void> {\n  const { status } = await MediaLibrary.requestPermissionsAsync();\n  if (status !== 'granted') throw new Error('Media library permission denied');\n  await MediaLibrary.saveToLibraryAsync(localUri);\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Part 2: Text-to-Video with a Polling Pattern"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Video generation is compute-intensive and typically takes 30 seconds to several minutes. APIs like RunwayML, Kling, and (when available) Sora follow an async job pattern: you submit a generation request and get back a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "jobId"
          },
          {
            "type": "text",
            "text": ", then poll a status endpoint until the video is ready."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Polling Implementation"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "type VideoJobStatus = 'queued' | 'processing' | 'done' | 'error';\n\ninterface VideoJob {\n  jobId: string;\n  status: VideoJobStatus;\n  videoUrl?: string;\n  error?: string;\n}\n\n// Submit and poll \u2014 backend proxy forwards to RunwayML/Kling\nasync function generateVideo(\n  prompt: string,\n  onProgress: (status: VideoJobStatus) => void\n): Promise<string> {\n  // 1. Submit\n  const submitRes = await fetch('https://your-api.com/videos/generate', {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ prompt }),\n  });\n  const { jobId } = await submitRes.json() as { jobId: string };\n\n  // 2. Poll every 5 seconds\n  while (true) {\n    await new Promise(r => setTimeout(r, 5000));\n\n    const pollRes = await fetch(`https://your-api.com/videos/${jobId}`);\n    const job = await pollRes.json() as VideoJob;\n    onProgress(job.status);\n\n    if (job.status === 'done') {\n      if (!job.videoUrl) throw new Error('No video URL in done response');\n      return job.videoUrl;\n    }\n    if (job.status === 'error') {\n      throw new Error(job.error ?? 'Video generation failed');\n    }\n    // status === 'queued' | 'processing' \u2192 keep polling\n  }\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Displaying the Video with expo-av"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "bash"
        },
        "content": [
          {
            "type": "text",
            "text": "npx expo install expo-av"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "tsx"
        },
        "content": [
          {
            "type": "text",
            "text": "import { Video, ResizeMode } from 'expo-av';\nimport * as FileSystem from 'expo-file-system';\nimport { useState } from 'react';\nimport { View, Text, Pressable, ActivityIndicator } from 'react-native';\n\nexport default function TextToVideoScreen() {\n  const [localVideoUri, setLocalVideoUri] = useState<string | null>(null);\n  const [status, setStatus] = useState<string>('');\n  const [loading, setLoading] = useState(false);\n\n  async function handleGenerate(prompt: string) {\n    setLoading(true);\n    try {\n      const remoteUrl = await generateVideo(prompt, s => setStatus(s));\n\n      // Download to local cache\n      const localPath = FileSystem.cacheDirectory + `video_${Date.now()}.mp4`;\n      await FileSystem.downloadAsync(remoteUrl, localPath);\n      setLocalVideoUri(localPath);\n    } finally {\n      setLoading(false);\n    }\n  }\n\n  return (\n    <View style={{ flex: 1, padding: 20 }}>\n      <Pressable\n        onPress={() => handleGenerate('a time-lapse of clouds over mountains')}\n        style={{ backgroundColor: '#6366f1', padding: 14, borderRadius: 8, alignItems: 'center' }}\n      >\n        <Text style={{ color: '#fff', fontWeight: '700' }}>Generate Video</Text>\n      </Pressable>\n\n      {loading && (\n        <View style={{ alignItems: 'center', marginTop: 20 }}>\n          <ActivityIndicator />\n          <Text style={{ marginTop: 8, color: '#6b7280' }}>{status}</Text>\n        </View>\n      )}\n\n      {localVideoUri && (\n        <Video\n          source={{ uri: localVideoUri }}\n          style={{ width: '100%', aspectRatio: 16 / 9, marginTop: 20, borderRadius: 12 }}\n          resizeMode={ResizeMode.CONTAIN}\n          useNativeControls\n          shouldPlay\n          isLooping\n        />\n      )}\n    </View>\n  );\n}"
          }
        ]
      },
