            "type": "text",
            "text": "Sharing Generated Media"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import * as Sharing from 'expo-sharing';\n\nexport async function shareMedia(localUri: string): Promise<void> {\n  const available = await Sharing.isAvailableAsync();\n  if (!available) {\n    throw new Error('Sharing is not available on this device');\n  }\n  await Sharing.shareAsync(localUri, {\n    mimeType: localUri.endsWith('.mp4') ? 'video/mp4' : 'image/png',\n    dialogTitle: 'Share your AI creation',\n  });\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Expired image URLs. "
                  },
                  {
                    "type": "text",
                    "text": "DALL\u00b7E 3 URLs expire in ~60 minutes. Always call "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "FileSystem.downloadAsync()"
                  },
                  {
                    "type": "text",
                    "text": " immediately after generation. Never store the raw URL in a database."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "API keys in the mobile bundle. "
                  },
                  {
                    "type": "text",
                    "text": "Never call DALL\u00b7E or video generation APIs directly from the app. These keys are extractable from the JS bundle. Always proxy these calls through your backend."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Polling too aggressively. "
                  },
                  {
                    "type": "text",
                    "text": "Polling every second inflates API usage and drains battery. Use a 5-second interval and add exponential backoff after multiple failures. Stop polling after a timeout (e.g., 5 minutes) and surface an error."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "No cancellation on unmount. "
                  },
                  {
                    "type": "text",
                    "text": "If the user navigates away mid-poll, your "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "while(true)"
                  },
                  {
                    "type": "text",
                    "text": " loop keeps running and calls "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "setState"
                  },
                  {
                    "type": "text",
                    "text": " on an unmounted component. Use a "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "cancelled"
                  },
                  {
                    "type": "text",
                    "text": " flag in a "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "useEffect"
                  },
                  {
                    "type": "text",
                    "text": " cleanup to break out of the loop."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Content policy violations. "
                  },
                  {
                    "type": "text",
                    "text": "DALL\u00b7E and video APIs reject prompts violating content policies, returning a "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "400"
                  },
                  {
                    "type": "text",
                    "text": " error. Claude's prompt enhancement should sanitize inputs, but user creativity will still occasionally hit moderation. Catch the error and surface a clear message rather than a generic crash."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Use Claude to enhance vague user prompts into rich, model-optimized descriptions before sending to image or video APIs."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Text-to-image (DALL\u00b7E 3) is synchronous \u2014 the URL arrives in seconds. Download it immediately with "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "expo-file-system"
                  },
                  {
                    "type": "text",
                    "text": " before it expires."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Text-to-video is asynchronous \u2014 submit a job, receive a jobId, poll a status endpoint every 5 seconds until status is "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "'done'"
                  },
                  {
                    "type": "text",
                    "text": "."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Always proxy image and video generation APIs through your backend \u2014 never call them directly from the Expo app with embedded keys."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Use "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "expo-av"
                  },
                  {
                    "type": "text",
                    "text": " for video playback, "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "expo-media-library"
                  },
                  {
                    "type": "text",
                    "text": " to save to the camera roll, and "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "expo-sharing"
                  },
                  {
                    "type": "text",
                    "text": " to share via the native share sheet."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}