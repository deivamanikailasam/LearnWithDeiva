owspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Provide best result so far"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Short explanation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Explain budget was hit"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Offer cheaper mode"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"Draft-only\" mode as fallback"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Principle"},{"type":"text","text":": \"Fail safe and return partial result rather than crashing workflow\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Quick Start Plan (When Starting from Zero)"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Add per-run token cap + tool call cap"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Log cost per run, store with outcome"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Add routing"},{"type":"text","text":": small tasks → cheaper model, complex → stronger"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Put daily cap on each user"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Result"},{"type":"text","text":": Gain control quickly without gutting quality."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of Cost & Loop Control like "},{"type":"text","marks":[{"type":"bold"}],"text":"giving a junior intern a corporate card"},{"type":"text","text":": you wouldn't give them an unlimited credit card — you'd give them a prepaid card with a $50 limit, track usage, and require approval for anything over $10. Similarly, agents need bounded budgets, visible tracking, and hard limits."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Cost per task (not cost per call) is the unit that matters for agents"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Every agent run needs bounded budget: max steps, max tool calls, token/cost caps, time limits"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Set per-run token cap + tool call cap; log cost per run with outcome"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Define explicit exit conditions: success, failure, or timeout — every path must end predictably"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Set hard iteration limits: even smartest agent shouldn't think forever"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use loop detection: semantic similarity > 0.95 → trigger \"Reflect\" interrupt or terminate"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Route by complexity: small/repetitive → cheaper model, high-risk/complex → stronger model"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use ephemeral token budgets with hard caps (e.g., $5.00 max_spend) — API key \"dies\" when hit"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"When budgets hit: return partial output + explanation + offer cheaper \"draft-only\" mode"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Track: mean steps per run, aborted runs due to budgets, tool retry rates"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Alert on anomalies same day — runaway loop is same-day problem, not month-end"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use reserve-run-commit pattern with idempotency keys for safe retries"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Cost control is not about starving agent — it's about making spend predictable and tied to outcomes"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"The core question to ask: "},{"type":"text","marks":[{"type":"bold"}],"text":"\"What stops this from running forever?\""},{"type":"text","text":" If there's no clear answer, you don't have an AI system — you have an open cost center."}]}]}}
