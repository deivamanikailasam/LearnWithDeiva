{"format":"tiptap/v1","updatedAt":"2026-06-22T04:34:49.124Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Based on industry best practices for agent cost and loop control, "},{"type":"text","marks":[{"type":"bold"}],"text":"\"Cost & Loop Control\""},{"type":"text","text":" is the principle that "},{"type":"text","marks":[{"type":"bold"}],"text":"AI agent runs must be bounded with explicit budgets and termination criteria"},{"type":"text","text":" to prevent runaway costs from infinite loops, retries, and unbounded token usage."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","text":"Cost & Loop Control manages "},{"type":"text","marks":[{"type":"bold"}],"text":"cost per task"},{"type":"text","text":" (not cost per call) by implementing "},{"type":"text","marks":[{"type":"bold"}],"text":"budgets, iteration limits, and termination criteria"},{"type":"text","text":" that prevent agents from running indefinitely and burning through budgets."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Core Problem"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Issue"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"What Happens"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Infinite loops"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Agent thinks, acts, observes, repeats — but never stops"}]}]}