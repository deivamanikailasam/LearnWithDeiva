{"format":"tiptap/v1","updatedAt":"2026-06-20T07:02:51.970Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"bold"}],"text":"context window"},{"type":"text","text":" is the total amount of text (in tokens) that Claude can see and consider in a single request, including:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Your prompt"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Any uploaded text or files"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Previous conversation turns (if the system supports it)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"System instructions"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Implications"},{"type":"text","text":":"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Larger context windows let you:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Paste more code or documentation"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Include entire documents"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Maintain longer conversation histories"}]}]}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Different models (e.g., Haiku, Sonnet, Opus) and product tiers may have different context limits."}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"While exact numbers aren’t always emphasized in marketing pages, Anthropic’s models are known for supporting "},{"type":"text","marks":[{"type":"bold"}],"text":"long-form context"},{"type":"text","text":", which is a key differentiator compared to some other models."}]}]}}
