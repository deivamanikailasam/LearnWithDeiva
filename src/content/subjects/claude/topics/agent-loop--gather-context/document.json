{"format":"tiptap/v1","updatedAt":"2026-06-22T04:16:47.337Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Based on the official Claude Code documentation, "},{"type":"text","marks":[{"type":"bold"}],"text":"\"Gathering Context\""},{"type":"text","text":" is the "},{"type":"text","marks":[{"type":"bold"}],"text":"first phase of the agentic loop"},{"type":"text","text":" (also called \"The Agent Loop\") in Claude. Here's what it means:"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","text":"When you give Claude a task, it works through three phases: "},{"type":"text","marks":[{"type":"bold"}],"text":"gather context → take action → verify results"},{"type":"text","text":". \"Gathering Context\" is where Claude understands your task by retrieving relevant information before making changes."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Activities in This Phase"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Activity"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"What It Does"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use subagents"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Spawn parallel subagents for task efficiency to delegate work"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Compact/maintain context"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Summarize and compress message history to preserve critical details"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Agentic/semantic search"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Search files and codebases to retrieve relevant context for the task"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Read files"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Explore your project by reading multiple files to understand how components connect"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why It Matters"}]},{"type":"paragraph","content":[{"type":"text","text":"Gathering Context is essential because:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude sees your whole project"},{"type":"text","text":" — unlike inline assistants that only see the current file, Claude can search across your entire directory and subdirectories"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"It informs next steps"},{"type":"text","text":" — Each tool use during context gathering gives Claude new information that determines what action to take next"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Token efficiency"},{"type":"text","text":" — More context means lower quality code if you spend too many tokens per-loop; subagents help by returning summaries instead of bloating your main context"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of it like a developer debugging: before fixing code, you first "},{"type":"text","marks":[{"type":"bold"}],"text":"read the error output"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"bold"}],"text":"search for relevant files"},{"type":"text","text":", and "},{"type":"text","marks":[{"type":"bold"}],"text":"understand the codebase"},{"type":"text","text":". Claude does this autonomously using tools like file reading, search, and execution."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Gathering Context is phase 1 of Claude's 3-phase agentic loop"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Uses subagents, semantic search, and context compaction to retrieve relevant information"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"These phases blend together — Claude uses tools throughout all phases"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"The loop adapts based on what Claude learns from each previous step"}]}]}]},{"type":"paragraph"}]}}
