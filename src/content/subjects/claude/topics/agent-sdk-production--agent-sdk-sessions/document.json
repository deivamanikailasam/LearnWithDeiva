,"content":[{"type":"text","text":"Session ID"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Capture the session ID"},{"type":"text","text":" to resume later:"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// TypeScript: Session ID returned on ResultMessage\nconst result = await agent.query(prompt);\nconst sessionId = result.sessionId; // Save this ID"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Python"},{"type":"text","text":": Session ID returned on "},{"type":"text","marks":[{"type":"code"}],"text":"ResultMessage"},{"type":"text","text":" at end of run."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Resuming Sessions"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How to Resume"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// TypeScript: Use resume option with session ID\nconst result = await agent.query(prompt, {\n  resume: sessionId\n});"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Python: Use resume option with session ID\nresult = agent.query(prompt, resume=session_id)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What happens"},{"type":"text","text":": \"The SDK automatically handles loading the conversation history and context when you resume a session, allowing Claude to continue exactly where it left off\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Forking Sessions"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Create a new session from a resumed state"},{"type":"text","text":":"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Option"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Type"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"forkSession"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"TypeScript"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"fork_session"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Python"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Purpose"},{"type":"text","text":": \"Create a new session ID that starts from the resumed state\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Session Storage"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Built-in Implementation: InMemorySessionStore"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Default: InMemorySessionStore\nfrom claude_agent_sdk import Agent\n\nagent = Agent()  # Uses InMemorySessionStore by default"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Critical limitation"},{"type":"text","text":": \"The built-in implementation is "},{"type":"text","marks":[{"type":"code"}],"text":"InMemorySessionStore"},{"type":"text","text":". The SDK marks this explicitly as "},{"type":"text","marks":[{"type":"bold"}],"text":"not suitable for production"},{"type":"text","text":", because all session state is lost when the process exits\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Production Storage: SessionStore Protocol"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"For production deployments, implement the "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"SessionStore"},{"type":"text","marks":[{"type":"bold"}],"text":" protocol backed by persistent storage"},{"type":"text","text":"."}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Storage Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Description"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"File-based"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Store sessions in local files"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Redis"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"In-memory database with persistence"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PostgreSQL"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"SQL database for sessions"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"S3"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Cloud storage for sessions"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"[mem0](https://mem0.ai/blog/persistent-memory-for-claude-agents-sdk)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example implementations"},{"type":"text","text":": \"The SDK ships examples for file-based, Redis, PostgreSQL, and S3 stores\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Implementing SessionStore"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// TypeScript: Implement SessionStore interface\nimport { SessionStore, Session } from \"@anthropic-ai/claude-agent-sdk\";\n\nclass RedisSessionStore implements SessionStore {\n  async get(sessionId: string): Promise<Session | null> {\n    // Redis lookup\n    return await redis.get(sessionId);\n  }\n  \n  async set(sessionId: string, session: Session): Promise<void> {\n    // Redis save\n    await redis.set(sessionId, session);\n  }\n  \n  async delete(sessionId: string): Promise<void> {\n    // Redis delete\n    await redis.del(sessionId);\n  }\n}\n\n// Use with agent\nconst agent = new Agent({ sessionStore: new RedisSessionStore() });"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"State"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What Session State Is"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Session state is the agent's scratchpad during that interaction"},{"type":"text","text":"."}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Each session's state contains:\n- Key-value pairs\n- Values updated by agent throughout session\n- Files read, analysis performed, decisions reached"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key fact"},{"type":"text","text":": \"The agent has full context from everything that happened earlier in the same session: files it has read, analysis it has performed, decisions it has reached\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"State Properties"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Property Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Description"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key-value pairs"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"State properties are effectively key-value pairs"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Scoped buckets"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Properties organized into buckets (User state, Conversation state)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Read/write API"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Agent reads/writes through state management object"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"[learn.microsoft](https://learn.microsoft.com/en-us/microsoft-365/agents-sdk/state-concepts)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Differences"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Dimension"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Session State"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"User Context"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Persistence"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Within session only"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Across sessions (if implemented)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Keyed by"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Session ID"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"User identity"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Availability"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Lost when process exits (InMemory)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Persistent storage"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"[mem0](https://mem0.ai/blog/persistent-memory-for-claude-agents-sdk)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Critical limitation"},{"type":"text","text":": \"Session state is keyed by session ID, not by the person who triggered it. There is no user-identity layer in the SDK's session model\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Production Best Practices"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"State Management"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Python: Manage state properties\nfrom claude_agent_sdk import Agent\n\nagent = Agent()\n\n# Read state\nstate_value = agent.state.get(\"user_preference\")\n\n# Write state\nagent.state.set(\"user_preference\", \"dark_mode\")"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Session Continuity"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// TypeScript: Maintain session continuity\nconst sessionId = result.sessionId;\n\n// Next interaction\nconst nextResult = await agent.query(prompt, { resume: sessionId });"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key"},{"type":"text","text":": \"The agent SDK manages session state for you, so keeping track of the session identifier is all that's necessary to continue an existing session\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"State Persistence"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"For production-grade agents, store session data outside the agent's runtime"},{"type":"text","text":"."}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Python: Use DatabaseSessionService\nfrom google.adk import SessionService\n\nsession_service = DatabaseSessionService(\n    database_uri=\"postgresql://user:password@localhost/db\"\n)"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Session State vs Memory"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Two Types of Context"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Description"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Availability"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Session state"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Short-term scratchpad within session"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Within session only"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Long-term memory"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Persistent context across sessions"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Across sessions (requires external implementation)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key insight"},{"type":"text","text":": \"The Claude Agents SDK tracks session state but not user context across sessions\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Adding Persistent Memory"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it does NOT include"},{"type":"text","text":": \"A mechanism for building user-specific context that persists and grows across sessions\"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Solution"},{"type":"text","text":": Use external memory systems like Mem0 to add persistent, per-user memory."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of sessions like "},{"type":"text","marks":[{"type":"bold"}],"text":"phone calls"},{"type":"text","text":": each session is a single phone call with the agent. The session ID is the call number. When you hang up (end session), you can call back later using the same call number (resume), and the agent will remember everything from that previous call. Session state is like a scratchpad the agent uses during the call — notes, decisions, files opened. But once the call ends, the scratchpad is cleared (unless you use persistent storage). Long-term memory is like writing notes in a permanent notebook that persists across all calls."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Session = agent instance maintaining conversation history across multiple interactions"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Session ID returned on ResultMessage: capture it to resume later"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Resume: use "},{"type":"text","marks":[{"type":"code"}],"text":"resume"},{"type":"text","text":" option (Python/TypeScript) with session ID to continue where left off"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Fork: create new session ID from resumed state ("},{"type":"text","marks":[{"type":"code"}],"text":"forkSession"},{"type":"text","text":" TypeScript, "},{"type":"text","marks":[{"type":"code"}],"text":"fork_session"},{"type":"text","text":" Python)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"InMemorySessionStore: built-in, NOT for production (state lost when process exits)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Production storage: implement SessionStore protocol with file-based, Redis, PostgreSQL, or S3"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Session state: agent's scratchpad (key-value pairs, files read, analysis, decisions)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Session state keyed by session ID, not user identity: no user-identity layer in SDK"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"State management: key-value pairs organized into scoped buckets (User state, Conversation state)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Session state = within session only; Long-term memory = across sessions (requires external implementation)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Agent SDK manages session state: keeping session identifier is all that's necessary to continue"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"\"The agent SDK manages session state for you, so keeping track of the session identifier is all that's necessary to continue an existing session\" — the absolute minimum for session continuity."}]}]}}
