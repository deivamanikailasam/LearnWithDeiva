{"format":"tiptap/v1","updatedAt":"2026-06-22T06:27:16.212Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Based on the official Claude documentation and resources, "},{"type":"text","marks":[{"type":"bold"}],"text":"\"Sessions & State\""},{"type":"text","text":" in the Agent SDK in Production refers to "},{"type":"text","marks":[{"type":"bold"}],"text":"the mechanisms for managing conversation history and agent context across multiple interactions, enabling agents to maintain state and resume work precisely where they left off"},{"type":"text","text":" — critical for production deployments where agents handle long-running tasks."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Sessions"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What Sessions Are"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"A session is an agent instance within an environment"},{"type":"text","text":" that maintains conversation history across multiple interactions."}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Session = Agent + Environment + Conversation History\n    ↓\nTracks progress while events drive execution\n    ↓\nContinues conversation across multiple user interactions"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key capability"},{"type":"text","text":": \"Sessions allow you to continue conversations across multiple interactions while maintaining full context\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Session Lifecycle"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Phase"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"