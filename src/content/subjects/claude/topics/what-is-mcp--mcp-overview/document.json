{"format":"tiptap/v1","updatedAt":"2026-06-22T03:43:32.076Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Based on my research, I can now explain the "},{"type":"text","marks":[{"type":"bold"}],"text":"\"MCP Overview\""},{"type":"text","text":" section within "},{"type":"text","marks":[{"type":"bold"}],"text":"\"What Is MCP\""},{"type":"text","text":" as part of "},{"type":"text","marks":[{"type":"bold"}],"text":"\"MCP Fundamentals\""},{"type":"text","text":" for Claude:"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What is MCP (Model Context Protocol)?"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"MCP (Model Context Protocol)"},{"type":"text","text":" is an open-source standard created by Anthropic for connecting AI applications like Claude to external systems. Think of it as a "},{"type":"text","marks":[{"type":"bold"}],"text":"USB-C port for AI applications"},{"type":"text","text":" — just as USB-C provides a standardized way to connect electronic devices, MCP provides a standardized way to connect AI applications to external systems."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Purpose"}]},{"type":"paragraph","content":[{"type":"text","text":"Using MCP, AI applications like Claude can connect to:\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Data sources"},{"type":"text","text":" (e.g., local files, databases, Google Calendar, Notion)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Tools"},{"type":"text","text":" (e.g., search engines, calculators, GitHub, Slack)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Workflows"},{"type":"text","text":" (e.g., specialized prompts, browser automation)"}]},{"type":"paragraph","content":[{"type":"text","text":"This enables them to "},{"type":"text","marks":[{"type":"bold"}],"text":"access key information and perform tasks"},{"type":"text","text":" on behalf of users."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What MCP Enables"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Agents can access your Google Calendar and Notion, acting as a more personalized AI assistant"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Claude Code can generate an entire web app using a Figma design"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Enterprise chatbots can connect to multiple databases across an organization"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"AI models can create 3D designs on Blender and print them using a 3D printer"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Core Architecture: Host-Client-Server Model"}]},{"type":"paragraph","content":[{"type":"text","text":"MCP operates through a "},{"type":"text","marks":[{"type":"bold"}],"text":"three-tier architecture"},{"type":"text","text":":"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Component"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Role"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Host"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"The LLM application (like Claude) that initiates requests and processes responses"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Server"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"The external service providing tools, data, or functionality (database, search API, calendar)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Client"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Middleware that translates between the host and server, executing operations"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Three Primitives"}]},{"type":"paragraph","content":[{"type":"text","text":"MCP defines three core primitives for interaction:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Primitive"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Controller"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Purpose"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Example"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tools"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Model-controlled"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Perform actions"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"github_create_issue"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"read_file"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Resources"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"App-controlled"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Read-only data access"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"docs://documents/{id}"},{"type":"text","text":", database records"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prompts"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"User-controlled"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Instruction templates"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"summarize_document"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"code_review"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why MCP Matters"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Before MCP"},{"type":"text","text":": Every AI application needed custom code to connect with databases, APIs, and services — each integration was different, creating maintenance overhead."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"With MCP"},{"type":"text","text":": One standardized protocol works across Claude, ChatGPT, Cursor, VS Code, and all MCP-compatible applications instantly. Write an MCP server once, and it works everywhere."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Benefits"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Reduces integration complexity"},{"type":"text","text":": One MCP client connects to any compliant server"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Minimizes hallucination risk"},{"type":"text","text":": Models work with current, validated information"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Enables multi-hop reasoning"},{"type":"text","text":": Agents can chain multiple tools for complex tasks"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Improves security"},{"type":"text","text":": Centralized authentication and permissions"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Standardizes auditing"},{"type":"text","text":": Consistent tracking across all tool interactions"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Transport Layers"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Transport"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Best For"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Complexity"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"stdio"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Local development, desktop apps"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Low"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Streamable HTTP"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Production, cloud deployment"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Medium"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"MCP was introduced by Anthropic in "},{"type":"text","marks":[{"type":"bold"}],"text":"November 2024"},{"type":"text","text":", adopted by OpenAI in March 2025, and donated to the Linux Foundation's Agentic AI Foundation in December 2025. Claude was the first production LLM to support MCP natively."}]}]}}
