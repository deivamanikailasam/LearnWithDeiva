x_tokens=1024,\n    tools=[{\n        \"type\": \"computer_20241022\",\n        \"name\": \"computer\",\n        \"display_width\": 1024,\n        \"display_height\": 768\n    }],\n    messages=[{\n        \"role\": \"user\",\n        \"content\": [\n            {\"type\": \"text\", \"text\": \"Open Chrome and search for 'Python tutorials'\"},\n            {\"type\": \"image\", \"source\": {...}}  # Current screenshot\n        ]\n    }]\n)\n\n# Claude returns tool_use:\n# {\n#   \"type\": \"tool_use\",\n#   \"name\": \"computer\",\n#   \"input\": {\n#     \"action\": \"mouse_move\",\n#     \"coordinate\": [450, 100]\n#   }\n# }\n\n# Your app executes the action on the actual computer\n# Take new screenshot, repeat loop"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Required driver code"}]},{"type":"paragraph","content":[{"type":"text","text":"You must write substantial driver code to:\n1. Capture screenshots\n2. Execute Claude's tool instructions (mouse/keyboard simulation)\n3. Handle errors and edge cases\n4. Manage the loop until task completion"}]},{"type":"paragraph","content":[{"type":"text","text":"The model doesn't work well without proper screen dimensions and parameters."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Real-world example"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Airport flight search automation"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Task: \"Search for flights from NYC to London on December 15\"\n\n1. Claude sees desktop screenshot → identifies Chrome icon\n2. mouse_move to Chrome icon [250, 150]\n3. left_click → Chrome opens\n4. mouse_move to address bar [500, 80]\n5. left_click → Address bar active\n6. type \"google.com\" + Enter\n7. mouse_move to search box [600, 300]\n8. left_click → Search box active\n9. type \"flights NYC London December 15\" + Enter\n10. Continue navigating results until task complete"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common mistakes"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Mistake"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Fix"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Wrong screen dimensions"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Match training dimensions exactly"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No isolation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Run in Docker container, not on production system"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Insufficient loop handling"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Implement proper retry logic for failed actions"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Missing error handling"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidt