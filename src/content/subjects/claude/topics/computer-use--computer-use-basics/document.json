{"format":"tiptap/v1","updatedAt":"2026-06-21T15:58:30.504Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What it is"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Computer Use"},{"type":"text","text":" is a capability introduced in "},{"type":"text","marks":[{"type":"bold"}],"text":"Claude 3.5 Sonnet v2"},{"type":"text","text":" (October 2024) that enables models to control computers through visual perception and simulated input. It combines:\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Image reasoning"},{"type":"text","text":" (multimodal AI that sees screenshots)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Tool use"},{"type":"text","text":" (structured API calls)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Pixel counting"},{"type":"text","text":" (precise cursor positioning)"}]},{"type":"paragraph","content":[{"type":"text","text":"The model processes screen images, analyzes what's happening, and navigates by issuing mouse clicks and keyboard strokes."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why it matters"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Problem solved"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Solution"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"AI can't interact with GUIs"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Controls computer visually like humans"}]}]}]},{"type"