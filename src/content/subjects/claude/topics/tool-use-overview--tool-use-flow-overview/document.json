{"format":"tiptap/v1","updatedAt":"2026-06-21T14:46:37.768Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How tool use works"},{"type":"text","text":" is the "},{"type":"text","marks":[{"type":"bold"}],"text":"agentic loop protocol"},{"type":"text","text":" that transforms Claude from a text generator into an action-taking system. It's a "},{"type":"text","marks":[{"type":"bold"}],"text":"contract between your application and the model"},{"type":"text","text":": you specify available operations and their input/output shapes; Claude decides when to call them and returns structured calls that your code executes."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Core insight"},{"type":"text","text":": \"Tool use is what turns Claude from a text generator into something that can take actions in the world — search the web, query a database, send an email, run a calculation.\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why It Matters"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Without tool use"},{"type":"text","text":": Claude can only generate text → \"What's the weather?\" → guesses from training data (wrong)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"With tool use"},{"type":"text","text":": Claude calls your function → you fetch real-time data → Claude incorporates result → accurate answer"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"For your distributed systems work at Box Hill"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Database queries"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"query_users(\"SELECT FROM users WHERE id =?\")"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"API calls"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"fetch_stock_price(\"AAPL\")"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"call_payment_service(amount, currency)"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Code execution"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"run_tests(\"npm test\")"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"execute_code(\"python script.py\")"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"File operations"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"read_file(\"src/auth.ts\")"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"list_files(\"src/\")"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Benefits"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Benefit"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Value"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Impact"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Action capability"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Call APIs, run code, query DB"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Real-world execution"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Transparent reasoning"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Text + tool_use blocks"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Claude explains what it's doing"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Control flow signal"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"stop_reason"},{"type":"text","text":" values"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Drive agent logic"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Parallel execution"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Multiple tool_use blocks"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Efficiency gains"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Validation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"JSON Schema input"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Prevents misuse"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Auditability"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tool calls recorded"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Security, compliance"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Trade-offs"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Trade-off"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Impact"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Mitigation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Not executing itself"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Your code runs tool"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Implement client-side handler"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Latency overhead"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Round-trip: Claude → code → Claude"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use parallel tool calls"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multiple turns"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tool loop = multiple API calls"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use SDK Tool Runner wrapper"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tool misuse"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Model calls wrong tool"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Write specific descriptions"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cost"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Multiple API calls = expensive"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use direct response for trivial tasks"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Token consumption"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Each tool definition = input tokens"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Keep focused tool sets"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How It Works"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Tool Loop (Protocol)"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"1. You define tools (name + description + JSON Schema input_schema)\n2. You call Claude with tools=... and tool_choice\n3. Claude either responds with text OR asks to call tools (stop_reason == \"tool_use\")\n4. Your app executes tool(s) and sends results back as tool_result blocks (references tool_use_id)\n5. Repeat until stop_reason == \"end_turn\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Mental Model: Tool as Contract"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Your app: \"Here are available tools and their shapes\"\nClaude: \"I need to use tool X with inputs Y\"\nYour app: \"Okay, executing tool X with Y → result Z\"\nClaude: \"Got result Z → now I can continue reasoning\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Three-Step Handshake"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Step 1: You define tool\n  └─ name: \"get_stock_price\"\n  └─ description: \"Get current stock price for symbol\"\n  └─ input_schema: { symbol: \"string\", required: [\"symbol\"] }\n\nStep 2: Claude returns tool_use block\n  └─ type: \"tool_use\"\n  └─ id: \"toolu_01A12v3xX\"\n  └─ name: \"get_stock_price\"\n  └─ input: { symbol: \"AAPL\" }\n\nStep 3: Your app sends tool_result\n  └─ type: \"tool_result\"\n  └─ tool_use_id: \"toolu_01A12v3xX\"\n  └─ content: \"175.43\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Components"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Tool Definition Schema"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"{\n  name: \"get_stock_price\",           // Unique identifier\n  description: \"Get the current stock price for a given symbol. Use this when you need real-time stock prices.\",\n  input_schema: {\n    type: \"object\",\n    properties: {\n      symbol: {\n        type: \"string\",\n        description: \"Stock symbol (e.g., 'AAPL' for Apple)\"\n      }\n    },\n    required: [\"symbol\"]\n  }\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key"},{"type":"text","text":": Description is what Claude reads to decide whether to call the tool."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Bad description"},{"type":"text","text":": \"Check stock\" → vague, Claude won't use it\n"},{"type":"text","marks":[{"type":"bold"}],"text":"Good description"},{"type":"text","text":": \"Get current stock price for symbol. Use when you need real-time stock prices.\" → specific, Claude calls it"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Claude's Response (Tool Use Mode)"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"role\": \"assistant\",\n  \"content\": [\n    {\n      \"type\": \"text\",\n      \"text\": \"I need to check the stock price for AAPL.\"\n    },\n    {\n      \"type\": \"tool_use\",\n      \"id\": \"toolu_01A12v3xX\",\n      \"name\": \"get_stock_price\",\n      \"input\": { \"symbol\": \"AAPL\" }\n    }\n  ],\n  \"stop_reason\": \"tool_use\"\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key differences from text response"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"code"}],"text":"stop_reason: \"tool_use\""},{"type":"text","text":" (not "},{"type":"text","marks":[{"type":"code"}],"text":"\"end_turn\""},{"type":"text","text":")\n- "},{"type":"text","marks":[{"type":"code"}],"text":"content"},{"type":"text","text":" array contains both text + tool_use blocks"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Your App's Tool Result"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"type\": \"tool_result\",\n  \"tool_use_id\": \"toolu_01A12v3xX\",  // Must match tool_use.id\n  \"content\": \"175.43\"\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Requirement"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"tool_use_id"},{"type":"text","text":" must match the original tool_use block's "},{"type":"text","marks":[{"type":"code"}],"text":"id"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Control Flow: stop_reason Values"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"switch (response.stop_reason) {\n  case \"tool_use\":\n    // Claude requested tool execution → execute tools → send results back\n    break;\n  case \"end_turn\":\n    // Claude completed response → conversation can continue\n    break;\n  case \"max_tokens\":\n    // Claude reached token limit → may have more to say\n    break;\n  case \"stop_sequence\":\n    // Claude encountered predefined stop sequence\n    break;\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"stop_reason"},{"type":"text","text":" acts as control flow signal for your agent."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Step-by-Step Implementation"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 1: Define Tool Schema"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"const tools = [\n  {\n    name: \"get_stock_price\",\n    description: \"Get the current stock price for a given symbol. Use this when you need real-time stock prices.\",\n    input_schema: {\n      type: \"object\",\n      properties: {\n        symbol: {\n          type: \"string\",\n          description: \"Stock symbol (e.g., 'AAPL' for Apple)\"\n        }\n      },\n      required: [\"symbol\"]\n    }\n  }\n];"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best practice"},{"type":"text","text":": Write specific, detailed descriptions."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 2: Call Claude with Tools"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"const response = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [\n    {\n      role: \"user\",\n      content: \"What's the stock price for AAPL?\"\n    }\n  ],\n  tools: tools,\n  tool_choice: { type: \"auto\" } // Default: Claude decides when to call\n});"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude decides"},{"type":"text","text":": With default "},{"type":"text","marks":[{"type":"code"}],"text":"tool_choice: { type: \"auto\" }"},{"type":"text","text":", Claude calls tool when request maps to tool's capability and answer isn't in context."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 3: Check for Tool Use"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// When stop_reason == \"tool_use\"\nif (response.stop_reason === \"tool_use\") {\n  // Extract tool_use blocks from content\n  const toolUseBlocks = response.content.filter(c => c.type === \"tool_use\");\n  \n  console.log(\"Number of tool calls:\", toolUseBlocks.length);\n  \n  // Extract: name, input, id for each\n  toolUseBlocks.forEach(block => {\n    console.log(\"Tool name:\", block.name);\n    console.log(\"Tool input:\", block.input);\n    console.log(\"Tool ID:\", block.id);\n  });\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"stop_reason"},{"type":"text","text":" is your primary indicator for agent logic."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 4: Execute Tool in Your Code"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Your app executes the tool\nfunction executeTool(toolName, toolInput) {\n  switch (toolName) {\n    case \"get_stock_price\":\n      return getStockPrice(toolInput.symbol);\n    case \"query_database\":\n      return queryDatabase(toolInput.query);\n    default:\n      throw new Error(`Unknown tool: ${toolName}`);\n  }\n}\n\n// Execute each tool\nconst toolExecutions = toolUseBlocks.map(block => {\n  const result = executeTool(block.name, block.input);\n  return { toolUseId: block.id, result: result };\n});"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 5: Send Tool Result Back to Claude"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Create tool_result blocks\nconst toolResultBlocks = toolExecutions.map(exec => ({\n  type: \"tool_result\",\n  tool_use_id: exec.toolUseId,\n  content: exec.result.toString()\n}));\n\n// Send back to Claude\nconst response2 = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [\n    ...response.messages,\n    {\n      role: \"user\",\n      content: toolResultBlocks\n    }\n  ],\n  tools: tools\n});\n\n// Claude continues reasoning with result\nconsole.log(response2.content[0].text);\n// \"AAPL is currently trading at $175.43\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 6: Handle Parallel Tool Calls"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Claude requests multiple tools in one turn\nconst toolUseBlocks = response.content.filter(c => c.type === \"tool_use\");\n\n// Execute in parallel\nconst results = await Promise.all(\n  toolUseBlocks.map(block => executeTool(block.name, block.input))\n);\n\n// Send back all results\nconst toolResultBlocks = toolUseBlocks.map((block, i) => ({\n  type: \"tool_result\",\n  tool_use_id: block.id,\n  content: results[i].toString()\n}));"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Result"},{"type":"text","text":": Claude can call 2+ tools in parallel, efficiency gain."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Client Tools vs. Server Tools"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Client Tools (Your Code Executes)"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Example: get_stock_price\nconst response = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [{ role: \"user\", content: \"What's AAPL stock?\" }],\n  tools: [{ name: \"get_stock_price\", description: \"...\", input_schema: {...} }]\n});\n\n// stop_reason == \"tool_use\"\n// Your code executes get_stock_price(\"AAPL\")\n// Send tool_result back to Claude"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Examples"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"get_stock_price"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"query_database"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"send_email"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"read_file"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Server Tools (Anthropic Executes)"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Example: web_search\nconst response = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [{ role: \"user\", content: \"What's the weather in Boston?\" }],\n  tools: [{ name: \"web_search\", description: \"Search the web...\", input_schema: {...} }]\n});\n\n// You see results directly, no execution handling"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Examples"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"web_search"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"code_execution"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"web_fetch"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"tool_search"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key difference"},{"type":"text","text":": Client tools = you handle execution; Server tools = Anthropic handles execution."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Advanced Patterns"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Tool Runner SDK (Auto-Generate Schema)"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// TypeScript SDK's Tool Runner\nimport { ToolRunner } from \"@anthropic-ai/sdk/tool-runner\";\n\n// Your actual function\nasync function lookupBuildingCode(address: string): Promise<string> {\n  return \"Zone 3\";\n}\n\n// Tool Runner: reads types + docs, builds schema automatically\nconst runner = new ToolRunner({\n  model: \"claude-4-sonnet-20251027\",\n  tools: [lookupBuildingCode] // Pass function, SDK builds schema\n});\n\n// Send prompt, wait for result\nconst result = await runner.run(\"What's the building code for 123 Main St?\");\nconsole.log(result); // \"Zone 3\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Advantage"},{"type":"text","text":": Shrinks code to \"describe tool → send prompt → wait for result\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. System Prompt Guidance (Optional)"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Optional: Encourage tool usage\nconst response = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  system: \"When you need real-time data, use the get_stock_price tool. Don't guess from training data.\",\n  messages: [\n    { role: \"user\", content: \"What's AAPL's stock price?\" }\n  ],\n  tools: [{ name: \"get_stock_price\", description: \"...\", input_schema: {...} }]\n});"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Helpful but not required"},{"type":"text","text":": Claude can still use tools from "},{"type":"text","marks":[{"type":"code"}],"text":"tools"},{"type":"text","text":" parameter alone."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Tool Choice Steering"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"const response = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [{ role: \"user\", content: \"What's the weather?\" }],\n  tools: [getWeatherTool],\n  tool_choice: { type: \"auto\" } // Claude decides (default)\n});\n\nconst response2 = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [{ role: \"user\", content: \"What's the weather?\" }],\n  tools: [getWeatherTool],\n  tool_choice: { type: \"any\" } // Claude MUST use at least one tool\n});"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Options"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"code"}],"text":"auto"},{"type":"text","text":": Claude decides (default)\n- "},{"type":"text","marks":[{"type":"code"}],"text":"any"},{"type":"text","text":": Claude must use at least one tool"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Examples"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example 1: Stock Price Lookup"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"User"},{"type":"text","text":": \"What's the stock price for AAPL?\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude response"},{"type":"text","text":" ("},{"type":"text","marks":[{"type":"code"}],"text":"stop_reason: \"tool_use\""},{"type":"text","text":"):"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"content\": [\n    { \"type\": \"text\", \"text\": \"I need to check the stock price for AAPL.\" },\n    {\n      \"type\": \"tool_use\",\n      \"id\": \"toolu_01A12v3xX\",\n      \"name\": \"get_stock_price\",\n      \"input\": { \"symbol\": \"AAPL\" }\n    }\n  ]\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Your code executes"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"const result = getStockPrice(\"AAPL\"); // 175.43"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Send back tool_result"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"type\": \"tool_result\",\n  \"tool_use_id\": \"toolu_01A12v3xX\",\n  \"content\": \"175.43\"\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude final response"},{"type":"text","text":" ("},{"type":"text","marks":[{"type":"code"}],"text":"stop_reason: \"end_turn\""},{"type":"text","text":"):"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"content\": [\n    { \"type\": \"text\", \"text\": \"AAPL is currently trading at $175.43\" }\n  ]\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example 2: Parallel Stock Queries"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"User"},{"type":"text","text":": \"What are the stock prices for AAPL and GOOGL?\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude response"},{"type":"text","text":" (2 tool_use blocks):"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"content\": [\n    { \"type\": \"tool_use\", \"id\": \"toolu_01A\", \"name\": \"get_stock_price\", \"input\": { \"symbol\": \"AAPL\" } },\n    { \"type\": \"tool_use\", \"id\": \"toolu_01B\", \"name\": \"get_stock_price\", \"input\": { \"symbol\": \"GOOGL\" } }\n  ]\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Your code executes in parallel"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"const [aapl, googl] = await Promise.all([\n  getStockPrice(\"AAPL\"),\n  getStockPrice(\"GOOGL\")\n]);"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Send back both results"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"[\n  { \"type\": \"tool_result\", \"tool_use_id\": \"toolu_01A\", \"content\": \"175.43\" },\n  { \"type\": \"tool_result\", \"tool_use_id\": \"toolu_01B\", \"content\": \"142.67\" }\n]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude final"},{"type":"text","text":": \"AAPL is $175.43 and GOOGL is $142.67.\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tool use = contract between app and model"},{"type":"text","text":" → You define tools, Claude decides when to call"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Three-step handshake"},{"type":"text","text":": Define → Tool Use → Tool Result → Repeat"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"stop_reason = control signal"},{"type":"text","text":" → "},{"type":"text","marks":[{"type":"code"}],"text":"\"tool_use\""},{"type":"text","text":" vs. "},{"type":"text","marks":[{"type":"code"}],"text":"\"end_turn\""},{"type":"text","text":" drives agent logic"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"tool_use_id must match"},{"type":"text","text":" → tool_result references original tool_use.id"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude doesn't execute"},{"type":"text","text":" → Your code runs the tool"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Client vs. Server tools"},{"type":"text","text":" → Your code vs. Anthropic infrastructure"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Parallel tool calls"},{"type":"text","text":" → Multiple tool_use blocks per turn"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use Tool Runner SDK"},{"type":"text","text":" → Automatic schema + loop handling"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"System prompt optional"},{"type":"text","text":" → Claude sees tools from "},{"type":"text","marks":[{"type":"code"}],"text":"tools"},{"type":"text","text":" parameter alone"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Write specific descriptions"},{"type":"text","text":" → Vague = bad tool use, specific = good"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"For your Box Hill distributed systems work, I'd implement "},{"type":"text","marks":[{"type":"bold"}],"text":"the three-step handshake with parallel tool calls + Tool Runner SDK"},{"type":"text","text":", giving you automatic schema generation, reduced turns, and efficiency gains while maintaining full control over tool execution."}]}]}}
