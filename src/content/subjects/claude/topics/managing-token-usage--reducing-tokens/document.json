:"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Run "},{"type":"text","marks":[{"type":"code"}],"text":"/compact"},{"type":"text","text":" "},{"type":"text","marks":[{"type":"bold"}],"text":"proactively"},{"type":"text","text":" after each work phase, not when bloated"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Over-relying on long "},{"type":"text","marks":[{"type":"code"}],"text":"CLAUDE.md"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Keep focused—essentials only; trim rarely-needed parts"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Not using "},{"type":"text","marks":[{"type":"code"}],"text":".claudeignore"},{"type":"text","text":" in monorepos"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Set up at workspace + package level"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Treating every task as one big task"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Smaller, scoped sessions outperform marathon sessions in cost + quality"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Context rot is real:"},{"type":"text","text":" Quality degrades as context fills—token management is a "},{"type":"text","marks":[{"type":"bold"}],"text":"quality problem"},{"type":"text","text":", not just cost"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use built-in commands strategically:"},{"type":"text","text":" "},{"type":"text","marks":[{"type":"code"}],"text":"/compact"},{"type":"text","text":" after each phase, "},{"type":"text","marks":[{"type":"code"}],"text":"/clear"},{"type":"text","text":" between unrelated tasks"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Front-load setup:"},{"type":"text","text":" Good "},{"type":"text","marks":[{"type":"code"}],"text":"CLAUDE.md"},{"type":"text","text":" + "},{"type":"text","marks":[{"type":"code"}],"text":".claudeignore"},{"type":"text","text":" save tokens on every session"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Scope everything:"},{"type":"text","text":" Precise prompts, focused sessions, minimal outputs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Offload where possible:"},{"type":"text","text":" Tasks not requiring Claude's reasoning shouldn't consume its context"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Git commits = checkpoints:"},{"type":"text","text":" Safe to clear context without losing progress"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"The developers getting most consistent results aren't those with biggest context windows—they're those who keep those windows "},{"type":"text","marks":[{"type":"bold"}],"text":"clean"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","text":"Want me to help you set up a "},{"type":"text","marks":[{"type":"code"}],"text":"CLAUDE.md"},{"type":"text","text":" template for your specific project, or show you how to configure "},{"type":"text","marks":[{"type":"code"}],"text":".claudeignore"},{"type":"text","text":" for a Box Hill/Victoria codebase?"}]}]}}
