{"format":"tiptap/v1","updatedAt":"2026-06-21T13:30:55.328Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Claude uses "},{"type":"text","marks":[{"type":"bold"}],"text":"tokens"},{"type":"text","text":" as its unit of text processing (roughly 1.5 tokens per word, ~4 letters per token), and its "},{"type":"text","marks":[{"type":"bold"}],"text":"context window"},{"type":"text","text":" is the total tokens it can hold at once—Claude Sonnet 4 has a "},{"type":"text","marks":[{"type":"bold"}],"text":"200,000-token"},{"type":"text","text":" context window. Reducing token usage is critical for both cost savings and preventing "},{"type":"text","marks":[{"type":"bold"}],"text":"context rot"},{"type":"text","text":" (quality degradation when the window fills with noise)."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What Consumes Tokens in Claude"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Token Sink"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Why It's Expensive"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Large file reads"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Reading 1,000-line files to answer questions about one function"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Verbose tool outputs"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Terminal/API responses with excessive detail"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Repetitive instructions"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Explaining project conventions every session"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Unnecessary context retention"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Old conversation turns no longer relevant"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Code syntax"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Code is more token-dense than natural language; Python is more efficient than Rust/C++"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Output tokens cost ~5× more than input tokens (e.g., Claude writing 300 lines of code is much pricier than reading 300 lines)."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"10 Techniques to Reduce Token Usage"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. Use Plan Mode Before Executing"}]},{"type":"paragraph","content":[{"type":"text","text":"Ask Claude to produce a structured plan "},{"type":"text","marks":[{"type":"bold"}],"text":"without executing"},{"type":"text","text":" anything first. This catches misunderstandings early—fixing a plan costs almost nothing vs. fixing half-executed work."}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Before doing anything, write out your full plan"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. Run "},{"type":"text","marks":[{"type":"code"}],"text":"/compact"},{"type":"text","text":" Regularly"}]},{"type":"paragraph","content":[{"type":"text","text":"Built-in command that "},{"type":"text","marks":[{"type":"bold"}],"text":"summarizes conversation history"},{"type":"text","text":" into a condensed representation, replacing raw history while retaining essential context."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cadence:"},{"type":"text","text":" Run after completing any discrete phase (e.g., finished writing a component → compact before tests)."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. Use "},{"type":"text","marks":[{"type":"code"}],"text":"/clear"},{"type":"text","text":" When Switching Tasks"}]},{"type":"paragraph","content":[{"type":"text","text":"Unlike "},{"type":"text","marks":[{"type":"code"}],"text":"/compact"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"/clear"},{"type":"text","text":" "},{"type":"text","marks":[{"type":"bold"}],"text":"wipes context entirely"},{"type":"text","text":". Use when moving to unrelated problems—debugging payment module vs. building auth system share nothing."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"4. Write a "},{"type":"text","marks":[{"type":"code"}],"text":"CLAUDE.md"},{"type":"text","text":" File"}]},{"type":"paragraph","content":[{"type":"text","text":"Place at project root; Claude auto-reads it every session. Capture:\n- Project architecture overview\n- Key files + purposes\n- Coding style/conventions\n- Common commands (run tests, start dev server)\n- Things Claude should never do"}]},{"type":"paragraph","content":[{"type":"text","text":"Eliminates hundreds of tokens of repetitive setup per session."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Keep it short:"},{"type":"text","text":" A 2,000-token file starts every session with significant tax—essentials only."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"5. Use "},{"type":"text","marks":[{"type":"code"}],"text":".claudeignore"},{"type":"text","text":" to Exclude Irrelevant Files"}]},{"type":"paragraph","content":[{"type":"text","text":"Same syntax as "},{"type":"text","marks":[{"type":"code"}],"text":".gitignore"},{"type":"text","text":". Exclude:\n- "},{"type":"text","marks":[{"type":"code"}],"text":"node_modules/"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"code"}],"text":"dist/"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"code"}],"text":"build/"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"code"}],"text":"*.log"},{"type":"text","text":" files\n- Large binary assets\n- Third-party vendor directories"}]},{"type":"paragraph","content":[{"type":"text","text":"Prevents automatic pulling into context during exploration/search."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"6. Write Precise, Scoped Prompts"}]},{"type":"paragraph","content":[{"type":"text","text":"Vague prompts → expensive sessions. Narrow scope directly reduces tokens:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Bad"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Good"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"Fix the bugs in my code\""}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"In "},{"type":"text","marks":[{"type":"code"}],"text":"src/api/users.ts"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"getUserById"},{"type":"text","text":" returns undefined when user exists. Error:. Fix only this function.\""}]}]}]}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"7. Break Long Tasks Into Focused Sessions"}]},{"type":"paragraph","content":[{"type":"text","text":"Use Git commits as "},{"type":"text","marks":[{"type":"bold"}],"text":"natural session boundaries"},{"type":"text","text":":\n1. Session ends → commit to Git\n2. New session starts → load only what's needed\n3. Repeat"}]},{"type":"paragraph","content":[{"type":"text","text":"Makes "},{"type":"text","marks":[{"type":"code"}],"text":"/clear"},{"type":"text","text":" guilt-free since progress is saved."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"8. Ask for Minimal Outputs"}]},{"type":"paragraph","content":[{"type":"text","text":"Default Claude is generous with explanation. When you don't need it:\n- \"Implement without explaining your approach\"\n- \"Return only the modified function, no surrounding code\"\n- \"Give me the answer directly, skip the reasoning\""}]},{"type":"paragraph","content":[{"type":"text","text":"Difference between full reasoning vs. skipping it: "},{"type":"text","marks":[{"type":"bold"}],"text":"40–60% token savings"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","text":"Add to "},{"type":"text","marks":[{"type":"code"}],"text":"CLAUDE.md"},{"type":"text","text":": \"Unless asked, provide implementations without lengthy explanations. Prefer concise responses.\""}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"9. Provide Context Files Directly"}]},{"type":"paragraph","content":[{"type":"text","text":"Instead of asking \"How does authentication work?\" (Claude explores → many file reads), paste relevant files upfront:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Here's the auth middleware [paste]. Here's the token validation function [paste]. Given this, implement X."}]},{"type":"paragraph","content":[{"type":"text","text":"Spend fewer tokens than exploratory reads + precise context."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"10. Offload Discrete Tasks to External Tools"}]},{"type":"paragraph","content":[{"type":"text","text":"Delegate web searches, email sending, image generation, data lookups to specialized tools returning "},{"type":"text","marks":[{"type":"bold"}],"text":"compact results"},{"type":"text","text":" vs. 3,000-token outputs."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"},{"type":"text","text":" MindStudio's Agent Skills Plugin lets Claude call 120+ capabilities as method calls, returning clean results while context stays focused on reasoning."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Built-in Tracking Commands"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Command"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Purpose"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"ro