      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Similarity Search Queries"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "pgvector provides three distance operators: "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "<->"
          },
          {
            "type": "text",
            "text": " (L2), "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "<#>"
          },
          {
            "type": "text",
            "text": " (negative inner product), and "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "<=>"
          },
          {
            "type": "text",
            "text": " (cosine distance). For text embeddings, cosine distance is the standard choice."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "-- Find the 5 most semantically similar chunks to a query embedding\n-- Replace '[0.1, 0.2, ...]' with the actual query vector\nSELECT\n    dc.id,\n    dc.text,\n    dc.metadata,\n    1 - (dc.embedding <=> '[0.12, -0.03, ...]'::vector) AS cosine_similarity\nFROM document_chunks dc\nORDER BY dc.embedding <=> '[0.12, -0.03, ...]'::vector\nLIMIT 5;"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Hybrid search: vector + relational filter"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The power of pgvector over standalone vector databases is combining semantic search with SQL filters on the same row:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "-- Semantic search restricted to a specific document category and language\nSELECT\n    dc.id,\n    dc.text,\n    1 - (dc.embedding <=> $1::vector) AS similarity\nFROM document_chunks dc\nJOIN documents d ON d.id = dc.document_id\nWHERE d.category = 'legal'\n  AND (dc.metadata ->> 'language') = 'en'\n  AND d.published_at > '2025-01-01'\nORDER BY dc.embedding <=> $1::vector\nLIMIT 10;"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "marks": [
                  {
                    "type": "bold"
                  }
                ],
                "text": "Index use with WHERE clauses:"
              },
              {
                "type": "text",
                "text": " pgvector ANN indexes work best when the WHERE clause doesn't filter out too many rows. If the WHERE clause leaves fewer than ~10% of rows, PostgreSQL may choose a sequential scan even with an index. Add a partial index to narrow the index to the filtered subset when a filter is always applied."
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "The RAG Pattern with Claude"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Retrieval-augmented generation (RAG) uses the top-K similar chunks as context for Claude. The embedding search happens before the Claude call; Claude sees only the retrieved text, not the full corpus."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\nimport cohere\nimport psycopg2\nimport numpy as np\nfrom pgvector.psycopg2 import register_vector\n\nco = cohere.Client(api_key=\"...\")\nclaude = anthropic.Anthropic()\n\ndef retrieve_chunks(\n    conn,\n    query: str,\n    top_k: int = 5,\n    filter_category: str | None = None,\n) -> list[dict]:\n    # Embed the query (input_type differs from document embedding)\n    query_emb = co.embed(\n        texts=[query],\n        model=\"embed-english-v3.0\",\n        input_type=\"search_query\",\n    ).embeddings[0]\n\n    q_vec = np.array(query_emb)\n\n    with conn.cursor(cursor_factory=psycopg2.extras.RealDictCursor) as cur:\n        filter_sql = \"AND d.category = %s\" if filter_category else \"\"\n        params = [q_vec, top_k]\n        if filter_category:\n            params.insert(1, filter_category)\n        cur.execute(\n            f\"\"\"\n            SELECT dc.text,\n                   1 - (dc.embedding <=> %s::vector) AS score,\n                   dc.metadata\n            FROM document_chunks dc\n            JOIN documents d ON d.id = dc.document_id\n            WHERE 1=1 {filter_sql}\n            ORDER BY dc.embedding <=> %s::vector\n            LIMIT %s\n            \"\"\",\n            [q_vec] + ([filter_category] if filter_category else []) + [q_vec, top_k],\n        )\n        return cur.fetchall()\n\ndef rag_answer(conn, question: str, category: str | None = None) -> str:\n    chunks = retrieve_chunks(conn, question, top_k=5, filter_category=category)\n\n    context = \"\\n\\n---\\n\\n\".join(\n        f\"[score {c['score']:.3f}] {c['text']}\" for c in chunks\n    )\n\n    response = claude.messages.create(\n        model=\"claude-sonnet-4-6\",\n        max_tokens=1024,\n        system=(\n            \"You are a helpful assistant. Answer the user's question using only \"\n            \"the provided context. If the context is insufficient, say so.\"\n        ),\n        messages=[\n            {\n                \"role\": \"user\",\n                \"content\": f\"Context:\\n{context}\\n\\nQuestion: {question}\",\n            }\n        ],\n    )\n    return response.content[0].text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Operational Considerations"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Keeping embeddings current"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When a document is updated, you must re-embed all its chunks — partial re-embedding with a changed embedding model produces a mixed-model index that returns nonsense results. Two safe patterns:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Delete + reinsert:"
                  },
                  {
                    "type": "text",
                    "text": " Delete all chunks for the document (cascades via FK), reinsert the new chunks with fresh embeddings. Simple and safe, but briefly leaves the document unsearchable."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Shadow table:"
                  },
                  {
                    "type": "text",
                    "text": " Write new chunks to a staging table, then swap with a single transaction rename or view update. No downtime, but more complex schema management."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Dimension mismatch"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "vector(N)"
          },
          {
            "type": "text",
            "text": " type enforces a fixed dimension at the column level. If you change embedding models (e.g., 1536 → 1024), you must "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "ALTER COLUMN"
          },
          {
            "type": "text",
            "text": " and re-embed the entire table. Keep model name and dimension in a configuration table so the mismatch is caught at startup rather than at query time:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "CREATE TABLE embedding_config (\n    id          SERIAL PRIMARY KEY,\n    model       TEXT NOT NULL,\n    dimension   INT  NOT NULL,\n    active      BOOL NOT NULL DEFAULT true\n);\nINSERT INTO embedding_config (model, dimension) VALUES ('embed-english-v3.0', 1024);"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def assert_dimension_matches(conn) -> None:\n    with conn.cursor() as cur:\n        cur.execute(\"SELECT model, dimension FROM embedding_config WHERE active LIMIT 1\")\n        row = cur.fetchone()\n        if row is None:\n            raise RuntimeError(\"No active embedding config\")\n        model, expected_dim = row\n        cur.execute(\n            \"\"\"\n            SELECT atttypmod FROM pg_attribute\n            WHERE attrelid = 'document_chunks'::regclass\n              AND attname = 'embedding'\n            \"\"\"\n        )\n        actual_dim = cur.fetchone()[0] - 1  # pgvector stores dim+1 in atttypmod\n        if actual_dim != expected_dim:\n            raise RuntimeError(\n                f\"Embedding column is {actual_dim}-d but config says {expected_dim}-d ({model})\"\n            )"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "maintenance_work_mem for index builds"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "-- Increase memory for the index build session (resets after the session ends)\nSET maintenance_work_mem = '512MB';\n\nCREATE INDEX idx_chunks_hnsw\n    ON document_chunks\n    USING hnsw (embedding vector_cosine_ops)\n    WITH (m = 16, ef_construction = 64);\n\n-- IVFFlat builds faster in parallel (PostgreSQL 16+)\nSET max_parallel_maintenance_workers = 4;\nCREATE INDEX idx_chunks_ivf\n    ON document_chunks\n    USING ivfflat (embedding vector_cosine_ops)\n    WITH (lists = 200);"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "pgvector adds a native vector type"
                  },
                  {
                    "type": "text",
                    "text": " and ANN indexes to PostgreSQL, letting you store embeddings in the same database as your relational data."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Use an external embedding model"
                  },
                  {
                    "type": "text",
                    "text": " (Cohere, OpenAI, sentence-transformers) to generate vectors; Anthropic does not expose a public embeddings endpoint."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Cosine distance ("
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code",
                        "bold": true
                      }
                    ],
                    "text": "<=>"
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": ")"
                  },
                  {
                    "type": "text",
                    "text": " is the standard operator for text embeddings; IVFFlat and HNSW index types both support it."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Hybrid search"
                  },
                  {
                    "type": "text",
                    "text": " — embedding similarity filtered by SQL predicates — is pgvector's main advantage over standalone vector databases."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "RAG with Claude:"
                  },
                  {
                    "type": "text",
                    "text": " embed the query, retrieve top-K chunks from pgvector, pass them as context to Claude. Claude generates a grounded answer without needing to know the full document corpus."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "HNSW for high-recall workloads"
                  },
                  {
                    "type": "text",
                    "text": "; IVFFlat when memory is constrained or the corpus is large and built in batch."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}