type":"text","text":"Professional but friendly"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Measurement Frameworks"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Framework 1: "},{"type":"text","marks":[{"type":"bold"}],"text":"A/B Testing"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Compare prompt variations side by side:"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Process:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Run both versions on same inputs"},{"type":"text","text":"\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Score outputs objectively"},{"type":"text","text":"\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Keep the winner"},{"type":"text","text":"\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Iterate further"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Test Case\ninput = \"What's my balance?\"\n\n# Version A (Old)\nprompt_A = \"You are a customer support bot. Answer questions.\"\noutput_A = \"Your balance is $1,234.56\"  # ❌ Failed: Should ask for ID first\n\n# Version B (New)\nprompt_B = \"You are a customer support bot. Ask for Account ID before showing balance.\"\noutput_B = \"To check your balance, I need your 10-digit Account ID.\"  # ✅ Passed\n\n# Score\npass_rate_A = 72%\npass_rate_B = 91%  # ✅ Winner"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Keep Version B and iterate further."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Framework 2: "},{"type":"text","marks":[{"type":"bold"}],"text":"Incremental Changes"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Change one thing at a time:"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Process:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Find biggest failure"},{"type":"text","text":"\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Hypothesize a fix"},{"type":"text","text":"\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Test the change"},{"type":"text","text":"\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Keep or revert"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Current prompt failure\ninput = \"What's my balance?\"\noutput = \"Your balance is $1,234.56\"  # ❌ Failed\nreason = \"Missing: Should ask for Account ID first\"\n\n# Hypothesis\nhypothesis = \"Adding explicit instruction will fix this\"\n\n# Test change\nnew_prompt = old_prompt + \"IMPORTANT: Ask for Account ID before showing balance.\"\nnew_output = \"To check your balance, I need your Account ID.\"  # ✅ Passed\n\n# Result\nkeep_change = True"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Framework 3: "},{"type":"text","marks":[{"type":"bold"}],"text":"Golden Dataset Evaluation"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Every time you change your system prompt, you run the entire Golden Dataset through the model. If your 'Pass Rate' drops, your change was a mistake.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Process:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Maintain Golden Dataset"},{"type":"text","text":" (10-50 test cases with expected outputs)\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Run entire dataset on every prompt change"},{"type":"text","text":"\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Calculate overall pass rate"},{"type":"text","text":"\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Keep only if pass rate improves"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"golden_dataset = [\n    {\"input\": \"What's my balance?\", \"expected\": \"Ask for Account ID\"},\n    {\"input\": \"Send $50 to Bob\", \"expected\": \"Insufficient funds error\"},\n    {\"input\": \"Delete my account\", \"expected\": \"Escalate to Human\"},\n    # ... 47 more test cases\n]\n\n# Version A\npass_rate_A = 72/100 = 72%\n\n# Version B (after adding instruction)\npass_rate_B = 91/100 = 91%  # ✅ Winner\n\n# Version C (removed something)\npass_rate_C = 85/100 = 85%  # ❌ Worse than B, revert"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Framework 4: "},{"type":"text","marks":[{"type":"bold"}],"text":"Side-by-Side Comparison"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Test prompts interactively, compare model outputs side-by-side, and adjust parameters in real-time without writing code."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tools:"},{"type":"text","text":" Prompt playgrounds (OpenAI Playground, Hugging Face Spaces, Braintrust)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Prompt A: \"Write a good description\"\nOutput A: \"This is a good product.\"\n\nPrompt B: \"Write a 2-3 sentence product description that highlights the main benefit and includes a call to action\"\nOutput B: \"Transform your workflow with our intuitive automation tool. \nSave 10+ hours per week on repetitive tasks. Try it free today!\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Winner: Prompt B"},{"type":"text","text":" (more specific, better output)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Automated Measurement Scripts"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Script 1: "},{"type":"text","marks":[{"type":"bold"}],"text":"Basic Pass/Fail Test"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Here's a simple conceptual Python script for automated prompt testing:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"test_cases = [\n    {\"input\": \"Hi\", \"expected\": \"Greeting\"},\n    {\"input\": \"Delete my account\", \"expected\": \"Escalate to Human\"}\n]\n\ndef evaluate_prompt(prompt_version):\n    pass_count = 0\n    for case in test_cases:\n        response = call_llm(prompt_version, case[\"input\"])\n        if case[\"expected\"] in response:\n            pass_count += 1\n    accuracy = (pass_count / len(test_cases)) * 100\n    print(f\"Prompt {prompt_version} Accuracy: {accuracy}%\")\n    return accuracy\n\n# Run on every change\naccuracy_v1 = evaluate_prompt(\"prompt_v1.txt\")  # 72%\naccuracy_v2 = evaluate_prompt(\"prompt_v2.txt\")  # 91% ✅ Improvement"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Run this script every time you change your system prompt. If your 'Pass Rate' drops, your change was a mistake.\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Script 2: "},{"type":"text","marks":[{"type":"bold"}],"text":"Multi-Criteria Evaluation"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"More sophisticated evaluation with multiple success criteria:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"def evaluate_prompt_advanced(prompt_version):\n    test_cases = [\n        {\n            \"input\": \"What's my balance?\",\n            \"tests\": {\n                \"format\": lambda r: \"Account ID\" in r,  # Should ask for ID\n                \"accuracy\": lambda r: \"$\" not in r,  # Should not show balance yet\n                \"tone\": lambda r: r.lower().startswith(\"to check\")  # Professional\n            }\n        }\n    ]\n    \n    results = {\n        \"format\": [],\n        \"accuracy\": [],\n        \"tone\": []\n    }\n    \n    for case in test_cases:\n        response = call_llm(prompt_version, case[\"input\"])\n        for criterion, test_fn in case[\"tests\"].items():\n            if test_fn(response):\n                results[criterion].append(True)\n            else:\n                results[criterion].append(False)\n    \n    # Calculate scores\n    scores = {\n        criterion: (sum(passes) / len(passes)) * 100\n        for criterion, passes in results.items()\n    }\n    \n    overall = sum(scores.values()) / len(scores)\n    print(f\"Overall: {overall}%\")\n    print(f\"Format: {scores['format']}%\")\n    print(f\"Accuracy: {scores['accuracy']}%\")\n    print(f\"Tone: {scores['tone']}%\")\n    \n    return overall"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Visualizing Improvements"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Visual 1: "},{"type":"text","marks":[{"type":"bold"}],"text":"Before vs. After Table"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"A before vs. after table: one column with a generic prompt, the other with a refined prompt.\""}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Metric"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":