{"format":"tiptap/v1","updatedAt":"2026-06-21T00:26:11.968Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Measuring improvements"},{"type":"text","text":" is the critical step that transforms prompt engineering from guessing into disciplined engineering. You need "},{"type":"text","marks":[{"type":"bold"}],"text":"objective metrics"},{"type":"text","text":" to determine if your prompt changes actually make it better, not just \"feel\" better."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"The key insight:"},{"type":"text","text":" \"Prompt engineering is not 'set and forget.' It's a process that can be measured and improved.\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why Measurement Matters"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Bad Prompts Create Real Risks"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Vague or poorly structured prompts can create risks:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Risk"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Impact"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Example"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hallucinations"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth