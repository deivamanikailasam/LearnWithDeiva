st design"},{"type":"text","text":": All primitives use "},{"type":"text","marks":[{"type":"code"}],"text":"*/list"},{"type":"text","text":" methods for dynamic capability discovery"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Role separation"},{"type":"text","text":": Tools (actions), Resources (data), Prompts (guidance)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Control hierarchy"},{"type":"text","text":": Model vs. App vs. User control prevents unintended autonomy"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"USB-C analogy"},{"type":"text","text":": One protocol connecting any AI host to any service — write server once, work everywhere"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"This architecture shifts the tool-definition burden from your application to specialized MCP servers, enabling Claude to connect to databases, APIs, GitHub, and external services through a single open standard."}]}]}}
