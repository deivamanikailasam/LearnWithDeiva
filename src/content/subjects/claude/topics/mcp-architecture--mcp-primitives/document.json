t"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"code_review"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Tools"},{"type":"text","text":" — Model-Controlled Primitive"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it is"},{"type":"text","text":": Executable functions that the LLM (Claude) can invoke to perform actions in the external world."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why it matters"},{"type":"text","text":": Tools transform Claude from a passive chatbot into an agent that can:\n- Write to databases\n- Trigger API calls\n- Send emails\n- Create calendar events\n- Perform file operations"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How it works"},{"type":"text","text":":\n1. Client discovers tools via "},{"type":"text","marks":[{"type":"code"}],"text":"tools/list"},{"type":"text","text":" request\n2. LLM decides when to invoke a tool based on conversation context\n3. Client executes "},{"type":"text","marks":[{"type":"code"}],"text":"tools/call"},{"type":"text","text":" with arguments\n4. Server returns structured result as conversation context"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key characteristic"},{"type":"text","text":": The "},{"type":"text","marks":[{"type":"bold"}],"text":"model controls"},{"type":"text","text":" when tools are used — Claude decides autonomously based on natural language understanding."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Resources"},{"type":"text","text":" — App-Controlled Primitive"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it is"},{"type":"text","text":": Read-only data sources that provide contextual information to AI applications."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why it matters"},{"type":"text","text":": Resources give Claude access to:\n- File contents\n- Database records\n- API responses\n- Knowledge bases\n- Calendar data"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How it works"},{"type":"text","text":":\n1. Client lists resources via "},{"type":"text","marks":[{"type":"code"}],"text":"resources/list"},{"type":"text","text":"\n2. Client reads specific resource via "},{"type":"text","marks":[{"type":"code"}],"text":"resources/read"},{"type":"text","text":" with URI\n3. Server returns data with MIME type handling (JSON, text, etc.)\n4. Data becomes context for Claude's responses"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Types"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Direct resources"},{"type":"text","text":": Static URIs (e.g., "},{"type":"text","marks":[{"type":"code"}],"text":"docs://manual.pdf"},{"type":"text","text":")\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Templated resources"},{"type":"text","text":": Parameterized URIs (e.g., "},{"type":"text","marks":[{"type":"code"}],"text":"docs://documents/{id}"},{"type":"text","text":")"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key characteristic"},{"type":"text","text":": The "},{"type":"text","marks":[{"type":"bold"}],"text":"app controls"},{"type":"text","text":" resource access — you explicitly choose which data to read, not the model."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Prompts"},{"type":"text","text":" — User-Controlled Primitive"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it is"},{"type":"text","text":": Pre-crafted, reusable instruction templates that encode domain expertise for common workflows."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why it matters"},{"type":"text","text":": Prompts provide:\n- High-quality instruction templates (e.g., "},{"type":"text","marks":[{"type":"code"}],"text":"summarize_document"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"code_review"},{"type":"text","text":")\n- Domain-specific guidance without rewriting prompts each time\n- Consistent workflows for document formatting, analysis, etc."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How it works"},{"type":"text","text":":\n1. User explicitly requests a prompt template\n2. Client lists available prompts via "},{"type":"text","marks":[{"type":"code"}],"text":"prompts/list"},{"type":"text","text":"\n3. User selects prompt (e.g., \"code_review\")\n4. Server returns structured prompt template with variables\n5. Template guides how LLM uses tools/resources"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key characteristic"},{"type":"text","text":": The "},{"type":"text","marks":[{"type":"bold"}],"text":"user controls"},{"type":"text","text":" prompts — you explicitly choose which template to use, providing intentional guidance."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Mental Model: Control Flow"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of the three primitives by "},{"type":"text","marks":[{"type":"bold"}],"text":"who controls when they're used"},{"type":"text","text":":"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tools"},{"type":"text","text":" → Model decides (autonomous action)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Resources"},{"type":"text","text":" → You decide (explicit data access)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prompts"},{"type":"text","text":" → You decide (explicit workflow guidance)"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"This separation prevents the model from blindly accessing data or following instructions without user intent."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use Each"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Claude needs to create a GitHub issue"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tools"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Claude needs to read a file for context"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Resources"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"t