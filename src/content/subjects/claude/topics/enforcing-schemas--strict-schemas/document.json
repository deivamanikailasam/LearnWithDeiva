l invocation\n    messages=[\n        {\"role\": \"user\", \"content\": \"Generate an order with 3 items for customer John Smith\"}\n    ],\n)\n\n# Extract structured data from tool_use block\norder = next(b.input for b in message.content if b.type == \"tool_use\")\nprint(f\"Order ID: {order['order_id']}\")\nprint(f\"Customer: {order['customer_name']}\")"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"JSON Schema Requirements for Strict Validation"}]},{"type":"paragraph","content":[{"type":"text","text":"Your schema must be "},{"type":"text","marks":[{"type":"bold"}],"text":"valid JSON Schema"},{"type":"text","text":" with these key elements:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"type\": \"object\",\n  \"properties\": {\n    \"order_id\": {\"type\": \"string\"},\n    \"customer\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"name\": {\"type\": \"string\"},\n        \"email\": {\"type\": \"string\"}\n      },\n      \"required\": [\"name\", \"email\"]  // Nested required fields\n    },\n    \"items\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"product_name\": {\"type\": \"string\"},\n          \"quantity\": {\"type\": \"integer\"},\n          \"unit_price\": {\"type\": \"number\"}\n        },\n        \"required\": [\"product_name\", \"quantity\", \"unit_price\"]\n      }\n    },\n    \"total_amount\": {\"type\": \"number\"},\n    \"status\": {\n      \"type\": \"string\",\n      \"enum\": [\"pending\", \"paid\", \"shipped\", \"delivered\"]  // Enum constraints\n    }\n  },\n  \"required\": [\"order_id\", \"customer\", \"items\", \"total_amount\", \"status\"]\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Common Mistakes That Break Strict Validation"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"row