apability negotiation handshake\n├── stdio/HTTP/SSE transport layer\n├── Stream parsing & newline delimiting\n└── Error handling & session management\n\nSDK (what you use)\n├── Decorate functions with @McpServerTool\n├── Define tools/resources/prompts\n└── Start server with minimal config"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Example: Python SDK (Minimal Server)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from mcp.server import Server\nfrom mcp.server.stdio import stdio_server\n\napp = Server(\"weather-server\")\n\n@app.tool()\ndef get_weather(location: str) -> str:\n    \"\"\"Get weather for a location\"\"\"\n    return f\"Sunny, 72°F in {location}\"\n\nasync def main():\n    async with stdio_server() as (read_stream, write_stream):\n        await app.run(\n            read_stream,\n            write_stream,\n            app.create_initialization_options()\n        )\n\nif __name__ == \"__main__\":\n    import asyncio\n    asyncio.run(main())"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What the SDK handles automatically:"},{"type":"text","text":"\n- JSON-RPC message parsing\n- "},{"type":"text","marks":[{"type":"code"}],"text":"initialize"},{"type":"text","text":" → "},{"type":"text","marks":[{"type":"code"}],"text":"initialized"},{"type":"text","text":" handshake\n- Tool discovery ("},{"type":"text","marks":[{"type":"code"}],"text":"tools/list"},{"type":"text","text":")\n- Tool invocation ("},{"type":"text","marks":[{"type":"code"}],"text":"tools/call"},{"type":"text","text":")\n- stdio stream management"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Example: C# SDK (Microsoft's Implementation)"}]},{"type":"codeBlock","attrs":{"language":"csharp"},"content":[{"type":"text","text":"using ModelContextProtocol.Server;\n\n[McpServerToolType]\npublic class TripTools {\n    [McpServerTool, Description(\"List all hotels\")]\n    public static async Task<List<Hotel>> ListHotels(string city) {\n        return await Task.FromResult(hotels);\n    }\n}\n\nvar builder = Host.CreateEmptyApplicationBuilder(settings: null);\nbuilder.Services\n    .AddMcpServer(options => {\n        options.ServerInfo = new() { Name = \"McpTripAdvisorServer\", Version = \"1.0.0\" };\n    })\n    .WithStdioServerTransport()\n    .WithTools<TripTools>();\n\nvar host = builder.Build();\nawait host.RunAsync();"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key features:"},{"type":"text","text":"\n- Attribute-based tool declaration (``)\n- Built-in AppSettings configuration\n- Async support native"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Example: TypeScript SDK"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import { McpServer } from \"@modelcontextprotocol/sdk/server/mcp.js\";\nimport { stdioServerTransport } from \"@modelcontextprotocol/sdk/server/stdio.js\";\n\nconst server = new McpServer({\n  name: \"weather-server\",\n  version: \"1.0.0\"\n});\n\nserver.tool(\"getWeather\", \"Get weather for location\", {\n  location: { type: \"string\" }\n}, async ({ location }) => {\n  return {\n    content: [{ type: \"text\", text: `Sunny, 72°F in ${location}` }]\n  };\n});\n\nconst transport = new stdioServerTransport();\nawait server.connect(transport);"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"When to Use Each SDK"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"t