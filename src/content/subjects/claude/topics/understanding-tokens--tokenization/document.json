{"format":"tiptap/v1","updatedAt":"2026-06-21T13:16:49.261Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Tokenization in Claude: How Claude Breaks Text into Tokens"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tokenization is the process of converting raw text into the numeric token IDs that Claude actually processes."},{"type":"text","text":" Before Claude ever \"reads\" your prompt, your text is algorithmically split into chunks and converted into integers that the model can work with mathematically."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Tokenization Process: Step by Step"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Raw Text → Token Chunks"}]},{"type":"paragraph","content":[{"type":"text","text":"Claude's tokenizer splits your text into "},{"type":"text","marks":[{"type":"bold"}],"text":"subword units"},{"type":"text","text":" using a method similar to "},{"type":"text","marks":[{"type":"bold"}],"text":"Byte Pair Encoding (BPE)"},{"type":"text","text":", which is standard across most LLMs."}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Common words"},{"type":"text","text":" → single token (e.g., \"the\", \"code\" = 1 token each)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Long/uncommon words"},{"type":"text","text":" → split into multiple tokens (e.g., \"unbelievable\" → \"un\" + \"believe\" + \"able\" = 3 tokens)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Punctuation"},{"type":"text","text":" → each character = 1 token (e.g., "},{"type":"text","marks":[{"type":"code"}],"text":","},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"?"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"!"},{"type":"text","text":")"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Whitespace"},{"type":"text","text":" → counted in tokens"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Code syntax"},{"type":"text","text":" → very efficient: "},{"type":"text","marks":[{"type":"code"}],"text":"()"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"code"}],"text":"{"},{"type":"text","text":" each = 1 token"}]}]}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Token Chunks → Numeric IDs"}]},{"type":"paragraph","content":[{"type":"text","text":"Each chunk is mapped to a "},{"type":"text","marks":[{"type":"bold"}],"text":"token ID"},{"type":"text","text":" from Claude's vocabulary (typically 50,000–200,000 unique tokens)."}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Hello, world!\" \n→ [\"Hello\", \",\", \" \", \"world\", \"!\"]\n→ [15496, 11, 25, 19245, 922]  (example token IDs)"}]},{"type":"paragraph","content":[{"type":"text","text":"Claude never sees the raw letters—it only processes this list of integers."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Numeric IDs → Model Processing"}]},{"type":"paragraph","content":[{"type":"text","text":"The model uses these IDs to:\n- Look up embeddings (mathematical representations) for each token\n- Calculate which tokens are most likely to follow based on training data"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Generation → Token Streaming"}]},{"type":"paragraph","content":[{"type":"text","text":"When Claude generates text, it outputs "},{"type":"text","marks":[{"type":"bold"}],"text":"one token at a time"},{"type":"text","text":" in a stream, with each token corresponding to a small chunk of text (often 1–4 characters)."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Characteristics of Claude's Tokenizer"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Feature"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Claude-Specific Detail"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tokenizer type"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Custom BPE (Byte Pair Encoding) trained on Claude's training data"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Vocabulary size"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"~50,000–200,000 unique tokens"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Average token length"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"~4 characters per token; ~1.5 tokens per word"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"English text ratio"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"1 token ≈ 3.5 characters or 0.75 words"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"CJK languages"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"1 token ≈ 1.5 characters (Chinese, Japanese, Korean carry more semantic weight)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Model-specific"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Different from GPT-5, Gemini, Grok—Claude tokenizes differently"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Real Examples: How Text Gets Tokenized"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Example 1: Common English Sentence"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Text: \"I won't believe it's unbelievable\"\nTokens: [\"I\", \" won\", \"'t\", \" believe\", \" it\", \"'s\", \" un\", \"believe\", \"able\"]\nCount: 9 tokens (7 words)"}]},{"type":"bulletList","content