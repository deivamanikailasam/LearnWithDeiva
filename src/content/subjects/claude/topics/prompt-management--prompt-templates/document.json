c}} for {{audience}}.\nKey points: {{key_points}}\nTone: {{tone}}\nWord count: {{word_count}}\n\"\"\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Option 2: Pydantic Class (JSON Schema)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from pydantic import BaseModel\n\nclass PromptSchema(BaseModel):\n    topic: str\n    audience: str\n    key_points: str\n    tone: str\n    word_count: int"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pydantic option:"},{"type":"text","text":" You expect the schema to be passed as JSON at runtime"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Building Templates: Step-by-Step"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 1: Define the Template Structure"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Promptplex example:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from promptplex import PromptManager, PromptTemplate\n\ntemplate = PromptTemplate(\n    name=\"blog_post_writer\",\n    template=\"\"\"Write a {post_type} blog post on {topic} for {audience}.\nKey points: {key_points}\nTone: {tone}\nWord count: {word_count}\"\"\",\n    variables=[\"post_type\", \"topic\", \"audience\", \"key_points\", \"tone\", \"word_count\"],\n    description=\"Generate blog posts with a clear structure\"\n)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key elements:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Name"},{"type":"text","text":" — Unique identifier for template\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Template string"},{"type":"text","text":" — The actual prompt with variables\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Variables list"},{"type":"text","text":" — All placeholders defined\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Description"},{"type":"text","text":" — Purpose documentation"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 2: Save and Version"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Promptplex:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"manager = PromptManager()\nmanager.add_template(template)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"MLflow UI:"},{"type":"text","text":"\n1. Navigate to "},{"type":"text","marks":[{"type":"bold"}],"text":"prompts pane"},{"type":"text","text":"\n2. Click "},{"type":"text","marks":[{"type":"bold"}],"text":"Create Prompt"},{"type":"text","text":"\n3. Provide "},{"type":"text","marks":[{"type":"bold"}],"text":"prompt name"},{"type":"text","text":"\n4. Type in your "},{"type":"text","marks":[{"type":"bold"}],"text":"prompt template"},{"type":"text","text":"\n5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Save it"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"To create a new version:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Click \"Create Prompt Version\" → Make changes → Save"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 3: Render with Variables"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Promptplex render:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"blog = template.render(\n    post_type=\"how-to guide\",\n    topic=\"prompt engineering\",\n    audience=\"startup founders\",\n    key_points=\"simplicity, consistency, speed\",\n    tone=\"friendly and informative\",\n    word_count=\"800\"\n)\nprint(blog)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"MLflow code:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from mlflow.genai import register_prompt\n\nregistered_prompt = register_prompt(\n    name=\"blog_post_writer\",\n    template=template\n)\n\n# Load and format with values\nformatted_prompt = registered_prompt.format(\n    topic=\"AI automation\",\n    audience=\"technical managers\",\n    key_points=\"efficiency, cost savings, scalability\",\n    tone=\"professional but accessible\",\n    word_count=\"1000\"\n)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 4: Register Prompt (MLflow)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"MLflow register_prompt:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import mlflow.genai as genai\n\ngenai.register_prompt(\n    name=\"invoice_extraction\",\n    template=\"\"\"Extract invoice data from: {{invoice_text}}\n\nOutput format:\n- Invoice ID: [string]\n- Date: [date]\n- Total: [number]\n- Vendor: [string]\"\"\"\n)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Real Management Platforms"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. MLflow Prompt Registry"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"MLflow has this prompt management tool. You can do this in two different ways: through UI or with the code.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Features:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"UI workflow"},{"type":"text","text":" — Create, update, compare, delete versions\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Code automation"},{"type":"text","text":" — "},{"type":"text","marks":[{"type":"code"}],"text":"mlflow.genai"},{"type":"text","text":" library\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Schema definition"},{"type":"text","text":" — Simple variables or Pydantic\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Version tracking"},{"type":"text","text":" — Full history"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"UI capabilities:"},{"type":"text","text":"\n- Create prompt\n- Create prompt version\n- Compare variants\n- Delete versions"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Promptplex"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Meet Promptplex, the Python library designed to bring order and efficiency to your prompt engineering process.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Features:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Centralized templates"},{"type":"text","text":" — All prompts in one place\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Versioned"},{"type":"text","text":" — Track changes, roll back\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Render anywhere"},{"type":"text","text":" — Use in content tool, chatbot, dashboard\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"No copy/paste"},{"type":"text","text":" — Single template, multiple uses"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Installation:"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"pip install promptplex"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Quick start:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# 1. Define a template\ntempla