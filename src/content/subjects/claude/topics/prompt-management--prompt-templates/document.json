ard-coded"},{"type":"text","text":" — Define placeholders\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Swappable"},{"type":"text","text":" — Fill with actual data"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Advanced Template Patterns"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern 1: Template Composition"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Supports composition of complex prompts from reusable components.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Base template\nrole_template = \"\"\"You are a {role} with {years} years of experience.\"\"\"\n\n# Task template\ntask_template = \"\"\"Your task is to {task} for {project}.\"\"\"\n\n# Combined template\ncombined = role_template + \"\\n\\n\" + task_template\n\n# Render\nfinal_prompt = combined.format(\n    role=\"senior Python engineer\",\n    years=\"10\",\n    task=\"write a function\",\n    project=\"data pipeline\"\n)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern 2: Partial Templates"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Reusable templates with variables, partials, and few-shot anchors.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Partials:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Partial for common section\ncommon_section = \"\"\"\nConstraints:\n- Maximum {max_words} words\n- No jargon without explanation\n- Include {num_examples} practical examples\n\"\"\"\n\n# Use in multiple templates\ntemplate1 = role_section + task_section + common_section.format(max_words=800, num_examples=2)\ntemplate2 = role_section + task_section + common_section.format(max_words=1000, num_examples=3)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern 3: Few-Shot Anchors"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Variables & few-shot examples\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template with examples:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"template = \"\"\"\nClassify this email: {{input_email}}\n\n<examples>\n<example>\nInput: \"I was double charged.\"\nOutput: Category: Billing, Reason: Incorrect charging\n</example>\n\n<example>\nInput: \"The app crashes.\"\nOutput: Category: Bug, Reason: Feature broken\n</example>\n</examples>\n\"\"\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Validation & Testing"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Validation Pipelines"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"A good template system... provides tooling for testing and iteration.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Validation features:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Schema validation"},{"type":"text","text":" — Check variable types\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Required fields"},{"type":"text","text":" — Ensure all variables present\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Format checking"},{"type":"text","text":" — Validate template structure"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Test Suite Integration"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Automated test suites against curated datasets with LLM-judge scoring and validation rubrics.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Testing workflow:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Create test cases"},{"type":"text","text":" — Define inputs and expected outputs\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Run test suite"},{"type":"text","text":" — Execute against dataset\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"LLM-judge scoring"},{"type":"text","text":" — Automated evaluation\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Validation rubrics"},{"type":"text","text":" — Quality criteria"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Centralize All Templates"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Promptplex centralizes all your prompt templates in one place, versioned and ready to use.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Do:"},{"type":"text","text":" Keep all prompts in a single registry or library "},{"type":"text","marks":[{"type":"bold"}],"text":"Don't:"},{"type":"text","text":" Scatter prompts across code files"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Define Variables Explicitly"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Variables — runtime substitution\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Do:"},{"type":"text","text":" List all variables in the template definition\n"},{"type":"text","marks":[{"type":"bold"}],"text":"Don't:"},{"type":"text","text":" Leave variables undefined"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Version Every Change"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Keep track of changes, roll back to previous versions, and maintain a clean history.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Do:"},{"type":"text","text":" Create new version for each modification\n"},{"type":"text","marks":[{"type":"bold"}],"text":"Don't:"},{"type":"text","text":" Edit the same version repeatedly"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Use Schema Validation"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"I have used the schema. Whatever the things that you place inside these double curly brackets becomes a variable which you can substitute at runtime. The other option for the schema is to use the pyantic class.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Do:"},{"type":"text","text":" Define Pydantic schema for complex prompts\n"},{"type":"text","marks":[{"type":"bold"}],"text":"Don't:"},{"type":"text","text":" Use simple variables when structure is needed"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Document with Metadata"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Metadata tags for discovery + lineage\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Do:"},{"type":"text","text":" Add descriptions and tags to templates\n"},{"type":"text","marks":[{"type":"bold"}],"text":"Don't:"},{"type":"text","text":" Leave templates without context"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Test Before Deploying"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"While iterating on your prompt, you can save versions of it.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Do:"},{"type":"text","text":" Test with variables before integration\n"},{"type":"text","marks":[{"type":"bold"}],"text":"Don't:"},{"type":"text","text":" Deploy untested templates"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Summary"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prompt templates and variables"},{"type":"text","text":" transform prompts from scattered text into maintainable configuration:"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What templates are:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Reusable prompts"},{"type":"text","text":" — Dynamic placeholders at runtime\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Separates logic"},{"type":"text","text":" — From application code\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Safe injection"},{"type":"text","text":" — Prevents errors\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Versioned"},{"type":"text","text":" — Track changes, roll back"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why use templates:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Separates logic from code"},{"type":"text","text":" — Not scattered\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Version control"},{"type":"text","text":" — Track, compare, rollback\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Dynamic flexibility"},{"type":"text","text":" — Runtime substitution"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Variable formats:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Double curly braces"},{"type":"text","text":" — "},{"type":"text","marks":[{"type":"code"}],"text":"{{variable}}"},{"type":"text","text":" [MLflow, Bedrock]\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Single curly braces"},{"type":"text","text":" — "},{"type":"text","marks":[{"type":"code"}],"text":"{variable}"},{"type":"text","text":" [Promptplex, LangChain]\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Brace brackets"},{"type":"text","text":" — "},{"type":"text","marks":[{"type":"code"}],"text":"${variable}"},{"type":"text","text":" [Some engines]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Building templates:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Define structure"},{"type":"text","text":" — Name, template, variables, description\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Save and version"},{"type":"text","text":" — Add to manager\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Render with variables"},{"type":"text","text":" — Fill at runtime\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Register prompt"},{"type":"text","text":" — "},{"type":"text","marks":[{"type":"code"}],"text":"mlflow.genai.register_prompt"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Management platforms:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"MLflow"},{"type":"text","text":" — UI + code, schema validation\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Promptplex"},{"type":"text","text":" — Python library, centralized\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Amazon Bedrock"},{"type":"text","text":" — Prompt library, variant comparison\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"InsightPrompts"},{"type":"text","text":" — 4-stage workflow (create→test→approve→deploy)\n5. "},{"type":"text","marks":[{"type":"bold"}],"text":"LangChain"},{"type":"text","text":" — Dynamic placeholders"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Advanced patterns:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Template composition"},{"type":"text","text":" — Combine reusable components\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Partial templates"},{"type":"text","text":" — Shared sections\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Few-shot anchors"},{"type":"text","text":" — Examples in templates"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best practices:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Centralize all templates"},{"type":"text","text":" — Single registry\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Define variables explicitly"},{"type":"text","text":" — List all\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Version every change"},{"type":"text","text":" — New version\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Use schema validation"},{"type":"text","text":" — Pydantic\n5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Document with metadata"},{"type":"text","text":" — Tags, descriptions\n6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Test before deploying"},{"type":"text","text":" — Validate first"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Prompt template management solves this by treating prompts as first-class configuration\""},{"type":"text","text":" — versioned, validated, and dynamically rendered."}]}]}}
