rks":[{"type":"bold"}],"text":"Constraints"},{"type":"text","text":" — Any limitations or requirements\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Audience"},{"type":"text","text":" — Who the output is for\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Tone"},{"type":"text","text":" — Desired voice/style"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example input:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"I want to create a prompt that:\n- Takes meeting notes as input\n- Summarizes them into structured format\n- Extracts key decisions, action items, and deadlines\n- Outputs in bullet points with clear sections\n- Is professional but not overly formal\n- Handles vague or incomplete notes gracefully"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 3: "},{"type":"text","marks":[{"type":"bold"}],"text":"Review and Edit"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"The generated prompt templates are also editable, allowing you to quickly tweak them for optimal performance.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Process:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Review the generated prompt"},{"type":"text","text":" — Claude creates a complete template\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Edit if needed"},{"type":"text","text":" — Tweak sections for your specific use case\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Test the prompt"},{"type":"text","text":" — Run it to see if it works\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Iterate"},{"type":"text","text":" — Refine based on results"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Real-World Use Cases"}]},{"type":"heading","attrs":{"level":3},"c