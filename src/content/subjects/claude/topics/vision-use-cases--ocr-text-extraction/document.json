":"# Extract invoice fields using Claude 3 Haiku\nimport litellm\nfrom litellm import completion\n\n# Encode image to binary\ndef encode_image(image_path):\n    with open(image_path, \"rb\") as f:\n        return f.read()\n\n# Send to Claude\nresponse = completion(\n    model=\"claude-3-haiku\",\n    messages=[{\n        \"role\": \"user\",\n        \"content\": [\n            {\"type\": \"image_url\", \"image_url\": {\"url\": encode_image(\"invoice.jpg\")}},\n            {\"type\": \"text\", \"text\": prompt}  # From above JSON prompt\n        ]\n    }]\n)\n\n# Extract JSON from response\ninvoice_data = extract_json(response)\nprint(invoice_data)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"INVOICE_NUMBER\": \"12345\",\n  \"CUSTOMER_NUMBER\": \"CUST001\",\n  \"CUSTOMER_NAME\": \"ABC Corp\",\n  \"VENDOR_NAME\": \"XYZ Services\",\n  \"INVOICE_AMOUNT\": \"$5,000.00\",\n  \"INVOICE_DATE\": \"2024-03-15\",\n  \"VENDOR_ADDRESS\": \"123 Main St, City\"\n}"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Example 2: Receipt Text Extraction"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Read this receipt and extract the restaurant name, total amount, date, and items ordered\""}]},{"type":"paragraph","content":[{"type":"text","text":"Results: Claude extracts structured data from receipt images."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Example 3: Speedometer Reading"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Read the speedometer value from this image\""}]},{"type":"paragraph","content":[{"type":"text","text":"Results: \"The speedometer is showing 140 km/h (~87 mph)\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"OCR Accuracy & Performance"}]},{"type":"table","conte