{"format":"tiptap/v1","updatedAt":"2026-06-22T04:07:10.814Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Managing MCP Tools"},{"type":"text","text":" in the MCP Connector API refers to controlling "},{"type":"text","marks":[{"type":"bold"}],"text":"which tools from an MCP server are available to Claude"},{"type":"text","text":", configuring their permissions, and handling their behavior through the "},{"type":"text","marks":[{"type":"code"}],"text":"tools"},{"type":"text","text":" array with "},{"type":"text","marks":[{"type":"code"}],"text":"mcp_toolset"},{"type":"text","text":" entries."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Two-Step MCP Configuration Process"}]},{"type":"paragraph","content":[{"type":"text","text":"MCP setup follows a strict separation:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Step"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"When"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"What You Do"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Agent Creation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Declare agent"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Specify which MCP servers to connect to (URL + name, "},{"type":"text","marks":[{"type":"bold"}],"text":"no auth"},{"type":"text","text":")"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Session Creation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Start session"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Provide credentials via vault IDs for those servers"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"This keeps secrets out of reusable agent definitions while allowing per-session authentication."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 1: Declare MCP Servers (Agent Creation)"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"mcp_servers\": [\n    {\n      \"type\": \"url\",\n      \"name\": \"github\",\n      \"url\": \"https://api.githubcopilot.com/mcp/\"\n    },\n    {\n      \"type\": \"url\",\n      \"name\": \"jira\",\n      \"url\": \"https://jira-mcp.example.com/sse\"\n    }\n  ]\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Server constraints:"},{"type":"text","text":"\n| Rule | Limit |\n|------|-------|\n| Max servers per agent | 20 |\n| Name length | 1–255 characters |\n| URL length | Up to 2048 characters |\n| Name uniqueness | Must be unique within agent |"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Critical requirement:"},{"type":"text","text":" Every declared server must be referenced by an "},{"type":"text","marks":[{"type":"code"}],"text":"mcp_toolset"},{"type":"text","text":", and every "},{"type":"text","marks":[{"type":"code"}],"text":"mcp_toolset"},{"type":"text","text":" must reference a declared server."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 2: Configure Tools (MCP Toolset)"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"tools\": [\n    {\n      \"type\": \"mcp_toolset\",\n      \"mcp_server_name\": \"github\"\n    }\n  ]\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"code"}],"text":"mcp_server_name"},{"type":"text","text":" must "},{"type":"text","marks":[{"type":"bold"}],"text":"exactly match"},{"type":"text","text":" the "},{"type":"text","marks":[{"type":"code"}],"text":"name"},{"type":"text","text":" from your "},{"type":"text","marks":[{"type":"code"}],"text":"mcp_servers"},{"type":"text","text":" array."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Managing Which Tools Are Available"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern 1: Default (All Tools Enabled)"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"type\": \"mcp_toolset\",\n  \"mcp_server_name\": \"github\"\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"All tools exposed by the MCP server are automatically available."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern 2: Allowlist (Only Specific Tools)"}]},{"type":"paragraph","content":[{"type":"text","text":"Use when the server exposes many tools but your agent only needs a few:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"type\": \"mcp_toolset\",\n  \"mcp_server_name\": \"github\",\n  \"default_config\": { \"enabled\": false },\n  \"configs\": [\n    { \"name\": \"get_issue\", \"enabled\": true },\n    { \"name\": \"list_issues\", \"enabled\": true },\n    { \"name\": \"add_issue_comment\", \"enabled\": true }\n  ]\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits:"},{"type":"text","text":"\n- Prevents clutter from tools you don't need\n- Keeps newly added tools (by server operator) off until you review them"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern 3: Denylist (Block Unsafe Tools)"}]},{"type":"paragraph","content":[{"type":"text","text":"Use for "},{"type":"text","marks":[{"type":"bold"}],"text":"read-only assistants"},{"type":"text","text":" or before "},{"type":"text","marks":[{"type":"bold"}],"text":"destructive actions"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"type\": \"mcp_toolset\",\n  \"mcp_server_name\": \"github\",\n  \"configs\": [\n    { \"name\": \"delete_repository\", \"enabled\": false }\n  ]\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"Keep all tools enabled except the ones you explicitly block."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern 4: Mixed (Allowlist + Defer Loading)"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"type\": \"mcp_toolset\",\n  \"mcp_server_name\": \"github\",\n  \"default_config\": {\n    \"enabled\": false,\n    \"defer_loading\": true\n  },\n  \"configs\": [\n    { \n      \"name\": \"search_issues\", \n      \"enabled\": true, \n      \"defer_loading\": false \n    },\n    { \"name\": \"list_issues\", \"enabled\": true }\n  ]\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use case:"},{"type":"text","text":" When you want to use "},{"type":"text","marks":[{"type":"bold"}],"text":"Tool search tool"},{"type":"text","text":" to selectively load tools."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Tool Configuration Options"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Property"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Default"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Effect"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"enabled"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"true"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Whether Claude can call the tool"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"defer_loading"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"false"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Don't send tool description initially (wait for Tool search)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tool naming:"},{"type":"text","text":" The "},{"type":"text","marks":[{"type":"code"}],"text":"name"},{"type":"text","text":" in each "},{"type":"text","marks":[{"type":"code"}],"text":"configs"},{"type":"text","text":" entry is the "},{"type":"text","marks":[{"type":"bold"}],"text":"bare tool name"},{"type":"text","text":" as reported by the server (e.g., "},{"type":"text","marks":[{"type":"code"}],"text":"\"get_issue\""},{"type":"text","text":", not "},{"type":"text","marks":[{"type":"code"}],"text":"\"github:get_issue\""},{"type":"text","text":")."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Permission Policies"}]},{"type":"paragraph","content":[{"type":"text","text":"The MCP toolset defaults to "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"always_ask"},{"type":"text","text":" permission policy:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"type\": \"mcp_toolset\",\n  \"mcp_server_name\": \"github\",\n  \"permission_policy\": \"always_ask\"  // Requires user approval before each tool call\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"This requires "},{"type":"text","marks":[{"type":"bold"}],"text":"user approval"},{"type":"text","text":" before each tool call, providing safety for sensitive operations."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Authentication with Vaults"}]},{"type":"paragraph","content":[{"type":"text","text":"Vaults are credential collections registered once and referenced by ID:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"session = client.beta.sessions.create(\n    agent=agent.id,\n    environment_id=environment.id,\n    vault_ids=[vault.id],  # Provides credentials for MCP servers\n)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Vault matching rules:"},{"type":"text","text":"\n| Rule | Description |\n|------|-------------|\n| Match by URL | Vault must contain credential with "},{"type":"text","marks":[{"type":"code"}],"text":"mcp_server_url"},{"type":"text","text":" "},{"type":"text","marks":[{"type":"bold"}],"text":"exactly matching"},{"type":"text","text":" the server URL |\n| No match = unauthenticated | If none matches, connection is attempted without authentication |"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Creating a vault credential:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"mcp_server_url\": \"https://api.githubcopilot.com/mcp/\",\n  \"authorization_token\": \"eyJhbGciOi...\"\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Handling Connection Errors"}]},{"type":"paragraph","content":[{"type":"text","text":"Session creation "},{"type":"text","marks":[{"type":"bold"}],"text":"does not validate"},{"type":"text","text":" MCP connectivity or credentials. If a server is unreachable:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"type\": \"session.error\",\n  \"mcp_server_name\": \"jira\",  // Affected server\n  \"retry_status\": 503  // Connection failed\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"You can:\n- Block further interaction with this error\n- Trigger credential rotation\n- Let the session continue without the affected server's tools"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Large Tool Output Handling"}]},{"type":"paragraph","content":[{"type":"text","text":"When an MCP tool output exceeds "},{"type":"text","marks":[{"type":"bold"}],"text":"100,000 tokens"},{"type":"text","text":":\n- Automatically written to a "},{"type":"text","marks":[{"type":"bold"}],"text":"file in the sandbox"},{"type":"text","text":"\n- Model receives "},{"type":"text","marks":[{"type":"bold"}],"text":"truncated preview"},{"type":"text","text":" with file path\n- Model can read full content from the file"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Multiple MCP Servers Example"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"mcp_servers\": [\n    {\n      \"type\": \"url\",\n      \"name\": \"github\",\n      \"url\": \"https://api.githubcopilot.com/mcp/\"\n    },\n    {\n      \"type\": \"url\",\n      \"name\": \"google-calendar\",\n      \"url\": \"https://calendar-mcp.example.com/sse\"\n    }\n  ],\n  \"tools\": [\n    {\n      \"type\": \"mcp_toolset\",\n      \"mcp_server_name\": \"github\"\n    },\n    {\n      \"type\": \"mcp_toolset\",\n      \"mcp_server_name\": \"google-calendar\",\n      \"default_config\": { \"defer_loading\": true },\n      \"configs\": [\n        { \"name\": \"search_events\", \"enabled\": true, \"defer_loading\": false }\n      ]\n    }\n  ]\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"Each server gets its own "},{"type":"text","marks":[{"type":"code"}],"text":"mcp_toolset"},{"type":"text","text":" entry."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Managing MCP tools"},{"type":"text","text":" = controlling which tools from each MCP server are available to Claude"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"default_config.enabled: false"},{"type":"text","text":" for allowlists, "},{"type":"text","marks":[{"type":"bold"}],"text":"omit it"},{"type":"text","text":" for denylists"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"defer_loading: true"},{"type":"text","text":" delays tool description until Tool search is triggered"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Vault credentials"},{"type":"text","text":" must match server URLs exactly"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Permission policy "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"always_ask"},{"type":"text","text":" requires user approval per tool call"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"100K token limit"},{"type":"text","text":" triggers automatic file writing"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Every server must have"},{"type":"text","text":" an "},{"type":"text","marks":[{"type":"code"}],"text":"mcp_toolset"},{"type":"text","text":", and vice versa"}]}]}]},{"type":"paragraph"}]}}
