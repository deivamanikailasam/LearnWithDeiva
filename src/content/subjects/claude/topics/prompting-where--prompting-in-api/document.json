{"format":"tiptap/v1","updatedAt":"2026-06-20T11:49:30.555Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Via the "},{"type":"text","marks":[{"type":"bold"}],"text":"Claude API"},{"type":"text","text":", you don’t “prompt” in a UI box—you prompt by "},{"type":"text","marks":[{"type":"bold"}],"text":"sending a structured request to the Messages endpoint"},{"type":"text","text":", where your prompt is encoded in the "},{"type":"text","marks":[{"type":"code"}],"text":"messages"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"code"}],"text":"system"},{"type":"text","text":" fields."}]},{"type":"paragraph","content":[{"type":"text","text":"In short:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Endpoint:"},{"type":"text","text":" "},{"type":"text","marks":[{"type":"code"}],"text":"POST https://api.anthropic.com/v1/messages"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"User prompt:"},{"type":"text","text":" in the "},{"type":"text","marks":[{"type":"code"}],"text":"messages"},{"type":"text","text":" array, with "},{"type":"text","marks":[{"type":"code"}],"text":"role: \"user\""},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"code"}],"text":"content: \"your text\""},{"type":"text","text":"."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"System prompt:"},{"type":"text","text":" in the top-level "},{"type":"text","marks":[{"type":"code"}],"text":"system"},{"type":"text","text":" field (optional but powerful)."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Conversation history:"},{"type":"text","text":" in the "},{"type":"text","marks":[{"type":"code"}],"text":"messages"},{"type":"text","text":" array, alternating "},{"type":"text","marks":[{"type":"code"}],"text":"user"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"code"}],"text":"assistant"},{"type":"text","text":" turns."}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Exact location of your prompt in the API request"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. User prompt (the main thing you’d type in chat)"}]},{"type":"paragraph","content":[{"type":"text","text":"Your primary prompt is in:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"model\": \"claude-sonnet-4-20250514\",\n  \"max_tokens\": 1024,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Hello, Claude. Explain LLMs in plain English.\"\n    }\n  ]\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"Here:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"\"role\": \"user\""},{"type":"text","text":" identifies this as the human’s input."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"\"content\""},{"type":"text","text":" is your actual text prompt (string or array of content blocks with text/images, tools, etc.)."}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"This is the "},{"type":"text","marks":[{"type":"bold"}],"text":"“where”"},{"type":"text","text":" for your prompt: the "},{"type":"text","marks":[{"type":"code"}],"text":"messages"},{"type":"text","text":" array, last "},{"type":"text","marks":[{"type":"code"}],"text":"user"},{"type":"text","text":" message (or the only one in a single-turn request)."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. System prompt (instructions, role, rules, context)"}]},{"type":"paragraph","content":[{"type":"text","text":"High-level instructions go in the top-level "},{"type":"text","marks":[{"type":"code"}],"text":"system"},{"type":"text","text":" field:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"model\": \"claude-sonnet-4-20250514\",\n  \"max_tokens\": 1024,\n  \"system\": \"You are a senior TypeScript engineer. Write clear, testable code. Do not hallucinate APIs.\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Refactor this function to be async and handle errors properly.\"\n    }\n  ]\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"This is the "},{"type":"text","marks":[{"type":"bold"}],"text":"system prompt"},{"type":"text","text":" (like a project-level or agent-level role description). It:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Sets Claude’s role (“senior TypeScript engineer”)."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Defines goals and constraints."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Applies across the whole conversation, not just the current turn."}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. Conversation history (multi-turn prompts)"}]},{"type":"paragraph","content":[{"type":"text","text":"For stateful, multi-turn conversations, you pass the full history in "},{"type":"text","marks":[{"type":"code"}],"text":"messages"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"model\": \"claude-sonnet-4-20250514\",\n  \"max_tokens\": 1024,\n  \"system\": \"You are a helpful coding assistant.\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Hello, Claude.\"\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": \"Hi! I'm Claude. How can I help you?\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Can you explain LLMs to me?\"\n    }\n  ]\n}"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Earlier turns are included to provide context."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"bold"}],"text":"current prompt"},{"type":"text","text":" is the last "},{"type":"text","marks":[{"type":"code"}],"text":"user"},{"type":"text","text":" message in the array."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"The API is "},{"type":"text","marks":[{"type":"bold"}],"text":"stateless"},{"type":"text","text":": you must send the full history each time."}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"4. Optional advanced prompt structures"}]},{"type":"paragraph","content":[{"type":"text","text":"You can also:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Pass "},{"type":"text","marks":[{"type":"bold"}],"text":"images"},{"type":"text","text":" as content blocks in the "},{"type":"text","marks":[{"type":"code"}],"text":"user"},{"type":"text","text":" message:"}]},{"type":"paragraph"},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"role\": \"user\",\n  \"content\": [\n    {\n      \"type\": \"image\",\n      \"source\": {\n        \"type\": \"url\",\n        \"url\": \"https://example.com/image.jpg\"\n      }\n    },\n    {\n      \"type\": \"text\",\n      \"text\": \"What's in this image?\"\n    }\n  ]\n}"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Include "},{"type":"text","marks":[{"type":"bold"}],"text":"tool definitions"},{"type":"text","text":" in the "},{"type":"text","marks":[{"type":"code"}],"text":"tools"},{"type":"text","text":" field for tool use."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use "},{"type":"text","marks":[{"type":"bold"}],"text":"structured outputs"},{"type":"text","text":" via "},{"type":"text","marks":[{"type":"code"}],"text":"output_config"},{"type":"text","text":" for guaranteed JSON schemas."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Add a "},{"type":"text","marks":[{"type":"bold"}],"text":"prefilled assistant message"},{"type":"text","text":" (on supported models) to shape Claude’s response, e.g.:"}]}]}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"role\": \"assistant\",\n  \"content\": \"The answer is (\"\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"This “puts words in Claude’s mouth” to guide multiple-choice answers."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"How to actually send this request"}]},{"type":"paragraph","content":[{"type":"text","text":"You can call the API via:"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"cURL"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"curl -X POST https://api.anthropic.com/v1/messages \\\n  -H \"x-api-key: YOUR_API_KEY\" \\\n  -H \"anthropic-version: 2023-06-01\" \\\n  -H \"content-type: application/json\" \\\n  -d '{\n    \"model\": \"claude-sonnet-4-20250514\",\n    \"max_tokens\": 1024,\n    \"system\": \"You are a senior Python engineer.\",\n    \"messages\": [\n      {\n        \"role\": \"user\",\n        \"content\": \"Explain this code and propose a fix.\"\n      }\n    ]\n  }'"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Python (official SDK)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\nmessage = client.messages.create(\n  model=\"claude-sonnet-4-20250514\",\n  max_tokens=1024,\n  system=\"You are a senior Python engineer.\",\n  messages=[\n    {\"role\": \"user\", \"content\": \"Explain this code and propose a fix.\"}\n  ]\n)\n\nprint(message.content)"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"model"},{"type":"text","text":" selects which Claude model."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"max_tokens"},{"type":"text","text":" limits output length."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"system"},{"type":"text","text":" is the system prompt."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"messages"},{"type":"text","text":" holds the conversation, with your "},{"type":"text","marks":[{"type":"bold"}],"text":"user prompt"},{"type":"text","text":" in the last "},{"type":"text","marks":[{"type":"code"}],"text":"user"},{"type":"text","text":" message."}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Summary: “Where to prompt via the API?”"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"User prompt:"},{"type":"text","text":" in the "},{"type":"text","marks":[{"type":"code"}],"text":"messages"},{"type":"text","text":" array, under "},{"type":"text","marks":[{"type":"code"}],"text":"role: \"user\", content: \"your text\""},{"type":"text","text":"."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"System prompt:"},{"type":"text","text":" in the top-level "},{"type":"text","marks":[{"type":"code"}],"text":"system"},{"type":"text","text":" field."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Conversation context:"},{"type":"text","text":" in the "},{"type":"text","marks":[{"type":"code"}],"text":"messages"},{"type":"text","text":" array with prior "},{"type":"text","marks":[{"type":"code"}],"text":"user"},{"type":"text","text":"/"},{"type":"text","marks":[{"type":"code"}],"text":"assistant"},{"type":"text","text":" turns."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"You send these via "},{"type":"text","marks":[{"type":"code"}],"text":"POST https://api.anthropic.com/v1/messages"},{"type":"text","text":" using HTTP or an SDK."}]}]}]},{"type":"paragraph"}]}}
