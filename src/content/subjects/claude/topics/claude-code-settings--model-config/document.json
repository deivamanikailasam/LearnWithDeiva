{"format":"tiptap/v1","updatedAt":"2026-06-22T13:15:24.833Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Model Configuration"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Model configuration"},{"type":"text","text":" is the part of Claude Code settings that decides "},{"type":"text","marks":[{"type":"bold"}],"text":"which Claude model runs for your session"},{"type":"text","text":", and optionally which models are allowed or preferred in different contexts."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What it controls"}]},{"type":"paragraph","content":[{"type":"text","text":"Model configuration can define:\n- The "},{"type":"text","marks":[{"type":"bold"}],"text":"default model"},{"type":"text","text":" Claude Code should use.\n- A "},{"type":"text","marks":[{"type":"bold"}],"text":"one-time model override"},{"type":"text","text":" for a single session.\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Model aliases or presets"},{"type":"text","text":" for different workflows.\n- In some setups, "},{"type":"text","marks":[{"type":"bold"}],"text":"fallback behavior"},{"type":"text","text":" if the primary model is unavailable."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Ways to change the model"}]},{"type":"paragraph","content":[{"type":"text","text":"There are three common ways to set the model:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Method"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scope"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Best for"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"/model"},{"type":"text","text":" inside Claude Code"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Current session immediately"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Fast switching while working"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"claude --model..."}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"One session at launch"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Trying a different model for a specific task"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Environment variable or settings file"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Persistent default"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Making a model your long-term default"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why it matters"}]},{"type":"paragraph","content":[{"type":"text","text":"Different models are better at different jobs. A faster model may be enough for quick edits, while a more capable model may be better for planning, debugging, or complex refactors. Model configuration lets you tune Claude Code for speed, cost, or reasoning quality without changing how you use the tool."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How it fits with settings"}]},{"type":"paragraph","content":[{"type":"text","text":"Model configuration usually lives in the same broader configuration stack as permissions and environment variables. That means you can set a global default in your shell or settings, then temporarily override it for a single session when needed."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Simple example"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"claude --model claude-sonnet-4-6"}]},{"type":"paragraph","content":[{"type":"text","text":"That starts Claude Code for this session using the model you specified, while leaving your normal default unchanged."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Mental model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of model configuration as the "},{"type":"text","marks":[{"type":"bold"}],"text":"engine selector"},{"type":"text","text":" for Claude Code. You are not changing the car, just deciding whether it should run in a quicker mode or a more capable one."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Model configuration chooses which Claude model Claude Code uses."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"You can change it instantly with "},{"type":"text","marks":[{"type":"code"}],"text":"/model"},{"type":"text","text":"."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"You can override it for one session with "},{"type":"text","marks":[{"type":"code"}],"text":"--model"},{"type":"text","text":"."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"You can make it persistent with environment variables or settings."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"The right model depends on whether you value speed, cost, or deeper reasoning."}]}]}]},{"type":"paragraph"}]}}
