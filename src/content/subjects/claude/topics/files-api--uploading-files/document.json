{"format":"tiptap/v1","updatedAt":"2026-06-21T17:10:26.223Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Uploading Files in The Files API"},{"type":"text","text":" is the process of uploading files to Claude's cloud storage so you can reference them by "},{"type":"text","marks":[{"type":"code"}],"text":"file_id"},{"type":"text","text":" in subsequent API requests without re-uploading content with every message, enabling efficient document workflows and code execution integration."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What it is"}]},{"type":"paragraph","content":[{"type":"text","text":"The Files API is a "},{"type":"text","marks":[{"type":"bold"}],"text":"beta service"},{"type":"text","text":" that lets you upload files once and reference them multiple times by ID across multiple API calls, avoiding the need to re-attach the same document with every request."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Benefits"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Traditional File Attachment"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Files API"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Send file contents with "},{"type":"text","marks":[{"type":"bold"}],"text":"every request"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Upload "},{"type":"text","marks":[{"type":"bold"}],"text":"once"},{"type":"text","text":", reference by ID multiple times"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Large payloads in each API call"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Smaller payloads (just file ID)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Must re-upload for each conversation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Persistent storage until deleted"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No code execution input/output"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Can use for "},{"type":"text","marks":[{"type":"bold"}],"text":"code interpreter"},{"type":"text","text":" input/output"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cost structure:"},{"type":"text","text":"\n- Upload, list, metadata retrieval, deletion, download = "},{"type":"text","marks":[{"type":"bold"}],"text":"FREE"},{"type":"text","text":"\n- Charged only for "},{"type":"text","marks":[{"type":"bold"}],"text":"input tokens"},{"type":"text","text":" from files attached in Messages requests"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How to Upload Files"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Method 1: Python SDK (Recommended)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\n# Upload a file\nuploaded = client.beta.files.upload(\n    file=(\n        \"report.pdf\",  # filename\n        open(\"report.pdf\", \"rb\"),  # file object\n        \"application/pdf\"  # MIME type\n    )\n)\n\nprint(f\"File ID: {uploaded.id}\")\nprint(f\"Size: {uploaded.size_bytes} bytes\")"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"File ID: file_abc123xyz\nSize: 1048576 bytes"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Method 2: Node.js SDK"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import Anthropic from \"@anthropic-ai/sdk\";\nimport { toFile } from \"@anthropic-ai/sdk\";\nimport * as fs from \"fs\";\n\nconst client = new Anthropic();\n\nconst uploaded = await client.beta.files.upload({\n    file: await toFile(\n        fs.createReadStream(\"sample/report.txt\"),\n        \"report.txt\",\n        { type: \"text/plain\" }\n    ),\n    betas: [\"files-api-2025-04-14\"]  // Required beta header\n});\n\n// Reference uploaded.id in subsequent requests"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Method 3: curl (Direct API)"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"curl https://api.anthropic.com/v1/files \\\n  -H 'Content-Type: multipart/form-data' \\\n  -H 'anthropic-version: 2023-06-01' \\\n  -H 'anthropic-beta: files-api-2025-04-14' \\\n  -H \"X-Api-Key: $ANTHROPIC_API_KEY\" \\\n  -F 'file=@/path/to/file'"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Response:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"id\": \"file_abc123xyz\",\n  \"object\": \"file\",\n  \"bytes\": 1048576,\n  \"created_at\": \"2024-09-23T10:30:00Z\",\n  \"filename\": \"report.pdf\",\n  \"mime_type\": \"application/pdf\",\n  \"downloadable\": true\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Method 4: R (ellmer package)"}]},{"type":"codeBlock","attrs":{"language":"r"},"content":[{"type":"text","text":"library(ellmer)\n\nfile <- claude_file_upload(\"path/to/file.pdf\")\n# Returns file object with ID for use in chat"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Required Beta Headers"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"The Files API is in beta"},{"type":"text","text":" — you must include the beta header:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"anthropic-beta: files-api-2025-04-14"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"SDK handling:"},{"type":"text","text":"\n- Official SDKs (Python, Node.js) set the header automatically when using "},{"type":"text","marks":[{"type":"code"}],"text":"beta.files.upload()"},{"type":"text","text":"\n- Direct API calls require manual header inclusion"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Using Uploaded Files in Messages"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Reference via "},{"type":"text","marks":[{"type":"code"}],"text":"file_id"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\n# 1. Upload once\nuploaded = client.beta.files.upload(\n    file=(\n        \"contract.pdf\",\n        open(\"contract.pdf\", \"rb\"),\n        \"application/pdf\"\n    )\n)\nprint(f\"Uploaded: {uploaded.id}\")  # file_abc123xyz\n\n# 2. Ask multiple questions using the same file_id\nquestions = [\n    \"What are the key terms and conditions?\",\n    \"What is the termination clause?\",\n    \"Summarize the payment schedule.\"\n]\n\nfor question in questions:\n    response = client.beta.messages.create(\n        model=\"claude-opus-4-8\",\n        max_tokens=16000,\n        messages=[{\n            \"role\": \"user\",\n            \"content\": [\n                {\"type\": \"text\", \"text\": question},\n                {\n                    \"type\": \"document\",  # For PDFs/text\n                    \"source\": {\n                        \"type\": \"file\",\n                        \"file_id\": uploaded.id\n                    }\n                }\n            ]\n        }]\n    )\n    \n    text = next((b.text for b in response.content if b.type == \"text\"), \"\")\n    print(f\"Q: {question}\")\n    print(f\"A: {text[:200]}...\\n\")\n\n# 3. Clean up when done\nclient.beta.files.delete(uploaded.id)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key difference:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"With regular file attachments, you send the file contents with every request, but with the Files API, you upload once and then reference the returned "},{"type":"text","marks":[{"type":"code"}],"text":"file_id"},{"type":"text","text":" in subsequent Messages requests.\""}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Content Block Types"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"File Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Content Block"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Example"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PDFs, TXT, DOCX"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"document"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"{\"type\": \"document\", \"source\": {\"type\": \"file\", \"file_id\": uploaded.id}}"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Images (PNG, JPEG)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"image"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"{\"type\": \"image\", \"source\": {\"type\": \"file\", \"file_id\": image_file.id}}"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Supported File Formats"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"PDFs & Documents"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PDF"},{"type":"text","text":" — Text extraction + image rendering"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"TXT"},{"type":"text","text":" — Plain text"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"DOCX"},{"type":"text","text":" — Word documents"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"ODT"},{"type":"text","text":" — OpenDocument Text"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"EPUB"},{"type":"text","text":" — E-books"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Images"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PNG"},{"type":"text","text":" — "},{"type":"text","marks":[{"type":"code"}],"text":"image/png"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"JPEG/JPG"},{"type":"text","text":" — "},{"type":"text","marks":[{"type":"code"}],"text":"image/jpeg"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"GIF"},{"type":"text","text":" — "},{"type":"text","marks":[{"type":"code"}],"text":"image/gif"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"WebP"},{"type":"text","text":" — "},{"type":"text","marks":[{"type":"code"}],"text":"image/webp"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Datasets"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"CSV"},{"type":"text","text":" — Used with code execution tool"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"JSON"},{"type":"text","text":" — Structured data"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"XLSX"},{"type":"text","text":" — Excel spreadsheets"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Note:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"The file extension or mimeType in most cases. Sending a text file as "},{"type":"text","marks":[{"type":"code"}],"text":"application/pdf"},{"type":"text","text":", or omitting the mimeType entirely (in which case it becomes "},{"type":"text","marks":[{"type":"code"}],"text":"application/octet-stream"},{"type":"text","text":"), both succeeded.\""}]}]},{"type":"paragraph","content":[{"type":"text","text":"Type mismatches are checked at the point of referencing via "},{"type":"text","marks":[{"type":"code"}],"text":"document"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"code"}],"text":"image"},{"type":"text","text":" block."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"File Size Limits"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Constraint"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Limit"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Max per file"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"500 MB"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Max per organization"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"500 GB total"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Original limit"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"32 MB (web upload) vs 500 MB (Files API)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Important improvement:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"The file size limit is 500MB per file and 500GB total per organization.\""}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Complete Workflow Example"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\n# STEP 1: Upload file\nuploaded = client.beta.files.upload(\n    file=(\n        \"financial_report.pdf\",\n        open(\"financial_report.pdf\", \"rb\"),\n        \"application/pdf\"\n    )\n)\nfile_id = uploaded.id\nprint(f\"✓ Uploaded: {file_id}\")\n\n# STEP 2: Make multiple queries\nqueries = [\n    \"Extract all revenue figures from Q1-Q4\",\n    \"What are the key expenses?\",\n    \"Summarize the financial highlights\"\n]\n\nfor query in queries:\n    response = client.beta.messages.create(\n        model=\"claude-opus-4-8\",\n        max_tokens=16000,\n        messages=[{\n            \"role\": \"user\",\n            \"content\": [\n                {\"type\": \"text\", \"text\": query},\n                {\n                    \"type\": \"document\",\n                    \"source\": {\n                        \"type\": \"file\",\n                        \"file_id\": file_id\n                    }\n                }\n            ]\n        }]\n    )\n    \n    answer = next((b.text for b in response.content if b.type == \"text\"), \"\")\n    print(f\"\\n{query}\")\n    print(f\"→ {answer[:300]}...\")\n\n# STEP 3: Delete file when done\nclient.beta.files.delete(file_id)\nprint(f\"✓ Deleted: {file_id}\")"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Managing Files"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"List All Files"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"files = client.beta.files.list()\n\nfor file in files:\n    print(f\"{file.id} - {file.filename} ({file.size_bytes} bytes)\")"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Get File Metadata"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"file_info = client.beta.files.retrieve(file_id=\"file_abc123xyz\")\n\nprint(f\"Filename: {file_info.filename}\")\nprint(f\"Size: {file_info.size_bytes} bytes\")\nprint(f\"MIME Type: {file_info.mime_type}\")\nprint(f\"Created: {file_info.created_at}\")\nprint(f\"Downloadable: {file_info.downloadable}\")"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Download File"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Note: Download may be restricted in some implementations\nfile_content = client.beta.files.download(file_id=\"file_abc123xyz\")\n\nwith open(\"downloaded_report.pdf\", \"wb\") as f:\n    f.write(file_content)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Delete File"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"client.beta.files.delete(file_id=\"file_abc123xyz\")\nprint(\"File deleted successfully\")"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Use Cases"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Persistent Document Analysis"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Upload contract once\ncontract = client.beta.files.upload(file=(\"contract.pdf\", open(...)))\n\n# Ask many questions across different conversations\nquestions = [\n    \"What are the termination terms?\",\n    \"What's the payment schedule?\",\n    \"Are there any legal restrictions?\"\n]\n\nfor q in questions:\n    response = client.messages.create(\n        messages=[{\n            \"content\": [\n                {\"type\": \"text\", \"text\": q},\n                {\"type\": \"document\", \"source\": {\"type\": \"file\", \"file_id\": contract.id}}\n            ]\n        }]\n    )"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Code Execution Input/Output"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Upload CSV for code execution\ncsv_file = client.beta.files.upload(\n    file=(\"data.csv\", open(\"data.csv\", \"rb\"), \"text/csv\")\n)\n\n# Use in code interpreter\nresponse = client.beta.messages.create(\n    model=\"claude-opus-4-8\",\n    max_tokens=16000,\n    messages=[{\n        \"role\": \"user\",\n        \"content\": [\n            {\"type\": \"text\", \"text\": \"Analyze this dataset and find correlations\"},\n            {\n                \"type\": \"document\",\n                \"source\": {\"type\": \"file\", \"file_id\": csv_file.id}\n            }\n        ]\n    }],\n    tools=[{\"name\": \"code_execution\"}]  # Code interpreter tool\n)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Multi-Image Analysis"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Upload multiple images once\nimages = []\nfor img_path in [\"photo1.png\", \"photo2.png\", \"photo3.png\"]:\n    img = client.beta.files.upload(\n        file=(img_path, open(img_path, \"rb\"), \"image/png\")\n    )\n    images.append(img.id)\n\n# Reference all images in one request\nresponse = client.beta.messages.create(\n    messages=[{\n        \"role\": \"user\",\n        \"content\": [\n            {\"type\": \"text\", \"text\": \"Compare these photos and identify differences\"},\n            {\"type\": \"image\", \"source\": {\"type\": \"file\", \"file_id\": images[0]}},\n            {\"type\": \"image\", \"source\": {\"type\": \"file\", \"file_id\": images [support.claude](https://support.claude.com/en/articles/8241126-upload-files-to-claude)}},\n            {\"type\": \"image\", \"source\": {\"type\": \"file\", \"file_id\": images [platform.claude](https://platform.claude.com/docs/en/managed-agents/files)}}\n        ]\n    }]\n)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Practice"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Why"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Upload once, reuse many"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Avoids re-uploading contents"}]}]}]},{"type":"tableRow","c