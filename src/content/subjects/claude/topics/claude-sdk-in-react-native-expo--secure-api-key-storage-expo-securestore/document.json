                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "marks": [
                          {
                            "type": "code"
                          }
                        ],
                        "text": "keychainService"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "string"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Keychain service name (namespace); defaults to bundle ID"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "marks": [
                          {
                            "type": "code"
                          }
                        ],
                        "text": "requireAuthentication"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "boolean"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Require Face ID / Touch ID / biometrics to read the value"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "marks": [
                          {
                            "type": "code"
                          }
                        ],
                        "text": "authenticationPrompt"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "string"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "The biometric prompt text shown to the user"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import * as SecureStore from \"expo-secure-store\";\n\n// Require biometric auth to read the key — maximum security\nawait SecureStore.setItemAsync(\"anthropic_api_key\", apiKey, {\n  keychainAccessible: SecureStore.WHEN_UNLOCKED,\n  requireAuthentication: true,\n  authenticationPrompt: \"Authenticate to access your API key\",\n});\n\n// Reading now triggers Face ID / Touch ID\nconst key = await SecureStore.getItemAsync(\"anthropic_api_key\", {\n  requireAuthentication: true,\n  authenticationPrompt: \"Authenticate to use Claude\",\n});"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "marks": [
                  {
                    "type": "bold"
                  }
                ],
                "text": "iOS note: "
              },
              {
                "type": "text",
                "text": ""
              },
              {
                "type": "text",
                "marks": [
                  {
                    "type": "code"
                  }
                ],
                "text": "requireAuthentication"
              },
              {
                "type": "text",
                "text": " uses LocalAuthentication (Face ID / Touch ID). On iOS, if the user has not set up biometrics, the read will fail. Always handle the "
              },
              {
                "type": "text",
                "marks": [
                  {
                    "type": "code"
                  }
                ],
                "text": "null"
              },
              {
                "type": "text",
                "text": " return case and fall back to prompting the user to re-enter the key."
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Combining SecureStore with the Anthropic SDK"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A practical pattern is a React context that loads the key from SecureStore once, creates the Anthropic client, and makes both available to the component tree:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// context/AnthropicContext.tsx\nimport { createContext, ReactNode, useContext, useEffect, useState } from \"react\";\nimport Anthropic from \"@anthropic-ai/sdk\";\nimport * as SecureStore from \"expo-secure-store\";\n\ntype AnthropicContextValue = {\n  client: Anthropic | null;\n  hasKey: boolean;\n  saveKey: (key: string) => Promise<void>;\n  removeKey: () => Promise<void>;\n};\n\nconst AnthropicContext = createContext<AnthropicContextValue>({\n  client: null,\n  hasKey: false,\n  saveKey: async () => {},\n  removeKey: async () => {},\n});\n\nexport function AnthropicProvider({ children }: { children: ReactNode }) {\n  const [client, setClient] = useState<Anthropic | null>(null);\n\n  async function load() {\n    const key = await SecureStore.getItemAsync(\"anthropic_api_key\");\n    if (key) {\n      setClient(new Anthropic({ apiKey: key, dangerouslyAllowBrowser: true }));\n    } else {\n      setClient(null);\n    }\n  }\n\n  useEffect(() => { load(); }, []);\n\n  async function saveKey(key: string) {\n    await SecureStore.setItemAsync(\"anthropic_api_key\", key);\n    await load();\n  }\n\n  async function removeKey() {\n    await SecureStore.deleteItemAsync(\"anthropic_api_key\");\n    setClient(null);\n  }\n\n  return (\n    <AnthropicContext.Provider value={{ client, hasKey: !!client, saveKey, removeKey }}>\n      {children}\n    </AnthropicContext.Provider>\n  );\n}\n\nexport const useAnthropic = () => useContext(AnthropicContext);"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Wrap the app root with "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "<AnthropicProvider>"
          },
          {
            "type": "text",
            "text": " and consume with "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "useAnthropic()"
          },
          {
            "type": "text",
            "text": " in any screen."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "When to Use SecureStore vs a Backend Proxy"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "SecureStore and a backend proxy are not mutually exclusive — they solve different problems:"
          }
        ]
      },
      {
        "type": "table",
        "content": [
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableHeader",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Scenario"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableHeader",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Best approach"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Users bring their own Anthropic API key"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Store key in SecureStore; client calls API directly"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "App provides AI features billed to you (the developer)"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Backend proxy; key never leaves your server"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "User auth token / session credential"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "SecureStore (for the user token), proxy (for the API key)"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Development / testing on a single device"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "marks": [
                          {
                            "type": "code"
                          }
                        ],
                        "text": "EXPO_PUBLIC_"
                      },
                      {
                        "type": "text",
                        "text": " env var (never ship to production)"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Limitations and Edge Cases"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "2 KB value limit. "
                  },
                  {
                    "type": "text",
                    "text": "SecureStore values are limited to 2 048 bytes. An Anthropic API key is ~100 bytes so this is not an issue, but avoid storing JWTs or large blobs directly. For larger data, encrypt it with a random key and store only that key in SecureStore."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Not available in Expo Go. "
                  },
                  {
                    "type": "text",
                    "text": "SecureStore requires native code that is not included in the Expo Go client. During development, use "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "npx expo prebuild"
                  },
                  {
                    "type": "text",
                    "text": " and run via "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "npx expo run:ios"
                  },
                  {
                    "type": "text",
                    "text": " / "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "npx expo run:android"
                  },
                  {
                    "type": "text",
                    "text": ", or use an Expo Development Build."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Not a cross-device sync mechanism. "
                  },
                  {
                    "type": "text",
                    "text": "The value is local to the device. If the user reinstalls the app or switches devices, the key is gone. If sync is needed, store the key on your server (encrypted) and fetch it after authentication."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Rooted / jailbroken devices. "
                  },
                  {
                    "type": "text",
                    "text": "On heavily compromised devices, the security guarantees weaken. Hardware-backed keys (Android Keystore with StrongBox, Secure Enclave on iOS) resist this better than software-only encryption. Expo SecureStore uses hardware backing on supported devices automatically."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Key rotation. "
                  },
                  {
                    "type": "text",
                    "text": "If the Anthropic API key needs to be rotated (e.g., it was leaked), users must update their stored key manually. For app-level keys, a proxy lets you rotate the server-side key without any app update."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing Secure Storage"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "SecureStore is a native module, so Jest mocks it by default. Add a mock for tests:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// __mocks__/expo-secure-store.ts\nconst store: Record<string, string> = {};\n\nexport const setItemAsync = jest.fn(async (key: string, value: string) => {\n  store[key] = value;\n});\n\nexport const getItemAsync = jest.fn(async (key: string) => {\n  return store[key] ?? null;\n});\n\nexport const deleteItemAsync = jest.fn(async (key: string) => {\n  delete store[key];\n});\n\nexport const WHEN_UNLOCKED = \"AccessibleWhenUnlocked\";"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// __tests__/ApiKeySettings.test.tsx\nimport { fireEvent, render, waitFor } from \"@testing-library/react-native\";\nimport * as SecureStore from \"expo-secure-store\";\nimport ApiKeySettings from \"../app/settings\";\n\nbeforeEach(() => jest.clearAllMocks());\n\ntest(\"saves a valid key to SecureStore\", async () => {\n  const { getByPlaceholderText, getByText } = render(<ApiKeySettings />);\n  fireEvent.changeText(getByPlaceholderText(\"sk-ant-...\"), \"sk-ant-\" + \"A\".repeat(90));\n  fireEvent.press(getByText(\"Save key\"));\n  await waitFor(() =>\n    expect(SecureStore.setItemAsync).toHaveBeenCalledWith(\n      \"anthropic_api_key\",\n      \"sk-ant-\" + \"A\".repeat(90)\n    )\n  );\n});\n\ntest(\"rejects a key that does not match the pattern\", async () => {\n  const { getByPlaceholderText, getByText } = render(<ApiKeySettings />);\n  fireEvent.changeText(getByPlaceholderText(\"sk-ant-...\"), \"bad-key\");\n  fireEvent.press(getByText(\"Save key\"));\n  await waitFor(() =>\n    expect(SecureStore.setItemAsync).not.toHaveBeenCalled()\n  );\n});"
          }
        ]
      },
