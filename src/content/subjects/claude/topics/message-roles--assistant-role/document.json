{"format":"tiptap/v1","updatedAt":"2026-06-20T12:40:10.858Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"An "},{"type":"text","marks":[{"type":"bold"}],"text":"assistant message"},{"type":"text","text":" is the response generated by the chat model based on the input it receives from user messages. It represents the "},{"type":"text","marks":[{"type":"bold"}],"text":"output of the chat model"},{"type":"text","text":" and is what the user sees as the assistant's reply in the conversation."}]},{"type":"paragraph","content":[{"type":"text","text":"But there's a second, more powerful use: "},{"type":"text","marks":[{"type":"bold"}],"text":"you can strategically provide assistant messages"},{"type":"text","text":" to guide or train the assistant to behave in a desired manner (few-shot prompting)."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Two uses of assistant messages"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Normal use: Model's response"}]},{"type":"paragraph","content":[{"type":"text","text":"When you send a user message, the model generates an assistant message as its response:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"role\": \"user\",\n  \"content\": \"Explain this code.\"\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"→ Model responds with:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"role\": \"assistant\",\n  \"content\": \"The code defines a function that...\"\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"This is the "},{"type":"text","marks":[{"type":"bold"}],"text":"standard flow"},{"type":"text","text":": user asks, assistant responds."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Strategic use: Pre-filling responses (few-shot examples)"}]},{"type":"paragraph","content":[{"type":"text","text":"You can "},{"type":"text","marks":[{"type":"bold"}],"text":"manually include assistant messages"},{"type":"text","text":" in your prompt to provide examples of desired behavior. This is how you do "},{"type":"text","marks":[{"type":"bold"}],"text":"few-shot prompting"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"model\": \"claude-sonnet-4-20250514\",\n  \"max_tokens\": 1024,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Classify this email.\"\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": \"Category: Billing. Reason: The email is about incorrect charging.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Classify this email.\"\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": \"Category: Bug. Reason: A specific feature is crashing.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Classify this email.\"\n    }\n  ]\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"Here, the assistant messages are "},{"type":"text","marks":[{"type":"bold"}],"text":"examples"},{"type":"text","text":" you provide, not the model's actual responses. The model learns the pattern and continues it for the final user message."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key characteristics of assistant messages"}]},{"type":"paragraph","content":[{"type":"text","text":"According to prompt engineering documentation:"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"What they do:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Maintain context"},{"type":"text","text":" by including them in the dialogue history"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Enable continuous conversation"},{"type":"text","text":" where the model provides consistent responses while referencing past assistant messages"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Guide behavior"},{"type":"text","text":" when used strategically as examples"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"When they appear:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Automatically"},{"type":"text","text":": When the model replies to user queries"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Manually"},{"type":"text","text":": When you pre-fill them in your prompt to teach patterns"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Assistant message vs. system message vs. user message"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":"left"},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Role"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":"left"},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Purpose"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":"left"},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Who provides it?"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"System"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"High-level instructions, behavioral policies, tone of voice"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Developer (setup)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"User"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Questions, prompts, commands from the human"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Human user"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Assistant"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Model's response to user inputs based on system context"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Model (or pre-filled by developer for examples)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"The different roles help "},{"type":"text","marks":[{"type":"bold"}],"text":"set context and direct the conversation efficiently"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Practical patterns for assistant messages"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern 1: Multi-turn conversation"}]},{"type":"paragraph","content":[{"type":"text","text":"Include the full conversation history with assistant responses:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Hello, Claude.\"\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": \"Hi! I'm Claude. How can I help you?\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Can you explain LLMs to me?\"\n    }\n  ]\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"The model "},{"type":"text","marks":[{"type":"bold"}],"text":"references past assistant messages"},{"type":"text","text":" to provide consistent, context-aware responses."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern 2: Few-shot prompting with examples"}]},{"type":"paragraph","content":[{"type":"text","text":"Provide examples of desired behavior:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Q: What is 2+2?\"\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": \"A: 4\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Q: What is 3+3?\"\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": \"A: 6\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Q: What is 5+5?\"\n    }\n  ]\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"This teaches the model the "},{"type":"text","marks":[{"type":"bold"}],"text":"Q: → A:"},{"type":"text","text":" pattern."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern 3: Prefilled response (schema guidance)"}]},{"type":"paragraph","content":[{"type":"text","text":"On supported models, you can provide a "},{"type":"text","marks":[{"type":"bold"}],"text":"prefilled assistant message"},{"type":"text","text":" to shape Claude's response:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"role\": \"assistant\",\n  \"content\": \"The answer is (\"\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"This \"puts words in Claude's mouth\" to guide multiple-choice answers. Claude will complete from that starting point."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern 4: Structured output with assistant pre-fill"}]},{"type":"paragraph","content":[{"type":"text","text":"For JSON schemas, you can pre-fill the opening:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Classify this email.\"\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": \"{\"\n    }\n  ]\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"This forces Claude to output JSON, starting with the opening brace."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern 5: Step-by-step reasoning examples"}]},{"type":"paragraph","content":[{"type":"text","text":"Teach the model to think before answering:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Solve this math problem.\"\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": \"<thinking>\\n1. First, identify what we know.\\n2. Then, set up the equation.\\n3. Finally, solve for x.\\n</thinking>\\n\\n<answer>\\nx = 5\\n</answer>\"\n    }\n  ]\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"This teaches Claude to use "},{"type":"text","marks":[{"type":"bold"}],"text":"thinking tags"},{"type":"text","text":" and show reasoning before the final answer."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why assistant messages matter"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Context management"}]},{"type":"paragraph","content":[{"type":"text","text":"Assistant messages allow the model to "},{"type":"text","marks":[{"type":"bold"}],"text":"maintain and separate different types of context"},{"type":"text","text":" (instructions vs. queries vs. responses), making conversation clearer and more structured."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Consistency"}]},{"type":"paragraph","content":[{"type":"text","text":"By including past assistant messages in the dialogue history, the model can provide "},{"type":"text","marks":[{"type":"bold"}],"text":"consistent responses while referencing past assistant messages"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. Behavior guidance"}]},{"type":"paragraph","content":[{"type":"text","text":"You can strategically use assistant messages to "},{"type":"text","marks":[{"type":"bold"}],"text":"guide or train the assistant to behave in a desired manner"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Common mistakes"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mistake 1: Not including conversation history"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"// ❌ Bad: No history\n{\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Can you explain LLMs to me?\"\n    }\n  ]\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"Without prior assistant messages, the model has "},{"type":"text","marks":[{"type":"bold"}],"text":"no context"},{"type":"text","text":" from previous turns."}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"// ✅ Good: Full history\n{\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Hello, Claude.\"\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": \"Hi! How can I help you?\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Can you explain LLMs to me?\"\n    }\n  ]\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mistake 2: Overusing assistant pre-fills"}]},{"type":"paragraph","content":[{"type":"text","text":"Only use assistant pre-fills when they genuinely help guide the response (e.g., for structured output). Don't pre-fill entire responses."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mistake 3: Confusing assistant messages with system messages"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"System message"},{"type":"text","text":": \"You are a senior engineer\" (constant role/behavior)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Assistant message"},{"type":"text","text":": \"Here's the refactored code...\" (example of desired output)"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Don't put role instructions in assistant messages; put them in the system message."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Summary"}]},{"type":"paragraph","content":[{"type":"text","text":"An "},{"type":"text","marks":[{"type":"bold"}],"text":"assistant message"},{"type":"text","text":" is:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"The model's response"},{"type":"text","text":" to user inputs based on the system context (standard flow)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"A strategic tool"},{"type":"text","text":" for few-shot prompting when you pre-fill examples of desired behavior"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Key uses:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Maintain conversation history"},{"type":"text","text":" for context-aware responses"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Teach patterns"},{"type":"text","text":" through examples (few-shot prompting)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Guide output format"},{"type":"text","text":" through pre-filling (schema guidance)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Enable continuous conversation"},{"type":"text","text":" where the model references past assistant messages"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Assistant messages are essential for "},{"type":"text","marks":[{"type":"bold"}],"text":"structured, consistent, and trainable interactions"},{"type":"text","text":" with chat models like Claude."}]}]}}
