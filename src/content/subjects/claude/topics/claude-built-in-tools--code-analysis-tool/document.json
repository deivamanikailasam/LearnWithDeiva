{"format":"tiptap/v1","updatedAt":"2026-06-20T10:46:12.153Z","doc":{"type":"doc","content":[{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude Code"},{"type":"text","text":" is an agentic coding environment where Claude can read files, run commands, search codebases, and call external tools on your behalf."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Under the hood, Claude Code sessions get a "},{"type":"text","marks":[{"type":"bold"}],"text":"pool of tools"},{"type":"text","text":": built‑in tools like shell execution, file reading/writing, search, plus any MCP‑provided tools and skills you’ve configured."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Recent updates added capabilities like:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Remote control"},{"type":"text","text":" of a live Claude Code session from browser/mobile."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Scheduled tasks"},{"type":"text","text":" to run recurring workflows."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Plugins / skills ecosystem"},{"type":"text","text":" for standardized dev workflows."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Parallel agents"},{"type":"text","text":" to tackle large refactors or multi‑file changes at once."}]}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Example: The tool pool might include "},{"type":"text","marks":[{"type":"code"}],"text":"BashTool"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"FileReadTool"},{"type":"text","text":", DB query tools from MCP, and custom linting or review skills; Claude chooses which to call step‑by‑step during a coding task."}]}]}}
