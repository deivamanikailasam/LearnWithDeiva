"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Developer copies key into "},{"type":"text","marks":[{"type":"code"}],"text":"config.py"},{"type":"text","text":":"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"python API_KEY = \"sk-ant-api03-xxxxx\""},{"type":"hardBreak"},{"type":"hardBreak"},{"type":"text","text":"2. Commits to GitHub"},{"type":"hardBreak"},{"type":"text","text":"3. GitHub bots detect pattern within **5 minutes**"},{"type":"hardBreak"},{"type":"text","text":"4. attacker scrapes key and runs: `bash curl -H \"x-api-key: sk-ant-api03-xxxxx\" https://api.anthropic.com/v1/messages ``"},{"type":"hardBreak"},{"type":"text","text":"5. $50,000 bill in 24 hours"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How to prevent:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Add "},{"type":"text","marks":[{"type":"code"}],"text":".env"},{"type":"text","text":" to "},{"type":"text","marks":[{"type":"code"}],"text":".gitignore"},{"type":"text","text":" "},{"type":"text","marks":[{"type":"bold"}],"text":"before"},{"type":"text","text":" creating it"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use "},{"type":"text","marks":[{"type":"code"}],"text":"git-secrets"},{"type":"text","text":" to block commits with credential patterns"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Never hardcode keys; always use environment variables"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Scenario 2: Production Key Exposed in Docker Image"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What happens:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type"