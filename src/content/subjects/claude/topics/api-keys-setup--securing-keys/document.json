{"format":"tiptap/v1","updatedAt":"2026-06-21T01:48:43.099Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Secure your Claude API key by "},{"type":"text","marks":[{"type":"bold"}],"text":"never hardcoding it"},{"type":"text","text":" in code, "},{"type":"text","marks":[{"type":"bold"}],"text":"always using environment variables"},{"type":"text","text":" ("},{"type":"text","marks":[{"type":"code"}],"text":"ANTHROPIC_API_KEY"},{"type":"text","text":") or a "},{"type":"text","marks":[{"type":"bold"}],"text":"secrets manager"},{"type":"text","text":" (AWS Secrets Manager, HashiCorp Vault) in production, "},{"type":"text","marks":[{"type":"bold"}],"text":"creating separate keys per environment"},{"type":"text","text":" (dev/staging/prod), "},{"type":"text","marks":[{"type":"bold"}],"text":"rotating keys every 90 days"},{"type":"text","text":", and "},{"type":"text","marks":[{"type":"bold"}],"text":"adding "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":".env"},{"type":"text","marks":[{"type":"bold"}],"text":" to "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":".gitignore"},{"type":"text","marks":[{"type":"bold"}],"text":" before creating it"},{"type":"text","text":". If a key is compromised, "},{"type":"text","marks":[{"type":"bold"}],"text":"deactivate it immediately"},{"type":"text","text":" in console.anthropic.com and generate a new one."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why API Key Security Matters"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What Happens When a Key Is Leaked"}]},{"type":"paragraph","content":[{"type":"text","text":"An exposed Claude API key can lead to:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Impact"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Consequence"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Unauthorized usage"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Anyone can call the API using your key, consuming your credits"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Unexpected charges"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"API keys have no expiry; attackers can generate massive bills quickly"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Data exposure"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"If your app processes sensitive data, attackers can access it through Claude"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Reputation damage"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Compromised credentials may violate compliance requirements (SOC 2, HIPAA, etc.)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"90% of API key leaks are caused by "},{"type":"text","marks":[{"type":"bold"}],"text":"human error"},{"type":"text","text":"—mostly accidentally committing keys to Git or hardcoding them in config files."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Core Security Principles"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Never Hardcode API Keys"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem:"},{"type":"text","text":" Hardcoding keys like this is the #1 cause of leaks:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ❌ WRONG - Never do this\nimport anthropic\n\nclient = anthropic.Anthropic(\n    api_key=\"sk-ant-api03-your-actual-key-here\"  # EXPOSED!\n)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why it's bad:"},{"type":"text","text":"\n- Keys end in "},{"type":"text","marks":[{"type":"bold"}],"text":"version history forever"},{"type":"text","text":" even after deletion\n- Anyone with repo access can run "},{"type":"text","marks":[{"type":"code"}],"text":"git log"},{"type":"text","text":" to find old keys\n- Keys get "},{"type":"text","marks":[{"type":"bold"}],"text":"accidentally exposed"},{"type":"text","text":" in PRs, screenshots, or logs"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Solution: Use environment variables"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ CORRECT\nimport anthropic\nimport os\n\nclient = anthropic.Anthropic(\n    api_key=os.environ.get(\"ANTHROPIC_API_KEY\")\n)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Never Commit Keys to Git"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem:"},{"type":"text","text":" GitHub has "},{"type":"text","marks":[{"type":"bold"}],"text":"automated bots"},{"type":"text","text":" scanning every public commit for API key patterns 24/7. By the time you notice a leak, attackers have already grabbed it."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Solution: Add "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":".env"},{"type":"text","marks":[{"type":"bold"}],"text":" to "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":".gitignore"},{"type":"text","marks":[{"type":"bold"}],"text":" BEFORE creating it"}]},{"type":"codeBlock","attrs":{"language":"gitignore"},"content":[{"type":"text","text":"# Add this to .gitignore first\n.env\n*.env\n.env.local\n.env.*.local\n\n# Then create your .env file"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Bonus:"},{"type":"text","text":" Use tools like "},{"type":"text","marks":[{"type":"bold"}],"text":"git-secrets"},{"type":"text","text":" to block commits containing credential patterns:"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Install git-secrets\ngit secrets install --global\n\n# Register common patterns\ngit secrets add sk-ant-api\ngit secrets add ANTHROPIC_API_KEY\n\n# Now it will block commits with secrets\ngit secrets --scan"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Separate Keys for Each Environment"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem:"},{"type":"text","text":" Using the same key for dev and production means if your dev environment gets compromised (via dependency vulnerability or misconfigured server), your production app is fully exposed."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Solution: Create separate keys per environment"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Environment"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Key Purpose"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Security Level"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Development"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Individual developer testing"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Low (local only)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Staging"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Integration testing"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Medium (team access)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Production"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Live application"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"High (secrets manager)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How to implement:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Go to "},{"type":"text","marks":[{"type":"bold"}],"text":"console.anthropic.com → API Keys"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Create keys with descriptive names:"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- "},{"type":"text","marks":[{"type":"code"}],"text":"dev-personal-<your-name>"},{"type":"text","text":" - "},{"type":"text","marks":[{"type":"code"}],"text":"staging-integration-tests"},{"type":"text","text":" - "},{"type":"text","marks":[{"type":"code"}],"text":"production-main-app"},{"type":"text","text":"\n3. Use workspaces to scope keys by project/environment"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Use Least Privilege"}]},{"type":"paragraph","content":[{"type":"text","text":"Every API key should only have the permissions it "},{"type":"text","marks":[{"type":"bold"}],"text":"actually needs"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How to apply:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"If your key only needs to call "},{"type":"text","marks":[{"type":"code"}],"text":"messages.create"},{"type":"text","text":", don't give it admin access"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"If your key only needs to access one workspace, scope it to that workspace"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use project-scoping features in the Anthropic console to limit what the key can access"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. Rotate Keys Regularly"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem:"},{"type":"text","text":" API keys "},{"type":"text","marks":[{"type":"bold"}],"text":"don't expire"},{"type":"text","text":" until you delete them. Attackers can use inactive keys indefinitely."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Solution: Rotate every 90 days"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rotation process:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Create a new key"},{"type":"text","text":" before revoking the old one"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Update all applications"},{"type":"text","text":" using the key"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Revoke the old key"},{"type":"text","text":" only after confirming the new one works"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Set up alerts"},{"type":"text","text":" for key usage anomalies"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Automated rotation script (example):"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\nimport os\nfrom datetime import datetime\n\ndef rotate_api_key():\n    # 1. Create new key (via Anthropic API)\n    new_key = create_new_anthropic_key(\"rotated-2026-06-21\")\n    \n    # 2. Save to secrets manager\n    save_to_secrets_manager(\"ANTHROPIC_API_KEY\", new_key)\n    \n    # 3. Deploy to pick up new key\n    trigger_deployment()\n    \n    # 4. Revoke old key\n    old_key = get_old_key_from_secrets()\n    revoke_anthropic_key(old_key)\n    \n    # 5. Log rotation\n    log_rotation(\"2026-06-21\", new_key[:10])\n\nrotate_api_key()"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"6. Know Where Every Key Lives"}]},{"type":"paragraph","content":[{"type":"text","text":"If someone asked you to list every API key your project uses and where each is stored, how long would it take?"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"If more than a few seconds, you have a visibility problem."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Solution:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Keep all keys in "},{"type":"text","marks":[{"type":"bold"}],"text":"one organized secure place"},{"type":"text","text":" (secrets manager)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Track: who has access, when last rotated, which service it belongs to"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Audit historical commits for accidental leaks"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"7. Have an Incident Response Plan"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Know in advance:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Which keys are most critical"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"How to revoke and regenerate each one"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Who needs to be notified if compromised"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Incident response checklist:"}]},{"type":"codeBlock","attrs":{"language":"markdown"},"content":[{"type":"text","text":"# API Key Compromise Response\n\n## Immediate Actions (0-15 minutes)\n1. [ ] Deactivate key in console.anthropic.com\n2. [ ] Generate new key\n3. [ ] Update production deployment\n4. [ ] Notify security team\n\n## Investigation (15-60 minutes)\n5. [ ] Check usage logs for anomalies\n6. [ ] Identify how key was exposed\n7. [ ] Review access logs\n\n## Remediation (1-24 hours)\n8. [ ] Rotate all related keys\n9. [ ] Update security policies\n10. [ ] Document incident"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Secure Storage Methods"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Method 1: Environment Variables (Local Development)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best for:"},{"type":"text","text":" Local development, single-user scripts"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Setup:"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"macOS / Linux"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# One-time in current terminal\nexport ANTHROPIC_API_KEY=\"sk-ant-api03-your-key\"\n\n# Permanent (~/.zshrc or ~/.bashrc)\necho 'export ANTHROPIC_API_KEY=\"sk-ant-api03-your-key\"' >> ~/.zshrc\nsource ~/.zshrc"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Windows PowerShell"}]},{"type":"codeBlock","attrs":{"language":"powershell"},"content":[{"type":"text","text":"# Current session\n$env:ANTHROPIC_API_KEY = \"sk-ant-api03-your-key\"\n\n# Permanent\n[System.Environment]::SetEnvironmentVariable(\n  \"ANTHROPIC_API_KEY\", \n  \"sk-ant-api03-your-key\", \n  \"User\"\n)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Verification:"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"echo $ANTHROPIC_API_KEY\n# Should print your key (not empty)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Method 2: "},{"type":"text","marks":[{"type":"code"}],"text":".env"},{"type":"text","text":" File (Local Projects)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best for:"},{"type":"text","text":" Local projects with multiple developers, CLI tools"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Setup:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Create "},{"type":"text","marks":[{"type":"code"}],"text":".env"},{"type":"text","text":" file:"}]}]}]},{"type":"codeBlock","attrs":{"language":"env"},"content":[{"type":"text","text":"ANTHROPIC_API_KEY=sk-ant-api03-your-key"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Add to "},{"type":"text","marks":[{"type":"code"}],"text":".gitignore"},{"type":"text","text":" "},{"type":"text","marks":[{"type":"bold"}],"text":"before creating the file"},{"type":"text","text":":"}]}]}]},{"type":"codeBlock","attrs":{"language":"gitignore"},"content":[{"type":"text","text":".env\n.env.local"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Load in Python:"}]}]}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from dotenv import load_dotenv\nimport os\n\nload_dotenv(\".env\")\nclient = anthropic.Anthropic()  # automatically reads ANTHROPIC_API_KEY"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Load in Node.js:"}]}]}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import \"dotenv/config\";\nimport Anthropic from \"@anthropic-ai/sdk\";\n\nconst client = new Anthropic();  // reads from env"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"⚠️ Critical:"},{"type":"text","text":" Never commit "},{"type":"text","marks":[{"type":"code"}],"text":".env"},{"type":"text","text":" to Git. Add it to "},{"type":"text","marks":[{"type":"code"}],"text":".gitignore"},{"type":"text","text":" "},{"type":"text","marks":[{"type":"bold"}],"text":"before"},{"type":"text","text":" creating it."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Method 3: Secrets Manager (Production)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best for:"},{"type":"text","text":" Production applications, cloud deployments, CI/CD pipelines"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"AWS Secrets Manager"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Setup:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Create secret:"}]}]}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"aws secretsmanager create-secret \\\n  --name anthropic/api-key \\\n  --secret-string \"sk-ant-api03-your-key\" \\\n  --description \"Claude API key for production\""}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Least-privilege IAM policy:"}]}]}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"secretsmanager:GetSecretValue\"\n      ],\n      \"Resource\": [\n        \"arn:aws:secretsmanager:region:account:secret:anthropic/api-key\"\n      ]\n    }\n  ]\n}"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Fetch in code:"}]}]}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import boto3\nimport anthropic\n\nsecrets_client = boto3.client(\"secretsmanager\")\nsecret = secrets_client.get_secret_value(Name=\"anthropic/api-key\")\n\napi_key = secret[\"SecretString\"]\nclient = anthropic.Anthropic(api_key=api_key)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"HashiCorp Vault"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best for:"},{"type":"text","text":" Enterprise environments, multi-cloud deployments"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Setup:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Store secret:"}]}]}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"vault kv put secret/anthropic/api-key value=\"sk-ant-api03-your-key\""}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Create policy:"}]}]}]},{"type":"codeBlock","attrs":{"language":"hcl"},"content":[{"type":"text","text":"# vault-policy.hcl\npath \"secret/anthropic/api-key\" {\n  capabilities = [\"read\"]\n}"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Fetch in code:"}]}]}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import hvac\nimport anthropic\n\nvault = hvac.Client()\nvault.token = \"your-vault-token\"\n\nsecret = vault.read(\"secret/anthropic/api-key\")\napi_key = secret[\"data\"][\"value\"]\n\nclient = anthropic.Anthropic(api_key=api_key)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Vault best practices:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use AppRole or Kubernetes auth methods"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Enable audit logging"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Regularly review and tighten policies"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Prefer explicit paths over wildcards"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Method 4: Workload Identity Federation (Advanced Production)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best for:"},{"type":"text","text":" CI/CD, Kubernetes, cloud workloads (May 2026 release)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it does:"}]},{"type":"paragraph","content":[{"type":"text","text":"Replaces static API keys ("},{"type":"text","marks":[{"type":"code"}],"text":"sk-ant-..."},{"type":"text","text":") with "},{"type":"text","marks":[{"type":"bold"}],"text":"short-lived JWT tokens"},{"type":"text","text":" (max 1 hour expiry) from your Identity Provider (AWS IAM, Google Cloud, GitHub Actions, etc.)."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How it works:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Workload obtains JWT from its IdP (signed ID token)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Present JWT to Anthropic's "},{"type":"text","marks":[{"type":"code"}],"text":"/v1/oau