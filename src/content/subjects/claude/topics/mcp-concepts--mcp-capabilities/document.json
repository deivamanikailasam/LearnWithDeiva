{"format":"tiptap/v1","updatedAt":"2026-06-22T03:51:24.042Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"In MCP (Model Context Protocol), "},{"type":"text","marks":[{"type":"bold"}],"text":"Capability Negotiation"},{"type":"text","text":" is the "},{"type":"text","marks":[{"type":"bold"}],"text":"initialization handshake"},{"type":"text","text":" where clients and servers explicitly declare what features they support. This two-way exchange determines which protocol features are available for the entire session."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","text":"Capability negotiation is "},{"type":"text","marks":[{"type":"bold"}],"text":"not just advertisement"},{"type":"text","text":"—it's a "},{"type":"text","marks":[{"type":"bold"}],"text":"contract"},{"type":"text","text":" that defines:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Purpose"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Feature discovery"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Both sides learn what the other can do"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Security boundary"}