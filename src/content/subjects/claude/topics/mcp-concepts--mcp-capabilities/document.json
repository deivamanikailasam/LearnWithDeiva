type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Two-way exchange"},{"type":"text","text":": Client declares what it supports; server declares what it provides"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Security contract"},{"type":"text","text":": Defines trust boundaries for the entire session"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Must-respect rule"},{"type":"text","text":": Neither side can use undeclared capabilities"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"One round trip"},{"type":"text","text":": Entire exchange completes quickly"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Version confirmation"},{"type":"text","text":": Both sides agree on protocol version"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"No magic"},{"type":"text","text":": Only methods explicitly advertised can be used"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Capability negotiation is MCP's way of ensuring "},{"type":"text","marks":[{"type":"bold"}],"text":"explicit, transparent agreement"},{"type":"text","text":" on what a session can do—preventing both security issues and unexpected behavior."}]}]}}
