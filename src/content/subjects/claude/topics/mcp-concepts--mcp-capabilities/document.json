ams\": {\n    \"protocolVersion\": \"2025-06-18\",\n    \"capabilities\": {\n      \"sampling\": {},\n      \"roots\": {\n        \"listChanged\": true\n      },\n      \"experimental\": {\n        \"featureX\": true\n      }\n    },\n    \"clientInfo\": {\n      \"name\": \"Claude Desktop\",\n      \"version\": \"1.0\"\n    }\n  }\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Client capabilities"},{"type":"text","text":" (what the client supports):\n| Capability | Purpose |\n|------------|---------|\n| "},{"type":"text","marks":[{"type":"code"}],"text":"sampling"},{"type":"text","text":" | Client can run LLM completions on server's behalf |\n| "},{"type":"text","marks":[{"type":"code"}],"text":"roots"},{"type":"text","text":" | Client can provide file system roots (directories) |\n| "},{"type":"text","marks":[{"type":"code"}],"text":"listChanged"},{"type":"text","text":" | Client supports notifications when root list changes |\n| "},{"type":"text","marks":[{"type":"code"}],"text":"experimental"},{"type":"text","text":" | Experimental/preview features |"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 2: Server Responds with Its Capabilities"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 1,\n  \"result\": {\n    \"protocolVersion\": \"2025-06-18\",\n    \"capabilities\": {\n      \"tools\": {\n        \"listChanged\": true\n      },\n      \"resources\": {\n        \"subscribe\": true,\n        \"listChanged\": true\n      },\n      \"prompts\": {\n        \"listChanged\": true\n      },\n      \"logging\": {}\n    },\n    \"serverInfo\": {\n      \"name\": \"Weather MCP Server\",\n      \"version\": \"2.1.0\"\n    }\n  }\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Server capabilities"},{"type":"text","text":" (what the server provides):\n| Capability | Purpose |\n|------------|---------|\n| "},{"type":"text","marks":[{"type":"code"}],"text":"tools"},{"type":"text","text":" | Server exposes tools that can be invoked |\n| "},{"type":"text","marks":[{"type":"code"}],"text":"tools.listChanged"},{"type":"text","text":" | Server notifies when tool list changes |\n| "},{"type":"text","marks":[{"type":"code"}],"text":"resources"},{"type":"text","text":" | Server exposes resources (files, data) |\n| "},{"type":"text","marks":[{"type":"code"}],"text":"resources.subscribe"},{"type":"text","text":" | Server supports resource subscriptions |\n| "},{"type":"text","marks":[{"type":"code"}],"text":"resources.listChanged"},{"type":"text","text":" | Server notifies when resource list changes |\n| "},{"type":"text","marks":[{"type":"code"}],"text":"prompts"},{"type":"text","text":" | Server provides prompt templates |\n| "},{"type":"text","marks":[{"type":"code"}],"text":"prompts.listChanged"},{"type":"text","text":" | Server notifies when prompt list changes |\n| "},{"type":"text","marks":[{"type":"code"}],"text":"logging"},{"type":"text","text":" | Server supports log-level control |"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 3: Client Sends "},{"type":"text","marks":[{"type":"code"}],"text":"initialized"},{"type":"text","text":" Notification"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"jsonrpc\": \"2.0\",\n  \"method\": \"initialized\"\n}"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"No ID"},{"type":"text","text":" (it's a notification)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Confirms both sides agree on capabilities"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"After this"},{"type":"text","text":": Tool calls, resource fetches begin flowing"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why It Matters"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Security Implications"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Risk"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"If skipped/ignored"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Over-declared capabilities"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Server claims it has tools but doesn't validate → attacker exploits"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Under-validation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Client doesn't check server's declarations → over-privileged session"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Unknown capabilities"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Defaulting to \"allow\" for unfamiliar features → security gap"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best practices:"},{"type":"text","text":"\n- ✅ "},{"type":"text","marks":[{"type":"bold"}],"text":"Validate server's declared capabilities"},{"type":"text","text":" match user approval\n- ✅ "},{"type":"text","marks":[{"type":"bold"}],"text":"Refuse capabilities you don't understand"},{"type":"text","text":" instead of allowing\n- ✅ "},{"type":"text","marks":[{"type":"bold"}],"text":"Log every initialize handshake"},{"type":"text","text":" for audit trails\n- ✅ "},{"type":"text","marks":[{"type":"bold"}],"text":"Show clear UI summary"},{"type":"text","text":" of what the server requests (like browser camera prompts)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Functional Implications"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Behavior"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Server didn't declare "},{"type":"text","marks":[{"type":"code"}],"text":"prompts"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Client "},{"type":"text","marks":[{"type":"bold"}],"text":"won't"},{"type":"text","text":" call "},{"type":"text","marks":[{"type":"code"}],"text":"prompts/list"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text",