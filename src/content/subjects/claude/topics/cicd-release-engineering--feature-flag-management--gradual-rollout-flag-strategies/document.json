      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Metric Gates: Advancing and Halting Rollouts"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Each rollout advance must be gated on observable signals, not calendar time alone. Define a metric gate with explicit pass/fail thresholds before the rollout begins:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "#!/usr/bin/env python3\n\"\"\"check_canary_gate.py \u2014 advance or halt based on metrics.\"\"\"\nimport os, sys, time\nimport anthropic  # example: using the Anthropic SDK to call a metrics check tool\n\n# These thresholds are set per-flag in flags.yml;\n# this script reads them and queries the metrics backend.\nFLAG       = os.environ[\"FLAG_NAME\"]           # e.g. \"cache_streaming\"\nWINDOW_MIN = int(os.environ.get(\"WINDOW_MIN\", \"60\"))\nMAX_ERROR_RATE_DELTA = float(os.environ.get(\"MAX_ERROR_RATE_DELTA\", \"0.005\"))  # 0.5pp\nMAX_P99_LATENCY_RATIO = float(os.environ.get(\"MAX_P99_LATENCY_RATIO\", \"1.2\"))  # 20% increase\n\ndef get_metrics(flag: str, window_minutes: int) -> dict:\n    \"\"\"Stub: replace with your actual metrics backend (Datadog, Prometheus, etc.)\"\"\"\n    # Returns: {error_rate, baseline_error_rate, p99_ms, baseline_p99_ms, request_count}\n    raise NotImplementedError(\"Connect to your metrics backend here\")\n\ndef evaluate(metrics: dict) -> tuple[bool, str]:\n    error_delta = metrics[\"error_rate\"] - metrics[\"baseline_error_rate\"]\n    latency_ratio = metrics[\"p99_ms\"] / metrics[\"baseline_p99_ms\"]\n    count = metrics[\"request_count\"]\n\n    if count < 1000:\n        return False, f\"Insufficient sample: {count} requests (need 1000)\"\n    if error_delta > MAX_ERROR_RATE_DELTA:\n        return False, f\"Error rate +{error_delta:.3%} exceeds threshold +{MAX_ERROR_RATE_DELTA:.3%}\"\n    if latency_ratio > MAX_P99_LATENCY_RATIO:\n        return False, f\"P99 latency {latency_ratio:.2f}x baseline exceeds {MAX_P99_LATENCY_RATIO:.2f}x\"\n    return True, f\"Gate passed: error_delta={error_delta:.4%}, p99_ratio={latency_ratio:.2f}x, n={count}\"\n\nif __name__ == \"__main__\":\n    metrics = get_metrics(FLAG, WINDOW_MIN)\n    passed, reason = evaluate(metrics)\n    print(reason)\n    sys.exit(0 if passed else 1)\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Run this script in GitHub Actions before each `canary_pct` increment PR is auto-merged. If it fails, the PR is blocked and an alert fires to the flag owner."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Automated Rollback on Metric Breach"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When a canary is active, a separate monitoring job watches error rate and latency in a sliding window. If thresholds are breached for more than 2 consecutive minutes, the rollback fires automatically:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "#!/usr/bin/env python3\n\"\"\"canary_watchdog.py \u2014 runs as a sidecar during active canary periods.\"\"\"\nimport os, time, subprocess, yaml\n\nFLAG  = os.environ[\"FLAG_NAME\"]\nSLEEP = int(os.environ.get(\"CHECK_INTERVAL_SEC\", \"60\"))\n\ndef current_pct(flag: str) -> int:\n    with open(\"config/flags.yml\") as f:\n        return yaml.safe_load(f)[\"flags\"][flag].get(\"canary_pct\", 0)\n\ndef metrics_ok(flag: str) -> bool:\n    result = subprocess.run(\n        [\"python3\", \"scripts/check_canary_gate.py\"],\n        env={**os.environ, \"FLAG_NAME\": flag, \"WINDOW_MIN\": \"5\"},\n        capture_output=True, text=True\n    )\n    return result.returncode == 0\n\ndef rollback(flag: str) -> None:\n    cfg = {}\n    with open(\"config/flags.yml\") as f:\n        cfg = yaml.safe_load(f)\n    cfg[\"flags\"][flag][\"canary_pct\"] = 0\n    cfg[\"flags\"][flag][\"state\"] = \"default_off\"\n    with open(\"config/flags.yml\", \"w\") as f:\n        yaml.dump(cfg, f, default_flow_style=False)\n    # Kubernetes: override env var immediately without a code deploy\n    rollback_var = cfg[\"flags\"][flag][\"rollback_env_var\"]\n    subprocess.run([\n        \"kubectl\", \"set\", \"env\", \"deployment/claude-api\",\n        f\"{rollback_var}=false\"\n    ], check=True)\n    print(f\"ROLLBACK: {flag} set to default_off, env var cleared\")\n\nconsecutive_failures = 0\nwhile True:\n    pct = current_pct(FLAG)\n    if pct == 0:\n        print(f\"{FLAG}: canary at 0%, watchdog exiting\")\n        break\n    if metrics_ok(FLAG):\n        consecutive_failures = 0\n    else:\n        consecutive_failures += 1\n        print(f\"{FLAG}: gate failed ({consecutive_failures} consecutive)\")\n        if consecutive_failures >= 2:\n            rollback(FLAG)\n            break\n    time.sleep(SLEEP)\n"
          }
        ]
