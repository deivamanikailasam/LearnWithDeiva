            "type": "text",
            "text": "Ring 0",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " is the engineering team's own production environment, "
          },
          {
            "type": "text",
            "text": "Ring 1",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " is internal employees, "
          },
          {
            "type": "text",
            "text": "Ring 2",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " is beta customers, and "
          },
          {
            "type": "text",
            "text": "Ring 3",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " is general availability. The rings are environment labels in the user profile, not code branches:"
          }
        ]
      },
