      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# src/flags.py \u2014 ring-aware check\nRING_ORDER = [\"ring0\", \"ring1\", \"ring2\", \"ring3\"]\n\ndef is_enabled(flag_name: str, user: dict | None = None) -> bool:\n    cfg = _REGISTRY.get(flag_name)\n    if cfg is None:\n        raise KeyError(f\"Flag '{flag_name}' is not registered\")\n\n    if cfg[\"state\"] == \"full_on\":\n        return True\n    if cfg[\"state\"] in (\"retired\", \"registered\", \"default_off\"):\n        return False\n\n    active_ring = cfg.get(\"active_ring\")  # e.g. \"ring1\"\n    if active_ring is None:\n        return False\n\n    user_ring = (user or {}).get(\"ring\", \"ring3\")\n    user_ring_idx  = RING_ORDER.index(user_ring)  if user_ring  in RING_ORDER else 3\n    active_ring_idx = RING_ORDER.index(active_ring) if active_ring in RING_ORDER else 3\n    return user_ring_idx <= active_ring_idx\n"
          }
        ]
