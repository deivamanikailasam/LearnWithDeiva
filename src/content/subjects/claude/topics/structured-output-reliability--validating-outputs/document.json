e\", \"email\"]\n    \n    # Check required fields\n    for field in required:\n        if field not in data:\n            raise ValueError(f\"Missing required field: {field}\")\n    \n    # Check types\n    if not isinstance(data[\"name\"], str):\n        raise TypeError(\"name must be string\")\n    if not isinstance(data[\"age\"], int):\n        raise TypeError(\"age must be integer\")\n    if not isinstance(data[\"email\"], str):\n        raise TypeError(\"email must be string\")\n    \n    return data"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Validation Strategy by Output Mode"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Claude Output Mode"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Need Validation?"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Recommended Approach"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Structured Outputs (JSON mode)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Minimal"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Schema validation only (Pydantic/Zod)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bo