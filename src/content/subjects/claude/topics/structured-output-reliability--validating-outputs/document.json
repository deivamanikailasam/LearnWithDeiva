:{"language":"python"},"content":[{"type":"text","text":"# With structured outputs (no pre-validation needed)\nmessage = client.messages.create(\n    model=\"claude-sonnet-4-6\",\n    output_format=User.model_json_schema(),  # Schema enforced at model level\n    messages=[{\"role\": \"user\", \"content\": \"Create user\"}]\n)\n\n# response is guaranteed valid JSON matching schema\nuser = User.model_validate_json(message.content)  # Only type-check, not full validation"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"You can delete or drastically reduce:"},{"type":"text","text":"\n- ❌ "},{"type":"text","marks":[{"type":"code"}],"text":"JSON.parse()"},{"type":"text","text":" failure handlers\n- ❌ Retry loops for \"valid JSON\"\n- ❌ Custom validation layers just to make output usable\n- ❌ \"Almost-correct\" response handling"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Validate at boundaries"},{"type":"text","text":" — Check Claude's output before passing to databases/APIs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use Pydantic/Zod"},{"type":"text","text":" — SDKs auto-validate types and provide clean error messages"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fail fast"},{"type":"text","text":" — Raise errors immediately on invalid output, don't proceed"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Log validation failures"},{"type":"text","text":" — Track patterns to improve prompts/schemas"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Return errors gracefully"},{"type":"text","text":" — Use retry contracts like "},{"type":"text","marks":[{"type":"code"}],"text":"{\"error\": \"reason\"}"},{"type":"text","text":" on failure"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Validation Checklist"}]},{"type":"paragraph","content":[{"type":"text","text":"Before using Claude's output:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Check"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Why"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ JSON parses correctly"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Prevent "},{"type":"text","marks":[{"type":"code"}],"text":"JSONDecodeError"},{"type":"text","text":" crashes"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Required fields present"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Avoid "},{"type":"text","marks":[{"type":"code"}],"text":"undefined"},{"type":"text","text":"/"},{"type":"text","marks":[{"type":"code"}],"text":"null"},{"type":"text","text":" bugs"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Types match schema"}]}]},{"type