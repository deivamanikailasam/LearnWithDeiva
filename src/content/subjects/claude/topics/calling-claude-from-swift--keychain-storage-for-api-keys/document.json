{
  "format": "tiptap/v1",
  "doc": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Storing an API key in "
          },
          {
            "type": "text",
            "marks": [{ "type": "code" }],
            "text": "UserDefaults"
          },
          {
            "type": "text",
            "text": " or a "
          },
          {
            "type": "text",
            "marks": [{ "type": "code" }],
            "text": ".plist"
          },
          {
            "type": "text",
            "text": " file exposes it to anyone who can read the app bundle or device backup. iOS Keychain encrypts secrets at the hardware level — the data is protected by the Secure Enclave on A-series devices and is scoped to your app by entitlement. For a Claude API key, Keychain is the only acceptable on-device storage mechanism."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "iOS Keychain storage architecture: App layer, Security Framework SecItem API, and hardware-encrypted Keychain database with accessibility attribute comparison"
        }
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Why Not UserDefaults or .plist?" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "UserDefaults writes to a plain property list file inside the app's data container. iTunes and iCloud backups include this file by default. An attacker with access to a backup — or to a jailbroken device — can read it directly. Keychain items, by contrast, are stored in a system daemon process ("
          },
          {
            "type": "text",
            "marks": [{ "type": "code" }],
            "text": "securityd"
          },
          {
            "type": "text",
            "text": "), encrypted with keys that are derived from the device's hardware UID and the user's passcode. The app never touches the raw ciphertext."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A second risk with UserDefaults is that the file is readable across processes on a simulator and can be extracted from a device backup without jailbreaking. Apple's App Transport Security and certificate pinning do not protect data at rest — only Keychain does."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "The SecItem API" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "iOS exposes Keychain through a C API in the Security framework — "
          },
          {
            "type": "text",
            "marks": [{ "type": "code" }],
            "text": "SecItemAdd"
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "marks": [{ "type": "code" }],
            "text": "SecItemCopyMatching"
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "marks": [{ "type": "code" }],
            "text": "SecItemUpdate"
          },
          {
            "type": "text",
            "text": ", and "
          },
          {
            "type": "text",
            "marks": [{ "type": "code" }],
            "text": "SecItemDelete"
          },
          {
            "type": "text",
            "text": ". All accept a "
          },
          {
            "type": "text",
            "marks": [{ "type": "code" }],
            "text": "CFDictionary"
          },
          {
            "type": "text",
            "text": " of attributes and return an "
          },
          {
            "type": "text",
            "marks": [{ "type": "code" }],
            "text": "OSStatus"
          },
          {
            "type": "text",
            "text": " integer where "
          },
          {
            "type": "text",
            "marks": [{ "type": "code" }],
            "text": "errSecSuccess == 0"
          },
          {
            "type": "text",
            "text": ". Three attribute keys matter most for API key storage:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "code" }], "text": "kSecClass: kSecClassGenericPassword" }, { "type": "text", "text": " — the item class for arbitrary byte blobs (as opposed to internet passwords or certificates)." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "code" }], "text": "kSecAttrService" }, { "type": "text", "text": " — a string that namespaces the item, typically your app's bundle identifier." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "code" }], "text": "kSecAttrAccount" }, { "type": "text", "text": " — the key name within the namespace, e.g. \"claude-api-key\"." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "code" }], "text": "kSecAttrAccessible" }, { "type": "text", "text": " — controls when the item can be read and whether it participates in iCloud Keychain backup." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "code" }], "text": "kSecValueData" }, { "type": "text", "text": " — the raw " }, { "type": "text", "marks": [{ "type": "code" }], "text": "Data" }, { "type": "text", "text": " payload. Encode your API key string to UTF-8 Data before writing." }] }]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Building a KeychainManager" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Wrapping the C API in a Swift type makes it testable and prevents the dictionary-building boilerplate from leaking throughout the app. A minimal "
          },
          {
            "type": "text",
            "marks": [{ "type": "code" }],
            "text": "KeychainManager"
          },
          {
            "type": "text",
            "text": " needs three operations: store, retrieve, and delete."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "swift" },
        "content": [
          {
            "type": "text",
            "text": "import Foundation\nimport Security\n\nenum KeychainError: Error {\n    case unhandledError(OSStatus)\n    case itemNotFound\n    case unexpectedData\n}\n\nstruct KeychainManager {\n    private let service: String\n\n    init(service: String = Bundle.main.bundleIdentifier ?? \"app\") {\n        self.service = service\n    }\n\n    // MARK: - Store\n\n    func store(key: String, value: String) throws {\n        guard let data = value.data(using: .utf8) else {\n            throw KeychainError.unexpectedData\n        }\n\n        // Try to update an existing item first.\n        let query = baseQuery(for: key)\n        let status = SecItemUpdate(query as CFDictionary,\n                                   [kSecValueData: data] as CFDictionary)\n\n        if status == errSecItemNotFound {\n            // Item does not exist yet — create it.\n            var addQuery = query\n            addQuery[kSecValueData as String] = data\n            addQuery[kSecAttrAccessible as String] =\n                kSecAttrAccessibleWhenUnlockedThisDeviceOnly\n\n            let addStatus = SecItemAdd(addQuery as CFDictionary, nil)\n            guard addStatus == errSecSuccess else {\n                throw KeychainError.unhandledError(addStatus)\n            }\n        } else if status != errSecSuccess {\n            throw KeychainError.unhandledError(status)\n        }\n    }\n\n    // MARK: - Retrieve\n\n    func retrieve(key: String) throws -> String {\n        var query = baseQuery(for: key)\n        query[kSecReturnData as String] = true\n        query[kSecMatchLimit as String] = kSecMatchLimitOne\n\n        var result: AnyObject?\n        let status = SecItemCopyMatching(query as CFDictionary, &result)\n\n        guard status != errSecItemNotFound else {\n            throw KeychainError.itemNotFound\n        }\n        guard status == errSecSuccess else {\n            throw KeychainError.unhandledError(status)\n        }\n        guard let data = result as? Data,\n              let string = String(data: data, encoding: .utf8) else {\n            throw KeychainError.unexpectedData\n        }\n        return string\n    }\n\n    // MARK: - Delete\n\n    func delete(key: String) throws {\n        let status = SecItemDelete(baseQuery(for: key) as CFDictionary)\n        guard status == errSecSuccess || status == errSecItemNotFound else {\n            throw KeychainError.unhandledError(status)\n        }\n    }\n\n    // MARK: - Private\n\n    private func baseQuery(for key: String) -> [String: Any] {\n        [\n            kSecClass as String:       kSecClassGenericPassword,\n            kSecAttrService as String: service,\n            kSecAttrAccount as String: key\n        ]\n    }\n}"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The store function uses an update-first pattern to avoid "
          },
          {
            "type": "text",
            "marks": [{ "type": "code" }],
            "text": "errSecDuplicateItem"
          },
          {
            "type": "text",
            "text": " errors: it calls "
          },
          {
            "type": "text",
            "marks": [{ "type": "code" }],
            "text": "SecItemUpdate"
          },
          {
            "type": "text",
            "text": " and only falls back to "
          },
          {
            "type": "text",
            "marks": [{ "type": "code" }],
            "text": "SecItemAdd"
          },
          {
            "type": "text",
            "text": " when the item does not exist. The accessibility attribute "
          },
          {
            "type": "text",
            "marks": [{ "type": "code" }],
            "text": "kSecAttrAccessibleWhenUnlockedThisDeviceOnly"
          },
          {
            "type": "text",
            "text": " is set only during creation because it is immutable after that point — updating the value does not change accessibility."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Choosing the Right Accessibility Constant" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The accessibility constant controls the trade-off between security and availability. For a Claude API key that is only needed while the user actively uses the app, "
          },
          {
            "type": "text",
            "marks": [{ "type": "code" }],
            "text": "kSecAttrAccessibleWhenUnlockedThisDeviceOnly"
          },
          {
            "type": "text",
            "text": " is the right choice. It prevents the item from migrating to a new device through iCloud Keychain and prevents reading when the screen is locked."
          }
        ]
      },
      {
        "type": "table",
        "content": [
          {
            "type": "tableRow",
            "content": [
              { "type": "tableHeader", "attrs": { "colspan": 1, "rowspan": 1, "colwidth": null }, "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Constant" }] }] },
              { "type": "tableHeader", "attrs": { "colspan": 1, "rowspan": 1, "colwidth": null }, "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Readable" }] }] },
              { "type": "tableHeader", "attrs": { "colspan": 1, "rowspan": 1, "colwidth": null }, "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "iCloud Sync" }] }] },
              { "type": "tableHeader", "attrs": { "colspan": 1, "rowspan": 1, "colwidth": null }, "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Use case" }] }] }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              { "type": "tableCell", "attrs": { "colspan": 1, "rowspan": 1, "colwidth": null }, "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "code" }], "text": "WhenUnlockedThisDeviceOnly" }] }] },
              { "type": "tableCell", "attrs": { "colspan": 1, "rowspan": 1, "colwidth": null }, "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Device unlocked" }] }] },
              { "type": "tableCell", "attrs": { "colspan": 1, "rowspan": 1, "colwidth": null }, "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "No" }] }] },
              { "type": "tableCell", "attrs": { "colspan": 1, "rowspan": 1, "colwidth": null }, "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "API keys (recommended)" }] }] }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              { "type": "tableCell", "attrs": { "colspan": 1, "rowspan": 1, "colwidth": null }, "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "code" }], "text": "AfterFirstUnlockThisDeviceOnly" }] }] },
              { "type": "tableCell", "attrs": { "colspan": 1, "rowspan": 1, "colwidth": null }, "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "After first post-reboot unlock" }] }] },
              { "type": "tableCell", "attrs": { "colspan": 1, "rowspan": 1, "colwidth": null }, "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "No" }] }] },
              { "type": "tableCell", "attrs": { "colspan": 1, "rowspan": 1, "colwidth": null }, "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Background services that refresh tokens" }] }] }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              { "type": "tableCell", "attrs": { "colspan": 1, "rowspan": 1, "colwidth": null }, "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "code" }], "text": "WhenUnlocked" }] }] },
              { "type": "tableCell", "attrs": { "colspan": 1, "rowspan": 1, "colwidth": null }, "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Device unlocked" }] }] },
              { "type": "tableCell", "attrs": { "colspan": 1, "rowspan": 1, "colwidth": null }, "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Yes" }] }] },
              { "type": "tableCell", "attrs": { "colspan": 1, "rowspan": 1, "colwidth": null }, "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Credentials needed across a user's devices" }] }] }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              { "type": "tableCell", "attrs": { "colspan": 1, "rowspan": 1, "colwidth": null }, "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "code" }], "text": "AfterFirstUnlock" }] }] },
              { "type": "tableCell", "attrs": { "colspan": 1, "rowspan": 1, "colwidth": null }, "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "After first unlock" }] }] },
              { "type": "tableCell", "attrs": { "colspan": 1, "rowspan": 1, "colwidth": null }, "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Yes" }] }] },
              { "type": "tableCell", "attrs": { "colspan": 1, "rowspan": 1, "colwidth": null }, "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Cross-device background services" }] }] }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Integrating with the Claude Client" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The Claude actor from the previous section can read the API key from Keychain at call time instead of requiring the caller to pass it in. This keeps the key off the call stack and out of logs."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "swift" },
        "content": [
          {
            "type": "text",
            "text": "actor ClaudeClient {\n    private let keychain = KeychainManager()\n    private let keychainKey = \"claude-api-key\"\n    private let session = URLSession.shared\n\n    // Store the key once — e.g., when the user first enters it in Settings.\n    func setAPIKey(_ apiKey: String) throws {\n        try keychain.store(key: keychainKey, value: apiKey)\n    }\n\n    func chat(messages: [[String: String]]) async throws -> String {\n        let apiKey = try keychain.retrieve(key: keychainKey)\n\n        var request = URLRequest(url: URL(string: \"https://api.anthropic.com/v1/messages\")!)\n        request.httpMethod = \"POST\"\n        request.setValue(apiKey, forHTTPHeaderField: \"x-api-key\")\n        request.setValue(\"2023-06-01\", forHTTPHeaderField: \"anthropic-version\")\n        request.setValue(\"application/json\", forHTTPHeaderField: \"Content-Type\")\n\n        let body: [String: Any] = [\n            \"model\": \"claude-opus-4-8\",\n            \"max_tokens\": 1024,\n            \"messages\": messages\n        ]\n        request.httpBody = try JSONSerialization.data(withJSONObject: body)\n\n        let (data, response) = try await session.data(for: request)\n        guard let http = response as? HTTPURLResponse, http.statusCode == 200 else {\n            throw URLError(.badServerResponse)\n        }\n\n        let decoded = try JSONDecoder().decode(MessagesResponse.self, from: data)\n        return decoded.content.first?.text ?? \"\"\n    }\n}\n\nstruct MessagesResponse: Decodable {\n    struct Block: Decodable { let text: String }\n    let content: [Block]\n}"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Retrieving the key inside the actor method rather than storing it as a property means the string lives in memory only for the duration of the network call. If the actor is deallocated between calls, no reference to the key survives in the heap."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Settings Screen: Storing the Key" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A typical settings flow asks the user to paste their Claude API key once, stores it in Keychain, and never displays the value again — only a masked placeholder. The SwiftUI view below demonstrates the pattern:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "swift" },
        "content": [
          {
            "type": "text",
            "text": "import SwiftUI\n\nstruct APIKeySettingsView: View {\n    @State private var apiKey = \"\"\n    @State private var isSaved = false\n    @State private var errorMessage: String?\n\n    private let client = ClaudeClient()\n    private let keychain = KeychainManager()\n    private let keychainKey = \"claude-api-key\"\n\n    var body: some View {\n        Form {\n            Section(\"Claude API Key\") {\n                SecureField(\"sk-ant-...\", text: $apiKey)\n                    .autocorrectionDisabled()\n                    .textInputAutocapitalization(.never)\n\n                Button(\"Save to Keychain\") {\n                    saveKey()\n                }\n                .disabled(apiKey.isEmpty)\n\n                if isSaved {\n                    Label(\"Saved securely\", systemImage: \"checkmark.shield\")\n                        .foregroundStyle(.green)\n                }\n                if let error = errorMessage {\n                    Text(error).foregroundStyle(.red).font(.caption)\n                }\n            }\n\n            Section {\n                Button(\"Remove Key\", role: .destructive) {\n                    removeKey()\n                }\n            }\n        }\n        .navigationTitle(\"Settings\")\n        .onAppear { loadMaskedKey() }\n    }\n\n    private func saveKey() {\n        do {\n            try keychain.store(key: keychainKey, value: apiKey)\n            apiKey = \"\"\n            isSaved = true\n            errorMessage = nil\n        } catch {\n            errorMessage = error.localizedDescription\n        }\n    }\n\n    private func removeKey() {\n        try? keychain.delete(key: keychainKey)\n        isSaved = false\n    }\n\n    private func loadMaskedKey() {\n        if let stored = try? keychain.retrieve(key: keychainKey),\n           !stored.isEmpty {\n            // Show only that a key exists — never the value itself.\n            apiKey = \"\"\n            isSaved = true\n        }\n    }\n}"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Using "
          },
          {
            "type": "text",
            "marks": [{ "type": "code" }],
            "text": "SecureField"
          },
          {
            "type": "text",
            "text": " rather than "
          },
          {
            "type": "text",
            "marks": [{ "type": "code" }],
            "text": "TextField"
          },
          {
            "type": "text",
            "text": " ensures the key is obscured on screen and not suggested by autocomplete. The "
          },
          {
            "type": "text",
            "marks": [{ "type": "code" }],
            "text": "apiKey"
          },
          {
            "type": "text",
            "text": " state variable is cleared immediately after a successful save so the value does not linger in the view's state tree."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Keychain Groups: Sharing Keys Across Targets" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "If your project includes multiple targets — say, the main app and a Share Extension — both need access to the same API key. Without a Keychain Sharing entitlement, each target gets its own isolated Keychain partition and cannot read items written by the other."
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "In Xcode, open the main target's Signing & Capabilities tab and add the Keychain Sharing capability." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Add the same group identifier (e.g. " }, { "type": "text", "marks": [{ "type": "code" }], "text": "com.example.myapp.keychaingroup" }, { "type": "text", "text": ") to every target that needs shared access." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Pass the group in the query dictionary:" }] }]
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "swift" },
        "content": [
          {
            "type": "text",
            "text": "// Add to baseQuery(for:) in KeychainManager when sharing is needed.\nprivate let accessGroup: String?\n\nprivate func baseQuery(for key: String) -> [String: Any] {\n    var dict: [String: Any] = [\n        kSecClass as String:       kSecClassGenericPassword,\n        kSecAttrService as String: service,\n        kSecAttrAccount as String: key\n    ]\n    if let group = accessGroup {\n        dict[kSecAttrAccessGroup as String] = group\n    }\n    return dict\n}"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Keychain Sharing requires an Apple Developer account and does not work in the simulator when the entitlement is signed for a specific team. Test on device when using access groups."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Testing Keychain Code" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The SecItem API works in the simulator, which makes unit testing straightforward. Define a protocol to decouple tests from the real implementation:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "swift" },
        "content": [
          {
            "type": "text",
            "text": "protocol SecretStorage {\n    func store(key: String, value: String) throws\n    func retrieve(key: String) throws -> String\n    func delete(key: String) throws\n}\n\nextension KeychainManager: SecretStorage {}\n\n// In tests, use an in-memory stub.\nfinal class InMemoryStorage: SecretStorage {\n    private var store: [String: String] = [:]\n\n    func store(key: String, value: String) throws { store[key] = value }\n    func retrieve(key: String) throws -> String {\n        guard let v = store[key] else { throw KeychainError.itemNotFound }\n        return v\n    }\n    func delete(key: String) throws { store.removeValue(forKey: key) }\n}\n\n// XCTest example\nfinal class ClaudeClientTests: XCTestCase {\n    func testRetrievesStoredAPIKey() throws {\n        let storage = InMemoryStorage()\n        try storage.store(key: \"claude-api-key\", value: \"test-key-123\")\n        let retrieved = try storage.retrieve(key: \"claude-api-key\")\n        XCTAssertEqual(retrieved, \"test-key-123\")\n    }\n\n    func testThrowsWhenKeyMissing() {\n        let storage = InMemoryStorage()\n        XCTAssertThrowsError(try storage.retrieve(key: \"missing-key\"))\n    }\n}"
          }
        ]
