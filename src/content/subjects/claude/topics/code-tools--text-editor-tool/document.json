"language":"python"},"content":[{"type":"text","text":"from anthropic import Anthropic\nimport os\n\nclient = Anthropic()\n\nresponse = client.messages.create(\n    model=\"claude-sonnet-4-5\",\n    max_tokens=1024,\n    tools=[{\"type\": \"text_editor_20250728\", \"name\": \"text_editor\"}],\n    messages=[{\"role\": \"user\", \"content\": \"View the file main.py\"}]\n)\n\n# Claude returns tool_use block:\n# {\n#   \"type\": \"tool_use\",\n#   \"name\": \"text_editor\",\n#   \"input\": {\n#     \"command\": \"view\",\n#     \"path\": \"main.py\"\n#   }\n# }\n\n# Your app executes:\nwith open(\"main.py\") as f:\n    content = f.read()\n\n# Return tool_result back to Claude:\nresponse2 = client.messages.create(\n    model=\"claude-sonnet-4-5\",\n    max_tokens=1024,\n    messages=[\n        {\"role\": \"user\", \"content\": \"View the file main.py\"},\n        response.content[0],  # tool_use block\n        {\n            \"role\": \"user\",\n            \"content\": [\n                {\n                    \"type\": \"tool_result\",\n                    \"tool_use_id\": response.content[0].id,\n                    \"content\": content\n                }\n            ]\n        }\n    ]\n)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"str_replace example (most common operation)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Claude requests:\n{\n  \"command\": \"str_replace\",\n  \"path\": \"main.py\",\n  \"old_str\": \"def hello():\\n    print('Hello')\",\n  \"new_str\": \"def hello():\\n    print('Hello, World!')\"\n}\n\n# Your app executes:\nwith open(\"main.py\", \"r\") as f:\n    content = f.read()\n\ncontent = content.replace(old_str, new_str)\n\nwith open(\"main.py\", \"w\") as f:\n    f.write(content)\n\n# Return result"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"View command options"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# View entire file with line numbers:\n{\n  \"command\": \"view\",\n  \"path\": \"main.py\"\n}\n\n# View specific line range:\n{\n  \"command\": \"view\",\n  \"path\": \"main.py\",\n  \"start_line\": 10,\n  \"end_line\": 20\n}\n\n# List directory:\n{\n  \"command\": \"view\",\n  \"path\": \"./src\"\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Insert example"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Claude requests:\n{\n  \"command\": \"insert\",\n  \"path\": \"main.py\",\n  \"line_number\": 5,\n  \"new_str\": \"def helper():\\n    return 'helper'\\n\"\n}\n\n# Your app executes:\nwith open(\"main.py\", \"r\") as f:\n    lines = f.readlines()\n\nlines.insert(5, \"def helper():\\n    return 'helper'\\n\")\n\nwith open(\"main.py\", \"w\") as f:\n    f.writelines(lines)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Delete example"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Claude requests:\n{\n  \"command\": \"delete\",\n  \"path\": \"main.py\",\n  \"start_line\": 10,\n  \"end_line\": 15\n}\n\n# Your app executes:\nwith open(\"main.py\", \"r\") as f:\n    lines = f.readlines()\n\ndel lines[10:15]\n\nwith open(\"main.py\", \"w\") as f:\n    f.writelines(lines)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Undo edit example"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Claude requests:\n{\n  \"command\": \"undo_edit\",\n  \"path\": \"main.py\"\n}\n\n# Your app executes (requires git wrapper recommended):\n# Option 1: Use git to revert last commit\n# Option 2: Store file history and restore previous version"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Token overhead"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}]