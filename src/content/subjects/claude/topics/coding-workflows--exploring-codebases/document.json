{"format":"tiptap/v1","updatedAt":"2026-06-22T11:17:51.725Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Exploring Codebases"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Exploring codebases"},{"type":"text","text":" is one of the most powerful everyday workflows in Claude Code — it lets you understand unfamiliar projects quickly by asking natural language questions instead of manually reading dozens of source files."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How Claude Explores Your Code"}]},{"type":"paragraph","content":[{"type":"text","text":"Claude Code doesn't magically know your codebase — it "},{"type":"text","marks":[{"type":"bold"}],"text":"reads and explores your code using specific tools"},{"type":"text","text":", just like you would:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tool"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"What It Does"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"When Claude Uses It"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Glob"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Searches for files matching patterns (e.g., "},{"type":"text","marks":[{"type":"code"}],"text":"**/*.tsx"},{"type":"text","text":")"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Discovering which files exist"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Grep"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Searches file contents for specific patterns"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Finding where a function or error appears"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Read"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Opens and reads file contents"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Understanding actual code logic"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"LSP"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Language Server Protocol — finds definitions and references"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tracing how functions are used across files"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Bash"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Runs shell commands"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Running tests, checking git history, build tools"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"This exploration phase is not wasted time — it is how Claude builds the "},{"type":"text","marks":[{"type":"bold"}],"text":"context needed to create a good plan"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Top-Down Exploration Pattern"}]},{"type":"paragraph","content":[{"type":"text","text":"Effective codebase analysis follows a top-down pattern: start broad, then narrow:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Start with a high-level overview"},{"type":"text","text":" — Claude reads "},{"type":"text","marks":[{"type":"code"}],"text":"package.json"},{"type":"text","text":", directory structure, config files, and entry points to build an architectural summary"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Identify key subsystems"},{"type":"text","text":" — understand the major modules, how they're organized, and where boundaries lie"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Drill into the specific area you need"},{"type":"text","text":" — once you know the landscape, focus on the subsystem relevant to your task"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Map the data flow"},{"type":"text","text":" — understanding how data moves through the system is often more valuable than understanding any single file"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Workflow 1: Get a Quick Codebase Overview"}]},{"type":"paragraph","content":[{"type":"text","text":"For when you've just joined a project and need to understand its structure:"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"cd /path/to/project\nclaude"}]},{"type":"paragraph","content":[{"type":"text","text":"Then ask:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"give me an overview of this codebase"}]},{"type":"paragraph","content":[{"type":"text","text":"Follow-up drills:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"explain the main architecture patterns used here\nwhat are the key data models?\nhow is authentication handled?"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tip:"},{"type":"text","text":" Start with broad questions, then narrow down to specific areas. Ask about coding conventions and patterns. Request a glossary of project-specific terms."}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Workflow 2: Find Relevant Code"}]},{"type":"paragraph","content":[{"type":"text","text":"For locating code tied to a specific feature or functionality:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"find the files that handle user authentication\nhow do these authentication files work together?\ntrace the login process from front-end to database"}]},{"type":"paragraph","content":[{"type":"text","text":"Use "},{"type":"text","marks":[{"type":"bold"}],"text":"domain language from the project"},{"type":"text","text":" — Claude understands terms from your codebase like \"subscription lifecycle\" or \"settlement pipeline\" without needing technical file paths."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Workflow 3: Explore Without Modifying (Plan Mode)"}]},{"type":"paragraph","content":[{"type":"text","text":"When you want to explore thoroughly "},{"type":"text","marks":[{"type":"bold"}],"text":"before changing anything"},{"type":"text","text":", use Plan Mode — Claude analyzes the codebase but will not modify files or execute commands:"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"claude --permission-mode plan"}]},{"type":"paragraph","content":[{"type":"text","text":"Or toggle mid-session with "},{"type":"text","marks":[{"type":"code"}],"text":"Shift+Tab"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use Plan Mode when:"},{"type":"text","text":"\n- Onboarding to a new codebase\n- Planning a complex refactor\n- Investigating a bug before touching code\n- You want a safe read-only analysis"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Workflow 4: Reference Files Directly"}]},{"type":"paragraph","content":[{"type":"text","text":"Use "},{"type":"text","marks":[{"type":"code"}],"text":"@"},{"type":"text","text":" to quickly include specific files or line ranges without waiting for Claude to search:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Explain the logic in @src/utils/auth.js\nWhat's the structure of @src/components?\nexplain @src/models/user.ts#10-45"}]},{"type":"paragraph","content":[{"type":"text","text":"This explicitly tells Claude exactly what to look at, rather than waiting for it to discover the file through search."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Workflow 5: Delegate Exploration to Subagents"}]},{"type":"paragraph","content":[{"type":"text","text":"Exploring a large codebase fills your context with file reads fast. Delegate the exploration so "},{"type":"text","marks":[{"type":"bold"}],"text":"only the findings come back"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"use a subagent to investigate how our auth system handles token refresh"}]},{"type":"paragraph","content":[{"type":"text","text":"The subagent reads files in its own context window and reports a summary, keeping your main session clean."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Capturing What You Learn"}]},{"type":"paragraph","content":[{"type":"text","text":"After exploring a codebase, "},{"type":"text","marks":[{"type":"bold"}],"text":"capture findings so you don't have to re-explore"},{"type":"text","text":" in future sessions:"}]},{"type":"codeBlock","attrs":{"language":"sql"},"content":[{"type":"text","text":"generate an architecture document for this project\nupdate CLAUDE.md with the key patterns and conventions we discovered\ncreate a glossary of domain-specific terms"}]},{"type":"paragraph","content":[{"type":"text","text":"This populates your "},{"type":"text","marks":[{"type":"code"}],"text":"CLAUDE.md"},{"type":"text","text":" file — a persistent memory file Claude reads at the start of every session."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Common Mistakes When Exploring"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Mistake"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Better Approach"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Asking overly broad tasks like \"find all issues across entire repo\""}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Be hyper-specific; isolate to files or subsystems"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Asking once then stopping"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Ask follow-up questions — drill from broad to specific"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Accepting shallow overviews"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Ask: \"Trace the actual function calls, not just the module names\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Exploring in main session with 20+ files"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use subagents for any investigation touching more than 5–10 files"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Running out of context mid-exploration"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use "},{"type":"text","marks":[{"type":"code"}],"text":"/compact"},{"type":"text","text":" to summarize, or "},{"type":"text","marks":[{"type":"code"}],"text":"/clear"},{"type":"text","text":" when switching areas"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of Claude Code's codebase exploration as a "},{"type":"text","marks":[{"type":"bold"}],"text":"pair programmer who has never seen your project before"},{"type":"text","text":". You wouldn't throw them in with a vague task — you'd start with a walkthrough, let them read the most important files, ask questions about how things connect, then gradually zoom into the part you need to change together. That same rhythm produces the best results in Claude Code."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Start broad, then narrow"},{"type":"text","text":" — overview → subsystems → specific files"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use Plan Mode"},{"type":"text","text":" for safe read-only exploration before making changes"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use @file references"},{"type":"text","text":" to point Claude at exact files or line ranges"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Delegate to subagents"},{"type":"text","text":" when exploring large codebases to protect context"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Capture findings in "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"CLAUDE.md"},{"type":"text","text":" so future sessions inherit your knowledge"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Be specific"},{"type":"text","text":" — domain language and exact function names beat vague descriptions"}]}]}]},{"type":"paragraph"}]}}
