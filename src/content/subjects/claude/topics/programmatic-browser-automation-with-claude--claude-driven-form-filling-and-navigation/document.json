"content":[{"type":"paragraph","content":[{"type":"text","text":"Terms agreement, preferences"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multi-step forms"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Signup flows with multiple pages"}]}]}]}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Manual Testing Pattern (Slash Command)"}]},{"type":"paragraph","content":[{"type":"text","text":"Create a reusable workflow with "},{"type":"text","marks":[{"type":"code"}],"text":".claude/commands/pw-manual-testing.md"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"markdown"},"content":[{"type":"text","text":"---\ndescription: Manually test a site and create a report\n---\n\n### Instructions\n1. Use Playwright CLI/MCP to test the scenario\n2. Navigate to the URL and perform interactions\n3. Observe and verify expected behavior\n4. Use `playwright-cli screenshot` for evidence\n5. Report findings in natural language:\n   - Steps performed\n   - Outcomes observed\n   - Issues or accessibility concerns"}]},{"type":"paragraph","content":[{"type":"text","text":"Then ask Claude:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"/pw-manual-testing\n\nTest the signup form on https://example.com/signup:\n1. Fill email, password, name fields\n2. Click \"Continue\"\n3. Verify navigation to dashboard"}]},{"type":"paragraph","content":[{"type":"text","text":"Claude executes all steps and generates a detailed MD report with screenshots."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Autonomous Form Filling Example"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// Claude can generate this from your plain-English request:\n// \"Sign up for the account with email test@example.com\"\n\nimport { test, expect } from '@playwright/test';\n\ntest('signup flow', async ({ page }) => {\n  await page.goto('https://example.com/signup');\n  \n  // Semantic locators discovered via accessibility tree\n  await page.getByRole('textbox', { name: 'Email' }).fill('test@example.com');\n  await page.getByRole('textbox', { name: 'Password' }).fill('SecurePass123');\n  await page.getByRole('textbox', { name: 'Full Name' }).fill('John Doe');\n  await page.getByRole('checkbox', { name: 'Terms' }).check();\n  await page.getByRole('button', { name: 'Continue' }).click();\n  \n  // Wait for navigation\n  await page.waitForLoadState('networkidle');\n  \n  // Verify success\n  await expect(page.getByRole('heading')).toContainText('Dashboard');\n});"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Multi-Step Navigation Pattern"}]},{"type":"paragraph","content":[{"type":"text","text":"For complex flows requiring multiple pages:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Step 1: Navigate to login\npage.goto('https://app.com/login')\npage.screenshot(path='/tmp/login.png')\n\n# Step 2: Fill credentials\npage.locator('#username').fill('user')\npage.locator('#password').fill('pass')\npage.locator('button[type=\"submit\"]').click()\n\n# Step 3: Wait for dashboard\npage.wait_for_selector('#dashboard')\npage.screenshot(path='/tmp/dashboard.png')\n\n# Step 4: Navigate to settings\npage.locator('role=link[text=\"Settings\"]').click()\npage.wait_for_load_state('networkidle')\n\n# Step 5: Update profile\npage.locator('#name').fill('New Name')\npage.locator('#bio').fill('Updated bio')\npage.locator('role=button[text=\"Save\"]').click()"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Capabilities"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Navigation Tools"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"browser_navigate"},{"type":"text","text":" - Go to URL"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"browser_navigate_back"},{"type":"text","text":" - Return to previous page"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"browser_click"},{"type":"text","text":" - Click any element"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"browser_evaluate"},{"type":"text","text":" - Run JavaScript in browser context"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"browser_take_screenshot"},{"type":"text","text":" - Capture visual evidence"}]}]}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Form Tools"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Fills text, dates, file uploads automatically"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Review step before submission"},{"type":"text","text":" - Pauses for manual approval before final submit"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Handles complex multi-page forms"}]}]}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"State Management"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tab management"},{"type":"text","text":" - Open/close multiple tabs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Ne