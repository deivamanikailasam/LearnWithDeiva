{"format":"tiptap/v1","updatedAt":"2026-06-22T08:34:40.049Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"This is the capability where "},{"type":"text","marks":[{"type":"bold"}],"text":"Claude autonomously navigates web pages and fills form inputs"},{"type":"text","text":" by inspecting the rendered DOM, discovering elements, and executing interactions without you writing test code manually."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","text":"Claude uses Playwright (via MCP or CLI) to:\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Navigate to URLs"},{"type":"text","text":" you specify\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Snapshot the page"},{"type":"text","text":" to get stable element references (e.g., "},{"type":"text","marks":[{"type":"code"}],"text":"e12"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"e45"},{"type":"text","text":")\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Fill form fields"},{"type":"text","text":" (text, dates, file uploads, dropdowns, checkboxes)\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Click buttons"},{"type":"text","text":" and trigger navigation\n5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Wait for state changes"},{"type":"text","text":" (network loads, page transitions)\n6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Verify results"},{"type":"text","text":" with screenshots or assertions"}]},{"type":"paragraph","content":[{"type":"text","text":"The workflow is "},{"type":"text","marks":[{"type":"bold"}],"text":"snapshot-driven"},{"type":"text","text":": open page → snapshot → interact using refs → snapshot again when DOM changes."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why It Matters"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Traditional Approach"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Claude-driven Approach"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Manually write selectors like "},{"type":"text","marks":[{"type":"code"}],"text":"#email"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"code"}],"text":".form-input"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Claude discovers elements via accessibility tree (roles, text, refs)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Hard to handle dynamic content"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Waits for "},{"type":"text","marks":[{"type":"code"}],"text":"networkidle"},{"type":"text","text":" and inspects rendered DOM"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Time-consuming test scripting"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Describe what to test in plain English; Claude executes"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Flaky tests when UI changes"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Uses semantic locators ("},{"type":"text","marks":[{"type":"code"}],"text":"role='textbox'"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"text='Submit'"},{"type":"text","text":") that are more resilient"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How It Works"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Core Workflow (Snapshot-Based)"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// 1. Navigate\nawait page.goto('https://example.com/signup');\n\n// 2. Snapshot to get element refs\n// Claude sees: e12=textbox[email], e15=button[Continue]\n\n// 3. Fill form using refs\nawait page.locator('e12').fill('user@example.com');\nawait page.locator('e14').fill('Password123!');\n\n// 4. Click button\nawait page.locator('e15').click();\n\n// 5. Wait for navigation\nawait page.waitForLoadState('networkidle');\n\n// 6. Verify\nawait page.takeScreenshot();"}]},{"type":"paragraph","content":[{"type":"text","text":"Each snapshot provides "},{"type":"text","marks":[{"type":"bold"}],"text":"stable element references"},{"type":"text","text":" that persist across DOM changes until you navigate."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Form Input Types Supported"}]},{"type":"paragraph","content":[{"type":"text","text":"Based on the Playwright Form Automator skill:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Input Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","cont