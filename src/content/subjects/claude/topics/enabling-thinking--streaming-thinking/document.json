{"format":"tiptap/v1","updatedAt":"2026-06-21T17:58:33.041Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Streaming Thinking"},{"type":"text","text":" is how Claude's extended thinking reasoning appears in real-time when you use the streaming API—thinking blocks arrive progressively as "},{"type":"text","marks":[{"type":"code"}],"text":"thinking_delta"},{"type":"text","text":" events, allowing you to display Claude's reasoning live as it happens."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","text":"In streaming mode, reasoning arrives as "},{"type":"text","marks":[{"type":"code"}],"text":"thinking_delta"},{"type":"text","text":" events. When extended thinking is enabled:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Thinking arrives first"},{"type":"text","text":" as streaming deltas"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Final answer comes after"},{"type":"text","text":" as "},{"type":"text","marks":[{"type":"code"}],"text":"text"},{"type":"text","text":" deltas"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"You can display both"},{"type":"text","text":" progressively to the user"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How Streaming Works"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"with client.messages.stream(\n    model=\"claude-sonnet-4-5-20250929\",\n    max_tokens=16000,\n    thinking={\"type\": \"enabled\", \"budget_tokens\": 10000},\n    messages=[{\"role\": \"user\", \"content\": \"...\"}]\n) as stream:\n    for event in stream:\n        if event.type == \"content_block_start\":\n            if event.content_block.type == \"thinking\":\n                print(\"🤔 Thinking: \", end=\"\")\n            else:\n                print(\"\\n📝 Response: \", end=\"\")\n        \n        elif event.type == \"content_block_delta\":\n            if hasattr(event.delta, \"thinking\"):\n                # Streaming thinking content\n                print(event.delta.thinking, end=\"\", flush=True)\n            elif hasattr(event.delta, \"text\"):\n                # Streaming final answer\n                print(event.delta.text, end=\"\", flush=True)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Event Types in Streaming Thinking"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Event Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"When It Fires"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"What It Contains"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"content_block_start"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"New block begins"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"type: \"thinking\""},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"code"}],"text":"type: \"text\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"content_block_delta"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Content streaming"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"thinking.delta"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"code"}],"text":"text.delta"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"content_block_stop"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Block ends"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Block complete"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"message_delta"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Final message"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"usage.output_tokens_details.thinking_tokens"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Characteristics"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Detail"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Billing"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Based on "},{"type":"text","marks":[{"type":"bold"}],"text":"full thinking tokens generated"},{"type":"text","text":", not the summary you see"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Token tracking"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use "},{"type":"text","marks":[{"type":"code"}],"text":"usage.output_tokens_details.thinking_tokens"},{"type":"text","text":" in response"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Streaming visibility"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"output_tokens_details.thinking_tokens"},{"type":"text","text":" appears only on final "},{"type":"text","marks":[{"type":"code"}],"text":"message_delta"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Summarization"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"On Claude 4 models, API returns a "},{"type":"text","marks":[{"type":"bold"}],"text":"summary"},{"type":"text","text":" of reasoning, not full stream"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Streaming Response Example"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"// content_block_start\n{\n  \"type\": \"content_block_start\",\n  \"content_block\": {\n    \"type\": \"thinking\",\n    \"thinking\": \"\",\n    \"signature\": \"...\"\n  }\n}\n\n// content_block_delta (thinking streaming)\n{\n  \"type\": \"content_block_delta\",\n  \"delta\": {\n    \"type\": \"thinking_delta\",\n    \"thinking\": \"Let me analyze this step by step...\"\n  }\n}\n\n// content_block_delta (text streaming)\n{\n  \"type\": \"content_block_delta\",\n  \"delta\": {\n    \"type\": \"text_delta\",\n    \"text\": \"Based on my analysis...\"\n  }\n}\n\n// message_delta (final token count)\n{\n  \"type\": \"message_delta\",\n  \"usage\": {\n    \"output_tokens\": 4523,\n    \"output_tokens_details\": {\n      \"thinking_tokens\": 3200\n    }\n  }\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Processing Streaming Thinking"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"def process_streaming_response(stream):\n    thinking_content = \"\"\n    text_content = \"\"\n    thinking_tokens = 0\n    \n    for event in stream:\n        if event.type == \"content_block_delta\":\n            if hasattr(event.delta, \"thinking\"):\n                thinking_content += event.delta.thinking\n                print(event.delta.thinking, end=\"\", flush=True)\n            elif hasattr(event.delta, \"text\"):\n                text_content += event.delta.text\n                print(event.delta.text, end=\"\", flush=True)\n        \n        elif event.type == \"message_delta\":\n            thinking_tokens = event.usage.output_tokens_details.thinking_tokens\n    \n    return {\n        \"thinking\": thinking_content,\n        \"response\": text_content,\n        \"thinking_tokens\": thinking_tokens\n    }"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Visual UX Pattern for Streaming Thinking"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Display thinking in collapsible UI\nfunction streamThinkingToUI(stream) {\n    const thinkingDiv = document.getElementById('thinking');\n    const responseDiv = document.getElementById('response');\n    \n    stream.on('content_block_start', (block) => {\n        if (block.type === 'thinking') {\n            thinkingDiv.classList.add('show'); // Expand thinking\n            thinkingDiv.textContent = '';\n        } else {\n            responseDiv.textContent = '';\n        }\n    });\n    \n    stream.on('content_block_delta', (delta) => {\n        if (delta.type === 'thinking_delta') {\n            thinkingDiv.textContent += delta.thinking;\n        } else if (delta.type === 'text_delta') {\n            responseDiv.textContent += delta.text;\n        }\n    });\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Important Considerations"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Consideration"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Impact"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Latency"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Extended thinking makes responses slower due to deliberation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cost"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Thinking tokens billed at output token rate—can be expensive"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Large budgets"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Reasoning above 32k tokens best run via batch to avoid timeouts"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Volatility"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Parameters ("},{"type":"text","marks":[{"type":"code"}],"text":"adaptive"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"effort"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"budget_tokens"},{"type":"text","text":") may change—check docs"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Streaming vs Non-Streaming Comparison"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Non-Streaming (Messages API)"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Streaming"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Response"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Full thinking block returned immediately"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Thinking arrives progressively as deltas"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Token visibility"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"thinking_tokens"},{"type":"text","text":" in response"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"thinking_tokens"},{"type":"text","text":" only in final "},{"type":"text","marks":[{"type":"code"}],"text":"message_delta"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"UX"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Show thinking after response done"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Show thinking as it happens"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use case"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Batch processing, simple apps"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Real-time chat, interactive UIs"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Best Practices for Streaming Thinking"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Do:"},{"type":"text","text":"\n- Use collapsible UI for thinking (hide by default)\n- Show thinking progressively to build transparency\n- Track "},{"type":"text","marks":[{"type":"code"}],"text":"thinking_tokens"},{"type":"text","text":" for cost monitoring\n- Set appropriate budget based on complexity"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Don't:"},{"type":"text","text":"\n- Always show thinking (can overwhelm users)\n- Enable for simple queries (wastes tokens)\n- Set extremely high budgets by default\n- Ignore thinking content in production"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When Streaming Thinking Helps"}]},{"type":"paragraph","content":[{"type":"text","text":"Streaming thinking is valuable when:\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"User transparency"},{"type":"text","text":" matters—showing reasoning builds trust\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Interactive debugging"},{"type":"text","text":"—developers want to see reasoning live\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Educational apps"},{"type":"text","text":"—teaching users how to solve problems\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Complex analysis"},{"type":"text","text":"—users want to understand the reasoning process\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"High-stakes decisions"},{"type":"text","text":"—verifying reasoning before final answer"}]},{"type":"paragraph","content":[{"type":"text","text":"The key advantage of streaming thinking is "},{"type":"text","marks":[{"type":"bold"}],"text":"real-time transparency"},{"type":"text","text":"—users see Claude's reasoning unfold as it happens, rather than waiting for a complete answer with reasoning appended afterward."}]}]}}
