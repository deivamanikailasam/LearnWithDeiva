            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Markdown: "
                  },
                  {
                    "type": "text",
                    "text": "Split on heading boundaries ("
                  },
