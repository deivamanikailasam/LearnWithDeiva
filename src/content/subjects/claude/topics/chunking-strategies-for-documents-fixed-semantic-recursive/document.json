                      }
                    ],
                    "text": "Code: "
                  },
                  {
                    "type": "text",
                    "text": "Function or class boundaries are better split points than token counts. Split on "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "def "
                  },
