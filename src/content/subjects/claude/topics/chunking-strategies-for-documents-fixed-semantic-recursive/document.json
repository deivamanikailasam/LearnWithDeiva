            "type": "text",
            "text": "import cohere\nimport psycopg2\nfrom psycopg2.extras import Json, execute_values\n\nco = cohere.Client(\"your-key\")\n\ndef embed_batch(texts: list[str]) -> list[list[float]]:\n    resp = co.embed(texts=texts, model=\"embed-english-v3.0\",\n                    input_type=\"search_document\")\n    return resp.embeddings\n\ndef ingest_document(conn, doc_id: str, text: str, source: str) -> int:\n    chunks = chunk_document(doc_id, text, strategy=\"recursive\",\n                             chunk_size=400, overlap=60)\n    texts = [c.text for c in chunks]\n\n    # Embed in batches of 96 (Cohere limit)\n    embeddings = []\n    for i in range(0, len(texts), 96):\n        embeddings.extend(embed_batch(texts[i:i+96]))\n\n    rows = [\n        (\n            c.doc_id,\n            c.chunk_index,\n            c.text,\n            embeddings[idx],\n            Json({\"source\": source, \"start\": c.start_char, \"end\": c.end_char}),\n        )\n        for idx, c in enumerate(chunks)\n    ]\n\n    with conn, conn.cursor() as cur:\n        execute_values(\n            cur,\n            \"\"\"\n            INSERT INTO document_chunks (doc_id, chunk_index, chunk_text, embedding, metadata)\n            VALUES %s\n            ON CONFLICT (doc_id, chunk_index) DO UPDATE\n                SET chunk_text = EXCLUDED.chunk_text,\n                    embedding   = EXCLUDED.embedding\n            \"\"\",\n            rows,\n        )\n    return len(chunks)"
          }
        ]
