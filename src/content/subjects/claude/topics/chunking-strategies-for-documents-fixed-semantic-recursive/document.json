                  },
                  {
                    "type": "text",
                    "text": " boundaries, keeping the full function body in one chunk."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Storing Chunk Metadata"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Each chunk should carry metadata enabling filtered retrieval and source attribution in Claude's response:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass, field\n\n@dataclass\nclass Chunk:\n    text: str\n    doc_id: str\n    chunk_index: int\n    start_char: int\n    end_char: int\n    metadata: dict = field(default_factory=dict)\n    # metadata: {source, page, section, created_at, ...}\n\ndef chunk_document(\n    doc_id: str,\n    text: str,\n    strategy: str = \"recursive\",\n    **kwargs,\n) -> list[Chunk]:\n    if strategy == \"fixed\":\n        texts = fixed_chunks(text, **kwargs)\n    elif strategy == \"recursive\":\n        texts = recursive_chunks(text, **kwargs)\n    else:\n        raise ValueError(f\"Unknown strategy: {strategy}\")\n\n    chunks, pos = [], 0\n    for i, chunk_text in enumerate(texts):\n        start = text.find(chunk_text, pos)\n        end = start + len(chunk_text)\n        chunks.append(Chunk(\n            text=chunk_text,\n            doc_id=doc_id,\n            chunk_index=i,\n            start_char=start,\n            end_char=end,\n        ))\n        pos = max(0, end - 50)  # allow re-overlap search\n    return chunks"
          }
        ]
      },
