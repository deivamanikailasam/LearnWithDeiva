ing & detection"}]},{"type":"paragraph","content":[{"type":"text","text":"Anthropic uses "},{"type":"text","marks":[{"type":"bold"}],"text":"hierarchical summarization"},{"type":"text","text":" for monitoring computer use:\n- Track AI actions in real-time\n- Detect suspicious patterns\n- Log audit trail of all operations"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. Human-in-the-loop oversight"}]},{"type":"paragraph","content":[{"type":"text","text":"For high-risk use cases, Anthropic requires:\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Human approval"},{"type":"text","text":" for sensitive operations\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"AI disclosure"},{"type":"text","text":" when outputs are consumer-facing\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Audit logging"},{"type":"text","text":" of all actions"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Security controls by implementation layer"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Layer"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Control"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Policy"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Usage Policy prohibitions on malicious activities"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":