\"c:/tmp/.anthropic\": {\"bind\": \"/workspace\", \"mode\": \"rw\"}},\n    ports={\"5900/tcp\": 5900, \"8501/tcp\": 8501}\n)\n# Container has NO access to your actual computer"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Action logging"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Log all AI actions for audit trail\nclass ActionLogger:\n    def log(self, action: str, coordinate: tuple, content: str):\n        with open(\"action_log.txt\", \"a\") as f:\n            f.write(f\"{timestamp}: {action} @ {coordinate} - {content}\\n\")\n\nlogger = ActionLogger()\n# Call logger.log() for every mouse_move, left_click, type, etc."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Approval steps for sensitive operations"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Require human approval before critical actions\nSENSEITIVE_ACTIONS = [\"delete\", \"write\", \"execute\", \"upload\"]\n\ndef requires_approval(action: str) -> bool:\n    return action in SENSITIVE_ACTIONS\n\nif requires_approval(claude_action):\n    if not human_approves():\n        raise Exception(\"Action denied by human\")"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Timeouts & error handling"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Prevent infinite loops\nimport time\n\ndef execute_with_timeout(action, timeout=30):\n    start = time.time()\n    result = execute_action(action)\n    if time.time() - start > timeout:\n        raise TimeoutError(\"Action exceeded timeout\")\n    return result"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Screen security"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Don't expose sensitive data"},{"type":"text","text":": Ensure container