      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Self-Hosting Portkey"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Portkey's gateway is open source and can be self-hosted if you cannot send prompts to managed infrastructure:"
          }
        ]
      },
      {
