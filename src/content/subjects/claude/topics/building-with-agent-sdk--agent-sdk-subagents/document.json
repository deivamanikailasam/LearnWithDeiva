{"format":"tiptap/v1","updatedAt":"2026-06-22T06:25:36.312Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Based on the official Claude documentation, "},{"type":"text","marks":[{"type":"bold"}],"text":"\"Subagents & Hooks\""},{"type":"text","text":" in the Agent SDK refers to two powerful patterns for building complex AI workflows: "},{"type":"text","marks":[{"type":"bold"}],"text":"Subagents"},{"type":"text","text":" delegate tasks to specialized assistant agents, while "},{"type":"text","marks":[{"type":"bold"}],"text":"Hooks"},{"type":"text","text":" intercept and control agent behavior at specific points in the execution lifecycle."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Subagents"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What They Are"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Subagents are assistant agents that can be used to delegate tasks"},{"type":"text","text":" within your agent workflow."}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Main Agent (orchestrator)\n    ↓\nDelegates to Subagent A (research specialist)\nDelegates to Subagent B (coding specialist)\nDelegates to Subagent C (review specialist)\n    ↓\nSubagents complete tasks\n    ↓\nResults aggregated by main agent"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key capability"},{"type":"text","text":": \"Subagent orchestration lets you delegate tasks to specialized assistant agents\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use Subagents"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Why Subagents Work"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multi-agent workflows"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Different agents for different roles (software engineer, architect, SRE, tester, UX designer, product manager)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Parallel execution"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Subagents can work simultaneously on different aspects of a task"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Specialized expertise"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Each subagent has unique skills/prompts for specific domains"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Complex tasks"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Break down large tasks into smaller, manageable pieces"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How to Create Subagents"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import { Agent, Subagent } from \"@anthropic-ai/claude-agent-sdk\";\n\n// Create main agent\nconst mainAgent = new Agent({\n  instructions: \"You are the orchestrator. Delegate to subagents for specialized work.\"\n});\n\n// Create subagents\nconst researchAgent = new Subagent({\n  instructions: \"You are a research specialist. Gather information and summarize findings.\"\n});\n\nconst codingAgent = new Subagent({\n  instructions: \"You are a coding specialist. Write, edit, and debug code.\"\n});\n\n// Delegate tasks\nawait mainAgent.delegate(\"Research this topic\", researchAgent);\nawait mainAgent.delegate(\"Write the implementation\", codingAgent);"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Subagent Communication"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Main agent sends task → Subagent processes → Returns result → Main agent integrates"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern"},{"type":"text","text":": \"Loop through these roles in your script, giving each agent a turn to work on a shared project goal\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Hooks"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What They Are"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hooks intercept and control agent behavior"},{"type":"text","text":" at specific points in the execution lifecycle."}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Agent lifecycle:\nUser Prompt → PreToolUse → Tool Execution → PostToolUse → Result\n     ↓          ↓             ↓              ↓           ↓\nHook       Hook          Hook           Hook        Hook"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key purpose"},{"type":"text","text":": \"Hooks allow you to intercept and modify agent behavior without retraining the model\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Hook Events"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Hook Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"When It Fires"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"UserPromptSubmit"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Before agent processes user prompt"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"PreToolUse"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Before agent executes a tool call"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"PostToolUse"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"After agent completes a tool call"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"PreCompact"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Before agent compacts context"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"Stop"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"When agent stops/shuts down"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"SubagentStop"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"When a subagent stops"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"[docs](https://docs.rs/claude-agent-sdk-rs/latest/claude_agent_sdk_rs/types/hooks/index.html)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How to Use Hooks"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import { Agent, Hooks } from \"@anthropic-ai/claude-agent-sdk\";\n\n// Create hooks\nconst hooks = new Hooks({\n  // Intercept before tool use\n  preToolUse: async (input) => {\n    console.log(`Tool ${input.toolName} will be called`);\n    \n    // Modify tool arguments\n    return {\n      ...input,\n      arguments: { ...input.arguments, validated: true }\n    };\n  },\n  \n  // Intercept after tool use\n  postToolUse: async (input) => {\n    console.log(`Tool ${input.toolName} completed`);\n    \n    // Log result or modify\n    return {\n      ...input,\n      result: { ...input.result, logged: true }\n    };\n  },\n  \n  // Intercept user prompt\n  userPromptSubmit: async (input) => {\n    console.log(`Received prompt: ${input.prompt}`);\n    \n    // Modify prompt before processing\n    return {\n      ...input,\n      prompt: `Enhanced: ${input.prompt}`\n    };\n  }\n});\n\n// Create agent with hooks\nconst agent = new Agent({ hooks });"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Hook Use Cases"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Case"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Implementation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Enforce rules"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"Read before write\" without retraining model"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Debugging"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Log all tool calls and results"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Security"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Validate tool arguments before execution"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Determinism"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Intercept hallucinated responses, inject feedback"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": \"If an agent hallucinates or skips a step (e.g., guessing a Pokemon stat instead of checking a script), a hook can intercept the response and inject feedback: 'Please make sure you write a script, please make sure you read this data.'\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Combining Subagents & Hooks"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Pattern: Subagents with Hook Guards"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// Create subagent with security hooks\nconst secureAgent = new Subagent({\n  instructions: \"You are a coding specialist.\",\n  hooks: {\n    preToolUse: async (input) => {\n      // Validate tool arguments\n      if (input.toolName === \"write_file\" && !input.arguments.path.startsWith(\"/safe/\")) {\n        throw new Error(\"Only write to safe directories\");\n      }\n      return input;\n    }\n  }\n});\n\n// Main agent delegates to secure subagent\nawait mainAgent.delegate(\"Write code\", secureAgent);"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of "},{"type":"text","marks":[{"type":"bold"}],"text":"subagents"},{"type":"text","text":" like "},{"type":"text","marks":[{"type":"bold"}],"text":"managing a team"},{"type":"text","text":": you're the project manager (main agent), and you delegate tasks to specialists (subagents) — one for research, one for coding, one for testing. Each specialist works independently on their portion, then you combine the results."}]},{"type":"paragraph","content":[{"type":"text","text":"Think of "},{"type":"text","marks":[{"type":"bold"}],"text":"hooks"},{"type":"text","text":" like "},{"type":"text","marks":[{"type":"bold"}],"text":"security checkpoints"},{"type":"text","text":" in an airport: before the agent passes through each checkpoint (tool call, prompt submission), the hook checks if it's safe, modifies it if needed, or blocks it entirely. The agent still goes through the process, but with guardrails."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Subagents = assistant agents for delegating tasks within agent workflow"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Subagent orchestration = delegate to specialized assistant agents"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use subagents for: multi-agent workflows, parallel execution, specialized expertise, complex tasks"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Create subagents: "},{"type":"text","marks":[{"type":"code"}],"text":"new Subagent({ instructions })"},{"type":"text","text":" + "},{"type":"text","marks":[{"type":"code"}],"text":"mainAgent.delegate(task, subagent)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Hooks = intercept and control agent behavior at specific lifecycle points"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Hook events: UserPromptSubmit, PreToolUse, PostToolUse, PreCompact, Stop, SubagentStop"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Create hooks: "},{"type":"text","marks":[{"type":"code"}],"text":"new Hooks({ preToolUse, postToolUse, userPromptSubmit })"},{"type":"text","text":" + pass to "},{"type":"text","marks":[{"type":"code"}],"text":"Agent({ hooks })"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Hook use cases: enforce rules, debugging, security, determinism"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Example: Hook intercepts hallucination, injects feedback (\"write script, read data\") without retraining"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Combine: Subagents with hook guards for security/validation"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"\"Subagents and Hooks expose infrastructure behind Claude Code as a library\" — enabling complex multi-agent orchestration and behavior control patterns."}]}]}}
