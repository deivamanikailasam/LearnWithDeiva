:null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Configuration"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Exponential backoff"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"1s → 2s → 4s → 8s"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Retry limits"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Max 3 attempts"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Handle partial failures"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Timeout, network errors, 5xx"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"When Exactly-Once Might Be Needed"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Rare, Specific Cases"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Why Need Exactly-Once"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Critical financial systems"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Double payment = catastrophic"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Payment recording"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Duplicate = financial loss"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Order creation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Duplicate orders = inventory issues"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Even then"},{"type":"text","text":": \"Implement at-least-once + idempotency\" (not true exactly-once)."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of "},{"type":"text","marks":[{"type":"bold"}],"text":"at-least-once"},{"type":"text","text":" like "},{"type":"text","marks":[{"type":"bold"}],"text":"sending a letter with self-addressed stamp"},{"type":"text","text":": you send it, and if it doesn't arrive, you resend it. The recipient might get duplicates, but they can throw away the extra ones (idempotency) — you guaranteed the letter arrives at least once, not exactly once."}]},{"type":"paragraph","content":[{"type":"text","text":"Think of "},{"type":"text","marks":[{"type":"bold"}],"text":"exactly-once"},{"type":"text","text":" like "},{"type":"text","marks":[{"type":"bold"}],"text":"trying to guarantee the postman never makes a mistake"},{"type":"text","text":": you'd need to track every single letter, check if it arrived, and if it did, tell the postman not to deliver it again. This is impossibly expensive and the postman will still make mistakes anyway — so you just use the self-addressed stamp approach and handle duplicates."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"At-least-once: execute ≥1 times (never lost, may duplicate)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Exactly-once: execute =1 time (never lost, never duplicated)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Reality"},{"type":"text","text":": Exactly-once is theoretically impossible in large distributed systems"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key fact"},{"type":"text","text":": Stripe, Kafka, AWS don't implement exactly-once by default — they use at-least-once + idempotency"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What \"exactly-once\" actually is"},{"type":"text","text":": At-least-once delivery + Idempotent operations + Deduplication"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Recommended approach"},{"type":"text","text":": At-least-once + idempotent handlers + proper retries + logging"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why preferred"},{"type":"text","text":": Moderate complexity, good performance, widely adopted (RabbitMQ, Kafka, Supabase)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Critical rule"},{"type":"text","text":": \"Every action-taking tool must be idempotent or the agent must dedupe\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Common patterns: Unique IDs, check-before-process, UPSERT, database constraints"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"At-least-once + idempotency = Effectively \"exactly-once\" for most practical purposes"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"At-least-once is good enough in most circumstances; exactly-once comes at high cost"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"\"You cannot have exactly-once delivery\" — what you can do is build a system that guarantees operations are applied exactly once "},{"type":"text","marks":[{"type":"bold"}],"text":"by building it on top of at-least-once with idempotency and deduplication"},{"type":"text","text":"."}]}]}}
