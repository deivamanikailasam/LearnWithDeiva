{"format":"tiptap/v1","updatedAt":"2026-06-21T17:07:32.674Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How PDFs Are Processed"},{"type":"text","text":" in Claude's PDF Support is a dual-modality pipeline that combines "},{"type":"text","marks":[{"type":"bold"}],"text":"text extraction"},{"type":"text","text":" with "},{"type":"text","marks":[{"type":"bold"}],"text":"image-based vision analysis"},{"type":"text","text":" for each page, enabling comprehensive understanding of both written and visual content without manual parsing."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What it is"}]},{"type":"paragraph","content":[{"type":"text","text":"PDF processing is Claude's ability to "},{"type":"text","marks":[{"type":"bold"}],"text":"directly ingest PDF files through the API"},{"type":"text","text":", extracting text and converting each page into an image for visual analysis, then reasoning over both modalities together."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Step-by-Step Processing Pipeline"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 1: "},{"type":"text","marks":[{"type":"bold"}],"text":"Content Extraction"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"PDF Upload → System parses document\n    ↓\nExtracts document structure and metadata"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What happens:"},{"type":"text","text":"\n- Claude's system parses the PDF file\n- Reads document structure (pages, sections, metadata)\n- Prepares for dual extraction (text + image)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 2: "},{"type":"text","marks":[{"type":"bold"}],"text":"Convert Each Page to Image"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Page 1 → Image\nPage 2 → Image\nPage 3 → Image\n... (all pages)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key details:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Each page converted into an image"},{"type":"text","text":" — preserves visual layout\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Layout preserved"},{"type":"text","text":" — formatting, positions, spacing kept\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Embedded figures included"},{"type":"text","text":" — charts, diagrams rendered as pixels\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Scanned PDFs handled"},{"type":"text","text":" — OCR applied to text images"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why this matters:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"PDF support is less about file handling and more about document understanding. Claude can use extracted text plus page images to reason about charts, tables, and figures.\""}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 3: "},{"type":"text","marks":[{"type":"bold"}],"text":"Extract Text from Each Page"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Page 1 Image → Text extraction\nPage 2 Image → Text extraction\nPage 3 Image → Text extraction"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Text extraction methods:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Native text parsing"},{"type":"text","text":" — for PDFs with embedded text (tagged PDFs, structured data)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"OCR (Optical Character Recognition)"},{"type":"text","text":" — for scanned PDFs (images of text)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Combined output"},{"type":"text","text":" — text provided alongside page image"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Important note:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Some PDFs store text as structured data (like HTML or tagged PDF), while others are pure images. This affects extraction quality.\""}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 4: "},{"type":"text","marks":[{"type":"bold"}],"text":"Provide Text + Page Images Together"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Combined Input:\n{\n  \"page\": 1,\n  \"text\": \"Extracted text content...\",\n  \"image\": \"Page 1 as image\"\n}\n{\n  \"page\": 2,\n  \"text\": \"Extracted text content...\",\n  \"image\": \"Page 2 as image\"\n}\n... (all pages)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key concept:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Text and images processed together"},{"type":"text","text":" — Claude receives both modalities\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"No need for separate pipelines"},{"type":"text","text":" — Claude's API handles everything automatically\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Combined analysis"},{"type":"text","text":" — Claude comprehends written AND visual content"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 5: "},{"type":"text","marks":[{"type":"bold"}],"text":"Text and Image Analysis (Vision Components)"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Claude's Vision Model Processes:\n├── Text (structured data)\n├── Images (visual pixels)\n    ↓\nReasons over both modalities together"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How it works:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Text analysis"},{"type":"text","text":" — Natural language understanding of extracted text\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Image analysis"},{"type":"text","text":" — Vision components from Claude interpret visual content\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Combined reasoning"},{"type":"text","text":" — Claude correlates text with visual elements\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Layout understanding"},{"type":"text","text":" — Interprets page-level context, formatting, structure"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Vision capabilities applied:"},{"type":"text","text":"\n- Grabs text itself\n- Implements vision components from Claude\n- Comprehends both written and visual content"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 6: "},{"type":"text","marks":[{"type":"bold"}],"text":"Comprehend Written AND Visual Content"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Claude's Understanding:\n├── Written content (text)\n├── Visual content (charts, diagrams, tables, images)\n├── Layout & formatting\n├── Page-level context\n    ↓\nIntegrated document understanding"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What Claude can now analyze:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Charts"},{"type":"text","text":" — data extraction, trends, values\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Diagrams"},{"type":"text","text":" — visual structure, relationships\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Tables"},{"type":"text","text":" — cell data, row/column extraction\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Images"},{"type":"text","text":" — visual content understanding\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Text"},{"type":"text","text":" — summarization, key themes, extraction"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 7: "},{"type":"text","marks":[{"type":"bold"}],"text":"Answer Specific Questions About Visual Elements"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"User Question: \"What does the chart on page 5 show?\"\n    ↓\nClaude analyzes:\n├── Text from page 5\n├── Image of page 5 (with chart)\n    ↓\nResponse: \"The chart shows revenue increasing 25% from Q1 to Q4\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Capabilities unlocked:"},{"type":"text","text":"\n- Ask questions about "},{"type":"text","marks":[{"type":"bold"}],"text":"charts, diagrams, and other non-text content"},{"type":"text","text":"\n- Gain "},{"type":"text","marks":[{"type":"bold"}],"text":"rich insights"},{"type":"text","text":" without complex data extraction setups\n- No need for "},{"type":"text","marks":[{"type":"bold"}],"text":"manual text parsing"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Technical Architecture"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Dual-Modality Pipeline"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"┌─────────────────────────────────────┐\n│  PDF Input (binary file)            │\n└──────────────┬──────────────────────┘\n               │\n               ▼\n┌─────────────────────────────────────┐\n│  Content Extraction Layer           │\n│  ├── Parse document structure      │\n│  ├── Convert pages to images       │\n│  └── Extract text from pages       │\n└──────────────┬──────────────────────┘\n               │\n               ▼\n┌─────────────────────────────────────┐\n│  Combined Input Generation          │\n│  { text: \"...\", image: \"...\" }      │\n└──────────────┬──────────────────────┘\n               │\n               ▼\n┌─────────────────────────────────────┐\n│  Claude Vision Model                │\n│  ├── Text analysis (NLP)            │\n│  ├── Image analysis (Vision)        │\n│  └── Combined reasoning             │\n└──────────────┬──────────────────────┘\n               │\n               ▼\n┌─────────────────────────────────────┐\n│  Response Generation                │\n│  └── Answer based on full context   │\n└─────────────────────────────────────┘"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why Dual Modality Matters"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Single Modality (Text Only)"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Dual Modality (Text + Image)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Missing chart data"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Charts interpreted visually"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Table structure lost"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Tables parsed with layout"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Diagrams ignored"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Diagrams understood"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Scanned PDFs fail"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ OCR applied to images"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Formatting lost"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Layout preserved"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key advantage:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"PDF support works by converting each page into an image for visual analysis. Claude then reasons over both modalities together, which helps it interpret layout, embedded figures, and page-level context that would be lost in a text-only pipeline.\""}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What PDFs Are Supported"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Supported PDF Types"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"PDF Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Handling"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rows