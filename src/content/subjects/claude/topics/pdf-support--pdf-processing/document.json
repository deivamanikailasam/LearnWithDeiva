ype":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PDFs with images"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Images analyzed for visual content"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Coverage:"},{"type":"text","text":" Claude's PDF capabilities extend to "},{"type":"text","marks":[{"type":"bold"}],"text":"any standard PDF"},{"type":"text","text":", handling text, images, charts, and tables."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Limitations"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Constraint"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Limit"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Max pages"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"100 pages per PDF"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Max file size"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"32 MB per request"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Password protection"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Not supported (cannot upload password-protected PDFs)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Model support"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Claude 3.5+ models only (Sonnet, Opus)"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Input Paths for PDFs"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Multiple ways to provide PDFs"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Method 1: URL\n{\"type\": \"file\", \"source\": {\"url\": \"https://example.com/document.pdf\"}}\n\n# Method 2: Base64 content\n{\"type\": \"file\", \"source\": {\n    \"data\": \"base64_encoded_pdf_content\",\n    \"media_type\": \"application/pdf\"\n}}\n\n# Method 3: File reference\n{\"type\": \"file\", \"source\": {\"file_id\": \"file_abc123\"}}  # Files API"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"API Integration"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Files API (beta) - upload PDF once\nfile_response = claude.files.create(\n    file=\"document.pdf\",\n    purpose=\"pdf_processing\"\n)\nfile_id = file_response.id  # \"file_abc123\"\n\n# Reference in subsequent requests\nmessages=[{\n    \"role\": \"user\",\n    \"content\": [\n        {\"type\": \"file\", \"source\": {\"file_id\": file_id}},\n        {\"type\": \"text\", \"text\": \"Summarize this document\"}\n    ]\n}]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Real-World Examples"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example 1: Chart Extraction"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"User: \"What does the chart on page 10 show?\"\n\nProcessing:\n1. System extracts page 10 → image + text\n2. Claude analyzes image (chart as pixels)\n3. Vision model reads chart values\n4. Response: \"The chart shows revenue increasing 25% from Q1 ($1M) to Q4 ($1.25M)\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example 2: Table Parsing"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"User: \"Extract the financial data from the table on page 5\"\n\nProcessing:\n1. Page 5 → image + text extraction\n2. Claude analyzes image (table layout preserved)\n3. Vision model parses cell structure\n4. Response: JSON with rows/columns and values"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example 3: Diagram Understanding"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"User: \"Explain the workflow shown in this diagram\"\n\nProcessing:\n1. Page with diagram → image + text\n2. Claude analyzes image (diagram as visual)\n3. Vision model understands flow, connections, labels\n4. Response: Step-by-step workflow explanation"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example 4: Scanned PDF OCR"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"User: \"Extract all text from this scanned contract\"\n\nProcessing:\n1. Each scanned page → image (text is pixels)\n2. OCR applied to extract text from images\n3. Text + image combined\n4. Response: Extracted text with formatting preserved"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Benefits of This Approach"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Benefit"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Explanation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"No manual parsing"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Claude's API handles everything automatically"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"No RAG pipeline needed"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No need to set up your own Retrieval-Augmented Generation system"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"No OCR setup"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Vision components handle scanned PDFs automatically"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"