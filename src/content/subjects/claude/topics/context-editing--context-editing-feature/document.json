em","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Short sessions (<30 min)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Starting "},{"type":"text","marks":[{"type":"bold"}],"text":"totally new phase"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How to Implement (Step-by-Step)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Enable Beta Flag"},{"type":"text","text":" (API)"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"betas: [\"context-management-2025-06-27\"]"}]},{"type":"paragraph","content":[{"type":"text","text":"Required to access context editing."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Configure Edit Policy"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"context_management: {\n  edits: [\n    {\n      type: \"clear_tool_uses_20250919\",\n      trigger: { type: \"tool_uses\", value: 2 },\n      keep: { type: \"tool_uses\", value: 1 }\n    }\n  ]\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"Removes old tool results when 2 new ones accumulate, keeps most recent."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Use Compatible Model"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"model: \"claude-4-sonnet-20251027\" // Sonnet 4.5"}]},{"type":"paragraph","content":[{"type":"text","text":"Available on "},{"type":"text","marks":[{"type":"bold"}],"text":"Sonnet 4.5, Sonnet 4.6, Opus 4.6, Opus 4.7, Opus 4.8, Mythos 5, Fable 5"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Monitor Applied Edits"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"if (response.provider_data?.context_management?.applied_edits) {\n  const edits = response.provider_data.context_management.applied_edits;\n  const lastEdit = edits[edits.length - 1];\n  \n  console.log(`Tokens saved: ${lastEdit.cleared_input_tokens}`);\n  console.log(`Tool uses cleared: ${lastEdit.cleared_tool_uses}`);\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"Track token savings and tool removals."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Combine with Memory Tool"},{"type":"text","text":" (Agentic Workflows)"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Memory tool stores insights outside context window\ncontext_management: {\n  edits: [\n    {\n      type: \"clear_tool_uses_20250919\",\n      trigger: { type: \"tool_uses\", value: 2 },\n      keep: { type: \"tool_uses\", value: 1 }\n    }\n  ],\n  memory: {\n    enabled: true,\n    directory: \"/path/to/memory\" // Client-side storage\n  }\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Combined"},{"type":"text","text":": 39% performance improvement vs. 29% for editing alone."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Set Custom Triggers"},{"type":"text","text":" (Advanced)"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"edits: [\n  {\n    type: \"clear_tool_uses_20250919\",\n    trigger: { type: \"tool_uses\", value: 3 }, // 3 new tool uses\n    keep: { type: \"tool_uses\", value: 2 }      // Keep 2 most recent\n  },\n  {\n    type: \"clear_thinking_blocks\",\n    trigger: { type: \"token_threshold\", value: 150000 },\n    keep: { type: \"thinking_blocks\", value: 1 }\n  }\n]"}]},{"type":"paragraph","content":[{"type":"text","text":"Multiple policies for different content types."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"7. "},{"type":"text","marks":[{"type":"bold"}],"text":"Implement Backup Strategy"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Before context editing clears tool results\nasync function backupToolResults(toolResults) {\n  await fs.writeFileSync(\n    '/backups/tool-results-' + Date.now() + '.json',\n    JSON.stringify(toolResults)\n  );\n}\n\n// Check for applied edits\nif (response.provider_data?.context_management?.applied_edits) {\n  const lastEdit = response.provider_data.context_management.applied_edits[-1];\n  if (lastEdit.cleared_tool_uses > 0) {\n    console.log(`⚠️ ${lastEdit.cleared_tool_uses} tool results cleared`);\n    // Optionally restore from backup if needed\n  }\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"No native undo → backup externally."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Examples"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example 1: 100-Turn Web Search Agent"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Without context editing"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Turn 30: Context = 185k tokens → fails (context exhausted)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"With context editing"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Turn 100: Context = 45k tokens → completes successfully\nTokens saved: 84% reduction\nTool results cleared: 127 tool uses"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example 2: Codebase Refactoring Agent"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Agent reads files, runs tests, grep searches\nconst tools = [\n  { name: \"read_file\", description: \"Read file contents\" },\n  { name: \"run_tests\", description: \"Execute test suite\" },\n  { name: \"grep\", description: \"Search codebase\" }\n];\n\n// Context editing configured\nconst response = await anthropic.messages.create({\n  betas: [\"context-management-2025-06-27\"],\n  context_management: {\n    edits: [\n      {\n        type: \"clear_tool_uses_20250919\",\n        trigger: { type: \"tool_uses\", value: 2 },\n        keep: { type: \"tool_uses\", value: 1 }\n      }\n    ]\n  },\n  model: \"claude-4-sonnet-20251027\",\n  tools: tools\n});\n\n// After 50 tool calls:\n// Cleared: 48 tool uses (kept 2 most recent)\n// Saved: 142,000 tokens\n// Agent continues refactoring without interruption"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example 3: Debugging Insights with Memory Tool"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Agent discovers root cause, saves to memory\ncontext_management: {\n  edits: [\n    {\n      type: \"clear_tool_uses_20250919\",\n      trigger: { type: \"tool_uses\", value: 2 },\n      keep: { type: \"tool_uses\", value: 1 }\n    }\n  ],\n  memory: {\n    enabled: true,\n    directory: \"/app/memory\"\n  }\n}\n\n// Session 1: Find root cause → save to memory\nawait saveToMemory({\n  key: \"auth-module-root-cause\",\n  value: \"JWT token expiry bug on line 847 of auth.ts\"\n});\n\n// Session 2: Clear context, recall from memory\nconst rootCause = await readFromMemory(\"auth-module-root-cause\");\n// Agent knows previous debugging insights without keeping 8,000 tokens"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Combined editing + memory"},{"type":"text","text":": 39% performance improvement."}]