ype":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Pre-configured triggers"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use custom edit policies"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How It Works"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Automatic Removal Process"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"1. Context grows → approach token limit\n2. Context editing detects stale tool uses\n3. Removes old tool calls + results (not user/assistant)\n4. Preserves conversation flow\n5. Agent continues without interruption"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What gets removed"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"code"}],"text":"tool_uses"},{"type":"text","text":" (older calls)\n- Tool results (outputs)\n- Thinking blocks (previous reasoning)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What gets preserved"},{"type":"text","text":":\n- User messages\n- Assistant responses\n- Conversation structure"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Configuration (Anthropic API)"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"import { Anthropic } from '@anthropic-ai/sdk';\n\nconst anthropic = new Anthropic({\n  betas: [\"context-management-2025-06-27\"], // Enable context editing\n  context_management: {\n    edits: [\n      {\n        type: \"clear_tool_uses_20250919\",\n        trigger: { type: \"tool_uses\", value: 2 }, // When 2 new tool uses\n        keep: { type: \"tool_uses\", value: 1 }     // Keep 1 most recent\n      }\n    ]\n  }\n});\n\nco