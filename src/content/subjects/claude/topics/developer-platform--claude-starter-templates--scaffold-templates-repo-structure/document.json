        "content": [
          {
            "type": "text",
            "text": "The prompts/ directory"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "yaml"
        },
        "content": [
          {
            "type": "text",
            "text": "# prompts/my-feature.yml — scaffold seed template\ntemplate_id: my-feature                 # replace with integration name\nversion: 0.1.0\nmodel_id: claude-sonnet-5               # or claude-haiku-4-5-20251001\nmax_input_tokens: 8000                  # set based on expected context size\nmax_output_tokens: 1024                 # set based on expected response length\nsafety_baseline_version: v3.1          # do not change; always use current canonical\ntoken_budget_version: \"1.0\"\n\n# Capability list — replace with your integration's actual capabilities\ncapability_list:\n  - \"DO: [describe the primary task this integration should perform]\"\n  - \"DO NOT: [describe what this integration must never do]\"\n\n# Eval suite location\neval_suite: evals/\n\n# CI blocking criteria\nblocking_criteria:\n  eval:\n    min_pass_rate: 0.90\n    max_regression_delta: 0.05\n  injection:\n    probe_sets:\n      - standard\n  process:\n    require_security_reviewer: false   # set true for customer-facing integrations"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "The src/ directory"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# src/handler.py — scaffold seed handler\nfrom claude_client import ClaudeClient\nfrom .context_builder import build_context\nfrom .response_parser import parse_response\nfrom template_registry import TemplateRegistry\nimport structlog\n\nlog = structlog.get_logger()\nregistry = TemplateRegistry()\nclient = ClaudeClient.from_env()\n\nasync def handle_request(\n    user_message: str,\n    context_data: dict,\n) -> dict:\n    \"\"\"Main entry point for the feature.\n\n    Args:\n        user_message: The user's input message.\n        context_data: Application context to inject (e.g., account data, history).\n\n    Returns:\n        Parsed response dict with 'content' and 'stop_reason' keys.\n    \"\"\"\n    template = registry.get(\"my-feature\", version=\"latest\")\n    context = build_context(context_data)\n\n    response = await client.create_message(\n        model=template.model_id,\n        max_tokens=template.max_output_tokens,\n        system=template.system_prompt,\n        messages=[\n            *context,\n            {\"role\": \"user\", \"content\": user_message},\n        ],\n    )\n\n    log.info(\n        \"feature_request\",\n        template_id=template.template_id,\n        template_version=template.version,\n        input_tokens=response.usage.input_tokens,\n        output_tokens=response.usage.output_tokens,\n        stop_reason=response.stop_reason,\n    )\n\n    return parse_response(response)"
          }
        ]
      },
