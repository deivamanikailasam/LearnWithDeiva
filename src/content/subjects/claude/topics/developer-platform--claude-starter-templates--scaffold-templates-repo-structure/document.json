        "content": [
          {
            "type": "text",
            "text": "What the scaffold's CI workflow contains"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "yaml"
        },
        "content": [
          {
            "type": "text",
            "text": "# .github/workflows/claude-ci.yml — pre-wired by scaffold\nname: Claude CI\n\non:\n  push:\n    branches: [main]\n  pull_request:\n\njobs:\n  gate-1-schema-validation:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n      - run: pip install pyyaml jsonschema\n      - run: python scripts/validate-template-schema.py prompts/my-feature.yml\n\n  gate-2-injection:\n    runs-on: ubuntu-latest\n    needs: gate-1-schema-validation\n    steps:\n      - uses: actions/checkout@v4\n      - run: pip install anthropic\n      - run: python scripts/run-injection-probes.py prompts/my-feature.yml\n        env:\n          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}\n\n  gate-3-eval:\n    runs-on: ubuntu-latest\n    needs: gate-2-injection\n    steps:\n      - uses: actions/checkout@v4\n      - run: pip install anthropic\n      - run: python evals/run_evals.py --dataset evals/golden_dataset.jsonl --template prompts/my-feature.yml\n        env:\n          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}\n\n  fitness-functions:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n      - run: pip install pytest pyyaml\n      - run: pytest tests/fitness/ -v\n\n  architecture-drift:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n      - run: pip install pyyaml\n      - run: python scripts/detect-architecture-drift.py\n\n  doc-completeness:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n      - run: python scripts/check-doc-completeness.py"
          }
        ]
      },
