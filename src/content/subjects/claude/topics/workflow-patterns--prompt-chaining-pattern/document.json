:"text","text":"Improves user experience in conversational assistants"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Anthropic's Dynamic Workflows (Beyond Prompt Chaining)"}]},{"type":"paragraph","content":[{"type":"text","text":"Important: Anthropic's engineers "},{"type":"text","marks":[{"type":"bold"}],"text":"stopped manually chaining prompts"},{"type":"text","text":" in May 2026. They now use "},{"type":"text","marks":[{"type":"bold"}],"text":"Dynamic Workflows in Claude Code"},{"type":"text","text":" — where Claude writes its own custom JavaScript harness on the fly:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Traditional Prompt Chaining"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Dynamic Workflows"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"You hand-code 50 prompt chains"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Claude writes harness JavaScript automatically"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Static, linear flow"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Subagents, parallel execution, per-agent model choice"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":