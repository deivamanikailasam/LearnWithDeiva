{"format":"tiptap/v1","updatedAt":"2026-06-21T01:44:58.117Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"To get a Claude API key: go to "},{"type":"text","marks":[{"type":"bold"}],"text":"console.anthropic.com"},{"type":"text","text":", sign in, click "},{"type":"text","marks":[{"type":"bold"}],"text":"API Keys"},{"type":"text","text":" in the left sidebar, click "},{"type":"text","marks":[{"type":"bold"}],"text":"Create Key"},{"type":"text","text":", name it (e.g., "},{"type":"text","marks":[{"type":"code"}],"text":"my-chatbot-dev"},{"type":"text","text":"), "},{"type":"text","marks":[{"type":"bold"}],"text":"copy it immediately"},{"type":"text","text":" (you'll never see it again), and store it as the environment variable "},{"type":"text","marks":[{"type":"code"}],"text":"ANTHROPIC_API_KEY"},{"type":"text","text":"—never hardcode it in code or commit it to Git."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Detailed Step-by-Step Guide"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 1: Create or Sign In to Your Anthropic Account"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Open your browser and go to "},{"type":"text","marks":[{"type":"bold"}],"text":"console.anthropic.com"},{"type":"text","text":" (this redirects to "},{"type":"text","marks":[{"type":"bold"}],"text":"platform.claude.com"},{"type":"text","text":", the Anthropic developer dashboard)."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"If you don't have an account, sign up using:"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- Email + password - Google OAuth - SSO (for enterprise accounts)\n3. Complete your profile and set up "},{"type":"text","marks":[{"type":"bold"}],"text":"billing"},{"type":"text","text":" (pay-as-you-go). New accounts typically get "},{"type":"text","marks":[{"type":"bold"}],"text":"$5 in free API credits"},{"type":"text","text":" to start.\n4. For production use, you may need to complete "},{"type":"text","marks":[{"type":"bold"}],"text":"identity verification"},{"type":"text","text":" (required in 2026) and add a prepaid credit (minimum $5) to unlock Tier‑1 rate limits."}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tip:"},{"type":"text","text":" Even if you already have a Claude.ai subscription (e.g., Max plan), you still need to create a developer account at console.anthropic.com to access API keys."}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 2: Navigate to the API Keys Section"}]},{"type":"paragraph","content":[{"type":"text","text":"Once logged in to the dashboard:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Look for "},{"type":"text","marks":[{"type":"bold"}],"text":"\"API Keys\""},{"type":"text","text":" in the "},{"type":"text","marks":[{"type":"bold"}],"text":"left sidebar"},{"type":"text","text":" under the \"Manage\" or \"Settings\" section."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Alternatively, click "},{"type":"text","marks":[{"type":"bold"}],"text":"\"Get API Key\""},{"type":"text","text":" on the main dashboard, which also takes you to the API Keys page."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"On the API Keys page, you'll see:"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- Your existing keys (with name, prefix, created date, last used, and status) - A "},{"type":"text","marks":[{"type":"bold"}],"text":"\"Create Key\""},{"type":"text","text":" button in the top-right corner."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 3: Create a New API Key"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Click "},{"type":"text","marks":[{"type":"bold"}],"text":"\"Create Key\""},{"type":"text","text":" (or \"+ Create Key\")."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Enter a "},{"type":"text","marks":[{"type":"bold"}],"text":"descriptive name"},{"type":"text","text":" for the key, such as:"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- "},{"type":"text","marks":[{"type":"code"}],"text":"my-chatbot-dev"},{"type":"text","text":" - "},{"type":"text","marks":[{"type":"code"}],"text":"claude-code-personal"},{"type":"text","text":" - "},{"type":"text","marks":[{"type":"code"}],"text":"production-app"},{"type":"text","text":"\n3. Optionally, select a "},{"type":"text","marks":[{"type":"bold"}],"text":"workspace"},{"type":"text","text":" if you have multiple (this scopes the key by project/environment).\n4. Click "},{"type":"text","marks":[{"type":"bold"}],"text":"\"Create Key\""},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"bold"}],"text":"\"Add\""},{"type":"text","text":" to generate the key."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 4: Copy and Save Your API Key Immediately"}]},{"type":"paragraph","content":[{"type":"text","text":"Your API key will appear in the format:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx..."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Critical:"},{"type":"text","text":" You "},{"type":"text","marks":[{"type":"bold"}],"text":"will only see the full key once"},{"type":"text","text":" on this page. After you leave or refresh, you won't be able to view it again."}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Click the copy button"},{"type":"text","text":" or manually copy the entire key."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Store it in a "},{"type":"text","marks":[{"type":"bold"}],"text":"secure location"},{"type":"text","text":":"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- Password manager (e.g., 1Password, Bitwarden) - Secrets manager (e.g., AWS Secrets Manager, HashiCorp Vault) - Encrypted "},{"type":"text","marks":[{"type":"code"}],"text":".env"},{"type":"text","text":" file (for local development only)\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Do NOT"},{"type":"text","text":": - Hardcode the key in your source code - Commit it to Git, GitHub, GitLab, or any public repository - Share it with others or post it in public chats"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Configuring Your API Key for Development"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Recommended: Use an Environment Variable"}]},{"type":"paragraph","content":[{"type":"text","text":"The safest and most common approach is to set the key as the "},{"type":"text","marks":[{"type":"code"}],"text":"ANTHROPIC_API_KEY"},{"type":"text","text":" environment variable. Both the Python and TypeScript SDKs automatically read this variable."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"macOS / Linux (bash or zsh)"}]},{"type":"paragraph","content":[{"type":"text","text":"For a "},{"type":"text","marks":[{"type":"bold"}],"text":"one-time"},{"type":"text","text":" setup in your current terminal:"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"export ANTHROPIC_API_KEY=\"sk-ant-api03-your-key-here\""}]},{"type":"paragraph","content":[{"type":"text","text":"To make it "},{"type":"text","marks":[{"type":"bold"}],"text":"permanent"},{"type":"text","text":" across sessions:"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# For zsh (default on macOS)\necho 'export ANTHROPIC_API_KEY=\"sk-ant-api03-your-key-here\"' >> ~/.zshrc\nsource ~/.zshrc\n\n# For bash\necho 'export ANTHROPIC_API_KEY=\"sk-ant-api03-your-key-here\"' >> ~/.bashrc\nsource ~/.bashrc"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Windows PowerShell"}]},{"type":"paragraph","content":[{"type":"text","text":"For current session:"}]},{"type":"codeBlock","attrs":{"language":"powershell"},"content":[{"type":"text","text":"$env:ANTHROPIC_API_KEY = \"sk-ant-api03-your-key-here\""}]},{"type":"paragraph","content":[{"type":"text","text":"For "},{"type":"text","marks":[{"type":"bold"}],"text":"permanent"},{"type":"text","text":" user-level setup:"}]},{"type":"codeBlock","attrs":{"language":"powershell"},"content":[{"type":"text","text":"[System.Environment]::SetEnvironmentVariable(\"ANTHROPIC_API_KEY\", \"sk-ant-api03-your-key-here\", \"User\")"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Windows Command Prompt"}]},{"type":"codeBlock","attrs":{"language":"cmd"},"content":[{"type":"text","text":"setx ANTHROPIC_API_KEY \"sk-ant-api03-your-key-here\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Local Development: Using a "},{"type":"text","marks":[{"type":"code"}],"text":".env"},{"type":"text","text":" File"}]},{"type":"paragraph","content":[{"type":"text","text":"For local projects, you can store the key in a "},{"type":"text","marks":[{"type":"code"}],"text":".env"},{"type":"text","text":" file:"}]},{"type":"codeBlock","attrs":{"language":"env"},"content":[{"type":"text","text":"ANTHROPIC_API_KEY=sk-ant-api03-your-key-here"}]},{"type":"paragraph","content":[{"type":"text","text":"Then:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Add "},{"type":"text","marks":[{"type":"code"}],"text":".env"},{"type":"text","text":" to your "},{"type":"text","marks":[{"type":"code"}],"text":".gitignore"},{"type":"text","text":":"}]}]}]},{"type":"codeBlock","attrs":{"language":"gitignore"},"content":[{"type":"text","text":".env\n*.env"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"In Python, load it with "},{"type":"text","marks":[{"type":"code"}],"text":"python-dotenv"},{"type":"text","text":":"}]}]}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from dotenv import load_dotenv\nimport os\n\nload_dotenv(\".env\")\nclient = anthropic.Anthropic()  # automatically reads ANTHROPIC_API_KEY"}]},{"type":"paragraph","content":[{"type":"text","text":"In Node.js, you can use "},{"type":"text","marks":[{"type":"code"}],"text":"dotenv"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import \"dotenv/config\";\nimport Anthropic from \"@anthropic-ai/sdk\";\n\nconst client = new Anthropic(); // reads ANTHROPIC_API_KEY from env"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Interactive Setup in Claude Code (Alternative)"}]},{"type":"paragraph","content":[{"type":"text","text":"If you're using "},{"type":"text","marks":[{"type":"bold"}],"text":"Claude Code"},{"type":"text","text":", on first launch it will prompt:"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"claude\n# Paste your key and press Enter"}]},{"type":"paragraph","content":[{"type":"text","text":"This stores the key locally for Claude Code only. For production and general SDKs, prefer environment variables."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Installing the Official SDKs"}]},{"type":"paragraph","content":[{"type":"text","text":"Once your API key is set, install the SDK for your language:"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Python"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"pip install anthropic"}]},{"type":"paragraph","content":[{"type":"text","text":"Then verify:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\nimport os\n\nclient = anthropic.Anthropic(\n    api_key=os.environ.get(\"ANTHROPIC_API_KEY\")\n)\n\nmessage = client.messages.create(\n    model=\"claude-sonnet-4-5-20250514\",\n    max_tokens=1024,\n    messages=[{\"role\": \"user\", \"content\": \"Hello, Claude!\"}]\n)\n\nprint(message.content)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Node.js / TypeScript"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"npm install @anthropic-ai/sdk"}]},{"type":"paragraph","content":[{"type":"text","text":"Then verify:"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import Anthropic from \"@anthropic-ai/sdk\";\n\nconst client = new Anthropic(); // reads ANTHROPIC_API_KEY automatically\n\nasync function hello() {\n  const msg = await client.messages.create({\n    model: \"claude-sonnet-4-5-20250514\",\n    max_tokens: 1024,\n    messages: [{ role: \"user\", content: \"Hello, Claude!\" }]\n  });\n  console.log(msg.content[0].text);\n}\n\nhello().catch(console.error);"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Security Best Practices"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Never Expose Keys in Code or Git"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Never"},{"type":"text","text":" hardcode API keys in source files, "},{"type":"text","marks":[{"type":"code"}],"text":".claude/settings.json"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"CLAUDE.md"},{"type":"text","text":", or config files that get committed."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Never"},{"type":"text","text":" commit "},{"type":"text","marks":[{"type":"code"}],"text":".env"},{"type":"text","text":" files or credential files to Git."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Always use "},{"type":"text","marks":[{"type":"bold"}],"text":"environment variables"},{"type":"text","text":" or a "},{"type":"text","marks":[{"type":"bold"}],"text":"secrets manager"},{"type":"text","text":"."}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Use Separate Keys for Environments"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Create different keys for:"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- "},{"type":"text","marks":[{"type":"code"}],"text":"development"},{"type":"text","text":" - "},{"type":"text","marks":[{"type":"code"}],"text":"staging"},{"type":"text","text":" - "},{"type":"text","marks":[{"type":"code"}],"text":"production"},{"type":"text","text":"\n- This reduces blast radius if one key is compromised and lets you track usage per environment."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Rotate Keys Regularly"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Create a new key before revoking the old one."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Update all applications using the key."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Revoke the old key only after confirming the new one works."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Set up alerts for unusual usage."}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"If Your Key Is Compromised"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Go to "},{"type":"text","marks":[{"type":"bold"}],"text":"Console → API Keys → Deactivate"},{"type":"text","text":" the compromised key."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Generate a "},{"type":"text","marks":[{"type":"bold"}],"text":"new key"},{"type":"text","text":"."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Replace the key in all environments and deployments."}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Understanding Pricing & Cost Management"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Pricing Tiers (as of 2026)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Model"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Price Level"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Characteristics"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"