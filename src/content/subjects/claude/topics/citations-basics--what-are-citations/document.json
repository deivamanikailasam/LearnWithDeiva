{"format":"tiptap/v1","updatedAt":"2026-06-21T17:40:52.737Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Citations"},{"type":"text","text":" in Claude's system are automatically generated references that link the AI's claims and answers back to the exact sentences, passages, and locations in source documents where that information originated, enabling verification and reducing hallucinations."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What it is"}]},{"type":"paragraph","content":[{"type":"text","text":"Citations are "},{"type":"text","marks":[{"type":"bold"}],"text":"precise source references embedded in Claude's responses"},{"type":"text","text":" that show users exactly which parts of uploaded documents (PDFs, text files) support each claim."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key concept:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Claude can now provide detailed references to the exact sentences and passages it uses to generate responses, leading to more verifiable, trustworthy outputs.\""}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why it matters"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Without Citations"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"With Citations"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Readers can't verify AI claims"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Users trace claims to source text"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Risk of hallucination"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Cited text minimizes hallucinations"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Manual prompt engineering needed"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Automatic, built-in citing"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Inconsistent source attribution"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Consistent, reliable citations"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Core benefit:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Citations builds upon this foundation, addressing a specific need in AI applications: verifying the sources behind AI-generated responses.\""}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How Citations Work"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Source Document Processing"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Step 1: User uploads document (PDF or text)\n  ↓\nStep 2: API chunks document into sentences\n  ↓\nStep 3: Chunked sentences + user context passed to model\n  ↓\nStep 4: Claude analyzes query + generates response\n  ↓\nStep 5: Citations automatically added for claims from sources"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Technical process:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"When Citations is enabled, the API processes user-provided source documents (PDF documents and plain text files) by chunking them into sentences. These chunked sentences, along with user-provided context, are then passed to the model with the user's query.\""}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Alternative:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Alternatively, users can provide their own chunks for the source documents.\""}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Automatic Citation Generation"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"User Query: \"What were Q3 revenue figures?\"\n  ↓\nClaude analyzes query + searches source chunks\n  ↓\nGenerates response: \"Q3 revenue was $1.2M [p. 15]\"\n  ↓\nCitation automatically links to exact sentence in source"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What happens:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Claude analyzes the query and generates a response that includes precise citations based on the provided chunks and context for any claims derived from the source material.\""}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key rule:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Cited text will reference source documents to minimize hallucinations.\""}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Citation Format"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Page Number Citations"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"For PDFs:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"The methodology uses a randomized controlled trial design [p. 45].\nKey findings show 25% improvement in outcomes [pp. 78-82]."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"For plain text documents:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Citations include character ranges showing exact position in text.\nExample: \"Revenue increased 15% [chars 1234-1256]\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Citation structure:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Citations include the page number range (1-indexed). For plain text documents: Citations include character ranges.\""}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Citation Types"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Format"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Example"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Single page"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"[p. X]"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"[p. 45]"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Page range"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"[pp. X-Y]"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"[pp. 78-82]"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Character range (text)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"[chars X-Y]"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"[chars 1234-1256]"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How to Enable Citations"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Via API Parameters"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\nresponse = client.messages.create(\n    model=\"claude-3-5-sonnet-20241022\",  # Supports Citations\n    max_tokens=1024,\n    betas=[\"citations-2024-09-19\"],  # Enable Citations beta\n    messages=[{\n        \"role\": \"user\",\n        \"content\": [\n            {\n                \"type\": \"document\",\n                \"source\": {\n                    \"type\": \"base64\",\n                    \"media_type\": \"application/pdf\",\n                    \"data\": encoded_pdf\n                },\n                \"citations\": {  # Enable citations for this document\n                    \"enabled\": True\n                }\n            },\n            {\n                \"type\": \"text\",\n                \"text\": \"What were the Q3 revenue figures?\"\n            }\n        ]\n    }]\n)\n\n# Citations appear in response metadata\nprint(response.citations)  # List of citation objects"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key parameter:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Beta header"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"citations-2024-09-19"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Model support"},{"type":"text","text":": Claude 3.5 Sonnet and Claude 3.5 Haiku"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Via API Documentation"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Enable Citations when creating message\nresponse = client.beta.messages.create(\n    model=\"claude-3-5-sonnet-20241022\",\n    cudf=\"citations\",  # Citations feature flag\n    messages=[...]\n)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Use Cases"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Document Summarization"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Generate concise summaries of long documents, like case files, \nwith each key point linked back to its original source.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example output:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Case Summary:\n- Defendant filed motion on March 15 [p. 12]\n- Court granted motion on April 2 [p. 18]\n- Settlement amount: $500,000 [p. 25]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Complex Q&A"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Provide detailed answers to user queries across a large corpus \nof documents, like financial statements, with each response \nelement traced back to specific sections of relevant texts.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example output:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Q: What were Q3 revenue figures?\nA: Q3 revenue was $1.2M, representing 15% growth from Q2 [pp. 15-16]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Customer Support"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Create support systems that can answer complex queries by \nreferencing multiple product manuals, FAQs, and support tickets, \nalways citing the exact source of information.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example output:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Q: How do I reset my password?\nA: Go to Settings → Account → Security → Reset Password [Manual p. 8, FAQ p. 3]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Legal Contract Review"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Extract key terms and clauses with source references:\n- Termination clause: 30-day notice required [p. 5]\n- Payment terms: $5,000/month [p. 7]\n- Indemnification: Provider liable for damages [p. 9]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Research Paper Analysis"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Extract methodology and findings:\n- Methodology: Randomized controlled trial (n=500) [p. 45]\n- Key findings: 25% improvement in outcomes [pp. 78-82]\n- Limitations: Sample size too small [p. 95]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Benefits of Citations"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Benefit"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Explanation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Enhanced accountability"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Trace every claim to source"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Reduced hallucination"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Cited text references source documents"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Verifiable outputs"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Users verify sources behind AI responses"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Trustworthy results"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Detailed references build confidence"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"No prompt engineering"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Automatic, built-in citing"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Consistent performance"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No inconsistent manual attribution"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key advantage:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Previously, developers relied on complex prompts that instruct Claude to include source information, often resulting in inconsistent performance and significant time investment in prompt engineering and testing. With Citations, users can now add source documents to the context window, and when querying the model, Claude automatically cites claims in its output that are inferred from those sources.\""}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Limitations & Considerations"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Limitation"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Detail"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Model support"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Only Claude 3.5 Sonnet and Claude 3.5 Haiku"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Document types"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"PDF documents and plain text files only"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Beta feature"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Citations is in beta (citations-2024-09-19)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Chunking required"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Documents must be chunked into sentences"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"User-provided chunks"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Optional: users can provide custom chunks"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Important note:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"All Claude models are trained to be trustworthy and steerable by design. Citations builds upon this foundation, addressing a specific need in AI applications.\""}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Citation vs. Non-Citation Comparison"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"ro