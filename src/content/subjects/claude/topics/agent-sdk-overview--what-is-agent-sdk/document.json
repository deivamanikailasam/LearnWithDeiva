t":"CI without human involvement"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Implement Continuous Integration autonomously"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Integration into larger systems"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Agent within existing system with state management"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multi-agent orchestration"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Delegate between agents, custom storage"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": \"You can supply it with specifications, and it will execute a series of skills or commands autonomously, ultimately generating a pull request once the task is completed\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It's NOT"}]},{"type":"paragraph","content":[{"type":"text","text":"The Agent SDK is "},{"type":"text","marks":[{"type":"bold"}],"text":"not"},{"type":"text","text":":"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Not What"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Why"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"AI model"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Doesn't decide what agent says"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Orchestration engine"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"You wire in AI service or business logic"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No-code builder"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Requires programming in Python/TypeScript"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Clarification"},{"type":"text","text":": \"The Agent SDK doesn't decide what an agent says. These elements are the job of whatever AI service or business logic the developer wires into the agent\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of the Agent SDK like "},{"type":"text","marks":[{"type":"bold"}],"text":"turning a power tool into a programmable robot"},{"type":"text","text":": Claude Code is the power drill (brilliant, autonomous, does everything). The Agent SDK is the mechanical arm + controller that lets you program the drill to do specific tasks automatically — read this file, run this command, edit this code, verify it worked, repeat until done. You're not building a new drill; you're exposing the existing drill's capabilities to your code."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Agent SDK = Claude Code as a library (formerly Claude Code SDK, renamed)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Build AI agents that autonomously read files, run commands, search web, edit code"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Same tools, agent loop, context management as Claude Code — programmable in Python/TypeScript"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Built-in tools: reading files, running commands, editing code — no need to implement tool execution"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Agent Loop: Gather Context → Take Action → Verify Work → Repeat"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Harness: Tools + Prompts + File System + Skills + Sub-agents + Memory"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Opinionated design: Bash tool most powerful, files as memory, context engineering via filesystem"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"She's not an AI model, orchestration engine, or no-code builder — you wire in your AI/service logic"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Python 3.10+, TypeScript/Node.js 18+"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Beneficial when: precise tool call control, CI without humans, agent in larger system, multi-agent orchestration"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"The SDK is built directly on top of Claude Code because Anthropic found they were \"rebuilding the same parts over and over again\" for internal tools, exposing Claude Code's core capabilities as a library."}]}]}}
