aragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"NATS JetStream"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"High-performance messaging"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"High"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Migration rule"},{"type":"text","text":": Migrate from Redis to Kafka when single stream exceeds ~5k events/sec sustained."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Consumer Groups"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Pattern"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Description"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Single consumer"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"One worker per stream; simple, no horizontal scale"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Consumer group"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Multiple workers, partition-keyed for ordering within key"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Event sourcing"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Agent state rebuilt entirely from event log replay"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Trigger-only"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Event is \"go look at the world\" signal; agent re-fetches current state via tools"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Idempotency Store"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Critical for preventing duplicate actions"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Redis approach\nredis.set(\n    f\"idempotency:{event_id}\",\n    \"processed\",\n    ex=3600  # TTL: 1 hour\n)\n\n# Check before processing\nif redis.exists(f\"idempotency:{event_id}\"):\n    return ACK  # Already processed, skip"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Alternative"},{"type":"text","text":": Postgres unique constraint on event_id"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Dead Letter Queue (DLQ)"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Message fails processing\n    ↓\nRetry with backoff (3 attempts)\n    ↓\nStill failing\n    ↓\nRoute to DLQ\n    ↓\nAlert when DLQ depth grows\n    ↓\nFailure analysis offline from main flow"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Purpose"},{"type":"text","text":": Capture messages that fail after retries so failure analysis doesn't block main flow."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Implementation Details"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"AWS Setup Requirements"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# 1. Create SNS topic and SQS queue\naws sns create-topic --name agent-events\naws sqs create-queue --queue-name agent-queue\n\n# 2. Subscribe SQS queue to SNS topic\naws sns subscribe \\\n  --topic-arn arn:aws:sns:region:account:agent-events \\\n  --protocol sqs \\\n  --notification-endpoint arn:aws:sqs:region:account:agent-queue\n\n# 3. Configure DLQ for failed messages\naws sqs create-queue --queue-name agent-dlq\n\n# 4. Set DLQ policy on main queue\naws sqs set-queue-attributes \\\n  --queue-url https://sqs.region.amazonaws.com/account/agent-queue \\\n  --attributes '{\"RedrivePolicy\":\"{...DLQ ARN...}\"}'\n\n# 5. Ensure IAM permissions for SNS publishing and SQS operations"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Lambda + SQS Integration"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import boto3\nimport json\n\n# Lambda function triggered by SQS\ndef lambda_handler(event, context):\n    messages = event['Records']\n    \n    for message in messages:\n        event_id = message['messageId']\n        \n        # Idempotency check\n        if is_already_processed(event_id):\n            continue  # Skip duplicate, auto-ACK\n        \n        # Parse message\n        payload = json.loads(message['body'])\n        \n        # Dispatch to agent\n        try:\n            result = dispatch_to_agent(payload)\n            \n            # Persist outcome\n            persist_outcome(result)\n            \n            # Emit follow-up event (optional)\n            emit_outcome_event(result)\n            \n        except Exception as e:\n            # Retry with backoff\n            if should_retry(event_id):\n                raise  # Lambda will retry, SQS will redeliver\n            else:\n                # Send to DLQ\n                send_to_dlq(message, str(e))"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Design Patterns"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Pattern 1: Compact Message Payloads"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pass references, not inline data"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"event_id\": \"evt-123\",\n  \"type\": \"document_processed\",\n  \"s3_uri\": \"s3://bucket/documents/report.pdf\",\n  \"dynamodb_key\": \"doc-456\"\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why"},{"type":"text","text":": Compact payloads pass S3 URIs, DynamoDB keys, or document IDs rather than inline data; consumer retrieves full payload on demand."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Pattern 2: Backpressure Mechanisms"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Queue depth > threshold\n    ↓\nCloudWatch alarm triggers\n    ↓\nThrottle producers OR scale consumers\n    ↓\nPrevent queues reaching timeout-triggering depths"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Implementation"},{"type":"text","text":": Use CloudWatch alarms on queue depth to trigger producer throttling or consumer scaling."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Pattern 3: Long Polling + Batch Size"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Configure SQS consumers based on latency/throughput requirements"},{"type":"text","text":":"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Setting"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Benefit"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Long polling"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Reduces empty receives (cost savings)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Large batch size"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Amortizes request overhead across more messages"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Trade-off"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Balance empty-receive cost vs per-message latency vs throughput"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Async vs Synchronous Messaging"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Asynchronous (Queue-Triggered) ✅"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Fast Agent → Message Queue → Slow Agent\n    ↓\nDecoupled: each agent operates at optimal pace"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits"},{"type":"text","text":":\n- Agents operate independently at optimal pace\n- Queue absorbs throughput variations\n- Levels load across workflow\n- Slow agents don't block fast agents\n- Each agent scales independently based on queue depth"}]},{"type":"paragraph","content":[{"type":"text","text":"[docs.aws.amazon](https://docs.aws.amazon.com/it_it/wellarchitected/latest/agentic-ai-lens/agentperf04-bp01.md)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Synchronous (HTTP Request) ❌"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Fast Agent → Slow Agent → Response\n    ↓\nTight coupling: slow agent blocks entire chain"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem"},{"type":"text","text":": Synchronous request-response patterns create tight coupling that makes a slow downstream agent block entire upstream chain."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best practice"},{"type":"text","text":": Use asynchronous patterns by default, reserve synchronous communication for interactions requiring immediate responses."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of queue-triggered agents like "},{"type":"text","marks":[{"type":"bold"}],"text":"a restaurant kitchen with a ticket system"},{"type":"text","text":": orders (events) drop into the queue (ticket rack), chefs (agents) pull tickets when they're ready, each chef works at their own pace without waiting for others, and if a ticket is problematic (can't fulfill order), it gets moved to a separate \"messy tickets\" bin (DLQ) for later review. The queue absorbs when orders come faster than chefs can work, preventing chaos."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Queue-triggered agents = agents triggered by queue/stream events instead of HTTP requests"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Core pattern: Subscribe → receive → enrich → decide → act → ACK"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use when: external event trigger, near-real-time reaction, multiple consumers, durable replay needed"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Don't use when: user waiting synchronously, event rate <1/min, tools can't be idempotent"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Event sources: Redis Streams (≤10k/sec), Kafka (10k–1M+), SQS, NATS JetStream"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Idempotency: Redis SET with TTL or Postgres unique constraint on event_id"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"DLQ: Separate stream for poison events after N retry attempts"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"AWS pattern: SNS (pub/sub fan-out) + SQS (queue) + Lambda (agent)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Compact payloads: Pass S3 URIs, DynamoDB keys, document IDs — not inline data"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Backpressure: CloudWatch alarms on queue depth trigger producer throttling or consumer scaling"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Long polling + batch size: balance empty-receive cost vs latency vs throughput"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Async default: agents operate independently, slow agents don't block fast agents"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Async decouples producers from consumers so fast agents are not held up by slow ones, each agent scales independently based on its own queue depth, and failure analysis happens off the main path via DLQs."}]}]}}
