{"format":"tiptap/v1","updatedAt":"2026-06-22T04:42:48.007Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Based on the AWS documentation and industry best practices for event-driven agent architectures, "},{"type":"text","marks":[{"type":"bold"}],"text":"\"Queue-triggered agents (SQS / Pub/Sub → agent dispatch)\""},{"type":"text","text":" is a pattern where "},{"type":"text","marks":[{"type":"bold"}],"text":"AI agents are asynchronously triggered by messages from queue services (like AWS SQS or Pub/Sub systems)"},{"type":"text","text":", enabling scalable, decoupled agent workflows that don't require synchronous HTTP requests."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","text":"Queue-triggered agents create "},{"type":"text","marks":[{"type":"bold"}],"text":"event-driven agent systems"},{"type":"text","text":" where agents are triggered by queue/stream events instead of direct HTTP requests:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Event Source (SQS / Pub/Sub)\n    ↓\nConsumer pulls event\n    ↓\nIdempotency check (duplicate?)\n    ↓\nAgent dispatch (enrich → decide → act)\n    ↓\nOutcome + ACK"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Core Pattern"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Component"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Role"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Event source"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"SQS, Kafka, Redis Streams, NATS that holds events"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Consumer"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Pulls events, dispatches to agent handler, manages ACK lifecycle"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Idempotency store"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Redis SET with TTL or Postgres unique constraint on event_id"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Agent handler"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Receives event, runs reasoning loop, calls tools"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Outcome emitter"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Persists decision + emits follow-up event (optional)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"DLQ"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Dead Letter Queue for poison events after N retry attempts"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Complete Core Flow"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Event source (Redis Streams / Kafka / SQS / NATS)\n    ↓\n[Consumer group: one or more workers pull events]\n    ↓\n[Idempotency check] -- duplicate?\n    ↓\nACK and exit\n    ↓\n[Agent loop: enrich state via tools, decide, act]\n    ↓\n├── success ──> emit outcome event + persist state + ACK\n└── failure ──> retry with backoff; after N attempts, DLQ"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"AWS Architecture: SQS + SNS Pattern"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why SQS + SNS Together"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Publisher → SNS Topic → Multiple SQS Queues → Multiple Lambda/Agents\n    ↓\nImmediate notification (SNS) AND persistent queue (SQS)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"SNS"},{"type":"text","text":" = publish/subscribe fan-out (multiple subscribers to same topic)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"SQS"},{"type":"text","text":" = message queue (durable, polling, retry, DLQ)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Together"},{"type":"text","text":" = messages delivered to apps needing immediate notification AND persisted for later processing"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Complete Architecture Diagram"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Event Source (S3, API, Cron)\n    ↓\nAWS SNS Topic (pub/sub broadcast)\n    ↓\nSQS Queue 1 → Lambda Agent 1\nSQS Queue 2 → Lambda Agent 2\nSQS Queue 3 → Lambda Agent 3\n    ↓\nDLQ (Dead Letter Queue) for failed messages"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"When to Use Queue-Triggered Agents"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"✅ Use When"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Why Queue Works"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Trigger is external event"},{"type":"text","text":" (cancellation, status change, scheduled job)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Not synchronous user request"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Near-real-time reaction needed"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No human waiting synchronously for response"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"ty