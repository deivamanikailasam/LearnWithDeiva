{"format":"tiptap/v1","updatedAt":"2026-06-20T10:23:50.727Z","doc":{"type":"doc","content":[{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Memory"},{"type":"text","text":" is Claude’s cross‑session recall layer: it summarizes key facts from past conversations and uses them automatically in future ones."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"It stores "},{"type":"text","marks":[{"type":"bold"}],"text":"high‑level, stable information"},{"type":"text","text":", like your preferences, ongoing projects, or background details, instead of a verbatim log of every message."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"As of March 2026, Anthropic rolled out "},{"type":"text","marks":[{"type":"bold"}],"text":"persistent memory to all users including the free tier"},{"type":"text","text":", not just paying customers."}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"What it typically remembers:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Personal/profile context you explicitly share and reuse (role, stack, industries)."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Preferences (tone, formatting, coding style, tools)."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Long‑running tasks or projects you revisit often."}]}]}]},{"type":"paragraph"}]}}
