"type":"code"}],"text":"anthropic-beta: extended-thinking-202505-14"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tool integration"},{"type":"text","text":": Must use Messages API with tools"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Thinking enabled"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"thinking: {type: \"enabled\"}"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Appropriate budget"},{"type":"text","text":": 4000-8000 tokens for good reasoning without extreme latency"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why It Matters"}]},{"type":"paragraph","content":[{"type":"text","text":"Interleaved Thinking represents more than a technical improvement—it's a "},{"type":"text","marks":[{"type":"bold"}],"text":"fundamental change"},{"type":"text","text":" evolving Claude from a responsive tool into an "},{"type":"text","marks":[{"type":"bold"}],"text":"adaptive thinking partner"},{"type":"text","text":" that mirrors how human experts actually work: step by step, learning and adjusting as they go."}]},{"type":"paragraph","content":[{"type":"text","text":"This creates "},{"type":"text","marks":[{"type":"bold"}],"text":"explainable problem-solving"},{"type":"text","text":" that reacts dynamically to changing circumstances, where understanding and tracing the model's decision-making process is fundamental."}]}]}}
