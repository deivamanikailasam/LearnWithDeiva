xt":"Performance Differences"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Task Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Better Approach"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Math proofs, combinatorics, exact arithmetic"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Extended thinking (native reasoning)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Multi-file debugging, complex algorithms"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Extended thinking"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Puzzles, chained deductions"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Extended thinking"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Strategic planning with multiple options"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Extended thinking"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Simple factual questions"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Chain-of-thought or direct prompting"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Creative text generation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Direct prompting (no reasoning needed)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Retrieval/Q&A tasks"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Chain-of-thought often better"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use Each"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use Extended Thinking when:"},{"type":"text","text":"\n- Task requires "},{"type":"text","marks":[{"type":"bold"}],"text":"exploration of alternatives"},{"type":"text","text":"\n- You need "},{"type":"text","marks":[{"type":"bold"}],"text":"verification of correctness"},{"type":"text","text":"\n- Task involves "},{"type":"text","marks":[{"type":"bold"}],"text":"catching edge cases"},{"type":"text","text":"\n- Multi-step math, debugging code, strategic planning"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use Chain-of-Thought when:"},{"type":"text","text":"\n- You want "},{"type":"text","marks":[{"type":"bold"}],"text":"visible reasoning"},{"type":"text","text":" for transparency/teaching\n- Task is simpler retrieval or Q&A\n- You want to "},{"type":"text","marks":[{"type":"bold"}],"text":"guide the reasoning steps"},{"type":"text","text":" explicitly\n- Cost matters more than maximum performance"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Hybrid Strategies"}]},{"type":"paragraph","content":[{"type":"text","text":"You can combine both approaches:\n- Enable extended thinking for silent reasoning\n- Add CoT prompting to guide specific aspects of the reasoning\n- This works when you need both deep reasoning and some user control"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Cost & Latency"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Factor"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Chain-of-Thought"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Extended Thinking"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Token cost"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Reasoning tokens = output tokens"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Thinking tokens billed at output rate"}]}]}]},{"type":"ta