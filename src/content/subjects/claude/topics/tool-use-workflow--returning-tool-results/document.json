"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Must optionally flag errors"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use "},{"type":"text","marks":[{"type":"code"}],"text":"is_error: true"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How It Works"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Protocol: "},{"type":"text","marks":[{"type":"code"}],"text":"tool_use_id"},{"type":"text","text":" Linkage"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Step 1: Claude returns tool_use block\n  └─ { type: \"tool_use\", id: \"toolu_01A12v3xX\", name: \"get_stock_price\", input: { symbol: \"AAPL\" } }\n\nStep 2: Your app stores ID\n  └─ const toolId = \"toolu_01A12v3xX\";\n\nStep 3: Your app executes tool\n  └─ const result = getStockPrice(\"AAPL\"); // 175.43\n\nStep 4: Your app sends tool_result with matching ID\n  └─ { type: \"tool_result\", tool_use_id: \"toolu_01A12v3xX\", content: \"175.43\" }\n\nStep 5: Claude continues reasoning with result\n  └─ \"AAPL is currently trading at $175.43\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"code"}],"text":"tool_result"},{"type":"text","text":" Block Structure"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"type\": \"tool_result\",\n  \"tool_use_id\": \"toolu_01A12v3xX\",  // Must match original tool_use.id\n  \"content\": \"175.43\",                  // Result as string (or structured)\n  \"is_error\": false                     // Optional error flag\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Parallel Results Pattern"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Claude requests multiple tools\nconst toolUseBlocks = response.content.filter(c => c.type === \"tool_use\");\n\n// Execute in parallel\nconst results = await Promise.all(\n  toolUseBlocks.map(block => {\n    const { name, input, id } = block;\n    return executeTool(name, input); // Returns result\n  })\n);\n\n// Map results back to tool_use_ids\nconst toolResultBlocks = toolUseBlocks.map((block, i) => ({\n  type: \"tool_result\",\n  tool_use_id: block.id,  // Match original ID\n  content: results[i].toString()\n}));\n\n// Send all results back in one message\nconst response2 = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [\n    ...response.messages,\n    { role: \"user\", content: toolResultBlocks }\n  ],\n  tools: tools\n});"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Match "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_use_id"},{"type":"text","marks":[{"type":"bold"}],"text":" Exactly"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Extract ID from tool_use block\nconst toolUseBlock = response.content.find(c => c.type === \"tool_use\");\nconst toolId = toolUseBlock.id; // \"toolu_01A12v3xX\"\n\n// Store ID before execution\nconst storedId = toolId;\n\n// Execute tool\nconst result = executeTool(toolUseBlock.name, toolUseBlock.input);\n\n// Send back with SAME ID\nconst toolResult = {\n  type: \"tool_result\",\n  tool_use_id: storedId, // Must match exactly\n  content: result.toString()\n};"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Convert Complex Objects to String"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// ❌ Bad: Object as content\nconst toolResult = {\n  type: \"tool_result\",\n  tool_use_id: \"toolu_01A\",\n  content: { price: 175.43, timestamp: \"2026-01-01T12:00:00Z\" } // Wrong!\n};\n\n// ✅ Good: Serialize to string\nconst toolResult = {\n  type: \"tool_result\",\n  tool_use_id: \"toolu_01A\",\n  content: JSON.stringify({ price: 175.43, timestamp: \"2026-01-01T12:00:00Z\" })\n};\n// content: '{\"price\":175.43,\"timestamp\":\"2026-01-01T12:00:00Z\"}'"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Handle Errors with "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"is_error"},{"type":"text","marks":[{"type":"bold"}],"text":" Flag"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"try {\n  const result = executeTool(toolName, toolInput);\n  \n  const toolResult = {\n    type: \"tool_result\",\n    tool_use_id: toolId,\n    content: result.toString(),\n    is_error: false\n  };\n} catch (error) {\n  const toolResult = {\n    type: \"tool_result\",\n    tool_use_id: toolId,\n    content: error.message,\n    is_error: true\n  };\n  \n  console.error(\"Tool execution failed:\", error);\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Send All Parallel Results in One Message"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Multiple tool_use blocks\nconst toolUseBlocks = response.content.filter(c => c.type === \"tool_use\");\n\n// Execute all\nconst results = await Promise.all(\n  toolUseBlocks.map(block => executeTool(block.name, block.input))\n);\n\n// Create all results\nconst toolResultBlocks = toolUseBlocks.map((block, i) => ({\n  type: \"tool_result\",\n  tool_use_id: block.id,\n  content: results[i].toString()\n}));\n\n// Send in one message (not multiple)\nawait client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [\n    ...response.messages,\n    { role: \"user\", content: toolResultBlocks } // One message with all results\n  ],\n  tools: tools\n});"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Use Message History"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Append tool_result to existing messages\nMESSAGES.append({ \"role\": \"assistant\", \"content\": response.content });\nMESSAGES.append({\n  \"role\": \"user\",\n  \"content\": [{\n    \"type\": \"tool_result\",\n    \"tool_use_id\": last_tool_call.id,\n    \"content\": result\n  }]\n});"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_result"},{"type":"text","marks":[{"type":"bold"}],"text":" must include "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_use_id"},{"type":"text","text":" → Links result to original request"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Match ID exactly"},{"type":"text","text":" → Store "},{"type":"text","marks":[{"type":"code"}],"text":"tool_use.id"},{"type":"text","text":" before execution"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Content must be string"},{"type":"text","text":" → Use "},{"type":"text","marks":[{"type":"code"}],"text":"JSON.stringify()"},{"type":"text","text":" for objects"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"is_error: true"},{"type":"text","marks":[{"type":"bold"}],"text":" for failures"},{"type":"text","text":" → Graceful error recovery"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Send parallel results in one message"},{"type":"text","text":" → Efficiency gain"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Append to message history"},{"type":"text","text":" → Don't start fresh, continue conversation"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multiple results for parallel calls"},{"type":"text","text":" → Map each result to its ID"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Protocol completion"},{"type":"text","text":" → Closes the tool loop"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Auditability"},{"type":"text","text":" → Results recorded in conversation"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use SDK Tool Runner"},{"type":"text","text":" → Automatic handling of entire loop"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"For your Box Hill distributed systems work, I'd implement "},{"type":"text","marks":[{"type":"bold"}],"text":"exact "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_use_id"},{"type":"text","marks":[{"type":"bold"}],"text":" matching + "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"JSON.stringify()"},{"type":"text","marks":[{"type":"bold"}],"text":" for complex objects + "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"is_error: true"},{"type":"text","marks":[{"type":"bold"}],"text":" for database failures + single message for parallel results"},{"type":"text","text":". This gives you protocol compliance while maintaining efficiency and error handling."}]}]}}
