{"format":"tiptap/v1","updatedAt":"2026-06-21T16:51:01.721Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Claude supports "},{"type":"text","marks":[{"type":"bold"}],"text":"multiple images in a single prompt"},{"type":"text","text":", allowing you to send and reason over several images at once. This enables powerful use cases like comparisons, sequences, large documents split into chunks, and object identification from examples."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What it is"}]},{"type":"paragraph","content":[{"type":"text","text":"\"Multiple Images\" in vision basics means attaching "},{"type":"text","marks":[{"type":"bold"}],"text":"more than one image"},{"type":"text","text":" to a single user message/prompt, so Claude can analyze them together rather than individually."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Capabilities"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Case"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Description"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Comparisons"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Compare similar items across images (e.g., product versions, design iterations)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sequences"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Analyze time-ordered or step-by-step images (e.g., process flows, before/after)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Large documents"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Split oversized images (long receipts, full-page diagrams) into chunks and feed each chunk"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Object identification from examples"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Pass reference images of different categories, then ask Claude to identify matches"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Limits & Constraints"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Constraint"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Limit"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Web interface"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Maximum "},{"type":"text","marks":[{"type":"bold"}],"text":"5 photos per session"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"API"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Maximum "},{"type":"text","marks":[{"type":"bold"}],"text":"20 images"},{"type":"text","text":" per request"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Resolution per image"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Max "},{"type":"text","marks":[{"type":"bold"}],"text":"2000px height/width"},{"type":"text","text":" when sending multiple images"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Formats"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"PNG, JPEG, GIF, WebP (same as single-image)"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How It Works"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Multiple large image chunks:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Split a large receipt image into chunks\nfrom PIL import Image\n\nimg = Image.open('large_receipt.png')\nchunk_size = 1000  # pixels\n\n# Split into 4 chunks and send all to Claude\nchunks = [img.crop((0, 0, chunk_size, chunk_size)), ...]\n\n# Send all chunks in one message\nresponse = claude.messages.create(\n    messages=[{\"role\": \"user\", \"content\": [\n        {\"type\": \"image\", \"source\": chunk1},\n        {\"type\": \"image\", \"source\": chunk2},\n        {\"type\": \"image\", \"source\": chunk3},\n        {\"type\": \"image\", \"source\": chunk4},\n        {\"type\": \"text\", \"text\": \"What's the restaurant name and total?\"}\n    ]}]\n)"}]},{"type":"paragraph","content":[{"type":"text","text":"Result: Claude sees all chunks as one document and returns the complete answer."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Reference examples for identification:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Pass reference images of different pants types\nresponse = claude.messages.create(\n    messages=[{\"role\": \"user\", \"content\": [\n        {\"type\": \"image\", \"source\": chinos_reference},\n        {\"type\": \"image\", \"source\": jeans_reference},\n        {\"type\": \"image\", \"source\": dress_pants_reference},\n        {\"type\": \"image\", \"source\": unknown_pants},\n        {\"type\": \"text\", \"text\": \"What type of pants is in the last image?\"}\n    ]}]\n)"}]},{"type":"paragraph","content":[{"type":"text","text":"Claude uses the examples to identify the pants type."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Best Practices"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Place all images first"},{"type":"text","text":" in your message before text\n- Claude processes content sequentially, so giving complete visual context upfront improves performance"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Order images logically"},{"type":"text","text":"\n- For comparisons: use consistent left-to-right ordering (e.g., \"Version 1 → Version 2\")\n- For sequences: maintain chronological or step order"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. Be explicit about relationships"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Compare the UI before and after the refactor. Focus on layout changes.\"\n\"Identify which pants type matches the last image based on the examples above.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"4. Use structured output for multi-image extraction"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Extract text from all 4 receipt chunks and return as JSON: {restaurant, total, date}\""}]},{"type":"paragraph","content":[{"type":"text","text":"Structured outputs (JSON) with validators reduce errors."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"5. Crop dense images"},{"type":"text","text":"\n- Clean inputs beat longer prompts; crop/segment when details are dense\n- For OCR on small text, higher resolution per chunk is critical"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Common Mistakes to Avoid"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Mistake"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Fix"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Sending images after text in prompt"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Place "},{"type":"text","marks":[{"type":"bold"}],"text":"all images first"},{"type":"text","text":", then text question"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Exceeding 2000px per image (multi-image)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Downscale each image to ≤2000px"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Not specifying image order relationships"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Explicitly state: \"Image 1 is before, Image 2 is after\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Too many images without clear goal"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use 5-10 max; focus on specific task"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Hallucination on ambiguous comparisons"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Add role assignment: \"You are a UI designer comparing versions\""}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Real-World Example: Scientific Paper Analyzer"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# PDF → multi-page images → extraction\npdf_pages = convert_pdf_to_images('paper.pdf')  # 20 pages\n\n# Send all pages to Claude\nresponse = claude.messages.create(\n    messages=[{\"role\": \"user\", \"content\": [\n        *[{\"type\": \"image\", \"source\": page} for page in pdf_pages],\n        {\"type\": \"text\", \"text\": \"Extract all figures and their captions\"}\n    ]}]\n)"}]},{"type":"paragraph","content":[{"type":"text","text":"This handles multi-page documents that would exceed single-image limits."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Comparison: Single vs. Multiple Images"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Single Image"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Multiple Images"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Max count"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"1"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"5 (web) / 20 (API)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Resolution limit"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"8000×8000px"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"2000×2000px each"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Best for"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Standalone analysis"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Comparisons, sequences, large docs"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Token cost"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Based on pixel count"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Sum of all images' pixel counts"}]}]}]}]},{"type":"paragraph"}]}}
