{"format":"tiptap/v1","updatedAt":"2026-06-21T13:46:23.270Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Tool Use with Prompt Caching"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"1. Caching Tool Definitions"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Where to Place Breakpoints"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"tools = [\n    {\n        \"name\": \"get_weather\",\n        \"description\": \"Get current weather\",\n        \"input_schema\": {...}\n    },\n    {\n        \"name\": \"search_web\",\n        \"description\": \"Search the web\",\n        \"input_schema\": {...},\n        \"cache_control\": {\"type\": \"ephemeral\"}  # ✅ Breakpoint on last tool\n    }\n]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Result:"},{"type":"text","text":" Caches entire tool-definitions prefix from first tool through the marked breakpoint."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"MCP Toolsets (Special Case)"}]},{"type":"paragraph","content":[{"type":"text","text":"For "},{"type":"text","marks":[{"type":"code"}],"text":"mcp_toolset"},{"type":"text","text":", you don't control tool order:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"tools = [\n    {\n        \"name\": \"mcp_toolset\",\n        \"cache_control\": {\"type\": \"ephemeral\"}  # ✅ Breakpoint on entry itself\n    }\n]"}]},{"type":"paragraph","content":[{"type":"text","text":"API applies breakpoint to "},{"type":"text","marks":[{"type":"bold"}],"text":"final expanded tool"},{"type":"text","text":" automatically."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"2. Preserving Cache with Dynamic Tools"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":