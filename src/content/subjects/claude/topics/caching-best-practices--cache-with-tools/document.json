or turn in conversation:\n    messages = [\n        {\n            \"role\": \"system\",\n            \"content\": large_system_prompt + large_codebase + turn.question\n        }\n    ]\n    tools = [get_weather, search_web, ...]\n    response = client.messages.create(model=\"...\", messages=messages, tools=tools)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cost:"},{"type":"text","text":" 100% input price every turn"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"After (With Caching)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Cache system + codebase once\nmessages = [\n    {\n        \"role\": \"system\",\n        \"content\": [\n            {\n                \"type\": \"text\",\n                \"text\": large_system_prompt,\n                \"cache_control\": {\"type\": \"ephemeral\"}  # ✅ Cache 1\n            },\n            {\n                \"type\": \"text\",\n                \"text\": large_codebase,\n                \"cache_control\": {\"type\": \"ephemeral\"}  # ✅ Cache 2\n            }\n        ]\n    }\n]\n\n# Cache tools\ntools = [\n    {\n        \"name\": \"get_weather\",\n        \"input_schema\": {...}\n    },\n    {\n        \"name\": \"search_web\",\n        \"input_schema\": {...},\n        \"cache_control\": {\"type\": \"ephemeral\"}  # ✅ Cache 3\n    }\n]\n\n# Add dynamic question (not cached)\nfor turn in conversation:\n    messages[0][\"content\"].append({\n        \"type\": \"text\",\n        \"text\": turn.question  # ❌ Not cached (dynamic)\n    })\n    response = client.messages.create(model=\"...\", messages=messages, tools=tools)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cost:"},{"type":"text","text":"\n- Turn 1: 125% (write)\n- Turns 2+: 10% (read) → "},{"type":"text","marks":[{"type":"bold"}],"text":"90% savings"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Place breakpoint on last tool"},{"type":"text","text":" — caches entire tool-definitions prefix"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"MCP toolsets: breakpoint on entry"},{"type":"text","text":" — API applies to final expanded tool"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tool search preserves cache"},{"type":"text","text":" — "},{"type":"text","marks":[{"type":"code"}],"text":"tool_reference"},{"type":"text","text":" blocks don't invalidate prefix"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cache hierarchy: tools → system → messages"},{"type":"text","text":" — change invalidates level + everything after"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Server tools get automatic breakpoints"},{"type":"text","text":" — agentic loops read from cache"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Avoid invalidations"},{"type":"text","text":" — don't toggle web search/citations mid-conversation"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"References + caching"},{"type":"text","text":" — stable docs, system prompts, few-shot examples perfect"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Projects cache automatically"},{"type":"text","text":" — documents reused without using messages"}]}]}]},{"type":"paragraph"}]}}
