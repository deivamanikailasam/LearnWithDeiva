        "content": [
          {
            "type": "text",
            "text": "Cost Attribution by Feature"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When a Claude integration serves multiple product features (summarisation, code completion, document Q&A), allocating cost by feature is essential for product decisions. Use the feature label on token counters."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Add feature context via a context variable or parameter\nimport contextvars\n\nCURRENT_FEATURE: contextvars.ContextVar[str] = contextvars.ContextVar(\n    \"current_feature\", default=\"unknown\"\n)\n\n\nasync def call_claude_for_feature(\n    client: anthropic.AsyncAnthropic,\n    feature: str,\n    messages: list[dict],\n    model: str = \"claude-sonnet-5\",\n    max_tokens: int = 1024,\n) -> str:\n    token = CURRENT_FEATURE.set(feature)\n    try:\n        response = await client.messages.create(\n            model=model,\n            messages=messages,\n            max_tokens=max_tokens,\n        )\n        record_token_usage(response, model=model, feature=feature)\n        return response.content[0].text\n    finally:\n        CURRENT_FEATURE.reset(token)\n\n\n# PromQL: cost by feature\n# sum(rate(claude_api_tokens_input_total[1h])) by (feature) * 3 / 1_000_000   # sonnet-5 input\n# sum(rate(claude_api_tokens_output_total[1h])) by (feature) * 15 / 1_000_000  # sonnet-5 output\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
