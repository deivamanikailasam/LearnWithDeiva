      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "These prices are as of the knowledge cutoff. Verify against the Anthropic pricing page before using them in cost forecasts or billing systems."
              }
            ]
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass\n\n\nMODEL_PRICING: dict[str, tuple[float, float]] = {\n    # model: (input_price_per_million, output_price_per_million)\n    \"claude-opus-4-8\": (15.00, 75.00),\n    \"claude-sonnet-5\": (3.00, 15.00),\n    \"claude-haiku-4-5-20251001\": (0.80, 4.00),\n}\n\n\ndef compute_call_cost(\n    model: str,\n    input_tokens: int,\n    output_tokens: int,\n    cache_read_tokens: int = 0,\n    cache_creation_tokens: int = 0,\n) -> float:\n    \"\"\"Return cost in USD for a single API call.\"\"\"\n    if model not in MODEL_PRICING:\n        raise ValueError(f\"Unknown model: {model}\")\n    input_price, output_price = MODEL_PRICING[model]\n    # Prompt cache reads are billed at 10% of normal input price\n    cache_read_price = input_price * 0.10\n    # Cache creation adds a surcharge on top of normal input price\n    cache_create_price = input_price * 1.25\n    cost = (\n        (input_tokens / 1_000_000) * input_price\n        + (output_tokens / 1_000_000) * output_price\n        + (cache_read_tokens / 1_000_000) * cache_read_price\n        + (cache_creation_tokens / 1_000_000) * cache_create_price\n    )\n    return cost\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Instrumenting Token Counters"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Record input and output tokens as Prometheus Counters immediately after each API response. Add prompt-caching counters if your service uses prompt caching."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from prometheus_client import Counter\nimport anthropic\n\nclaude_input_tokens = Counter(\n    \"claude_api_tokens_input_total\",\n    \"Input tokens sent to Claude API\",\n    [\"model\", \"feature\"],  # feature = the product feature that initiated the call\n)\nclaude_output_tokens = Counter(\n    \"claude_api_tokens_output_total\",\n    \"Output tokens received from Claude API\",\n    [\"model\", \"feature\"],\n)\nclaude_cache_read_tokens = Counter(\n    \"claude_api_tokens_cache_read_total\",\n    \"Tokens served from prompt cache (billed at reduced rate)\",\n    [\"model\", \"feature\"],\n)\nclaude_cache_creation_tokens = Counter(\n    \"claude_api_tokens_cache_creation_total\",\n    \"Tokens used to create a new prompt cache entry\",\n    [\"model\", \"feature\"],\n)\n\n\ndef record_token_usage(\n    response: anthropic.types.Message,\n    model: str,\n    feature: str,\n) -> None:\n    claude_input_tokens.labels(model=model, feature=feature).inc(\n        response.usage.input_tokens\n    )\n    claude_output_tokens.labels(model=model, feature=feature).inc(\n        response.usage.output_tokens\n    )\n    if hasattr(response.usage, \"cache_read_input_tokens\"):\n        claude_cache_read_tokens.labels(model=model, feature=feature).inc(\n            response.usage.cache_read_input_tokens\n        )\n    if hasattr(response.usage, \"cache_creation_input_tokens\"):\n        claude_cache_creation_tokens.labels(model=model, feature=feature).inc(\n            response.usage.cache_creation_input_tokens\n        )\n"
          }
        ]
      },
