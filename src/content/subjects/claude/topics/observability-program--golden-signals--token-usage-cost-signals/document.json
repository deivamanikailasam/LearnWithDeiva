      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Daily and Monthly Cost Forecasting"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Projecting monthly spend from real-time token metrics allows finance and engineering to catch budget overruns before they happen."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass\n\n\n@dataclass\nclass CostForecast:\n    model: str\n    hourly_usd: float\n    daily_usd: float\n    monthly_usd: float\n    days_until_budget_exceeded: float | None  # None if within budget\n\n    @classmethod\n    def from_prometheus(\n        cls,\n        model: str,\n        input_rate_per_min: float,    # tokens per minute from PromQL rate()\n        output_rate_per_min: float,\n        monthly_budget_usd: float,\n    ) -> \"CostForecast\":\n        input_price, output_price = MODEL_PRICING[model]\n        hourly = (\n            input_rate_per_min * 60 * input_price / 1_000_000\n            + output_rate_per_min * 60 * output_price / 1_000_000\n        )\n        daily = hourly * 24\n        monthly = daily * 30\n        if monthly > monthly_budget_usd and daily > 0:\n            days_left = (monthly_budget_usd / monthly) * 30\n        else:\n            days_left = None\n        return cls(\n            model=model,\n            hourly_usd=round(hourly, 4),\n            daily_usd=round(daily, 2),\n            monthly_usd=round(monthly, 2),\n            days_until_budget_exceeded=round(days_left, 1) if days_left else None,\n        )\n"
          }
        ]
      },
