      {
        "type": "codeBlock",
        "attrs": {
          "language": "promql"
        },
        "content": [
          {
            "type": "text",
            "text": "# Output-to-input ratio (baseline: measure over 7 days, alert when 2\u00d7 baseline)\nsum(rate(claude_api_tokens_output_total[5m])) by (feature)\n/\nsum(rate(claude_api_tokens_input_total[5m])) by (feature)\n\n# Average input tokens per request (alert on > 20% increase vs 7-day baseline)\nsum(rate(claude_api_tokens_input_total[5m])) by (model)\n/\nsum(rate(claude_api_requests_total{status=\"success\"}[5m])) by (model)\n\n# Cache effectiveness ratio (prompt cache read fraction)\nsum(rate(claude_api_tokens_cache_read_total[5m]))\n/\n(sum(rate(claude_api_tokens_input_total[5m])) + sum(rate(claude_api_tokens_cache_read_total[5m])))\n"
          }
        ]
