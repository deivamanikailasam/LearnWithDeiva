{"format":"tiptap/v1","updatedAt":"2026-06-20T12:49:10.461Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"An "},{"type":"text","marks":[{"type":"bold"}],"text":"instruction"},{"type":"text","text":" is the core component of a prompt that tells the model what task to perform. It's the "},{"type":"text","marks":[{"type":"bold"}],"text":"specific task or instruction you want the model to perform"},{"type":"text","text":"—the imperative statement that directs the AI on what to do."}]},{"type":"paragraph","content":[{"type":"text","text":"Think of it as your "},{"type":"text","marks":[{"type":"bold"}],"text":"command to the AI"},{"type":"text","text":": \"These are my instructions. These are the things that you need to do and these are the things that I want.\""}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"What instructions do"}]},{"type":"paragraph","content":[{"type":"text","text":"Instructions are the "},{"type":"text","marks":[{"type":"bold"}],"text":"task specification"},{"type":"text","text":" that tells the model:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What to do"},{"type":"text","text":" (summarize, classify, generate, explain, refactor)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What to process"},{"type":"text","text":" (text, code, data, images)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What outcome to achieve"},{"type":"text","text":" (the desired result)"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"The instruction is the "},{"type":"text","marks":[{"type":"bold"}],"text":"core component of the prompt"},{"type":"text","text":" where you explicitly state the task or question that the AI is expected to perform or answer."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key characteristics of good instructions"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. They should be clear and concise"}]},{"type":"paragraph","content":[{"type":"text","text":"Instructions should be clear, concise, and put in separate lines so they don't get mixed up with the rest of the prompt."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Summarize this user feedback."}]},{"type":"paragraph","content":[{"type":"text","text":"vs. vague:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Do something with this."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Be explicit and specific"}]},{"type":"paragraph","content":[{"type":"text","text":"Just like with humans, to achieve successful results with AI, you need to give a "},{"type":"text","marks":[{"type":"bold"}],"text":"clear instruction rather than a vague one"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","text":"A good instruction not only requests a task but also "},{"type":"text","marks":[{"type":"bold"}],"text":"specifies criteria to consider when performing the task"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Weak:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Summarize this."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Strong:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Write a 3-sentence executive summary focusing on the business impact."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. Include criteria and constraints"}]},{"type":"paragraph","content":[{"type":"text","text":"A good instruction specifies:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Criteria"},{"type":"text","text":" to consider (polite tone, conveying responsibility)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Specific details"},{"type":"text","text":" or constraints"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How to complete the task"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Write a business email that:\n- Is polite in tone\n- Conveys responsibility\n- Includes a clear call to action\n- Is under 150 words"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Common instruction types"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Classification instructions"}]},{"type":"paragraph","content":[{"type":"text","text":"Tell the model to categorize inputs:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Classify the text into neutral, negative, or positive."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Instruction: Classify emails into Billing, Bug, Feature, or Other."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Summarization instructions"}]},{"type":"paragraph","content":[{"type":"text","text":"Tell the model to condense information:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Summarize this user feedback."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"With specific requirements:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Write a 3-sentence executive summary focusing on the business impact."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. Generation instructions"}]},{"type":"paragraph","content":[{"type":"text","text":"Tell the model to create new content:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"List ideas for starting a dog-walking business."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"More specific:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Write a 3-paragraph email to trial users who didn't convert.\nTone: friendly but professional.\nGoal: get them to try the analytics feature."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"4. Explanation instructions"}]},{"type":"paragraph","content":[{"type":"text","text":"Tell the model to clarify or teach:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Explain this code in simple terms."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"With audience specification:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Explain what Generative AI is to a beginner in computer science."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"5. Transformation instructions"}]},{"type":"paragraph","content":[{"type":"text","text":"Tell the model to change format or structure:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Convert this JSON to YAML."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"With constraints:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Refactor this function to be async and handle errors properly.\nDo not invent endpoints or libraries not in the codebase."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"6. Analysis instructions"}]},{"type":"paragraph","content":[{"type":"text","text":"Tell the model to examine or evaluate:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Analyze this contract for risk clauses."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Detailed:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Analyze customer agreements for risk in:\n- Liability clauses\n- Indemnity clauses\n- Data privacy clauses\n- Termination clauses\n\nFor each, provide: (a) quote, (b) summary, (c) risk score 1–5."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"How to structure instructions"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Best practice 1: Use imperative statements"}]},{"type":"paragraph","content":[{"type":"text","text":"An instruction is an "},{"type":"text","marks":[{"type":"bold"}],"text":"imperative statement"},{"type":"text","text":" that tells the model what to do."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Examples:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"List ideas for...\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Classify the text into...\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Summarize this...\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Explain this code...\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Refactor this function...\""}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best practice 2: Put instructions in separate lines"}]},{"type":"paragraph","content":[{"type":"text","text":"Instructions should be put in separate lines so they don't get mixed up with the rest of the prompt."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Instruction: Summarize the user feedback.\nInput: \"I love the product but it's too expensive.\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best practice 3: Combine with other components"}]},{"type":"paragraph","content":[{"type":"text","text":"Instructions work alongside:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Context"},{"type":"text","text":" — background information (e.g., \"I'm a beginner studying cell biology\")"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Input Data"},{"type":"text","text":" — the actual content to process (e.g., \"I think the food was okay.\")"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output Indicator"},{"type":"text","text":" — desired format (e.g., \"Respond in JSON with fields: category, reason\")"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Complete example:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Instruction: Classify the text into neutral, negative, or positive.\nContext: This is for a customer support system.\nInput Data: I think the food was okay.\nOutput Indicator: Respond with only the label."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Real-world instruction examples"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 1: Code review"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Weak:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Help me with my code. It's broken."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Strong:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"You are a senior Python engineer.\n\nInstruction:\n1) Ask me for any files or logs you need.\n2) Once I provide them, identify the likely cause.\n3) Propose a fix and show updated code snippets.\n\nConstraints:\n- Explain in simple terms suitable for an intermediate developer.\n- Do not invent endpoints or libraries not already in the code."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 2: Email classification (with examples)"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Instruction:\nLabel customer emails into one of four categories: Billing, Bug, Feature, or Other.\n\nOutput JSON:\n{\n  \"category\": \"<one_of: Billing | Bug | Feature | Other>\",\n  \"reason\": \"<short explanation>\"\n}\n\nExamples:\nEmail: \"I was double charged this month.\"\n→ Category: Billing\nReason: The email is about incorrect charging.\n\nEmail: \"The app crashes when I click Export.\"\n→ Category: Bug\nReason: A specific feature is crashing.\n\nNow label this email:\n\"Can you add a Google Sheets export option?\""}]},{"type":"paragraph","content":[{"type":"text","text":"This combines instruction with few-shot examples to guide the model."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 3: Multi-step planning"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Instruction:\nWe're working on a feature announcement blog post for city officials about urban planning and AI.\n\nProcess:\n1. First, propose 5 specific angles with a short thesis for each.\n2. Wait for my feedback.\n3. Then we'll outline and write the full post together.\n\nTask:\nPropose 5 angles now. Do not write the full post yet."}]},{"type":"paragraph","content":[{"type":"text","text":"This breaks the work into "},{"type":"text","marks":[{"type":"bold"}],"text":"stages"},{"type":"text","text":" and uses follow-up instructions."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Common mistakes with instructions"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mistake 1: Being too vague"}]},{"type":"paragraph","content":[{"type":"text","text":"❌ \"Do something with this.\""}]},{"type":"paragraph","content":[{"type":"text","text":"✅ \"Write a 3-sentence executive summary focusing on the business impact.\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mistake 2: Not specifying criteria"}]},{"type":"paragraph","content":[{"type":"text","text":"❌ \"Write an email.\""}]},{"type":"paragraph","content":[{"type":"text","text":"✅ \"Write a business email that is polite in tone, conveys responsibility, includes a clear call to action, and is under 150 words.\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mistake 3: Mixing instructions with context"}]},{"type":"paragraph","content":[{"type":"text","text":"❌ \"I'm a beginner studying cell biology and I find photosynthesis difficult, so just explain it.\""}]},{"type":"paragraph","content":[{"type":"text","text":"✅"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Context: I'm a beginner studying cell biology and find photosynthesis difficult.\nInstruction: Explain photosynthesis in simple terms."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mistake 4: Not being explicit about output format"}]},{"type":"paragraph","content":[{"type":"text","text":"❌ \"Summarize this text.\""}]},{"type":"paragraph","content":[{"type":"text","text":"✅ \"Summarize this text in exactly 3 bullet points, each under 20 words.\""}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Summary"}]},{"type":"paragraph","content":[{"type":"text","text":"An "},{"type":"text","marks":[{"type":"bold"}],"text":"instruction"},{"type":"text","text":" is the core component that tells the model what task to perform. It should be:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Clear and concise"},{"type":"text","text":" — not vague or ambiguous"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Explicit and specific"},{"type":"text","text":" — specify criteria and constraints"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Imperative"},{"type":"text","text":" — use commands like \"List,\" \"Classify,\" \"Summarize,\" \"Explain\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Separate"},{"type":"text","text":" — put in separate lines so they don't get mixed up"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Combined"},{"type":"text","text":" — work with context, input data, and output indicator"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"A good instruction is like giving clear directions to a human: it tells the model "},{"type":"text","marks":[{"type":"bold"}],"text":"what to do, what criteria to follow, and what outcome to achieve"},{"type":"text","text":"."}]}]}}
