  "doc": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Memory decay and relevance scoring"
          },
          {
            "type": "text",
            "text": " in advanced agent memory systems is the mechanism that automatically "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "reduces the importance of old or unused memories over time"
          },
          {
            "type": "text",
            "text": " while "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "boosting the importance of recently accessed or frequently used ones"
          },
          {
            "type": "text",
            "text": ", ensuring the agent retrieves the most relevant knowledge for the current context instead of being overwhelmed by stale data. Each memory carries a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "relevance score"
          },
          {
            "type": "text",
            "text": " computed from "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "recency"
          },
          {
            "type": "text",
            "text": " (how recently it was accessed), "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "frequency"
          },
          {
            "type": "text",
            "text": " (how often it\u2019s referenced), and "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "semantic alignment"
          },
          {
            "type": "text",
            "text": " (how well it matches the current query), and this score decays exponentially unless reinforced by recall."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Memory decay and relevance scoring concept diagram",
          "title": null
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "What it is"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Memory decay and relevance scoring manage "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "which memories stay active"
          },
          {
            "type": "text",
            "text": " vs. "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "which are forgotten"
          },
          {
            "type": "text",
            "text": ":\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Relevance score"
          },
          {
            "type": "text",
            "text": ": A numeric value (0\u20131) representing how useful a memory is for the current context.\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Decay curve"
          },
          {
            "type": "text",
            "text": ": A function that reduces the score over time if the memory isn\u2019t accessed.\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Reinforcement"
          },
          {
            "type": "text",
            "text": ": When a memory is recalled, its score increases (flattening the decay curve).\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Budgeted forgetting"
          },
          {
            "type": "text",
            "text": ": A maximum memory budget (e.g., top 100 memories) that triggers pruning of low-scoring entries."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Each memory unit stores:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "json"
        },
        "content": [
          {
            "type": "text",
            "text": "{\n  \"id\": \"pref_json_001\",\n  \"fact\": \"User prefers JSON output\",\n  \"relevance_score\": 0.85,\n  \"last_accessed\": \"2026-06-22T19:40:00Z\",\n  \"access_count\": 12,\n  \"created_at\": \"2026-01-15T10:00:00Z\"\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Why it matters"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Without decay and scoring:\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Memory bloat"
          },
          {
            "type": "text",
            "text": ": The agent accumulates all memories indefinitely.\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Stale retrieval"
          },
          {
            "type": "text",
            "text": ": Old memories (e.g., \u201cUser preferred Python 6 months ago\u201d) dominate search.\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Context dilution"
          },
          {
            "type": "text",
            "text": ": Too many irrelevant memories dilute relevance for the current query.\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Performance degradation"
          },
          {
            "type": "text",
            "text": ": Large memory stores slow down retrieval."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "With decay and scoring:\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Memories stay fresh"
          },
          {
            "type": "text",
            "text": ": Old memories decay; recent ones stay relevant.\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Retrieval stays fast"
          },
          {
            "type": "text",
            "text": ": Top-k queries return only the most relevant memories.\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Performance stays high"
          },
          {
            "type": "text",
            "text": ": Memory stores stay bounded (e.g., top 100).\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Learning from use"
          },
          {
            "type": "text",
            "text": ": Frequently accessed memories reinforce their importance."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "This is critical for "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "long-running agents"
          },
          {
            "type": "text",
            "text": " that interact with users over weeks/months, where memory relevance changes over time (e.g., user switches from Python to JavaScript)."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Mental model"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Think of memory decay as "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "viral memes"
          },
          {
            "type": "text",
            "text": ":\n- A meme goes viral (high relevance) when first posted.\n- If people keep sharing it (reinforcement), it stays relevant.\n- If people stop sharing it (no access), it fades (decay).\n- New memes constantly compete for attention."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Or think of it as "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "muscle memory"
          },
          {
            "type": "text",
            "text": ":\n- You practice a skill (reinforcement) \u2192 it stays strong.\n- You stop practicing (no access) \u2192 it fades (decay).\n- The more you practice, the longer it lasts."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "How it works"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "1. Relevance scoring formula"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The relevance score is computed from three factors:"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Recency"
          },
          {
            "type": "text",
            "text": ": How recently was the memory accessed?"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def recency_score(last_accessed: datetime, now: datetime):\n    time_elapsed_hours = (now - last_accessed).total_seconds() / 3600\n    # Exponential decay: score halves every 24 hours\n    return 0.5 ** (time_elapsed_hours / 24)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Frequency"
          },
          {
            "type": "text",
            "text": ": How often is it referenced?"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def frequency_score(access_count: int):\n    # Logarithmic scaling: more accesses = higher score, but saturates\n    return math.log1p(access_count) / math.log1p(100)  # Max ~1.0 at 100 accesses"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Semantic alignment"
          },
          {
            "type": "text",
            "text": ": Does it match the current context?"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def semantic_alignment_score(memory_fact: str, query: str):\n    # Cosine similarity between embeddings\n    memory_vector = embed(memory_fact)\n    query_vector = embed(query)\n    return cosine_similarity(memory_vector, query_vector)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Combined relevance score"
          },
          {
            "type": "text",
            "text": ":"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def calculate_relevance(memory: dict, query: str, now: datetime):\n    recency = recency_score(memory[\"last_accessed\"], now)\n    frequency = frequency_score(memory[\"access_count\"])\n    semantic = semantic_alignment_score(memory[\"fact\"], query)\n    \n    # Weighted combination (adjust weights based on use case)\n    relevance = 0.5 * recency + 0.3 * frequency + 0.2 * semantic\n    return relevance"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "2. Decay curve"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The score decays exponentially unless reinforced:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def apply_forgetting_curve(score: float, time_elapsed_hours: float):\n    # Exponential forgetting: score halves every 24 hours\n    return score * (0.5 ** (time_elapsed_hours / 24))"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Example:\n- Memory with score 0.9, last accessed 24 hours ago \u2192 score = 0.9 \u00d7 0.5 = 0.45.\n- Memory with score 0.9, last accessed 48 hours ago \u2192 score = 0.9 \u00d7 0.25 = 0.225."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "3. Reinforcement (spaced repetition)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When a memory is recalled, its score increases:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def reinforce_memory(memory: dict):\n    memory[\"access_count\"] += 1\n    memory[\"last_accessed\"] = datetime.utcnow()\n    \n    # Boost score based on access count (more accesses = stronger memory)\n    boost = 0.1 * math.log1p(memory[\"access_count\"])\n    memory[\"relevance_score\"] = min(1.0, memory[\"relevance_score\"] + boost)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Example:\n- Memory accessed 1st time \u2192 score = 0.45 + 0.1 \u00d7 log(1) = 0.45.\n- Memory accessed 10th time \u2192 score = 0.45 + 0.1 \u00d7 log(10) = 0.68."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "4. Budgeted forgetting (pruning)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The system maintains a maximum memory budget (e.g., top 100 memories):"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def prune_memories(memories: list, max_budget: int = 100):\n    # Sort by relevance score (descending)\n    sorted_memories = sorted(memories, key=lambda m: m[\"relevance_score\"], reverse=True)\n    \n    # Keep only top-k memories\n    return sorted_memories[:max_budget]"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Example:\n- Store has 500 memories.\n- Budget is 100.\n- Prune lowest 400 memories (those with score < 0.2)."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Implementation patterns"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Pattern 1: Exponential decay with PostgreSQL"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# schema.sql\nCREATE TABLE memories (\n    id TEXT PRIMARY KEY,\n    fact TEXT NOT NULL,\n    relevance_score FLOAT NOT NULL,\n    last_accessed TIMESTAMPTZ NOT NULL,\n    access_count INT NOT NULL DEFAULT 0,\n    created_at TIMESTAMPTZ NOT NULL\n);\n\nCREATE INDEX idx_relevance ON memories(relevance_score DESC);\n# decay.py\nfrom datetime import datetime\n\ndef decay_memories():\n    now = datetime.utcnow()\n    \n    # Update all memories: apply decay based on time elapsed\n    db.execute(\"\"\"\n        UPDATE memories\n        SET relevance_score = relevance_score * (0.5 ^ (EXTRACT(EPOCH FROM (now - last_accessed)) / 86400))\n    \"\"\")\n    \n    # Prune low-scoring memories (keep top 100)\n    db.execute(\"\"\"\n        DELETE FROM memories\n        WHERE id NOT IN (\n            SELECT id FROM memories\n            ORDER BY relevance_score DESC\n            LIMIT 100\n        )\n    \"\"\")"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Pattern 2: Relevance scoring with vector store"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# relevance.py\nfrom pinecone import Pinecone\n\npc = Pinecone(api_key=\"...\")\nindex = pc.Index(\"memories\")\n\ndef query_with_decay(query: str, top_k: int = 10):\n    now = datetime.utcnow()\n    query_vector = embed(query)\n    \n    # Query vector store\n    results = index.query(\n        vector=query_vector,\n        top_k=top_k * 2,  # Get more candidates\n        include_metadata=True\n    )\n    \n    # Compute relevance scores\n    scored = []\n    for match in results[\"matches\"]:\n        metadata = match[\"metadata\"]\n        \n        # Recency: time since last accessed\n        last_accessed = datetime.fromisoformat(metadata[\"last_accessed\"])\n        time_elapsed_hours = (now - last_accessed).total_seconds() / 3600\n        recency = 0.5 ** (time_elapsed_hours / 24)\n        \n        # Frequency: log scaling of access count\n        frequency = math.log1p(metadata[\"access_count\"]) / math.log1p(100)\n        \n        # Semantic: cosine similarity from vector search\n        semantic = match[\"score\"]\n        \n        # Combined relevance\n        relevance = 0.5 * recency + 0.3 * frequency + 0.2 * semantic\n        \n        scored.append({\n            \"id\": metadata[\"id\"],\n            \"fact\": metadata[\"fact\"],\n            \"relevance\": relevance\n        })\n    \n    # Sort by relevance and return top-k\n    scored = sorted(scored, key=lambda x: x[\"relevance\"], reverse=True)\n    return scored[:top_k]\n\ndef reinforce_memory(memory_id: str):\n    # Update metadata: increment access count, update last_accessed\n    metadata = index.fetch(ids=[memory_id])[\"vectors\"][memory_id][\"metadata\"]\n    metadata[\"access_count\"] += 1\n    metadata[\"last_accessed\"] = datetime.utcnow().isoformat()\n    \n    index.update(\n        id=memory_id,\n        metadata=metadata\n    )"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Pattern 3: Adaptive forgetting with Mem0"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Mem0 provides a built-in "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Memory Decay"
          },
          {
            "type": "text",
            "text": " toggle that biases search ranking toward recently-used memories:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from mem0 import Memory\n\n# Enable memory decay\nconfig = {\n    \"decay_enabled\": True,\n    \"decay_rate\": 0.01,  # 1% daily decay\n    \"max_memories\": 100  # Budget\n}\n\nmemory = Memory(config=config)\n\n# Store memory\nmemory.add(\"User prefers JSON output\", user_id=\"user_123\")\n\n# Query memory (automatically applies decay)\nresults = memory.search(\"What does the user prefer?\", user_id=\"user_123\")\n\n# Reinforce memory (when recalled)\nmemory.reinforce(results[0][\"id\"])"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Benefits"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Prevents bloat"
                  },
                  {
                    "type": "text",
                    "text": ": Memory stores stay bounded (e.g., top 100)."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Stays fresh"
                  },
                  {
                    "type": "text",
                    "text": ": Old memories decay; recent ones stay relevant."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Fast retrieval"
                  },
                  {
                    "type": "text",
                    "text": ": Top-k queries return only the most relevant memories."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Learning from use"
                  },
                  {
                    "type": "text",
                    "text": ": Frequently accessed memories reinforce their importance."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Trade-offs"
