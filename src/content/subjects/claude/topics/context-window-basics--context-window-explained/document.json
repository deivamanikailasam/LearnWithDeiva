"bold"}],"text":"sliding context window"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"[Session Start]\n↓\nTokens accumulate with every turn (user + assistant)\n↓\nOnce limit is approached (200k or 1M tokens)\n↓\nOldest content is discarded\n↓\nMost recent tokens are retained\n↓\n[Session Continues]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What happens:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Tokens accumulate"},{"type":"text","text":" with every exchange\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Older tokens are removed"},{"type":"text","text":" when approaching the limit\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Conversation reflects the last X tokens"},{"type":"text","text":" (200k or 1M)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Long-form sessions remain coherent"},{"type":"text","text":" as long as data stays within the window"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Unified Buffer Architecture"}]},{"type":"paragraph","content":[{"type":"text","text":"Unlike traditional memory systems with short-term and long-term storage:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"┌─────────────────────────────────────┐\n│         UNIFIED CONTEXT BUFFER       │\n│  ┌─────────────────────────────┐   │\n│  │ System Prompt               │   │\n│  │ System Tools                │   │\n│  │ Custom Agents               │   │\n│  │ Memory Files (CLAUDE.md)    │   │\n│  │ Messages (conversation)     │   │\n│  │ Tool Outputs                │   │\n│  │ File Reads                  │   │\n│  └─────────────────────────────┘   │\n│         ↓ 200k / 1M tokens         │\n└─────────────────────────────────────┘"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"