      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass, field\nfrom datetime import date\nfrom typing import Literal\n\nTreatmentOption = Literal[\"mitigate\", \"accept\", \"transfer\", \"avoid\"]\n\n@dataclass\nclass MitigationAction:\n    action_id: str\n    description: str\n    owner: str\n    due_date: date\n    status: Literal[\"not_started\", \"in_progress\", \"completed\", \"overdue\"] = \"not_started\"\n    completion_evidence: str = \"\"    # filled in when status = \"completed\"\n\n@dataclass\nclass TreatmentPlan:\n    risk_id: str\n    treatment_option: TreatmentOption\n    rationale: str\n    target_residual_score: int\n    target_date: date\n    actions: list[MitigationAction] = field(default_factory=list)\n    approved_by: str = \"\"\n    approved_at: date = None\n\n    @property\n    def completion_pct(self) -> float:\n        if not self.actions:\n            return 0.0\n        completed = sum(1 for a in self.actions if a.status == \"completed\")\n        return round(100 * completed / len(self.actions), 1)\n\n    @property\n    def overdue_actions(self) -> list[MitigationAction]:\n        today = date.today()\n        return [a for a in self.actions if a.due_date < today and a.status != \"completed\"]\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Mitigation Action Tracking"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import sqlite3, json\nfrom pathlib import Path\nfrom datetime import date, datetime, timezone\n\nTRACKING_DB = Path(\"/var/data/risk/mitigation_tracking.db\")\n\ndef init_tracking_db():\n    with sqlite3.connect(TRACKING_DB) as conn:\n        conn.execute(\"\"\"\n            CREATE TABLE IF NOT EXISTS treatment_plans (\n                risk_id        TEXT PRIMARY KEY,\n                treatment      TEXT NOT NULL,\n                rationale      TEXT NOT NULL,\n                target_score   INTEGER NOT NULL,\n                target_date    TEXT NOT NULL,\n                approved_by    TEXT,\n                approved_at    TEXT,\n                plan_json      TEXT NOT NULL   -- full TreatmentPlan serialised\n            )\n        \"\"\")\n        conn.execute(\"\"\"\n            CREATE TABLE IF NOT EXISTS action_updates (\n                update_id    INTEGER PRIMARY KEY AUTOINCREMENT,\n                risk_id      TEXT NOT NULL,\n                action_id    TEXT NOT NULL,\n                ts           TEXT NOT NULL,\n                new_status   TEXT NOT NULL,\n                note         TEXT\n            )\n        \"\"\")\n\ndef save_treatment_plan(plan: TreatmentPlan):\n    with sqlite3.connect(TRACKING_DB) as conn:\n        conn.execute(\"\"\"\n            INSERT OR REPLACE INTO treatment_plans VALUES (?,?,?,?,?,?,?,?)\n        \"\"\", (\n            plan.risk_id, plan.treatment_option, plan.rationale,\n            plan.target_residual_score, str(plan.target_date),\n            plan.approved_by, str(plan.approved_at) if plan.approved_at else None,\n            json.dumps({\n                \"actions\": [\n                    {\"action_id\": a.action_id, \"description\": a.description,\n                     \"owner\": a.owner, \"due_date\": str(a.due_date),\n                     \"status\": a.status, \"evidence\": a.completion_evidence}\n                    for a in plan.actions\n                ]\n            })\n        ))\n\ndef update_action_status(\n    risk_id: str, action_id: str, new_status: str, note: str = \"\"\n):\n    with sqlite3.connect(TRACKING_DB) as conn:\n        conn.execute(\"\"\"\n            INSERT INTO action_updates (risk_id, action_id, ts, new_status, note)\n            VALUES (?,?,?,?,?)\n        \"\"\", (risk_id, action_id, datetime.now(timezone.utc).isoformat(), new_status, note))\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Overdue Action Escalation"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Mitigation actions that slip past their due date without a documented extension create a governance gap: the register shows a treatment plan exists but evidence shows it is not being executed. Automate overdue detection and route notifications to the risk owner and their line manager."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from datetime import date, timedelta\n\ndef find_overdue_actions(plans: list[TreatmentPlan]) -> list[dict]:\n    today = date.today()\n    overdue = []\n    for plan in plans:\n        for action in plan.actions:\n            if action.status not in (\"completed\",) and action.due_date < today:\n                days_overdue = (today - action.due_date).days\n                overdue.append({\n                    \"risk_id\": plan.risk_id,\n                    \"action_id\": action.action_id,\n                    \"description\": action.description,\n                    \"owner\": action.owner,\n                    \"due_date\": str(action.due_date),\n                    \"days_overdue\": days_overdue,\n                    \"severity\": \"critical\" if days_overdue > 30 else \"warning\",\n                })\n    return sorted(overdue, key=lambda x: x[\"days_overdue\"], reverse=True)\n\ndef send_overdue_notifications(overdue_actions: list[dict]) -> None:\n    \"\"\"Dispatch notifications to action owners and risk managers.\"\"\"\n    for item in overdue_actions:\n        message = (\n            f\"Risk action overdue ({item['days_overdue']} days): \"\n            f\"[{item['risk_id']}] {item['description']}\\n\"\n            f\"Owner: {item['owner']} | Due: {item['due_date']}\"\n        )\n        # Wire to your alerting system (email, Slack, JIRA comment, etc.)\n        print(f\"NOTIFY {item['owner']}: {message}\")\n        if item[\"severity\"] == \"critical\":\n            print(f\"ESCALATE to risk manager: {message}\")\n"
          }
        ]
      },
