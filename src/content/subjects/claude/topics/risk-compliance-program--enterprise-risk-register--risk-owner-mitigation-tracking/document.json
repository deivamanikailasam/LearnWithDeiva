          {
            "type": "text",
            "text": "Quarterly Review Report"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The quarterly review report consolidates the state of all open risks and treatment plans into a single document for the AI Steering Committee. Generate it programmatically from the register and tracking database to ensure it reflects the current state rather than manually curated status."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def quarterly_review_report(\n    register: list,           # list[RiskEntry]\n    plans: list[TreatmentPlan],\n    report_date: date,\n) -> dict:\n    plan_map = {p.risk_id: p for p in plans}\n    open_risks = [e for e in register if e.status == \"open\"]\n    overdue = find_overdue_actions(plans)\n\n    summary = {\n        \"report_date\": str(report_date),\n        \"open_risk_count\": len(open_risks),\n        \"overdue_action_count\": len(overdue),\n        \"risks_without_plan\": [\n            e.risk_id for e in open_risks\n            if e.risk_id not in plan_map and e.residual_score > 6\n        ],\n        \"plans_behind_schedule\": [\n            {\"risk_id\": p.risk_id, \"completion_pct\": p.completion_pct,\n             \"target_date\": str(p.target_date), \"overdue_actions\": len(p.overdue_actions)}\n            for p in plans\n            if p.overdue_actions\n        ],\n        \"risks_near_closure\": [\n            {\"risk_id\": p.risk_id, \"completion_pct\": p.completion_pct}\n            for p in plans\n            if p.completion_pct >= 80 and p.risk_id in plan_map\n        ],\n    }\n    return summary\n"
          }
        ]
