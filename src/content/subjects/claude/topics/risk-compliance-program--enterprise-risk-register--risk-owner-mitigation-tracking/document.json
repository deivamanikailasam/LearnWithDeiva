            "content": [
              {
                "type": "text",
                "text": "A risk acceptance signed six months ago by a CISO who has since left the organisation is not a current acceptance. When an acceptance expires or the accepting executive changes, the risk must be re-evaluated. Track acceptances in the log alongside the register to ensure expiry triggers are not missed."
              }
            ]
          }
        ]
