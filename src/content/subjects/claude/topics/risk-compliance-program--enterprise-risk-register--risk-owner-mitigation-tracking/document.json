          {
            "type": "text",
            "text": "Risk Acceptance Process"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Some risks cannot be reduced below the tolerable threshold without prohibitive cost or without eliminating the business value of the Claude feature entirely. In these cases, the organisation formally accepts the residual risk. Acceptance is not a passive decision — it requires documented sign-off at the right authority level and a scheduled re-review date."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass\nfrom datetime import date\nimport json\nfrom pathlib import Path\n\nACCEPTANCE_LOG = Path(\"/var/data/risk/risk_acceptances.jsonl\")\n\n@dataclass\nclass RiskAcceptance:\n    risk_id: str\n    residual_score: int\n    rationale: str                # why the risk is being accepted rather than mitigated\n    business_justification: str   # why the feature is worth the residual risk\n    accepted_by: str              # must be the Accountable Executive for this category\n    accepted_at: date\n    review_date: date             # mandatory re-review — acceptance is not permanent\n    conditions: list[str]         # what must remain true for the acceptance to stand\n\ndef record_acceptance(acceptance: RiskAcceptance):\n    \"\"\"Persist a formal risk acceptance decision.\"\"\"\n    record = {\n        \"risk_id\": acceptance.risk_id,\n        \"residual_score\": acceptance.residual_score,\n        \"rationale\": acceptance.rationale,\n        \"business_justification\": acceptance.business_justification,\n        \"accepted_by\": acceptance.accepted_by,\n        \"accepted_at\": str(acceptance.accepted_at),\n        \"review_date\": str(acceptance.review_date),\n        \"conditions\": acceptance.conditions,\n    }\n    with open(ACCEPTANCE_LOG, \"a\", encoding=\"utf-8\") as f:\n        f.write(json.dumps(record) + \"\\n\")\n\ndef check_acceptance_expiry(acceptances_path: Path = ACCEPTANCE_LOG) -> list[dict]:\n    \"\"\"Return acceptances whose review_date has passed — these need re-evaluation.\"\"\"\n    today = date.today()\n    expired = []\n    for line in acceptances_path.read_text().splitlines():\n        if not line:\n            continue\n        record = json.loads(line)\n        if date.fromisoformat(record[\"review_date\"]) < today:\n            expired.append(record)\n    return expired\n"
          }
        ]
      },
