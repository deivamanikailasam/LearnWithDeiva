{"format":"tiptap/v1","updatedAt":"2026-06-22T04:13:11.871Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Based on the Claude Code training documentation, here's what "},{"type":"text","marks":[{"type":"bold"}],"text":"\"Defining Agents\""},{"type":"text","text":" in the "},{"type":"text","marks":[{"type":"bold"}],"text":"\"What Are Agents\""},{"type":"text","text":" section covers:"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Core Definition"}]},{"type":"paragraph","content":[{"type":"text","text":"An "},{"type":"text","marks":[{"type":"bold"}],"text":"agent"},{"type":"text","text":" is a specialized Claude Code subprocess with:\n- Its own isolated context window\n- Its own set of allowed tools\n- An optional system prompt defining behavior"}]},{"type":"paragraph","content":[{"type":"text","text":"Three things define an agent:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Component"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Purpose"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Name & description"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tells Claude when and why to invoke it automatically"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tools list"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"What the agent is allowed to use"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"System prompt"},{"type":"text","text":" (optional)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Shapes focus and constraints"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How You Define Agents"}]},{"type":"paragraph","content":[{"type":"text","text":"Agents are stored as "},{"type":"text","marks":[{"type":"bold"}],"text":"Markdown files in "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":".claude/agents/"},{"type":"text","text":" with YAML frontmatter:"}]},{"type":"codeBlock","attrs":{"language":"markdown"},"content":[{"type":"text","text":"---\nname: test-runner\ndescription: Run the test suite and report failures\ntools: [bash, read_file]\n---\n\nYou are a test runner. Run tests and report results. Do not fix bugs."}]},{"type":"paragraph","content":[{"type":"text","text":"The markdown body becomes the agent's "},{"type":"text","marks":[{"type":"bold"}],"text":"system prompt"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Distinction: Agent vs. Skill"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"A skill tells the current Claude what to do; an agent is a separate Claude that goes off and does it\""}]}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Skill"},{"type":"text","text":": Standardizes interactions within your current session"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Agent"},{"type":"text","text":": Delegates to an isolated subprocess, runs independently, returns results"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why Define Agents?"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Parallelism"},{"type":"text","text":" is the main reason: spawn multiple sub-agents simultaneously for independent tasks (running tests while generating documentation, checking multiple schemas)."}]},{"type":"paragraph","content":[{"type":"text","text":"Agents also optimize "},{"type":"text","marks":[{"type":"bold"}],"text":"token usage"},{"type":"text","text":" by delegating tasks and retaining only necessary output instead of full conversation history."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Automatic Invocation"}]},{"type":"paragraph","content":[{"type":"text","text":"Claude "},{"type":"text","marks":[{"type":"bold"}],"text":"automatically"},{"type":"text","text":" reads the "},{"type":"text","marks":[{"type":"code"}],"text":"description"},{"type":"text","text":" field and spawns the agent when a task matches closely enough—no manual invocation needed. Writing a "},{"type":"text","marks":[{"type":"bold"}],"text":"specific description"},{"type":"text","text":" is critical: vague descriptions cause over-invocation or ignored agents."}]}]}}
