{"format":"tiptap/v1","updatedAt":"2026-06-21T17:14:05.977Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Managing Files in The Files API"},{"type":"text","text":" encompasses the complete lifecycle of files after upload: listing stored files, retrieving metadata, downloading content, and deleting files to prevent storage accumulation—all critical for maintaining efficient document workflows and avoiding unnecessary costs."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What it is"}]},{"type":"paragraph","content":[{"type":"text","text":"File management refers to "},{"type":"text","marks":[{"type":"bold"}],"text":"operations beyond uploading"},{"type":"text","text":" that allow you to view, inspect, retrieve, and clean up files stored in Claude's cloud, including pagination, metadata access, and deletion workflows."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Management Operations"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"List All Files"},{"type":"text","text":" (Discover Stored Files)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Python SDK:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\n# List all files in your workspace\nfiles = client.beta.files.list()\n\nfor file in files:\n    print(f\"{file.id} - {file.filename} ({file.size_bytes} bytes)\")"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"file_abc123xyz - contract.pdf (1048576 bytes)\nfile_xyz789abc - report.txt (524288 bytes)\nfile_def456ghi - photo.png (2097152 bytes)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Node.js SDK:"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"const files = await client.beta.files.list();\n\nconsole.log(files.data);\n// Returns paginated list with pagination_token"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Curl (Direct API):"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"curl https://api.anthropic.com/v1/files \\\n  -H 'anthropic-version: 2023-06-01' \\\n  -H 'anthropic-beta: files-api-2025-04-14' \\\n  -H \"X-Api-Key: $ANTHROPIC_API_KEY\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pagination (Large file sets):"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Paginate through many files\nfiles = client.beta.files.list(limit=100)\n\nfor file in files.data:\n    print(f\"{file.id}: {file.filename}\")\n\n# Get next page\nnext_page = client.beta.files.list(after=files.last_id, limit=100)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Retrieve File Metadata"},{"type":"text","text":" (Get File Details)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Python SDK:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\n# Get metadata for a specific file\nfile_info = client.beta.files.retrieve(file_id=\"file_abc123xyz\")\n\nprint(f\"Filename: {file_info.filename}\")\nprint(f\"Size: {file_info.size_bytes} bytes\")\nprint(f\"MIME Type: {file_info.mime_type}\")\nprint(f\"Created: {file_info.created_at}\")\nprint(f\"Downloadable: {file_info.downloadable}\")"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Filename: financial_report.pdf\nSize: 1048576 bytes\nMIME Type: application/pdf\nCreated: 2024-09-23T10:30:00Z\nDownloadable: true"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Node.js SDK:"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"const file = await client.beta.files.retrieve({\n    file_id: \"file_abc123xyz\"\n});\n\nconsole.log({\n    id: file.id,\n    filename: file.filename,\n    size_bytes: file.size_bytes,\n    content_type: file.content_type,\n    created_at: file.created_at\n});"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Curl (Direct API):"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"curl https://api.anthropic.com/v1/files/file_abc123xyz \\\n  -H 'anthropic-version: 2023-06-01' \\\n  -H 'anthropic-beta: files-api-2025-04-14' \\\n  -H \"X-Api-Key: $ANTHROPIC_API_KEY\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Response:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"id\": \"file_abc123xyz\",\n  \"object\": \"file\",\n  \"bytes\": 1048576,\n  \"created_at\": \"2024-09-23T10:30:00Z\",\n  \"filename\": \"financial_report.pdf\",\n  \"mime_type\": \"application/pdf\",\n  \"downloadable\": true\n}"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Download File Content"},{"type":"text","text":" (Retrieve Stored Files)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Python SDK:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\n# Download file content\nfile_content = client.beta.files.download(file_id=\"file_abc123xyz\")\n\n# Save to local file\nwith open(\"downloaded_report.pdf\", \"wb\") as f:\n    f.write(file_content)\n\nprint(\"File downloaded successfully\")"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Node.js SDK:"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"const fileData = await client.beta.files.download({\n    file_id: \"file_abc123xyz\"\n});\n\n// Save to file\nimport * as fs from \"fs\";\nfs.writeFileSync(\"downloaded_report.pdf\", fileData);"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Curl (Direct API):"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"curl https://api.anthropic.com/v1/files/file_abc123xyz/content \\\n  -H 'anthropic-version: 2023-06-01' \\\n  -H 'anthropic-beta: files-api-2025-04-14' \\\n  -H \"X-Api-Key: $ANTHROPIC_API_KEY\" \\\n  -o downloaded_report.pdf"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Important limitation:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Download restrictions: can only download files the API generates, not files you uploaded.\""}]}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Files you upload"},{"type":"text","text":": Generally "},{"type":"text","marks":[{"type":"bold"}],"text":"cannot download"},{"type":"text","text":" (restricted)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Files Claude generates"},{"type":"text","text":": Can download output files"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Delete File"},{"type":"text","text":" (Clean Up Storage)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Python SDK:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\n# Upload file\nuploaded = client.beta.files.upload(\n    file=(\n        \"temp_report.pdf\",\n        open(\"temp_report.pdf\", \"rb\"),\n        \"application/pdf\"\n    )\n)\nfile_id = uploaded.id\n\n# Use the file...\n# ... (do work)\n\n# Delete when done\nclient.beta.files.delete(file_id)\nprint(f\"File deleted: {file_id}\")"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Node.js SDK:"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"await client.beta.files.delete({\n    file_id: \"file_abc123xyz\"\n});\n\nconsole.log(\"File deleted\");"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Curl (Direct API):"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"curl -X DELETE https://api.anthropic.com/v1/files/file_abc123xyz \\\n  -H 'anthropic-version: 2023-06-01' \\\n  -H 'anthropic-beta: files-api-2025-04-14' \\\n  -H \"X-Api-Key: $ANTHROPIC_API_KEY\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Response:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"id\": \"file_abc123xyz\",\n  \"deleted\": true\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Critical importance:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Files remain stored until deleted.\""}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Without deletion:"},{"type":"text","text":"\n- Files persist indefinitely\n- Storage costs accumulate\n- 500 GB org quota consumed\n- File IDs remain discoverable"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"With deletion:"},{"type":"text","text":"\n- Files removed from storage\n- No further costs\n- File ID becomes invalid\n- Cannot reference in future requests"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Complete Management Workflow"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Full Lifecycle Example"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\n# STEP 1: List existing files (audit)\nprint(\"=== Current Files ===\")\nfiles = client.beta.files.list()\nfor file in files:\n    print(f\"{file.id} - {file.filename} ({file.size_bytes} bytes)\")\n\n# STEP 2: Upload new file\nprint(\"\\n=== Uploading ===\")\nuploaded = client.beta.files.upload(\n    file=(\n        \"contract.pdf\",\n        open(\"contract.pdf\", \"rb\"),\n        \"application/pdf\"\n    )\n)\nfile_id = uploaded.id\nprint(f\"✓ Uploaded: {file_id}\")\n\n# STEP 3: Get metadata\nprint(\"\\n=== File Metadata ===\")\nfile_info = client.beta.files.retrieve(file_id=file_id)\nprint(f\"Filename: {file_info.filename}\")\nprint(f\"Size: {file_info.size_bytes} bytes\")\nprint(f\"MIME Type: {file_info.mime_type}\")\nprint(f\"Created: {file_info.created_at}\")\n\n# STEP 4: Use file in Messages\nprint(\"\\n=== Using File ===\")\nresponse = client.beta.messages.create(\n    model=\"claude-opus-4-8\",\n    max_tokens=16000,\n    messages=[{\n        \"role\": \"user\",\n        \"content\": [\n            {\"type\": \"text\", \"text\": \"What are the key terms?\"},\n            {\n                \"type\": \"document\",\n                \"source\": {\"type\": \"file\", \"file_id\": file_id}\n            }\n        ]\n    }]\n)\nprint(f\"Answer: {response.content[0].text[:200]}...\")\n\n# STEP 5: Delete when done\nprint(\"\\n=== Cleaning Up ===\")\nclient.beta.files.delete(file_id)\nprint(f\"✓ Deleted: {file_id}\")\n\n# STEP 6: Verify deletion (confirm)\nprint(\"\\n=== Files After Deletion ===\")\nfiles = client.beta.files.list()\nprint(f\"Total files remaining: {len(files)}\")"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Storage Quotas & Limits"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Organizational Limits"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Constraint"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Limit"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Max per file"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"500 MB"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Max per organization"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"500 GB total"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Expires after"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Optional expiration policy (not set by default)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cost implications:"},{"type":"text","text":"\n- Upload, list, retrieve metadata, delete = "},{"type":"text","marks":[{"type":"bold"}],"text":"FREE"},{"type":"text","text":"\n- Storage costs accumulate if files not deleted\n- 500 GB quota consumed per organization"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"File Lifecycle Patterns"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Pattern 1: "},{"type":"text","marks":[{"type":"bold"}],"text":"Temporary Workflow"},{"type":"text","text":" (Upload → Use → Delete)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Best for single-use tasks\nuploaded = client.beta.files.upload(\n    file=(\"temp.pdf\", open(\"temp.pdf\", \"rb\"), \"application/pdf\")\n)\n\n# Use once\nresponse = client.messages.create(\n    messages=[{\n        \"content\": [\n            {\"type\": \"document\", \"source\": {\"type\": \"file\", \"file_id\": uploaded.id}}\n        ]\n    }]\n)\n\n# Delete immediately\nclient.beta.files.delete(uploaded.id)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Pattern 2: "},{"type":"text","marks":[{"type":"bold"}],"text":"Persistent Document"},{"type":"text","text":" (Upload → Reuse → Delete Later)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Best for long-term document analysis\nuploaded = client.beta.files.upload(\n    file=(\"contract.pdf\", open(\"contract.pdf\", \"rb\"), \"application/pdf\")\n)\nfile_id = uploaded.id\n\n# Use across many conversations\nfor day in range(10):\n    response = client.messages.create(\n        messages=[{\n            \"content\": [\n                {\"type\": \"document\", \"source\": {\"type\": \"file\", \"file_id\": file_id}},\n                {\"type\": \"text\", \"text\": f\"Question for day {day}\"}\n            ]\n        }]\n    )\n\n# Delete after project ends\nclient.beta.files.delete(file_id)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Pattern 3: "},{"type":"text","marks":[{"type":"bold"}],"text":"Bulk Management"},{"type":"text","text":" (List → Filter → Batch Delete)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Clean up old files\nfiles = client.beta.files.list()\n\n# Find files older than 30 days\nimport datetime\ncutoff = datetime.datetime.now() - datetime.timedelta(days=30)\n\nfor file in files:\n    created = datetime.datetime.fromisoformat(file.created_at)\n    if created < cutoff:\n        client.beta.files.delete(file.id)\n        print(f\"Deleted: {file.filename}\")"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Edge Cases & Error Handling"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Common Errors"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Error"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Cause"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Fix"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"404 Not Found"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"File deleted or doesn't exist"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":