tested\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Production"},{"type":"text","text":" — Pinned, immutable"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rollback methods:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Feature flag"},{"type":"text","text":" — Instant switch\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Git revert"},{"type":"text","text":" — Merge revert PR\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Database"},{"type":"text","text":" — "},{"type":"text","marks":[{"type":"code"}],"text":"previous_version"},{"type":"text","text":" column"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tools:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Braintrust"},{"type":"text","text":" — Content-addressable IDs\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"MLflow"},{"type":"text","text":" — UI + code\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Promptplex"},{"type":"text","text":" — Python library\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Agente"},{"type":"text","text":" — Git-based + dedicated"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Prompt versioning infrastructure allows prompt changes to ship independently of application code releases\""},{"type":"text","text":" — hotfix without redeploying."}]}]}}
