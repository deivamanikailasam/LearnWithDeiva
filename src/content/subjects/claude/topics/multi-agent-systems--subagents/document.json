old"}],"text":"Subagents share nothing"},{"type":"text","text":" — if subagent B needs output from subagent A, coordinator must explicitly pass it:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# WRONG — writer has zero context\nresearch = run_subagent(\"research_agent\", task=\"research Lambda limits\")\nwriter = run_subagent(\"writer_agent\", task=\"write about Lambda\")\n\n# RIGHT — explicitly pass context through coordinator\nresearch = run_subagent(\"research_agent\", task=\"research Lambda limits\")\nwriter = run_subagent(\"writer_agent\", task=\"write about Lambda\", context=research)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Isolation is the feature, not the bug"},{"type":"text","text":" — design for explicit context passing."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Parallel Subagents"}]},{"type":"paragraph","content":[{"type":"text","text":"Multiple tool calls in one response run "},{"type":"text","marks":[{"type":"bold"}],"text":"simultaneously"},{"type":"text","text":", cutting latency:"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// These 3 subagents run in parallel (same message)\n[Task]\ndescription: \"Security review\"\nrun_in_background: true\n\n[Task]\ndescription: \"Performance analysis\"  \nrun_in_background: true\n\n[Task]\ndescription: \"Test coverage\"\nrun_in_background: true"}]},{"type":"paragraph","content":[{"type":"text","text":"Parallel execution is "},{"type":"text","marks":[{"type":"bold"}],"text":"Nx faster where N = number of subagents"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Token Cost Reality"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Configuration"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Token Cost"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Single agent"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"1x"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"3 subagents"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"3–4x"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Agent Teams"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"3–4x+ (higher with peer communication)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Only use subagents when specialist quality justifies the 3–4x cost"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of subagents like "},{"type":"text","marks":[{"type":"bold"}],"text":"specialized contractors working for a project manager"},{"type":"text","text":": the PM (coordinator) assigns tasks to electrical, plumbing, and HVAC contractors (subagents). Each contractor works in their own isolated space with their own tools, reports back to the PM when done, and never talks directly to other contractors. The PM must explicitly pass information between contractors if needed."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Subagents are specialized workers spawned by coordinator, with isolated context and dedicated system prompts"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Subagents only report back to main agent — never talk to each other"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Each subagent has its own context window, separate from coordinator"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Subagents share nothing; coordinator must explicitly pass context between them"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"In Claude Code: use Task tool with "},{"type":"text","marks":[{"type":"code"}],"text":"run_in_background: true"},{"type":"text","text":" for parallel execution"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Parallel subagents (same message) run simultaneously, cutting latency"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Cost: 3–4x single agent — only use when specialist quality justifies it"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Production-ready and stable (unlike Agent Teams which is experimental)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Good for: embarrassingly parallel tasks, specialized expertise, context management"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Bad for: tasks needing peer-to-peer communication, dependencies, cost-sensitive work"}]}]}]},{"type":"paragraph","cont