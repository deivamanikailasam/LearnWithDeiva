type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"type"},{"type":"text","text":" - Text Input at Cursor Position"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"action\": \"type\",\n  \"text\": \"jacar@example.com\"\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Purpose"},{"type":"text","text":": Type text at the current cursor position."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Usage"},{"type":"text","text":":\n- Inserts text in active input field\n- Works with any text field (forms, editors, terminals)\n- Preserves cursor state"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Implementation"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"elif action.type == \"type\":\n    await computer.type(action.text)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"scroll"},{"type":"text","text":" - Scroll in Any Direction"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"action\": \"scroll\",\n  \"coordinate\": [512, 384],  // Scroll position (x, y)\n  \"amount\": [0, 300]  // (dx, dy) in pixels\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Scroll Properties"},{"type":"text","text":":"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Property"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Description"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"coordinate"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scroll destination (x, y)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"amount"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scroll offset in pixels (dx, dy)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Direction"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"code"}],"text":"scroll up"},{"type":"text","text":" by N pixels\n- "},{"type":"text","marks":[{"type":"code"}],"text":"scroll down"},{"type":"text","text":" by N pixels\n- "},{"type":"text","marks":[{"type":"code"}],"text":"scroll left"},{"type":"text","text":" by N pixels\n- "},{"type":"text","marks":[{"type":"code"}],"text":"scroll right"},{"type":"text","text":" by N pixels"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Implementation"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"elif action.type == \"scroll\":\n    await computer.scroll(action.x, action.y, action.dx, action.dy)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"key"},{"type":"text","text":" - Keyboard Input and Shortcuts"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"action\": \"key\",\n  \"key\": \"Control+c\"  // or \"Return\", \"Tab\", \"Escape\"\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key Input Types"},{"type":"text","text":":"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Key Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Examples"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Single keys"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"Return"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"Tab"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"Escape"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"Enter"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key combinations"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"Control+c"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"Alt+Tab"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"Shift+Delete"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hold key"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Hold key for specified duration"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Capabilities"},{"type":"text","text":":\n- Type text: Type characters at cursor position\n- Press key combinations: Execute shortcuts (Control+c)\n- Execute shortcuts: System commands (Alt+Tab, etc.)"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Structured Action Commands"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Return Format"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"The model receives screenshots as base64-encoded images and returns structured action commands"},{"type":"text","text":"."}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"type\": \"tool_use\",\n  \"name\": \"computer\",\n  \"input\": {\n    \"action\": \"click\",\n    \"coordinate\": [342, 156],\n    \"button\": \"left\"\n  }\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Typed Actions vs Raw Commands"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Actions are typed (click, type, scroll, etc.) rather than raw commands\""},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits of structured actions"},{"type":"text","text":":\n- Type safety (compiler validates action types)\n- Clear semantics (click ≠ type ≠ scroll)\n- Easier validation and error handling\n- API versioning support"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Complete Tool Lifecycle"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Singleton Pattern"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Singleton: share AsyncComputer instance across all runs\ncomputer = AsyncComputer()  # Shared instance\n\nfor run in runs:\n    # Use same computer instance\n    await computer.click(100, 200)\n    await computer.type(\"text\")"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use case"},{"type":"text","text":": Single shared instance for all runs."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Per-Request Pattern"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Per-request: create and dispose computer instances per run\nprovider = ComputerProvider()  # Factory\n\nfor run in runs:\n    computer = provider.create()  # New instance per run\n    await computer.click(100, 200)\n    await computer.type(\"text\")\n    # Dispose after run"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits"},{"type":"text","text":": \"Avoids state leakage between concurrent agent runs\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Perception-Action Loop"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Complete Flow"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Abstract computer-use loop\nwhile not done:\n    screenshot = await computer.screenshot()  # base64 image\n    actions = model.decide(screenshot, goal)  # structured actions\n    \n    for action in actions:\n        if action.type == \"click\":\n            await computer.click(action.x, action.y, action.button)\n        elif action.type == \"type\":\n            await computer.type(action.text)\n        elif action.type == \"scroll\":\n            await computer.scroll(action.x, action.y, action.dx, action.dy)\n        # ... other action types\n    \n    screenshot = await computer.screenshot()  # observe result"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key insight"},{"type":"text","text":": \"The architecture separates the computer abstraction from the agent via "},{"type":"text","marks":[{"type":"bold"}],"text":"ComputerTool"},{"type":"text","text":", which wraps an "},{"type":"text","marks":[{"type":"code"}],"text":"AsyncComputer"},{"type":"text","text":" instance and exposes it as a tool\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of these tool definitions like "},{"type":"text","marks":[{"type":"bold"}],"text":"a remote control with buttons"},{"type":"text","text":": each action (click, type, scroll, key) is a different button on the remote. When you press \"click,\" the remote sends coordinates (342, 156) to the TV. When you press \"type,\" it sends the text string. The remote never touches the TV directly—it just sends structured commands (typed actions) that the TV understands. The abstraction layer (AsyncComputer) is the wiring between remote and TV, and the lifecycle patterns (singleton vs per-request) determine whether you share one remote or use separate remotes."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Five action types: screenshot, click, type, scroll, key"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Tool definition: "},{"type":"text","marks":[{"type":"code"}],"text":"{\"type\": \"computer_20241022\", \"name\": \"computer\", \"display_width_px\": 1024, \"display_height_px\": 768}"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"screenshot: capture screen as base64 image for analysis"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"click: click at (x, y) with button type (left/right/middle)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"click variants: left_click, right_click, middle_click, double_click, triple_click"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"type: type text at current cursor position"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"scroll: scroll at (x, y) by (dx, dy) pixels in any direction"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"key: press key combinations (Control+c, Return, Tab, Escape)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Actions are typed (click/type/scroll) rather than raw commands"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Model receives base64 screenshots, returns structured action commands"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"AsyncComputer: abstract interface for screenshot capture and input actions"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"ComputerTool: wraps AsyncComputer, exposes as tool for agent to call"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Singleton pattern: single shared AsyncComputer for all runs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Per-request pattern: ComputerProvider factory, avoids state leakage between concurrent runs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Loop: screenshot → model.decide → execute actions → screenshot again"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"\"Actions are typed (click, type, scroll, etc.) rather than raw commands\" — this structured approach provides type safety, clear semantics, easier validation, and API versioning support."}]}]}}
