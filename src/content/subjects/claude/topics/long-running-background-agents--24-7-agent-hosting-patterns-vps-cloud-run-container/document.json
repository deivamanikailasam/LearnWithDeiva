":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"VPS"},{"type":"text","text":" = "},{"type":"text","marks":[{"type":"bold"}],"text":"Renting an apartment"},{"type":"text","text":": You have your own space (VM), can decorate however you want (full OS access), but you don't own the building. Your agent lives there 24/7, and you just check in when needed."}]}]}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cloud Run"},{"type":"text","text":" = "},{"type":"text","marks":[{"type":"bold"}],"text":"Staying in a hotel"},{"type":"text","text":": The hotel handles everything (scaling, networking), you just show up (send request) and leave. Perfect for short visits but not for living there 24/7."}]}]}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Container"},{"type":"text","text":" = "},{"type":"text","marks":[{"type":"bold"}],"text":"Building your own house"},{"type":"text","text":": You control everything (infrastructure), but you have to build and maintain it yourself. Great if you need specific features, but expensive and requires work."}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"VPS: dedicated VM, sandboxed, runs 24/7, sessions persist, €5/month minimum"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Cloud Run: fully managed serverless, stateless containers, auto-scaling, pay per request"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Container: self-hosted on Kubernetes/Docker, full infrastructure control, requires hardware investment"}]}]},{"type":"listItem","conten