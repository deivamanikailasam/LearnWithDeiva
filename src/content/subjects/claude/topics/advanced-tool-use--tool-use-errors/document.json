oubleshooting-tool-use)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Use "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"is_error: true"},{"type":"text","marks":[{"type":"bold"}],"text":" for Failures"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"try {\n  const result = queryDatabase(toolInput.query, toolInput.params);\n  \n  const toolResult = {\n    type: \"tool_result\",\n    tool_use_id: toolId,\n    content: JSON.stringify(result),\n    is_error: false\n  };\n} catch (error) {\n  const toolResult = {\n    type: \"tool_result\",\n    tool_use_id: toolId,\n    content: error.message,\n    is_error: true\n  };\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why"},{"type":"text","text":": Explicit failure indication for Claude."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Provide Clear, Actionable Error Messages"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// ❌ Bad: Generic\ncontent: \"Database error\"\n\n// ✅ Good: Informative + actionable\ncontent: \"Database connection failed: timeout after 30 seconds. Host: db.example.com, Port: 5432. Try connecting to backup server at db-backup.example.com or reduce query complexity.\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Keep Untrusted Content in tool_result"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// ✅ Safe: Keep untrusted content in tool_result\nconst toolResult = {\n  type: \"tool_result\",\n  tool_use_id: toolId,\n  content: thirdPartyApiResponse // Keep inside tool_result\n};\n\n// ❌ Dangerous: Don't put in system/user text\nsystem: thirdPartyApiResponse // Treat as untrusted!"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Handle Individual Errors in Parallel Calls"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Execute multiple tools\nconst results = await Promise.all(\n  toolUseBlocks.map(block => {\n    try {\n      return executeTool(block.name, block.input);\n    } catch (error) {\n      return { error: error.message };\n    }\n  })\n);\n\n// Map results with individual error handling\nconst toolResultBlocks = toolUseBlocks.map((block, i) => ({\n  type: \"tool_result\",\n  tool_use_id: block.id,\n  content: results[i].error ? results[i].error : JSON.stringify(results[i]),\n  is_error: results[i].error ? true : false\n}));"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Put "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_result"},{"type":"text","marks":[{"type":"bold"}],"text":" Before Any Text"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// ✅ Correct: tool_result first\n{\n  role: \"user\",\n  content: [\n    { type: \"tool_result\", tool_use_id: \"toolu_01A\", content: \"175.43\" },\n    { type: \"text\", text: \"Also, what's the weather?\" }\n  ]\n}\n\n// ❌ Wrong: text before tool_result\n{\n  role: \"user\",\n  content: [\n    { type: \"text\", text: \"Also, what's the weather?\" },\n    { type: \"tool_result\", tool_use_id: \"toolu_01A\", content: \"175.43\" }\n  ]\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Retry on Error"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"const maxRetries = 3;\nlet attempt = 0;\n\nwhile (attempt < maxRetries) {\n  try {\n    const result = executeTool(toolName, toolInput);\n    const toolResult = {\n      type: \"tool_result\",\n      tool_use_id: toolId,\n      content: JSON.stringify(result),\n      is_error: false\n    };\n    break; // Success, exit retry loop\n  } catch (error) {\n    attempt++;\n    if (attempt === maxRetries) {\n      const toolResult = {\n        type: \"tool_result\",\n        tool_use_id: toolId,\n        content: `Failed after ${maxRetries} attempts: ${error.message}`,\n        is_error: true\n      };\n    } else {\n      // Log and retry\n      console.warn(`Attempt ${attempt} failed: ${error.message}. Retrying...`);\n    }\n  }\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why"},{"type":"text","text":": Resilience for flaky operations."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"7. "},{"type":"text","marks":[{"type":"bold"}],"text":"Add "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"strict: true"},{"type":"text","marks":[{"type":"bold"}],"text":" for Schema Validation"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"const tool = {\n  name: \"query_database\",\n  description: \"Execute SQL query...\",\n  input_schema: {\n    type: \"object\",\n    properties: {\n      query: { type: \"string\" },\n      params: { type: \"array\" }\n    },\n    required: [\"query\"]\n  },\n  strict: true // Ensure Claude's tool calls match schema exactly\n};"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why"},{"type":"text","text":": Prevents Claude from inventing parameters."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text",