        "content": [
          {
            "type": "text",
            "text": "Docker Setup"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "dockerfile"
        },
        "content": [
          {
            "type": "text",
            "text": "# Dockerfile for containerized deployment\nFROM python:3.11\n\nWORKDIR /app\n\n# Install dependencies\nCOPY requirements.txt .\nRUN pip install claude-agent-sdk\n\n# Copy application code\nCOPY . .\n\n# Set environment variable\nENV ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}\n\n# Run agent service\nCMD [\"python\", \"agent_service.py\"]"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Kubernetes Deployment"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "yaml"
        },
        "content": [
          {
            "type": "text",
            "text": "# Kubernetes deployment manifest\napiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: claude-agent\nspec:\n  replicas: 3\n  selector:\n    matchLabels:\n      app: claude-agent\n  template:\n    metadata:\n      labels:\n        app: claude-agent\n    spec:\n      containers:\n      - name: agent\n        image: claude-agent:latest\n        env:\n        - name: ANTHROPIC_API_KEY\n          valueFrom:\n            secretKeyRef:\n              name: claude-secret\n              key: api-key\n        ports:\n        - containerPort: 8080"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Benefits"
          },
          {
            "type": "text",
            "text": ": Long-running sessions, custom orchestration, full control over infrastructure."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "VPS Deployment"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "For 24/7 Autonomy"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "bash"
        },
        "content": [
          {
            "type": "text",
            "text": "# VPS deployment script\n#!/bin/bash\n\n# Install dependencies\nsudo apt update\nsudo apt install python3 pip docker\n\n# Clone and setup agent\ncd /opt\ngit clone https://github.com/your-org/claude-agent.git\ncd claude-agent\n\n# Set API key securely\nexport ANTHROPIC_API_KEY=\"your-api-key\"\n\n# Run agent\npython3 agent_service.py --daemon"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Benefits"
          },
          {
            "type": "text",
            "text": ": Dedicated hardware, 24/7 autonomy, sessions persist across disconnects, full OS control."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Security Best Practices"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Credential Management"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Critical security rule"
          },
          {
            "type": "text",
            "text": ": \"Anthropic's secure deployment guide recommends placing credentials outside the agent's boundary entirely\"."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "yaml"
        },
        "content": [
          {
            "type": "text",
            "text": "DON'T: Store API keys in agent code\n    \u2193\nDO: Run a proxy that injects API keys\n    \u2193\nAgent receives authenticated requests without knowing keys"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "API Key Injection via Proxy"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Secure proxy pattern\nimport { Agent } from \"@anthropic-ai/claude-agent-sdk\";\n\n// Proxy injects API key, agent doesn't see it\nconst proxy = createProxy({\n  apiUrl: \"https://api.your-company.com/claude\",\n  apiKey: process.env.ANTHROPIC_API_KEY\n});\n\nexport async function handleRequest(prompt: string) {\n  const agent = new Agent({\n    // Agent uses proxy, not direct API key\n    apiUrl: proxy.apiUrl,\n    allowedTools: [\"read\", \"write\", \"bash\"]\n  });\n  \n  return agent.query(prompt);\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Environment Variables"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "bash"
        },
        "content": [
          {
            "type": "text",
            "text": "# Set API key as environment variable (not in code)\nexport ANTHROPIC_API_KEY=\"your-api-key-here\""
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Never"
          },
          {
            "type": "text",
            "text": ": Store API keys in source code or configuration files."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Production Architecture"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Multi-Agent Orchestrator Pattern"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "text"
        },
        "content": [
          {
            "type": "text",
            "text": "User Request \u2192 Orchestrator Agent\n    \u2193\nDelegates to:\n\u251c\u2500 Research Agent (web search)\n\u251c\u2500 Coding Agent (write code)\n\u251c\u2500 Review Agent (quality check)\n\u2514\u2500 MCP Server (CRM, API calls)\n    \u2193\nResults aggregated \u2192 Final response"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Session Management"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Python: Use production session store\nfrom claude_agent_sdk import Agent, RedisSessionStore\n\n# Use Redis (not InMemorySessionStore)\nsession_store = RedisSessionStore(redis_url=\"redis://localhost:6379\")\n\nagent = Agent(session_store=session_store)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Critical"
          },
          {
            "type": "text",
            "text": ": \"InMemorySessionStore is NOT suitable for production\" \u2014 use Redis, PostgreSQL, or S3-backed stores."
          }
        ]
      },
