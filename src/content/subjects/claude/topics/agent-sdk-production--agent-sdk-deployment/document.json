      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "AWS Lambda Example"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// TypeScript: Deploy to AWS Lambda\nimport { Handler } from \"aws-lambda\";\nimport { Agent } from \"@anthropic-ai/claude-agent-sdk\";\n\nexport const handler: Handler = async (event) => {\n  const agent = new Agent({\n    apiKey: event.apiKey,\n    allowedTools: [\"read\", \"write\", \"bash\"]\n  });\n  \n  const result = await agent.query(event.prompt);\n  return { result: result.output };\n};"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Benefits"
          },
          {
            "type": "text",
            "text": ": Auto-scaling, cost-efficiency for burst workloads, no server management."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Cloud Functions Example"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Python: Deploy to Google Cloud Functions\nfrom claude_agent_sdk import Agent\nimport functions_framework\n\nagent = Agent(allowed_tools=[\"read\", \"write\", \"bash\"])\n\n@functions_framework.http\ndef main(request):\n    prompt = request.json.get(\"prompt\")\n    result = agent.query(prompt)\n    return {\"result\": result.output}"
          }
        ]
      },
