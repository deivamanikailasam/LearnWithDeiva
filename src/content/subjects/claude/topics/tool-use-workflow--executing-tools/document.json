 executes"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Must implement client-side handler"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use SDK Tool Runner wrapper"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Latency overhead"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Round-trip: Claude → code → Claude"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use parallel tool calls"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multiple turns"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tool loop = multiple API calls"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use SDK wrapper"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Validation required"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Claude respects schema but you must validate"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Validate before execution"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Error handling"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Must catch and report failures"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Implement retry/backoff logic"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How It Works"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Execution Step in the Tool Loop"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Step 1: Claude returns tool_use block (stop_reason: \"tool_use\")\nStep 2: Your app extracts tool name, input, and id\nStep 3: Your app executes tool with input parameters\nStep 4: Your app sends tool_result back with tool_use_id and result\nStep 5: Claude continues reasoning with result"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Execution Pattern"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Step 1: Receive tool_use block\nconst response = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [{ role: \"user\", content: \"What's AAPL's stock price?\" }],\n  tools: [getStockPriceTool]\n});\n\n// Step 2: Extract tool_use blocks\nif (response.stop_reason === \"tool_use\") {\n  const toolUseBlocks = response.content.filter(c => c.type === \"tool_use\");\n  \n  // Step 3: Execute each tool\n  const results = await Promise.all(\n    toolUseBlocks.map(async (block) => {\n      const { name, input, id } = block;\n      \n      // Validate input before execution\n      if (typeof input.symbol !== \"string\") {\n        throw new Error(\"symbol must be a string\");\n      }\n      \n      // Execute the tool\n      const result = executeTool(name, input);\n      \n      return { toolUseId: id, result: result };\n    })\n  );\n  \n  // Step 4: Send tool_result back\n  const toolResultBlocks = results.map(r => ({\n    type: \"tool_result\",\n    tool_use_id: r.toolUseId,\n    content: r.result.toString()\n  }));\n  \n  const response2 = await client.messages.create({\n    model: \"claude-4-sonnet-20251027\",\n    messages: [\n      ...response.messages,\n      { role: \"user\", content: toolResultBlocks }\n    ],\n    tools: [getStockPriceTool]\n  });\n  \n  // Step 5: Claude gives final answer\n  console.log(response2.content[0].text);\n  // \"AAPL is currently trading at $175.43\"\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Mapping Tool Names to Functions"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Your app needs to map tool names to actual functions\nfunction executeTool(toolName, toolInput) {\n  switch (toolName) {\n    case \"get_stock_price\":\n      return getStockPrice(toolInput.symbol);\n    case \"query_database\":\n      return queryDatabase(toolInput.query, toolInput.params);\n    case \"run_tests\":\n      return runTests(toolInput.command, toolInput.timeout);\n    default:\n      throw new Error(`Unknown tool: ${toolName}`);\n  }\n}\n\n// Implementation\nfunction getStockPrice(symbol) {\n  // Fetch from external API\n  return 175.43;\n}\n\nfunction queryDatabase(query, params) {\n  // Execute SQL query\n  return [{ id: 1, name: \"John\" }];\n}\n\nfunction runTests(command, timeout) {\n  // Execute test command\n  return { passed: 95, failed: 0 };\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Parallel Execution"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Claude requests multiple tools in one turn\nconst toolUseBlocks = response.content.filter(c => c.type === \"tool_use\");\n\n// Execute in parallel\nconst results = await Promise.all(\n  toolUseBlocks.map(block => {\n    const { name, input, id } = block;\n    return executeTool(name, input); // Returns result\n  })\n);"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Result"},{"type":"text","text":": Claude can call 2+ tools in parallel, efficiency gain."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Validate Before Execution"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"function executeTool(toolName, toolInput) {\n  if (toolName === \"get_stock_price\") {\n    // Validate symbol is string\n    if (typeof toolInput.symbol !== \"string\") {\n      throw new Error(\"symbol must be a string\");\n    }\n    // Validate symbol length\n    if (toolInput.symbol.length > 5) {\n      throw new Error(\"symbol too long\");\n    }\n    // Execute\n    return getStockPrice(toolInput.symbol);\n  }\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why"},{"type":"text","text":": Schema guides Claude, but YOU validate before running."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Handle Errors Gracefully"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"function executeTool(toolName, toolInput) {\n  try {\n    if (toolName === \"query_database\") {\n      return queryDatabase(toolInput.query, toolInput.params);\n    }\n  } catch (error) {\n    // Log error for auditing\n    console.error(\"Tool execution failed:\", error);\n    \n    // Re-throw for Claude to handle\n    throw error;\n  }\n}\n\n// Send error back to Claude\nconst toolResultBlocks = results.map(r => ({\n  type: \"tool_result\",\n  tool_use_id: r.toolUseId,\n  content: r.result,\n  is_error: r.isError // Optional error flag\n}));"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why"},{"type":"text","text":": Graceful failure recovery."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Use Permissioning for Side Effects"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"function executeTool(toolName, toolInput) {\n  if (toolName === \"delete_database\") {\n    // Require explicit approval\n    if (!userProvidedApproval) {\n      throw new Error(\"Requires explicit approval for DELETE operations\");\n    }\n    return deleteDatabase(toolInput.query);\n  }\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why"},{"type":"text","text":": Safe operations, prevent unintended side effects."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Prefer Auditable Tools"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Add logging for auditing\nfunction executeTool(toolName, toolInput) {\n  const startTime = Date.now();\n  \n  const result = internalExecuteTool(toolName, toolInput);\n  \n  // Log for audit\n  console.log({\n    tool: toolName,\n    input: toolInput,\n    output: result,\n    duration: Date.now() - startTime,\n    timestamp: new Date().toISOString()\n  });\n  \n  return result;\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why"},{"type":"text","text":": Validated inputs/outputs, failure handling, permissioning."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Use SDK Tool Runner"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// TypeScript SDK's Tool Runner\nimport { ToolRunner } from \"@anthropic-ai/sdk/tool-runner\";\n\n// Your actual function\nasync function getStockPrice(symbol: string): Promise<number> {\n  return 175.43;\n}\n\n// Tool Runner: reads types + docs, builds schema automatically\nconst runner = new ToolRunner({\n  model: \"claude-4-sonnet-20251027\",\n  tools: [getStockPrice]\n});\n\n// Send prompt, wait for result\nconst result = await runner.run(\"What's AAPL's stock price?\");\nconsole.log(result); // 175.43"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Advantage"},{"type":"text","text":": Shrinks code to \"describe tool → send prompt → wait for result\"."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude doesn't execute tools"},{"type":"text","text":" → Your code runs the operation"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Execution step"},{"type":"text","text":": Extract → Validate → Execute → Send result back"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Validate before execution"},{"type":"text","text":" → Schema guides Claude, but YOU validate"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Handle errors gracefully"},{"type":"text","text":" → Log for auditing, report to Claude"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use permissioning for side effects"},{"type":"text","text":" → Require approval for DELETE/UPDATE"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prefer auditable tools"},{"type":"text","text":" → Validated inputs/outputs, failure handling"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Execute in parallel"},{"type":"text","text":" → Multiple tool_use blocks → Promise.all"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Map tool names to functions"},{"type":"text","text":" → switch statement or function registry"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use SDK Tool Runner"},{"type":"text","text":" → Automatic schema + loop handling"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Treat cost/latency as architecture"},{"type":"text","text":" → Measure parallelism, caching"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"For your Box Hill distributed systems work, I'd implement "},{"type":"text","marks":[{"type":"bold"}],"text":"validation before execution + error handling + permissioning for database DELETE/UPDATE operations + parallel execution for multiple queries"},{"type":"text","text":". This gives you safe, auditable tool execution while maintaining efficiency gains."}]}]}}
