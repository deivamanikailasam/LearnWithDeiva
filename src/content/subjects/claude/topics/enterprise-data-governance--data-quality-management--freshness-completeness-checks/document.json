      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Completeness Check Implementation"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass\nimport json\n\nREQUIRED_FIELDS = [\"source_id\", \"classification\", \"acl\", \"ingest_timestamp\", \"content_hash\"]\n\n@dataclass\nclass CompletenessResult:\n    total_chunks: int\n    complete_chunks: int\n    incomplete_chunks: int\n    completeness_rate: float\n    missing_by_field: dict[str, int]\n    incomplete_sample: list[dict]  # first 10 incomplete chunk IDs with missing fields\n\ndef check_completeness(collection) -> CompletenessResult:\n    results = collection.get(include=[\"metadatas\", \"ids\"])\n    total = len(results[\"ids\"])\n    complete = 0\n    missing_by_field = {f: 0 for f in REQUIRED_FIELDS}\n    incomplete_sample = []\n\n    for chunk_id, meta in zip(results[\"ids\"], results[\"metadatas\"]):\n        missing = [f for f in REQUIRED_FIELDS if not meta.get(f)]\n        if not missing:\n            complete += 1\n        else:\n            for f in missing:\n                missing_by_field[f] += 1\n            if len(incomplete_sample) < 10:\n                incomplete_sample.append({\"chunk_id\": chunk_id, \"missing\": missing})\n\n    rate = round(complete / total * 100, 2) if total else 0.0\n    return CompletenessResult(\n        total_chunks=total,\n        complete_chunks=complete,\n        incomplete_chunks=total - complete,\n        completeness_rate=rate,\n        missing_by_field=missing_by_field,\n        incomplete_sample=incomplete_sample,\n    )\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Quarantining Incomplete Chunks"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def quarantine_incomplete_chunks(collection, quarantine_collection):\n    \"\"\"\n    Move chunks with missing required fields to a quarantine collection.\n    Quarantined chunks are not returned by retrieval queries.\n    \"\"\"\n    results = collection.get(include=[\"metadatas\", \"documents\", \"embeddings\", \"ids\"])\n    quarantine_ids = []\n\n    for chunk_id, meta, doc, emb in zip(\n        results[\"ids\"], results[\"metadatas\"],\n        results[\"documents\"], results[\"embeddings\"],\n    ):\n        missing = [f for f in REQUIRED_FIELDS if not meta.get(f)]\n        if missing:\n            quarantine_collection.add(\n                ids=[chunk_id],\n                embeddings=[emb],\n                documents=[doc],\n                metadatas=[{**meta, \"_quarantine_reason\": f\"missing: {missing}\",\n                             \"_quarantined_at\": __import__(\"datetime\").datetime\n                             .now(__import__(\"datetime\").timezone.utc).isoformat()}],\n            )\n            quarantine_ids.append(chunk_id)\n\n    if quarantine_ids:\n        collection.delete(ids=quarantine_ids)\n        print(f\"Quarantined {len(quarantine_ids)} incomplete chunks\")\n    return quarantine_ids\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Scheduling and Alerting"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Both checks must run on a schedule and on-demand after every ingest. The following example uses a simple scheduler; in production, replace with Airflow, AWS EventBridge, or a similar orchestrator."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import schedule, time, json\nfrom datetime import datetime, timezone\nfrom pathlib import Path\n\nALERT_LOG = Path(\"logs/quality_alerts.jsonl\")\n\ndef alert(severity: str, message: str, details: dict):\n    record = {\n        \"timestamp\": datetime.now(timezone.utc).isoformat(),\n        \"severity\": severity,\n        \"message\": message,\n        \"details\": details,\n    }\n    with ALERT_LOG.open(\"a\") as f:\n        f.write(json.dumps(record) + \"\\n\")\n    print(f\"[{severity}] {message}\")\n\ndef run_quality_checks(collection, quarantine_collection):\n    # Freshness sweep\n    run_freshness_sweep(collection)\n\n    # Completeness check\n    result = check_completeness(collection)\n    if result.completeness_rate < 98.0:\n        alert(\n            \"P2\" if result.completeness_rate >= 95.0 else \"P1\",\n            f\"Completeness below threshold: {result.completeness_rate}%\",\n            {\"missing_by_field\": result.missing_by_field,\n             \"sample\": result.incomplete_sample},\n        )\n        quarantine_incomplete_chunks(collection, quarantine_collection)\n\n# Schedule: daily at 02:00 UTC\nschedule.every().day.at(\"02:00\").do(\n    run_quality_checks, collection=collection, quarantine_collection=quarantine_col\n)\n\n# Also expose as a callable for post-ingest hooks\ndef post_ingest_hook(source_id: str, collection, quarantine_collection):\n    \"\"\"Call immediately after any ingest completes.\"\"\"\n    result = check_completeness(collection)\n    if not result.incomplete_chunks == 0:\n        quarantine_incomplete_chunks(collection, quarantine_collection)\n        alert(\"P2\", f\"Post-ingest completeness issue for {source_id}\",\n              {\"incomplete\": result.incomplete_chunks})\n"
          }
        ]
      },
