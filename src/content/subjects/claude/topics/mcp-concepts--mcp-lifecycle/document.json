:"STDIO Shutdown Sequence (Detailed)"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"1. Close input stream (client → server)\n2. If unresponsive, send SIGTERM\n3. If still unresponsive, send SIGKILL"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Graceful Shutdown (Async)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Python asyncio triggers CancelledError\n# Server's main event loop handles cleanup\ncancelled = CancelledError()\nawait cleanup_resources()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cleanup steps:"},{"type":"text","text":"\n| Step | Purpose |\n|------|---------|\n| "},{"type":"text","marks":[{"type":"bold"}],"text":"Resource cleanup"},{"type":"text","text":" | Release all allocated resources |\n| "},{"type":"text","marks":[{"type":"bold"}],"text":"Connection closure"},{"type":"text","text":" | Properly close communication channels |\n| "},{"type":"text","marks":[{"type":"bold"}],"text":"State reset"},{"type":"text","text":" | Reset server for next session |"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Special Cases"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Error Handling"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Error type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Recovery"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Unrecoverable error"}]}]},{"type":"tableCell","attrs":{"c