{"format":"tiptap/v1","updatedAt":"2026-06-20T12:29:39.689Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"A "},{"type":"text","marks":[{"type":"bold"}],"text":"user message"},{"type":"text","text":" is the actual instruction, question, task, or data you send to the model in a chat interaction. While the system prompt defines the AI's role and behavior long-term, the user message contains the "},{"type":"text","marks":[{"type":"bold"}],"text":"specific work to be done"},{"type":"text","text":" in that moment."}]},{"type":"paragraph","content":[{"type":"text","text":"Think of it as the "},{"type":"text","marks":[{"type":"bold"}],"text":"task within the role"},{"type":"text","text":": if the system prompt says \"you're a senior engineer,\" the user message says \"refactor this function.\""}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Core elements of a user message"}]},{"type":"paragraph","content":[{"type":"text","text":"A well-crafted user prompt typically contains these key components:"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Instruction / Task"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What you want the model to do"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"A specific instruction or question"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Example: \"Classify the text into neutral, negative, or positive\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Example: \"Explain this code in simple terms\""}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Context"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"External information that steers better responses"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Background about the situation, audience, or domain"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Example: \"I'm a beginner studying cell biology and find photosynthesis difficult\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Example: \"This is for a SaaS product targeting mid-market tech companies\""}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. Input Data"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"The actual content to process"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Text, code, images, or data the model needs to analyze"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Example: \"I think the food was okay.\" (for sentiment classification)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Example: A code snippet wrapped in ```tsx blocks[]"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"4. Output Indicator"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Type or format of the expected output"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"JSON schema, bullet points, tables, word count, etc."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Example: \"Respond in this exact JSON format: { category, reason }\"]"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Example: \"List 5 ideas with explanations (max 20 words each)\"]"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"This is often summarized as the "},{"type":"text","marks":[{"type":"bold"}],"text":"R-C-T-O formula"},{"type":"text","text":" (Role, Context, Task, Output), though in user messages, "},{"type":"text","marks":[{"type":"bold"}],"text":"role"},{"type":"text","text":" is often in the system prompt instead.]"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Message roles in chat models"}]},{"type":"paragraph","content":[{"type":"text","text":"When using chat models like Claude (via the Messages API) or OpenAI models, you can structure your prompt using "},{"type":"text","marks":[{"type":"bold"}],"text":"three different roles"},{"type":"text","text":":]"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":"left"},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Role"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":"left"},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Purpose"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":"left"},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"System"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Sets overall behavior (constant)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"You are a senior TypeScript engineer\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"User"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Specific task or data (changes per turn)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"Refactor this function to be async\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Assistant"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Model response OR examples of desired behavior"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"Here's the refactored code...\""}]}]}]}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"bold"}],"text":"system message"},{"type":"text","text":" is not required but helps set assistant behavior.]"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"bold"}],"text":"user message"},{"type":"text","text":" is what you use to directly prompt the model.]"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"bold"}],"text":"assistant message"},{"type":"text","text":" corresponds to the model response, but you can also define one to pass "},{"type":"text","marks":[{"type":"bold"}],"text":"examples of desired behavior"},{"type":"text","text":" (few-shot prompting).]"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Common user message patterns"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Zero-shot prompting"}]},{"type":"paragraph","content":[{"type":"text","text":"Directly prompting the model without examples:"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Format:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"<Question>?"}]},{"type":"paragraph","content":[{"type":"text","text":"or"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"<Instruction>"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Classify the text into neutral, negative, or positive.\nText: I think the food was okay.\nSentiment:"}]},{"type":"paragraph","content":[{"type":"text","text":"This is called "},{"type":"text","marks":[{"type":"bold"}],"text":"zero-shot"},{"type":"text","text":" because you're not providing any demonstrations about the task.]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Few-shot prompting (with exemplars)"}]},{"type":"paragraph","content":[{"type":"text","text":"Provide demonstrations of the task you want the model to achieve:"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"QA format:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Q: <Question>?\nA: <Answer>\nQ: <Question>?\nA: <Answer>\nQ: <Question>?\nA: <Answer>\nQ: <Question>?\nA:"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Classify emails into Billing, Bug, Feature, or Other.\n\nEmail: \"I was double charged this month.\"\nCategory: Billing\nReason: The email is about incorrect charging.\n\nEmail: \"The app crashes when I click Export.\"\nCategory: Bug\nReason: A specific feature is crashing.\n\nEmail: \"Can you add a Google Sheets export option?\"\nCategory:"}]},{"type":"paragraph","content":[{"type":"text","text":"This is "},{"type":"text","marks":[{"type":"bold"}],"text":"few-shot prompting"},{"type":"text","text":" — providing exemplars (demonstrations) to guide the model.]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. Role + Task + Context + Format"}]},{"type":"paragraph","content":[{"type":"text","text":"A complete user prompt with all four layers:]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"You are a professional customer support agent.\nSummarize the following email in 2 bullet points, focusing on the customer's main issue and requested action.\n\nEmail:\n\"Hi, I've been trying to log in for 3 days and keep getting 'invalid password' errors even though I'm sure my password is correct. I need access urgently for a client presentation tomorrow. Can you help me reset it or troubleshoot this?\""}]},{"type":"paragraph","content":[{"type":"text","text":"Note: In best practice, "},{"type":"text","marks":[{"type":"bold"}],"text":"role instructions should go in the System Message"},{"type":"text","text":", not the User Message, to keep the AI consistent across multiple interactions.]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"4. Structured user messages with tags"}]},{"type":"paragraph","content":[{"type":"text","text":"Use XML-style tags to separate instruction from data:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"<task>\nClassify this customer email into one of: Billing, Bug, Feature, Other.\n</task>\n\n<rules>\n- Category must be exactly one of the four values.\n- Reason must be ≤ 25 words.\n- If unclear, set category to \"Other\" and explain why.\n</rules>\n\n<email>\n\"I was double charged this month.\"\n</email>\n\n<output_format>\n{\n  \"category\": \"<one_of: Billing | Bug | Feature | Other>\",\n  \"reason\": \"<short explanation>\"\n}\n</output_format>"}]},{"type":"paragraph","content":[{"type":"text","text":"This is especially effective with Claude, which responds well to "},{"type":"text","marks":[{"type":"bold"}],"text":"XML structuring"},{"type":"text","text":".[]]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"5. Multi-turn conversation (with history)"}]},{"type":"paragraph","content":[{"type":"text","text":"Include previous conversation turns to provide context:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"model\": \"claude-sonnet-4-20250514\",\n  \"max_tokens\": 1024,\n  \"system\": \"You are a helpful coding assistant.\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Hello, Claude.\"\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": \"Hi! I'm Claude. How can I help you?\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Can you explain LLMs to me?\"\n    }\n  ]\n}"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"bold"}],"text":"current prompt"},{"type":"text","text":" is the last "},{"type":"text","marks":[{"type":"code"}],"text":"user"},{"type":"text","text":" message."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Earlier turns provide "},{"type":"text","marks":[{"type":"bold"}],"text":"conversation history"},{"type":"text","text":" for context.]"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"6. User message with image input"}]},{"type":"paragraph","content":[{"type":"text","text":"Include text and images in the same user message:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"role\": \"user\",\n  \"content\": [\n    {\n      \"type\": \"image\",\n      \"source\": {\n        \"type\": \"url\",\n        \"url\": \"https://example.com/image.jpg\"\n      }\n    },\n    {\n      \"type\": \"text\",\n      \"text\": \"What's in this image?\"\n    }\n  ]\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"User messages can contain "},{"type":"text","marks":[{"type":"bold"}],"text":"text and/or image content blocks"},{"type":"text","text":".]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"7. User message with assistant pre-fill (schema guidance)"}]},{"type":"paragraph","content":[{"type":"text","text":"On supported models, you can provide a "},{"type":"text","marks":[{"type":"bold"}],"text":"prefilled assistant message"},{"type":"text","text":" to shape Claude's response:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"role\": \"assistant\",\n  \"content\": \"The answer is (\"\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"This \"puts words in Claude's mouth\" to guide multiple-choice answers.]"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Real-world user message examples"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 1: Code explanation"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Weak:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Help me with my code. It's broken."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Strong:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"You are a senior Python engineer.\n\nContext:\n- I'm building a FastAPI backend.\n- The API crashes when handling large JSON payloads.\n\nTask:\n1) Ask me for any files or logs you need.\n2) Once I provide them, identify the likely cause.\n3) Propose a fix and show updated code snippets.\n\nConstraints:\n- Explain in simple terms suitable for an intermediate developer.\n- Do not invent endpoints or libraries not already in the code."}]},{"type":"paragraph","content":[{"type":"text","text":"This applies "},{"type":"text","marks":[{"type":"bold"}],"text":"role, context, task steps, and constraints"},{"type":"text","text":" to the user message (or divides role/constraints into system vs. user depending on your setup).]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 2: Email classifier (few-shot)"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Task:\nLabel customer emails into one of four categories: Billing, Bug, Feature, or Other.\n\nOutput JSON:\n{\"category\": \"<one_of>\", \"reason\": \"<short explanation>\"}\n\nExamples:\nEmail: \"I was double charged this month and my receipt shows two payments.\"\n→ Category: Billing\nReason: The email is about incorrect charging.\n\nEmail: \"The app crashes every time I click 'Export to CSV'.\"\n→ Category: Bug\nReason: A specific feature is crashing.\n\nEmail: \"It would be great if the dashboard could export directly to Google Sheets.\"\n→ Category: Feature\nReason: User is requesting a new capability.\n\nNow label this email:\n\"Can you add a dark mode option to the settings page?\""}]},{"type":"paragraph","content":[{"type":"text","text":"This is a classic "},{"type":"text","marks":[{"type":"bold"}],"text":"few-shot prompting"},{"type":"text","text":" pattern with clear examples and output format.]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 3: Multi-step planning"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"We're working on a feature announcement blog post for city officials about urban planning and AI.\n\nProcess:\n1. First, propose 5 specific angles with a short thesis for each.\n2. Wait for my feedback.\n3. Then we'll outline and write the full post together.\n\nTask:\nPropose 5 angles now. Do not write the full post yet."}]},{"type":"paragraph","content":[{"type":"text","text":"This breaks the work into "},{"type":"text","marks":[{"type":"bold"}],"text":"stages"},{"type":"text","text":" (outline → refine → write), treating Claude as a collaborator, not just a result machine.]"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key principles for user messages"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Be explicit and specific"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Don't say: \"Write something good.\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Say: \"Write a 3-paragraph email to trial users who didn't convert. Tone: friendly but professional. Audience: tech managers. Goal: get them to try the analytics feature.\""}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Claude does not have context on your norms unless you tell it explicitly.]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Use examples when possible"}]},{"type":"paragraph","content":[{"type":"text","text":"Examples are a "},{"type":"text","marks":[{"type":"bold"}],"text":"secret weapon shortcut"},{"type":"text","text":" for getting Claude to generate exactly what you need. By providing a few well-crafted examples, you can dramatically improve accuracy, consistency, and quality.[]]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. Structure with tags and sections"}]},{"type":"paragraph","content":[{"type":"text","text":"Use XML-style tags like "},{"type":"text","marks":[{"type":"code"}],"text":"<task>"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"<rules>"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"<examples>"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"<context>"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"<output_format>"},{"type":"text","text":" to organize your prompt. This helps Claude distinguish instructions from data.[]]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"4. Specify output format"}]},{"type":"paragraph","content":[{"type":"text","text":"Clearly outline your desired output:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Numbered or bulleted lists"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Tables with defined columns"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Step-by-step guides"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"JSON or XML schemas"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Markdown or CSV]"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"5. Include constraints"}]},{"type":"paragraph","content":[{"type":"text","text":"Impose constraints to narrow focus:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Time limits"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Resource restrictions"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Audience knowledge levels"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Specific methodologies to embrace or avoid]"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Example: \"Suggest 3 social media marketing strategies (<$500 budget) that can be executed by a single person within 2 weeks, focusing solely on Instagram and TikTok.\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"6. Iterate through follow-ups"}]},{"type":"paragraph","content":[{"type":"text","text":"The real skill is "},{"type":"text","marks":[{"type":"bold"}],"text":"refining prompts through follow-ups"},{"type":"text","text":", adding context, and adjusting constraints until the output matches your intent.]"}]},{"type":"paragraph","content":[{"type":"text","text":"Treat prompt crafting as an iterative process:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Start with a simple version"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Run the workflow 5–10 times with varied inputs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Identify where outputs drift or fail"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Add constraints or examples to the prompt"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Repeat