{"format":"tiptap/v1","updatedAt":"2026-06-22T08:33:44.365Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"This approach lets Claude "},{"type":"text","marks":[{"type":"bold"}],"text":"discover and create robust Playwright selectors by inspecting the rendered DOM in real-time"},{"type":"text","text":", rather than manually writing brittle selectors that break when the UI changes."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","text":"Instead of hardcoding selectors like "},{"type":"text","marks":[{"type":"code"}],"text":"#submit-btn"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"code"}],"text":".card > div:nth-child(3)"},{"type":"text","text":", you let Claude:\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Navigate to the live page"},{"type":"text","text":" using Playwright MCP\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Inspect the rendered DOM"},{"type":"text","text":" (including dynamic content, React/Vue components, shadow DOM)\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Identify the best selectors"},{"type":"text","text":" based on semantic attributes (roles, text, IDs)\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Generate working Playwright code"},{"type":"text","text":" with validated selectors"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why It Matters"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Problem with Manual Selectors"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Solution with Dynamic Generation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Flaky tests when UI changes"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Selectors validated against actual DOM"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Guessing which attribute to use"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Claude analyzes all available attributes"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Hard to handle dynamic content"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Inspects rendered state after network loads"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Time-consuming selector debugging"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Auto-generates Page Object Model (POM) with reusable functions"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How It Works"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Method 1: Browser Recording + Context Extraction (Recommended)"}]},{"type":"paragraph","content":[{"type":"text","text":"This is the most reliable workflow using Playwright MCP:"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 1: Initialize Browser"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Browser init\nURL: makemytrip.com"}]},{"type":"paragraph","content":[{"type":"text","text":"Claude opens a Playwright-controlled browser window."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 2: Record Your Interactions"},{"type":"text","text":"\nAs you click, search, and fill forms, "},{"type":"text","marks":[{"type":"bold"}],"text":"Claude records every action in real-time"},{"type":"text","text":" on the right side of the interface. No manual test writing needed."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 3: Add DOM Context"},{"type":"text","text":"\n- Click the "},{"type":"text","marks":[{"type":"bold"}],"text":"+ icon"},{"type":"text","text":" at bottom-right\n- Select "},{"type":"text","marks":[{"type":"bold"}],"text":"DOM"},{"type":"text","text":"\n- Choose a specific page section important for your test"}]},{"type":"paragraph","content":[{"type":"text","text":"This extracts the "},{"type":"text","marks":[{"type":"bold"}],"text":"exact HTML component"},{"type":"text","text":", ensuring Claude picks the best selectors instead of guessing."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 4: Extract Context"},{"type":"text","text":"\nAsk Claude to call:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"get context"}]},{"type":"paragraph","content":[{"type":"text","text":"This retrieves all recorded interactions "},{"type":"text","marks":[{"type":"bold"}],"text":"plus the selected HTML component"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 5: Generate Playwright Test"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Using the context, help me write playwright code for e2e testing."}]},{"type":"paragraph","content":[{"type":"text","text":"Claude generates a "},{"type":"text","marks":[{"type":"bold"}],"text":"fully usable Playwright test with validated selectors"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Enhanced Prompt for Better Selectors"}]},{"type":"codeBlock","attrs":{"language":"markdown"},"content":[{"type":"text","text":"## DON'T ASSUME ANYTHING. Whatever you write in code, it must be found in the context. Otherwise leave comments.\n\n## Goal\nHelp me write playwright code with following functionalities:\n- [[add semi-high level functionality you want here]]\n\n## Steps\n- First fetch the context from `get-context` tool, until it returns no elements remaining\n- Based on context and user functionality, write code in POM format, encapsulating high level functionality into reusable functions\n- Try executing code using `execute-code` tool. Navigate to the correct page\n- Write spec file using those reusable functions, covering multiple scenarios\n\nThis prompt ensures selectors are working (a problem we face with LLM-based tests a lot)."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Method 2: Reconnaissance-Then-Action Pattern (For Dynamic Webapps)"}]},{"type":"paragraph","content":[{"type":"text","text":"When the server is already running:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# 1. Inspect rendered DOM\npage.screenshot(path='/tmp/inspect.png', full_page=True)\ncontent = page.content()\npage.locator('button').all()\n\n# 2. Identify selectors from inspection results\n# 3. Execute actions using discovered selectors"}]},{"type":"paragraph","content":[{"type":"text","text":"This handles "},{"type":"text","marks":[{"type":"bold"}],"text":"dynamic content"},{"type":"text","text":" by inspecting after "},{"type":"text","marks":[{"type":"code"}],"text":"networkidle"},{"type":"text","text":" wait."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Method 3: Playwright Agent Trio (Advanced)"}]},{"type":"paragraph","content":[{"type":"text","text":"Playwright ships with three specialized Claude Code subagents:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Agent"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Role"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Selector Generation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Planner"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Explores app, produces Markdown test plan"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Navigates app finding user paths"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Generator"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Transforms plans into Playwright tests"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Actively interacts with app to verify every selector works"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Healer"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Fixes failing tests"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Finds new selectors when button text changes"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Setup:"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"npx playwright init-agents --loop=claude"}]},{"type":"paragraph","content":[{"type":"text","text":"The generator uses "},{"type":"text","marks":[{"type":"bold"}],"text":"semantic locators"},{"type":"text","text":" and implements proper waiting strategies."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Best Practices for Dynamic Selector Generation"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use semantic locators"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"role='button'"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"text='Submit'"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"data-testid"},{"type":"text","text":" instead of CSS paths"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Always wait for network"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"page.wait_for_selector()"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"code"}],"text":"page.wait_for_state('networkidle')"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Encapsulate in POM"},{"type":"text","text":": Create reusable functions for high-level actions"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Validate selectors"},{"type":"text","text":": Use "},{"type":"text","marks":[{"type":"code"}],"text":"execute-code"},{"type":"text","text":" tool to test generated code before committing"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Don't assume"},{"type":"text","text":": Require Claude to find elements in the extracted context"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Real-World Example: MakeMyTrip Search Test"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// Generated by Claude with validated selectors\nimport { test, expect } from '@playwright/test';\n\ntest('MakeMyTrip search flow', async ({ page }) => {\n  await page.goto('https://makemytrip.com');\n  \n  // Selector validated against actual DOM\n  await page.locator('role=tab[text=\"Flight\"]').click();\n  await page.locator('role=textbox[label=\"From\"]').fill('Delhi');\n  await page.locator('role=option[text=\"Delhi, India\"]').click();\n  \n  await page.locator('role=textbox[label=\"To\"]').fill('Bangalore');\n  await page.locator('role=option[text=\"Bangalore, India\"]').click();\n  \n  await page.locator('role=button[text=\"Search\"]').click();\n  \n  await expect(page.locator('role=list[item]')).toContainText('Flight');\n});"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Record interactions, don't write them"},{"type":"text","text":": Let Claude watch your browser actions and auto-generate tests"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"DOM context is critical"},{"type":"text","text":": Selecting specific HTML sections ensures Claude picks reliable selectors"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Validate before committing"},{"type":"text","text":": Use "},{"type":"text","marks":[{"type":"code"}],"text":"execute-code"},{"type":"text","text":" to test selectors work in real"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Semantic locators beat CSS paths"},{"type":"text","text":": Roles, text, and test IDs are more resilient"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Healer agent fixes broken selectors"},{"type":"text","text":": Automatically updates locators when UI changes"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"This approach eliminates the \"guessing which selectors to use\" and \"debugging flaky AI-generated test cases\" problems that traditional test automation faces."}]}]}}
