{"format":"tiptap/v1","updatedAt":"2026-06-22T04:48:34.092Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Based on the official documentation and industry best practices for long-running agent workflows, "},{"type":"text","marks":[{"type":"bold"}],"text":"\"Checkpointing and resuming long agent runs (Managed Agent Runtime pattern)\""},{"type":"text","text":" is the architectural practice of "},{"type":"text","marks":[{"type":"bold"}],"text":"persisting agent state at regular intervals to durable storage, enabling the agent to resume from the last checkpoint after crashes rather than restarting from scratch"},{"type":"text","text":" — reducing hours of lost work to a几分钟 resume."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Checkpointing"},{"type":"text","text":" is: "},{"type":"text","marks":[{"type":"bold"}],"text":"\"Per-step durable write of agent state (scratchpad, plan, prior tool returns), keyed by session, resumable from any step\""},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Core Problem"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Agent loop that runs for hours or days\n    ↓\nCrashes, hits rate limit, or gets rebooted\n    ↓\nState is in-process (memory)\n    ↓\nStart over from scratch"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cost"},{"type":"text","text":": \"Every long-running agent loses time and money on retries\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Solution"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Agent step N → state(N) → Checkpoint to durable storage (workspace/DB)\n    ↓\nCrash happens\n    ↓\nNew process → load(session, last_step) → resume from N+1"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Result"},{"type":"text","text":": \"With checkpointing, crashes become a rounding error\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Properties of Good Checkpoints"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Property"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Why It Matters"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Per-step writes"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Cheap enough to checkpoint every step"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Durable storage"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Survives process restart (DB, file, workspace)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Session keys"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Resume the right loop (session ID)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Versioned state"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Replay or fork from any step"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cross-runtime"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Resume on a different machine"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"In one line"},{"type":"text","text":": \"Checkpoint per step; resume by session id\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"The Checkpoint-and-Resume Pattern"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Design Principle"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Treat your agent like a long-running server process, not a request handler\""},{"type":"text","text":"."}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Request Handler"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Long-Running Server Process"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Checkpoint once at end"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Checkpoint after every batch"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Lose all work on crash"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Resume from last checkpoint"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Start from document 1"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Start from document 201 (where failed)"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Workflow Example"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Scenario: Process 200 documents over 3 days\n    ↓\nCheckpoint after every batch (e.g., 10 documents)\n    ↓\nDocument 201 fails at 2:30am\n    ↓\nWithout checkpointing: Restart from document 1 (lose 2 days of work)\n    ↓\nWith checkpointing: Resume from document 201 (lose 10 documents)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Common failure mode"},{"type":"text","text":": \"Most common failure mode in multi-day workflows is context loss\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Implementation Strategy"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Per-Step Checkpointing"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Agent step N\nstate = {\n    \"scratchpad\": current_scratchpad,\n    \"plan\": current_plan,\n    \"tool_returns\": prior_tool_results,\n    \"step_number\": N,\n    \"timestamp\": datetime.now()\n}\n\n# Persist to durable storage\ncheckpoint_store.save(\n    session_id=session_id,\n    step_number=N,\n    state=state\n)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key"},{"type":"text","text":": \"Cheap enough to do every step\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Resume from Last Checkpoint"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Load last checkpoint\ncheckpoint = checkpoint_store.load(\n    session_id=session_id,\n    step_number=checkpoint_store.get_last_step(session_id)\n)\n\n# Resume agent\nagent.state = checkpoint.state\nagent.step_number = checkpoint.step_number + 1\n\n# Continue processing\nagent.run()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Result"},{"type":"text","text":": \"Resume is a load, not a rebuild\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Checkpoint Lifecycle Management"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"1. Set TTL-based expiration:\n   Workflows that never complete eventually age out\n    ↓\n2. Explicit cleanup after completion:\n   Reclaim space immediately after successful completion\n    ↓\n3. Monitor checkpoint store health:\n   Storage growth or access latency surfaces before recovery fails"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Purpose"},{"type":"text","text":": \"Lifecycle management keeps the checkpoint store from growing without bound\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Implementation Options"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Option 1: Managed Session Storage (Amazon Bedrock AgentCore Runtime)"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"AgentCore Runtime supports long-running workloads\n    ↓\nManaged session storage persists filesystem state\n    ↓\nState persists across stop and resume cycles"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use for"},{"type":"text","text":": Coarse-grained checkpointing (filesystem-level state)."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Option 2: Workflow-State-Aware Checkpointing (AWS Step Functions)"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Step Functions persists execution state at every transition\n    ↓\nEnables restart from point of failure (not beginning)\n    ↓\nRedrive capability from specific failure points"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use for"},{"type":"text","text":": Dynamic workflows driven by supervisor agents, workflow-stage-aware checkpointing."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Option 3: Custom Checkpointing (Amazon Bedrock AgentCore Memory)"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Use AgentCore Memory for custom checkpoint state\n    ↓\nPersist checkpoint state and specification context\n    ↓\nFor agents with bespoke checkpointing needs"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use for"},{"type":"text","text":": Agents requiring custom checkpointing discipline."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Critical Requirement: Idempotency"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why Idempotency is Required"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Checkpointing is only useful if recovery is safe, and recovery is only safe if steps are idempotent\""},{"type":"text","text":"."}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Idempotent step: produces same result whether it runs once or five times with same input\n    ↓\nRetry or resume doesn't add duplicate side effects"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Without idempotency"},{"type":"text","text":": \"Checkpoint-based recovery can produce duplicate side effects or data corruption\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How to Design Idempotent Steps"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Technique"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Example"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Idempotency keys"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"External calls need unique keys"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Conditional writes"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"State mutations need \"if-not-already-set\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Event deduplication"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Event emissions need deduplication logic"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best practice"},{"type":"text","text":": \"Design each step to be idempotent before implementing checkpointing\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Benefits"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Benefit"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Impact"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Workflow restart cost drops"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Resume starts from last checkpoint, not from beginning"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Duplicate work prevented"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Idempotent checkpoint-based recovery"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Compute efficiency improves"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Recovery avoids redundant recomputation"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Risk if not established"},{"type":"text","text":": High."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Anti-Patterns"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Anti-Pattern"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Problem"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"No intermediate state persistence"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Force complete restarts on any failure"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Checkpoints without idempotency"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Duplicate side effects or data corruption on resume"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Skipping checkpoint cleanup"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Accumulate storage indefinitely"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of checkpointing like "},{"type":"text","marks":[{"type":"bold"}],"text":"save points in a video game"},{"type":"text","text":": if you're playing a 3-hour game and your computer crashes, you don't restart from the beginning (document 1). Instead, you load the last save point (checkpoint after document 200) and continue from there. The checkpoint is durable storage (your save file), the session ID is the game instance, and resuming is loading the save—not rebuilding the game from scratch."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Checkpointing = per-step durable write of agent state (scratchpad, plan, tool returns), keyed by session"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Without checkpointing: crashes mean restart from scratch, lose time and money"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"With checkpointing: resume from last checkpoint, crashes become rounding error"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Key properties: per-step writes, durable storage, session keys, versioned state, cross-runtime"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Treat agent like long-running server process, not request handler"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Checkpoint after every batch, not after every document"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Resume from document 201 (where failed), not document 1 (restart)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Resume is a load, not a rebuild"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Checkpoint lifecycle: TTL expiration + explicit cleanup after completion"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Critical: steps must be idempotent (same result running once or five times)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Idempotency: use keys, conditional writes, event deduplication"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Implementation: AgentCore Runtime (filesystem), Step Functions (workflow-state), AgentCore Memory (custom)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Benefits: restart cost drops, duplicate work prevented, compute efficiency improves"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Anti-patterns: no persistence, checkpoints without idempotency, skip cleanup"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Risk if not established: High"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"\"Long-running workflows without checkpoints pay the full restart cost for every failure, no matter how late it happens. Persisting state at natural boundaries and designing every step to be idempotent lets an agent resume from the last completed checkpoint rather than redo work\"."}]}]}}
