ph","content":[{"type":"text","text":"Claude might skip tools"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Add system prompt guidance"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"any"},{"type":"text","marks":[{"type":"bold"}],"text":" = more freedom"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"More risk of misuse"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Clear prompt contract"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"force"},{"type":"text","marks":[{"type":"bold"}],"text":" = specific"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Only one tool available"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use when you need specific tool"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prompt design critical"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"As important as "},{"type":"text","marks":[{"type":"code"}],"text":"tool_choice"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Write explicit instructions"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cost/latency"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Multiple turns for tool calls"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use parallel calls, PTC"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How It Works"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"code"}],"text":"tool_choice"},{"type":"text","text":" Parameter Options"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// 1. AUTO (default): Claude decides when to use tools\nconst response1 = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [{ role: \"user\", content: \"What's AAPL's stock price?\" }],\n  tools: [getStockPriceTool],\n  tool_choice: { type: \"auto\" } // Claude decides\n});\n\n// 2. ANY: Claude MUST call at least one tool\nconst response2 = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [{ role: \"user\", content: \"What's AAPL's stock price?\" }],\n  tools: [getStockPriceTool],\n  tool_choice: { type: \"any\" } // Forces tool call\n});\n\n// 3. FORCE specific tool: Claude must call this exact tool\nconst response3 = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [{ role: \"user\", content: \"What's AAPL's stock price?\" }],\n  tools: [getStockPriceTool],\n  tool_choice: { type: \"force\", name: \"get_stock_price\" } // Forces specific tool\n});"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"System Prompt Nudges (Steering)"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Light instruction: measurably increases tool use\nconst response1 = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  system: \"Use the tools to investigate before responding.\",\n  messages: [{ role: \"user\", content: \"What's the weather in Boston?\" }],\n  tools: [getWeatherTool]\n});\n\n// Stronger form: pushes to tool-first behavior\nconst response2 = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  system: \"Always call a tool first before responding.\",\n  messages: [{ role: \"user\", content: \"What's the weather in Boston?\" }],\n  tools: [getWeatherTool]\n});\n\n// Conservative: keeps triggering behavior minimal\nconst response3 = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  system: \"Use your judgment about whether to call a tool or respond directly.\",\n  messages: [{ role: \"user\", content: \"What's the weather in Boston?\" }],\n  tools: [getWeatherTool]\n});"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When Claude Uses Tools (Default Behavior)"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// With tool_choice: { type: \"auto\" }\nClaude calls a tool when:\n1. The request maps to that tool's described capability\n2. AND the answer isn't already in context\n\nClaude responds directly for:\n- Stable knowledge (e.g., \"What's the capital of France?\")\n- Creative tasks (e.g., writing, poetry)\n- Conversational turns (e.g., chat)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Use "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_choice: { type: \"auto\" }"},{"type":"text","marks":[{"type":"bold"}],"text":" for Selective Usage"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"const response = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [{ role: \"user\", content: \"What's AAPL's stock price?\" }],\n  tools: [getStockPriceTool],\n  tool_choice: { type: \"auto\" } // Default: Claude decides\n});"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why"},{"type":"text","text":": Intelligent tool selection for most use cases."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Use "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_choice: { type: \"any\" }"},{"type":"text","marks":[{"type":"bold"}],"text":" for Hard Guarantee"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"const response = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [{ role: \"user\", content: \"What's AAPL's stock price?\" }],\n  tools: [getStockPriceTool],\n  tool_choice: { type: \"any\" } // Forces tool call instead of nudge\n});"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why"},{"type":"text","text":": Hard guarantee rather than nudge."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Use "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_choice: { type: \"force\" }"},{"type":"text","marks":[{"type":"bold"}],"text":" for Specific Tool"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"const response = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [{ role: \"user\", content: \"Get stock price for AAPL\" }],\n  tools: [getStockPriceTool, getWeatherTool],\n  tool_choice: { type: \"force\", name: \"get_stock_price\" } // Forces specific tool\n});"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why"},{"type":"text","text":": Deterministic behavior, specific tool required."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Add System Prompt for Tool Selection"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Light instruction: measurably increases tool use\nconst response = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  system: \"Use the tools to investigate before responding.\",\n  messages: [{ role: \"user\", content: \"What's the weather in Boston?\" }],\n  tools: [getWeatherTool]\n});"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why"},{"type":"text","text":": Prompt design matters as much as "},{"type":"text","marks":[{"type":"code"}],"text":"tool_choice"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Use Strong System Prompt for Tool-First"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"const response = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  system: \"Always call a tool first before responding.\",\n  messages: [{ role: \"user\", content: \"What's the weather in Boston?\" }],\n  tools: [getWeatherTool]\n});"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why"},{"type":"text","text":": Pushes further than light instruction."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Use Conservative System Prompt for Judgment"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"const response = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  system: \"Use your judgment about whether to call a tool or respond directly.\",\n  messages: [{ role: \"user\", content: \"What's the weather in Boston?\" }],\n  tools: [getWeatherTool]\n});"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why"},{"type":"text","text":": Keeps triggering behavior conservative."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"7. "},{"type":"text","marks":[{"type":"bold"}],"text":"Write Clear Prompt Contract"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// ❌ Bad: Vague instruction\nsystem: \"Use tools when needed.\"\n\n// ✅ Good: Clear contract\nsystem: \"When you need real-time data (stock prices, weather, database queries), always call the appropriate tool first. Do not guess from training data.\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"8. "},{"type":"text","marks":[{"type":"bold"}],"text":"Treat Cost/Latency as Architecture"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Measure parallelism, caching, PTC tradeoffs\nconst parallelResponse = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [{ role: \"user\", content: \"Get stock prices for AAPL and GOOGL\" }],\n  tools: [getStockPriceTool],\n  tool_choice: { type: \"auto\" }\n});\n\n// Use PTC for 37% fewer tokens\nconst ptcResponse = await runPTC({\n  tools: [getStockPriceTool],\n  prompt: \"Get stock prices for AAPL and GOOGL\"\n});"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_choice: { type: \"auto\" }"},{"type":"text","marks":[{"type":"bold"}],"text":" = selective"},{"type":"text","text":" → Claude decides when to use tools"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_choice: { type: \"any\" }"},{"type":"text","marks":[{"type":"bold"}],"text":" = hard guarantee"},{"type":"text","text":" → Forces tool call instead of nudge"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_choice: { type: \"force\" }"},{"type":"text","marks":[{"type":"bold"}],"text":" = specific tool"},{"type":"text","text":" → Deterministic behavior"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"System prompt matters as much as "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_choice"},{"type":"text","text":" → Clear prompt contract"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Light instruction increases tool use"},{"type":"text","text":" → \"Use the tools to investigate before responding\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Stronger form pushes further"},{"type":"text","text":" → \"Always call a tool first before responding\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Conservative keeps minimal"},{"type":"text","text":" → \"Use your judgment about whether to call a tool\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude calls tool when"},{"type":"text","text":": request maps to capability + answer not in context"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude responds directly for"},{"type":"text","text":": stable knowledge, creative tasks, conversational turns"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Treat cost/latency as architecture"},{"type":"text","text":" → Measure parallelism, caching, PTC"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"For your Box Hill distributed systems work, I'd implement "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_choice: { type: \"auto\" }"},{"type":"text","marks":[{"type":"bold"}],"text":" + system prompt \"Always call a tool first before responding when you need real-time data\""},{"type":"text","text":". This gives you intelligent tool selection while forcing tool-first behavior for database queries, API calls, and validation operations."}]}]}}
