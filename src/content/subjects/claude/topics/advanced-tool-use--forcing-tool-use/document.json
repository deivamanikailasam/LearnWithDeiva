{"format":"tiptap/v1","updatedAt":"2026-06-21T15:07:19.560Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Forcing & choosing tools"},{"type":"text","text":" is controlling when Claude calls tools through the "},{"type":"text","marks":[{"type":"code"}],"text":"tool_choice"},{"type":"text","text":" parameter and system prompt instructions. You can guide Claude to use tools selectively ("},{"type":"text","marks":[{"type":"code"}],"text":"auto"},{"type":"text","text":"), force it to always use a tool ("},{"type":"text","marks":[{"type":"code"}],"text":"any"},{"type":"text","text":"), or force a specific tool ("},{"type":"text","marks":[{"type":"code"}],"text":"force"},{"type":"text","text":")."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Core concept"},{"type":"text","text":": \"With default "},{"type":"text","marks":[{"type":"code"}],"text":"tool_choice: { type: \"auto\" }"},{"type":"text","text":", Claude decides on each turn whether to call a tool or respond directly. This boundary is steerable through your system prompt.\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why It Matters"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Without control"},{"type":"text","text":": Claude might skip tools when you need real-time data → gives stale answers from training"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"With control"},{"type":"text","text":": You force tool use when you need external data → accurate, up-to-date results"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"For your distributed systems work"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Database queries"},{"type":"text","text":": Force tool when you need live data, not cached context\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"API calls"},{"type":"text","text":": Force tool for real-time stock prices, not training data\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Validation"},{"type":"text","text":": Force tool to check permissions before operations\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Cost efficiency"},{"type":"text","text":": Use "},{"type":"text","marks":[{"type":"code"}],"text":"auto"},{"type":"text","text":" for simple tasks, avoid unnecessary tool calls"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Benefits"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Benefit"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Value"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Impact"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Selective usage"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"auto"},{"type":"text","text":" mode → Claude decides"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Reduces unnecessary calls"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":