{"format":"tiptap/v1","updatedAt":"2026-06-20T07:02:26.843Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Claude is designed to handle large amounts of text in a single context window."}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Large conversations"},{"type":"text","text":": You can have long, multi-turn conversations where Claude keeps track of earlier details without you repeating everything."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Large documents"},{"type":"text","text":": It can read long reports, specs, or codebases and refer back to specific sections."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Projects"},{"type":"text","text":": In Projects, you can maintain a persistent workspace with:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Multiple documents"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Background context"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Previous chat history"},{"type":"hardBreak"},{"type":"text","text":"This effectively gives you a “long-term memory” for a specific topic or project."}]}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Long context is crucial for:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Complex engineering projects"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Legal or compliance documents"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Multi-part research tasks"},{"type":"hardBreak"},{"type":"text","t