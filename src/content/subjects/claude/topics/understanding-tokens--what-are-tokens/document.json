{"format":"tiptap/v1","updatedAt":"2026-06-21T13:15:11.686Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tokens are the fundamental unit of text that Claude uses to read, understand, and generate content."},{"type":"text","text":" Instead of processing words or sentences directly, Claude breaks all text into smaller chunks called tokens—each token is typically a piece of a word, a single character, punctuation, or whitespace."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How Tokens Work (Technical Details)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Explanation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Size"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"~4 characters per token on average; ~1.5 tokens per English word"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Examples"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"programmatically\" → \"program\" + \"matically\" (2 tokens); punctuation like "},{"type":"text","marks":[{"type":"code"}],"text":","},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"code"}],"text":"?"},{"type":"text","text":" = 1 token each"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Code"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Code syntax is very token-efficient: "},{"type":"text","marks":[{"type":"code"}],"text":"()"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"{"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"}"},{"type":"text","text":" each = 1 token"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tokenizer"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Claude uses a custom tokenizer trained on its data—different from GPT or other models"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Concepts"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Input vs Output Tokens"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- "},{"type":"text","marks":[{"type":"bold"}],"text":"Input tokens"},{"type":"text","text":": Everything you submit (your message + conversation history + files + system prompts) - "},{"type":"text","marks":[{"type":"bold"}],"text":"Output tokens"},{"type":"text","text":": Text Claude generates in response - "},{"type":"text","marks":[{"type":"bold"}],"text":"Pricing"},{"type":"text","text":": Output tokens cost ~5x more than input tokens (e.g., Sonnet: "},{"type":"inlineMath","attrs":{"latex":"3/M input vs"}},{"type":"text","text":"15/M output)"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Context Window"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- Every Claude model has a fixed "},{"type":"text","marks":[{"type":"bold"}],"text":"context window"},{"type":"text","text":"—its memory limit of how many tokens it can hold at once - Most Claude models: ~200k tokens - When you exceed it, "},{"type":"text","marks":[{"type":"bold"}],"text":"earlier tokens get dropped"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cache Tokens"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- Claude supports "},{"type":"text","marks":[{"type":"bold"}],"text":"prompt caching"},{"type":"text","text":" where repeated context (long system prompts, codebase snapshots) is stored and reused at much lower cost - This is why adding project context to your system prompt helps keep usage lower over time"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Real-World Example"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sentence"},{"type":"text","text":": \"Hello, is it me you are looking for?\""}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"8 words"},{"type":"text","text":" but "},{"type":"text","marks":[{"type":"bold"}],"text":"~10 tokens"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Breakdown: "},{"type":"text","marks":[{"type":"code"}],"text":"Hello"},{"type":"text","text":" + "},{"type":"text","marks":[{"type":"code"}],"text":","},{"type":"text","text":" + "},{"type":"text","marks":[{"type":"code"}],"text":"is"},{"type":"text","text":" + "},{"type":"text","marks":[{"type":"code"}],"text":"it"},{"type":"text","text":" + "},{"type":"text","marks":[{"type":"code"}],"text":"me"},{"type":"text","text":" + "},{"type":"text","marks":[{"type":"code"}],"text":"you"},{"type":"text","text":" + "},{"type":"text","marks":[{"type":"code"}],"text":"are"},{"type":"text","text":" + "},{"type":"text","marks":[{"type":"code"}],"text":"looking"},{"type":"text","text":" + "},{"type":"text","marks":[{"type":"code"}],"text":"for"},{"type":"text","text":" + "},{"type":"text","marks":[{"type":"code"}],"text":"?"},{"type":"text","text":" = 10 tokens"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why this matters"},{"type":"text","text":": If your chat uses half the context window (100k tokens), Claude's performance becomes noticeably unreliable—information in the middle gets \"lost\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Quick Reference"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Metric"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Value"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"1 token ≈"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"4 characters or ¾ of a word"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"1,000 tokens ≈"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"750 words (~2 pages)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Standard context"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"~200k tokens"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"1M token context"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Available on some models (e.g., Gemini 2.5 Pro, Claude Opus)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Understanding tokens is critical because "},{"type":"text","marks":[{"type":"bold"}],"text":"every prompt you send and every response you get costs tokens"},{"type":"text","text":"—and they compound as conversations grow longer due to conversation history being reprocessed each time"}]}]}}
