                  "colwidth": null
                },
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Decision domain"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {
                  "colspan": 1,
                  "rowspan": 1,
                  "colwidth": null
                },
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "What kind of decision does this Claude integration inform or make?"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {
                  "colspan": 1,
                  "rowspan": 1,
                  "colwidth": null
                },
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Credit, hiring, and healthcare decisions trigger specific regulatory obligations; customer service and content generation do not"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "attrs": {
                  "colspan": 1,
                  "rowspan": 1,
                  "colwidth": null
                },
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Decision authority"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {
                  "colspan": 1,
                  "rowspan": 1,
                  "colwidth": null
                },
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Does Claude decide autonomously, recommend, or draft for human review?"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {
                  "colspan": 1,
                  "rowspan": 1,
                  "colwidth": null
                },
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Autonomous decisions require stronger justification and controls than advisory outputs reviewed by a human"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "attrs": {
                  "colspan": 1,
                  "rowspan": 1,
                  "colwidth": null
                },
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Affected population"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {
                  "colspan": 1,
                  "rowspan": 1,
                  "colwidth": null
                },
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Who receives the outcome — and could they be harmed by an error?"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {
                  "colspan": 1,
                  "rowspan": 1,
                  "colwidth": null
                },
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Consumer-facing systems affecting members of the public require broader fairness testing than internal tools"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "attrs": {
                  "colspan": 1,
                  "rowspan": 1,
                  "colwidth": null
                },
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Decision reversibility"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {
                  "colspan": 1,
                  "rowspan": 1,
                  "colwidth": null
                },
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Can an affected individual correct an error, or is the outcome permanent?"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {
                  "colspan": 1,
                  "rowspan": 1,
                  "colwidth": null
                },
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Loan denials and hiring rejections are highly reversible; criminal risk assessments and medical advice are not"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Trigger Criteria — When an AIA Is Required"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Not every Claude integration requires a formal AIA. Apply these trigger criteria to determine whether an assessment is needed:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The output of Claude directly or indirectly affects a consequential decision about a natural person (credit, employment, housing, healthcare, law enforcement, education, public benefits)"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Claude processes sensitive personal data categories: race, ethnicity, religion, health, sexual orientation, political opinion, union membership, biometric or genetic data"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The use case reaches 100 or more individuals per month through an automated decision process"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The deployment is covered by a regulation that mandates impact assessment (EU AI Act high-risk category, Canada's Directive on Automated Decision-Making, NYC LL144)"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The AI Owner or legal team identifies significant reputational or financial risk if the system produces biased or inaccurate outputs at scale"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "When in doubt, scope a lightweight AIA. A completed lightweight assessment that concludes the risk is low is better evidence of responsible governance than no assessment at all."
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Three Tiers of AIA Depth"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Tier 1 — Lightweight AIA (1–2 days)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For low-to-medium impact use cases with limited volume. Covers the essential questions without deep quantitative analysis:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Use case description: what does Claude do, who reviews it, what decisions flow from it?"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Affected population: who could be harmed by an error?"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Bias risk screening: are any sensitive attributes present in the input or correlated with output?"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Existing safeguards: is there a human review gate, output filter, or override mechanism?"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Residual risk conclusion: low / medium / high"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Review schedule: when will this be revisited?"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Tier 2 — Standard AIA (1–2 weeks)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For medium-to-high impact use cases or those subject to regulatory requirements. Adds quantitative analysis:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "All Tier 1 content plus:"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Fairness metrics: impact ratios across demographic groups for the relevant decision outcome"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Accuracy analysis: error rate analysis disaggregated by demographic group"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Explainability: can the decision be explained to the affected individual in plain language?"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Adversarial testing: red-team scenarios targeting bias and discrimination"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Stakeholder consultation: impacted groups or their representatives consulted"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Regulatory mapping: specific obligations triggered and how they are met"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Tier 3 — Full AIA with External Review (4–8 weeks)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For high-risk or prohibited-category use cases, or those subject to EU AI Act Annex III, NYC LL144, or equivalent regulations:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "All Tier 2 content plus:"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Independent external audit of the bias and fairness analysis"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Fundamental rights impact assessment (EU AI Act Art. 27)"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Human rights analysis for jurisdictions with relevant frameworks"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Public disclosure of key findings (where required)"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Regulatory submission or registration"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Board or executive-level sign-off"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Scoping Interview Questions"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Conduct a structured scoping interview with the AI owner and product manager before beginning the AIA. These questions surface the information needed to assign the correct tier:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# aia_scoping_interview.py — generates the scoping questionnaire and scores the tier\n\nfrom dataclasses import dataclass\nfrom typing import Optional\n\nSCOPING_QUESTIONS = [\n    {\n        \"id\": \"Q1\",\n        \"question\": \"Does the Claude output directly inform a decision about a specific person?\",\n        \"high_risk_answer\": \"yes\",\n        \"weight\": 3,\n    },\n    {\n        \"id\": \"Q2\",\n        \"question\": \"Does the decision affect access to credit, employment, housing, healthcare, education, or public benefits?\",\n        \"high_risk_answer\": \"yes\",\n        \"weight\": 4,\n    },\n    {\n        \"id\": \"Q3\",\n        \"question\": \"Is there a human who reviews and can override every Claude output before it affects the person?\",\n        \"high_risk_answer\": \"no\",\n        \"weight\": 3,\n    },\n    {\n        \"id\": \"Q4\",\n        \"question\": \"Does Claude process sensitive attributes (race, health, religion, sexual orientation)?\",\n        \"high_risk_answer\": \"yes\",\n        \"weight\": 3,\n    },\n    {\n        \"id\": \"Q5\",\n        \"question\": \"Can affected individuals correct an error in the decision?\",\n        \"high_risk_answer\": \"no\",\n        \"weight\": 2,\n    },\n    {\n        \"id\": \"Q6\",\n        \"question\": \"Does the system affect more than 1,000 individuals per year?\",\n        \"high_risk_answer\": \"yes\",\n        \"weight\": 2,\n    },\n    {\n        \"id\": \"Q7\",\n        \"question\": \"Is the use case listed in EU AI Act Annex III or Canada's high-impact category?\",\n        \"high_risk_answer\": \"yes\",\n        \"weight\": 5,\n    },\n]\n\ndef score_aia_tier(answers: dict[str, str]) -> dict:\n    \"\"\"\n    answers: {question_id: \"yes\"/\"no\"}\n    Returns the recommended AIA tier and score.\n    \"\"\"\n    score = 0\n    for q in SCOPING_QUESTIONS:\n        if answers.get(q[\"id\"]) == q[\"high_risk_answer\"]:\n            score += q[\"weight\"]\n\n    if score >= 10:\n        tier = \"Tier 3 — Full AIA with External Review\"\n    elif score >= 5:\n        tier = \"Tier 2 — Standard AIA\"\n    elif score >= 2:\n        tier = \"Tier 1 — Lightweight AIA\"\n    else:\n        tier = \"Exempt — Register in AI Inventory Only\"\n\n    return {\"score\": score, \"recommended_tier\": tier, \"answers\": answers}\n\n# Example: customer support draft generator\nanswers = {\n    \"Q1\": \"no\",   # does not inform a decision about a specific person\n    \"Q2\": \"no\",\n    \"Q3\": \"yes\",  # human reviews every draft\n    \"Q4\": \"no\",\n    \"Q5\": \"yes\",\n    \"Q6\": \"yes\",  # reaches many customers\n    \"Q7\": \"no\",\n}\nresult = score_aia_tier(answers)\nprint(f\"Score: {result['score']} → {result['recommended_tier']}\")\n# Score: 2 → Tier 1 — Lightweight AIA\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Defining the Assessment Boundary"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Once the tier is established, define the exact boundary of what the AIA covers. Ambiguous boundaries cause two common failures:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Under-inclusion: the AIA covers only the Claude API call but not the downstream business logic that converts the Claude output into a decision"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Over-inclusion: the AIA tries to cover the entire product, making it so broad that no specific risk receives adequate analysis"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The correct boundary is the decision process: from the moment user or customer data enters the system to the moment a consequential outcome is applied to that person. For a Claude-assisted hiring screener, this includes:"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Resume data ingestion and preprocessing (before Claude sees it)"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Claude's assessment generation (what Claude produces)"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Score normalization or ranking logic applied to Claude's output"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Human recruiter review of the ranked list"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Final hiring decision and candidate notification"
                  }
                ]
              }
