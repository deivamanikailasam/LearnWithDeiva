{
  "format": "tiptap/v1",
  "updatedAt": "2026-06-22T10:48:45.807Z",
  "doc": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Memory access control per agent role"
          },
          {
            "type": "text",
            "text": " is the practice of enforcing "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "role-based access control (RBAC)"
          },
          {
            "type": "text",
            "text": " on shared memory so that each agent can only read from or write to the memory scopes it\u2019s authorized for. Instead of all agents having unrestricted access to a single memory store, you define roles (e.g., "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "support"
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "success"
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "admin"
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "scraper"
          },
          {
            "type": "text",
            "text": ") and map each role to specific permissions ("
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "memories:read"
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "memories:write"
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "memories:delete"
          },
          {
            "type": "text",
            "text": "). This prevents data leakage (e.g., a scraper agent shouldn\u2019t access user-preference memories) and maintains security in production deployments."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "What it is"
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Diagram for Memory access control per agent role",
          "title": null
        }
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Memory access control per agent role defines "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "which agents can access which memories"
          },
          {
            "type": "text",
            "text": ":\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Roles"
          },
          {
            "type": "text",
            "text": ": Named groups of permissions (e.g., "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "support"
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "scraper"
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "admin"
          },
          {
            "type": "text",
            "text": ").\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Permissions"
          },
          {
            "type": "text",
            "text": ": Actions an agent can perform ("
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "read"
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "write"
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "delete"
          },
          {
            "type": "text",
            "text": ").\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Scopes"
          },
          {
            "type": "text",
            "text": ": Memory partitions (e.g., "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "user"
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "project"
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "local"
          },
          {
            "type": "text",
            "text": ").\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Access policies"
          },
          {
            "type": "text",
            "text": ": Rules attached to memories (e.g., \u201cOnly "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "support"
          },
          {
            "type": "text",
            "text": " or "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "success"
          },
          {
            "type": "text",
            "text": " agents can retrieve this\u201d)."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Example RBAC mapping:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "json"
        },
        "content": [
          {
            "type": "text",
            "text": "{\n  \"role\": \"scraper\",\n  \"permissions\": [\"memories:read\"],\n  \"scopes\": [\"memories:public\"],\n  \"access_policy\": \"Only scraper can read public memories\"\n}\n{\n  \"role\": \"support\",\n  \"permissions\": [\"memories:read\", \"memories:write\"],\n  \"scopes\": [\"memories:user\", \"memories:project\"],\n  \"access_policy\": \"Only support or success agents can retrieve this\"\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Why it matters"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Without access control:\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Data leakage"
          },
          {
            "type": "text",
            "text": ": A scraper agent reads user-preference memories (privacy violation).\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Unauthorized writes"
          },
          {
            "type": "text",
            "text": ": An agent modifies critical configuration (e.g., "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "user.preference.output_format"
          },
          {
            "type": "text",
            "text": ").\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Inconsistent behavior"
          },
          {
            "type": "text",
            "text": ": Agents read conflicting data from different scopes.\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "No audit trail"
          },
          {
            "type": "text",
            "text": ": You can\u2019t track who accessed what memory."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "With access control:\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Secure isolation"
          },
          {
            "type": "text",
            "text": ": Agents only access their authorized scopes.\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Prevented leakage"
          },
          {
            "type": "text",
            "text": ": Scrapers can\u2019t access user data; support can.\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Auditability"
          },
          {
            "type": "text",
            "text": ": You can track who wrote/read which memory.\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Compliance"
          },
          {
            "type": "text",
            "text": ": Meets RBAC standards (NIST)."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "This is critical for "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "production agent swarms"
          },
          {
            "type": "text",
            "text": " with 100+ agents, where security and data isolation are mandatory."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Mental model"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Think of memory access control as "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "building access cards"
          },
          {
            "type": "text",
            "text": ":\n- Each agent has a card (role).\n- Each room (memory scope) has a lock (access policy).\n- The card opens only authorized rooms.\n- The scraper card opens the \u201cpublic memories\u201d room; the support card opens \u201cuser memories\u201d and \u201cproject memories.\u201d"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Or think of it as "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "database permissions"
          },
          {
            "type": "text",
            "text": ":\n- Each agent is a database user.\n- Each table (memory scope) has permissions (read/write/delete).\n- The database enforces permissions at the query layer."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "How it works"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "1. Define roles and permissions"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# rbac.py\nROLES = {\n    \"scraper\": [\"memories:read\"],\n    \"support\": [\"memories:read\", \"memories:write\"],\n    \"admin\": [\"memories:read\", \"memories:write\", \"memories:delete\"]\n}\n\nSCOPES = {\n    \"memories:public\": [\"scraper\", \"support\", \"admin\"],\n    \"memories:user\": [\"support\", \"admin\"],\n    \"memories:project\": [\"support\", \"admin\"]\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "2. Assign roles to agents"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# agent_config.py\nagents = {\n    \"agent_scraper_003\": {\"role\": \"scraper\"},\n    \"agent_support_001\": {\"role\": \"support\"},\n    \"agent_admin_001\": {\"role\": \"admin\"}\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "3. Enforce access control at the memory store"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# memory_store_rbac.py\nclass MemoryStoreRBAC:\n    def __init__(self):\n        self.store = {}  # key -> (value, owner_role, access_policy)\n    \n    def write(self, agent_id: str, key: str, value: str, scope: str):\n        agent_role = agents[agent_id][\"role\"]\n        \n        # Check write permission\n        if \"memories:write\" not in ROLES[agent_role]:\n            raise PermissionError(f\"Agent {agent_id} (role={agent_role}) lacks write permission\")\n        \n        # Check scope access\n        if scope not in SCOPES or agent_role not in SCOPES[scope]:\n            raise PermissionError(f\"Agent {agent_id} cannot access scope {scope}\")\n        \n        # Store with access policy\n        self.store[key] = (value, agent_role, f\"Only {scope} agents can retrieve\")\n    \n    def read(self, agent_id: str, key: str, scope: str):\n        agent_role = agents[agent_id][\"role\"]\n        \n        # Check read permission\n        if \"memories:read\" not in ROLES[agent_role]:\n            raise PermissionError(f\"Agent {agent_id} (role={agent_role}) lacks read permission\")\n        \n        # Check scope access\n        if scope not in SCOPES or agent_role not in SCOPES[scope]:\n            raise PermissionError(f\"Agent {agent_id} cannot access scope {scope}\")\n        \n        # Retrieve value\n        if key not in self.store:\n            raise KeyError(f\"Key {key} not found\")\n        \n        value, owner_role, access_policy = self.store[key]\n        return value"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "4. Use memory scopes (Azure Foundry)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Azure Foundry Agent Service uses the "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "scope"
          },
          {
            "type": "text",
            "text": " parameter to partition memory:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# azure_foundry.py\nfrom azure.ai.foundry import AgentService\n\nagent = AgentService(name=\"support_agent\")\n\n# Write to user-scoped memory\nagent.memory.write(\n    key=\"user.preference.output_format\",\n    value=\"json\",\n    scope=\"user\"  # Only this user can access\n)\n\n# Write to project-scoped memory\nagent.memory.write(\n    key=\"project.backend.db\",\n    value=\"postgresql\",\n    scope=\"project\"  # Team can access\n)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "5. Resource-based policy (Bedrock AgentCore)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Amazon Bedrock uses resource-based policies to deny access from unauthorized principals:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "json"
        },
        "content": [
          {
            "type": "text",
            "text": "# bedrock_policy.json\n{\n  \"Sid\": \"DenyNonAgentRuntimeAccess\",\n  \"Effect\": \"Deny\",\n  \"Principal\": \"*\",\n  \"Action\": [\"memory:Get\", \"memory:Put\"],\n  \"Condition\": {\n    \"StringNotEquals\": {\n      \"aws:PrincipalArn\": \"arn:aws:iam::123456789012:role/AgentCoreRuntime\"\n    }\n  }\n}"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "This policy:\n- Denies all principals except "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "AgentCoreRuntime"
          },
          {
            "type": "text",
            "text": ".\n- Prevents developers from accessing memory via API.\n- Allows agents to use memory through Runtime."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "6. Access policy with TTL (Governed AI Memory)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Governed AI Memory stores access policies with each memory:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# governed_memory.py\nclass GovernedMemory:\n    def write(self, agent_id: str, key: str, value: str, ttl_days: int = 90, access_policy: str = None):\n        # Store with access policy and TTL\n        self.store[key] = {\n            \"value\": value,\n            \"owner\": agent_id,\n            \"ttl\": ttl_days,\n            \"access_policy\": access_policy or f\"Only {agent_id} can retrieve\"\n        }\n    \n    def read(self, agent_id: str, key: str):\n        entry = self.store[key]\n        \n        # Check access policy\n        if agent_id not in entry[\"access_policy\"]:\n            raise PermissionError(f\"Agent {agent_id} cannot access this memory\")\n        \n        # Check TTL\n        if entry[\"ttl\"] < 0:\n            raise KeyError(f\"Memory {key} expired\")\n        \n        return entry[\"value\"]"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Implementation patterns"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Pattern 1: RBAC with Agno (Mem0)"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# agno_rbac.py\nfrom agno import Agent\n\nsupport_agent = Agent(\n    role=\"support\",\n    permissions=[\"memories:read\", \"memories:write\"],\n    scopes=[\"memories:user\", \"memories:project\"]\n)\n\nscraper_agent = Agent(\n    role=\"scraper\",\n    permissions=[\"memories:read\"],\n    scopes=[\"memories:public\"]\n)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Pattern 2: Memory scopes with Claude Code"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Claude Code uses three scopes:\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              },
              {
                "type": "code"
              }
            ],
            "text": "user"
          },
          {
            "type": "text",
            "text": ": Cross-project, per-user (not shared, not versioned).\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              },
              {
                "type": "code"
              }
            ],
            "text": "project"
          },
          {
            "type": "text",
            "text": ": Team-shared, versioned.\n- "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              },
              {
                "type": "code"
              }
            ],
            "text": "local"
          },
          {
            "type": "text",
            "text": ": Personal, git-ignored."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# claude_code.py\nfrom claude_code import Subagent\n\n# User-scoped memory (recommended default)\nsubagent = Subagent(\n    name=\"backend_agent\",\n    memory_scope=\"user\"  # Cross-project knowledge\n)\n\n# Project-scoped memory (team-shared)\nsubagent = Subagent(\n    name=\"project_agent\",\n    memory_scope=\"project\"  # Team-shared knowledge\n)\n\n# Local-scoped memory (personal)\nsubagent = Subagent(\n    name=\"local_agent\",\n    memory_scope=\"local\"  # Personal knowledge\n)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Pattern 3: Resource-based policy (Bedrock)"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# bedrock_policy.py\nimport boto3\n\nclient = boto3.client(\"bedrock\")\n\n# Create resource-based policy\npolicy = {\n    \"Sid\": \"DenyNonAgentRuntimeAccess\",\n    \"Effect\": \"Deny\",\n    \"Principal\": \"*\",\n    \"Action\": [\"memory:Get\", \"memory:Put\"],\n    \"Condition\": {\n        \"StringNotEquals\": {\n            \"aws:PrincipalArn\": \"arn:aws:iam::123456789012:role/AgentCoreRuntime\"\n        }\n    }\n}\n\nclient.put_resource_policy(\n    resourceArn=\"arn:aws:bedrock:us-east-1:123456789012:memory/abc123\",\n    policy=json.dumps(policy)\n)"
          }
