      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Best Practices for Prompt Structure"
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Diagram for Structuring Prompts for Caching",
          "title": null
        }
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "To maximize caching benefits, structure your prompts around "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "static vs. dynamic separation"
          },
          {
            "type": "text",
            "text": ":"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "1. Static vs. Dynamic Content Separation"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Key Principle"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "text"
        },
        "content": [
          {
            "type": "text",
            "text": "Static (Cached)                 Dynamic (Not Cached)\n─────────────────────────➤      ────────────────────➤\nSystem instructions             User-specific question\nTool definitions                Variable parameters\nLarge documents (books, APIs)   User-provided context\nConversation history            New input"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Practical Structure"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "messages = [\n    {\n        \"role\": \"system\",\n        \"content\": [\n            {\n                \"type\": \"text\",\n                \"text\": \"You are a helpful Apache Spark expert. Always provide concise, technical answers.\",\n                \"cache_control\": {\"type\": \"ephemeral\"}  # ✅ Static part cached\n            }\n        ]\n    },\n    {\n        \"role\": \"user\",\n        \"content\": \"What are the top 3 benefits of using Apache Spark?\"  # ❌ Dynamic part not cached\n    }\n]"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "2. Chunk Large Documents Strategically"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Before (Bad Structure)"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# All dynamic: entire document + question mixed together\nmessages = [\n    {\n        \"role\": \"user\",\n        \"content\": large_document_text + \"What is the title?\"\n    }\n]"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "After (Good Structure)"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Static part cached, dynamic part separate\nmessages = [\n    {\n        \"role\": \"user\",\n        \"content\": [\n            {\n                \"type\": \"text\",\n                \"text\": large_document_text,  # ✅ Cached (static)\n                \"cache_control\": {\"type\": \"ephemeral\"}\n            },\n            {\n                \"type\": \"text\",\n                \"text\": \"What is the title?\"  # ❌ Not cached (dynamic)\n            }\n        ]\n    }\n]"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Result:"
          },
          {
            "type": "text",
            "text": " Document cached, reused across multiple queries."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
