      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "4. Use Automatic Caching for Multi-Turn"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Single Line Change (Automatic)"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "conversation = [\n    {\"role\": \"user\", \"content\": \"First message\" + large_context},\n    {\"role\": \"assistant\", \"content\": \"Response 1\"},\n    {\"role\": \"user\", \"content\": \"Second message\"},\n    {\"role\": \"assistant\", \"content\": \"Response 2\"},\n]\n\nresponse = client.messages.create(\n    model=\"claude-3-5-sonnet-20241022\",\n    cache_control={\"type\": \"ephemeral\"},  # ✅ Automatic for entire conversation\n    messages=conversation\n)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Result:"
          },
          {
            "type": "text",
            "text": " After first turn, nearly "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "100% of input tokens read from cache"
          },
          {
            "type": "text",
            "text": " on every subsequent turn."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Performance:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "yaml"
        },
        "content": [
          {
            "type": "text",
            "text": "No caching:    4.89s\nCache write:   4.28s\nCache hit:     1.48s\nSpeedup:       3.3x"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "5. Separate Repeated Context from Variable Questions"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Before (Inefficient)"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Re-sending entire context every time\nfor question in questions:\n    messages = [\n        {\n            \"role\": \"user\",\n            \"content\": book_text + question  # Re-sends book every time\n        }\n    ]\n    response = client.messages.create(...)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "After (Efficient)"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Cache book once, send questions separately\nmessages = [\n    {\n        \"role\": \"user\",\n        \"content\": [\n            {\n                \"type\": \"text\",\n                \"text\": book_text,  # ✅ Cached once\n                \"cache_control\": {\"type\": \"ephemeral\"}\n            },\n            {\n                \"type\": \"text\",\n                \"text\": question  # ❌ Variable, not cached\n            }\n        ]\n    }\n]\n\nfor question in questions:\n    response = client.messages.create(model=\"claude-3-5-sonnet-20241022\", messages=messages)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Result:"
          },
          {
            "type": "text",
            "text": " Cache reused across all questions, 90% cost reduction."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "6. Avoid Prompt Structure Mistakes"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "❌ Mistake: Bloated System Prompts"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# 3,000 tokens consumed EVERY turn\nsystem_prompt = \"\"\"\nYou are a helpful assistant.\nDO NOT do the following:\n- Don't be verbose\n- Don't repeat yourself\n- Don't ...\n[2,900 more tokens of \"do not\" lists]\n\"\"\""
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "✅ Fix: Minimal System Prompts"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# 500 tokens, positive instructions only\nsystem_prompt = \"\"\"\nYou are a helpful assistant specializing in literature analysis.\nBe concise and provide direct answers.\n\"\"\""
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "7. Use Multiple Content Blocks (Not Concatenated Strings)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "❌ Bad: Concatenated Strings"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "{\n    \"role\": \"user\",\n    \"content\": system_prompt + large_document + question  # All one block\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "✅ Good: Separate Content Blocks"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "{\n    \"role\": \"user\",\n    \"content\": [\n        {\n            \"type\": \"text\",\n            \"text\": system_prompt,\n            \"cache_control\": {\"type\": \"ephemeral\"}  # Cache block\n        },\n        {\n            \"type\": \"text\",\n            \"text\": large_document,\n            \"cache_control\": {\"type\": \"ephemeral\"}  # Cache block\n        },\n        {\n            \"type\": \"text\",\n            \"text\": question  # Not cached (dynamic)\n        }\n    ]\n}"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Why:"
          },
          {
            "type": "text",
            "text": " Individual blocks can be cached separately; dynamic parts don't invalidate cached blocks."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
