{"format":"tiptap/v1","updatedAt":"2026-06-20T12:15:20.223Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"A "},{"type":"text","marks":[{"type":"bold"}],"text":"system prompt"},{"type":"text","text":" is the foundational instruction set that defines an LLM's "},{"type":"text","marks":[{"type":"bold"}],"text":"role, behavior, tone, constraints, and capabilities"},{"type":"text","text":" for a particular use case. Unlike user prompts (which change with each interaction), the system prompt remains "},{"type":"text","marks":[{"type":"bold"}],"text":"constant"},{"type":"text","text":" and establishes the context within which all user interactions occur."}]},{"type":"paragraph","content":[{"type":"text","text":"Think of it as the AI's "},{"type":"text","marks":[{"type":"bold"}],"text":"\"job description\""},{"type":"text","text":", while user prompts are the specific tasks the user asks within that role."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"What goes into a system prompt?"}]},{"type":"paragraph","content":[{"type":"text","text":"System prompts typically include several key elements:"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Role and Purpose"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What is the AI supposed to do?"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Example: \"You are a customer interview coach who helps product managers improve their interviewing skills.\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"This specifies the "},{"type":"text","marks":[{"type":"bold"}],"text":"persona or perspective"},{"type":"text","text":" the AI should take while generating output."}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Behavioral Guidelines"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tone, constraints, and scenario handling"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"When to ask clarifying questions"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"How to structure responses"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"What topics to avoid"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Example: \"Use friendly but professional English. Never ask for personal information. Always provide 2-3 actionable suggestions.\""}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. Evaluation Criteria"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rubrics or frameworks"},{"type":"text","text":" guiding how the AI assesses inputs and generates outputs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Ensures consistency across interactions"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Example: \"When evaluating code, prioritize: 1) security, 2) correctness, 3) readability, 4) performance.\""}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"4. Context and Domain Knowledge"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Domain-specific information"},{"type":"text","text":" the AI needs to reference"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Often combined with uploaded files, project rules, or knowledge bases"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Example: \"This system is for a SaaS company selling analytics software to mid-market tech companies.\""}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key structural principles"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"A good system prompt is:"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Structured like a technical spec"},{"type":"text","text":" — not a stream-of-consciousness blob. It should have:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hierarchy"},{"type":"text","text":" (sections with clear headings)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prioritization"},{"type":"text","text":" (what matters most)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Logical flow"},{"type":"text","text":" (foundation → details → constraints)"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"The 10-step system prompt structureAnthropic's recommended framework:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Context"},{"type":"text","text":" — background about the task or domain"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tone"},{"type":"text","text":" — how the AI should communicate"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Background"},{"type":"text","text":" — relevant domain knowledge"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Task"},{"type":"text","text":" — clear definition of what to do"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Examples"},{"type":"text","text":" — work samples showing desired behavior"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"History"},{"type":"text","text":" — prior conversation context (if applicable)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Task restatement"},{"type":"text","text":" — reinforcing the goal"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step-by-step reasoning"},{"type":"text","text":" — encouraging thinking"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output format"},{"type":"text","text":" — specifying structure"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"(Optional) Additional constraints"},{"type":"text","text":" — edge cases and rules"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Concrete examples"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 1: Senior developer"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"You are a senior TypeScript engineer working on a SaaS product.\n\nGoals:\n- Write clean, testable, maintainable code.\n- Never hallucinate APIs or libraries not in the codebase.\n- Prioritize security over cleverness.\n\nProcess:\n1. First, explain your understanding of the problem.\n2. Then, propose a plan with 3-5 steps.\n3. Finally, show the code changes in unified diff format.\n\nConstraints:\n- Follow existing patterns in the repo.\n- TypeScript strict mode must pass.\n- Never remove or weaken existing tests."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 2: Contract analyst"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"You are a contract analyst for a mid-size SaaS company.\n\nTask:\nAnalyze customer agreements for risk in liability, indemnity, data privacy, and termination clauses.\n\nOutput format:\n- Bullet points for each clause found\n- For each: (a) quote, (b) plain-language summary, (c) risk score 1–5, (d) recommendation\n\nConstraints:\n- If something is ambiguous, explicitly say so.\n- Do not provide legal advice; flag items for human review."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 3: Prompt rewriter (project-level)"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"You are an expert prompt engineer specializing in improving Claude prompts.\n\nRules:\n- Always ask clarifying questions before rewriting.\n- Keep rewritten prompts concise but explicit.\n- Output the final prompt in a markdown block.\n- Do not execute the prompt; just optimize it."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"System prompt vs. user prompt"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":"left"},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":"left"},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"System Prompt"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":"left"},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"User Prompt"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Stability"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Constant across all interactions"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Changes with each interaction"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Purpose"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Defines role, behavior, constraints, capabilities"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Specific task or question"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Location"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Top-level "},{"type":"text","marks":[{"type":"code"}],"text":"system"},{"type":"text","text":" field in API"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Last "},{"type":"text","marks":[{"type":"code"}],"text":"user"},{"type":"text","text":" message in "},{"type":"text","marks":[{"type":"code"}],"text":"messages"},{"type":"text","text":" array"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Think of it as"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"Job description\""}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"Task within that role\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"You are a senior engineer\""}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"Refactor this function\""}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why system prompts matter"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"For Claude specifically"}]},{"type":"paragraph","content":[{"type":"text","text":"Anthropic emphasizes that "},{"type":"text","marks":[{"type":"bold"}],"text":"role prompting is the most powerful way to use system prompts"},{"type":"text","text":" with Claude:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Assign the chatbot a specific role, like 'news editor' or 'financial planner.' This technique can significantly boost Claude's performance in complex scenarios like legal analysis or financial modeling.\""}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"In production systems"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"System prompts are the primary way to configure how an AI assistant behaves and responds."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"They enable "},{"type":"text","marks":[{"type":"bold"}],"text":"consistent, steerable agents"},{"type":"text","text":" across many conversations."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"They reduce the need to repeat the same instructions in every user prompt."}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Common patterns"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Contract-style system prompts"}]},{"type":"paragraph","content":[{"type":"text","text":"Treat the system prompt like a "},{"type":"text","marks":[{"type":"bold"}],"text":"contract"},{"type":"text","text":" with clear obligations:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Define responsibilities"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Specify constraints"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"List evaluation criteria"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Output schemas"}]},{"type":"paragraph","content":[{"type":"text","text":"Force structured outputs:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Respond in this exact JSON format:\n{\n  \"category\": \"<one_of: Billing | Bug | Feature | Other>\",\n  \"reason\": \"<short explanation>\",\n  \"confidence\": \"<high | medium | low>\"\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Few-shot examples"}]},{"type":"paragraph","content":[{"type":"text","text":"Include work samples:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Here are examples of good responses:\n\n<example>\nUser: \"I was double charged.\"\nAssistant: \"Category: Billing. Reason: The email is about incorrect charging.\"\n</example>"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"4. Step-by-step reasoning"}]},{"type":"paragraph","content":[{"type":"text","text":"Encourage thinking:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Before giving your final answer:\n1. Think through the problem step by step.\n2. Identify potential edge cases.\n3. Verify your answer against the constraints."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Implementation in different contexts"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"In Claude Console (Workbench)"}]},{"type":"paragraph","content":[{"type":"text","text":"The system prompt goes in the "},{"type":"text","marks":[{"type":"code"}],"text":"system"},{"type":"text","marks":[{"type":"bold"}],"text":" field"},{"type":"text","text":" when you create a prompt test. You can also add it to the "},{"type":"text","marks":[{"type":"bold"}],"text":"project instructions"},{"type":"text","text":" for persistent context."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"In Claude API"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"model\": \"claude-sonnet-4-20250514\",\n  \"max_tokens\": 1024,\n  \"system\": \"You are a senior TypeScript engineer. Write clean, testable code.\",\n  \"messages\": [\n    {\"role\": \"user\", \"content\": \"Refactor this function.\"}\n  ]\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"In "},{"type":"text","marks":[{"type":"link","attrs":{"href":"http://Claude.ai","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}},{"type":"bold"}],"text":"Claude.ai"},{"type":"text","marks":[{"type":"bold"}],"text":" Projects"}]},{"type":"paragraph","content":[{"type":"text","text":"Inside a project, you can set "},{"type":"text","marks":[{"type":"bold"}],"text":"project-level instructions"},{"type":"text","text":" that act like a system prompt for all conversations in that project."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best practices"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Start simple"},{"type":"text","text":" — don't overcomplicate the first version."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Be explicit"},{"type":"text","text":" — Claude doesn't have context on your norms unless you tell it."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use examples"},{"type":"text","text":" — few-shot examples dramatically improve accuracy and consistency."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Structure with sections"},{"type":"text","text":" — use headings, lists, and tags like "},{"type":"text","marks":[{"type":"code"}],"text":"<rules>"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"<examples>"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"<context>"},{"type":"text","text":"."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Test and iterate"},{"type":"text","text":" — treat system prompts as hypotheses; measure performance on real test cases and refine."}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Summary"}]},{"type":"paragraph","content":[{"type":"text","text":"A "},{"type":"text","marks":[{"type":"bold"}],"text":"system prompt"},{"type":"text","text":" is your AI assistant's foundational job description. It defines:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Role"},{"type":"text","text":" (who it is)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Purpose"},{"type":"text","text":" (what it does)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Behavior"},{"type":"text","text":" (how it acts)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Constraints"},{"type":"text","text":" (what it must/must not do)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Format"},{"type":"text","text":" (how it presents output)"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"It stays "},{"type":"text","marks":[{"type":"bold"}],"text":"constant across all interactions"},{"type":"text","text":", while user prompts change with each task. Structured system prompts are the most powerful way to steer Claude toward reliable, consistent, expert-level behavior."}]}]}}
