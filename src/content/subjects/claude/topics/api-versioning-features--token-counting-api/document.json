\"role\": \"user\", \"content\": \"Your prompt text\"}]\n)\n\n# Compare\nprint(f\"Current model: {current_count.input_tokens} tokens\")\nprint(f\"New tokenizer: {new_count.input_tokens} tokens\")\nprint(f\"Difference: {new_count.input_tokens - current_count.input_tokens} tokens\")\nprint(f\"Percentage: {(new_count.input_tokens / current_count.input_tokens) * 100:.1f}%\")"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Production Recommendation"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Count prompts with the newest tokenizer model"},{"type":"text","text":" to get accurate estimates:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Production: Count with newer tokenizer\ncount = client.messages.count_tokens(\n    model=\"claude-fable-5\",  # Or \"claude-mythos-5\"\n    messages=[{\"role\": \"user\", \"content\": \"Your prompt\"}]\n)\n\n# Use this count for budgeting and context window checks"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Supported Models"}]},{"type":"paragraph","content":[{"type":"text","text":"All active Claude models support token counting:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Model Family"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Models"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Opus 4.x"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"claude-opus-4-8"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"claude-opus-4-7"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"claude-opus-4-6"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"claude-opus-4-5"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"claude-opus-4-1"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sonnet 4.x"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"claude-sonnet-4-6"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"claude-sonnet-4-5"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"claude-sonnet-4"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Haiku"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"claude-haiku-4-5"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"claude-3-5-haiku"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fable/Mythos"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"claude-fable-5"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"claude-mythos-5"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"[platform.claude](https://platform.claude.com/docs/en/build-with-claude/token-counting)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Note:"},{"type":"text","text":" All models in the above list support token counting with the same API."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Use Cases for Token Counting"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Manage Costs and Budgeting"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\n# Count tokens before sending\ncount = client.messages.count_tokens(\n    model=\"claude-sonnet-4-6\",\n    messages=[{\"role\": \"user\", \"content\": \"Long document...\"}]\n)\n\n# Estimate cost (Sonnet 4.6: $3/MTok input, $15/MTok output)\ninput_cost = count.input_tokens * 3 / 1_000_000\noutput_cost_estimated = 100 * 15 / 1_000_000  # Assume 100 output tokens\n\ntotal_cost = input_cost + output_cost_estimated\nprint(f\"Estimated cost: ${total_cost:.4f}\")"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Stay Within Model Context Window"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\n# Check if prompt fits within context window\ncount = client.messages.count_tokens(\n    model=\"claude-sonnet-4-6\",\n    messages=[{\"role\": \"user\", \"content\": \"Long document...\"}]\n)\n\n# Sonnet 4.6 has 200K context window\ncontext_limit = 200_000\n\nif count.input_tokens > context_limit:\n    print(f\"Warning: Prompt ({count.input_tokens} tokens) exceeds context limit ({context_limit})\")\n    # Truncate or split prompt\nelse:\n    print(f\"Prompt fits: {count.input_tokens}/{context_limit} tokens ({count.input_tokens/context_limit*100:.1f}% used)\")"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Make Model Routing Decisions"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\ndef choose_model(prompt):\n    # Count tokens\n    count = client.messages.count_tokens(\n        model=\"claude-sonnet-4-6\",\n        messages=[{\"role\": \"user\", \"content\": prompt}]\n    )\n    \n    # Route based on token count\n    if count.input_tokens > 100_000:\n        # Use Haiku for large documents (cheaper, faster)\n        return \"claude-haiku-4-5\"\n    elif count.input_tokens > 50_000:\n        # Use Sonnet for medium prompts\n        return \"claude-sonnet-4-6\"\n    else:\n        # Use Opus for complex reasoning\n        return \"claude-opus-4-8\"\n\n# Usage\nmodel = choose_model(\"Your prompt...\")\nresponse = client.messages.create(model=model, max_tokens=1024, messages=[{\"role\": \"user\", \"content\": \"Your prompt...\"}])"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Fit Prompts Within Rate Limits"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\n# Check token count before sending\ncount = client.messages.count_tokens(\n    model=\"claude-sonnet-4-6\",\n    messages=[{\"role\": \"user\", \"content\": \"Long prompt...\"}]\n)\n\n# Sonnet 4.6 ITPM limit: 40,000 tokens/min\nitpm_limit = 40_000\n\n# Buffer to 80% to avoid hitting limits\nsafe_limit = itpm_limit * 0.8\n\nif count.input_tokens > safe_limit:\n    print(f\"Warning: Single prompt ({count.input_tokens} tokens) exceeds 80% of ITPM limit ({safe_limit})\")\n    # Split into multiple requests or reduce content\nelse:\n    print(f\"Safe to send: {count.input_tokens}/{safe_limit} tokens ({count.input_tokens/safe_limit*100:.1f}% of limit)\")"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. Optimize Prompt Caching"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\n# Count tokens with and without caching\ncount_no_cache = client.messages.count_tokens(\n    model=\"claude-sonnet-4-6\",\n    messages=[{\"role\": \"user\", \"content\": \"Long document...\"}]\n)\n\ncount_with_cache = client.messages.count_tokens(\n    model=\"claude-sonnet-4-6\",\n    messages=[\n        {\n            \"role\": \"user\",\n            \"content\": [\n                {\n                    \"type\": \"text\",\n                    \"text\": \"Long document...\",\n                    \"cache_control\": {\"type\": \"ephemeral\"}  # Cache this\n                }\n            ]\n        }\n    ]\n)\n\n# Compare\nprint(f\"No cache: {count_no_cache.input_tokens} tokens\")\nprint(f\"With cache: {count_with_cache.input_tokens} tokens\")\nprint(f\"Saved: {count_no_cache.input_tokens - count_with_cache.input_tokens} tokens\")"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Token Counting vs. Actual Billing"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Token Counting is an Estimate"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Count tokens before sending\ncount_before = client.messages.count_tokens(\n    model=\"claude-sonnet-4-6\",\n    messages=[{\"role\": \"user\", \"content\": \"Hello\"}]\n)\n\n# Send actual message\nresponse = client.messages.create(\n    model=\"claude-sonnet-4-6\",\n    max_tokens=1024,\n    messages=[{\"role\": \"user\", \"content\": \"Hello\"}]\n)\n\n# Compare\nprint(f\"Count before: {count_before.input_tokens} tokens\")  # Estimate\nprint(f\"Actual billing: {response.usage.input_tokens} tokens\")  # Actual"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why They Differ"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Factor"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Impact"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"System optimizations"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Anthropic may add tokens for optimizations (included in count but "},{"type":"text","marks":[{"type":"bold"}],"text":"not billed"},{"type":"text","text":")"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tokenizer version"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Different tokenizer versions may produce slightly different counts"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Caching behavior"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Cache breakpoints may affect actual token usage vs. estimate"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Streaming overhead"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Streaming may add small overhead not reflected in count"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rule:"},{"type":"text","text":" Token counts are "},{"type":"text","marks":[{"type":"bold"}],"text":"estimates"},{"type":"text","text":" for planning and budgeting. Actual billing reflects only your content (not system-added tokens)."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Token Counting on Other Platforms"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Amazon Bedrock"}]},{"type":"paragraph","content":[{"type":"text","text":"The Count Tokens API is available in Amazon Bedrock:"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"curl -X POST \\\n  -H \"Authorization: Bearer $(gcloud auth print-access-token)\" \\\n  -H \"Content-Type: application/json; charset=utf-8\" \\\n  -d @request.json \\\n  \"https://LOCATION-aiplatform.googleapis.com/v1/projects/PROJECT_ID/locations/LOCATION/publishers/anthropic/models/count-tokens:rawPredict\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Request body:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"model\": \"claude-sonnet-4-6\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"how many tokens are in this request?\"\n    }\n  ]\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Quota:"},{"type":"text","text":" 2,000 requests per minute by default (on AWS)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Google Cloud Vertex AI"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"POST https://LOCATION-aiplatform.googleapis.com/v1/projects/PROJECT_ID/locations/LOCATION/publishers/anthropic/models/count-tokens:rawPredict"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Supported models:"},{"type":"text","text":"\n- Claude Fable 5\n- Claude Opus 4.8, 4.7, 4.6, 4.5, 4.1\n- Claude Sonnet 4.6, 4.5, 4\n- Claude Haiku 4.5, 3.5 Haiku"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Always Count Before Sending"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Check token count before API call\ncount = client.messages.count_tokens(model=\"...\")"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits:"},{"type":"text","text":"\n- Avoid unexpected costs\n- Prevent context window overflows\n- Stay within rate limits"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Use Newest Tokenizer for Accuracy"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Count with newer tokenizer (Fable/Mythos 5)\ncount = client.messages.count_tokens(\n    model=\"claude-fable-5\"  # Or \"claude-mythos-5\"\n    ...\n)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Buffer to 80% of Limits"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Buffer to 80% of ITPM limit\nsafe_limit = itpm_limit * 0.8"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Track Token Usage Over Time"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\nfrom datetime import datetime\n\nclient = anthropic.Anthropic()\n\n# Log token counts\ntoken_log = []\n\ndef log_and_send(prompt):\n    count = client.messages.count_tokens(\n        model=\"claude-sonnet-4-6\",\n        messages=[{\"role\": \"user\", \"content\": prompt}]\n    )\n    \n    token_log.append({\n        \"timestamp\": datetime.now().isoformat(),\n        \"prompt_length\": len(prompt),\n        \"token_count\": count.input_tokens\n    })\n    \n    return client.messages.create(...)\n\n# Analyze usage\nfor entry in token_log:\n    print(f\"{entry['timestamp']}: {entry['token_count']} tokens ({entry['prompt_length']} chars)\")"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. Monitor Token Counting Limits"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Check if you're hitting token counting rate limits\nimport anthropic\n\nclient = anthropic.Anthropic()\n\ntry:\n    count = client.messages.count_tokens(...)\nexcept anthropic.RateLimitError:\n    print(\"Token counting rate limit exceeded. Wait 60s or contact sales for upgrade.\")"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"External Resources"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Official Documentation"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Token counting - Claude API Docs"},{"type":"text","text":": Complete token counting reference with usage, rate limits, and model tokenizer differences"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Count tokens in a Message - Claude API Reference"},{"type":"text","text":": API endpoint documentation for "},{"type":"text","marks":[{"type":"code"}],"text":"/v1/messages/count_tokens"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pricing - Claude API Docs"},{"type":"text","text":": Per-model pricing to calculate costs from token counts"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Platform Integrations"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Count tokens for Claude models (Google Cloud)"},{"type":"text","text":": Vertex AI integration for token counting"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Count Tokens API (Amazon Bedrock)"},{"type":"text","text":": Bedrock integration for token counting prior to inference"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Community Resources"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Counting Claude Tokens Without a Tokenizer (gopenai)"},{"type":"text","text":": How to get accurate token counts after the fact from API responses"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude Counter (GitHub)"},{"type":"text","text":": Browser extension showing token count, cache timer, and usage bars on claude.ai"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best way to count tokens (Stack Overflow)"},{"type":"text","text":": Discussion about counting Anthropic tokens (closed)"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Summary"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Count tokens before sending"},{"type":"text","text":" to manage costs, rate limits, and context windows"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"client.messages.count_tokens()"},{"type":"text","text":" in Python SDK (or raw HTTP to "},{"type":"text","marks":[{"type":"code"}],"text":"/v1/messages/count_tokens"},{"type":"text","text":")"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Accepts same inputs as messages.create()"},{"type":"text","text":": system prompts, tools, images, PDFs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Returns "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"input_tokens"},{"type":"text","text":": Estimate of input tokens (may differ slightly from actual billing)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"System-added tokens NOT billed"},{"type":"text","text":": Count includes optimizations but only your content is billed"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Free to use"},{"type":"text","text":": No cost for token counting, but separate rate limits"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rate limits by tier"},{"type":"text","text":": 100/2,000/4,000/8,000 RPM for Tiers 1-4"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Model-specific tokenizer"},{"type":"text","text":": Count uses tokenizer of model you pass (Fable/Mythos 5 = ~30% more tokens)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Count with newest tokenizer"},{"type":"text","text":": Use "},{"type":"text","marks":[{"type":"code"}],"text":"claude-fable-5"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"code"}],"text":"claude-mythos-5"},{"type":"text","text":" for accurate estimates"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Separate limits"},{"type":"text","text":": Token counting has independent rate limits from message creation"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Production Checklist"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\n# ✅ Production-ready token counting\ndef safe_send_prompt(prompt):\n    # 1. Count tokens first\n    count = client.messages.count_tokens(\n        model=\"claude-fable-5\",  # Newest tokenizer\n        messages=[{\"role\": \"user\", \"content\": prompt}]\n    )\n    \n    # 2. Check context window (200K for Sonnet 4.6)\n    if count.input_tokens > 160_000:  # 80% of 200K buffer\n        raise ValueError(\"Prompt too long\")\n    \n    # 3. Check ITPM (40,000 for Sonnet 4.6)\n    if count.input_tokens > 32_000:  # 80% of 40K buffer\n        raise ValueError(\"Prompt exceeds 80% of ITPM limit\")\n    \n    # 4. Send if safe\n    return client.messages.create(\n        model=\"claude-sonnet-4-6\",\n        max_tokens=1024,\n        messages=[{\"role\": \"user\", \"content\": prompt}]\n    )"}]},{"type":"paragraph","content":[{"type":"text","text":"Token counting is essential for "},{"type":"text","marks":[{"type":"bold"}],"text":"production reliability"},{"type":"text","text":" with the Claude API. By counting tokens before sending prompts, you avoid unexpected costs, stay within rate limits, and ensure prompts fit within context windows. Use the newest tokenizer models for accurate estimates, and always buffer to 80% of limits for safety."}]}]}}
