        "content": [
          {
            "type": "text",
            "text": "# governance_gate.py — run as a CI/CD step before production deployment\n\nimport json, sys\nfrom datetime import datetime, timezone\nfrom pathlib import Path\n\nREVIEW_REGISTER = Path(\"config/governance_reviews.json\")\n\ndef check_governance_gate(app_id: str) -> bool:\n    \"\"\"\n    Returns True (gate passes) only if all scheduled reviews for this app are current.\n    Exits with code 1 (blocking the pipeline) if any review is overdue.\n    \"\"\"\n    reviews = json.loads(REVIEW_REGISTER.read_text())\n    app_reviews = reviews.get(app_id, {})\n    now = datetime.now(timezone.utc).isoformat()\n    overdue = []\n\n    for review_type, meta in app_reviews.items():\n        due = meta.get(\"next_review_due\", \"\")\n        if due and due < now:\n            overdue.append(f\"{review_type} (due {due[:10]})\")\n\n    if overdue:\n        print(f\"GOVERNANCE GATE FAILED for {app_id}:\")\n        for item in overdue:\n            print(f\"  - Overdue: {item}\")\n        print(\"Complete all overdue governance reviews before deploying.\")\n        sys.exit(1)\n\n    print(f\"Governance gate passed for {app_id}: all reviews current.\")\n    return True\n\nif __name__ == \"__main__\":\n    app_id = sys.argv[1] if len(sys.argv) > 1 else \"unknown\"\n    check_governance_gate(app_id)\n"
          }
        ]
