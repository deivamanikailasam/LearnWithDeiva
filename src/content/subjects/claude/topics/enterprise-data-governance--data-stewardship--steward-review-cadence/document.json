          {
            "type": "text",
            "text": "import smtplib\nfrom email.message import EmailMessage\n\nSTEWARD_CONTACTS = {\n    \"legal\": \"legal-steward@company.com\",\n    \"hr\": \"hr-steward@company.com\",\n    \"finance\": \"finance-steward@company.com\",\n}\n\nAI_GOV_LEAD = \"ai-governance@company.com\"\nDPO = \"dpo@company.com\"\nCDO = \"cdo@company.com\"\n\ndef notify_exception(exc: GovernanceException, domain: str):\n    msg = EmailMessage()\n    msg[\"Subject\"] = f\"[{exc.severity}] Claude Governance Exception: {exc.category} — {exc.app_id}\"\n    msg[\"From\"] = \"governance-bot@company.com\"\n\n    recipients = [STEWARD_CONTACTS.get(domain, AI_GOV_LEAD), AI_GOV_LEAD]\n    if exc.severity == \"P1\":\n        recipients += [DPO, CDO]\n\n    msg[\"To\"] = \", \".join(recipients)\n    msg.set_content(\n        f\"Exception ID: {exc.exception_id}\\n\"\n        f\"Severity: {exc.severity}\\n\"\n        f\"Category: {exc.category}\\n\"\n        f\"Application: {exc.app_id}\\n\"\n        f\"Source: {exc.source_id or 'N/A'}\\n\"\n        f\"Description: {exc.description}\\n\"\n        f\"Detected by: {exc.detected_by}\\n\"\n        f\"Detected at: {exc.detected_at}\\n\\n\"\n        f\"Required action: See governance runbook for {exc.severity} response procedure.\"\n    )\n    with smtplib.SMTP(\"smtp.company.com\") as smtp:\n        smtp.send_message(msg)\n"
          }
