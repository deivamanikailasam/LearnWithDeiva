          {
            "type": "text",
            "text": "import json, uuid\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom dataclasses import dataclass, asdict\nfrom typing import Optional\n\nEXCEPTION_LOG = Path(\"logs/governance_exceptions.jsonl\")\n\n@dataclass\nclass GovernanceException:\n    exception_id: str\n    detected_at: str\n    severity: str             # \"P1\" | \"P2\" | \"P3\"\n    category: str             # \"acl_violation\" | \"source_retraction\" | \"classification_change\" | etc.\n    app_id: str\n    source_id: Optional[str]\n    description: str\n    detected_by: str\n    status: str = \"open\"      # \"open\" | \"in_progress\" | \"resolved\"\n    resolution: Optional[str] = None\n    resolved_at: Optional[str] = None\n    resolved_by: Optional[str] = None\n\ndef log_exception(\n    severity: str,\n    category: str,\n    app_id: str,\n    description: str,\n    detected_by: str,\n    source_id: str | None = None,\n) -> GovernanceException:\n    exc = GovernanceException(\n        exception_id=str(uuid.uuid4())[:12],\n        detected_at=datetime.now(timezone.utc).isoformat(),\n        severity=severity,\n        category=category,\n        app_id=app_id,\n        source_id=source_id,\n        description=description,\n        detected_by=detected_by,\n    )\n    with EXCEPTION_LOG.open(\"a\") as f:\n        f.write(json.dumps(asdict(exc)) + \"\\n\")\n    return exc\n\ndef resolve_exception(exception_id: str, resolution: str, resolved_by: str):\n    exceptions = [json.loads(l) for l in EXCEPTION_LOG.read_text().splitlines() if l]\n    updated = []\n    for e in exceptions:\n        if e[\"exception_id\"] == exception_id:\n            e[\"status\"] = \"resolved\"\n            e[\"resolution\"] = resolution\n            e[\"resolved_at\"] = datetime.now(timezone.utc).isoformat()\n            e[\"resolved_by\"] = resolved_by\n        updated.append(e)\n    EXCEPTION_LOG.write_text(\"\\n\".join(json.dumps(e) for e in updated) + \"\\n\")\n"
          }
        ]
