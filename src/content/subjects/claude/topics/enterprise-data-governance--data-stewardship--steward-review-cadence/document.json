            "type": "text",
            "text": "# quarterly-review-checklist.yaml — completed by domain steward each quarter\n\ndomain: \"Legal\"\nsteward: \"Maria Chen\"\nquarter: \"Q2-2025\"\nreview_date: \"2025-07-01\"\n\nsources_reviewed:\n  - source_id: \"legal-policy-docs\"\n    documents_current: true\n    acl_still_accurate: true\n    action: \"none\"\n\n  - source_id: \"compliance-runbooks-2024\"\n    documents_current: false\n    notes: \"2025 runbooks published — need to re-ingest updated versions\"\n    action: \"re-ingest\"\n    action_owner: \"Tech Steward (Dev Team)\"\n    action_due: \"2025-07-15\"\n\nnew_sources_requested: []          # none this quarter\nsources_to_retire: []\n\nattestation:\n  statement: >\n    I have reviewed all data sources in the Legal domain approved for Claude\n    and confirm the register is accurate as of the review date.\n  steward_signature: \"Maria Chen\"\n  date: \"2025-07-01\"\n"
          }
