              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Full " }, { "type": "text", "marks": [{ "type": "code" }], "text": "Message" }, { "type": "text", "text": " object with usage stats" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Extract " }, { "type": "text", "marks": [{ "type": "code" }], "text": "result.message.content[0].text" }] }] }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "code" }], "text": "errored" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Error with " }, { "type": "text", "marks": [{ "type": "code" }], "text": "type" }, { "type": "text", "text": " and " }, { "type": "text", "marks": [{ "type": "code" }], "text": "message" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Log and optionally resubmit in a new batch" }] }] }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "code" }], "text": "canceled" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "No payload" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Resubmit if the batch was canceled unintentionally" }] }] }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "code" }], "text": "expired" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "No payload" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Resubmit; consider splitting into smaller batches" }] }] }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Building a Complete Pipeline" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A production batch pipeline typically reads from a data source, chunks into batches of up to 10,000, persists the batch IDs for durability, and retries failed items in a follow-up batch:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "python" },
        "content": [
          {
            "type": "text",
            "text": "import json\nimport time\nfrom pathlib import Path\nimport anthropic\n\nclient = anthropic.Anthropic()\n\ndef build_request(doc_id: str, text: str) -> dict:\n    return {\n        \"custom_id\": doc_id,\n        \"params\": {\n            \"model\": \"claude-haiku-4-5\",\n            \"max_tokens\": 128,\n            \"messages\": [{\n                \"role\": \"user\",\n                \"content\": f\"Extract 3 key topics from this text as a JSON list:\\n\\n{text[:2000]}\",\n            }],\n        },\n    }\n\ndef run_batch_pipeline(\n    documents: dict[str, str],  # {doc_id: text}\n    state_file: Path = Path(\"batch_state.json\"),\n    chunk_size: int = 10_000,\n) -> dict[str, str]:  # {doc_id: result_text}\n    results: dict[str, str] = {}\n    failed: list[str] = []\n\n    doc_items = list(documents.items())\n    chunks = [\n        doc_items[i:i + chunk_size]\n        for i in range(0, len(doc_items), chunk_size)\n    ]\n\n    batch_ids: list[str] = []\n    for chunk in chunks:\n        requests = [build_request(doc_id, text) for doc_id, text in chunk]\n        batch = client.messages.batches.create(requests=requests)\n        batch_ids.append(batch.id)\n        print(f\"Submitted batch {batch.id} ({len(requests)} requests)\")\n\n    # Persist batch IDs so the pipeline survives a restart\n    state_file.write_text(json.dumps(batch_ids))\n\n    # Wait for all batches\n    for batch_id in batch_ids:\n        while True:\n            b = client.messages.batches.retrieve(batch_id)\n            if b.processing_status == \"ended\":\n                break\n            time.sleep(60)\n\n        for result in client.messages.batches.results(batch_id):\n            if result.result.type == \"succeeded\":\n                results[result.custom_id] = result.result.message.content[0].text\n            else:\n                failed.append(result.custom_id)\n\n    # Retry failed items once\n    if failed:\n        print(f\"Retrying {len(failed)} failed items\")\n        retry_requests = [\n            build_request(doc_id, documents[doc_id])\n            for doc_id in failed\n        ]\n        retry_batch = client.messages.batches.create(requests=retry_requests)\n        while True:\n            b = client.messages.batches.retrieve(retry_batch.id)\n            if b.processing_status == \"ended\":\n                break\n            time.sleep(60)\n        for result in client.messages.batches.results(retry_batch.id):\n            if result.result.type == \"succeeded\":\n                results[result.custom_id] = result.result.message.content[0].text\n\n    return results"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Canceling a Batch" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "If you submit a batch by mistake or want to cut costs on a long-running job, cancel it before it ends:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "python" },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\n\nclient = anthropic.Anthropic()\n\n# Cancel — requests already completed will not be affected\nbatch = client.messages.batches.cancel(\"msgbatch_01XFDUDYJgAACzvnptvVoYEL\")\nprint(batch.processing_status)  # \"canceling\" or \"ended\"\n\n# The batch moves to \"ended\" once in-flight requests finish\n# Results for completed requests are still available\nfor result in client.messages.batches.results(batch.id):\n    if result.result.type == \"succeeded\":\n        print(f\"{result.custom_id}: {result.result.message.content[0].text[:60]}\")"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Listing and Managing Batches" }]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "python" },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\n\nclient = anthropic.Anthropic()\n\n# List recent batches (most recent first, auto-paginated)\nfor batch in client.messages.batches.list(limit=10):\n    counts = batch.request_counts\n    print(\n        f\"{batch.id[:24]}  \"\n        f\"[{batch.processing_status:12}]  \"\n        f\"ok={counts.succeeded}  err={counts.errored}  \"\n        f\"created={batch.created_at.isoformat()}\"\n    )\n\n# Delete a batch to free storage (results no longer retrievable)\nclient.messages.batches.delete(\"msgbatch_01XFDUDYJgAACzvnptvVoYEL\")"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Cost and Token Accounting" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Each "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "succeeded" },
          { "type": "text", "text": " result includes a " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "usage" },
          { "type": "text", "text": " object with " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "input_tokens" },
          { "type": "text", "text": " and " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "output_tokens" },
          { "type": "text", "text": ". Aggregate these to reconcile costs:" }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "python" },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\n\nclient = anthropic.Anthropic()\n\n# Haiku pricing at batch rate (50% discount) — verify current rates in Console\n# Example: $0.125 / M input tokens, $0.625 / M output tokens for Haiku batch\nINPUT_COST_PER_M  = 0.125\nOUTPUT_COST_PER_M = 0.625\n\ntotal_input = 0\ntotal_output = 0\n\nfor result in client.messages.batches.results(\"msgbatch_01XFDUDYJgAACzvnptvVoYEL\"):\n    if result.result.type == \"succeeded\":\n        usage = result.result.message.usage\n        total_input  += usage.input_tokens\n        total_output += usage.output_tokens\n\ncost = (\n    total_input  / 1_000_000 * INPUT_COST_PER_M +\n    total_output / 1_000_000 * OUTPUT_COST_PER_M\n)\nprint(f\"Input tokens:  {total_input:,}\")\nprint(f\"Output tokens: {total_output:,}\")\nprint(f\"Estimated cost: ${cost:.4f}\")"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Combining Batches with Prompt Caching" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Prompt caching works inside batch requests. If all 10,000 requests share the same system prompt, mark it with "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "cache_control" },
          { "type": "text", "text": " to reduce input token cost further. The cache TTL applies per-request just as it does in real-time calls:" }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "python" },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\n\nclient = anthropic.Anthropic()\n\nSYSTEM_PROMPT = \"\"\"You are a data extraction assistant. Extract structured fields from\nthe provided document in JSON format. Include: title, date, author, summary, and keywords.\"\"\"\n\n# Mark the shared system prompt for caching across all batch requests\ndef build_cached_request(doc_id: str, document_text: str) -> dict:\n    return {\n        \"custom_id\": doc_id,\n        \"params\": {\n            \"model\": \"claude-haiku-4-5\",\n            \"max_tokens\": 512,\n            \"system\": [\n                {\n                    \"type\": \"text\",\n                    \"text\": SYSTEM_PROMPT,\n                    \"cache_control\": {\"type\": \"ephemeral\"},  # cached across requests\n                }\n            ],\n            \"messages\": [{\n                \"role\": \"user\",\n                \"content\": document_text,\n            }],\n        },\n    }\n\ndocuments = {\n    f\"doc-{i}\": f\"Document content {i}...\" for i in range(5000)\n}\n\nrequests = [\n    build_cached_request(doc_id, text)\n    for doc_id, text in documents.items()\n]\n\nbatch = client.messages.batches.create(requests=requests)\nprint(f\"Submitted {len(requests)} cached batch requests: {batch.id}\")"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Operational Considerations" }]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "bold" }], "text": "29-day result retention." },
                  { "type": "text", "text": " Results are available for 29 days after the batch ends. Delete them manually if you want to reclaim storage sooner, but download first." }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "bold" }], "text": "24-hour processing limit." },
                  { "type": "text", "text": " Any requests not completed within 24 hours are marked " },
                  { "type": "text", "marks": [{ "type": "code" }], "text": "expired" },
                  { "type": "text", "text": ". Split very large batches if you observe consistent expirations." }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "bold" }], "text": "Batches do not count against RPM." },
                  { "type": "text", "text": " The batch API uses a separate capacity pool. Submitting a 10,000-request batch does not consume your synchronous RPM allowance." }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "bold" }], "text": "Partial success is normal." },
                  { "type": "text", "text": " A batch can end with some requests errored. Always inspect " },
                  { "type": "text", "marks": [{ "type": "code" }], "text": "request_counts.errored" },
                  { "type": "text", "text": " and resubmit errored items if needed." }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "bold" }], "text": "custom_id ordering is not preserved." },
                  { "type": "text", "text": " Results come back in an arbitrary order. Always use " },
                  { "type": "text", "marks": [{ "type": "code" }], "text": "custom_id" },
                  { "type": "text", "text": " to match results to inputs, never by position." }
                ]
              }
            ]
          }
        ]
      },
      {
