      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Submitting a Batch" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Each batch is a list of "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "Request" },
          { "type": "text", "text": " objects. Each request has a " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "custom_id" },
          { "type": "text", "text": " you choose and a " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "params" },
          { "type": "text", "text": " dict identical to a synchronous " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "messages.create" },
          { "type": "text", "text": " call:" }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "python" },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\n\nclient = anthropic.Anthropic()\n\n# Build the list of requests — up to 10,000 per batch\nrequests = [\n    {\n        \"custom_id\": f\"doc-{i}\",\n        \"params\": {\n            \"model\": \"claude-haiku-4-5\",\n            \"max_tokens\": 256,\n            \"messages\": [\n                {\n                    \"role\": \"user\",\n                    \"content\": f\"Classify the sentiment of this review as positive, negative, or neutral:\\n\\n{review}\",\n                }\n            ],\n        },\n    }\n    for i, review in enumerate(reviews)  # reviews is a list of strings\n]\n\n# Submit — returns immediately with a batch ID\nbatch = client.messages.batches.create(requests=requests)\n\nprint(f\"Batch ID: {batch.id}\")\nprint(f\"Status:   {batch.processing_status}\")\nprint(f\"Requests: {batch.request_counts}\")\n# Batch ID: msgbatch_01XFDUDYJgAACzvnptvVoYEL\n# Status:   in_progress\n# Requests: BatchRequestCounts(canceled=0, errored=0, expired=0, processing=150, succeeded=0)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "custom_id" },
          { "type": "text", "text": " is your correlation key. It must be unique within the batch, up to 64 characters, and can contain only ASCII letters, digits, underscores, and hyphens. You use it to match each result to its input without relying on ordering (batch results are not guaranteed to be returned in submission order)." }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Polling for Completion" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Poll periodically until "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "processing_status" },
          { "type": "text", "text": " is " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "\"ended\"" },
          { "type": "text", "text": ". The batch can take up to 24 hours. Do not poll more often than once per minute — excessive polling wastes compute and counts against your RPM limit:" }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "python" },
        "content": [
          {
            "type": "text",
            "text": "import time\n\ndef wait_for_batch(batch_id: str, poll_interval: int = 60) -> anthropic.types.Batch:\n    \"\"\"Poll until the batch reaches a terminal state.\"\"\"\n    while True:\n        batch = client.messages.batches.retrieve(batch_id)\n        status = batch.processing_status\n        counts = batch.request_counts\n\n        print(\n            f\"[{status}] processing={counts.processing} \"\n            f\"succeeded={counts.succeeded} \"\n            f\"errored={counts.errored}\"\n        )\n\n        if status == \"ended\":\n            return batch\n\n        time.sleep(poll_interval)\n\nfinished = wait_for_batch(batch.id)\nprint(f\"Batch ended — succeeded: {finished.request_counts.succeeded}\")"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              { "type": "text", "marks": [{ "type": "bold" }], "text": "Webhook alternative:" },
              { "type": "text", "text": " For production pipelines, avoid polling entirely. Register a webhook URL in the Anthropic Console to receive a POST when the batch ends. The payload contains the batch ID, status, and request counts — retrieve results only when notified." }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Retrieving and Parsing Results" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Results are returned as a JSONL stream (one JSON object per line). Each line is a "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "BatchResult" },
          { "type": "text", "text": " with a " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "custom_id" },
          { "type": "text", "text": ", a " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "result" },
          { "type": "text", "text": " union, and a " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "type" },
          { "type": "text", "text": " discriminator:" }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "python" },
        "content": [
          {
            "type": "text",
            "text": "# Stream results — the SDK yields BatchResult objects\nfor result in client.messages.batches.results(batch.id):\n    match result.result.type:\n        case \"succeeded\":\n            message = result.result.message\n            text = message.content[0].text\n            print(f\"{result.custom_id}: {text[:80]}\")\n\n        case \"errored\":\n            err = result.result.error\n            print(f\"{result.custom_id} FAILED: [{err.type}] {err.message}\")\n\n        case \"canceled\":\n            print(f\"{result.custom_id}: canceled by user request\")\n\n        case \"expired\":\n            print(f\"{result.custom_id}: expired before processing (24h limit)\")"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Result Types" }]
      },
      {
        "type": "table",
        "content": [
          {
            "type": "tableRow",
            "content": [
              { "type": "tableHeader", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "result.type" }] }] },
              { "type": "tableHeader", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "result.message / result.error" }] }] },
              { "type": "tableHeader", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Action" }] }] }
            ]
          },
