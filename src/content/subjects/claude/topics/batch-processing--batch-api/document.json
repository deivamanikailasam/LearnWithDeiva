  "doc": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The Message Batches API lets you submit up to 10,000 inference requests in a single call and retrieve results when they are ready — at a 50% cost discount compared to real-time API calls. It is the right tool for any workload that can tolerate asynchronous results: nightly data pipelines, document classification, eval runs, and dataset enrichment."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Message Batches API lifecycle: Submit → Processing → Poll → Retrieve, with terminal states and request_counts breakdown"
        }
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
