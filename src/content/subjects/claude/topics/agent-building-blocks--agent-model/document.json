{"format":"tiptap/v1","updatedAt":"2026-06-22T04:21:02.454Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Based on the official resources from Anthropic's \"Building Effective AI Agents\" research and Claude documentation, "},{"type":"text","marks":[{"type":"bold"}],"text":"\"The Model\""},{"type":"text","text":" is the "},{"type":"text","marks":[{"type":"bold"}],"text":"core LLM (Large Language Model)"},{"type":"text","text":" that serves as the foundation for all agent building blocks."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","text":"The Model is the "},{"type":"text","marks":[{"type":"bold"}],"text":"direct model prompting access"},{"type":"text","text":" — the LLM itself (Claude) enhanced with augmentations like retrieval, tools, and memory. It's the \"brain\" that makes decisions, reasons about problems, and generates responses."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Characteristics"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"What It Means"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Core component"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"The LLM that processes inputs and generates outputs"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Native tool use"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Claude models support tool use natively, interleaving tool use and reasoning"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Decision maker"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Determines what actions to take, what tools to call, and when to stop"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Reasoning engine"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Thinks, plans, and executes rather than just following prompts"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"The Model vs. Agent Harness"}]},{"type":"paragraph","content":[{"type":"text","text":"Anthropic distinguishes between two approaches:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"What it is"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Direct model prompting access"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Pre-built, configurable agent harness"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Name"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"The Model"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Agent (Managed Agents)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Infrastructure"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"You manage the loop"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Runs in managed infrastructure"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best for"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"One-off requests, custom workflows"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Long-running tasks, asynchronous work"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Components"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Just the LLM"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Model + system prompt + tools + MCP servers + skills"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How the Model Works in Agents"}]},{"type":"paragraph","content":[{"type":"text","text":"The Model operates within the "},{"type":"text","marks":[{"type":"bold"}],"text":"agentic loop"},{"type":"text","text":":"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude receives prompt"},{"type":"text","text":" → SDK sends to model"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Model reasons"},{"type":"text","text":" → Decides what tool to use next"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Model emits tool_use"},{"type":"text","text":" → Requests a tool (not executes it)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Client executes tool"},{"type":"text","text":" → Returns result as tool_result block"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Model sees result"},{"type":"text","text":" → Decides next step or produces final answer"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"The key insight: "},{"type":"text","marks":[{"type":"bold"}],"text":"The model never executes tools itself — it only requests them"},{"type":"text","text":". The application/client executes tools and feeds results back."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of the Model as the "},{"type":"text","marks":[{"type":"bold"}],"text":"employee"},{"type":"text","text":" while other building blocks (Skills, Projects, MCP, Subagents) are the "},{"type":"text","marks":[{"type":"bold"}],"text":"tools, training, and resources"},{"type":"text","text":" you give them. The employee is smart, but needs the right infrastructure to do real work."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"The Model is the LLM (Claude) at the center of all agent systems"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Supports native tool use with interleaved reasoning and tool calls"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Makes decisions about what to do next based on context and feedback"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Never executes tools itself — only requests them; the client executes"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Works within the agentic loop: gather context → take action → verify → repeat"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Can be used standalone (direct prompting) or embedded in an Agent harness (Managed Agents)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Enhanced with augmentations (retrieval, tools, memory) to become agentic"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"The Model is the \"people\" component in the analogy: you need people (Model/Subagents), training manuals (Skills), filing cabinets (Projects), and connectors (MCP) to build effective agents."}]}]}}
