{"format":"tiptap/v1","updatedAt":"2026-06-22T06:31:44.007Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Based on the official documentation and resources, "},{"type":"text","marks":[{"type":"bold"}],"text":"\"Permissions & Safety\""},{"type":"text","text":" in the Agent SDK in Production refers to "},{"type":"text","marks":[{"type":"bold"}],"text":"the comprehensive security infrastructure that governs and restricts what agents can do"},{"type":"text","text":", including fine-grained permission controls, deny rules, permission callbacks, and sandboxing configurations that prevent unauthorized actions and protect production systems from agent misuse."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Permission Pipeline"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Four-Layer Pipeline"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Every tool call a Claude Agent SDK agent makes passes through a four-layer permission pipeline"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"1. Deny Rules (blocked tools)\n   ↓\n2. Permission Mode (read-only, read-write, skip)\n   ↓\n3. Permission Callbacks (dynamic checks)\n   ↓\n4. Tool Execution (if allowed)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key insight"},{"type":"text","text":": \"The four-layer permission pipeline that governs every tool call a Claude Agent SDK agent makes\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Permission Modes"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Three Permission Modes"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Mode"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Description"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Case"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"ReadOnly"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Agent can only read files, cannot modify"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Analysis, debugging"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"ReadWrite"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Agent can read and write files"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Code editing, file creation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"DangerouslySkipPermissions"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Bypass all confirmations (read/write/execute)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Temporary containers, isolated VMs"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"[reddit](https://www.reddit.com/r/ClaudeCode/comments/1rs05i3/claude_code_as_an_autonomous_agent_the_permission/)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Setting Permission Mode"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// TypeScript: Set permission mode\nconst agent = new Agent({\n  permissions: {\n    mode: \"ReadWrite\"  // or \"ReadOnly\" or \"DangerouslySkipPermissions\"\n  },\n  allowedTools: [\"read\", \"write\", \"bash\"]\n});"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Python: Set permission mode\nagent = Agent(\n    permissions={\"mode\": \"ReadWrite\"},\n    allowed_tools=[\"read\", \"write\", \"bash\"]\n)"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Deny Rules"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Blocking Specific Tools"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// TypeScript: Deny specific tools\nconst agent = new Agent({\n  denyTools: [\"kubectl\", \"npm install\"],  // Block malicious commands\n  allowedTools: [\"read\", \"write\", \"bash\"]\n});"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"CLI Equivalent"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# CLI: Block specific tools\nclaude --max-turns 10 --allowedTools \"Read,Glob,Grep\" \"your instruction\""}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Permission Callbacks"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Dynamic Permission Checks"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use permission callbacks to restrict what agents can do dynamically"},{"type":"text","text":"."}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// TypeScript: Permission callback\nconst agent = new Agent({\n  permissions: {\n    mode: \"ReadWrite\",\n    callback: async (toolCall) => {\n      // Check if tool is allowed\n      if (toolCall.toolName === \"write_file\") {\n        // Only allow writing to safe directories\n        if (!toolCall.path.startsWith(\"/safe/\")) {\n          throw new Error(\"Only write to safe directories\");\n        }\n      }\n      return true;  // Allow\n    }\n  }\n});"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Python: Permission callback\ndef permission_callback(tool_call):\n    # Check if tool is allowed\n    if tool_call.tool_name == \"write_file\":\n        # Only allow writing to safe directories\n        if not tool_call.path.startswith(\"/safe/\"):\n            raise ValueError(\"Only write to safe directories\")\n    return True  # Allow\n\nagent = Agent(\n    permissions={\n        \"mode\": \"ReadWrite\",\n        \"callback\": permission_callback\n    }\n)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key capability"},{"type":"text","text":": \"The SDK provides fine-grained permission controls and hook functions that let you intercept tool calls before they execute\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Allowed Tools"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Specifying Allowed Tools"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// TypeScript: Define allowed tools\nconst agent = new Agent({\n  allowedTools: [\"read\", \"write\", \"bash\", \"web_search\"]\n});"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Python: Define allowed tools\nagent = Agent(\n    allowed_tools=[\"read\", \"write\", \"bash\", \"web_search\"]\n)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Tool-Based Permissions"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Allowed Tools"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Analysis only"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"allowedTools: \"Read,Glob,Grep\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Analysis + notifications"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"allowedTools: \"Read,Bash (*)\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"CI/CD with commits"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"allowedTools: \"Edit,Bash (commit),Bash (push)\""}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"[reddit](https://www.reddit.com/r/ClaudeCode/comments/1rs05i3/claude_code_as_an_autonomous_agent_the_permission/)"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Safety Limits"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Max Turns"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# CLI: Limit number of actions\nclaude --max-turns 10 \"your instruction\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Purpose"},{"type":"text","text":": \"Without this, it could enter an endless loop\" — prevents infinite action cycles."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Max Budget"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# CLI: Limit spending\nclaude --max-budget-usd 0.50 \"your instruction\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Purpose"},{"type":"text","text":": \"Critical safety measure—don't rely solely on max-turns\" — halts operation if spending exceeds limit."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Headless Mode"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# CLI: Headless mode for automated execution\nclaude -p \"your instruction\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits"},{"type":"text","text":": No UI, no prompts, seamlessly integrates with scripts, CI/CD, cron jobs."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Sandboxing"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Critical Limitation"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"The permissions system in Claude offers minimal security benefits"},{"type":"text","text":"."}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"If you block kubectl command:\n  - Agent could create alias: alias kubectl='malicious-command'\n  - Agent could use bash script: bash -c \"kubectl ...\"\n  - Agent could access credential files directly\n  - Agent could interact with API directly"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key insight"},{"type":"text","text":": \"Permissions in Claude are almost completely useless from a security point of view\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"True Security: Strong Sandboxing"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"To truly mitigate the risks of prompt injection, effective containment through strong sandboxing is essential\""},{"type":"text","text":"."}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Sandboxing options:\n├─ Temporary containers (ephemeral, isolated)\n├─ Isolated VMs (duplex isolation from host)\n├─ Network restrictions (no external access)\n└─ File system restrictions (limited paths)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best practice"},{"type":"text","text":": \"The --dangerously-skip-permissions flag is more suitable for temporary containers or isolated VMs, not for servers that handle production data\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Production Safety Patterns"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Don't Use on Production Servers"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"It's quite risky to operate this on your live production server\""},{"type":"text","text":"."}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Safe alternatives:\n├─ Stream logs to external platform (Humio, Elasticsearch)\n├─ Analyze from separate location with read permissions\n└─ Use isolated environments for agent execution"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Account Suspension Risk"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Users have been sharing that using -p has led to their accounts being suspended without options for appeal regarding non-API usage\""},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Critical"},{"type":"text","text":": Keep this in mind when using headless mode."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Permission Security Checklist"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Practice"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Why"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"--allowedTools"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tailor to specific task, not overly broad"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Set "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"--max-turns"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Prevent endless loops"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Set "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"--max-budget-usd"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Critical safety against runaway costs"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use temporary containers"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Not production servers with real data"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Implement strong sandboxing"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Permissions alone are insufficient"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use permission callbacks"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Dynamic checks before tool execution"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use deny rules"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Block specific dangerous tools"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Avoid "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"DangerouslySkipPermissions"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Only for isolated environments"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"[linkedin](https://www.linkedin.com/posts/rickhigh_claude-agent-sdk-permissions-an-ai-agent-activity-7470112564950036480-p34q)"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Hooks for Safety"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Intercepting Tool Calls"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hooks can intercept and modify tool calls before execution"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"const agent = new Agent({\n  hooks: {\n    preToolUse: async (input) => {\n      // Validate tool arguments\n      if (input.toolName === \"write_file\" && !input.arguments.path.startsWith(\"/safe/\")) {\n        throw new Error(\"Only write to safe directories\");\n      }\n      return input;\n    }\n  }\n});"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key capability"},{"type":"text","text":": \"Hook functions that let you intercept tool calls before they execute\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of permissions like "},{"type":"text","marks":[{"type":"bold"}],"text":"a security guard at a building"},{"type":"text","text":": they check if you're allowed to enter (permission mode), stop you from certain areas (deny rules), and can ask for additional verification (permission callbacks). But the guard can be tricked (prompt injection). True security is like "},{"type":"text","marks":[{"type":"bold"}],"text":"a vault"},{"type":"text","text":": you put the agent in an isolated container (sandboxing) where it can't affect the real production system even if it tries to break out. Permissions are the guard, sandboxing is the vault—use both for real security."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Four-layer permission pipeline: deny rules → permission mode → callbacks → tool execution"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Three modes: ReadOnly (read-only), ReadWrite (read/write), DangerouslySkipPermissions (bypass all)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Permission callbacks: dynamic checks before tool execution ("},{"type":"text","marks":[{"type":"code"}],"text":"callback: async (toolCall) => {... }"},{"type":"text","text":")"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"allowedTools: tailor to task (analysis: Read/Glob/Grep; CI/CD: Edit/Bash commit/Bash push)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"--max-turns 10: prevents endless loops"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"--max-budget-usd 0.50: critical safety against runaway costs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"-p headless mode: no UI, integrates with scripts/CI/CD/cron jobs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"CRITICAL: Permissions are \"almost completely useless from a security point of view\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"True security: strong sandboxing (temporary containers, isolated VMs, network restrictions)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"DangerouslySkipPermissions: only for isolated environments, NOT production servers with real data"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Don't use on live production servers: risk of account suspension, use external analysis"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Hooks: intercept tool calls before execution (preToolUse callback)"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"\"To truly mitigate the risks of prompt injection, effective containment through strong sandboxing is essential\" — permissions alone are insufficient; use isolated containers/VMs for production safety."}]}]}}
