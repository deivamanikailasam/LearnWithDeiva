8K → 15K"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Simple logic"},{"type":"text","text":": 1K-2K"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Medium coding"},{"type":"text","text":": 3K-5K"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hard math/proofs"},{"type":"text","text":": 8K-15K"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Very complex"},{"type":"text","text":": 15K-32K"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key"},{"type":"text","text":": Claude won't always use full budget—it uses what it needs"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. Effort Level Optimization (Claude 4 models)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Effort Level"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Cost"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Latency"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Quality"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Best For"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"low"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Base"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"17s (baseline)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Baseline"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Routine tasks"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"medium"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"+negligible"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"2-3x low"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Same as high"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Practical balance"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"high"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"+negligible"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"60s (3.5x low)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"+15-17%"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Most coding"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"xhigh"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"+negligible"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"80-100s"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"+15-17%"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Complex coding, agents"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"max"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"+significant"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"140s+"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Highest"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Hard problems"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Critical insight"},{"type":"text","text":": Effort is primarily a "},{"type":"text","marks":[{"type":"bold"}],"text":"time and rate-limit cost, not token cost"},{"type":"text","text":". For routine coding, "},{"type":"text","marks":[{"type":"code"}],"text":"medium"},{"type":"text","text":" produces same quality as "},{"type":"text","marks":[{"type":"code"}],"text":"high"},{"type":"text","text":" in fraction of time."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"4. Infrastructure Optimizations"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Streaming"},{"type":"text","text":": Enable to show partial results while thinking completes"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"RAG"},{"type":"text","text":": Retrieve only top 5-15 chunks instead of pasting whole docs\n- Reduces prompt size dramatically\n- Often reduces need for extended thinking"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Caching"},{"type":"text","text":": Cache repeated context (system prompts, policy text)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Budget caps"},{"type":"text","text":": Set explicit SLOs (e.g., p95 under X seconds)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Real-World Cost Impact"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Case study"},{"type":"text","text":": Production pipeline migration\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Before"},{"type":"text","text":": $34,000/month with official API\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"After"},{"type":"text","text":": $4,800/month (85.9% reduction)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Latency"},{"type":"text","text":": p99 improved from 2,340ms → 890ms"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Opus + Extended Thinking"},{"type":"text","text":":\n- One Opus conversation = quota as 10+ Sonnet conversations\n- Burns through limits extremely fast\n- Use sparingly"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When NOT to Use Reasoning (Tradeoff Never Worth It)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ❌ Wasteful: extended thinking adds cost with no benefit\nresponse = client.messages.create(\n    model=\"claude-sonnet-4-5\",\n    thinking={\"type\": \"enabled\", \"budget_tokens\": 5000},  # Unnecessary\n    messages=[{\"role\": \"user\", \"content\": \"What is the capital of France?\"}]\n)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rule"},{"type":"text","text":": If latency matters AND task doesn't require deep reasoning, skip it"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Reasoning isn't \"smarter\""},{"type":"text","text":"—it's LLMs spending more compute time (test-time compute) for accuracy"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Value"},{"type":"text","text":": Improves success rate on \"think-before-answer\" tasks from 30-50% → 70-80%"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cost"},{"type":"text","text":": 10-100x more expensive than regular LLMs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Latency"},{"type":"text","text":": Adds seconds to minutes depending on budget"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use as specialized tool"},{"type":"text","text":": For \"hard problems,\" not daily workhorses"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Default"},{"type":"text","text":": Disable globally, enable selectively for known hard problems"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tuning"},{"type":"text","text":": Start at 1,024 tokens, increase gradually until quality stabilizes"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Effort levels"},{"type":"text","text":": Often better lever than switching models"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output tokens = latency budget"},{"type":"text","text":": Optimizeeverything to reduce output token count"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Question"},{"type":"text","text":": \"How much thinking do I want this call to do?\" not \"should I use reasoning?\""}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"The tradeoff is straightforward: "},{"type":"text","marks":[{"type":"bold"}],"text":"fast responses = short prompts + bounded outputs; higher reliability on complex tasks = more time + more tokens"},{"type":"text","text":"."}]}]}}
