}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Thinking tokens are NOT free"},{"type":"text","text":":\n- Priced at "},{"type":"text","marks":[{"type":"bold"}],"text":"$3.75 per million tokens"},{"type":"text","text":" (between input and output pricing)\n- Count toward your output token costs\n- API doesn't report separate "},{"type":"text","marks":[{"type":"code"}],"text":"thinking_tokens"},{"type":"text","text":" field—they're lumped into "},{"type":"text","marks":[{"type":"code"}],"text":"output_tokens"},{"type":"text","text":"\n- At max effort, single prompt can consume "},{"type":"text","marks":[{"type":"bold"}],"text":"10x more tokens"},{"type":"text","text":" than low effort"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Real example"},{"type":"text","text":":\n- One complex algorithm problem: 2K input + 800 output tokens = "},{"type":"text","marks":[{"type":"bold"}],"text":"$0.05"},{"type":"text","text":"\n- Regular LLM for same task: "},{"type":"text","marks":[{"type":"bold"}],"text":"$0.00006"},{"type":"text","text":" (800x cheaper)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Latency Mechanism"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Latency = fixed_overhead + (input_tokens × processing_time) + (output_tokens × generation_time) + reasoning_time"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Three main latency knobs"},{"type":"text","text":":\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Input size"},{"type":"text","text":": Doubling 1K→2K tokens adds only 50-200ms (parallel processing)\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Output size"},{"type":"text","text":": Doubling 500→1K tokens "},{"type":"text","marks":[{"type":"bold"}],"text":"roughly doubles"},{"type":"text","text":" generation time (sequential)\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Reasoning depth"},{"type":"text","text":": Deeper thinking = more compute time = linear latency increase"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Critical insight"},{"type":"text","text":": Output tokens are the "},{"type":"text","marks":[{"type":"bold"}],"text":"primary driver"},{"type":"text","text":" of total response time. A 10K-token prompt generating 100 tokens is faster than 1K-token prompt generating 2,000 tokens."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hidden latency factors"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Context bloat"},{"type":"text","text":": 50-200K tokens per request unnecessarily (long history, pasted docs)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"No streaming"},{"type":"text","text":": User sees nothing until completion\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Model choice"},{"type":"text","text":": Haiku is 2-3x faster than Sonnet; Sonnet is 1.5-2x faster than Opus"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When the Tradeoff is Worth It"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Task Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Cost Increase"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Latency Increase"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Quality Gain"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align"