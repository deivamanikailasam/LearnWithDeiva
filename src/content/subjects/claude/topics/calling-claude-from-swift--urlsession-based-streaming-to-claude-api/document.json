{
  "format": "tiptap/v1",
  "doc": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "iOS 15 introduced "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "URLSession.bytes(for:)" },
          {
            "type": "text",
            "text": ", a native async sequence API that makes server-sent event (SSE) streaming first-class in Swift without any third-party libraries. Claude's Messages API speaks SSE when you pass "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "\"stream\": true" },
          {
            "type": "text",
            "text": ", so the two fit together directly: open a URLSession request, iterate over lines with "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "for try await" },
          {
            "type": "text",
            "text": ", strip the SSE prefix, decode JSON deltas, and update your SwiftUI view on the main actor. This section walks through every layer of that stack with runnable code."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Architecture Overview" }]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "URLSession SSE streaming architecture: Swift iOS App → HTTPS POST to Claude API → SSE chunks back → async sequence loop with four stages"
        }
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Codable Models for Request and Response" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Define "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "Codable" },
          {
            "type": "text",
            "text": " structs that match the Claude API JSON shapes. You only need to decode the fields you actually use — Swift's "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "JSONDecoder" },
          {
            "type": "text",
            "text": " ignores extra keys by default."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "swift" },
        "content": [
          {
            "type": "text",
            "text": "import Foundation\n\n// MARK: - Request\n\nstruct ClaudeRequest: Encodable {\n    let model: String\n    let maxTokens: Int\n    let messages: [Message]\n    let stream: Bool\n\n    enum CodingKeys: String, CodingKey {\n        case model, messages, stream\n        case maxTokens = \"max_tokens\"\n    }\n\n    struct Message: Encodable {\n        let role: String  // \"user\" or \"assistant\"\n        let content: String\n    }\n}\n\n// MARK: - Streaming response events\n\nstruct StreamEvent: Decodable {\n    let type: String\n    let delta: Delta?\n    let usage: Usage?\n\n    struct Delta: Decodable {\n        let type: String?\n        let text: String?\n    }\n\n    struct Usage: Decodable {\n        let outputTokens: Int?\n        enum CodingKeys: String, CodingKey {\n            case outputTokens = \"output_tokens\"\n        }\n    }\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Building the URLRequest" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The Claude API requires three headers: "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "x-api-key" },
          { "type": "text", "text": ", " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "anthropic-version" },
          { "type": "text", "text": ", and " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "content-type: application/json" },
          {
            "type": "text",
            "text": ". The API key must never be embedded in the app binary — fetch it from your backend or, for development only, from a "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": ".xcconfig" },
          {
            "type": "text",
            "text": " file that is git-ignored."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "swift" },
        "content": [
          {
            "type": "text",
            "text": "func makeClaudeRequest(messages: [ClaudeRequest.Message], apiKey: String) throws -> URLRequest {\n    let url = URL(string: \"https://api.anthropic.com/v1/messages\")!\n    var request = URLRequest(url: url)\n    request.httpMethod = \"POST\"\n    request.setValue(\"application/json\", forHTTPHeaderField: \"content-type\")\n    request.setValue(apiKey, forHTTPHeaderField: \"x-api-key\")\n    request.setValue(\"2023-06-01\", forHTTPHeaderField: \"anthropic-version\")\n\n    let body = ClaudeRequest(\n        model: \"claude-haiku-4-5\",\n        maxTokens: 1024,\n        messages: messages,\n        stream: true\n    )\n    request.httpBody = try JSONEncoder().encode(body)\n    return request\n}"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              { "type": "text", "marks": [{ "type": "bold" }], "text": "API key in production:" },
              { "type": "text", "text": " In a shipping app, the iOS client should never hold the Anthropic API key. Route requests through your own backend (a Vapor or Express server, or a Cloudflare Worker) that injects the key server-side. The client calls your domain, not api.anthropic.com directly." }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Streaming with URLSession.bytes()" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "URLSession.bytes(for:) opens the HTTP connection and returns an "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "AsyncLineSequence" },
          { "type": "text", "text": " via " },
          { "type": "text", "marks": [{ "type": "code" }], "text": ".lines" },
          {
            "type": "text",
            "text": ". Each element is one newline-delimited string from the response body. For SSE, that means each element is either a line of the form "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "data: {json}" },
          { "type": "text", "text": " or a blank line separating events. The loop below handles both:" }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "swift" },
        "content": [
          {
            "type": "text",
            "text": "import Foundation\n\nactor ClaudeClient {\n    private let session = URLSession.shared\n    private let decoder = JSONDecoder()\n\n    func stream(\n        messages: [ClaudeRequest.Message],\n        apiKey: String,\n        onDelta: @Sendable @escaping (String) async -> Void\n    ) async throws {\n        let request = try makeClaudeRequest(messages: messages, apiKey: apiKey)\n        let (bytes, response) = try await session.bytes(for: request)\n\n        guard let http = response as? HTTPURLResponse else {\n            throw ClaudeError.invalidResponse\n        }\n        guard http.statusCode == 200 else {\n            throw ClaudeError.apiError(statusCode: http.statusCode)\n        }\n\n        for try await line in bytes.lines {\n            // SSE data lines start with \"data: \"\n            guard line.hasPrefix(\"data: \") else { continue }\n            let json = String(line.dropFirst(6))  // strip \"data: \"\n\n            // Final sentinel — stream is done\n            if json == \"[DONE]\" { break }\n\n            let event = try decoder.decode(StreamEvent.self, from: Data(json.utf8))\n\n            // Only content_block_delta events carry text\n            if event.type == \"content_block_delta\",\n               let text = event.delta?.text {\n                await onDelta(text)\n            }\n        }\n    }\n}\n\nenum ClaudeError: Error {\n    case invalidResponse\n    case apiError(statusCode: Int)\n}"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "actor" },
          {
            "type": "text",
            "text": " keyword gives "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "ClaudeClient" },
          {
            "type": "text",
            "text": " built-in mutual exclusion. Concurrent calls to "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "stream()" },
          {
            "type": "text",
            "text": " are serialized automatically — no "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "DispatchQueue" },
          { "type": "text", "text": " or locks required." }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Wiring to SwiftUI" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The view model holds the accumulating response string and drives UI updates. Because "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "@Published" },
          {
            "type": "text",
            "text": " must be mutated on the main thread, use "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "await MainActor.run" },
          { "type": "text", "text": " inside the delta callback." }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "swift" },
        "content": [
          {
            "type": "text",
            "text": "import SwiftUI\n\n@MainActor\nfinal class ChatViewModel: ObservableObject {\n    @Published var output = \"\"\n    @Published var isStreaming = false\n    @Published var error: String?\n\n    private let client = ClaudeClient()\n    private var streamTask: Task<Void, Never>?\n\n    func send(prompt: String, apiKey: String) {\n        // Cancel any in-progress stream\n        streamTask?.cancel()\n        output = \"\"\n        isStreaming = true\n        error = nil\n\n        streamTask = Task {\n            do {\n                let messages = [ClaudeRequest.Message(role: \"user\", content: prompt)]\n                try await client.stream(messages: messages, apiKey: apiKey) { [weak self] delta in\n                    await MainActor.run {\n                        self?.output += delta\n                    }\n                }\n            } catch is CancellationError {\n                // Silently handle user-initiated cancel\n            } catch {\n                await MainActor.run {\n                    self.error = error.localizedDescription\n                }\n            }\n            await MainActor.run { self.isStreaming = false }\n        }\n    }\n\n    func cancel() {\n        streamTask?.cancel()\n        isStreaming = false\n    }\n}\n\nstruct ChatView: View {\n    @StateObject private var viewModel = ChatViewModel()\n    @State private var prompt = \"\"\n    let apiKey: String\n\n    var body: some View {\n        VStack {\n            ScrollView {\n                Text(viewModel.output)\n                    .frame(maxWidth: .infinity, alignment: .leading)\n                    .padding()\n            }\n            if let err = viewModel.error {\n                Text(err).foregroundColor(.red).font(.caption).padding(.horizontal)\n            }\n            HStack {\n                TextField(\"Ask Claude...\", text: $prompt)\n                    .textFieldStyle(.roundedBorder)\n                if viewModel.isStreaming {\n                    Button(\"Stop\") { viewModel.cancel() }\n                        .tint(.red)\n                } else {\n                    Button(\"Send\") {\n                        viewModel.send(prompt: prompt, apiKey: apiKey)\n                    }\n                    .disabled(prompt.isEmpty)\n                }\n            }\n            .padding()\n        }\n    }\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "SSE Event Types" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Claude's streaming API emits six event types. Most implementations only need "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "content_block_delta" },
          {
            "type": "text",
            "text": " for the text, but understanding the full sequence helps with token counting and stop-reason handling."
          }
        ]
      },
      {
        "type": "table",
        "content": [
          {
            "type": "tableRow",
            "content": [
              { "type": "tableHeader", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Event type" }] }] },
              { "type": "tableHeader", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Key fields" }] }] },
              { "type": "tableHeader", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Purpose" }] }] }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "code" }], "text": "message_start" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "message.model, message.usage.input_tokens" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Stream opened; log model and input token count" }] }] }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "code" }], "text": "content_block_start" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "index, content_block.type" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "New content block started (type is always \"text\" for text generation)" }] }] }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "code" }], "text": "content_block_delta" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "delta.type, delta.text" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Text chunk — append delta.text to output" }] }] }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "code" }], "text": "content_block_stop" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "index" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Block complete; safe to present final text" }] }] }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "code" }], "text": "message_delta" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "delta.stop_reason, usage.output_tokens" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Stop reason: end_turn, max_tokens, stop_sequence" }] }] }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "code" }], "text": "message_stop" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "(none)" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Stream fully complete; close connection" }] }] }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Cancellation and Task Lifecycle" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Swift structured concurrency cancellation propagates through the async sequence automatically. When you call "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "streamTask?.cancel()" },
          {
            "type": "text",
            "text": ", the "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "for try await" },
          {
            "type": "text",
            "text": " loop throws "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "CancellationError" },
          {
            "type": "text",
            "text": " on its next iteration, which unwinds the actor call and closes the network connection. You must catch "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "CancellationError" },
          { "type": "text", "text": " separately from other errors (as shown in the view model above) to avoid surfacing it as a user-facing error message." }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For SwiftUI view lifecycle, cancel the task in "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": ".onDisappear" },
          { "type": "text", "text": " to avoid a reference to a deallocated view model:" }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "swift" },
        "content": [
          {
            "type": "text",
            "text": ".onDisappear {\n    viewModel.cancel()\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Handling API Errors" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When the API returns a non-200 status, the response body is a JSON error object, not an SSE stream. Read the body separately before iterating lines:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "swift" },
        "content": [
          {
            "type": "text",
            "text": "struct APIErrorResponse: Decodable {\n    let error: APIError\n    struct APIError: Decodable {\n        let type: String\n        let message: String\n    }\n}\n\n// In stream() — after checking statusCode != 200:\nlet errorData = try await session.data(for: request).0\nif let apiError = try? decoder.decode(APIErrorResponse.self, from: errorData) {\n    throw ClaudeError.message(apiError.error.message)\n}\nthrow ClaudeError.apiError(statusCode: http.statusCode)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Common status codes from Claude API:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "code" }], "text": "401" },
                  { "type": "text", "text": " — invalid or missing API key." }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "code" }], "text": "429" },
                  { "type": "text", "text": " — rate limit exceeded. Retry with exponential backoff." }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "code" }], "text": "529" },
                  { "type": "text", "text": " — API overloaded. Treat the same as 429." }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "code" }], "text": "400" },
                  { "type": "text", "text": " — malformed request (usually bad JSON or unsupported model string)." }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Conversation History" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Claude is stateless — every request must contain the full conversation history. Track messages in the view model and append both the user turn and the completed assistant turn after each exchange:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "swift" },
        "content": [
          {
            "type": "text",
            "text": "@MainActor\nfinal class ChatViewModel: ObservableObject {\n    @Published var output = \"\"\n    @Published var isStreaming = false\n    private(set) var history: [ClaudeRequest.Message] = []\n    private let client = ClaudeClient()\n    private var streamTask: Task<Void, Never>?\n\n    func send(prompt: String, apiKey: String) {\n        streamTask?.cancel()\n        output = \"\"\n        isStreaming = true\n\n        // Append user turn before sending\n        history.append(.init(role: \"user\", content: prompt))\n        let snapshot = history  // capture current history\n\n        streamTask = Task {\n            var assistantText = \"\"\n            do {\n                try await client.stream(messages: snapshot, apiKey: apiKey) { delta in\n                    await MainActor.run {\n                        self.output += delta\n                        assistantText += delta\n                    }\n                }\n                // Append assistant turn for next round\n                await MainActor.run {\n                    self.history.append(.init(role: \"assistant\", content: assistantText))\n                    self.isStreaming = false\n                }\n            } catch is CancellationError {\n                await MainActor.run { self.isStreaming = false }\n            } catch {\n                await MainActor.run {\n                    self.isStreaming = false\n                    // Optionally remove the user turn that failed\n                    self.history.removeLast()\n                }\n            }\n        }\n    }\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Minimum iOS Version and Dependencies" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "This approach requires iOS 15 for "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "URLSession.bytes(for:)" },
          { "type": "text", "text": " and iOS 15's "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "AsyncLineSequence" },
          {
            "type": "text",
            "text": ". No Swift packages are needed. If you must support iOS 13 or 14, you will need to use a URLSessionDataDelegate and manually buffer incoming bytes — significantly more code. For most new apps, targeting iOS 16+ is the pragmatic choice."
          }
        ]
      },
      {
        "type": "table",
        "content": [
          {
            "type": "tableRow",
            "content": [
              { "type": "tableHeader", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "iOS version" }] }] },
              { "type": "tableHeader", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Streaming approach" }] }] },
              { "type": "tableHeader", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Complexity" }] }] }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "iOS 15+" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "code" }], "text": "URLSession.bytes(for:)" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Low — async sequence, no extra dependencies" }] }] }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "iOS 13–14" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "URLSessionDataDelegate + manual buffering" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "High — delegate callbacks, manual line splitting" }] }] }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Any iOS" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Swift-Anthropic SDK (third-party)" }] }] },
              { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Low — SDK hides all SSE parsing" }] }] }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Common Pitfalls" }]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "bold" }], "text": "Forgetting the anthropic-version header." },
                  { "type": "text", "text": " The API returns a 400 error without it. Set it to " },
                  { "type": "text", "marks": [{ "type": "code" }], "text": "\"2023-06-01\"" },
                  { "type": "text", "text": " (the current stable version)." }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "bold" }], "text": "Updating @Published from a background thread." },
                  { "type": "text", "text": " The " },
                  { "type": "text", "marks": [{ "type": "code" }], "text": "for try await" },
                  { "type": "text", "text": " loop runs on a background thread. Without " },
                  { "type": "text", "marks": [{ "type": "code" }], "text": "await MainActor.run" },
                  { "type": "text", "text": ", you'll hit a SwiftUI runtime warning and possible crashes on iOS 16+." }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "bold" }], "text": "Not catching CancellationError separately." },
                  { "type": "text", "text": " If your catch block sets " },
                  { "type": "text", "marks": [{ "type": "code" }], "text": "error = error.localizedDescription" },
                  { "type": "text", "text": " for all errors, the user sees an error banner every time they cancel. Handle " },
                  { "type": "text", "marks": [{ "type": "code" }], "text": "CancellationError" },
                  { "type": "text", "text": " silently." }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "bold" }], "text": "Embedding the API key in the binary." },
                  { "type": "text", "text": " Even in a .xcconfig file that is git-ignored, the key ends up in the compiled binary where it can be extracted by tools like " },
                  { "type": "text", "marks": [{ "type": "code" }], "text": "strings" },
                  { "type": "text", "text": ". Always call Claude through your own backend in production." }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "bold" }], "text": "Not handling the [DONE] sentinel." },
                  { "type": "text", "text": " Claude's API appends a final " },
                  { "type": "text", "marks": [{ "type": "code" }], "text": "data: [DONE]" },
                  { "type": "text", "text": " line after " },
                  { "type": "text", "marks": [{ "type": "code" }], "text": "message_stop" },
                  { "type": "text", "text": ". If you pass " },
                  { "type": "text", "marks": [{ "type": "code" }], "text": "\"[DONE]\"" },
                  { "type": "text", "text": " to JSONDecoder it will throw. Add a " },
                  { "type": "text", "marks": [{ "type": "code" }], "text": "if json == \"[DONE]\" { break }" },
                  { "type": "text", "text": " guard before decoding." }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Summary" }]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "URLSession.bytes(for:) on iOS 15+ provides everything needed to consume Claude's SSE stream without any third-party library. The pattern is: build a "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "URLRequest" },
          { "type": "text", "text": " with the required headers, call " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "session.bytes(for:)" },
          { "type": "text", "text": ", iterate " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "bytes.lines" },
          { "type": "text", "text": " with " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "for try await" },
          { "type": "text", "text": ", strip the " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "\"data: \"" },
          { "type": "text", "text": " prefix, decode " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "content_block_delta" },
          { "type": "text", "text": " events, and push text to the UI via " },
          { "type": "text", "marks": [{ "type": "code" }], "text": "await MainActor.run" },
          {
            "type": "text",
            "text": ". Wrapping the client in an "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "actor" },
          {
            "type": "text",
            "text": " gives thread safety for free, and cancellation via "
          },
          { "type": "text", "marks": [{ "type": "code" }], "text": "Task.cancel()" },
          {
            "type": "text",
            "text": " propagates automatically through the async sequence. Keep the API key out of the binary by routing through your own backend before shipping to the App Store."
          }
        ]
      }
    ]
  }
}
