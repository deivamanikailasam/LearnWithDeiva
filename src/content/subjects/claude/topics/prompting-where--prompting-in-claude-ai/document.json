{"format":"tiptap/v1","updatedAt":"2026-06-20T11:39:37.629Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"In "},{"type":"text","marks":[{"type":"link","attrs":{"href":"http://Claude.ai","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}},{"type":"bold"}],"text":"Claude.ai"},{"type":"text","text":", you prompt primarily in the "},{"type":"text","marks":[{"type":"bold"}],"text":"main chat input box"},{"type":"text","text":" at the bottom of the conversation surface, and you can also use "},{"type":"text","marks":[{"type":"bold"}],"text":"project‑level instructions"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"bold"}],"text":"built‑in prompting tools"},{"type":"text","text":" to structure and refine prompts."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Main chat input (the core place to prompt)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Where it is:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"On the "},{"type":"text","marks":[{"type":"link","attrs":{"href":"http://Claude.ai","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"Claude.ai"},{"type":"text","text":" web UI (or in the app), open a chat with Claude."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"At the bottom of the screen, you see a text input field with a "},{"type":"text","marks":[{"type":"bold"}],"text":"Send"},{"type":"text","text":" button (or an arrow icon)."}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it does:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"This is where you type your "},{"type":"text","marks":[{"type":"bold"}],"text":"user prompt"},{"type":"text","text":": the task, question, or instruction for Claude."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Everything you send here becomes part of the conversation context and is used by Claude to generate its response."}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How to use it well:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Start with a clear "},{"type":"text","marks":[{"type":"bold"}],"text":"role + task + context + constraints + output format"},{"type":"text","text":"."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use line breaks, lists, and tags like "},{"type":"text","marks":[{"type":"code"}],"text":"<context>"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"<examples>"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"<rules>"},{"type":"text","text":" to structure your prompt."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"For long tasks, you can paste data directly into this input or attach files (if your interface supports attachments)."}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Project / Conversation-level instructions (for reusable context)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"link","attrs":{"href":"http://Claude.ai","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"Claude.ai"},{"type":"text","text":" supports "},{"type":"text","marks":[{"type":"bold"}],"text":"Projects"},{"type":"text","text":" (sometimes called “Claude Projects”) where you can define persistent context and instructions for a group of conversations."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Where it is:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"In the left sidebar, under "},{"type":"text","marks":[{"type":"bold"}],"text":"Projects"},{"type":"text","text":" (or a similar section)."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Create a new project (e.g., “Prompt Rewriter”, “Marketing Assistant”, “Code Reviewer”)."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Inside the project, there’s often an instructions field or a place to set "},{"type":"text","marks":[{"type":"bold"}],"text":"system-like guidance"},{"type":"text","text":" for that project."}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it does:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"You can write "},{"type":"text","marks":[{"type":"bold"}],"text":"project instructions"},{"type":"text","text":" that act like a system prompt: define Claude’s role, style, rules, and typical workflows for that project."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Every conversation in that project inherits this context, so you don’t need to repeat the same instructions in every prompt."}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"You are an expert prompt engineer specializing in improving Claude prompts.\n\nRules:\n- Always ask clarifying questions before rewriting.\n- Keep rewritten prompts concise but explicit.\n- Output the final prompt in a markdown block.\n- Do not execute the prompt; just optimize it."}]},{"type":"paragraph","content":[{"type":"text","text":"This is especially useful when you want a "},{"type":"text","marks":[{"type":"bold"}],"text":"consistent collaborator persona"},{"type":"text","text":" across many prompts in a project."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. Prompt Generator and Prompt Improver (built-in tools)"}]},{"type":"paragraph","content":[{"type":"text","text":"Claude Console / "},{"type":"text","marks":[{"type":"link","attrs":{"href":"http://Claude.ai","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"Claude.ai"},{"type":"text","text":" offers "},{"type":"text","marks":[{"type":"bold"}],"text":"prompting tools"},{"type":"text","text":" to help you build and refine prompts:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"“The Claude Console also offers prompting tools—prompt generator, templates and variables, and prompt improver—to help you build and refine prompts quickly.”"}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prompt Generator"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"If you don’t have a first draft, you can use the "},{"type":"text","marks":[{"type":"bold"}],"text":"Prompt Generator"},{"type":"text","text":" in the Claude Console."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"It asks you questions about your task and then generates a structured prompt for you."}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Where to find it:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"In the Claude Console (or within "},{"type":"text","marks":[{"type":"link","attrs":{"href":"http://Claude.ai","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"Claude.ai"},{"type":"text","text":"’s tools panel), look for "},{"type":"text","marks":[{"type":"bold"}],"text":"Prompt Generator"},{"type":"text","text":" or similar."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"It may be an interactive tool or a button that opens a guided form."}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prompt Improver"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"If you already have a rough prompt, you can run it through the "},{"type":"text","marks":[{"type":"bold"}],"text":"Prompt Improver"},{"type":"text","text":"."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"It analyzes your prompt and suggests improvements: clarity, structure, examples, constraints, etc."}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How to use:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Paste your draft prompt into the tool."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Let it suggest changes."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Then paste the improved prompt back into the main chat input to use with Claude."}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"4. Interactive Prompt Maker (artifact-based tool)"}]},{"type":"paragraph","content":[{"type":"text","text":"There is also an "},{"type":"text","marks":[{"type":"bold"}],"text":"Interactive Prompt Maker"},{"type":"text","text":" artifact on "},{"type":"text","marks":[{"type":"link","attrs":{"href":"http://Claude.ai","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"Claude.ai"},{"type":"text","text":":"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"“Create perfect AI prompts in 3 steps: describe your task, answer tailored questions, get optimized prompts. Built with Claude AI at "},{"type":"text","marks":[{"type":"link","attrs":{"href":"http://Claude.ai","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}},{"type":"bold"}],"text":"Claude.ai"},{"type":"text","marks":[{"type":"bold"}],"text":".”"}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How it works:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"You describe your task."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"The tool asks tailored questions (e.g., audience, tone, format, constraints)."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"It generates an optimized prompt for you."}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Where to use:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"In "},{"type":"text","marks":[{"type":"link","attrs":{"href":"http://Claude.ai","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"Claude.ai"},{"type":"text","text":", you can open this as an interactive artifact (a guided tool)."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"The final prompt is then copied into the "},{"type":"text","marks":[{"type":"bold"}],"text":"main chat input"},{"type":"text","text":" to use with Claude."}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"5. How the pieces fit together: where to “prompt” in practice"}]},{"type":"paragraph","content":[{"type":"text","text":"Typical workflow:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Start in the main chat input:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Type your initial task in the bottom input box and hit send."}]}]}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"If you want reusable context:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Create a "},{"type":"text","marks":[{"type":"bold"}],"text":"Project"},{"type":"text","text":" and set persistent instructions there, then prompt inside that project."}]}]}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"If you don’t have a good prompt yet:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use the "},{"type":"text","marks":[{"type":"bold"}],"text":"Prompt Generator"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"bold"}],"text":"Interactive Prompt Maker"},{"type":"text","text":" to build one."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Then paste the generated prompt into the main chat input."}]}]}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"If you have a rough prompt:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use the "},{"type":"text","marks":[{"type":"bold"}],"text":"Prompt Improver"},{"type":"text","text":" to refine it."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Then paste the improved prompt into the main chat input."}]}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"In short: "},{"type":"text","marks":[{"type":"bold"}],"text":"you type your actual prompts into the main chat input"},{"type":"text","text":"; projects and tools help you design, refine, and reuse them."}]}]}}
