{"format":"tiptap/v1","updatedAt":"2026-06-21T14:58:20.309Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","text":"A "},{"type":"text","marks":[{"type":"bold"}],"text":"Tool Use Request"},{"type":"text","text":" is the initial API call to Claude that includes the "},{"type":"text","marks":[{"type":"code"}],"text":"tools"},{"type":"text","text":" parameter, defining which functions are available for Claude to call. This request tells Claude what operations it can perform and when to use them."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Core concept"},{"type":"text","text":": \"You send a request with tools defined → Claude responds with tool_use blocks (stop_reason: 'tool_use') → your application executes → feed results back → Claude gives final answer\"."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why It Matters"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Without tool use request"},{"type":"text","text":": Claude can only generate text → no external actions"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"With tool use request"},{"type":"text","text":": Claude knows available tools → can call them when needed → performs real-world actions"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"For your distributed systems work at Box Hill"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Database access"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"query_database(query, params)"},{"type":"text","text":" → fetch user data\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"API integration"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"fetch_stock_price(sym