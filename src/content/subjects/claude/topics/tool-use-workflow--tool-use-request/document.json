bleCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Manual loop (define → call → execute → result)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use SDK wrapper"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How It Works"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Tool Use Workflow Sequence"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Step 1: Initial Request → User message + tools defined\nStep 2: Tool Request → Claude outputs tool_use blocks (stop_reason: \"tool_use\")\nStep 3: Data Retrieval → Your app executes tools and collects results\nStep 4: Final Response → Send tool_result back + Claude synthesizes answer"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Request Structure"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"const response = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [\n    {\n      role: \"user\",\n      content: \"What's the stock price for AAPL?\"\n    }\n  ],\n  tools: [\n    {\n      name: \"get_stock_price\",\n      description: \"Get the current stock price for a given symbol...\",\n      input_schema: {\n        type: \"object\",\n        properties: { symbol: { type: \"string\" } },\n        required: [\"symbol\"]\n      }\n    }\n  ],\n  tool_choice: { type: \"auto\" } // Default: Claude decides\n});"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Claude's Decision Logic"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// With default tool_choice: { type: \"auto\" }\nClaude decides on each turn whether to call a tool or respond directly.\n\nIt calls a tool when:\n1. The request maps to that tool's described capability\n2. AND the answer isn't already in context\n\nIt responds directly for:\n- Stable knowledge (e.g., \"What's the capital of France?\")\n- Creative tasks (e.g., writing, poetry)\n- Conversational turns (e.g., chat)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Response When Tool Is Called"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"role\": \"assistant\",\n  \"content\": [\n    {\n      \"type\": \"text\",\n      \"text\": \"I need to check the stock price for AAPL.\"\n    },\n    {\n      \"type\": \"tool_use\",\n      \"id\": \"toolu_01A12v3xX\",\n      \"name\": \"get_stock_price\",\n      \"input\": { \"symbol\": \"AAPL\" }\n    }\n  ],\n  \"stop_reason\": \"tool_use\" // ← Control flow signal\n}"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Use Default "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_choice: { type: \"auto\" }"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"const response = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [{ role: \"user\", content: \"What's AAPL's stock price?\" }],\n  tools: [getStockPriceTool],\n  tool_choice: { type: \"auto\" } // Claude decides when to use tools\n});"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why"},{"type":"text","text":": Claude intelligently decides when tools are needed."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Steer Behavior with System Prompt"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Light instruction: measurably increases tool use\nconst response = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  system: \"Use the tools to investigate before responding.\",\n  messages: [{ role: \"user\", content: \"What's the weather in Boston?\" }],\n  tools: [getWeatherTool]\n});\n\n// Stronger form: forces tool-first behavior\nconst response2 = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  system: \"Always call a tool first before responding.\",\n  messages: [{ role: \"user\", content: \"What's the weather in Boston?\" }],\n  tools: [getWeatherTool]\n});\n\n// Conservative: keeps triggering behavior minimal\nconst response3 = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  system: \"Use your judgment about whether to call a tool or respond directly.\",\n  messages: [{ role: \"user\", content: \"What's the weather in Boston?\" }],\n  tools: [getWeatherTool]\n});"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Use "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_choice: { type: \"any\" }"},{"type":"text","marks":[{"type":"bold"}],"text":" for Hard Guarantee"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"const response = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [{ role: \"user\", content: \"What's AAPL's stock price?\" }],\n  tools: [getStockPriceTool],\n  tool_choice: { type: \"any\" } // Claude MUST call at least one tool\n});"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why"},{"type":"text","text":": Forces tool call instead of nudging."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Add "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"strict: true"},{"type":"text","marks":[{"type":"bold"}],"text":" for Schema Enforcement"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"const response = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [{ role: \"user\", content: \"AAPL price?\" }],\n  tools: [\n    {\n      name: \"get_stock_price\",\n      description: \"Get current stock price...\",\n      input_schema: { ... },\n      strict: true // Ensure Claude's tool calls match schema exactly\n    }\n  ]\n});"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why"},{"type":"text","text":": Prevents schema violations."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Handle Multiple Tool Calls in Parallel"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// User requests multiple items\nconst response = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [{ role: \"user\", content: \"What are stock prices for AAPL and GOOGL?\" }],\n  tools: [getStockPriceTool]\n});\n\n// Claude returns multiple tool_use blocks\nconst toolUseBlocks = response.content.filter(c => c.type === \"tool_use\");\nconsole.log(toolUseBlocks.length); // 2\n\n// Execute in parallel\nconst results = await Promise.all(\n  toolUseBlocks.map(block => executeTool(block.name, block.input))\n);"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tool use request = initial API call with tools parameter"},{"type":"text","text":" → Defines available functions"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Workflow sequence"},{"type":"text","text":": Request → Tool Request → Data Retrieval → Final Response"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Default tool_choice: auto"},{"type":"text","text":" → Claude decides when to use tools"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"System prompt steers behavior"},{"type":"text","text":" → \"Use tools to investigate\" increases tool use"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"tool_choice: any = hard guarantee"},{"type":"text","text":" → Forces tool call instead of nudge"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"stop_reason: \"tool_use\""},{"type":"text","text":" → Control flow signal for agent logic"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multiple tool_use blocks"},{"type":"text","text":" → Parallel execution for efficiency"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Add strict: true"},{"type":"text","text":" → Ensures schema compliance"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Token overhead"},{"type":"text","text":" → Tool definitions = input tokens, keep focused"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use SDK Tool Runner"},{"type":"text","text":" → Automatic loop handling"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"For your Box Hill distributed systems work, I'd implement "},{"type":"text","marks":[{"type":"bold"}],"text":"default "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_choice: auto"},{"type":"text","marks":[{"type":"bold"}],"text":" + system prompt \"Use the tools to investigate before responding\" + "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"strict: true"},{"type":"text","marks":[{"type":"bold"}],"text":" for schema enforcement"},{"type":"text","text":". This gives you intelligent tool selection while ensuring Claude always checks external data before responding."}]}]}}
