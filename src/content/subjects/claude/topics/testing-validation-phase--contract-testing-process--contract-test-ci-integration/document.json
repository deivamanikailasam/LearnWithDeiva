                  "rowspan": 1,
                  "colwidth": null
                },
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "WIP (work-in-progress) pacts"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {
                  "colspan": 1,
                  "rowspan": 1,
                  "colwidth": null
                },
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Include pacts from feature branches that haven't been merged yet"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {
                  "colspan": 1,
                  "rowspan": 1,
                  "colwidth": null
                },
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "When consumers develop against unreleased provider features"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Pending pacts let consumer teams deploy their changes to the broker without immediately breaking provider CI. The provider will see the pact as pending, attempt verification, and only start failing if verification fails after the first attempt."
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Recording Deployments and Environments"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The can-i-deploy command checks whether all consumers of a provider version are already deployed to the target environment. This requires the broker to know which version is deployed where. Record every deployment with record-deployment."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "bash"
        },
        "content": [
          {
            "type": "text",
            "text": "# After every successful deployment to any environment, record it:\npact-broker record-deployment \\\n  --broker-base-url \"$PACT_BROKER_URL\" \\\n  --broker-token \"$PACT_BROKER_TOKEN\" \\\n  --pacticipant claude-service \\\n  --version \"$DEPLOY_SHA\" \\\n  --environment production  # or: staging, development\n\n# Check before every deployment:\npact-broker can-i-deploy \\\n  --broker-base-url \"$PACT_BROKER_URL\" \\\n  --broker-token \"$PACT_BROKER_TOKEN\" \\\n  --pacticipant claude-service \\\n  --version \"$CANDIDATE_SHA\" \\\n  --to-environment production\n# Exit 0 = safe. Exit 1 = one or more consumer pacts not yet verified.\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Local Development Workflow"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Engineers do not need to run the full broker pipeline locally. The pact files checked into the repo are sufficient for local testing."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "bash"
        },
        "content": [
          {
            "type": "text",
            "text": "# Consumer developer \u2014 generate a new pact locally\ncd chat-frontend\npytest tests/pact/ -v\n# Pact written to pacts/chat-frontend-claude-service.json\n\n# Provider developer \u2014 verify against local pact files (no broker needed)\ncd claude-service\nPACT_DIR=../chat-frontend/pacts \\\nPACT_PROVIDER_VERIFICATION=true \\\npytest tests/pact/verify_pacts_local.py -v\n"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# claude-service/tests/pact/verify_pacts_local.py\n# Lighter version for local dev \u2014 verifies against checked-in pact files\nimport os\nfrom pathlib import Path\nfrom pact import Verifier\nimport uvicorn, threading, time\nfrom app import app\n\nPACT_DIR = os.environ.get(\"PACT_DIR\", \"../../pacts\")\nPROVIDER_PORT = 9090\n\ndef test_verify_local_pacts():\n    config = uvicorn.Config(app, host=\"127.0.0.1\", port=PROVIDER_PORT, log_level=\"error\")\n    server = uvicorn.Server(config)\n    t = threading.Thread(target=server.run, daemon=True); t.start()\n    time.sleep(1)\n\n    verifier = Verifier(\n        provider=\"claude-service\",\n        provider_base_url=f\"http://127.0.0.1:{PROVIDER_PORT}\",\n    )\n    success, _ = verifier.verify_pacts(\n        PACT_DIR,\n        provider_states_setup_url=f\"http://127.0.0.1:{PROVIDER_PORT}/_pact/provider-states\",\n    )\n    assert success == 0\n"
          }
        ]
      },
