ontent":[{"type":"text","text":"Example for complex reasoning:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"First, assess our current content performance and pinpoint gaps. \nNext, identify which topics would deliver most value. \nFinally, formulate a strategy centered on high-value topics.\""}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"When to Use It"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Use thinking models for:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Ambiguous tasks"},{"type":"text","text":" with limited information"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Finding needles in haystacks"},{"type":"text","text":" (large unstructured data)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multi-step agentic planning"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Complex code review/debugging"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Legal/financial analysis"},{"type":"text","text":" requiring nuance"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Don't use for:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Speed/cost prioritized"},{"type":"text","text":" straightforward tasks"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Well-defined execution"},{"type":"text","text":" tasks"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Simple queries"},{"type":"text","text":" that don't require reasoning"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How to Implement"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"API Configuration (Python)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"client.messages.create(\n    model=\"claude-opus-4-8\",\n    max_tokens=64000,\n    thinking={\"type\": \"adaptive\"},  # Use adaptive, not budget_tokens\n    output_config={\"effort\": \"high\"},  # Control thinking depth\n    messages=[{\"role\": \"user\", \"content\": \"...\"}]\n)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Constraining Overthinking"}]},{"type":"paragraph","content":[{"type":"text","text":"Add explicit guidance:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"When deciding how to approach a problem, choose an approach and commit. \nAvoid revisiting decisions unless new information contradicts reasoning. \nPick one approach and see it through.\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Enable Clarifying Questions"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Ask clarifying questions if needed\""}]},{"type":"paragraph","content":[{"type":"text","text":"This lets the model end reasoning early when lacking key info instead of guessing."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Self-Check Appending"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Before you finish, verify your answer against [test criteria].\""}]},{"type":"paragraph","content":[{"type":"text","text":"Catches errors reliably for coding/math."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common Mistakes"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tabl