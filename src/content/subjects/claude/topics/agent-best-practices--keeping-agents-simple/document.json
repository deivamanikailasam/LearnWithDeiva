":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"User: \"Research climate impact of agriculture, write report, generate slides\"\n\nOrchestrator → Research Agent → Writer Agent → Slides Agent → Synthesize"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"The \"Start Simple\" Strategy"}]},{"type":"paragraph","content":[{"type":"text","text":"The recommended progression is:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Start with one agent"},{"type":"text","text":" — Get one working well, understand the basics"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use CLAUDE.md for rules"},{"type":"text","text":" — Capture project rules, coding standards, workflow preferences"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Add complexity only when needed"},{"type":"text","text":" — Don't build five agents on day one"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Validate before scaling"},{"type":"text","text":" — Test single agent thoroughly before adding orchestrator"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key mistake"},{"type":"text","text":": Building complex multi-agent systems before understanding when they're actually needed."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of \"Keep It Simple\" like "},{"type":"text","marks":[{"type":"bold"}],"text":"software architecture"},{"type":"text","text":": you don't start with microservices for a simple CRUD app. You start with a single service, and only add complexity when the load, scale, or requirements actually demand it."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Simple agent architectures are often sufficient—don't default to complex multi-agent systems"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Start with one agent, get it working well, understand the fundamentals"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Simple is more cost-effective: 1x token cost vs 3–4x+ for multi-agent"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Single agents are easier to debug, maintain, and reason about"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Add complexity (orchestrator-workers, parallelization, routing) only when you have clear need"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use CLAUDE.md for rules before building complex agent teams"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Most Claude Code problems are setup problems, not model problems—fix setup first"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"A vague multi-agent CLAUDE.md × 3 agents = 3x noise—keep rules precise"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Don't build five agents on day one—get one working well first"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Simple is often sufficient; complex multi-agent setups often cost more without better results"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"The principle is: "},{"type":"text","marks":[{"type":"bold"}],"text":"prefer simple architectures unless you have a clear, justified need for complexity"},{"type":"text","text":"—most tasks don't require multi-agent systems, and simple is often the better choice."}]}]}}
