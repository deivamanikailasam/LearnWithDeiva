      {
        "type": "codeBlock",
        "attrs": {
          "language": "yaml"
        },
        "content": [
          {
            "type": "text",
            "text": "# .github/workflows/emergency-rollback.yml\n# Rollback to a previous approved build \u2014 no approval gate required\nname: Emergency Rollback\non:\n  workflow_dispatch:\n    inputs:\n      target_build_sha:\n        description: \"Build SHA to roll back to (must have a prior production_approved audit event)\"\n        required: true\n\njobs:\n  rollback:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n\n      - name: Verify prior approval exists\n        run: |\n          python3 scripts/audit_log.py query             --build-sha ${{ inputs.target_build_sha }}           | grep \"production_approved\" || (echo \"No prior approval found\" && exit 1)\n\n      - name: Execute rollback\n        env:\n          KUBECONFIG: ${{ secrets.PROD_KUBECONFIG }}\n        run: python3 scripts/rollback.py prod ${{ secrets.PROD_KUBECONFIG }} ${{ github.sha }}\n\n      - name: Record rollback in audit log\n        run: |\n          python3 scripts/audit_log.py append             --event \"rollback_initiated\"             --build-sha ${{ inputs.target_build_sha }}             --approver \"${{ github.actor }}\"             --reason \"Emergency rollback via workflow_dispatch\"             --run-id \"${{ github.run_id }}\"\n"
          }
        ]
