        "content": [
          {
            "type": "text",
            "text": "The Audit Log"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The audit log is an append-only record of every significant deployment event. It is the source of truth for compliance reviews, incident attribution, and rollback decisions."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# scripts/audit_log.py\n\"\"\"Append-only audit log for deployment events.\"\"\"\nimport json, pathlib, datetime, hashlib, argparse, sys\n\nAUDIT_LOG_PATH = pathlib.Path(\"audit_log.jsonl\")   # JSONL: one event per line\n\nVALID_EVENTS = {\n    \"build_created\",\n    \"gate_passed\",\n    \"gate_failed\",\n    \"production_approved\",\n    \"production_rejected\",\n    \"deployment_started\",\n    \"deployment_completed\",\n    \"deployment_failed\",\n    \"canary_promoted\",\n    \"rollback_initiated\",\n    \"rollback_completed\",\n}\n\ndef append_event(event: str, build_sha: str, approver: str = \"\", reason: str = \"\",\n                 run_id: str = \"\", extra: dict | None = None):\n    if event not in VALID_EVENTS:\n        raise ValueError(f\"Unknown audit event: {event!r}\")\n\n    record = {\n        \"timestamp\": datetime.datetime.utcnow().isoformat() + \"Z\",\n        \"event\": event,\n        \"build_sha\": build_sha,\n        \"approver\": approver,\n        \"reason\": reason,\n        \"run_id\": run_id,\n        **(extra or {}),\n    }\n    # Chain hash: each record hashes the previous record's hash for tamper detection\n    prev_hash = _last_hash()\n    record[\"prev_hash\"] = prev_hash\n    record_json = json.dumps(record, sort_keys=True, separators=(\",\", \":\"))\n    record[\"record_hash\"] = hashlib.sha256(record_json.encode()).hexdigest()\n\n    with AUDIT_LOG_PATH.open(\"a\") as f:\n        f.write(json.dumps(record) + \"\\n\")\n    return record\n\ndef _last_hash() -> str:\n    if not AUDIT_LOG_PATH.exists():\n        return \"genesis\"\n    lines = AUDIT_LOG_PATH.read_text().strip().splitlines()\n    if not lines:\n        return \"genesis\"\n    return json.loads(lines[-1]).get(\"record_hash\", \"unknown\")\n\ndef query_by_build(build_sha: str) -> list[dict]:\n    \"\"\"Return all audit events for a given build SHA.\"\"\"\n    if not AUDIT_LOG_PATH.exists():\n        return []\n    return [\n        json.loads(line)\n        for line in AUDIT_LOG_PATH.read_text().splitlines()\n        if json.loads(line).get(\"build_sha\") == build_sha\n    ]\n\ndef verify_chain() -> tuple[bool, str]:\n    \"\"\"Verify that no record has been tampered with.\"\"\"\n    if not AUDIT_LOG_PATH.exists():\n        return True, \"Empty log\"\n    records = [json.loads(line) for line in AUDIT_LOG_PATH.read_text().splitlines()]\n    prev_hash = \"genesis\"\n    for i, r in enumerate(records):\n        if r.get(\"prev_hash\") != prev_hash:\n            return False, f\"Chain broken at record {i}: expected prev_hash={prev_hash!r}\"\n        prev_hash = r.get(\"record_hash\", \"\")\n    return True, f\"Chain intact ({len(records)} records)\"\n\nif __name__ == \"__main__\":\n    parser = argparse.ArgumentParser()\n    subparsers = parser.add_subparsers(dest=\"cmd\")\n    ap = subparsers.add_parser(\"append\")\n    ap.add_argument(\"--event\"); ap.add_argument(\"--build-sha\"); ap.add_argument(\"--approver\", default=\"\")\n    ap.add_argument(\"--reason\", default=\"\"); ap.add_argument(\"--run-id\", default=\"\")\n    vp = subparsers.add_parser(\"verify\")\n    qp = subparsers.add_parser(\"query\"); qp.add_argument(\"--build-sha\")\n    args = parser.parse_args()\n    if args.cmd == \"append\":\n        r = append_event(args.event, args.build_sha, args.approver, args.reason, args.run_id)\n        print(f\"Appended: {r['event']} ({r['record_hash'][:12]}...)\")\n    elif args.cmd == \"verify\":\n        ok, msg = verify_chain()\n        print(msg); sys.exit(0 if ok else 1)\n    elif args.cmd == \"query\":\n        for r in query_by_build(args.build_sha):\n            print(json.dumps(r, indent=2))\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Querying the Audit Trail"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The audit trail supports two core queries: the deployment history for a specific build (used during incident response) and the list of all approvers for a time window (used for compliance reports)."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# scripts/audit_report.py\n\"\"\"Generate human-readable audit reports from the JSONL log.\"\"\"\nimport json, pathlib, datetime\nfrom collections import defaultdict\n\nAUDIT_LOG_PATH = pathlib.Path(\"audit_log.jsonl\")\n\ndef deployment_history(build_sha: str) -> str:\n    \"\"\"Print the full lifecycle of a specific build \u2014 for incident response.\"\"\"\n    records = [\n        json.loads(line)\n        for line in AUDIT_LOG_PATH.read_text().splitlines()\n        if json.loads(line).get(\"build_sha\") == build_sha\n    ]\n    if not records:\n        return f\"No audit events for build {build_sha}\"\n\n    lines = [f\"Audit history for build {build_sha}\", \"=\" * 60]\n    for r in records:\n        approver = f\" (by {r['approver']})\" if r.get(\"approver\") else \"\"\n        reason = f\" \u2014 {r['reason']}\" if r.get(\"reason\") else \"\"\n        lines.append(f\"  {r['timestamp']}  {r['event']}{approver}{reason}\")\n    return \"\\n\".join(lines)\n\ndef approver_report(since_date: str) -> str:\n    \"\"\"List every production approval since a given date \u2014 for compliance.\"\"\"\n    since = datetime.datetime.fromisoformat(since_date)\n    records = [\n        json.loads(line)\n        for line in AUDIT_LOG_PATH.read_text().splitlines()\n        if json.loads(line).get(\"event\") == \"production_approved\"\n        and datetime.datetime.fromisoformat(json.loads(line)[\"timestamp\"].rstrip(\"Z\")) >= since\n    ]\n\n    by_approver = defaultdict(list)\n    for r in records:\n        by_approver[r.get(\"approver\", \"unknown\")].append(r)\n\n    lines = [f\"Production approvals since {since_date}\", \"=\" * 60]\n    for approver, events in by_approver.items():\n        lines.append(f\"  {approver}: {len(events)} approvals\")\n        for e in events:\n            lines.append(f\"    {e['timestamp']}  build={e['build_sha'][:8]}\")\n    return \"\\n\".join(lines)\n"
          }
        ]
      },
