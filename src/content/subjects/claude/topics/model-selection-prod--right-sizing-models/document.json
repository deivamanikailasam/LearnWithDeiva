            "type": "text",
            "text": "import random\n\nSAMPLE_RATE = 0.05  # Score 5% of production traffic\n\ndef monitored_complete(user_message: str, model: str, scorer) -> str:\n    resp = client.messages.create(\n        model=model,\n        max_tokens=1024,\n        messages=[{\"role\": \"user\", \"content\": user_message}],\n    )\n    output = resp.content[0].text\n\n    # Sample for quality scoring\n    if random.random() < SAMPLE_RATE:\n        score = scorer(user_message, output)\n        log_quality_metric(model=model, score=score, input_tokens=resp.usage.input_tokens)\n        # Alert if rolling average drops below threshold\n        check_quality_threshold(model=model)\n\n    return output\n"
