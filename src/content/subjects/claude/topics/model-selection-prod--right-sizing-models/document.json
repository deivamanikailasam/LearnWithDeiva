      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Automated Tier Benchmarking"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\nimport statistics\nfrom typing import Callable\n\nclient = anthropic.Anthropic()\n\nMODELS = [\"claude-haiku-4-5\", \"claude-sonnet-4-6\", \"claude-opus-4-8\"]\n\ndef benchmark_tiers(\n    prompts: list[str],\n    system: str,\n    scorer: Callable[[str, str], float],  # (input, output) -> 0.0-1.0\n    max_tokens: int = 512,\n) -> dict[str, dict]:\n    \"\"\"\n    Run prompts through all three tiers and score outputs.\n    scorer: your quality function \u2014 LLM judge, regex check, exact match, etc.\n    Returns per-model stats.\n    \"\"\"\n    results = {}\n\n    for model in MODELS:\n        scores = []\n        tokens_in = []\n        tokens_out = []\n\n        for prompt in prompts:\n            resp = client.messages.create(\n                model=model,\n                max_tokens=max_tokens,\n                system=system,\n                messages=[{\"role\": \"user\", \"content\": prompt}],\n            )\n            output = resp.content[0].text\n            score = scorer(prompt, output)\n            scores.append(score)\n            tokens_in.append(resp.usage.input_tokens)\n            tokens_out.append(resp.usage.output_tokens)\n\n        results[model] = {\n            \"pass_rate\":   sum(1 for s in scores if s >= 0.8) / len(scores),\n            \"mean_score\":  round(statistics.mean(scores), 3),\n            \"p10_score\":   round(sorted(scores)[len(scores)//10], 3),\n            \"avg_input_t\": round(statistics.mean(tokens_in)),\n            \"avg_output_t\": round(statistics.mean(tokens_out)),\n        }\n\n    return results\n\n\n# Example: classification scorer\ndef classification_scorer(input_text: str, output: str) -> float:\n    expected = get_ground_truth_label(input_text)  # your ground-truth function\n    predicted = output.strip().lower()\n    return 1.0 if predicted == expected else 0.0\n"
          }
        ]
      },
