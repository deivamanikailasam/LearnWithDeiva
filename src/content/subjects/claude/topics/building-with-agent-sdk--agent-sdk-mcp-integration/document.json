{"format":"tiptap/v1","updatedAt":"2026-06-22T06:23:26.545Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Based on the official documentation for the Claude Agent SDK, "},{"type":"text","marks":[{"type":"bold"}],"text":"\"MCP Integration\""},{"type":"text","text":" refers to "},{"type":"text","marks":[{"type":"bold"}],"text":"the Model Context Protocol (MCP) feature that extends Claude Code with custom tools and capabilities through MCP servers"},{"type":"text","text":", enabling your AI agents to interact with external systems, APIs, databases, and services beyond the built-in tools."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What MCP Is"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Server Model Context Protocol (MCP) extends Claude Code with custom tools and capabilities"},{"type":"text","text":"."}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Built-in tools (Read, Write, Bash, WebSearch)\n    ↓\nMCP adds custom tools\n    ↓\nAgent can now: send emails, update CRM, call APIs, query databases"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key capability"},{"type":"text","text":": \"This is crucial for giving your agent real control over accounts through MCP servers\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"MCP Server Types"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Three Deployment Modes"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Mode"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"How It Runs"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Communication"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"External process"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Separate process running independently"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"stdin/stdout (local)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"HTTP/SSE"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Remote server accessible via URL"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Network (HTTP or SSE)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"In-process"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Runs directly within your SDK application"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Embedded in app"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"[platform.claude](https://platform.claude.com/docs/id/agent-sdk/mcp)"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Configuration"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Using "},{"type":"text","marks":[{"type":"code"}],"text":".mcp.json"},{"type":"text","text":" File"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Configure MCP servers in "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":".mcp.json"},{"type":"text","text":" at your project root:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"mcpServers\": {\n    \"filesystem\": {\n      \"command\": \"npx\",\n      \"args\": [\"@modelcontextprotocol/server-filesystem\"],\n      \"env\": {\n        \"ALLOWED_PATHS\": \"/Users/me/projects\"\n      }\n    }\n  }\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"External Process Example"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"mcpServers\": {\n    \"my-tool\": {\n      \"command\": \"node\",\n      \"args\": [\"./my-mcp-server.js\"],\n      \"env\": {\n        \"DEBUG\": \"${DEBUG:-false}\"\n      }\n    }\n  }\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Process"},{"type":"text","text":": External process communicating via stdin/stdout."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Remote SSE Server"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"mcpServers\": {\n    \"remote-api\": {\n      \"type\": \"sse\",\n      \"url\": \"https://api.example.com/mcp/sse\",\n      \"headers\": {\n        \"Authorization\": \"Bearer ${API_TOKEN}\"\n      }\n    }\n  }\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Remote HTTP Server"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"mcpServers\": {\n    \"http-service\": {\n      \"type\": \"http\",\n      \"url\": \"https://api.example.com/mcp\",\n      \"headers\": {\n        \"X-API-Key\": \"${API_KEY}\"\n      }\n    }\n  }\n}"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Using MCP in Code"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Basic Query with MCP"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import { query } from \"@anthropic-ai/claude-agent-sdk\";\n\nfor await (const message of query({\n  prompt: \"List files in my project\",\n  options: {\n    mcpServers: {\n      \"filesystem\": {\n        command: \"npx\",\n        args: [\"@modelcontextprotocol/server-filesystem\"],\n        env: {\n          ALLOWED_PATHS: \"/Users/me/projects\"\n        }\n      }\n    },\n    allowedTools: [\"mcp__filesystem__list_files\"]\n  }\n})) {\n  if (message.type === \"result\" && message.subtype === \"success\") {\n    console.log(message.result);\n  }\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Using Resources (Database Example)"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import { query } from \"@anthropic-ai/claude-agent-sdk\";\n\n// List available resources\nfor await (const message of query({\n  prompt: \"What resources are available from the database server?\",\n  options: {\n    mcpServers: {\n      \"database\": {\n        command: \"npx\",\n        args: [\"@modelcontextprotocol/server-database\"]\n      }\n    },\n    allowedTools: [\"mcp__list_resources\", \"mcp__read_resource\"]\n  }\n})) {\n  if (message.type === \"result\") console.log(message.result);\n}"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Environment Variables"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Configuration with Env Vars"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"mcpServers\": {\n    \"secure-api\": {\n      \"type\": \"sse\",\n      \"url\": \"https://api.example.com/mcp\",\n      \"headers\": {\n        \"Authorization\": \"Bearer ${API_TOKEN}\",\n        \"X-API-Key\": \"${API_KEY:-default-key}\"\n      }\n    }\n  }\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Set environment variables"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"process.env.API_TOKEN = \"your-token\";\nprocess.env.API_KEY = \"your-key\";"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Error Handling"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Handle MCP Connection Failures"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import { query } from \"@anthropic-ai/claude-agent-sdk\";\n\nfor await (const message of query({\n  prompt: \"Process data\",\n  options: {\n    mcpServers: {\n      \"data-processor\": dataServer\n    }\n  }\n})) {\n  // Check MCP server status\n  if (message.type === \"system\" && message.subtype === \"init\") {\n    const failedServers = message.mcp_servers.filter(\n      s => s.status !== \"connected\"\n    );\n    if (failedServers.length > 0) {\n      console.warn(\"Failed to connect:\", failedServers);\n    }\n  }\n  \n  // Handle execution errors\n  if (message.type === \"result\" && message.subtype === \"error_during_execution\") {\n    console.error(\"Execution failed\");\n  }\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key"},{"type":"text","text":": \"Handle MCP connection failures well\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Tool Names"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"MCP Tool Naming Convention"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"mcp__{server_name}__{tool_name}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Examples"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"code"}],"text":"mcp__filesystem__list_files"},{"type":"text","text":" - Filesystem server, list files tool\n- "},{"type":"text","marks":[{"type":"code"}],"text":"mcp__list_resources"},{"type":"text","text":" - List resources tool\n- "},{"type":"text","marks":[{"type":"code"}],"text":"mcp__read_resource"},{"type":"text","text":" - Read resource tool"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Real-World Examples"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example 1: Make MCP with Composio"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Connect agent to Make account"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// Get and set up API keys\n// Install Composio SDK and Claude Agents SDK\n// Create Tool Router session for Make\n// Configure AI agent that can use Make as tool"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Capabilities"},{"type":"text","text":":\n- Get all available Make operations\n- Show supported languages for Make automations\n- List all timezones used in Make"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key features"},{"type":"text","text":":\n- Native MCP support through Claude's agent framework\n- Streaming responses for real-time interaction\n- Permission bypass for smooth automated workflows"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example 2: Bright Data Web MCP"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Web scraping integration"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// Connect Claude Agent SDK to Bright Data's Web MCP\n// Step-by-step tutorial with web scraping examples"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"MCP Resources"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Resources vs Tools"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"MCP servers can expose:\n- Resources (can be registered and read by Claude) [web:363]\n- Tools (can be called by Claude) [web:363]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": Database server exposes resources that Claude can read."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Limitations"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Current Limitations"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Limitation"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Description"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"OAuth2 support"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"MCP OAuth2 authentication in client is not currently supported"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tool routing"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tool router generates secure MCP URL for agent access"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"[platform.claude](https://platform.claude.com/docs/id/agent-sdk/mcp)"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of MCP integration like "},{"type":"text","marks":[{"type":"bold"}],"text":"adding smartphone apps to a phone"},{"type":"text","text":": Claude Code is the base phone (phones calls, sends messages). MCP is like installing apps (WhatsApp, Spotify, calendar) — you download the app (MCP server), configure it ("},{"type":"text","marks":[{"type":"code"}],"text":".mcp.json"},{"type":"text","text":"), and then the phone can do new things (send WhatsApp messages, play music, check calendar). Each app is independent, can be remote or local, and the phone just needs to know how to talk to it (protocol)."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"MCP = Model Context Protocol, extends Claude Code with custom tools/capabilities"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Three modes: External process (stdin/stdout), HTTP/SSE (remote), In-process (embedded)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Configure in "},{"type":"text","marks":[{"type":"code"}],"text":".mcp.json"},{"type":"text","text":" at project root: mcpServers with command, args, env"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Tool naming: "},{"type":"text","marks":[{"type":"code"}],"text":"mcp__{server}__{tool}"},{"type":"text","text":" (e.g., "},{"type":"text","marks":[{"type":"code"}],"text":"mcp__filesystem__list_files"},{"type":"text","text":")"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use in code: "},{"type":"text","marks":[{"type":"code"}],"text":"query()"},{"type":"text","text":" with "},{"type":"text","marks":[{"type":"code"}],"text":"mcpServers"},{"type":"text","text":" config + "},{"type":"text","marks":[{"type":"code"}],"text":"allowedTools"},{"type":"text","text":" array"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Environment variables: `"},{"type":"inlineMath","attrs":{"latex":"{API_TOKEN}` or `"}},{"type":"text","text":"{API_KEY:-default-key}` in config"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Error handling: Check "},{"type":"text","marks":[{"type":"code"}],"text":"message.mcp_servers"},{"type":"text","text":" for failed connections"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Real-world: Make MCP (Composio), Bright Data Web MCP for web scraping"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Resources: MCP servers expose resources (can be read) + tools (can be called)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Limitation: OAuth2 authentication in client not currently supported"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"\"MCP is crucial for giving your agent real control over accounts through MCP servers\" — enabling agents to interact with external systems like Make, databases, APIs beyond built-in tools."}]}]}}
