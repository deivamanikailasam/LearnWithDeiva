      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Ingestion Pipeline"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Loading and Chunking"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# ingestion/chunker.py\nfrom __future__ import annotations\nimport re\nfrom dataclasses import dataclass\n\nCHUNK_SIZE = 512      # tokens (approximated as chars / 4)\nOVERLAP = 0.10        # 10 % of chunk size\n\n\n@dataclass\nclass Chunk:\n    text: str\n    source: str    # document URL or path\n    page: int\n    acl_groups: list[str]  # groups allowed to see this document\n\n\ndef chunk(text: str, source: str, page: int = 0, acl_groups: list[str] | None = None) -> list[Chunk]:\n    acl_groups = acl_groups or []\n    step = int(CHUNK_SIZE * 4)\n    overlap = int(step * OVERLAP)\n    chunks = []\n    start = 0\n    while start < len(text):\n        end = min(start + step, len(text))\n        # Prefer splitting on paragraph or sentence boundary\n        boundary = text.rfind(\"\\n\\n\", start, end)\n        if boundary == -1:\n            boundary = text.rfind(\". \", start, end)\n        if boundary != -1 and boundary > start + step // 2:\n            end = boundary + 1\n        chunks.append(Chunk(text=text[start:end].strip(), source=source, page=page, acl_groups=acl_groups))\n        start = end - overlap\n    return chunks\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Embedding and Indexing"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# ingestion/embedder.py\nimport openai, numpy as np\nfrom typing import Sequence\nfrom .chunker import Chunk\n\n_client = openai.OpenAI()\nEMBED_MODEL = \"text-embedding-3-large\"\nBATCH_SIZE = 100\n\n\ndef embed_chunks(chunks: Sequence[Chunk]) -> list[tuple[Chunk, list[float]]]:\n    \"\"\"Return (chunk, vector) pairs in the same order as input.\"\"\"\n    results = []\n    for i in range(0, len(chunks), BATCH_SIZE):\n        batch = chunks[i : i + BATCH_SIZE]\n        resp = _client.embeddings.create(\n            model=EMBED_MODEL,\n            input=[c.text for c in batch],\n        )\n        for chunk, embedding_obj in zip(batch, resp.data):\n            results.append((chunk, embedding_obj.embedding))\n    return results\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Query Service"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Hybrid Retrieval with RRF"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# retrieval/reranker.py\nfrom __future__ import annotations\n\nRRF_K = 60  # standard constant for Reciprocal Rank Fusion\n\n\ndef reciprocal_rank_fusion(\n    dense_ids: list[str],\n    sparse_ids: list[str],\n) -> list[str]:\n    \"\"\"Return chunk IDs ranked by combined RRF score (dense + sparse).\"\"\"\n    scores: dict[str, float] = {}\n    for rank, doc_id in enumerate(dense_ids):\n        scores[doc_id] = scores.get(doc_id, 0.0) + 1.0 / (RRF_K + rank + 1)\n    for rank, doc_id in enumerate(sparse_ids):\n        scores[doc_id] = scores.get(doc_id, 0.0) + 1.0 / (RRF_K + rank + 1)\n    return sorted(scores, key=lambda d: scores[d], reverse=True)\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Claude Prompt with Citations"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# service/prompt.py\nfrom __future__ import annotations\nfrom dataclasses import dataclass\n\n@dataclass\nclass RetrievedChunk:\n    text: str\n    source: str\n    score: float\n\n\nSYSTEM_PROMPT = \"\"\"You are an enterprise knowledge assistant. Answer the user's question\nusing ONLY the provided context chunks. For every claim, cite the source document\nusing [1], [2], etc. If the context does not contain sufficient information to answer,\nsay \"I don't have enough information in the provided documents to answer this.\"\nNever make up information not present in the context.\"\"\"\n\n\ndef build_prompt(query: str, chunks: list[RetrievedChunk]) -> list[dict]:\n    context_parts = []\n    for i, chunk in enumerate(chunks, 1):\n        context_parts.append(f\"[{i}] Source: {chunk.source}\\n{chunk.text}\")\n    context = \"\\n\\n---\\n\\n\".join(context_parts)\n    return [\n        {\n            \"role\": \"user\",\n            \"content\": f\"Context:\\n{context}\\n\\nQuestion: {query}\",\n        }\n    ]\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "FastAPI Handler"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# service/handler.py\nimport anthropic\nfrom fastapi import FastAPI, Depends, HTTPException\nfrom pydantic import BaseModel\nfrom .auth import get_current_user_groups\nfrom .prompt import build_prompt, RetrievedChunk\nfrom retrieval.dense import dense_search\nfrom retrieval.sparse import bm25_search\nfrom retrieval.reranker import reciprocal_rank_fusion\n\napp = FastAPI()\nclaude = anthropic.Anthropic()\nMODEL = \"claude-sonnet-5\"\nTOP_K = 8\n\n\nclass QueryRequest(BaseModel):\n    question: str\n\n\n@app.post(\"/query\")\nasync def query(req: QueryRequest, user_groups: list[str] = Depends(get_current_user_groups)):\n    # Retrieve with ACL filtering applied at the vector store layer\n    dense_ids = dense_search(req.question, top_k=TOP_K * 2, acl_groups=user_groups)\n    sparse_ids = bm25_search(req.question, top_k=TOP_K * 2, acl_groups=user_groups)\n    ranked_ids = reciprocal_rank_fusion(dense_ids, sparse_ids)[:TOP_K]\n\n    chunks = [load_chunk(cid) for cid in ranked_ids]  # fetch chunk text from store\n    messages = build_prompt(req.question, [RetrievedChunk(c.text, c.source, 1.0) for c in chunks])\n\n    response = claude.messages.create(\n        model=MODEL,\n        max_tokens=1024,\n        system=build_prompt.__doc__,\n        messages=messages,\n    )\n    return {\"answer\": response.content[0].text, \"sources\": [c.source for c in chunks]}\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "CI Gate: Retrieval Recall Eval"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The golden path requires a "
          },
          {
            "type": "text",
            "text": "retrieval_recall",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " eval in CI: for each question in "
          },
          {
            "type": "text",
            "text": "evals/cases/seed.jsonl",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ", the expected source document must appear in the top-"
          },
          {
            "type": "text",
            "text": "K",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " retrieved chunks. A recall below 80 % fails the build."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# evals/runner.py\nimport json, sys\nfrom pathlib import Path\nfrom retrieval.dense import dense_search\nfrom retrieval.sparse import bm25_search\nfrom retrieval.reranker import reciprocal_rank_fusion\n\nTOP_K = 8\nRECALL_THRESHOLD = 0.80\n\n\ndef run_eval(cases_path: Path) -> float:\n    cases = [json.loads(l) for l in cases_path.read_text().splitlines() if l.strip()]\n    hits = 0\n    for case in cases:\n        q = case[\"question\"]\n        expected_source = case[\"expected_source\"]\n        dense_ids = dense_search(q, top_k=TOP_K * 2, acl_groups=[])\n        sparse_ids = bm25_search(q, top_k=TOP_K * 2, acl_groups=[])\n        ranked = reciprocal_rank_fusion(dense_ids, sparse_ids)[:TOP_K]\n        if any(expected_source in cid for cid in ranked):\n            hits += 1\n    recall = hits / len(cases)\n    print(f\"Retrieval recall: {recall:.0%} ({hits}/{len(cases)})\")\n    return recall\n\n\nif __name__ == \"__main__\":\n    recall = run_eval(Path(\"evals/cases/seed.jsonl\"))\n    if recall < RECALL_THRESHOLD:\n        print(f\"FAIL: recall {recall:.0%} < {RECALL_THRESHOLD:.0%} threshold\")\n        sys.exit(1)\n    print(\"PASS\")\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Access Control: ACL Filtering at Retrieval Time"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Enterprise RAG must enforce document-level access control. The golden path implements this by storing "
          },
          {
            "type": "text",
            "text": "acl_groups",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " alongside each chunk in the vector store and filtering at query time — before any document text reaches Claude. This prevents Claude from revealing restricted information even if prompted to ignore safety instructions."
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Filter at retrieval time, not prompt time. Adding 'do not reveal confidential documents' to the system prompt is not a security control — it is easily bypassed by prompt injection in the user query. The vector store WHERE clause is the actual security boundary."
              }
            ]
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "-- pgvector retrieval with ACL filter (parameterized)\nSELECT id, text, source,\n       embedding <-> $1::vector AS distance\nFROM document_chunks\nWHERE acl_groups && $2::text[]   -- chunks tagged with at least one of the user's groups\nORDER BY distance\nLIMIT $3;\n"
          }
        ]
      },
