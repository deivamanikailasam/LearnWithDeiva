        },
        "content": [
          {
            "type": "text",
            "text": "my-rag-service/\n├── ingestion/\n│   ├── loader.py          # Pull docs from S3, Confluence, or SharePoint\n│   ├── chunker.py         # Recursive character splitter (512 tokens)\n│   ├── embedder.py        # Batch embedding via text-embedding-3-large\n│   └── indexer.py         # Upsert chunks + metadata to vector store\n├── retrieval/\n│   ├── dense.py           # pgvector / OpenSearch dense retrieval\n│   ├── sparse.py          # BM25 sparse retrieval\n│   └── reranker.py        # Reciprocal Rank Fusion (RRF)\n├── service/\n│   ├── handler.py         # FastAPI endpoint; calls retrieval + Claude\n│   ├── prompt.py          # Prompt builder with citations\n│   └── auth.py            # JWT validation + ACL filter injection\n├── evals/\n│   ├── cases/seed.jsonl   # 10+ QA pairs with expected answer + source doc\n│   └── runner.py          # Eval harness: retrieval recall + answer fidelity\n├── prompts/\n│   └── rag_qa.yaml        # Versioned system prompt\n├── .github/workflows/\n│   └── ci.yml             # Ingestion test, eval gate, deploy\n├── IDP_catalog.yml\n└── copier.yml             # Template variables for scaffold regeneration\n"
          }
