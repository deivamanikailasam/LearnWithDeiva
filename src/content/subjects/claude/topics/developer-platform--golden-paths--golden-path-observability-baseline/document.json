          {
            "type": "text",
            "text": "Golden Path Observability and Security Baseline"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Every service generated from a Claude golden path scaffold ships with a mandatory "
          },
          {
            "type": "text",
            "text": "observability and security baseline",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": ": structured logging, distributed tracing, Prometheus metrics, and security controls wired up from the first commit. Teams cannot opt out of the baseline without platform team approval — consistency across the fleet is what makes cross-service dashboards, alerts, and audits possible."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Observability stack: service → OTel collector → logs/traces/metrics backends + security layer",
          "title": null
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Structured Logging"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "All services must emit JSON-structured logs with a common schema. Plain-text logs are not accepted because they cannot be queried, alerted on, or aggregated across services."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Shared logging module — included in every scaffold\nimport logging, json, time, os\n\nclass StructuredLogger:\n    SERVICE = os.environ.get(\"SERVICE_NAME\", \"unknown-service\")\n    ENV = os.environ.get(\"ENVIRONMENT\", \"dev\")\n\n    def __init__(self, name: str):\n        self._log = logging.getLogger(name)\n        if not self._log.handlers:\n            handler = logging.StreamHandler()\n            handler.setFormatter(logging.Formatter(\"%(message)s\"))\n            self._log.addHandler(handler)\n            self._log.setLevel(logging.INFO)\n\n    def _emit(self, level: str, event: str, **fields):\n        record = {\n            \"ts\": time.time(),\n            \"level\": level,\n            \"service\": self.SERVICE,\n            \"env\": self.ENV,\n            \"event\": event,\n            **fields,\n        }\n        self._log.info(json.dumps(record))\n\n    def info(self, event: str, **fields): self._emit(\"info\", event, **fields)\n    def warning(self, event: str, **fields): self._emit(\"warning\", event, **fields)\n    def error(self, event: str, **fields): self._emit(\"error\", event, **fields)\n\n\n# Usage in service code\nlog = StructuredLogger(__name__)\n\nlog.info(\"claude_call\", model=\"claude-sonnet-5\", input_tokens=342, latency_ms=820)\nlog.error(\"claude_call_failed\", error=\"rate_limit\", retry_after_s=15)\n"
          }
        ]
      },
