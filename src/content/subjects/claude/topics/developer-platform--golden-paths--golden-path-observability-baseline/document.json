      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Distributed Tracing with OpenTelemetry"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The scaffold configures OpenTelemetry on startup and wraps every Claude API call and tool execution in a span. This links a single user request across the retrieval step, the Claude call, and any downstream tool calls into one trace."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# telemetry/tracing.py — included in every scaffold\nfrom opentelemetry import trace\nfrom opentelemetry.sdk.trace import TracerProvider\nfrom opentelemetry.sdk.trace.export import BatchSpanProcessor\nfrom opentelemetry.exporter.otlp.proto.grpc.trace_exporter import OTLPSpanExporter\nimport os, anthropic\n\ndef configure_tracing(service_name: str) -> None:\n    provider = TracerProvider()\n    provider.add_span_processor(\n        BatchSpanProcessor(OTLPSpanExporter(\n            endpoint=os.environ[\"OTEL_EXPORTER_OTLP_ENDPOINT\"]\n        ))\n    )\n    trace.set_tracer_provider(provider)\n\ntracer = trace.get_tracer(\"claude-service\")\n\ndef traced_claude_call(model: str, messages: list, **kwargs) -> anthropic.types.Message:\n    with tracer.start_as_current_span(\"claude.messages.create\") as span:\n        span.set_attribute(\"claude.model\", model)\n        span.set_attribute(\"claude.message_count\", len(messages))\n        client = anthropic.Anthropic()\n        response = client.messages.create(model=model, messages=messages, **kwargs)\n        span.set_attribute(\"claude.input_tokens\", response.usage.input_tokens)\n        span.set_attribute(\"claude.output_tokens\", response.usage.output_tokens)\n        return response\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Prometheus Metrics"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Three counters and two histograms are required in every service. They feed the standard Grafana dashboard that the platform team maintains for all Claude services."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# telemetry/metrics.py\nfrom prometheus_client import Counter, Histogram, start_http_server\n\n# Required counters\nrequests_total = Counter(\"claude_service_requests_total\",\n    \"Total requests\", [\"service\", \"model\", \"status\"])\n\ntokens_total = Counter(\"claude_service_tokens_total\",\n    \"Total tokens consumed\", [\"service\", \"model\", \"direction\"])   # direction: input/output\n\ntool_calls_total = Counter(\"claude_service_tool_calls_total\",\n    \"Total tool calls\", [\"service\", \"tool_name\", \"outcome\"])      # outcome: success/rejected/error\n\n# Required histograms\nlatency_seconds = Histogram(\"claude_service_latency_seconds\",\n    \"Claude API call latency\", [\"service\", \"model\"],\n    buckets=[0.1, 0.5, 1.0, 2.0, 5.0, 10.0, 30.0])\n\ntokens_per_request = Histogram(\"claude_service_tokens_per_request\",\n    \"Token count per request\", [\"service\", \"direction\"],\n    buckets=[100, 500, 1000, 2000, 5000, 10000, 50000])\n\ndef init_metrics(port: int = 9090) -> None:\n    start_http_server(port)   # Prometheus scrapes /metrics on this port\n"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Label cardinality matters. Never use user IDs, session IDs, or query text as metric labels — high-cardinality labels create millions of time series and crash Prometheus. Only use low-cardinality labels: service, model, status, tool_name."
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Standard Alerts"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The golden path scaffold includes a "
          },
          {
            "type": "text",
            "text": "monitoring/alerts.yml",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " file with four required alerts pre-wired. Teams can add service-specific alerts but cannot remove these."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "yaml"
        },
        "content": [
          {
            "type": "text",
            "text": "# monitoring/alerts.yml — Prometheus alerting rules\ngroups:\n  - name: claude_service_baseline\n    rules:\n      - alert: HighErrorRate\n        expr: |\n          rate(claude_service_requests_total{status=\"error\"}[5m])\n          / rate(claude_service_requests_total[5m]) > 0.05\n        for: 5m\n        labels:\n          severity: warning\n        annotations:\n          summary: \"{{ $labels.service }} error rate > 5% for 5 min\"\n\n      - alert: HighP95Latency\n        expr: |\n          histogram_quantile(0.95,\n            rate(claude_service_latency_seconds_bucket[5m])\n          ) > 10\n        for: 5m\n        labels:\n          severity: warning\n        annotations:\n          summary: \"{{ $labels.service }} p95 latency > 10s\"\n\n      - alert: TokenBudgetExceeded\n        expr: |\n          increase(claude_service_tokens_total{direction=\"input\"}[1h]) > 500000\n        labels:\n          severity: critical\n        annotations:\n          summary: \"{{ $labels.service }} consumed > 500k input tokens in 1h\"\n\n      - alert: ServiceDown\n        expr: up{job=\"{{ service_name }}\"} == 0\n        for: 2m\n        labels:\n          severity: critical\n        annotations:\n          summary: \"{{ $labels.service }} is not responding to Prometheus scrape\"\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Security Baseline"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Secrets Management"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "No secret — API key, database password, or OAuth token — may appear in source code, environment variables baked into Docker images, or CI logs. The golden path requires all secrets to be fetched at runtime from a secrets manager."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# config/secrets.py — scaffold includes this; services import it\nimport boto3, json, os, functools\n\n_sm = boto3.client(\"secretsmanager\", region_name=os.environ.get(\"AWS_REGION\", \"us-east-1\"))\n\n@functools.lru_cache(maxsize=None)\ndef get_secret(secret_name: str) -> dict:\n    \"\"\"Fetch and parse a JSON secret. Cached per process lifetime.\"\"\"\n    raw = _sm.get_secret_value(SecretId=secret_name)\n    return json.loads(raw[\"SecretString\"])\n\n# Usage\ndef get_anthropic_key() -> str:\n    return get_secret(os.environ[\"ANTHROPIC_SECRET_NAME\"])[\"ANTHROPIC_API_KEY\"]\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "IAM Least-Privilege Role"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "yaml"
        },
        "content": [
          {
            "type": "text",
            "text": "# infra/iam.yaml — CloudFormation / CDK snippet\nClaudeServiceRole:\n  Type: AWS::IAM::Role\n  Properties:\n    AssumeRolePolicyDocument:\n      Statement:\n        - Effect: Allow\n          Principal:\n            Service: lambda.amazonaws.com   # or ecs-tasks.amazonaws.com\n          Action: sts:AssumeRole\n    Policies:\n      - PolicyName: MinimalPermissions\n        PolicyDocument:\n          Statement:\n            # Read the ONE secret this service needs\n            - Effect: Allow\n              Action: secretsmanager:GetSecretValue\n              Resource: !Sub \"arn:aws:secretsmanager:*:*:secret:${ServiceName}/*\"\n            # CloudWatch logs\n            - Effect: Allow\n              Action:\n                - logs:CreateLogGroup\n                - logs:CreateLogStream\n                - logs:PutLogEvents\n              Resource: !Sub \"arn:aws:logs:*:*:log-group:/aws/lambda/${ServiceName}:*\"\n            # Explicitly deny broad access\n            - Effect: Deny\n              Action:\n                - iam:*\n                - s3:DeleteBucket\n                - rds:DeleteDBInstance\n              Resource: \"*\"\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Prompt Injection Guard"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "User-supplied text flowing into Claude prompts is an injection surface. The golden path includes a lightweight guard that detects common injection patterns and rejects the request before it reaches Claude."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# security/prompt_guard.py\nimport re\n\n# Patterns that commonly appear in prompt injection attempts\n_INJECTION_PATTERNS = [\n    re.compile(r\"ignore (all )?(previous|prior|above) instructions\", re.IGNORECASE),\n    re.compile(r\"(you are|act as|pretend to be) (a )?(?!an? (helpful|knowledgeable))\", re.IGNORECASE),\n    re.compile(r\"system prompt|<system>|\\[INST\\]\", re.IGNORECASE),\n    re.compile(r\"jailbreak|DAN mode|developer mode\", re.IGNORECASE),\n]\n\nclass PromptInjectionDetected(ValueError):\n    pass\n\ndef guard_user_input(text: str) -> str:\n    \"\"\"Raise PromptInjectionDetected if text contains injection patterns.\"\"\"\n    for pattern in _INJECTION_PATTERNS:\n        if pattern.search(text):\n            # Log the attempt for security audit — do NOT log the actual text\n            from telemetry.metrics import tool_calls_total\n            tool_calls_total.labels(\n                service=os.environ.get(\"SERVICE_NAME\", \"unknown\"),\n                tool_name=\"prompt_guard\",\n                outcome=\"injection_detected\",\n            ).inc()\n            raise PromptInjectionDetected(\n                f\"Input rejected: matched injection pattern '{pattern.pattern}'\"\n            )\n    return text\n"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "The prompt guard is a first line of defense, not a complete security solution. It catches common patterns but cannot detect all injection attempts. Claude's own safety training provides an additional layer."
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
