{"format":"tiptap/v1","updatedAt":"2026-06-22T04:08:04.091Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"MCP in Claude Code"},{"type":"text","text":" is the integration of the Model Context Protocol into Claude Code's CLI, giving Claude Code access to "},{"type":"text","marks":[{"type":"bold"}],"text":"hundreds of external tools, databases, and APIs"},{"type":"text","text":" through MCP servers. This transforms Claude Code from a pure coding assistant into a "},{"type":"text","marks":[{"type":"bold"}],"text":"workflow engine"},{"type":"text","text":" that can interact directly with external systems using natural language."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What MCP Enables in Claude Code"}]},{"type":"paragraph","content":[{"type":"text","text":"With connected MCP servers, you can ask Claude Code to:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Task"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Example Request"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Implement features from issue trackers"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"Add the feature described in JIRA issue ENG-4521 and create a PR on GitHub\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text