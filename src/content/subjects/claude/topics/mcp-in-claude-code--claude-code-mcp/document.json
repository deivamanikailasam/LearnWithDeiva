xt":"Event-driven services"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"⚠️ "},{"type":"text","marks":[{"type":"bold"}],"text":"SSE is deprecated"},{"type":"text","text":" — use HTTP servers instead where available."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Installing MCP Servers"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Option 1: Remote HTTP Server"},{"type":"text","text":" (Recommended)"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Basic syntax\nclaude mcp add --transport http <name> <url>\n\n# Real example: Connect to Notion\nclaude mcp add --transport http notion https://mcp.notion.com/mcp\n\n# With Bearer token\nclaude mcp add --transport http secure-api https://api.example.com/mcp \\\n  --header \"Authorization: Bearer your-token\""}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Option 2: Local stdio Server"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Basic syntax\nclaude mcp add [options] <name> -- <command> [args...]\n\n# Real example: Add Airtable server\nclaude mcp add --env AIRTABLE_API_KEY=YOUR_KEY --transport stdio airtable \\\n  -- npx -y airtable-mcp-server"}]},{"type":"paragraph","content":[{"type":"text","text":"⚠️ "},{"type":"text","marks":[{"type":"bold"}],"text":"Important: Separate server arguments with "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"--"},{"type":"text","text":" — the double dash separates Claude's options from the server command."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Option 3: Import from Claude Desktop"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"claude mcp add-from-claude-desktop"}]},{"type":"paragraph","content":[{"type":"text","text":"Requires macOS or WS