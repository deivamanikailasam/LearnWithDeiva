"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"~/.claude.json"},{"type":"text","text":" [project path]"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Project"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Current project only"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Yes (via version control)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":".mcp.json"},{"type":"text","text":" in project root"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"User"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"All your projects"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"~/.claude.json"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Scope hierarchy"},{"type":"text","text":" (when same server is defined multiple times):\n1. Local scope (highest precedence)\n2. Project scope\n3. User scope\n4. Plugin-provided servers\n5. claude.ai connectors"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Authentication with OAuth 2.0"}]},{"type":"paragraph","content":[{"type":"text","text":"Many cloud MCP servers require authentication. Claude Code supports OAuth 2.0:"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Add server requiring auth\nclaude mcp add --transport http sentry https://mcp.sentry.dev/mcp"}]},{"type":"paragraph","content":[{"type":"text","text":"Then authenticate:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"/mcp"}]},{"type":"paragraph","content":[{"type":"text","text":"Follow browser login flow."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tips:"},{"type":"text","text":"\n- Tokens stored securely in system keychain (macOS) or credentials file\n- Use \"Clear authentication\" in "},{"type":"text","marks":[{"type":"code"}],"text":"/mcp"},{"type":"text","text":" to revoke access\n- OAuth works with HTTP servers only"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Automatic Reconnection"}]},{"type":"paragraph","content":[{"type":"text","text":"For HTTP/SSE servers that disconnect mid-session:\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"5 reconnection attempts"},{"type":"text","text":" with exponential backoff (1s → 2s → 4s → 8s → 16s)\n- Server appears as "},{"type":"text","marks":[{"type":"bold"}],"text":"pending"},{"type":"text","text":" in "},{"type":"text","marks":[{"type":"code"}],"text":"/mcp"},{"type":"text","text":" while reconnecting\n- After 5 failures: marked as "},{"type":"text","marks":[{"type":"bold"}],"text":"failed"},{"type":"text","text":" (retry manually)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Stdio servers"},{"type":"text","text":" don't auto-reconnect (local processes)"}]},{"type":"paragraph","content":[{"type":"text","text":"Initial connection also retries up to "},{"type":"text","marks":[{"type":"bold"}],"text":"3 times"},{"type":"text","text":" on transient errors (5xx, connection refused, timeout)."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"MCP Tool Search (Scale Support)"}]},{"type":"paragraph","content":[{"type":"text","text":"Enabled by default, MCP tool search allows Claude to:\n- Load tools "},{"type":"text","marks":[{"type":"bold"}],"text":"selectively"},{"type":"text","text":" from large MCP servers\n- Wait for connecting servers inside the "},{"type":"text","marks":[{"type":"code"}],"text":"ToolSearch"},{"type":"text","text":" call"}]},{"type":"paragraph","content":[{"type":"text","text":"Disable with "},{"type":"text","marks":[{"type":"code"}],"text":"ENABLE_TOOL_SEARCH=false"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Large Tool Output Handling"}]},{"type":"paragraph","content":[{"type":"text","text":"When MCP tool output exceeds "},{"type":"text","marks":[{"type":"bold"}],"text":"10,000 tokens"},{"type":"text","text":":\n- Warning displayed\n- Increase limit: "},{"type":"text","marks":[{"type":"code"}],"text":"MAX_MCP_OUTPUT_TOKENS=50000"}]},{"type":"paragraph","content":[{"type":"text","text":"(Note: Earlier docs mentioned 100K token limit for file writing in sandbox)."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Per-Server Tool Execution Timeout"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"// In .mcp.json\n{\n  \"mcpServers\": {\n    \"my-server\": {\n      \"type\": \"http\",\n      \"url\": \"https://mcp.example.com\",\n      \"timeout\": 600000  // 10 minutes in milliseconds\n    }\n  }\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"Overrides "},{"type":"text","marks":[{"type":"code"}],"text":"MCP_TOOL_TIMEOUT"},{"type":"text","text":" for that server only."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Using Claude Code as an MCP Server"}]},{"type":"paragraph","content":[{"type":"text","text":"You can run Claude Code itself as an MCP server for other applications:"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Start as stdio MCP server\nclaude mcp serve"}]},{"type":"paragraph","content":[{"type":"text","text":"Add to Claude Desktop config:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"mcpServers\": {\n    \"claude-code\": {\n      \"type\": \"stdio\",\n      \"command\": \"claude\",\n      \"args\": [\"mcp\", \"serve\"],\n      \"env\": {}\n    }\n  }\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"⚠️ Use full path to "},{"type":"text","marks":[{"type":"code"}],"text":"claude"},{"type":"text","text":" executable if not in PATH ("},{"type":"text","marks":[{"type":"code"}],"text":"which claude"},{"type":"text","text":")."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Plugin-Provided MCP Servers"}]},{"type":"paragraph","content":[{"type":"text","text":"Plugins can bundle MCP servers automatically:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"// In .mcp.json at plugin root\n{\n  \"mcpServers\": {\n    \"database-tools\": {\n      \"command\": \"${CLAUDE_PLUGIN_ROOT}/servers/db-server\",\n      \"args\": [\"--config\", \"${CLAUDE_PLUGIN_ROOT}/config.json\"],\n      \"env\": { \"DB_URL\": \"${DB_URL}\" }\n    }\n  }\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits:"},{"type":"text","text":"\n- Bundled distribution (tools + servers together)\n- Automatic setup (no manual configuration)\n- Team consistency (everyone gets same tools)"}]},{"type":"paragraph","content":[{"type":"text","text":"Tool names include plugin + server: "},{"type":"text","marks":[{"type":"code"}],"text":"mcp__plugin_my-plugin_database-tools__query"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Use MCP Servers from Claude.ai"}]},{"type":"paragraph","content":[{"type":"text","text":"If logged into Claude Code with Claude.ai account:\n- MCP servers added at "},{"type":"text","marks":[{"type":"bold"}],"text":"claude.ai/customize/connectors"},{"type":"text","text":" are automatically available\n- Team/Enterprise: only admins can add servers"}]},{"type":"paragraph","content":[{"type":"text","text":"View in Claude Code:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"/mcp"}]},{"type":"paragraph","content":[{"type":"text","text":"Claude.ai servers appear with indicators."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Disable claude.ai connectors:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"// In any settings scope\n{\n  \"disableClaudeAiConnectors\": true\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"Or environment variable: "},{"type":"text","marks":[{"type":"code"}],"text":"ENABLE_CLAUDEAI_MCP_SERVERS=false"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"MCP in Claude Code"},{"type":"text","text":" = CLI integration for external tool access via natural language"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Remote HTTP"},{"type":"text","text":" is recommended (SSE deprecated); "},{"type":"text","marks":[{"type":"bold"}],"text":"stdio"},{"type":"text","text":" for local tools"}]}]},{"type":"listItem","content":[{"type":"