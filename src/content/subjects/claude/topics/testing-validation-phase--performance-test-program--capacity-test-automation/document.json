      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Staircase Ramp Pattern"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Rather than a smooth ramp, a staircase test holds each load level for long enough to reach steady state (typically 5 minutes), measures percentiles at that level, then steps up. This produces a clean latency-vs-concurrency curve and clearly identifies the knee point where latency starts increasing nonlinearly."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# tests/capacity/staircase_locustfile.py\nfrom locust import HttpUser, task, between, LoadTestShape\n\nSTAIRCASE_STAGES = [\n    # (duration_seconds, users, spawn_rate)\n    (60,  10,  5),   # warm-up\n    (300, 10,  1),   # step 1: measure at 10 VU\n    (300, 25,  5),   # step 2: measure at 25 VU\n    (300, 50,  5),   # step 3: measure at 50 VU\n    (300, 75,  5),   # step 4: measure at 75 VU\n    (300, 100, 5),   # step 5: measure at 100 VU\n    (300, 130, 10),  # step 6: saturation zone\n    (60,  0,   50),  # cool-down\n]\n\nclass StaircaseShape(LoadTestShape):\n    def tick(self):\n        run_time = self.get_run_time()\n        elapsed = 0\n        for duration, users, spawn_rate in STAIRCASE_STAGES:\n            elapsed += duration\n            if run_time < elapsed:\n                if users == 0:\n                    return None  # end test\n                return users, spawn_rate\n        return None\n\nclass ClaudeUser(HttpUser):\n    wait_time = between(2, 5)\n\n    @task\n    def chat_message(self):\n        self.client.post(\n            \"/v1/messages\",\n            json={\n                \"model\": \"claude-haiku-4-5-20251001\",\n                \"max_tokens\": 256,\n                \"messages\": [{\"role\": \"user\", \"content\": \"What is 2 + 2? Answer briefly.\"}],\n            },\n            headers={\n                \"x-api-key\": \"test-key\",\n                \"anthropic-version\": \"2023-06-01\",\n                \"content-type\": \"application/json\",\n            },\n            name=\"POST /v1/messages\",\n            catch_response=True,\n        )\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Capacity Report Generator"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "After a staircase run, the Locust CSV output contains per-step statistics. The capacity report generator reads this data, identifies the saturation point, computes headroom percentage, and outputs a structured report."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# tests/capacity/generate_report.py\n\"\"\"\nGenerate a capacity report from Locust staircase CSV output.\nUsage: python generate_report.py /tmp/results_stats_history.csv --sla-p99-ms 6000\n\"\"\"\nimport csv\nimport sys\nimport json\nimport argparse\nfrom collections import defaultdict\nfrom pathlib import Path\nfrom dataclasses import dataclass, field\n\n@dataclass\nclass StepResult:\n    user_count: int\n    p50_ms: float\n    p99_ms: float\n    rps: float\n    error_rate_pct: float\n\ndef parse_history_csv(path: str) -> list[StepResult]:\n    \"\"\"\n    Locust --csv writes a history CSV with per-interval stats.\n    Aggregate by user_count to get step-level results.\n    \"\"\"\n    by_users: dict[int, list[dict]] = defaultdict(list)\n    with open(path) as f:\n        for row in csv.DictReader(f):\n            if row.get(\"Name\") != \"Aggregated\":\n                continue\n            vu = int(float(row.get(\"User count\", 0)))\n            if vu > 0:\n                by_users[vu].append(row)\n\n    results = []\n    for vu in sorted(by_users):\n        rows = by_users[vu]\n        # Take the last half of each step's rows (steady-state portion)\n        steady = rows[len(rows)//2:] if len(rows) > 2 else rows\n        p99s = [float(r[\"99%\"]) for r in steady if r.get(\"99%\")]\n        p50s = [float(r[\"50%\"]) for r in steady if r.get(\"50%\")]\n        rpss = [float(r[\"Requests/s\"]) for r in steady if r.get(\"Requests/s\")]\n        fail_rates = []\n        for r in steady:\n            total = int(r.get(\"Request Count\", 0))\n            failed = int(r.get(\"Failure Count\", 0))\n            if total > 0:\n                fail_rates.append(failed / total * 100)\n        results.append(StepResult(\n            user_count=vu,\n            p99_ms=sum(p99s) / len(p99s) if p99s else 0,\n            p50_ms=sum(p50s) / len(p50s) if p50s else 0,\n            rps=sum(rpss) / len(rpss) if rpss else 0,\n            error_rate_pct=sum(fail_rates) / len(fail_rates) if fail_rates else 0,\n        ))\n    return results\n\ndef find_saturation(steps: list[StepResult], sla_p99_ms: float) -> int | None:\n    \"\"\"Return user_count at the first step where p99 exceeds the SLA.\"\"\"\n    for step in steps:\n        if step.p99_ms > sla_p99_ms:\n            return step.user_count\n    return None\n\ndef generate_report(steps: list[StepResult], sla_p99_ms: float) -> dict:\n    saturation_vu = find_saturation(steps, sla_p99_ms)\n    safe_vu = max(\n        (s.user_count for s in steps if s.p99_ms <= sla_p99_ms),\n        default=0\n    )\n    report = {\n        \"sla_p99_ms\": sla_p99_ms,\n        \"safe_capacity_vu\": safe_vu,\n        \"saturation_vu\": saturation_vu,\n        \"headroom_pct\": round((safe_vu / saturation_vu - 1) * 100, 1) if saturation_vu else None,\n        \"steps\": [\n            {\n                \"user_count\": s.user_count,\n                \"p50_ms\": round(s.p50_ms, 0),\n                \"p99_ms\": round(s.p99_ms, 0),\n                \"rps\": round(s.rps, 1),\n                \"error_rate_pct\": round(s.error_rate_pct, 2),\n                \"within_sla\": s.p99_ms <= sla_p99_ms,\n            }\n            for s in steps\n        ],\n    }\n    return report\n\nif __name__ == \"__main__\":\n    parser = argparse.ArgumentParser()\n    parser.add_argument(\"history_csv\")\n    parser.add_argument(\"--sla-p99-ms\", type=float, default=6000)\n    parser.add_argument(\"--output\", default=\"/tmp/capacity_report.json\")\n    args = parser.parse_args()\n    steps = parse_history_csv(args.history_csv)\n    report = generate_report(steps, args.sla_p99_ms)\n    Path(args.output).write_text(json.dumps(report, indent=2))\n    print(json.dumps(report, indent=2))\n    if report[\"saturation_vu\"]:\n        print(f\"\\nSaturation at {report['saturation_vu']} VU. Safe capacity: {report['safe_capacity_vu']} VU.\")\n    else:\n        print(\"\\nNo saturation found \u2014 system stayed within SLA for all test steps.\")\n"
          }
        ]
      },
