      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Generate a human-readable Markdown report suitable for posting as a GitHub comment or storing as a CI artifact."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# tests/capacity/markdown_report.py\nimport json\nfrom pathlib import Path\n\ndef format_report(report: dict) -> str:\n    lines = [\n        \"## Capacity Test Report\\n\",\n        f\"**SLA threshold:** p99 < {report['sla_p99_ms']/1000:.0f}s  \",\n        f\"**Safe capacity:** {report['safe_capacity_vu']} concurrent users  \",\n    ]\n    if report[\"saturation_vu\"]:\n        lines.append(f\"**Saturation point:** {report['saturation_vu']} concurrent users  \")\n        headroom = report.get(\"headroom_pct\")\n        if headroom is not None:\n            status = \"\u2705\" if headroom >= 25 else (\"\u26a0\ufe0f\" if headroom >= 10 else \"\ud83d\udea8\")\n            lines.append(f\"**Headroom:** {headroom:.0f}% {status}  \")\n    else:\n        lines.append(\"**Saturation:** not reached (system stayed within SLA) \u2705  \")\n\n    lines.append(\"\\n| VU | p50 latency | p99 latency | Throughput | Error rate | SLA |\")\n    lines.append(\"|-----|-------------|-------------|------------|------------|-----|\")\n    for s in report[\"steps\"]:\n        sla_icon = \"\u2705\" if s[\"within_sla\"] else \"\u274c\"\n        lines.append(\n            f\"| {s['user_count']} \"\n            f\"| {s['p50_ms']:.0f}ms \"\n            f\"| {s['p99_ms']:.0f}ms \"\n            f\"| {s['rps']:.1f} req/s \"\n            f\"| {s['error_rate_pct']:.1f}% \"\n            f\"| {sla_icon} |\"\n        )\n    return \"\\n\".join(lines)\n\nif __name__ == \"__main__\":\n    import sys\n    report = json.loads(Path(sys.argv[1]).read_text())\n    print(format_report(report))\n"
          }
        ]
      },
