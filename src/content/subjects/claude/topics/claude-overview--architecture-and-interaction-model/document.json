{"format":"tiptap/v1","updatedAt":"2026-06-20T03:02:29.993Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"From a developer’s perspective, “Claude” is accessed primarily via the "},{"type":"text","marks":[{"type":"bold"}],"text":"Messages API"},{"type":"text","text":", a REST endpoint at "},{"type":"text","marks":[{"type":"code"}],"text":"POST /v1/messages"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","text":"Core concepts:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Messages"},{"type":"text","text":": you send a list of messages (roles: "},{"type":"text","marks":[{"type":"code"}],"text":"system"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"user"},{"type":"text","text":", and sometimes "},{"type":"text","marks":[{"type":"code"}],"text":"assistant"},{"type":"text","text":") plus configuration like "},{"type":"text","marks":[{"type":"code"}],"text":"model"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"max_tokens"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"temperature"},{"type":"text","text":", and optional "},{"type":"text","marks":[{"type":"code"}],"text":"tools"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"files"},{"type":"text","text":", or "},{"type":"text","marks":[{"type":"code"}],"text":"metadata"},{"type":"text","text":"."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"System prompts"},{"type":"text","text":": high‑level behavior instructions (tone, constraints, task scope) that steer Claude across a whole conversation."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"User prompts"},{"type":"text","text":": concrete questions or tasks, possibly including inlined documents, URLs, or references to uploaded files."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tool calls"},{"type":"text","text":": in tool‑use mode, Claude returns actions describing which tool to call and with what arguments, then you execute the tools and feed results back as messages."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Streaming & batching"},{"type":"text","text":": the API supports streaming token‑by‑token responses and batch processing to scale workloads efficiently."}]}]}]},{"type":"paragraph"}]}}
