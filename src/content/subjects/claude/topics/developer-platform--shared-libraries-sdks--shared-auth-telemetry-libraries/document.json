        "content": [
          {
            "type": "text",
            "text": "Shared Telemetry Library (acme-telemetry)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The telemetry library configures OpenTelemetry tracing, Prometheus metrics, and structured logging with a single "
          },
          {
            "type": "text",
            "text": "configure_telemetry()",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " call. It wraps the OTel SDK setup that would otherwise require 40+ lines of boilerplate in every service."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Setup"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# acme_telemetry/setup.py\nfrom __future__ import annotations\nimport logging, os\nfrom opentelemetry import trace\nfrom opentelemetry.sdk.trace import TracerProvider\nfrom opentelemetry.sdk.trace.export import BatchSpanProcessor\nfrom opentelemetry.exporter.otlp.proto.grpc.trace_exporter import OTLPSpanExporter\nfrom opentelemetry.instrumentation.fastapi import FastAPIInstrumentor\nfrom opentelemetry.instrumentation.httpx import HTTPXClientInstrumentor\nfrom prometheus_client import start_http_server\nfrom .logging import configure_structured_logging\n\n\ndef configure_telemetry(\n    service_name: str,\n    metrics_port: int = 9090,\n    otel_endpoint: str | None = None,\n) -> None:\n    \"\"\"Wire up tracing, metrics, and structured logging.  Call at app startup.\"\"\"\n    otel_endpoint = otel_endpoint or os.environ.get(\n        \"OTEL_EXPORTER_OTLP_ENDPOINT\", \"http://otel-collector:4317\"\n    )\n    # Tracing\n    provider = TracerProvider()\n    provider.add_span_processor(\n        BatchSpanProcessor(OTLPSpanExporter(endpoint=otel_endpoint))\n    )\n    trace.set_tracer_provider(provider)\n\n    # Auto-instrument FastAPI and outbound HTTP calls\n    FastAPIInstrumentor().instrument()\n    HTTPXClientInstrumentor().instrument()\n\n    # Metrics\n    start_http_server(metrics_port)\n\n    # Structured logging\n    configure_structured_logging(service_name)\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Structured Logging Integration"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# acme_telemetry/logging.py\nimport logging, json, time, os\nfrom opentelemetry import trace\n\nclass OTelJsonFormatter(logging.Formatter):\n    \"\"\"Emit JSON log records with OTel trace/span IDs for correlation.\"\"\"\n\n    def __init__(self, service: str):\n        super().__init__()\n        self._service = service\n\n    def format(self, record: logging.LogRecord) -> str:\n        span_ctx = trace.get_current_span().get_span_context()\n        return json.dumps({\n            \"ts\": time.time(),\n            \"level\": record.levelname.lower(),\n            \"service\": self._service,\n            \"env\": os.environ.get(\"ENVIRONMENT\", \"dev\"),\n            \"logger\": record.name,\n            \"message\": record.getMessage(),\n            \"trace_id\": f\"{span_ctx.trace_id:032x}\" if span_ctx.is_valid else None,\n            \"span_id\": f\"{span_ctx.span_id:016x}\" if span_ctx.is_valid else None,\n        })\n\n\ndef configure_structured_logging(service: str) -> None:\n    root = logging.getLogger()\n    root.setLevel(logging.INFO)\n    if not root.handlers:\n        handler = logging.StreamHandler()\n        handler.setFormatter(OTelJsonFormatter(service))\n        root.addHandler(handler)\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Custom Business Metrics"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The telemetry library ships pre-built metric factories for the most common Claude service patterns. Teams call the factory; the library registers the metric under the standard naming convention."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# acme_telemetry/metrics.py\nfrom prometheus_client import Counter, Histogram\n\n_SERVICE = None\n\ndef init(service_name: str) -> None:\n    global _SERVICE\n    _SERVICE = service_name\n\n\ndef claude_call_counter() -> Counter:\n    return Counter(\n        \"claude_service_requests_total\",\n        \"Total Claude API calls\",\n        [\"service\", \"model\", \"status\"],\n    )\n\ndef claude_latency_histogram() -> Histogram:\n    return Histogram(\n        \"claude_service_latency_seconds\",\n        \"Claude API call latency\",\n        [\"service\", \"model\"],\n        buckets=[0.1, 0.5, 1.0, 2.0, 5.0, 10.0, 30.0],\n    )\n\ndef claude_token_counter() -> Counter:\n    return Counter(\n        \"claude_service_tokens_total\",\n        \"Total tokens consumed\",\n        [\"service\", \"model\", \"direction\"],  # direction: input / output\n    )\n\n# Custom business metric — registered by the service, consistent label structure\ndef business_counter(metric_name: str, description: str, labels: list[str]) -> Counter:\n    return Counter(\n        f\"claude_service_{metric_name}_total\",\n        description,\n        [\"service\"] + labels,\n    )\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Wiring Both Libraries into a Service"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# main.py — full startup sequence for a Claude service\nimport os\nfrom fastapi import FastAPI\nfrom acme_telemetry.setup import configure_telemetry\nfrom acme_auth.fastapi import add_auth_middleware\n\nSERVICE_NAME = os.environ[\"SERVICE_NAME\"]\n\n# 1. Configure telemetry first (before any routes or middleware)\nconfigure_telemetry(service_name=SERVICE_NAME, metrics_port=9090)\n\n# 2. Create app\napp = FastAPI(title=SERVICE_NAME)\n\n# 3. Add auth middleware (before routes)\nadd_auth_middleware(app, required_scope=\"claude:invoke\")\n\n# 4. Add routes\nfrom service.routes import router\napp.include_router(router)\n\n@app.get(\"/health\")\nasync def health():\n    return {\"status\": \"ok\", \"service\": SERVICE_NAME}\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Library Versioning and Fleet Upgrade"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Both libraries publish to the internal PyPI registry under the "
          },
          {
            "type": "text",
            "text": "acme-",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " namespace. The internal SDK wrapper ("
          },
          {
            "type": "text",
            "text": "acme-claude",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ") depends on both and pins their versions, so teams that install "
          },
          {
            "type": "text",
            "text": "acme-claude",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " receive compatible versions of all three libraries without thinking about transitive dependency resolution."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "toml"
        },
        "content": [
          {
            "type": "text",
            "text": "# pyproject.toml of acme-claude (internal SDK wrapper)\n[project]\nname = \"acme-claude\"\nversion = \"1.5.0\"\ndependencies = [\n    \"anthropic>=0.34.0,<1.0.0\",\n    \"acme-auth>=2.1.0,<3.0.0\",        # JWT + JWKS + FastAPI middleware\n    \"acme-telemetry>=1.4.0,<2.0.0\",   # OTel + structured logs + Prometheus\n    \"acme-secrets>=1.0.0,<2.0.0\",     # Secrets Manager client\n]\n"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Consumer services should depend only on acme-claude, not on acme-auth or acme-telemetry directly. This lets the platform team update transitive dependency versions without requiring every consuming service to change its own dependency declarations."
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Security Considerations"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "JWKS cache invalidation",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": ": the cache has a 1-hour TTL by default. When the identity provider rotates signing keys, the JWKS endpoint is updated immediately; the old key is removed after a grace period of at least 1 hour to allow in-flight tokens signed with the old key to finish validating. The cache's TTL ensures the new key is picked up within 1 hour."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Scope validation is mandatory",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": ": the middleware raises 403 if the required scope is absent. Services must always set "
                  },
                  {
                    "type": "text",
                    "text": "required_scope",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " — passing "
                  },
                  {
                    "type": "text",
                    "text": "None",
                    "marks": [
                      {
                        "type": "code"
