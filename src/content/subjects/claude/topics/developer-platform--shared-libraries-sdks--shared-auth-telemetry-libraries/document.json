        "content": [
          {
            "type": "text",
            "text": "Shared Auth Library (acme-auth)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The auth library handles OIDC/JWT validation, JWKS key caching, and scope-based authorization as a FastAPI or Flask middleware. Services add one line to get enterprise authentication — they never write token validation logic themselves."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "JWT Validation with JWKS Caching"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# acme_auth/jwt.py\nfrom __future__ import annotations\nimport time, functools\nimport httpx\nfrom jose import jwt, JWTError\n\nclass JWKSCache:\n    \"\"\"Fetches and caches JWKS keys; refreshes on cache miss or TTL expiry.\"\"\"\n\n    def __init__(self, jwks_uri: str, ttl_seconds: float = 3600.0):\n        self._uri = jwks_uri\n        self._ttl = ttl_seconds\n        self._keys: list[dict] = []\n        self._fetched_at = 0.0\n\n    def get_keys(self) -> list[dict]:\n        now = time.monotonic()\n        if now - self._fetched_at > self._ttl or not self._keys:\n            resp = httpx.get(self._uri, timeout=5.0)\n            resp.raise_for_status()\n            self._keys = resp.json()[\"keys\"]\n            self._fetched_at = now\n        return self._keys\n\n\nclass JWTValidator:\n    def __init__(self, issuer: str, audience: str, jwks_uri: str):\n        self._issuer = issuer\n        self._audience = audience\n        self._cache = JWKSCache(jwks_uri)\n\n    def validate(self, token: str) -> dict:\n        \"\"\"Return the decoded claims dict, or raise on invalid token.\"\"\"\n        try:\n            return jwt.decode(\n                token,\n                self._cache.get_keys(),\n                algorithms=[\"RS256\"],\n                audience=self._audience,\n                issuer=self._issuer,\n            )\n        except JWTError as e:\n            raise ValueError(f\"Invalid token: {e}\") from e\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "FastAPI Middleware"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# acme_auth/fastapi.py\nfrom __future__ import annotations\nfrom fastapi import FastAPI, Request, HTTPException\nfrom fastapi.security import HTTPBearer, HTTPAuthorizationCredentials\nfrom .jwt import JWTValidator\nimport os\n\n_bearer = HTTPBearer()\n\n\ndef add_auth_middleware(\n    app: FastAPI,\n    required_scope: str | None = None,\n) -> None:\n    \"\"\"Add OIDC JWT auth to a FastAPI app.  Call before adding routes.\"\"\"\n    validator = JWTValidator(\n        issuer=os.environ[\"OIDC_ISSUER\"],\n        audience=os.environ[\"OIDC_AUDIENCE\"],\n        jwks_uri=f\"{os.environ['OIDC_ISSUER']}/.well-known/jwks.json\",\n    )\n\n    @app.middleware(\"http\")\n    async def auth_middleware(request: Request, call_next):\n        # Skip health check and metrics endpoints\n        if request.url.path in (\"/health\", \"/metrics\"):\n            return await call_next(request)\n\n        auth_header = request.headers.get(\"Authorization\", \"\")\n        if not auth_header.startswith(\"Bearer \"):\n            raise HTTPException(status_code=401, detail=\"Missing Bearer token\")\n\n        token = auth_header.removeprefix(\"Bearer \")\n        try:\n            claims = validator.validate(token)\n        except ValueError as e:\n            raise HTTPException(status_code=401, detail=str(e))\n\n        if required_scope and required_scope not in claims.get(\"scope\", \"\").split():\n            raise HTTPException(status_code=403, detail=f\"Missing required scope: {required_scope}\")\n\n        request.state.user = claims   # downstream handlers access via request.state.user\n        return await call_next(request)\n\n\n# Usage in a service:\n#   from acme_auth.fastapi import add_auth_middleware\n#   app = FastAPI()\n#   add_auth_middleware(app, required_scope=\"claude:invoke\")\n"
          }
        ]
      },
