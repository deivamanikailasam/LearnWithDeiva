{"format":"tiptap/v1","updatedAt":"2026-06-21T04:50:05.765Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"The official "},{"type":"text","marks":[{"type":"bold"}],"text":"Python and TypeScript SDKs provide streaming helpers"},{"type":"text","text":" that automatically parse SSE events and extract text. Instead of manually iterating over raw SSE events and extracting "},{"type":"text","marks":[{"type":"code"}],"text":"event.delta.text"},{"type":"text","text":", you can use "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"stream.text_stream"},{"type":"text","text":" (Python) or "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"stream.textStream"},{"type":"text","text":" (TypeScript) to get clean text chunks directly. For the complete accumulated message, use "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"stream.get_final_message()"},{"type":"text","text":" (Python) or "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"stream.finalMessage()"},{"type":"text","text":" (TypeScript) after the stream completes. These helpers filter out non-text events, handle concatenation, and return the final "},{"type":"text","marks":[{"type":"code"}],"text":"Message"},{"type":"text","text":" object with full metadata."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Python SDK Streaming Helpers"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"code"}],"text":"stream()"},{"type":"text","text":" Method (Recommended)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\n# ✅ Use stream() method with context manager\nwith client.messages.stream(\n    max_tokens=1024,\n    messages=[{\"role\": \"user\", \"content\": \"Hello\"}],\n    model=\"claude-sonnet-4-6\",\n) as stream:  # ← Returns StreamingMessageStream object\n    for text in stream.text_stream:  # ← Clean text chunks\n        print(text, end=\"\", flush=True)\n    \n    print()  # New line after stream\n    \n    # Get final complete Message\n    final_message = stream.get_final_message()\n    print(f\"Tokens used: {final_message.usage.output_tokens}\")"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key differences from "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"create(stream=True)"},{"type":"text","marks":[{"type":"bold"}],"text":":"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"code"}],"text":"stream()"},{"type":"text","text":" returns a "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"StreamingMessageStream"},{"type":"text","text":" object (context manager)\n- Automatically handles stream cleanup with "},{"type":"text","marks":[{"type":"code"}],"text":"with"},{"type":"text","text":" statement\n- Cleaner API for simple streaming cases\n- Same underlying SSE events, just easier to use"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"code"}],"text":"text_stream"},{"type":"text","text":" Helper"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\nstream = client.messages.stream(\n    max_tokens=1024,\n    messages=[{\"role\": \"user\", \"content\": \"Write a poem\"}],\n    model=\"claude-sonnet-4-6\",\n)\n\nwith stream:\n    # ✅ Simple: just text, no manual event parsing\n    for text in stream.text_stream:\n        print(text, end=\"\", flush=True)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"text_stream"},{"type":"text","marks":[{"type":"bold"}],"text":" does:"},{"type":"text","text":"\n- Filters only "},{"type":"text","marks":[{"type":"code"}],"text":"content_block_delta"},{"type":"text","text":" events with "},{"type":"text","marks":[{"type":"code"}],"text":"text_delta"},{"type":"text","text":" type\n- Extracts "},{"type":"text","marks":[{"type":"code"}],"text":"delta.text"},{"type":"text","text":" from each event\n- Yields strings (not raw SSE JSON objects)\n- You get clean text, ready to print"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"code"}],"text":"get_final_message()"},{"type":"text","text":" Helper"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\nstream = client.messages.stream(\n    max_tokens=1024,\n    messages=[{\"role\": \"user\", \"content\": \"Hello\"}],\n    model=\"claude-sonnet-4-6\",\n)\n\nwith stream:\n    for text in stream.text_stream:\n        print(text, end=\"\", flush=True)\n    print()\n    \n    # ✅ Get complete Message after stream finishes\n    final_message = stream.get_final_message()\n    \n    # Access full response\n    print(f\"Full text: {final_message.content[0].text}\")\n    print(f\"Input tokens: {final_message.usage.input_tokens}\")\n    print(f\"Output tokens: {final_message.usage.output_tokens}\")\n    print(f\"Stop reason: {final_message.stop_reason}\")"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Important:"},{"type":"text","text":" "},{"type":"text","marks":[{"type":"code"}],"text":"get_final_message()"},{"type":"text","text":" only works if you "},{"type":"text","marks":[{"type":"bold"}],"text":"consumed the entire stream"},{"type":"text","text":". If you break early or skip events, it may return incomplete data."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Async Version"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import asyncio\nimport anthropic\n\nclient = anthropic.AsyncAnthropic()\n\nasync def main():\n    stream = await client.messages.stream(\n        max_tokens=1024,\n        messages=[{\"role\": \"user\", \"content\": \"Write a poem\"}],\n        model=\"claude-sonnet-4-6\",\n    )\n    \n    with stream:\n        # ✅ Async text stream\n        async for text in stream.text_stream:\n            print(text, end=\"\", flush=True)\n        \n        print()\n        \n        # ✅ Async final message\n        final_message = await stream.get_final_message()\n        print(f\"Full: {final_message.content[0].text}\")\n\nasyncio.run(main())"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"TypeScript SDK Streaming Helpers"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"code"}],"text":"stream()"},{"type":"text","text":" Method"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import Anthropic from \"@anthropic-ai/sdk\";\n\nconst client = new Anthropic();\n\n// ✅ Use stream() method\nconst stream = await client.messages.stream({\n    max_tokens: 1024,\n    messages: [{ role: \"user\", content: \"Hello\" }],\n    model: \"claude-sonnet-4-6\",\n});\n\n// ✅ Simple: textStream returns clean text chunks\nfor await (const text of stream.textStream) {\n    process.stdout.write(text);\n}\n\nconsole.log();\n\n// ✅ Get final complete Message\nconst finalMessage = await stream.finalMessage();\nconsole.log(`Tokens used: ${finalMessage.usage.output_tokens}`);\nconsole.log(`Full text: ${finalMessage.content[0].text}`);"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"code"}],"text":"textStream"},{"type":"text","text":" Helper"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import Anthropic from \"@anthropic-ai/sdk\";\n\nconst stream = await client.messages.stream({\n    max_tokens: 1024,\n    messages: [{ role: \"user\", content: \"Write a poem\" }],\n    model: \"claude-sonnet-4-6\",\n});\n\n// ✅ Simple: textStream yields strings (not raw events)\nfor await (const text of stream.textStream) {\n    process.stdout.write(text);\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"textStream"},{"type":"text","marks":[{"type":"bold"}],"text":" does:"},{"type":"text","text":"\n- Filters "},{"type":"text","marks":[{"type":"code"}],"text":"content_block_delta"},{"type":"text","text":" events with "},{"type":"text","marks":[{"type":"code"}],"text":"text_delta"},{"type":"text","text":" type\n- Extracts "},{"type":"text","marks":[{"type":"code"}],"text":"delta.text"},{"type":"text","text":" from each event\n- Yields strings (not raw SSE JSON)\n- Same behavior as Python's "},{"type":"text","marks":[{"type":"code"}],"text":"text_stream"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"code"}],"text":"finalMessage()"},{"type":"text","text":" Helper"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"const stream = await client.messages.stream({\n    max_tokens: 1024,\n    messages: [{ role: \"user\", content: \"Hello\" }],\n    model: \"claude-sonnet-4-6\",\n});\n\nfor await (const text of stream.textStream) {\n    process.stdout.write(text);\n}\n\nconsole.log();\n\n// ✅ Get complete Message after stream finishes\nconst finalMessage = await stream.finalMessage();\n\nconsole.log(`Full text: ${finalMessage.content[0].text}`);\nconsole.log(`Input tokens: ${finalMessage.usage.input_tokens}`);\nconsole.log(`Output tokens: ${finalMessage.usage.output_tokens}`);\nconsole.log(`Stop reason: ${finalMessage.delta.stop_reason}`);"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best practice:"},{"type":"text","text":" Don't wrap "},{"type":"text","marks":[{"type":"code"}],"text":".on()"},{"type":"text","text":" events in "},{"type":"text","marks":[{"type":"code"}],"text":"new Promise()"},{"type":"text","text":" — "},{"type":"text","marks":[{"type":"code"}],"text":"finalMessage()"},{"type":"text","text":" handles all completion/error/abort states internally."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Comparison: Helpers vs Raw Events"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Raw Events (Manual)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\nstream = client.messages.create(\n    max_tokens=1024,\n    messages=[{\"role\": \"user\", \"content\": \"Hello\"}],\n    model=\"claude-sonnet-4-6\",\n    stream=True,\n)\n\n# ❌ Manual: parse each event type\nfor event in stream:\n    if event.type == \"content_block_delta\":\n        if event.delta.type == \"text_delta\":\n            print(event.delta.text, end=\"\", flush=True)\n    \n    elif event.type == \"message_delta\":\n        print(f\"\\nStop reason: {event.delta.stop_reason}\")\n\nprint()\nfinal_message = stream.get_final_message()"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"With Helpers (Recommended)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\nstream = client.messages.stream(\n    max_tokens=1024,\n    messages=[{\"role\": \"user\", \"content\": \"Hello\"}],\n    model=\"claude-sonnet-4-6\",\n)\n\nwith stream:\n    # ✅ Simple: just text, no manual parsing\n    for text in stream.text_stream:\n        print(text, end=\"\", flush=True)\n    print()\n    \n    final_message = stream.get_final_message()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits of helpers:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Feature"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Helpers"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Raw Events"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Code complexity"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Low (1 line for text)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"High (multiple if/elif)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Event filtering"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Automatic"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Manual"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Text extraction"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Built-in"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Manual "},{"type":"text","marks":[{"type":"code"}],"text":"event.delta.text"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Error handling"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Built-in"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Manual"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Stream cleanup"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"with"},{"type":"text","text":" statement"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Manual "},{"type":"text","marks":[{"type":"code"}],"text":"stream.close()"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best for"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Simple text"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tool use, thinking, custom"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"[usingclaude](https://usingclaude.com/en/api/advanced/claude-api-streaming)"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Real-World Examples"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example 1: Chat Interface (Simple)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\nmessages = [{\"role\": \"user\", \"content\": \"Explain quantum computing\"}]\n\nstream = client.messages.stream(\n    max_tokens=1024,\n    messages=messages,\n    model=\"claude-sonnet-4-6\",\n)\n\nprint(\"Claude: \", end=\"\", flush=True)\n\nwith stream:\n    for text in stream.text_stream:\n        print(text, end=\"\", flush=True)\n    \n    print()\n    \n    final_message = stream.get_final_message()\n    messages.append({\"role\": \"assistant\", \"content\": final_message.content})"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example 2: Tool Use (Advanced — Raw Events Needed)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\ntools = [{\"name\": \"get_weather\", \"description\": \"Get weather\", ...}]\n\nstream = client.messages.stream(\n    model=\"claude-opus-4-8\",\n    max_tokens=1024,\n    tools=tools,\n    messages=[{\"role\": \"user\", \"content\": \"Weather in SF?\"}],\n)\n\ntool_input = \"\"\n\nwith stream:\n    # ❌ Can't use text_stream for tool use — need raw events\n    for event in stream:\n        if event.type == \"content_block_delta\":\n            if event.delta.type == \"text_delta\":\n                print(event.delta.text, end=\"\", flush=True)\n            \n            elif event.delta.type == \"input_json_delta\":\n                tool_input += event.delta.partial_json\n                print(f\"\\n[Tool input: {tool_input}]\", flush=True)\n        \n        elif event.type == \"content_block_stop\":\n            print()\n    \n    final_message = stream.get_final_message()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why raw events for tool use:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"code"}],"text":"text_stream"},{"type":"text","text":" only yields text deltas\n- Tool input uses "},{"type":"text","marks":[{"type":"code"}],"text":"input_json_delta"},{"type":"text","text":" (not text)\n- Need to manually extract "},{"type":"text","marks":[{"type":"code"}],"text":"event.delta.partial_json"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example 3: Extended Thinking (Advanced — Raw Events Needed)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\nstream = client.messages.stream(\n    model=\"claude-sonnet-4-5\",\n    max_tokens=2000,\n    messages=[{\"role\": \"user\", \"content\": \"Solve this riddle...\"}],\n)\n\nwith stream:\n    # ❌ Can't use text_stream for thinking — need raw events\n    for event in stream:\n        if event.type == \"content_block_delta\":\n            if event.delta.type == \"thinking_delta\":\n                print(f\"[Thinking]: {event.delta.thinking}\", end=\"\", flush=True)\n            elif event.delta.type == \"text_delta\":\n                print(event.delta.text, end=\"\", flush=True)\n    \n    print()\n    final_message = stream.get_final_message()"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example 4: Error Handling"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\ntry:\n    stream = client.messages.stream(\n        max_tokens=1024,\n        messages=[{\"role\": \"user\", \"content\": \"Hello\"}],\n        model=\"claude-sonnet-4-6\",\n    )\n    \n    with stream:\n        for text in stream.text_stream:\n            print(text, end=\"\", flush=True)\n        print()\n        \n        final_message = stream.get_final_message()\n        \nexcept anthropic.APIConnectionError as e:\n    print(f\"\\n[Network error] {e}\")\n    \nexcept anthropic.RateLimitError as e:\n    print(f\"\\n[Rate limited] {e}\")\n    \nexcept Exception as e:\n    print(f\"\\n[Unexpected error] {e}\")"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Streaming Helpers for Platform Integrations"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Google Vertex AI"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from anthropic import AnthropicVertex\n\nclient = AnthropicVertex(project_id=\"my-project\", region=\"us-east5\")\n\nstream = client.messages.stream(\n    model=\"claude-3-5-sonnet-v2@20241022\",\n    max_tokens=1024,\n    messages=[{\"role\": \"user\", \"content\": \"Banana bread recipe\"}],\n)\n\nresult = []\nwith stream:\n    for text in stream.text_stream:\n        print(text, end=\"\", flush=True)\n        result.append(text)\n    \n    print()\n    final_message = stream.get_final_message()"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Amazon Bedrock"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from anthropic import AnthropicBedrockMantle\n\nclient = AnthropicBedrockMantle()\n\nstream = client.messages.stream(\n    model=\"claude-3-5-sonnet-20241022\",\n    max_tokens=1024,\n    messages=[{\"role\": \"user\", \"content\": \"Hello\"}],\n)\n\nwith stream:\n    for text in stream.text_stream:\n        print(text, end=\"\", flush=True)\n    \n    print()\n    final_message = stream.get_final_message()"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Always Flush Output"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ CORRECT — immediate display\nprint(text, end=\"\", flush=True)\n\n# ❌ WRONG — output may buffer\nprint(text, end=\"\")"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Use "},{"type":"text","marks":[{"type":"code"}],"text":"stream()"},{"type":"text","text":" with "},{"type":"text","marks":[{"type":"code"}],"text":"with"},{"type":"text","text":" Context"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ CORRECT — automatic cleanup\nstream = client.messages.stream(...)\nwith stream:\n    for text in stream.text_stream:\n        print(text, end=\"\", flush=True)\n\n# ❌ RISKY — may not clean up properly\nstream = client.messages.stream(...)\nfor text in stream.text_stream:\n    print(text, end=\"\", flush=True)  # Missing cleanup"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Don't Skip Events Before "},{"type":"text","marks":[{"type":"code"}],"text":"get_final_message()"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"stream = client.messages.stream(...)\n\nwith stream:\n    # ❌ WRONG — breaking early may lose data\n    for text in stream.text_stream:\n        print(text, end=\"\", flush=True)\n        if text == \"STOP\":\n            break  # ← Stream interrupted!\n    \n    final_message = stream.get_final_message()  # May be incomplete\n\n# ✅ CORRECT — consume entire stream\nwith stream:\n    for text in stream.text_stream:\n        print(text, end=\"\", flush=True)\n    \n    final_message = stream.get_final_message()  # Complete"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Use "},{"type":"text","marks":[{"type":"code"}],"text":"finalMessage()"},{"type":"text","text":" Instead of Promises (TypeScript)"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ❌ WRONG — don't wrap .on() in Promise\nconst promise = new Promise((resolve, reject) => {\n    stream.on(\"text\", (text) => { resolve(text); });\n});\n\n// ✅ CORRECT — use finalMessage()\nconst finalMessage = await stream.finalMessage();"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. Buffer for Web UIs"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// Consider buffering a few tokens before rendering\n// to avoid excessive DOM updates\nconst buffer: string[] = [];\nlet bufferTimer: Timer;\n\nfor await (const text of stream.textStream) {\n    buffer.push(text);\n    \n    if (!bufferTimer) {\n        bufferTimer = setTimeout(() => {\n            render(buffer.join(\"\"));\n            buffer.length = 0;\n            bufferTimer = null;\n        }, 100);  // Buffer 100ms\n    }\n}"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Summary"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"SDK Streaming Helpers Cheat Sheet"}]},{"type":"table","content":[{"type":"tableRow","content"