{"format":"tiptap/v1","updatedAt":"2026-06-22T04:27:58.159Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Based on the official Claude documentation and multi-agent systems research, "},{"type":"text","marks":[{"type":"bold"}],"text":"\"Coordination & Communication\""},{"type":"text","text":" is how agents in a multi-agent system "},{"type":"text","marks":[{"type":"bold"}],"text":"work together to complete complex tasks"},{"type":"text","text":" — encompassing both how they coordinate work distribution and how they exchange information."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","text":"Coordination & Communication encompasses "},{"type":"text","marks":[{"type":"bold"}],"text":"methods for coordinating multiple agents"},{"type":"text","text":" including parallel agent initialization, sequential agent workflows, agent communication patterns, and task delegation strategies."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Two Core Components"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Component"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"What It Handles"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Coordination"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"How agents organize work, delegate tasks, and manage flow"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Communication"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"How agents exchange information, share state, and pass results"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Coordination Patterns"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Hub-and-Spoke (Coordinator-Subagent)"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Coordinator (Main Agent)\n    ↓\nRoute to specialists\n    ↓\nSubagent 1 │ Subagent 2 │ Subagent 3\n(isolated) │ (isolated) │ (isolated)\n    ↓       ↓       ↓\nAll report back to coordinator only\n    ↓\nCoordinator synthesizes"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key characteristics"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Coordinator"},{"type":"text","text":" decomposes work, delegates to subagents, aggregates results\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Subagents"},{"type":"text","text":" never talk to each other — all coordination through coordinator\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"One-way reporting"},{"type":"text","text":" — subagents only report back to coordinator\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Isolated context"},{"type":"text","text":" — each subagent has own context window"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best for"},{"type":"text","text":": Parallel exploration tasks, independent analyses, embarrassingly parallel work"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Agent Teams (Peer-to-Peer)"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Planner Agent\n    ↓\nCreates specialized agents\n    ↓\nTeam Member 1 ← ↔ → Team Member 2\n    ↓          ↓          ↓\nTeam Member 3 ← ↔ → Team Member 4\n    ↓\nShared task list + self-coordination\n    ↓\nPlanner synthesizes"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key characteristics"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Team members"},{"type":"text","text":" can communicate directly with each other\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Shared task list"},{"type":"text","text":" — agents work on common goals\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Self-coordination"},{"type":"text","text":" — less coordinator control, more peer autonomy\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Peer messaging"},{"type":"text","text":" — teammates can message each other directly"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best for"},{"type":"text","text":": Complex tasks requiring discussion, collaboration, peer information sharing"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Orchestrator-Workers (Dynamic)"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Orchestrator (Central LLM)\n    ↓\nAnalyzes task → Dynamically determines subtasks\n    ↓\nSubtask 1 │ Subtask 2 │ Subtask 3\nWorker 1  │ Worker 2  │ Worker 3\n    ↓      ↓      ↓\nResults\n    ↓\nOrchestrator synthesizes"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key characteristics"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Orchestrator"},{"type":"text","text":" analyzes each unique task and dynamically determines best subtasks\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Workers"},{"type":"text","text":" execute assigned subtasks with specialized prompts\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Adaptive"},{"type":"text","text":" — orchestrator can revise decomposition based on what workers discover\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Dynamic"},{"type":"text","text":" — subtasks emerge as you investigate (unlike parallelization's fixed subtasks)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best for"},{"type":"text","text":": Unpredictable subtasks, complex tasks, research systems requiring adaptation"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Communication Patterns"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How Agents Exchange Information"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Method"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"What It Is"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Example"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tool call results"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Subagent returns structured output via tool result"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"JSON with research findings"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Structured outputs"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"JSON, XML passed between agents"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"{\"score\": 85, \"critique\": [...]}"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Conversation history"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Context passed into new API calls"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Previous turn included in next request"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Critical insight"},{"type":"text","text":": Communication happens "},{"type":"text","marks":[{"type":"bold"}],"text":"through context"},{"type":"text","text":" — agents don't share memory directly."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Explicit Context Passing (Critical for Subagents)"}]},{"type":"paragraph","content":[{"type":"text","text":"Subagents share nothing — coordinator must explicitly pass context:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# WRONG — writer has zero context\nresearch = run_subagent(\"research_agent\", task=\"research Lambda limits\")\nwriter = run_subagent(\"writer_agent\", task=\"write about Lambda\")\n\n# RIGHT — explicitly pass context through coordinator\nresearch = run_subagent(\"research_agent\", task=\"research Lambda limits\")\nwriter = run_subagent(\"writer_agent\", task=\"write about Lambda\", context=research)"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Coordination vs Communication: Key Differences"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Coordination"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Communication"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Focus"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"How agents organize and delegate work"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"How agents exchange information"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Decides"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Which agent does what, when"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"What data flows between agents"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mechanism"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Task decomposition, routing, aggregation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tool results, structured outputs, context"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Control"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Who manages the flow (coordinator vs peers)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"How messages are routed (one-way vs peer-to-peer)"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"When to Use Each Pattern"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Pattern"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Coordination Model"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Communication Model"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Best For"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hub-and-Spoke"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Coordinator manages all flow"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"One-way to coordinator only"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Parallel independent tasks"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Agent Teams"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Shared task list + self-coordination"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Peer-to-peer messaging"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Complex collaboration needing peer talk"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Orchestrator-Workers"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Orchestrator dynamically determines subtasks"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Results to orchestrator for synthesis"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Unpredictable subtasks, research systems"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Coordination Best Practices"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Use Concurrent Agent Deployment"}]},{"type":"paragraph","content":[{"type":"text","text":"Always deploy agents concurrently for maximum performance:"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// All 3 subagents run simultaneously (same message)\n[Task] description: \"Security\" run_in_background: true\n[Task] description: \"Performance\" run_in_background: true\n[Task] description: \"Tests\" run_in_background: true"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Match Agent Specialization to Task Requirements"}]},{"type":"paragraph","content":[{"type":"text","text":"Assign domain-focused system prompts and tools to specialists:\n- Security agent → security checklist + penetration testing tools\n- Performance agent → perf benchmarks + optimization guidelines\n- Documentation agent → style guide + template repository"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Use Coordination Agents for Complex Workflows"}]},{"type":"paragraph","content":[{"type":"text","text":"For multi-step workflows, use coordination agents to manage dependencies."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Explicitly Carry State Forward"}]},{"type":"paragraph","content":[{"type":"text","text":"Since each agent is stateless (only knows what's in current context window), orchestration must explicitly carry state:"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Pass previous results to next agent\nconst state = {\n  previousTurn: agent1.output,\n  currentPhase: \"implementation\"\n};\nagent2.input = { task, state };"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Communication Best Practices"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Use Structured Outputs (JSON/XML)"}]},{"type":"paragraph","content":[{"type":"text","text":"Agents communicate best via structured formats:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"iteration\": 1,\n  \"score\": 72,\n  \"pass\": false,\n  \"critique\": [\"missing type hints\", \"no array check\"],\n  \"suggestions\": [\"add @type\", \"check length\"]\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Design Clear Protocols"}]},{"type":"paragraph","content":[{"type":"text","text":"Define explicit message formats and routing rules:\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Protocol design"},{"type":"text","text":": How messages are formatted\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Message routing"},{"type":"text","text":": Which agent receives which messages\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Channel management"},{"type":"text","text":": How communication channels are organized"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Handle Distributed Failures"}]},{"type":"paragraph","content":[{"type":"text","text":"When coordinating concurrent agents, handle failures explicitly:\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Retry logic"},{"type":"text","text":" for failed subagents\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Timeout handling"},{"type":"text","text":" for long-running tasks\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Fallback strategies"},{"type":"text","text":" when primary agent fails"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of coordination & communication like "},{"type":"text","marks":[{"type":"bold"}],"text":"a construction project"},{"type":"text","text":":"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hub-and-spoke"},{"type":"text","text":": Architect (coordinator) gives tasks to electrical, plumbing, HVAC contractors who work separately and report back only to architect"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Agent Teams"},{"type":"text","text":": Construction crew where electricians, plumbers, and carpenters talk directly to each other (\"I need to run wires before you install pipes\")"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Orchestrator-Workers"},{"type":"text","text":": Project manager who dynamically figures out what needs to be done based on what workers discover (\"You found a collapsed wall — we also need to add structural support\")"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Coordination = how agents organize work; Communication = how agents exchange information"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Hub-and-spoke: coordinator manages flow, subagents report only to coordinator (no peer talk)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Agent Teams: shared task list, peer-to-peer messaging, self-coordination (experimental)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Orchestrator-Workers: orchestrator dynamically determines subtasks, can adapt based on results"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Communication happens through context — agents don't share memory directly"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Subagents share nothing — coordinator must explicitly pass context between them"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Always use concurrent agent deployment for maximum performance"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Match agent specialization to task requirements for optimal results"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Each agent is stateless — only knows what's in current context window"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use structured outputs (JSON/XML) for clear communication between agents"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Coordination patterns determine topology (hierarchical, mesh, adaptive); communication patterns determine how information flows (request-reply, pipeline, scatter-gather)."}]}]}}
