{"format":"tiptap/v1","updatedAt":"2026-06-20T09:56:04.387Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How to share:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Tap the "},{"type":"text","marks":[{"type":"bold"}],"text":"share button "},{"type":"text","text":"at the top right of the chat."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Shared links display the actual title instead of \"Untitled chat\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"You can share entire projects with teammates"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What sharing does:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Takes a "},{"type":"text","marks":[{"type":"bold"}],"text":"snapshot of your AI state"},{"type":"text","text":" — not just text"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Later, paste the link to load that exact state again"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"No retraining or resets needed — like cloning your best version on demand"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Privacy:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Threads are private unless you choose to share them"}]}]}]},{"type":"paragraph"}]}}
