{"format":"tiptap/v1","updatedAt":"2026-06-21T17:35:31.691Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Summarization & Extraction"},{"type":"text","text":" in Document Workflows are two complementary capabilities where Claude can "},{"type":"text","marks":[{"type":"bold"}],"text":"generate concise summaries of entire documents"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"bold"}],"text":"pull out specific data points, facts, or structured information"},{"type":"text","text":" from uploaded PDFs, DOCX files, and other documents for research, compliance, and professional analysis."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What it is"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Summarization"},{"type":"text","text":": Creating condensed versions that capture main points without losing critical information"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Extraction"},{"type":"text","text":": Pulling out specific data, entities, or structured content from dense documents"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why it matters"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Traditional Approach"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Claude Summarization & Extraction"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Manual reading (hours)"}]