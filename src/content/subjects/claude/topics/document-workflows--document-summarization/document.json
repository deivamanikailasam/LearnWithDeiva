":"text","marks":[{"type":"bold"}],"text":"Structured Summarization Prompts"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Complete summary prompt:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Read all sections and provide:\n1. A concise overall summary\n2. Key points from each major section/chapter\n3. Main arguments, insights, or findings\n4. Important data, patterns, or conclusions\n\nPresent output in clear headings and bullet points.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Research paper summary:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Summarize this research paper including:\n- Research question/hypothesis\n- Methodology used\n- Key findings\n- Limitations mentioned\n- Conclusions drawn\n\nFormat as a table with section headers.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Business report summary:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Extract and analyze data from this annual report:\n- Revenue figures by quarter\n- Key expense categories\n- Financial highlights\n- Profit margins\n- Growth trends\n\nReturn as JSON with exact values from charts.\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Model Selection for Summarization"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Task"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Recommended Model"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Quick summaries"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude 3.5/3.7 Sonnet"},{"type":"text","text":" (faster)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Deep analysis"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude Opus 4.7"},{"type":"text","text":" (more detailed)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multi-thousand pages"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude Sonnet 4"},{"type":"text","text":" (1M token context)"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How Extraction Works"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Entity Extraction Workflow"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Step 1: Choose AI Model\n  ↓ Select pre-trained Generative AI with NER capabilities\nStep 2: Preprocess Document\n  ↓ Text extraction (OCR if needed) + data cleaning\nStep 3: Entity Extraction API Call\n  ↓ NER model extracts entities from text\nStep 4: Customization\n  ↓ Fine-tune for domain-specific entities\nStep 5: Integration\n  ↓ Combine with summarization into single workflow\nStep 6: Postprocessing\n  ↓ Consolidate entities + highlight in summary\nStep 7: Output Presentation\n  ↓ Display to user in formatted UI"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Implementation steps:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Use the same or different AI model trained for Named Entity Recognition (NER) to extract entities from the text. Depending on AI provider, may need to fine-tune model to improve entity recognition specific to domain.\""}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Extraction Targets"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Document Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Extractable Content"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Legal Contracts"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Clauses, obligations, dates, parties, termination terms"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Financial Reports"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Revenue figures, expenses, profit margins, trends"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Research Papers"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Hypotheses, methodologies, findings, limitations"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Business Reports"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"KPIs, metrics, financial data, growth rates"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Technical Specs"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Parameters, requirements, procedures, warnings"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Named Entity Extraction Examples"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Legal contract extraction:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Extract all entities from this contract:\n- INVOICE_NUMBER (9-digit)\n- CUSTOMER_NUMBER (alphanumeric)\n- CUSTOMER_NAME\n- VENDOR_NAME\n- CONTRACT_START_DATE (YYYY-MM-DD)\n- CONTRACT_END_DATE (YYYY-MM-DD)\n- PAYMENT_AMOUNT (currency)\n- TERMINATION_CLAUSE\n\nReturn as JSON. If unclear, return 'UNK'.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"INVOICE_NUMBER\": \"123456789\",\n  \"CUSTOMER_NUMBER\": \"CUST001\",\n  \"CUSTOMER_NAME\": \"ABC Corp\",\n  \"VENDOR_NAME\": \"XYZ Services\",\n  \"CONTRACT_START_DATE\": \"2024-03-15\",\n  \"CONTRACT_END_DATE\": \"2025-03-14\",\n  \"PAYMENT_AMOUNT\": \"$5,000.00\",\n  \"TERMINATION_CLAUSE\": \"30-day notice required\"\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Visual PDF Extraction"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"For PDFs <100 pages:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Claude 4/3.7/3.5 Sonnet interpret charts, graphics, and tables, enabling nuanced document analysis for research, reporting, or compliance review.\""}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Chart/data extraction:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Upload financial report\nuploaded = client.beta.files.upload(\n    file=(\"annual_report.pdf\", open(\"annual_report.pdf\", \"rb\"), \"application/pdf\")\n)\n\n# Extract data from charts\nresponse = client.beta.messages.create(\n    model=\"claude-opus-4-8\",\n    messages=[{\n        \"role\": \"user\",\n        \"content\": [\n            {\"type\": \"text\", \"text\": \"Extract all data from charts and graphs:\n- Revenue trends over time\n- Regional breakdown percentages\n- Key metrics with exact values\n\nReturn as JSON with categories and values.\"},\n            {\"type\": \"document\", \"source\": {\"type\": \"file\", \"file_id\": uploaded.id}}\n        ]\n    }]\n)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Result:"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"revenue_trends\": [\n    {\"quarter\": \"Q1\", \"value\": 1000000},\n    {\"quarter\": \"Q2\", \"value\": 1150000},\n    {\"quarter\": \"Q3\", \"value\": 1250000},\n    {\"quarter\": \"Q4\", \"value\": 1250000}\n  ],\n  \"regional_breakdown\": [\n    {\"region\": \"North America\", \"percentage\": 45},\n    {\"region\": \"Europe\", \"percentage\": 30},\n    {\"region\": \"Asia\", \"percentage\": 25}\n  ]\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Table Extraction"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Text-based tables:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Claude can reconstruct and analyze tables when they are stored as text within the PDF. It can compare rows, extract trends, and summarize tabular information.\""}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Table extraction prompt:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Extract the table from this document:\n- List all rows and columns\n- Summarize trends across rows\n- Identify key patterns\n\nReturn as markdown table.\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Enable Citations for Verification"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"On Amazon Bedrock:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Visual PDF understanding is only available if citations are enabled. Without citations, Claude defaults to text extraction only.\""}]}]},{"type":"paragraph","content":[{"type":"text","marks