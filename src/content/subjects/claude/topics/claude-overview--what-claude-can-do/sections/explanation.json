+        .spinner {
+            border: 4px solid #f3f3f3;
+            border-top: 4px solid #667eea;
+            border-radius: 50%;
+            width: 40px;
+            height: 40px;
+            animation: spin 1s linear infinite;
+            margin: 0 auto 15px;
+        }
+        @keyframes spin {
+            0% { transform: rotate(0deg); }
+            100% { transform: rotate(360deg); }
+        }
+        .alert {
+            border-radius: 10px;
+            border: none;
+        }
+        .table {
+            border-radius: 10px;
+            overflow: hidden;
+        }
+        .table th {
+            background: #667eea;
+            color: white;
+            border: none;
+        }
+        .badge {
+            font-size: 0.8em;
+            padding: 5px 10px;
+        }
+        .file-info {
+            background: #e8f4fd;
+            border-radius: 10px;
+            padding: 15px;
+            margin-bottom: 20px;
+        }
+        .comparison-table {
+            font-size: 0.9em;
+        }
+        .comparison-table th {
+            background: #495057;
+            color: white;
+        }
+        .comparison-table td {
+            vertical-align: middle;
+        }
+        .status-badge {
+            font-size: 0.75em;
+        }
+    </style>
+</head>
+<body>
+    <div class="container-fluid">
+        <div class="row justify-content-center">
+            <div class="col-lg-10">
+                <div class="main-container">
+                    <!-- Header -->
+                    <div class="header">
+                        <h1><i class="fas fa-file-excel"></i> Excel Data Extractor</h1>
+                        <p>Extract and compare data from Excel files with intelligent column mapping</p>
+                    </div>
+
+                    <!-- Upload Section -->
+                    <div class="upload-area" id="uploadArea">
+                        <div class="upload-icon">
+                            <i class="fas fa-cloud-upload-alt"></i>
+                        </div>
+                        <h4>Upload Excel File</h4>
+                        <p class="text-muted">Drag and drop your Excel file here or click to browse</p>
+                        <input type="file" id="fileInput" accept=".xlsx,.xls" style="display: none;">
+                        <button class="btn btn-primary" onclick="document.getElementById('fileInput').click()">
+                            <i class="fas fa-folder-open"></i> Choose File
+                        </button>
+                    </div>
+
+                    <!-- File Info -->
+                    <div class="file-info" id="fileInfo" style="display: none;">
+                        <h5><i class="fas fa-info-circle"></i> File Information</h5>
+                        <div id="fileDetails"></div>
+                    </div>
+
+                    <!-- Loading -->
+                    <div class="loading" id="loading">
+                        <div class="spinner"></div>
+                        <p>Processing Excel file...</p>
+                    </div>
+
+                    <!-- Results -->
+                    <div id="results" style="display: none;">
+                        <!-- Summary Stats -->
+                        <div class="result-card">
+                            <div class="result-header">
+                                <i class="fas fa-chart-bar"></i> Summary Statistics
+                            </div>
+                            <div class="result-body">
+                                <div class="stats-grid" id="summaryStats"></div>
+                            </div>
+                        </div>
+
+                        <!-- Column Mapping -->
+                        <div class="result-card">
+                            <div class="result-header">
+                                <i class="fas fa-map"></i> Column Mapping
+                            </div>
+                            <div class="result-body">
+                                <div id="columnMapping"></div>
+                            </div>
+                        </div>
+
+                        <!-- Data Comparison -->
+                        <div class="result-card">
+                            <div class="result-header">
+                                <i class="fas fa-balance-scale"></i> Data Comparison
+                            </div>
+                            <div class="result-body">
+                                <div id="dataComparison"></div>
+                            </div>
+                        </div>
+
+                        <!-- Extracted Data -->
+                        <div class="result-card">
+                            <div class="result-header">
+                                <i class="fas fa-table"></i> Extracted Data
+                            </div>
+                            <div class="result-body">
+                                <div id="extractedData"></div>
+                            </div>
+                        </div>
+
+                        <!-- Download Results -->
+                        <div class="text-center mt-4">
+                            <button class="btn btn-success btn-lg" id="downloadBtn" style="display: none;">
+                                <i class="fas fa-download"></i> Download Results
+                            </button>
+                        </div>
+                    </div>
+
+                    <!-- Error Messages -->
+                    <div id="errorMessages"></div>
+                </div>
+            </div>
+        </div>
+    </div>
+
+    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
+    <script>
+        let currentResults = null;
+
+        // File upload handling
+        const uploadArea = document.getElementById('uploadArea');
+        const fileInput = document.getElementById('fileInput');
+        const loading = document.getElementById('loading');
+        const results = document.getElementById('results');
+        const fileInfo = document.getElementById('fileInfo');
+
+        // Drag and drop functionality
+        uploadArea.addEventListener('dragover', (e) => {
+            e.preventDefault();
+            uploadArea.classList.add('dragover');
+        });
+
+        uploadArea.addEventListener('dragleave', () => {
+            uploadArea.classList.remove('dragover');
+        });
+
+        uploadArea.addEventListener('drop', (e) => {
+            e.preventDefault();
+            uploadArea.classList.remove('dragover');
+            const files = e.dataTransfer.files;
+            if (files.length > 0) {
+                handleFile(files[0]);
+            }
+        });
+
+        fileInput.addEventListener('change', (e) => {
+            if (e.target.files.length > 0) {
+                handleFile(e.target.files[0]);
+            }
+        });
+
+        function handleFile(file) {
+            if (!file.name.match(/\.(xlsx|xls)$/)) {
+                showError('Please select a valid Excel file (.xlsx or .xls)');
+                return;
+            }
+
+            // Show file info
+            showFileInfo(file);
+
+            // Upload and process
+            uploadFile(file);
+        }
+
+        function showFileInfo(file) {
+            const fileDetails = document.getElementById('fileDetails');
+            fileDetails.innerHTML = `
+                <div class="row">
+                    <div class="col-md-6">
+                        <strong>Filename:</strong> ${file.name}<br>
+                        <strong>Size:</strong> ${(file.size / 1024 / 1024).toFixed(2)} MB<br>
+                        <strong>Type:</strong> ${file.type || 'Excel file'}
+                    </div>
+                    <div class="col-md-6">
+                        <strong>Last Modified:</strong> ${new Date(file.lastModified).toLocaleString()}
+                    </div>
+                </div>
+            `;
+            fileInfo.style.display = 'block';
+        }
+
+        function uploadFile(file) {
+            const formData = new FormData();
+            formData.append('file', file);
+
+            loading.style.display = 'block';
+            results.style.display = 'none';
+            hideError();
+
+            fetch('/upload', {
+                method: 'POST',
+                body: formData
+            })
+            .then(response => response.json())
+            .then(data => {
+                loading.style.display = 'none';
+                if (data.success) {
+                    currentResults = data.results;
+                    displayResults(data.results);
+                } else {
+                    showError(data.error || 'An error occurred while processing the file');
+                }
+            })
+            .catch(error => {
+                loading.style.display = 'none';
+                showError('Network error: ' + error.message);
+            });
+        }
+
+        function displayResults(results) {
+            results.style.display = 'block';
+            
+            // Display summary stats
+            displaySummaryStats(results.summary);
+            
+            // Display column mapping
+            displayColumnMapping(results.column_mapping);
+            
+            // Display data comparison
+            displayDataComparison(results.comparison);
+            
+            // Display extracted data
+            displayExtractedData(results.extracted_data);
+            
+            // Show download button
+            document.getElementById('downloadBtn').style.display = 'inline-block';
+        }
+
+        function displaySummaryStats(summary) {
+            const statsContainer = document.getElementById('summaryStats');
+            statsContainer.innerHTML = `
+                <div class="stat-item">
+                    <div class="stat-value">${summary.total_rows}</div>
+                    <div class="stat-label">Total Rows</div>
+                </div>
+                <div class="stat-item">
+                    <div class="stat-value">${summary.total_columns}</div>
+                    <div class="stat-label">Total Columns</div>
+                </div>
+                <div class="stat-item">
+                    <div class="stat-value">${summary.mapped_columns}</div>
+                    <div class="stat-label">Mapped Columns</div>
+                </div>
+                <div class="stat-item">
+                    <div class="stat-value">${summary.comparison_matches}</div>
+                    <div class="stat-label">Matches Found</div>
+                </div>
+            `;
+        }
+
+        function displayColumnMapping(mapping) {
+            const mappingContainer = document.getElementById('columnMapping');
+            let html = '<div class="table-responsive"><table class="table table-striped">';
+            html += '<thead><tr><th>Standard Column</th><th>Excel Column</th><th>Confidence</th><th>Status</th></tr></thead><tbody>';
+            
+            for (const [standard, excel] of Object.entries(mapping)) {
+                const confidence = mapping.confidence ? mapping.confidence[standard] : 'N/A';
+                const status = excel ? 'success' : 'warning';
+                const statusText = excel ? 'Mapped' : 'Not Found';
+                
+                html += `
+                    <tr>
+                        <td><strong>${standard}</strong></td>
+                        <td>${excel || 'Not found'}</td>
+                        <td>${confidence}</td>
+                        <td><span class="badge bg-${status} status-badge">${statusText}</span></td>
+                    </tr>
+                `;
+            }
+            
+            html += '</tbody></table></div>';
+            mappingContainer.innerHTML = html;
+        }
+
+        function displayDataComparison(comparison) {
+            const comparisonContainer = document.getElementById('dataComparison');
+            
+            if (!comparison || Object.keys(comparison).length === 0) {
+                comparisonContainer.innerHTML = '<p class="text-muted">No comparison data available</p>';
+                return;
+            }
+
+            let html = '<div class="table-responsive"><table class="table table-striped comparison-table">';
+            html += '<thead><tr><th>Field</th><th>Matches</th><th>Mismatches</th><th>Match Rate</th><th>Details</th></tr></thead><tbody>';
+            
+            for (const [field, data] of Object.entries(comparison)) {
+                const matchRate = data.total > 0 ? ((data.matches / data.total) * 100).toFixed(1) : 0;
+                const matchClass = matchRate >= 80 ? 'success' : matchRate >= 50 ? 'warning' : 'danger';
+                
+                html += `
+                    <tr>
+                        <td><strong>${field}</strong></td>
+                        <td><span class="badge bg-success">${data.matches}</span></td>
+                        <td><span class="badge bg-danger">${data.mismatches}</span></td>
+                        <td><span class="badge bg-${matchClass}">${matchRate}%</span></td>
+                        <td>
+                            <button class="btn btn-sm btn-outline-primary" onclick="showComparisonDetails('${field}')">
+                                View Details
+                            </button>
+                        </td>
+                    </tr>
+                `;
+            }
+            
+            html += '</tbody></table></div>';
+            comparisonContainer.innerHTML = html;
+        }
+
+        function displayExtractedData(data) {
+            const dataContainer = document.getElementById('extractedData');
+            
+            if (!data || data.length === 0) {
+                dataContainer.innerHTML = '<p class="text-muted">No data extracted</p>';
+                return;
+            }
+
+            // Show first 10 rows
+            const displayData = data.slice(0, 10);
+            const columns = Object.keys(displayData[0] || {});
+            
+            let html = '<div class="table-responsive"><table class="table table-striped">';
+            html += '<thead><tr>';
+            columns.forEach(col => {
+                html += `<th>${col}</th>`;
+            });
+            html += '</tr></thead><tbody>';
+            
+            displayData.forEach(row => {
+                html += '<tr>';
+                columns.forEach(col => {
+                    html += `<td>${row[col] || ''}</td>`;
+                });
+                html += '</tr>';
+            });
+            
+            html += '</tbody></table></div>';
+            
+            if (data.length > 10) {
+                html += `<p class="text-muted">Showing first 10 rows of ${data.length} total rows</p>`;
+            }
+            
+            dataContainer.innerHTML = html;
+        }
+
+        function showComparisonDetails(field) {
+            if (!currentResults || !currentResults.comparison[field]) return;
+            
+            const details = currentResults.comparison[field].details;
+            let html = `<h5>Comparison Details for ${field}</h5>`;
+            html += '<div class="table-responsive"><table class="table table-sm">';
+            html += '<thead><tr><th>Row</th><th>Expected</th><th>Actual</th><th>Status</th></tr></thead><tbody>';
+            
+            details.forEach(detail => {
+                const statusClass = detail.match ? 'success' : 'danger';
+                const statusText = detail.match ? 'Match' : 'Mismatch';
+                
+                html += `
+                    <tr>
+                        <td>${detail.row}</td>
+                        <td>${detail.expected}</td>
+                        <td>${detail.actual}</td>
+                        <td><span class="badge bg-${statusClass}">${statusText}</span></td>
+                    </tr>
+                `;
+            });
+            
+            html += '</tbody></table></div>';
+            
+            // Show in modal or alert
+            alert(html.replace(/<[^>]*>/g, '')); // Simple alert for now
+        }
+
+        function showError(message) {
+            const errorContainer = document.getElementById('errorMessages');
+            errorContainer.innerHTML = `
+                <div class="alert alert-danger alert-dismissible fade show" role="alert">
+                    <i class="fas fa-exclamation-triangle"></i> ${message}
+                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
+                </div>
+            `;
+        }
+
+        function hideError() {
+            document.getElementById('errorMessages').innerHTML = '';
+        }
+
+        // Download functionality
+        document.getElementById('downloadBtn').addEventListener('click', () => {
+            if (currentResults) {
+                const dataStr = JSON.stringify(currentResults, null, 2);
+                const dataBlob = new Blob([dataStr], {type: 'application/json'});
+                const url = URL.createObjectURL(dataBlob);
+                const link = document.createElement('a');
+                link.href = url;
+                link.download = 'excel_extraction_results.json';
+                link.click();
+                URL.revokeObjectURL(url);
+            }
+        });
+    </script>
+</body>
+</html>

