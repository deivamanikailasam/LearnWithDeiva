span":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Error handling"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Must handle errors for each parallel call"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Individual error recovery"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Resource contention"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Multiple DB calls may overload system"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Rate limiting, connection pooling"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How It Works"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Parallel vs. Sequential Comparison"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Sequential (3 calls):\nTurn 1: Claude → tool_use #1 → your code → tool_result #1 → Claude\nTurn 2: Claude → tool_use #2 → your code → tool_result #2 → Claude\nTurn 3: Claude → tool_use #3 → your code → tool_result #3 → Claude\nTotal: 3 API calls, 1,500ms latency\n\nParallel (3 calls):\nTurn 1: Claude → tool_use #1 + tool_use #2 + tool_use #3 → your code (parallel) → all tool_results → Claude\nTotal: 1 API call, 500ms latency"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Parallel Tool Call Pattern"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// User requests multiple items\nconst response = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [{ role: \"user\", content: \"What are stock prices for AAPL, GOOGL, and MSFT?\" }],\n  tools: [getStockPriceTool]\n});\n\n// Claude returns multiple tool_use blocks\nconst toolUseBlocks = response.content.filter(c => c.type === \"tool_use\");\nconsole.log(toolUseBlocks.length); // 3\n\n// Store IDs before execution\nconst toolIds = toolUseBlocks.map(block => block.id);\n\n// Execute in parallel\nconst results = await Promise.all(\n  toolUseBlocks.map(block => {\n    const { name, input } = block;\n    return executeTool(name, input); // Returns result\n  })\n);\n\n// Map results back to tool_use_ids\nconst toolResultBlocks = toolUseBlocks.map((block, i) => ({\n  type: \"tool_result\",\n  tool_use_id: block.id,  // Match original ID\n  content: results[i].toString()\n}));\n\n// Send all results back in one message\nconst response2 = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  messages: [\n    ...response.messages,\n    { role: \"user\", content: toolResultBlocks } // One message with all results\n  ],\n  tools: [getStockPriceTool]\n});\n\n// Claude gives final answer\nconsole.log(response2.content[0].text);\n// \"AAPL is $175.43, GOOGL is $142.67, MSFT is $378.91\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use Parallel vs. Sequential"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Parallel"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Sequential"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Independent queries"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Multiple stock prices"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Dependencies"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Query user → then query user's orders"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Validation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Check permissions, token, role"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"File reads"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Read multiple files"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"API calls"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Fetch data from multiple services"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Call service A → then use result to call service B"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Batch operations"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Update multiple records"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"[claudecn](https://claudecn.com/en/docs/cookbook/tool-use/parallel-tools/)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Iterate "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"response.content"},{"type":"text","marks":[{"type":"bold"}],"text":" for Multiple Blocks"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Extract all tool_use blocks\nconst toolUseBlocks = response.content.filter(c => c.type === \"tool_use\");\n\n// Process each one\ntoolUseBlocks.forEach(block => {\n  const { name, input, id } = block;\n  console.log(`Executing ${name} with input ${JSON.stringify(input)}, id: ${id}`);\n});"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Use "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"Promise.all"},{"type":"text","marks":[{"type":"bold"}],"text":" for Parallel Execution"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Execute all tools in parallel\nconst results = await Promise.all(\n  toolUseBlocks.map(block => executeTool(block.name, block.input))\n);"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Match "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_use_id"},{"type":"text","marks":[{"type":"bold"}],"text":" Correctly"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Store IDs before execution\nconst toolIds = toolUseBlocks.map(block => block.id);\n\n// Execute\nconst results = await Promise.all(\n  toolUseBlocks.map(block => executeTool(block.name, block.input))\n);\n\n// Map with correct IDs\nconst toolResultBlocks = toolUseBlocks.map((block, i) => ({\n  type: \"tool_result\",\n  tool_use_id: block.id,  // Must match original\n  content: results[i].toString()\n}));"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Send All Results in One Message"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// ✅ Good: One message with all results\nawait client.messages.create({\n  messages: [\n    ...response.messages,\n    { role: \"user\", content: toolResultBlocks } // All results together\n  ]\n});\n\n// ❌ Bad: Multiple messages (sequential)\ntoolResultBlocks.forEach(result => {\n  await client.messages.create({\n    messages: [...response.messages, { role: \"user\", content: result }]\n  });\n});"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Add Prompting to Boost Parallel Success"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Basic prompting: ~100% parallel success rate\nconst response = await client.messages.create({\n  model: \"claude-4-sonnet-20251027\",\n  system: \"When you need multiple pieces of information, call all tools in parallel.\",\n  messages: [{ role: \"user\", content: \"Get stock prices for AAPL, GOOGL, MSFT\" }],\n  tools: [getStockPriceTool]\n});"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Use Batch Tool for Dependent Calls"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Instead of sequential calls, create a batch tool\nconst batchStockPricesTool = {\n  name: \"batch_stock_prices\",\n  description: \"Get stock prices for multiple symbols in one call. Use when you need multiple prices.\",\n  input_schema: {\n    type: \"object\",\n    properties: {\n      symbols: {\n        type: \"array\",\n        description: \"List of stock symbols\",\n        items: { type: \"string\" }\n      }\n    },\n    required: [\"symbols\"]\n  }\n};\n\n// Claude calls ONE tool instead of 3\nconst response = await client.messages.create({\n  messages: [{ role: \"user\", content: \"Get stock prices for AAPL, GOOGL, MSFT\" }],\n  tools: [batchStockPricesTool]\n});\n\n// Your code executes once, returns all prices\nconst result = batchStockPrices([\"AAPL\", \"GOOGL\", \"MSFT\"]);\n// [{ symbol: \"AAPL\", price: 175.43 }, { symbol: \"GOOGL\", price: 142.67 }, ...]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Parallel = multiple tools in one turn"},{"type":"text","text":" → Claude emits N "},{"type":"text","marks":[{"type":"code"}],"text":"tool_use"},{"type":"text","text":" blocks"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Parallel reduces latency by 66%"},{"type":"text","text":" → 3 calls in 500ms vs. 1,500ms"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude 4 excels at parallel"},{"type":"text","text":" → High success rate without prompting"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"Promise.all"},{"type":"text","marks":[{"type":"bold"}],"text":" for execution"},{"type":"text","text":" → True parallel, not sequential"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Match "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_use_id"},{"type":"text","marks":[{"type":"bold"}],"text":" correctly"},{"type":"text","text":" → Each result needs its original ID"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Send all results in one message"},{"type":"text","text":" → Efficiency gain"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Iterate "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"response.content"},{"type":"text","text":" → Handle multiple "},{"type":"text","marks":[{"type":"code"}],"text":"tool_use"},{"type":"text","text":" blocks"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use batch tools for dependencies"},{"type":"text","text":" → Reduce turns when tools depend on each other"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Add prompting for 100%"},{"type":"text","text":" → \"Call all tools in parallel\" boosts success rate"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cost/latency as architecture"},{"type":"text","text":" → Measure parallelism tradeoffs"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"For your Box Hill distributed systems work, I'd implement "},{"type":"text","marks":[{"type":"bold"}],"text":"parallel execution for independent database queries + batch tools for dependent operations + "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"Promise.all"},{"type":"text","marks":[{"type":"bold"}],"text":" for true parallel execution"},{"type":"text","text":". This gives you 66% latency reduction for stock price lookups, user validation, and file reads while maintaining efficiency."}]}]}}
