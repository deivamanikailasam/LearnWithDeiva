{"format":"tiptap/v1","updatedAt":"2026-06-21T15:06:07.770Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Parallel tool use"},{"type":"text","text":" is Claude's capability to call "},{"type":"text","marks":[{"type":"bold"}],"text":"multiple tools simultaneously in a single turn"},{"type":"text","text":" instead of sequentially. When Claude needs multiple pieces of information, it can emit multiple "},{"type":"text","marks":[{"type":"code"}],"text":"tool_use"},{"type":"text","text":" blocks in one response that your application executes in parallel, then sends all results back together."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key insight"},{"type":"text","text":": \"Claude 4 models excel at parallel tool execution. They have a high success rate in using parallel tool calling without any prompting to do so, but some minor prompting can boost this behavior to ~100% parallel tool use success rate.\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why It Matters"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sequential tool calls"},{"type":"text","text":": Fetch stock 1 → 500ms → Fetch stock 2 → 500ms → Fetch stock 3 → 500ms = "},{"type":"text","marks":[{"type":"bold"}],"text":"1,500ms total"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Parallel tool calls"},{"type":"text","text":": Fetch stocks 1, 2, 3 simultaneously = "},{"type":"text","marks":[{"type":"bold"}],"text":"500ms total"},{"type":"text","text":" (66% faster)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"For your distributed systems work at Box Hill"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Multiple database queries"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"query_users(...) + query_orders(...) + query_products(...)"},{"type":"text","text":" → 3 queries in parallel\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"API integrations"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"fetchStockPrice(\"AAPL\") + fetchStockPrice(\"GOOGL\") + fetchStockPrice(\"MSFT\")"},{"type":"text","text":" → 3 API calls in parallel\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Validation steps"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"validateUser(id) + validatePermissions(id) + validateAccessToken(id)"},{"type":"text","text":" → 3 checks in parallel\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"File operations"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"readFile(\"auth.ts\") + readFile(\"database.ts\") + readFile(\"api.ts\")"},{"type":"text","text":" → 3 file reads in parallel"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Benefits"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Benefit"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Value"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Impact"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Latency reduction"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"c