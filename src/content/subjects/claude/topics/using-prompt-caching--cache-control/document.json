":3},"content":[{"type":"text","text":"Placing Breakpoints"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"response = client.messages.create(\n    model=\"claude-3-5-sonnet-20241022\",\n    messages=[\n        {\n            \"role\": \"user\",\n            \"content\": [\n                {\n                    \"type\": \"text\",\n                    \"text\": large_book_text,\n                    \"cache_control\": {\"type\": \"ephemeral\"}  # Breakpoint on book\n                },\n                {\n                    \"type\": \"text\",\n                    \"text\": \"What is the title?\"\n                }\n            ]\n        }\n    ]\n)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Multi-Turn with Explicit Breakpoints"}]},{"type":"paragraph","content":[{"type":"text","text":"You "},{"type":"text","marks":[{"type":"bold"}],"text":"manually move the breakpoint forward"},{"type":"text","text":" on each turn:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Turn 1\nmessage_1 = [\n    {\n        \"role\": \"user\",\n        \"content\": [\n            {\n                \"type\": \"text\",\n                \"text\": large_book_text,\n                \"cache_control\": {\"type\": \"ephemeral\"}  # Breakpoint 1\n            },\n            {\"type\": \"text\", \"text\": \"What is the title?\"}\n        ]\n    }\n]\n\n# Turn 2 (move breakpoint forward)\nmessage_2 = [\n    {\n        \"role\": \"user\",\n        \"content\": [\n            {\n                \"type\": \"text\",\n                \"text\": large_book_text,  # No cache_control here\n                # Breakpoint moved to next block\n            },\n            {\"type\": \"text\", \"text\": previous_question},\n            {\n                \"type\": \"text\",\n                \"text\": \"Who are Mr. and Mrs. Bennet?\",\n                \"cache_control\": {\"type\": \"ephemeral\"}  # Breakpoint 2\n            }\n        ]\n    }\n]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Performance:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Turn 1:  Time 4.53s, Cache read 187,361 tokens\nTurn 2:  Time 7.57s, Cache read 187,399 tokens\nTurn 3:  Time 6.85s, Cache write 294 tokens, Cache read 187,399 tokens\nTurn 4:  Time 7.00s, Cache write 315 tokens, Cache read 187,693 tokens"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Breakpoint Placement Strategy"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Where to Place Breakpoints"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Block Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Placement"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Why"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"System message"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Last system block"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Part of static prefix, reused across all turns"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"