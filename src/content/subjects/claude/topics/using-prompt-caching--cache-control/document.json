]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Automatic Breakpoints for Server Tools"}]},{"type":"paragraph","content":[{"type":"text","text":"When your request has prompt caching enabled and Claude uses server tools (web search, web fetch, code execution):"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"API automatically places cache breakpoint on server tool result\n→ Before running next iteration of agentic loop\n→ Later iterations read growing prefix from cache"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key details:"},{"type":"text","text":"\n- Always uses "},{"type":"text","marks":[{"type":"bold"}],"text":"default 5-minute TTL"},{"type":"text","text":", independent of your custom TTL\n- Appears under "},{"type":"text","marks":[{"type":"code"}],"text":"cache_creation.ephemeral_5m_input_tokens"},{"type":"text","text":" in response usage\n- Only applies when request already has "},{"type":"text","marks":[{"type":"bold"}],"text":"at least one "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"cache_control"},{"type":"text","marks":[{"type":"bold"}],"text":" marker"},{"type":"text","text":"\n- Requests without prompt caching do "},{"type":"text","marks":[{"type":"bold"}],"text":"not"},{"type":"text","text":" receive automatic breakpoint"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mixed Automatic + Explicit Approach"}]},{"type":"paragraph","content":[{"type":"text","text":"You can combine both:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"conversation = [\n    {\n        \"role\": \"user\",\n        \"content\": [\n            {\n                \"type\": \"text\",\n                \"text\": large_book_text,\n                \"cache_control\": {\"type\": \"ephemeral\"}  # Explicit breakpoint\n            }\n        ]\n 