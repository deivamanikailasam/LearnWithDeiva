        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "If your infrastructure uses OpenTelemetry, emit lineage spans as OTEL spans instead of custom JSONL. This lets you view lineage in Jaeger, Grafana Tempo, or any OTLP-compatible backend alongside your service traces."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from opentelemetry import trace\nfrom opentelemetry.sdk.trace import TracerProvider\nfrom opentelemetry.sdk.trace.export import BatchSpanProcessor\nfrom opentelemetry.exporter.otlp.proto.grpc.trace_exporter import OTLPSpanExporter\n\nprovider = TracerProvider()\nprovider.add_span_processor(\n    BatchSpanProcessor(OTLPSpanExporter(endpoint=\"http://otel-collector:4317\"))\n)\ntrace.set_tracer_provider(provider)\notel_tracer = trace.get_tracer(\"claude.lineage\")\n\ndef otel_traced_call(user_message: str, session_id: str):\n    with otel_tracer.start_as_current_span(\"claude.interaction\") as root:\n        root.set_attribute(\"session.id\", session_id)\n        root.set_attribute(\"user.prompt_hash\", text_hash(user_message))\n\n        with otel_tracer.start_as_current_span(\"claude.rag_retrieval\") as rag_span:\n            results = retrieve_documents(user_message)\n            rag_span.set_attribute(\"rag.source_count\", len(results))\n            rag_span.set_attribute(\"rag.source_ids\", str([r[\"source_id\"] for r in results]))\n\n        with otel_tracer.start_as_current_span(\"claude.api_call\") as api_span:\n            response = call_claude_api(user_message, results)\n            api_span.set_attribute(\"claude.model\", \"claude-opus-4-8\")\n            api_span.set_attribute(\"claude.input_tokens\", response.usage.input_tokens)\n            api_span.set_attribute(\"claude.output_tokens\", response.usage.output_tokens)\n\n        return response.content[0].text\n"
          }
