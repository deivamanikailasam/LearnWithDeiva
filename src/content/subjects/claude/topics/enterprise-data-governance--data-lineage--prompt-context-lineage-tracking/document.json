      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Lineage Record Schema"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass, field\nfrom typing import Optional\nimport hashlib, time, uuid\n\n@dataclass\nclass LineageSpan:\n    span_id: str\n    trace_id: str\n    span_type: str                  # one of the types above\n    parent_span_ids: list[str]      # empty for root spans\n    timestamp: str                  # ISO 8601 UTC\n    attributes: dict                # span-type-specific fields\n    status: str = \"ok\"             # \"ok\" | \"error\"\n\n    @classmethod\n    def new(cls, trace_id: str, span_type: str,\n            parent_ids: list[str], attrs: dict) -> \"LineageSpan\":\n        return cls(\n            span_id=str(uuid.uuid4())[:8],\n            trace_id=trace_id,\n            span_type=span_type,\n            parent_span_ids=parent_ids,\n            timestamp=__import__(\"datetime\").datetime.utcnow().isoformat() + \"Z\",\n            attributes=attrs,\n        )\n\ndef text_hash(text: str) -> str:\n    \"\"\"Stable fingerprint of text content without storing the content itself.\"\"\"\n    return hashlib.sha256(text.encode()).hexdigest()[:16]\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Implementing the Lineage Tracer"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The lineage tracer wraps the context assembly and Claude API call steps. It instruments each stage to emit spans, then writes them to an append-only store."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Tracer Implementation"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import json, uuid\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom dataclasses import asdict\nimport anthropic\n\nLINEAGE_LOG = Path(\"logs/lineage.jsonl\")\n\nclass LineageTracer:\n    def __init__(self, trace_id: str | None = None):\n        self.trace_id = trace_id or str(uuid.uuid4())\n        self._spans: list[LineageSpan] = []\n\n    def record_user_input(self, text: str, session_id: str) -> LineageSpan:\n        span = LineageSpan.new(\n            self.trace_id, \"user_input\", [],\n            {\"text_hash\": text_hash(text), \"char_count\": len(text), \"session_id\": session_id},\n        )\n        self._spans.append(span)\n        return span\n\n    def record_rag_retrieval(self, query: str, results: list[dict],\n                              parent_id: str) -> LineageSpan:\n        span = LineageSpan.new(\n            self.trace_id, \"rag_retrieval\", [parent_id],\n            {\n                \"retrieval_query_hash\": text_hash(query),\n                \"source_ids\": [r[\"source_id\"] for r in results],\n                \"chunk_ids\": [r[\"chunk_id\"] for r in results],\n                \"similarity_scores\": [round(r[\"score\"], 4) for r in results],\n            },\n        )\n        self._spans.append(span)\n        return span\n\n    def record_system_prompt(self, template_id: str, version: str,\n                              text: str) -> LineageSpan:\n        span = LineageSpan.new(\n            self.trace_id, \"system_prompt\", [],\n            {\"template_id\": template_id, \"version\": version,\n             \"text_hash\": text_hash(text), \"char_count\": len(text)},\n        )\n        self._spans.append(span)\n        return span\n\n    def record_context_assembly(self, messages: list[dict],\n                                 parent_ids: list[str], total_tokens: int,\n                                 truncated: bool) -> LineageSpan:\n        context_text = json.dumps(messages)\n        span = LineageSpan.new(\n            self.trace_id, \"context_assembly\", parent_ids,\n            {\"context_hash\": text_hash(context_text), \"total_tokens\": total_tokens,\n             \"truncation_applied\": truncated},\n        )\n        self._spans.append(span)\n        return span\n\n    def record_api_call(self, model: str, region: str, input_tokens: int,\n                         request_id: str, parent_id: str) -> LineageSpan:\n        span = LineageSpan.new(\n            self.trace_id, \"claude_api_call\", [parent_id],\n            {\"model\": model, \"region\": region, \"input_tokens\": input_tokens,\n             \"anthropic_request_id\": request_id},\n        )\n        self._spans.append(span)\n        return span\n\n    def record_response(self, output_text: str, output_tokens: int,\n                         finish_reason: str, latency_ms: int,\n                         parent_id: str) -> LineageSpan:\n        span = LineageSpan.new(\n            self.trace_id, \"claude_response\", [parent_id],\n            {\"output_hash\": text_hash(output_text), \"output_tokens\": output_tokens,\n             \"finish_reason\": finish_reason, \"latency_ms\": latency_ms},\n        )\n        self._spans.append(span)\n        return span\n\n    def flush(self):\n        \"\"\"Write all spans to the append-only lineage log.\"\"\"\n        with LINEAGE_LOG.open(\"a\") as f:\n            for span in self._spans:\n                f.write(json.dumps(asdict(span)) + \"\\n\")\n        self._spans.clear()\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "End-to-End Traced Claude Call"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import time\n\ndef traced_claude_call(\n    user_message: str,\n    session_id: str,\n    rag_results: list[dict],  # [{\"source_id\": ..., \"chunk_id\": ..., \"score\": ..., \"text\": ...}]\n    system_template_id: str = \"support-v2\",\n    system_version: str = \"2025-01\",\n    system_text: str = \"You are a helpful assistant.\",\n):\n    tracer = LineageTracer()\n    client = anthropic.Anthropic()\n\n    # Record each input span\n    user_span = tracer.record_user_input(user_message, session_id)\n    sys_span = tracer.record_system_prompt(system_template_id, system_version, system_text)\n    rag_span = tracer.record_rag_retrieval(user_message, rag_results, user_span.span_id)\n\n    # Assemble context\n    rag_context = \"\\n\\n\".join(r[\"text\"] for r in rag_results)\n    messages = [\n        {\"role\": \"user\", \"content\": f\"Context:\\n{rag_context}\\n\\nQuestion: {user_message}\"}\n    ]\n    assembly_span = tracer.record_context_assembly(\n        messages,\n        parent_ids=[user_span.span_id, sys_span.span_id, rag_span.span_id],\n        total_tokens=len(system_text.split()) + len(user_message.split()) + sum(len(r[\"text\"].split()) for r in rag_results),\n        truncated=False,\n    )\n\n    t0 = time.monotonic()\n    response = client.messages.create(\n        model=\"claude-opus-4-8\",\n        max_tokens=1024,\n        system=system_text,\n        messages=messages,\n    )\n    latency_ms = round((time.monotonic() - t0) * 1000)\n\n    api_span = tracer.record_api_call(\n        model=\"claude-opus-4-8\",\n        region=\"us-east-1\",\n        input_tokens=response.usage.input_tokens,\n        request_id=response.id,\n        parent_id=assembly_span.span_id,\n    )\n    tracer.record_response(\n        output_text=response.content[0].text,\n        output_tokens=response.usage.output_tokens,\n        finish_reason=response.stop_reason,\n        latency_ms=latency_ms,\n        parent_id=api_span.span_id,\n    )\n    tracer.flush()\n    return response.content[0].text\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Querying the Lineage Store"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Once lineage is stored as JSONL (or in a dedicated store like OpenSearch or Postgres), you can answer governance questions by querying across spans linked by trace_id."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Find All Traces That Used a Specific Source Document"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import json\nfrom pathlib import Path\n\ndef traces_using_source(source_id: str) -> list[str]:\n    \"\"\"\n    Return all trace_ids whose rag_retrieval span referenced source_id.\n    Use this when a source document is deleted or retracted.\n    \"\"\"\n    affected = []\n    for line in Path(\"logs/lineage.jsonl\").read_text().splitlines():\n        span = json.loads(line)\n        if span[\"span_type\"] == \"rag_retrieval\":\n            if source_id in span[\"attributes\"].get(\"source_ids\", []):\n                affected.append(span[\"trace_id\"])\n    return list(set(affected))\n\n# Example: a legal document was retracted — find all AI responses it influenced\nretracted = traces_using_source(\"doc-policy-2024-03\")\nprint(f\"{len(retracted)} traces affected by retraction of doc-policy-2024-03\")\n# → 47 traces affected\n"
