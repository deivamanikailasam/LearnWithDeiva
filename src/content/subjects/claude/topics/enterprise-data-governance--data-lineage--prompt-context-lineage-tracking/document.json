            "type": "text",
            "text": "def reconstruct_trace(trace_id: str) -> list[dict]:\n    \"\"\"Return all spans for a trace, sorted by timestamp.\"\"\"\n    spans = []\n    for line in Path(\"logs/lineage.jsonl\").read_text().splitlines():\n        span = json.loads(line)\n        if span[\"trace_id\"] == trace_id:\n            spans.append(span)\n    return sorted(spans, key=lambda s: s[\"timestamp\"])\n\n# Reconstruct and display\nfor span in reconstruct_trace(\"tr-2025-abc123\"):\n    print(f\"[{span['span_type']}] {span['span_id']} \"\n          f\"parents={span['parent_span_ids']} \"\n          f\"attrs={span['attributes']}\")\n"
