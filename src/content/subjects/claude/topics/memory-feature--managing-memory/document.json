{"format":"tiptap/v1","updatedAt":"2026-06-20T10:24:04.807Z","doc":{"type":"doc","content":[{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"You can "},{"type":"text","marks":[{"type":"bold"}],"text":"inspect and manage"},{"type":"text","text":" stored memories in a dedicated memory/settings view, which shows Claude’s saved summaries of you."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"You can "},{"type":"text","marks":[{"type":"bold"}],"text":"delete individual memories"},{"type":"text","text":" that are incorrect or no longer relevant, or clear memory entirely if you want a fresh start."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Memory is "},{"type":"text","marks":[{"type":"bold"}],"text":"optional and user‑controlled"},{"type":"text","text":": you can turn it off entirely if you don’t want Claude to retain any cross‑session information."}]}]}]},{"type":"paragraph"}]}}
