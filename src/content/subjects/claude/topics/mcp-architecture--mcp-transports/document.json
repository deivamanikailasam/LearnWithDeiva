d"},{"type":"text","text":" header for stateful sessions"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use HTTP/SSE:"},{"type":"text","text":"\n- ✅ "},{"type":"text","marks":[{"type":"bold"}],"text":"Remote servers"},{"type":"text","text":" (client/server on different machines)\n- ✅ Server needs to "},{"type":"text","marks":[{"type":"bold"}],"text":"push notifications"},{"type":"text","text":" to clients (e.g., streaming results)\n- ✅ "},{"type":"text","marks":[{"type":"bold"}],"text":"Multi-client"},{"type":"text","text":" servers (one server serving many Claude instances)\n- ✅ Browser-based clients (SSE works natively)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Trade-offs:"},{"type":"text","text":"\n- ❌ Requires network infrastructure (DNS, TLS, load balancers)\n- ❌ Authentication/authorization needed\n- ❌ Higher latency than stdio"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Pure HTTP (Request-Response Only)"}]},{"type":"paragraph","content":[{"type":"text","text":"Some documentation distinguishes "},{"type":"text","marks":[{"type":"bold"}],"text":"pure HTTP"},{"type":"text","text":" (no SSE) as a third option:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Pure HTTP"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mechanism"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Client sends POST → Server responds → Connection closes"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best for"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Serverless (AWS Lambda), stateless operations, maximum scalability"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Limitation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No server-to-client notifications, cannot stream"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of MCP like a "},{"type":"text","marks":[{"type":"bold"}],"text":"phone call"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"stdio"},{"type":"text","text":" = Two people in the same room passing notes (fastest, local only)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"HTTP/SSE"},{"type":"text","text":" = Live cricket score app (open once, continuous updates push automatically)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Pure HTTP"},{"type":"text","text":" = Ordering at a restaurant (ask → get response → done)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Same protocol, different channels"},{"type":"text","text":": All transports use identical JSON-RPC messages"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Start with stdio"},{"type":"text","text":": Easiest setup, fastest for local development"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Scale to HTTP/SSE"},{"type":"text","text":": When you need remote access, multi-client support, or streaming"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Claude Desktop"},{"type":"text","text":" primarily uses stdio for local servers but supports SSE for remote servers"}]}]}]},{"type":"paragraph"}]}}
