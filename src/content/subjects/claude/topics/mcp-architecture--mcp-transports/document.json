{"format":"tiptap/v1","updatedAt":"2026-06-22T03:49:03.745Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"In MCP (Model Context Protocol) Architecture, "},{"type":"text","marks":[{"type":"bold"}],"text":"Transports"},{"type":"text","text":" are the communication channels that carry JSON-RPC messages between a Claude client and an MCP server. The protocol is "},{"type":"text","marks":[{"type":"bold"}],"text":"transport-agnostic"},{"type":"text","text":"—the same message format works over any channel, but the channel itself determines latency, deployment options, and capabilities."}]},{"type":"paragraph","content":[{"type":"text","text":"The two primary transports are "},{"type":"text","marks":[{"type":"bold"}],"text":"stdio"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"bold"}],"text":"HTTP/SSE"},{"type":"text","text":" (often written together because SSE is an HTTP feature):"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"stdio (Standard Input/Output)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"How it works"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mechanism"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Client spawns the MCP server as a "},{"type":"text","marks":[{"type":"bold"}],"text":"child process"},{"type":"text","text":" on the same machine"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Communication"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Messages flow through "},{"type":"text","marks":[{"type":"bold"}],"text":"stdin"},{"type":"text","text":" (client → server) and "},{"type":"text","marks":[{"type":"bold"}],"text":"stdout"},{"type":"text","text":" (server → client), one JSON-RPC message per line"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Logs"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Server diagnostics go to "},{"type":"text","marks":[{"type":"bold"}],"text":"stderr"},{"type":"text","text":" (separate from messages)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Connection"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Persistent, local IPC (no network)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use stdio:"},{"type":"text","text":"\n- ✅ Local development tools, CLI apps, VS Code extensions\n- ✅ Claude Desktop (its primary transport for local servers)\n- ✅ Zero network overhead, fastest latency\n- ✅ No authentication needed (process isolation provides security)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Limitations:"},{"type":"text","text":"\n- ❌ Only works on the "},{"type":"text","marks":[{"type":"bold"}],"text":"same machine"},{"type":"text","text":"\n- ❌ Server lifecycle tied to client (no connection sharing)\n- ❌ Cannot serve multiple clients"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"HTTP/SSE (Server-Sent Events over HTTP)"}]},{"type":"paragraph","content":[{"type":"text","text":"This is actually "},{"type":"text","marks":[{"type":"bold"}],"text":"two-directional HTTP"},{"type":"text","text":":"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Direction"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Mechanism"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Client → Server"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"HTTP "},{"type":"text","marks":[{"type":"bold"}],"text":"POST"},{"type":"text","text":" requests with JSON-RPC payload"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Server → Client"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"SSE stream"},{"type":"text","text":" ("},{"type":"text","marks":[{"type":"code"}],"text":"text/event-stream"},{"type":"text","text":") pus