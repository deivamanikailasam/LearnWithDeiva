}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Thinking tokens unoptimized"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"3-5x visible output cost"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Model Tiering Strategy"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Smart model tiering:\n- Opus: deep reasoning, complex decisions\n- Minimax: bulk of pipeline (70-80% of work)\n- Quen: simple calls, lightweight tasks"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cost savings"},{"type":"text","text":":\n- Minimax: ~30 cents per million input tokens\n- Opus: $5 per million input tokens\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"12x cheaper"},{"type":"text","text":" for routine pipeline work"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Cost Calculation Formula"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Before You Commit"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Calculate your expected monthly cost\ndef calculate_agent_cost(hours_per_day, token_input_millions, token_output_millions):\n    \n    # Runtime cost\n    runtime_hours = hours_per_day * 30\n    runtime_cost = runtime_hours * 0.08\n    \n    # Token cost (example rates)\n    input_token_cost = token_input_millions * 5.00  # Opus rate\n    output_token_cost = token_output_millions * 25.00  # Opus rate\n    \n    total = runtime_cost + input_token_cost + output_token_cost\n    \n    return {\n        \"runtime_cost\": runtime_cost,\n        \"token_cost\": input_token_cost + output_token_cost,\n        \"total_cost\": total\n    }"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example Calculation"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Scenario: Agent runs 3 hours/day, 5 million input tokens, 1 million output tokens/month\n\nRuntime cost: 3 × 30 × $0.08 = $7.20\nInput tokens: 5 × $5.00 = $25.00\nOutput tokens: 1 × $25.00 = $25.00\nTotal: $57.20/month"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of agent cost modeling like "},{"type":"text","marks":[{"type":"bold"}],"text":"renting a car vs. owning one"},{"type":"text","text":":"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Managed Agents (burst)"},{"type":"text","text":" = "},{"type":"text","marks":[{"type":"bold"}],"text":"Uber/rental"},{"type":"text","text":": Pay per hour you actually use it ($0.08/hour). If you only drive 3 hours/day, you pay $7.20/month. No maintenance, no insurance, just use it when needed."}]}]}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Self-build (always-on)"},{"type":"text","text":" = "},{"type":"text","marks":[{"type":"bold"}],"text":"Buy a car"},{"type":"text","text":": Flat $5-50/month (VPS cost). You drive it 24/7, but you pay the same regardless of usage. You handle maintenance, but it's cheaper if you use it constantly."}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"The math"},{"type":"text","text":": If you drive 3 hours/day, Uber costs $7.20/month. If you drive 24 hours/day, buying a car ($50/month) is cheaper than Uber ($58/month)."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Managed Agents: $0.08/hour runtime + standard Claude token costs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"24/7 always-on: 720 hours × $0.08 = $57.60 ≈ $58/month runtime (before tokens)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Burst usage: 3 hours/day = 90 hours × $0.08 = $7.20/month runtime (extremely attractive)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"For most teams: agents run in bursts, not 24/7"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Runtime cost formula: (hours_per_day × 30 × $0.08) + token costs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Managed Agents wins when: burst/occasional usage, uncertain demand, team of 1-5"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Self-build wins when: always-on 24/7 ($5-50 vs. $58/month), high-volume, privacy-critical"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Token optimization: tier models (Opus for reasoning, Minimax for bulk, Quen for simple)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Model tiering saves: Minimax costs 1/12x of Opus for routine pipeline work"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Common mistake: 80% wasted spend on frontier models for routine tasks"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Think tokens: 30 cents per million input (Minimax) vs. $5 per million (Opus)"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"For most teams, the math is extremely attractive for burst usage — an agent running 24/7 costs about $58/month in runtime alone, but if you only run it 3 hours/day, you pay just $7.20/month plus tokens."}]}]}}
