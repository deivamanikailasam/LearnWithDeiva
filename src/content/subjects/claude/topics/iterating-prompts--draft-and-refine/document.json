{"format":"tiptap/v1","updatedAt":"2026-06-21T00:24:44.222Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Drafting and refining"},{"type":"text","text":" is the core iterative loop of prompt engineering. Instead of trying to write a perfect prompt immediately, you follow a structured workflow: "},{"type":"text","marks":[{"type":"bold"}],"text":"Define → Draft → Refine → Reuse"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"The key mindset:"},{"type":"text","text":" \"Don't overthink it — a structured first draft beats a perfect prompt that never gets written. Most good prompts require 2-3 iterations. That's normal and fast.\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"The 4-Step Draft & Refine Workflow"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 1: Define"},{"type":"text","text":" (Before Writing)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Before writing a single word of your prompt, answer three questions:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What do I actually need?"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- Not: \"help with emails\" - But: \"a 3-sentence follow-up to a prospect who went quiet\""}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Who is the output for?"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- Audience matters (executives vs. developers vs. customers)"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What format do I need it in?"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- JSON, bullet points, essay, code, table?"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefit:"},{"type":"text","text":" \"Thirty seconds of defining saves five minutes of iteration.\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 2: Draft"},{"type":"text","text":" (Write First Version)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Write the prompt using the 4-Part Formula: Role + Task + Context + Format"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"4-Part Prompt Formula:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Part"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"What to Include"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Example"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Role"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Who is the AI?"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"You are a senior Python engineer\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Task"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"What to do?"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"Write a function to calculate factorial\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Context"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Why/When?"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"For a data processing pipeline\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Format"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"How to output?"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"Return code with type hints and docstring\""}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Role: You are a senior Python engineer\nTask: Write a function to calculate factorial\nContext: For a data processing pipeline\nFormat: Return code with type hints and docstring"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Add any power techniques that fit"},{"type":"text","text":" (Chain-of-Thought, XML tags, examples, etc.)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key principle:"},{"type":"text","text":" A structured first draft beats perfection. Don't overthink it."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 3: Refine"},{"type":"text","text":" (Iterate Based on Output)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Review the output and iterate. Use the follow-up toolkit. Most good prompts require 2-3 iterations."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"The Iteration Loop:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Draft: Write your first prompt\n   ↓\nTest: Run the prompt and see output\n   ↓\nRefine: Change your prompt to be more specific\n   ↓\nRepeat until you get desired results"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Refinement techniques:"},{"type":"text","text":"\n- Make it more specific\n- Add missing context\n- Clarify the format\n- Add examples\n- Use better structure (XML tags, sections)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 4: Reuse"},{"type":"text","text":" (Save What Works)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When you find a prompt structure that works, save it. Build a personal prompt library."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits:"},{"type":"text","text":"\n- Good prompts are reusable assets\n- The best ones save hours every week\n- Don't reinvent the wheel"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"The Meta-Prompt Workflow (AI-Assisted Refinement)"}]},{"type":"paragraph","content":[{"type":"text","text":"For complex prompts, use "},{"type":"text","marks":[{"type":"bold"}],"text":"AI to help you refine your prompt"},{"type":"text","text":":"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 1: Initial Prompt Creation"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use an AI assistant to help you create high-quality prompts:"},{"type":"text","text":" "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://10xdevelopers.dev/prompt-engineering/meta-prompt-workflow/","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"10xdevelopers"}]},{"type":"codeBlock","attrs":{"language":"prompt"},"content":[{"type":"text","text":"Adopt the role of an expert prompt engineer.\nYou are an AI assistant designed to help users create high-quality, detailed task prompts.\nYour goal is to iteratively refine the user's prompt by:\n• Understanding the task scope and objectives\n• Defining expected deliverables and success criteria\n• Clarifying technical and procedural requirements\n• Organizing the prompt into clear sections or steps\n• Ensuring the prompt is easy to understand and follow\n\nAsk the user fast questions (role, instructions, reasoning steps, output format, examples, context/audience, tone) before you create a detailed prompt."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 2: Run the Generated Prompt"}]},{"type":"paragraph","content":[{"type":"text","text":"Test the AI-generated prompt "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://10xdevelopers.dev/prompt-engineering/meta-prompt-workflow/","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"10xdevelopers"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 3: Evaluate the Prompt"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use this evaluation prompt to critique your draft:"},{"type":"text","text":" "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://10xdevelopers.dev/prompt-engineering/meta-prompt-workflow/","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"10xdevelopers"}]},{"type":"codeBlock","attrs":{"language":"prompt"},"content":[{"type":"text","text":"Rate this prompt out of 10.\nList all strengths and weaknesses of this prompt, and proceed to improving so it's 10/10.\n\nResponse:\nImproved prompt (aiming for 10/10)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 4: Testing and Iteration"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Test the prompt in a new chat. If output needs improvement, return to the prompt creation chat and use this feedback prompt:"},{"type":"text","text":" "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://10xdevelopers.dev/prompt-engineering/meta-prompt-workflow/","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"10xdevelopers"}]},{"type":"codeBlock","attrs":{"language":"prompt"},"content":[{"type":"text","text":"Now analyze my feedback after testing the prompt:\nWeaknesses:\n[LIST ALL BAD THINGS ABOUT THE PROMPT]\n\nStrengths:\n[LIST BRIEFLY WHAT YOU LIKE ABOUT THE PROMPT]\n\nIdeas:\n[IF YOU HAVE MORE IDEAS TO IMPROVE IT, LIST THEM HERE]\n\nConsidering my feedback above, proceed to surgically improving the prompt, focusing on the areas I listed as weaknesses."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 5: Iterative Refinement"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Continue the cycle of:"},{"type":"text","text":" "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://10xdevelopers.dev/prompt-engineering/meta-prompt-workflow/","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"10xdevelopers"},{"type":"text","text":"\n- Testing the prompt\n- Sharing feedback\n- Refining the prompt\n- Testing again"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Repeat until desired results."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common Refinement Strategies"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Strategy 1: Add Role Clarity"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem:"},{"type":"text","text":" Output lacks expertise or persona "},{"type":"text","marks":[{"type":"bold"}],"text":"Fix:"},{"type":"text","text":" Add explicit role definition"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Before:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Write a marketing email\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"After:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"You are a senior B2B marketer with 10 years of experience in SaaS. \nWrite a marketing email for enterprise prospects who went quiet.\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Strategy 2: Clarify the Task"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem:"},{"type":"text","text":" Output is vague or incomplete "},{"type":"text","marks":[{"type":"bold"}],"text":"Fix:"},{"type":"text","text":" Make task more specific"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Before:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Analyze this data\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"After:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Analyze this quarterly sales data and:\n1. Identify top 3 revenue drivers\n2. Spot anomalies or outliers\n3. Calculate growth rate vs. previous quarter\n4. List 3 actionable recommendations\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Strategy 3: Add Context"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem:"},{"type":"text","text":" Output misses important background "},{"type":"text","marks":[{"type":"bold"}],"text":"Fix:"},{"type":"text","text":" Provide relevant context"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Before:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Write code to sort a list\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"After:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Write code to sort a list of user dictionaries by 'created_at' timestamp.\nThis is for a dashboard showing recent activity.\nPerformance matters: we're sorting 10,000+ records.\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Strategy 4: Define Format Explicitly"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem:"},{"type":"text","text":" Output is unstructured or hard to parse "},{"type":"text","marks":[{"type":"bold"}],"text":"Fix:"},{"type":"text","text":" Specify exact format"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Before:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Summarize this article\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"After:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Summarize this article in this format:\n\n## Executive Summary\n[1-2 paragraph overview]\n\n## Key Points\n- Point 1\n- Point 2\n- Point 3\n\n## Action Items\n1. [Action]\n2. [Action]\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Strategy 5: Add Examples (Few-Shot)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem:"},{"type":"text","text":" Output doesn't match desired style "},{"type":"text","marks":[{"type":"bold"}],"text":"Fix:"},{"type":"text","text":" Provide examples"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Before:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Classify this email\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"After:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"\"Classify this email using these examples:\n\nExample 1:\nInput: \"I was double charged.\"\nOutput: Category: Billing, Reason: Incorrect charging\n\nExample 2:\nInput: \"The app crashes.\"\nOutput: Category: Bug, Reason: Feature broken\n\nNow classify: \"Export is too slow.\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Strategy 6: Use Structure (XML Tags)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem:"},{"type":"text","text":" Output is messy or hard to follow "},{"type":"text","marks":[{"type":"bold"}],"text":"Fix:"},{"type":"text","text":" Add XML structure"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Before:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Analyze this contract\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"After:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"<role>You are a legal assistant</role>\n\n<input>\n[contract text]\n</input>\n\n<output_format>\n## Executive Summary\n## Key Obligations\n## Risks\n## Recommendations\n</output_format>"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Strategy 7: Add Constraints"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem:"},{"type":"text","text":" Output is too long, uses wrong tone, or includes unwanted content "},{"type":"text","marks":[{"type":"bold"}],"text":"Fix:"},{"type":"text","text":" Set explicit constraints"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Before:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Write a blog post about APIs\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"After:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Write a blog post about APIs with these constraints:\n- Maximum 800 words\n- No jargon without explanation\n- Include 2 practical examples\n- Use active voice only\n- Target audience: developers with 0-6 months experience\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Refinement Toolkit: Follow-Up Techniques"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tool 1: Ask for Clarification"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When:"},{"type":"text","text":" Output is incomplete or unclear "},{"type":"text","marks":[{"type":"bold"}],"text":"Use:"},{"type":"text","text":" \"Can you clarify X?\" or \"What did you mean by Y?\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tool 2: Request More Detail"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When:"},{"type":"text","text":" Output is too brief "},{"type":"text","marks":[{"type":"bold"}],"text":"Use:"},{"type":"text","text":" \"Expand on point 2\" or \"Give me more details about X\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tool 3: Request Simplification"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When:"},{"type":"text","text":" Output is too complex "},{"type":"text","marks":[{"type":"bold"}],"text":"Use:"},{"type":"text","text":" \"Explain this in simpler terms\" or \"Make this easier to understand\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tool 4: Request Alternative Format"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When:"},{"type":"text","text":" Output format is wrong "},{"type":"text","marks":[{"type":"bold"}],"text":"Use:"},{"type":"text","text":" \"Rewrite this as a table\" or \"Convert to bullet points\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tool 5: Critique and Improve"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When:"},{"type":"text","text":" Output quality is low "},{"type":"text","marks":[{"type":"bold"}],"text":"Use:"},{"type":"text","text":" \"What are the weaknesses of this output and how can we improve it?\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices for Draft & Refine"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Keep First Drafts Simple"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Don't overthink it — a structured first draft beats a perfect prompt that never gets written."}]},{"type":"paragraph","content":[{"type":"text","text":"Start with the 4-Part Formula (Role + Task + Context + Format) and iterate."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Expect 2-3 Iterations"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Most good prompts require 2-3 iterations. That's normal and fast — don't treat the first response as final."}]},{"type":"paragraph","content":[{"type":"text","text":"Don't get discouraged if the first draft doesn't work perfectly."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Refine Based on Specific Feedback"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use the follow-up toolkit."},{"type":"text","text":" Identify what's wrong and fix it surgically."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Bad feedback:"},{"type":"text","text":" \"This isn't good\" "},{"type":"text","marks":[{"type":"bold"}],"text":"Good feedback:"},{"type":"text","text":" \"The tone is too casual, make it more professional\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Document Your Iterations"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Maintain a Prompt Changelog:"},{"type":"text","text":"\n- Version number and date\n- What changed and why\n- Test results before/after"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Test Before Finalizing"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Every professional LLM Engineer follows this cycle: Initial Prompt → Test on 10+ Examples → Failure Detected? → Refine → Repeat"}]},{"type":"paragraph","content":[{"type":"text","text":"Don't skip testing."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Summary"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"The Draft & Refine workflow:"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"4-Step Process:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Define"},{"type":"text","text":" — Answer: What do I need? Who's it for? What format?"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Draft"},{"type":"text","text":" — Use 4-Part Formula: Role + Task + Context + Format"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Refine"},{"type":"text","text":" — Iterate 2-3 times based on output"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Reuse"},{"type":"text","text":" — Save working prompts in a library"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"4-Part Prompt Formula:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Role:"},{"type":"text","text":" Who is the AI?"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Task:"},{"type":"text","text":" What to do?"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Context:"},{"type":"text","text":" Why/When?"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Format:"},{"type":"text","text":" How to output?"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"7 Refinement Strategies:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Add role clarity"},{"type":"text","text":" — Explicit persona"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Clarify task"},{"type":"text","text":" — Make specific"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Add context"},{"type":"text","text":" — Provide background"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Define format"},{"type":"text","text":" — Specify exact structure"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"