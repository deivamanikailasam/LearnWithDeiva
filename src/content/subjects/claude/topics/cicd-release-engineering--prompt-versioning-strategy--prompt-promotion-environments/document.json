        "type": "codeBlock",
        "attrs": {
          "language": "text"
        },
        "content": [
          {
            "type": "text",
            "text": "# Traffic split ratio\nsum by (version) (rate(prompt_requests_total{env=\"canary\"}[5m]))\n\n# Error rate by version\nsum by (version) (rate(prompt_errors_total{env=\"canary\"}[5m]))\n/ sum by (version) (rate(prompt_requests_total{env=\"canary\"}[5m]))\n\n# p99 latency by version\nhistogram_quantile(0.99,\n  sum by (le, version) (rate(prompt_latency_seconds_bucket{env=\"canary\"}[5m]))\n)\n"
          }
        ]
