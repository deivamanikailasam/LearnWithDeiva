e\": sections [youtube](https://www.youtube.com/watch?v=la9xXeLzQ9Y)},\n        {\"type\": \"text\", \"text\": \"Extract all figures and captions\"}\n    ]\n}]\n\n# Result: Claude treats as one document [web:20]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Prompting Tips for PDFs"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Ask Specific Questions"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"❌ Bad: \"What's in this document?\"\n✅ Good: \"Extract the restaurant name, total amount, and date from this receipt PDF\""}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Request Structured Output"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Extract all fields and return as JSON:\n{\n  'invoice_number': 'string',\n  'total_amount': 'number',\n  'date': 'YYYY-MM-DD'\n}\""}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Use Step-by-Step Reasoning"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"I'll scan this document page by page, extracting sections in order:\n1. Introduction\n2. Methodology\n3. Results\n4. Conclusion\""}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Reference Page Numbers"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"What does page 15 say about risk management?\"\n\"Extract the table from pages 20-22\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Limitations & Considerations"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align"