":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Vector search indexes and queries over numeric representations (vectors) of content"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Vector databases store embeddings: numerical text representations capturing meaning, not keywords"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Semantic search finds content with same meaning even with different words"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Knowledge base = pre-existing data source (vector store or SQL) for RAG retrieval"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Two types: Vector store (skip chunking/embedding) vs SQL database (query-based)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Vector DB is the retrieval engine in RAG system"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Search uses similarity: cosine similarity or Euclidean distance to measure \"closeness\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"ANN (Approximate Nearest Neighbor) algorithms quickly find likely closest matches"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Semantic search = vectors only; Hybrid search = vectors + raw text"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Popular options: MongoDB Atlas, Milvus Lite, Zilliz Cloud, Azure AI Search, Amazon Bedrock"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Vector databases are a core feature of RAG where they store chunks of documents and knowledge bases as embeddings, then find relevant text chunks by co