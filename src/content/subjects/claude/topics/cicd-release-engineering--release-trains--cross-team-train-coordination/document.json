      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Each train nominates one "
          },
          {
            "type": "text",
            "text": "release train coordinator (RTC)",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " \u2014 a senior engineer who owns cross-team communication for that train's duration. The RTC is not the release manager; they are an "
          },
          {
            "type": "text",
            "text": "information router",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": "."
          }
        ]
      },
