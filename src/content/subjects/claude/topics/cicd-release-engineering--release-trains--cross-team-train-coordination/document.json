      {
        "type": "codeBlock",
        "attrs": {
          "language": "bash"
        },
        "content": [
          {
            "type": "text",
            "text": "#!/usr/bin/env bash\n# go_no_go.sh \u2014 checklist run on deploy morning\nset -euo pipefail\n\nTRAIN=${1:?Train number required}\nBRANCH=\"release/train-${TRAIN}\"\n\necho \"=== Train ${TRAIN} Go/No-Go Checklist ===\"\n\n# 1. Check branch is ahead of main by only expected commits\nAHEAD=$(git rev-list --count origin/main..origin/${BRANCH})\necho \"Commits ahead of main: ${AHEAD}\"\n\n# 2. Confirm CI is green on release branch\necho \"Checking CI status on ${BRANCH}...\"\nSTATUS=$(gh run list --branch \"${BRANCH}\" --limit 1 --json conclusion -q '.[0].conclusion')\nif [ \"${STATUS}\" != \"success\" ]; then\n  echo \"FAIL: CI is ${STATUS} on ${BRANCH}\"\n  exit 1\nfi\necho \"CI: GREEN\"\n\n# 3. Confirm no open PRs labelled train-committed remain unmerged\nOPEN=$(gh pr list --label \"train-${TRAIN}-committed\" --state open --json number -q 'length')\nif [ \"${OPEN}\" -gt 0 ]; then\n  echo \"FAIL: ${OPEN} committed PR(s) still open \u2014 not all scope is merged\"\n  exit 1\nfi\necho \"Committed PRs: all merged\"\n\necho \"=== GO: Train ${TRAIN} is cleared for deploy ===\"\n"
          }
        ]
