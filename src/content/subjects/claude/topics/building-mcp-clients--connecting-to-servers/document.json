{"format":"tiptap/v1","updatedAt":"2026-06-22T04:00:11.198Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"In MCP (Model Context Protocol), "},{"type":"text","marks":[{"type":"bold"}],"text":"Connecting to Servers"},{"type":"text","text":" is the process of establishing a communication channel between your client application and an MCP server. This involves choosing the right transport mechanism (stdio for local servers, HTTP/SSE for remote servers) and performing the protocol handshake."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Two Transport Types"}]},{"type":"paragraph","content":[{"type":"text","text":"Clients connect to servers using one of two transport mechanisms:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Transport"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Case"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"How It Works"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"stdio"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Local servers (same machine)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Client spawns server as subprocess"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"HTTP/SSE"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Remote servers (different machines)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Client connects over network via HTTP"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Option 1: stdio Transport (Local Servers)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"stdio"},{"type":"text","text":" (standard input/output) spawns the MCP server as a "},{"type":"text","marks":[{"type":"bold"}],"text":"child process"},{"type":"text","text":" on your local machine:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Your Client App\n    ↓ spawns subprocess\nMCP Server Process\n    ↓ communicates via stdin/stdout\nJSON-RPC messages"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key characteristics:"},{"type":"text","text":"\n| Aspect | Detail |\n|--------|--------|\n| "},{"type":"text","marks":[{"type":"bold"}],"text":"Process lifecycle"},{"type":"text","text":" | Client controls server start/stop |\n| "},{"type":"text","marks":[{"type":"bold"}],"text":"Communication"},{"type":"text","text":" | Messages via stdin → stdout streams |\n| "},{"type":"text","marks":[{"type":"bold"}],"text":"Security"},{"type":"text","text":" | In-process, no network exposure |\n| "},{"type":"text","marks":[{"type":"bold"}],"text":"Setup"},{"type":"text","text":" | Specify command + arguments |"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Python SDK: Connecting via stdio"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from mcp import ClientSession\nfrom mcp.client.stdio import stdio_client\n\n# Create transport to local server\nasync with stdio_client(\n    command=\"python\",\n    args=[\"weather-server.py\"]\n) as (read, write):\n    \n    # Create session and perform handshake\n    async with ClientSession(read, write) as session:\n        await session.initialize()  # ← Handshake happens here\n        \n        # Server is now connected, ready to use\n        tools = await session.list_tools()\n        for tool in tools.tools:\n            print(f\"{tool.name}: {tool.description}\")"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What happens:"},{"type":"text","text":"\n1. Python spawns "},{"type":"text","marks":[{"type":"code"}],"text":"python weather-server.py"},{"type":"text","text":" subprocess\n2. Client opens stdin/stdout streams to subprocess\n3. "},{"type":"text","marks":[{"type":"code"}],"text":"initialize()"},{"type":"text","text":" performs capability negotiation handshake\n4. Server is connected and ready"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"TypeScript SDK: Connecting via stdio"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import { ClientSession } from \"@modelcontextprotocol/sdk/client/index.js\";\nimport { stdioClientTransport } from \"@modelcontextprotocol/sdk/client/stdio.js\";\n\n// Create transport\nconst transport = stdioClientTransport({\n  command: \"node\",\n  args: [\"weather-server.js\"]\n});\n\n// Create session\nconst session = new ClientSession(transport);\nawait session.initialize();  // Handshake\n\n// Use server\nconst tools = await session.listTools();\nconsole.log(tools.tools);"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"C# (.NET) SDK: Connecting via stdio"}]},{"type":"codeBlock","attrs":{"language":"csharp"},"content":[{"type":"text","text":"using ModelContextProtocol.Client;\n\n// Create MCP client with stdio transport\nIMcpClient mcpClient = await McpClientFactory.CreateAsync(\n    new StdioClientTransport(new()\n    {\n        Command = \"dotnet\",\n        Arguments = [\"run\", \"--project\", \"weather-server.csproj\"],\n        Name = \"Weather Server\"\n    })\n);\n\n// List tools\nIList<McpClientTool> tools = await mcpClient.ListToolsAsync();\nforeach (McpClientTool tool in tools)\n{\n    Console.WriteLine(tool);\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key difference"},{"type":"text","text":": Command can be "},{"type":"text","marks":[{"type":"code"}],"text":"dotnet run"},{"type":"text","text":" instead of compiled binary"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Configuration Options"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Parameter"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Python"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"TypeScript"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"C#"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Command"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"command=\"python\""}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"command: \"node\""}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"Command = \"dotnet\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Arguments"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"args=[\"server.py\"]"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"args: [\"server.js\"]"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"Arguments = [\"run\"]"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Environment"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"env={\"KEY\": \"val\"}"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"{ env: {...} }"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"EnvironmentVariables = {...}"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"cwd"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"cwd=\"/path\""}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Not shown"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"WorkingDirectory = \"/path\""}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Option 2: HTTP/SSE Transport (Remote Servers)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"HTTP/SSE"},{"type":"text","text":" connects to an MCP server running on a "},{"type":"text","marks":[{"type":"bold"}],"text":"different machine"},{"type":"text","text":" over the network:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Your Client App\n    ↓ HTTP POST + SSE stream\nRemote MCP Server (e.g., AWS, Cloudflare)\n    ↓ JSON-RPC messages\nCloud Infrastructure"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key characteristics:"},{"type":"text","text":"\n| Aspect | Detail |\n|--------|--------|\n| "},{"type":"text","marks":[{"type":"bold"}],"text":"Process lifecycle"},{"type":"text","text":" | Server runs independently (not spawned) |\n| "},{"type":"text","marks":[{"type":"bold"}],"text":"Communication"},{"type":"text","text":" | HTTP POST (client→server) + SSE stream (server→client) |\n| "},{"type":"text","marks":[{"type":"bold"}],"text":"Security"},{"type":"text","text":" | Requires authentication (API keys, tokens) |\n| "},{"type":"text","marks":[{"type":"bold"}],"text":"Setup"},{"type":"text","text":" | Provide endpoint URL |"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Python SDK: Connecting via HTTP/SSE"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from mcp import ClientSession\nfrom mcp.client.sse import sse_client\n\n# Create transport to remote server\nasync with sse_client(\n    endpoint=\"https://api.weather-server.com/mcp\"\n) as (read, write):\n    \n    # Create session and perform handshake\n    async with ClientSession(read, write) as session:\n        await session.initialize()\n        \n        # Server is connected\n        tools = await session.list_tools()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What happens:"},{"type":"text","text":"\n1. Client opens HTTP connection to endpoint\n2. Server sends SSE stream ("},{"type":"text","marks":[{"type":"code"}],"text":"text/event-stream"},{"type":"text","text":")\n3. Client sends POST requests with JSON-RPC\n4. "},{"type":"text","marks":[{"type":"code"}],"text":"initialize()"},{"type":"text","text":" performs handshake"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"TypeScript SDK: Connecting via HTTP/SSE"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import { ClientSession } from \"@modelcontextprotocol/sdk/client/index.js\";\nimport { sseClientTransport } from \"@modelcontextprotocol/sdk/client/sse.js\";\n\n// Create transport to remote server\nconst transport = sseClientTransport({\n  endpoint: \"https://api.weather-server.com/mcp\",\n  // Optional: authentication\n  requestInit: {\n    headers: {\n      \"Authorization\": \"Bearer your-api-key\"\n    }\n  }\n});\n\n// Create session\nconst session = new ClientSession(transport);\nawait session.initialize();"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use Each Transport"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Server is on same machine"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"stdio ✅ (faster, no auth needed)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Server is in cloud (AWS, Vercel)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"HTTP/SSE ✅"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Server is in container"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"HTTP/SSE ✅ (if exposed via port)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Building CLI tool"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"stdio ✅ (spawn local server)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Building web app"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"HTTP/SSE ✅ (browser can't spawn processes)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multiple clients need same server"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"HTTP/SSE ✅ (server runs independently)"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"The Connection Lifecycle (3 Steps)"}]},{"type":"paragraph","content":[{"type":"text","text":"Every connection follows this sequence:"}]},{"type":"codeBlock","attrs":{"language":"mermaid"},"content":[{"type":"text","text":"sequenceDiagram\n    Client->>Server: 1. Create transport\n    Client->>Server: 2. Open connection\n    Client->>Server: 3. initialize() (handshake)\n    Server->>Client: capabilities + version\n    Client->>Server: initialized (notification)\n    Client->>User: Connected, ready to use"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 1: Create Transport"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Python: Create transport object\ntransport = stdio_client(command=\"python\", args=[\"server.py\"])"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What happens"},{"type":"text","text":": Transport object configured but connection not yet opened"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 2: Open Connection"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Python: Open connection (async context manager)\nasync with transport as (read, write):\n    # read/write streams now open"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What happens"},{"type":"text","text":":\n- For stdio: Subprocess spawned, stdin/stdout streams opened\n- For HTTP/SSE: HTTP connection established, SSE stream started"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 3: Perform Handshake ("},{"type":"text","marks":[{"type":"code"}],"text":"initialize()"},{"type":"text","text":")"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"async with ClientSession(read, write) as session:\n    await session.initialize()  # ←必须进行"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What happens"},{"type":"text","text":":\n1. Client sends "},{"type":"text","marks":[{"type":"code"}],"text":"initialize"},{"type":"text","text":" request with capabilities\n2. Server responds with its capabilities + protocol version\n3. Client sends "},{"type":"text","marks":[{"type":"code"}],"text":"initialized"},{"type":"text","text":" notification\n4. Connection is "},{"type":"text","marks":[{"type":"bold"}],"text":"fully established"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Before this"},{"type":"text","text":": Server cannot handle tool calls, resources, or prompts"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Complete Client Wrapper (Python)"}]},{"type":"paragraph","content":[{"type":"text","text":"Here's a reusable wrapper that handles connection cleanly:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from mcp import ClientSession\nfrom mcp.client.stdio import stdio_client\nfrom typing import AsyncContextManager\n\nclass MCPClient(AsyncContextManager):\n    \"\"\"Wrapper that simplifies MCP connection and ensures cleanup\"\"\"\n    \n    def __init__(self, command: str, args: list[str]):\n        self._transport = stdio_client(command, args)\n        self._session: ClientSession | None = None\n    \n    async def __aenter__(self):\n        # Open transport\n        read, write = await self._transport.__aenter__()\n        \n        # Create session\n        self._session = ClientSession(read, write)\n        await self._session.__aenter__()\n        \n        # Perform handshake\n        await self._session.initialize()\n        \n        return self\n    \n    async def __aexit__(self, exc_type, exc_val, exc_tb):\n        # Clean up\n        if self._session:\n            await self._session.__aexit__(exc_type, exc_val, exc_tb)\n        await self._transport.__aexit__(exc_type, exc_val, exc_tb)\n    \n    # Core operations\n    async def list_tools(self):\n        result = await self._session.list_tools()\n        return result.tools\n    \n    async def call_tool(self, name: str, arguments: dict):\n        result = await self._session.call_tool(name, arguments)\n        return result.content\n\n# Usage\nasync def main():\n    async with MCPClient(\"python\", [\"server.py\"]) as client:\n        tools = await client.list_tools()\n        for tool in tools:\n            print(f\"{tool.name}: {tool.description}\")\n        \n        result = await client.call_tool(\"get_weather\", {\"location\": \"SF\"})\n        print(result)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits"},{"type":"text","text":":\n- ✅ Ensures connection closes properly (async context manager)\n- ✅ Simplifies API (no manual stream handling)\n- ✅ Handshake automatic (no need to call "},{"type":"text","marks":[{"type":"code"}],"text":"initialize()"},{"type":"text","text":")"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Testing Your Connection Before Building Full App"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best practice"},{"type":"text","text":": Test connection in isolation before integrating with LLM:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"async def test_connection():\n    async with MCPClient(\"python\", [\"server.py\"]) as client:\n        # Just list tools - no LLM involved\n        tools = await client.list_tools()\n        print(f\"Found {len(tools)} tools:\")\n        for tool in tools:\n            print(f\"  - {tool.name}\")"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why"},{"type":"text","text":": If this works, your connection is good. Then you can focus on LLM integration."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Two transports"},{"type":"text","text":": stdio (local) or HTTP/SSE (remote)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"stdio spawns process"},{"type":"text","text":": Client controls server lifecycle"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"HTTP/SSE is independent"},{"type":"text","text":": Server runs separately on cloud"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Three-step lifecycle"},{"type":"text","text":": Create transport → Open connection → "},{"type":"text","marks":[{"type":"code"}],"text":"initialize()"},{"type":"text","text":" handshake"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Handshake is required"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"initialize()"},{"type":"text","text":" MUST complete before using server"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Async context managers"},{"type":"text","text":": Ensure clean teardown (Python, TypeScript)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Wrapper classes simplify"},{"type":"text","text":": Create "},{"type":"text","marks":[{"type":"code"}],"text":"MCPClient"},{"type":"text","text":" wrapper for reusability"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Test in isolation"},{"type":"text","text":": Verify connection before LLM integration"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"1:1 connections"},{"type":"text","text":": Each client connects to one server"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multiple clients = multiple instances"},{"type":"text","text":": If connecting to multiple servers, create multiple clients"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content"