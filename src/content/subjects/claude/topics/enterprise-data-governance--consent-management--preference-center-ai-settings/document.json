      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Prefix all AI-related preference keys with claude. to namespace them cleanly within a broader user-settings system. This lets you load only the Claude preferences sub-set when the API gate needs them, rather than deserializing the full settings blob."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Data Model and Storage"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass, field\nfrom datetime import datetime, timezone\nfrom typing import Any\nimport uuid, json\n\n@dataclass\nclass PreferenceSet:\n    preference_id: str = field(default_factory=lambda: str(uuid.uuid4()))\n    user_id: str = \"\"\n    schema_version: str = \"1.0\"\n    updated_at: datetime = None\n    prefs: dict[str, Any] = field(default_factory=dict)\n\n    # Typed accessors with defaults\n    def get_bool(self, key: str, default: bool = True) -> bool:\n        return bool(self.prefs.get(key, default))\n\n    def get_int(self, key: str, default: int = 0) -> int:\n        return int(self.prefs.get(key, default))\n\n    def get_str(self, key: str, default: str = \"\") -> str:\n        return str(self.prefs.get(key, default))\n\n    def set(self, key: str, value: Any) -> None:\n        self.prefs[key] = value\n        self.updated_at = datetime.now(timezone.utc)\n"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import sqlite3, json\nfrom pathlib import Path\nfrom datetime import datetime, timezone\nfrom preference_model import PreferenceSet\n\nDB_PATH = Path(\"/var/data/consent/preferences.db\")\n\ndef init_db(db_path: Path = DB_PATH):\n    with sqlite3.connect(db_path) as conn:\n        conn.execute(\"\"\"\n            CREATE TABLE IF NOT EXISTS user_preferences (\n                user_id         TEXT PRIMARY KEY,\n                preference_id   TEXT NOT NULL,\n                schema_version  TEXT NOT NULL,\n                updated_at      TEXT NOT NULL,\n                prefs           TEXT NOT NULL    -- JSON object\n            )\n        \"\"\")\n\ndef save_preferences(pset: PreferenceSet, db_path: Path = DB_PATH):\n    with sqlite3.connect(db_path) as conn:\n        conn.execute(\"\"\"\n            INSERT INTO user_preferences VALUES (?,?,?,?,?)\n            ON CONFLICT(user_id) DO UPDATE SET\n                preference_id  = excluded.preference_id,\n                schema_version = excluded.schema_version,\n                updated_at     = excluded.updated_at,\n                prefs          = excluded.prefs\n        \"\"\", (\n            pset.user_id,\n            pset.preference_id,\n            pset.schema_version,\n            pset.updated_at.isoformat(),\n            json.dumps(pset.prefs),\n        ))\n\ndef load_preferences(user_id: str, db_path: Path = DB_PATH) -> PreferenceSet:\n    \"\"\"Return stored preferences, or a defaults object if none exist.\"\"\"\n    with sqlite3.connect(db_path) as conn:\n        conn.row_factory = sqlite3.Row\n        row = conn.execute(\n            \"SELECT * FROM user_preferences WHERE user_id = ?\", (user_id,)\n        ).fetchone()\n    if not row:\n        ps = PreferenceSet(user_id=user_id, updated_at=datetime.now(timezone.utc))\n        return ps\n    ps = PreferenceSet(\n        preference_id=row[\"preference_id\"],\n        user_id=user_id,\n        schema_version=row[\"schema_version\"],\n        updated_at=datetime.fromisoformat(row[\"updated_at\"]),\n        prefs=json.loads(row[\"prefs\"]),\n    )\n    return ps\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Preference API"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Expose a REST API so the UI can read and update preferences. Use PATCH semantics: the caller sends only the keys to change, and the server merges them with the current stored object. This avoids race conditions from parallel UI tabs sending different full-object PUT requests."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# FastAPI example — preference center API\nfrom fastapi import FastAPI, HTTPException, Depends\nfrom pydantic import BaseModel\nfrom typing import Any\nfrom datetime import datetime, timezone\nfrom preference_store import load_preferences, save_preferences\nfrom audit import log_preference_change\n\napp = FastAPI()\n\nclass PreferencePatch(BaseModel):\n    prefs: dict[str, Any]   # only the keys being changed\n\nALLOWED_KEYS = {\n    \"claude.history.enabled\", \"claude.history.ttl_days\",\n    \"claude.analytics.enabled\", \"claude.tone\", \"claude.language\",\n    \"claude.citations.enabled\",\n    # feature-specific toggles follow pattern: claude.feature.<id>.enabled\n}\n\ndef validate_patch(patch: dict[str, Any]) -> None:\n    for key in patch:\n        if key.startswith(\"claude.feature.\") and key.endswith(\".enabled\"):\n            continue\n        if key not in ALLOWED_KEYS:\n            raise HTTPException(status_code=400, detail=f\"Unknown preference key: {key}\")\n\n@app.get(\"/api/v1/preferences/{user_id}\")\nasync def get_preferences(user_id: str):\n    pset = load_preferences(user_id)\n    return {\"user_id\": user_id, \"prefs\": pset.prefs, \"updated_at\": pset.updated_at}\n\n@app.patch(\"/api/v1/preferences/{user_id}\")\nasync def patch_preferences(user_id: str, body: PreferencePatch):\n    validate_patch(body.prefs)\n    pset = load_preferences(user_id)\n    old_prefs = dict(pset.prefs)\n    for key, value in body.prefs.items():\n        pset.set(key, value)\n    save_preferences(pset)\n    log_preference_change(user_id, old_prefs, pset.prefs)\n    return {\"user_id\": user_id, \"updated\": list(body.prefs.keys())}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Consuming Preferences at the Claude API Gate"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Every Claude API call loads the caller's preferences and applies them before constructing the request. Feature toggles gate the call entirely; style preferences are injected into the system prompt."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\nfrom preference_store import load_preferences\n\nclient = anthropic.Anthropic()\n\nTONE_INSTRUCTIONS = {\n    \"professional\": \"Be concise and formal. Use business language.\",\n    \"friendly\":     \"Be warm and conversational. Use accessible language.\",\n    \"technical\":    \"Be precise and detailed. Include implementation specifics.\",\n}\n\nclass FeatureDisabledError(Exception):\n    pass\n\ndef call_claude_with_preferences(\n    user_id: str,\n    feature_id: str,\n    user_message: str,\n    base_system: str = \"\",\n) -> str:\n    prefs = load_preferences(user_id)\n\n    # Feature gate\n    if not prefs.get_bool(f\"claude.feature.{feature_id}.enabled\", default=True):\n        raise FeatureDisabledError(\n            f\"Feature '{feature_id}' is disabled in your preferences.\"\n        )\n\n    # Build system prompt with preference injections\n    tone_key = prefs.get_str(\"claude.tone\", \"professional\")\n    tone_instruction = TONE_INSTRUCTIONS.get(tone_key, \"\")\n\n    lang = prefs.get_str(\"claude.language\", \"en\")\n    lang_instruction = \"\" if lang == \"en\" else f\"Respond in language: {lang}.\"\n\n    citations_on = prefs.get_bool(\"claude.citations.enabled\", True)\n    cite_instruction = (\n        \"Always cite the source document when referencing retrieved information.\"\n        if citations_on else \"\"\n    )\n\n    system = \" \".join(filter(None, [base_system, tone_instruction, lang_instruction, cite_instruction]))\n\n    response = client.messages.create(\n        model=\"claude-sonnet-5\",\n        max_tokens=1024,\n        system=system,\n        messages=[{\"role\": \"user\", \"content\": user_message}],\n    )\n    return response.content[0].text\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Audit Logging for Preference Changes"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Every preference change must be logged with the old and new values so you can reconstruct the effective preference set at any point in time. This is necessary for debugging ('why did Claude stop citing sources for this user?') and for demonstrating compliance ('was analytics tracking disabled before that conversation?')."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import json\nfrom datetime import datetime, timezone\nfrom pathlib import Path\n\nPREF_AUDIT_LOG = Path(\"/var/data/consent/preference_changes.jsonl\")\n\ndef log_preference_change(\n    user_id: str,\n    old_prefs: dict,\n    new_prefs: dict,\n):\n    diff = {\n        key: {\"from\": old_prefs.get(key), \"to\": new_prefs.get(key)}\n        for key in set(old_prefs) | set(new_prefs)\n        if old_prefs.get(key) != new_prefs.get(key)\n    }\n    if not diff:\n        return\n    event = {\n        \"ts\": datetime.now(timezone.utc).isoformat(),\n        \"user_id\": user_id,\n        \"changes\": diff,\n    }\n    with open(PREF_AUDIT_LOG, \"a\", encoding=\"utf-8\") as f:\n        f.write(json.dumps(event) + \"\\n\")\n"
          }
        ]
