        "content": [
          {
            "type": "text",
            "text": "# Redis pub-sub example for preference change propagation\nimport redis, json\n\nr = redis.Redis(host=\"localhost\", port=6379, decode_responses=True)\n\nCHANNEL = \"claude:preference_changes\"\n\ndef publish_preference_change(user_id: str, changed_keys: list[str]):\n    message = json.dumps({\"user_id\": user_id, \"keys\": changed_keys})\n    r.publish(CHANNEL, message)\n\n# In each consumer process — subscribe and invalidate local cache\ndef start_preference_listener(local_cache: dict):\n    pubsub = r.pubsub()\n    pubsub.subscribe(CHANNEL)\n    for message in pubsub.listen():\n        if message[\"type\"] != \"message\":\n            continue\n        payload = json.loads(message[\"data\"])\n        user_id = payload[\"user_id\"]\n        if user_id in local_cache:\n            del local_cache[user_id]  # force reload on next request\n"
          }
        ]
