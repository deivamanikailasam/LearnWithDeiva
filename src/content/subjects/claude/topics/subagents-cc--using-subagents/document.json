}],"text":"yellow"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"purple"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"orange"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"pink"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"cyan"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"initialPrompt"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Auto-submitted first turn when running as the main session agent"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Controlling Tool Access"}]},{"type":"paragraph","content":[{"type":"text","text":"Tool access is the primary security boundary for subagents. There are three ways to control it:"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Allowlist only specific tools:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"---\nname: safe-researcher\ndescription: Read-only research agent\ntools: Read, Grep, Glob, Bash\n---"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Denylist specific tools, inherit the rest:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"---\nname: no-writes\ndescription: Full access except file writes\ndisallowedTools: Write, Edit\n---"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Scope MCP servers at the server level:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"---\nname: local-only\ndescription: Inherits all tools except GitHub MCP tools\ndisallowedTools: mcp__github\n---"}]},{"type":"paragraph","content":[{"type":"text","text":"If both "},{"type":"text","marks":[{"type":"code"}],"text":"tools"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"code"}],"text":"disallowedTools"},{"type":"text","text":" are set, the denylist is applied first, then the allowlist resolves against the remaining pool. If "},{"type":"text","marks":[{"type":"code"}],"text":"tools"},{"type":"text","text":" is omitted entirely, the subagent "},{"type":"text","marks":[{"type":"bold"}],"text":"inherits all tools"},{"type":"text","text":" from the main conversation — including every MCP tool — which is a common source of unintended over-permissioning."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Model Selection Strategy"}]},{"type":"paragraph","content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"code"}],"text":"model"},{"type":"text","text":" field lets you route tasks to the right model for the job:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Haiku"},{"type":"text","text":": Best for fast, read-only exploration and search — the built-in "},{"type":"text","marks":[{"type":"code"}],"text":"Explore"},{"type":"text","text":" agent uses this"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sonnet"},{"type":"text","text":": Balanced capability and speed — ideal for code review, analysis, and most custom agents"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Opus"},{"type":"text","text":": Maximum capability — use for complex architectural reasoning or multi-step planning"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Model resolution order is: "},{"type":"text","marks":[{"type":"code"}],"text":"CLAUDE_CODE_SUBAGENT_MODEL"},{"type":"text","text":" env var → per-invocation "},{"type":"text","marks":[{"type":"code"}],"text":"model"},{"type":"text","text":" parameter → subagent frontmatter "},{"type":"text","marks":[{"type":"code"}],"text":"model"},{"type":"text","text":" → main conversation model. This means you can override a specific subagent's model for a session without editing the definition file."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Persistent Memory"}]},{"type":"paragraph","content":[{"type":"text","text":"Setting "},{"type":"text","marks":[{"type":"code"}],"text":"memory: project"},{"type":"text","text":" gives a subagent a persistent directory that survives across conversations, enabling it to accumulate institutional knowledge over time:"}]},{"type":"codeBlock","attrs":{"language":"markdown"},"content":[{"type":"text","text":"---\nname: code-reviewer\ndescription: Reviews code for quality and best practices\nmemory: project\n---\n\nYou are a code reviewer. As you work, update your agent memory with\nrecurring patterns, anti-patterns, and architectural decisions you discover.\nThis builds up institutional knowledge across conversations."}]},{"type":"paragraph","content":[{"type":"text","text":"Memory scopes control where the knowledge is stored:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scope"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Path"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use when"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"user"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"~/.claude/agent-memory/<name>/"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Knowledge applies across all projects"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"project"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":".claude/agent-memory/<name>/"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Project-specific, shareable via version control"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"local"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":".claude/agent-memory-local/<name>/"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Project-specific, should NOT be committed"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"When memory is enabled, the subagent's system prompt automatically includes the first 200 lines or 25KB of "},{"type":"text","marks":[{"type":"code"}],"text":"MEMORY.md"},{"type":"text","text":", and "},{"type":"text","marks":[{"type":"code"}],"text":"Read"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"Write"},{"type":"text","text":", and "},{"type":"text","marks":[{"type":"code"}],"text":"Edit"},{"type":"text","text":" tools are auto-enabled."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Scoping MCP Servers to a Subagent"}]},{"type":"paragraph","content":[{"type":"text","text":"You can give a subagent access to MCP servers that aren't available in the main conversation, or conversely, keep an MCP server's tool descriptions out of the main context by defining it inline in the subagent's frontmatter:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"---\nname: browser-tester\ndescription: Tests features in a real browser using Playwright\nmcpServers:\n  # Inline: connected only while this subagent is active\n  - playwright:\n      type: stdio\n      command: npx\n      args: [\"-y\", \"@playwright/mcp@latest\"]\n  # Reference: reuses an already-configured server connection\n  - github\n---"}]},{"type":"paragraph","content":[{"type":"text","text":"This pattern is powerful for keeping expensive or specialized MCP tools (Playwright, database clients, external APIs) out of the main conversation's token budget, activating them only when the relevant subagent runs."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Hooks for Subagents"}]},{"type":"paragraph","content":[{"type":"text","text":"Subagents support "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://code.claude.com/docs/en/hooks","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"lifecycle hooks"},{"type":"text","text":" in two ways:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Frontmatter hooks"},{"type":"text","text":" — run only while that subagent is active (e.g., "},{"type":"text","marks":[{"type":"code"}],"text":"PreToolUse"},{"type":"text","text":" to validate operations)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Session settings hooks"},{"type":"text","text":" — "},{"type":"text","marks":[{"type":"code"}],"text":"SubagentStop"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"code"}],"text":"Stop"},{"type":"text","text":" events fire when a subagent completes, useful for chaining"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"This example creates a database subagent that enforces read-only queries via a "},{"type":"text","marks":[{"type":"code"}],"text":"PreToolUse"},{"type":"text","text":" hook:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"---\nname: db-reader\ndescription: Execute read-only database queries\ntools: Bash\nhooks:\n  PreToolUse:\n    - matcher: \"Bash\"\n      hooks:\n        - type: command\n          command: \"./scripts/validate-readonly-query.sh\"\n---"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"#!/bin/bash\n# validate-readonly-query.sh\nINPUT=$(cat)\nCOMMAND=$(echo \"$INPUT\" | jq -r '.tool_input.command // empty')\n\nif echo \"$COMMAND\" | grep -iE '\\b(INSERT|UPDATE|DELETE|DROP|CREATE|ALTER|TRUNCATE)\\b' > /dev/null; then\n  echo \"Blocked: Only SELECT queries are allowed\" >&2\n  exit 2\nfi\nexit 0"}]},{"type":"paragraph","content":[{"type":"text","text":"For pipeline chaining between subagents, register a "},{"type":"text","marks":[{"type":"code"}],"text":"SubagentStop"},{"type":"text","text":" hook in "},{"type":"text","marks":[{"type":"code"}],"text":".claude/settings.json"},{"type":"text","text":" that reads a queue file and prints the next suggested command to STDOUT — humans can then paste it in to approve the next step."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Isolation with Git Worktrees"}]},{"type":"paragraph","content":[{"type":"text","text":"Setting "},{"type":"text","marks":[{"type":"code"}],"text":"isolation: worktree"},{"type":"text","text":" runs the subagent in a temporary copy of the repository, branched from the default branch:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"---\nname: experimental-refactor\ndescription: Refactor code in an isolated branch without affecting the working tree\nisolation: worktree\n---"}]},{"type":"paragraph","content":[{"type":"text","text":"This is ideal for risky or experimental changes — the subagent gets its own isolated filesystem state, and the worktree is automatically cleaned up if it makes no changes."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Invoking Subagents Explicitly"}]},{"type":"paragraph","content":[{"type":"text","text":"Beyond automatic delegation, you can invoke subagents directly in a prompt:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"By name mention: "},{"type":"text","marks":[{"type":"code"}],"text":"\"Use the code-reviewer agent to analyze this file\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"With the "},{"type":"text","marks":[{"type":"code"}],"text":"@"},{"type":"text","text":" syntax: "},{"type":"text","marks":[{"type":"code"}],"text":"@code-reviewer analyze src/api/routes.ts"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"As a session agent: "},{"type":"text","marks":[{"type":"code"}],"text":"claude --agent code-reviewer"},{"type":"text","text":" to run the agent as the main session"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"When an agent runs as the main thread with "},{"type":"text","marks":[{"type":"code"}],"text":"claude --agent"},{"type":"text","text":", you can restrict which subagent types it can spawn using "},{"type":"text","marks":[{"type":"code"}],"text":"Agent(type)"},{"type":"text","text":" syntax in the "},{"type":"text","marks":[{"type":"code"}],"text":"tools"},{"type":"text","text":" field:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"---\nname: coordinator\ndescription: Orchestrates work across specialized agents\ntools: Agent(worker, researcher), Read, Bash\n---"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"A Production Pipeline Pattern"}]},{"type":"paragraph","content":[{"type":"text","text":"A well-proven three-stage pipeline for any software project:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":".claude/\n  agents/\n    pm-spec.md          # Reads enhancement → writes spec → sets READY_FOR_ARCH\n    architect-review.md # Validates design → writes ADR → sets READY_FOR_BUILD\n    implementer-tester.md # Implements + tests → sets DONE if green\n  hooks/\n    on-subagent-stop.sh # Reads queue, prints next suggested command to STDOUT\n  settings.json\nenhancements/\n  _queue.json           # slug → status tracking\ndocs/claude/\n  working-notes/        # PM output per feature slug\n  decisions/            # ADR output per feature slug"}]},{"type":"paragraph","content":[{"type":"text","text":"Each agent has a "},{"type":"text","marks":[{"type":"bold"}],"text":"single responsibility"},{"type":"text","text":", a "},{"type":"text","marks":[{"type":"bold"}],"text":"clear Definition of Done"},{"type":"text","text":", and a "},{"type":"text","marks":[{"type":"bold"}],"text":"HITL rule"},{"type":"text","text":" — for example, the architect stops and asks for approval before finalizing any public API change. The hook suggests the next step; a human pastes it in to proceed, preventing runaway chains."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Disabling Subagents"}]},{"type":"paragraph","content":[{"type":"text","text":"To block Claude from using specific subagents, add them to the "},{"type":"text","marks":[{"type":"code"}],"text":"deny"},{"type":"text","text":" array in "},{"type":"text","marks":[{"type":"code"}],"text":".claude/settings.json"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"{\n  \"permissions\": {\n    \"deny\": [\"Agent(Explore)\", \"Agent(my-custom-agent)\"]\n  }\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"To prevent all delegation, deny the "},{"type":"text","marks":[{"type":"code"}],"text":"Agent"},{"type":"text","text":" tool itself. In non-interactive or SDK mode, set "},{"type":"text","marks":[{"type":"code"}],"text":"CLAUDE_AGENT_SDK_DISABLE_BUILTIN_AGENTS=1"},{"type":"text","text":" to remove all built-in types and supply only your own."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common Mistakes and Anti-patterns"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Omitting "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tools"},{"type":"text","text":": This grants the subagent full access to every tool in the main conversation, including all MCP tools — always be intentional"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Vague descriptions"},{"type":"text","text":": Claude uses the "},{"type":"text","marks":[{"type":"code"}],"text":"description"},{"type":"text","text":" to decide when to delegate; a weak description leads to missed or incorrect invocations"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Over-broad subagents"},{"type":"text","text":": Give each subagent one clear goal, one input, one output, and one handoff rule — single-responsibility is the most important design principle"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Using "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"bypassPermissions"},{"type":"text","marks":[{"type":"bold"}],"text":" carelessly"},{"type":"text","text":": This skips all permission prompts including writes to sensitive directories like "},{"type":"text","marks":[{"type":"code"}],"text":".git"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"code"}],"text":".claude"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Not registering both "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"SubagentStop"},{"type":"text","marks":[{"type":"bold"}],"text":" and "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"Stop"},{"type":"text","text":": Register both hook events to reliably catch the end of any run"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Treating hooks as optional scripts"},{"type":"text","text":": Version them in "},{"type":"text","marks":[{"type":"code"}],"text":".claude/hooks/"},{"type":"text","text":", validate JSON with "},{"type":"text","marks":[{"type":"code"}],"text":"jq"},{"type":"text","text":", keep them idempotent, and make them executable"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mixing project and context-polluting tasks"},{"type":"text","text":": Any task that generates lots of logs, search results, or intermediate data is exactly the right candidate to offload to a subagent"}]}]}]},{"type":"paragraph"}]}}
