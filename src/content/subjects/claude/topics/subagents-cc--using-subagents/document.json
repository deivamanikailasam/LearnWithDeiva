ype":"text","text":" or "},{"type":"text","marks":[{"type":"code"}],"text":"Enter"},{"type":"text","text":" to save — available immediately without a restart"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Manual File Creation"}]},{"type":"paragraph","content":[{"type":"text","text":"Subagents are Markdown files with YAML frontmatter for configuration and a body that becomes the system prompt:"}]},{"type":"codeBlock","attrs":{"language":"markdown"},"content":[{"type":"text","text":"---\nname: code-reviewer\ndescription: Reviews code for quality and best practices after any code change\ntools: Read, Glob, Grep\nmodel: sonnet\n---\n\nYou are a senior code reviewer. Analyze code and provide specific,\nactionable feedback on quality, security, and best practices.\nExplain each issue, show the current code, and provide an improved version."}]},{"type":"paragraph","content":[{"type":"text","text":"Only "},{"type":"text","marks":[{"type":"code"}],"text":"name"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"code"}],"text":"description"},{"type":"text","text":" are required. The "},{"type":"text","marks":[{"type":"code"}],"text":"description"},{"type":"text","text":" field is critical — Claude uses it to decide "},{"type":"text","marks":[{"type":"italic"}],"text":"when"},{"type":"text","text":" to delegate to this subagent, so write it as a clear trigger condition."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"CLI-Defined Subagents"}]},{"type":"paragraph","content":[{"type":"text","text":"For session-scoped or automation use cases, pass subagents as JSON at launch without saving to disk:"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"claude --agents '{\n  \"code-reviewer\": {\n    \"description\": \"Expert code reviewer. Use proactively after code changes.\",\n    \"prompt\": \"You are a senior code reviewer. Focus on code quality, security, and best practic