ls"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Externalization"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Requires manual file management; no automatic sync"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How It Works"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Token Consumption Layers in Claude Code"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"┌─────────────────────────────────────┐\n│ System prompt (CLAUDE.md)  ~2k   │\n│ Project context (settings) ~1k   │\n│ Conversation history       fills │\n│ Tool call results          large │\n│ File contents (read_file)  large │\n│ Available: 200k total              │\n└─────────────────────────────────────┘"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Biggest culprits"},{"type":"text","text":": tool call results ("},{"type":"text","marks":[{"type":"code"}],"text":"read_file"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"bash"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"grep"},{"type":"text","text":"), long conversation threads, repeated file reads."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Truncation vs. Compaction Decision Tree"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Is context >70%?\n  ├─ Yes → Need new phase? → /clear (with checkpoint summary)\n  ├─ Yes → Continuing same work? → /compact with preservation\n  ├─ No → Using targeted reads? → Keep going\n  └─ No → Session ending? → Externalize to SESSION-NOTES.md"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"When to Use Each Strategy"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Use "},{"type":"text","marks":[{"type":"bold"}],"text":"Truncation (Oldest-First)"},{"type":"text","text":" When:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Starting a "},{"type":"text","marks":[{"type":"bold"}],"text":"totally new phase"},{"type":"text","text":" of work"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Older context is "},{"type":"text","marks":[{"type":"bold"}],"text":"irrelevant"},{"type":"text","text":" to current task"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"You have "},{"type":"text","marks":[{"type":"bold"}],"text":"checkpoint summaries"},{"type":"text","text":" saved externally"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Use "},{"type":"text","marks":[{"type":"bold"}],"text":"Selective Truncation"},{"type":"text","text":" When:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Context is "},{"type":"text","marks":[{"type":"bold"}],"text":"70–80%"},{"type":"text","text":" but need to continue"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Want to keep "},{"type":"text","marks":[{"type":"bold"}],"text":"last 5–10 message pairs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Using tools like "},{"type":"text","marks":[{"type":"bold"}],"text":"aichat Trim"},{"type":"text","text":" (brings usage to 50%)"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Use "},{"type":"text","marks":[{"type":"bold"}],"text":"Compaction (Summarization)"},{"type":"text","text":" When:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Long-running conversations"},{"type":"text","text":" requiring handoffs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Need to preserve "},{"type":"text","marks":[{"type":"bold"}],"text":"decisions and current state"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Transitioning between sessions"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Use "},{"type":"text","marks":[{"type":"bold"}],"text":"Externalization"},{"type":"text","text":" When:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Production agentic workflows"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Want "},{"type":"text","marks":[{"type":"bold"}],"text":"zero information loss"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Working on "},{"type":"text","marks":[{"type":"bold"}],"text":"multi-session projects"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How to Implement"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"/clear"},{"type":"text","marks":[{"type":"bold"}],"text":" Command (Nuclear Option)"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"/clear"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Wipes entire conversation history"},{"type":"text","text":" — loses reasoning behind decisions."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use safely with checkpoint summary"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Before we continue, write a markdown summary of:\n1. What we've accomplished so far\n2. What files we've modified and why\n3. What the next 3 steps are\n4. Any decisions or constraints I should know about\n\nSave it to PROGRESS.md"}]},{"type":"paragraph","content":[{"type":"text","text":"Then "},{"type":"text","marks":[{"type":"code"}],"text":"/clear"},{"type":"text","text":" and paste summary back in."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Manual Copy/Paste + "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"/clear"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"# Copy last 3–5 important messages\n# Run /clear\n# Paste copied text as first prompt in new session"}]},{"type":"paragraph","content":[{"type":"text","text":"Perfect control over exact content to keep; not elegant but effective."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"/compact"},{"type":"text","marks":[{"type":"bold"}],"text":" with Preservation Instructions"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"/compact \"Keep only the final plan and the last user prompt. Discard everything else.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Still summarization"},{"type":"text","text":" but guides what to preserve."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Selective compaction template"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"/compact \"MUST PRESERVE:\n1. Database schema (users, orders, payments)\n2. 4 API endpoints (POST /orders, GET /orders/:id, PATCH, DELETE)\n3. Last test results (3 passed, 1 failed)\nREMOVE: all code explorations, file reads, failed attempts\""}]},{"type":"paragraph","content":[{"type":"text","text":"Retains 95% relevance while freeing 77% context."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Command-Based Pruning (Requested Feature)"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"/prune --keep-last 5"}]},{"type":"paragraph","content":[{"type":"text","text":"Would keep only last 5 message pairs — "},{"type":"text","marks":[{"type":"bold"}],"text":"not yet implemented"},{"type":"text","text":" but requested in GitHub."}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"/prune --from-message <message-id>"}]},{"type":"paragraph","content":[{"type":"text","text":"Keep everything from specific message onward."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Smart Pruning with Checkpoint Markers"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"/checkpoint \"Task list created\"\n/prune --from-checkpoint"}]},{"type":"paragraph","content":[{"type":"text","text":"Allow users to set checkpoint markers; prune from checkpoint onward."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"6. "},{"type":"text","marks":[{"type":"bold"}],"text":"aichat Tool (Trim Rollover)"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Quit session\naichat resume <session-id>\n\n# From TUI select:\n✂ Trim: clones session, truncates long tool calls/results + older messages → 50% usage\n🔗 Rollover: new session + injects session log file path → 15–20% usage"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Never compact"},{"type":"text","text":" — use rollover + sometimes trim."}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"uv tool install claude-code-tools\nclaude plugin marketplace add pchalasani/claude-code-tools\nclaude plugin install \"aichat@cctools-plugins\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"7. "},{"type":"text","marks":[{"type":"bold"}],"text":"Session Handoff Pattern (Externalization)"}]},{"type":"codeBlock","attrs":{"language":"markdown"},"content":[{"type":"text","text":"# In CLAUDE.md, add:\n\n## Session Handoff Protocol\nAt end of each session, create SESSION-NOTES.md with:\n- What was accomplished\n- What was NOT done (and why)\n- Current blockers\n- Next session starting point\n- Any important context future sessions need"}]},{"type":"paragraph","content":[{"type":"text","text":"Externalizes memory to filesystem where it's free."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"8. "},{"type":"text","marks":[{"type":"bold"}],"text":"Checkpoint Summary Before Clear"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Before we continue, write a markdown summary of:\n1. What we've accomplished so far\n2. What files we've modified and why\n3. What the next 3 steps are\n4. Any decisions or constraints I should know about\n\nSave it to PROGRESS.md"}]},{"type":"paragraph","content":[{"type":"text","text":"Now "},{"type":"text","marks":[{"type":"code"}],"text":"/clear"},{"type":"text","text":" and paste summary back — lose conversation but keep knowledge."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"9. "},{"type":"text","marks":[{"type":"bold"}],"text":"Targeted Reads (Prevention Strategy)"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"# ❌ Bad: loads entire files (~8,000 tokens)\nread the codebase and understand how auth works\n\n# ✅ Good: surgical reads (~200 tokens)\ngrep -n 'auth\\|login\\|token' src/routes/*.js | head -30"}]},{"type":"paragraph","content":[{"type":"text","text":"Prompt Claude to use "},{"type":"text","marks":[{"type":"code"}],"text":"grep"},{"type":"text","text":"/"},{"type":"text","marks":[{"type":"code"}],"text":"find"},{"type":"text","text":" before "},{"type":"text","marks":[{"type":"code"}],"text":"read_file"},{"type":"text","text":" — gets answer with 1/10th context cost."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"10. "},{"type":"text","marks":[{"type":"bold"}],"text":"Subagents for Isolated Tasks"}]},{"type":"codeBlock","attrs":{"language":"sql"},"content":[{"type":"text","text":"Create a subagent that ONLY has access to src/utils/format.js.\nIts only job: add JSDoc comments to every function.\nReport back the changes when done."}]},{"type":"paragraph","content":[{"type":"text","text":"Subagent runs in own context window; results return as compact summary, not 10k token diff."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"11. "},{"type":"text","marks":[{"type":"bold"}],"text":"CLAUDE.md Pruning"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Review my CLAUDE.md and identify:\n1. Instructions that are outdated\n2. Instructions that are redundant\n3. Instructions that could be shorter\n\nSuggest a pruned version under 200 lines."}]},{"type":"paragraph","content":[{"type":"text","text":"Keep CLAUDE.md under 500 lines (ideally 200) since it loads every session."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Examples"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example 1: Mid-Refactor Context Crisis"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Scenario"},{"type":"text","text":": 15 files tracked, CLAUDE.md loaded, conversation history + tool outputs filling 180k tokens"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Before hitting limit"},{"type":"text