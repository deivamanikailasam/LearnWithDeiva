{"format":"tiptap/v1","updatedAt":"2026-06-21T13:50:10.552Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Truncation strategies"},{"type":"text","text":" are techniques for managing Claude's context window when it approaches capacity. They involve "},{"type":"text","marks":[{"type":"bold"}],"text":"removing, compressing, or externalizing"},{"type":"text","text":" older conversation history to make room for new tokens while preserving critical information."}]},{"type":"paragraph","content":[{"type":"text","text":"Unlike "},{"type":"text","marks":[{"type":"bold"}],"text":"compaction"},{"type":"text","text":" (which summarizes conversation history), truncation "},{"type":"text","marks":[{"type":"bold"}],"text":"drops messages entirely"},{"type":"text","text":" — either oldest-first, selective content, or based on user-defined markers."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why It Matters"}]},{"type":"paragraph","content":[{"type":"text","text":"When Claude hits truncation limits:\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Responses get shorter and less specific"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Claude asks you to re-explain things already covered"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"read_file"},{"type":"text","marks":[{"type":"bold"}],"text":" outputs get truncated"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Multi-step plans lose earlier steps"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Claude starts hedging"},{"type":"text","text":": \"I'm not sure if we already...\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Critical distinction"},{"type":"text","text":": API truncation returns "},{"type":"text","marks":[{"type":"code"}],"text":"stop_reason: \"max_tokens\""},{"type":"text","text":" (fix: increase "},{"type":"text","marks":[{"type":"code"}],"text":"max_tokens"},{"type":"text","text":") vs. context window limits that cause content disappearance (fix: prune/summarize history)."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Benefits of Truncation vs. Compaction"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Strategy"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Token Reduction"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Information Loss"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Best For"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Truncation (oldest-first)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"40–60%"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"High (loses reasoning)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"New work phases"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Selective truncation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"50–70%"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Medium (keeps recent)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Long sessions"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Compaction (summarize)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"50–80%"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Low-Medium"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Handoffs between sessions"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Externalization"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"100% (to disk)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text"