        "content": [
          {
            "type": "text",
            "text": "my-agent-service/\n├── agent/\n│   ├── orchestrator.py     # Main agent loop: call Claude, dispatch tools, handle human gates\n│   ├── tools/\n│   │   ├── registry.py     # Tool definitions and safety classification\n│   │   ├── read/           # read-only tools (execute immediately)\n│   │   │   ├── search_docs.py\n│   │   │   └── run_query.py\n│   │   └── write/          # write tools (require human approval)\n│   │       ├── send_email.py\n│   │       └── update_record.py\n│   ├── state.py            # Conversation + approval state in Redis/DynamoDB\n│   ├── audit.py            # Structured audit log writer\n│   └── human_gate.py       # Slack approval flow\n├── prompts/\n│   └── agent_system.yaml   # System prompt with tool usage guidance\n├── evals/\n│   ├── cases/seed.jsonl    # Task → expected final state test cases\n│   └── runner.py           # Eval harness\n├── .github/workflows/ci.yml\n└── IDP_catalog.yml\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Tool Registry and Safety Classification"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# agent/tools/registry.py\nfrom __future__ import annotations\nfrom dataclasses import dataclass, field\nfrom typing import Callable, Any\n\n@dataclass\nclass ToolDef:\n    name: str\n    description: str\n    input_schema: dict\n    handler: Callable[..., Any]\n    safe: bool  # True = execute immediately; False = require human approval\n\n\n# Read-only tools — execute immediately\ndef _search_docs(query: str, limit: int = 5) -> list[dict]:\n    \"\"\"Search internal documentation. Returns list of {title, snippet, url}.\"\"\"\n    ...  # implementation calls vector store\n\ndef _run_query(sql: str) -> list[dict]:\n    \"\"\"Run a SELECT query on the analytics database. INSERT/UPDATE/DELETE are rejected.\"\"\"\n    if any(w in sql.upper() for w in [\"INSERT\", \"UPDATE\", \"DELETE\", \"DROP\"]):\n        raise ValueError(\"Only SELECT queries are allowed\")\n    ...  # implementation runs query\n\n# Write tools — require human approval\ndef _send_email(to: str, subject: str, body: str) -> dict:\n    \"\"\"Send an email via the internal mail service.\"\"\"\n    ...\n\ndef _update_record(table: str, record_id: str, fields: dict) -> dict:\n    \"\"\"Update a record in the CRM.\"\"\"\n    ...\n\nTOOLS: list[ToolDef] = [\n    ToolDef(\"search_docs\", \"Search internal documentation\",\n            {\"type\": \"object\", \"properties\": {\"query\": {\"type\": \"string\"}, \"limit\": {\"type\": \"integer\", \"default\": 5}}, \"required\": [\"query\"]},\n            _search_docs, safe=True),\n    ToolDef(\"run_query\", \"Run a read-only SQL query\",\n            {\"type\": \"object\", \"properties\": {\"sql\": {\"type\": \"string\"}}, \"required\": [\"sql\"]},\n            _run_query, safe=True),\n    ToolDef(\"send_email\", \"Send an email\",\n            {\"type\": \"object\", \"properties\": {\"to\": {\"type\": \"string\"}, \"subject\": {\"type\": \"string\"}, \"body\": {\"type\": \"string\"}}, \"required\": [\"to\", \"subject\", \"body\"]},\n            _send_email, safe=False),\n    ToolDef(\"update_record\", \"Update a CRM record\",\n            {\"type\": \"object\", \"properties\": {\"table\": {\"type\": \"string\"}, \"record_id\": {\"type\": \"string\"}, \"fields\": {\"type\": \"object\"}}, \"required\": [\"table\", \"record_id\", \"fields\"]},\n            _update_record, safe=False),\n]\n\nTOOL_MAP = {t.name: t for t in TOOLS}\nCLAUDE_TOOLS = [{\"name\": t.name, \"description\": t.description, \"input_schema\": t.input_schema} for t in TOOLS]\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Orchestration Loop"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# agent/orchestrator.py\nimport anthropic, json\nfrom .tools.registry import TOOL_MAP, CLAUDE_TOOLS\nfrom .state import save_turn, load_history\nfrom .audit import audit_tool_call\nfrom .human_gate import request_approval\n\nCLIENT = anthropic.Anthropic()\nMODEL = \"claude-opus-4-8\"\nMAX_TURNS = 20   # hard cap to prevent runaway loops\n\n\ndef run_agent(task: str, session_id: str) -> str:\n    messages = load_history(session_id)\n    messages.append({\"role\": \"user\", \"content\": task})\n    save_turn(session_id, messages)\n\n    for turn in range(MAX_TURNS):\n        response = CLIENT.messages.create(\n            model=MODEL,\n            max_tokens=4096,\n            tools=CLAUDE_TOOLS,\n            messages=messages,\n        )\n\n        messages.append({\"role\": \"assistant\", \"content\": response.content})\n        save_turn(session_id, messages)\n\n        if response.stop_reason == \"end_turn\":\n            # Extract final text response\n            for block in response.content:\n                if block.type == \"text\":\n                    return block.text\n            return \"\"\n\n        if response.stop_reason != \"tool_use\":\n            break\n\n        # Process tool calls\n        tool_results = []\n        for block in response.content:\n            if block.type != \"tool_use\":\n                continue\n            tool = TOOL_MAP.get(block.name)\n            if tool is None:\n                result = {\"error\": f\"Unknown tool: {block.name}\"}\n            elif not tool.safe:\n                # Write tool: request human approval before executing\n                approved = request_approval(session_id, block.name, block.input)\n                audit_tool_call(session_id, block.name, block.input, result=None, approved=approved)\n                if not approved:\n                    result = {\"status\": \"rejected\", \"message\": \"Human operator rejected this action.\"}\n                else:\n                    result = tool.handler(**block.input)\n                    audit_tool_call(session_id, block.name, block.input, result=result, approved=True)\n            else:\n                result = tool.handler(**block.input)\n                audit_tool_call(session_id, block.name, block.input, result=result, approved=None)\n\n            tool_results.append({\n                \"type\": \"tool_result\",\n                \"tool_use_id\": block.id,\n                \"content\": json.dumps(result),\n            })\n\n        messages.append({\"role\": \"user\", \"content\": tool_results})\n        save_turn(session_id, messages)\n\n    return \"Agent reached maximum turns without completing the task.\"\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Human-in-the-Loop Gate"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When Claude proposes a write tool call, the orchestrator suspends the agent loop and sends a Slack approval request. The approval record is stored in the state store; the loop resumes (or aborts) based on the human's response."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# agent/human_gate.py\nimport time, os, uuid\nfrom .state import set_approval_pending, wait_for_approval\n\nSLACK_WEBHOOK = os.environ[\"SLACK_APPROVAL_WEBHOOK\"]\n\n\ndef request_approval(session_id: str, tool_name: str, tool_input: dict) -> bool:\n    approval_id = str(uuid.uuid4())[:8]\n    import requests, json\n    requests.post(SLACK_WEBHOOK, json={\n        \"text\": f\":robot_face: *Agent Approval Required* (session `{session_id}`)\",\n        \"blocks\": [\n            {\"type\": \"section\", \"text\": {\"type\": \"mrkdwn\", \"text\":\n                f\"Tool: `{tool_name}`\\nInputs: ```{json.dumps(tool_input, indent=2)}```\"}},\n            {\"type\": \"actions\", \"elements\": [\n                {\"type\": \"button\", \"text\": {\"type\": \"plain_text\", \"text\": \"Approve\"},\n                 \"style\": \"primary\", \"value\": f\"approve:{approval_id}:{session_id}\"},\n                {\"type\": \"button\", \"text\": {\"type\": \"plain_text\", \"text\": \"Reject\"},\n                 \"style\": \"danger\", \"value\": f\"reject:{approval_id}:{session_id}\"},\n            ]},\n        ],\n    })\n    set_approval_pending(approval_id)\n    # Poll for up to 10 minutes\n    decision = wait_for_approval(approval_id, timeout_seconds=600)\n    return decision == \"approve\"\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Structured Audit Log"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Every tool call — whether auto-executed (safe) or human-gated (write) — is recorded. The audit log is append-only, written to CloudWatch Logs with a structured schema for querying and compliance review."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# agent/audit.py\nimport json, logging, time, os\n\n_log = logging.getLogger(\"agent.audit\")\nlogging.basicConfig(level=logging.INFO, format=\"%(message)s\")\n\n\ndef audit_tool_call(\n    session_id: str,\n    tool_name: str,\n    tool_input: dict,\n    result: dict | None,\n    approved: bool | None,   # None = safe tool (no gate); True/False = gated\n) -> None:\n    record = {\n        \"event\": \"tool_call\",\n        \"session_id\": session_id,\n        \"tool\": tool_name,\n        \"input\": tool_input,\n        \"result_summary\": str(result)[:500] if result else None,\n        \"requires_approval\": approved is not None,\n        \"approved\": approved,\n        \"ts\": time.time(),\n    }\n    _log.info(json.dumps(record))\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Eval Gate: Task Completion Fidelity"
          }
        ]
      },
      {
        "type": "paragraph",
