        "content": [
          {
            "type": "text",
            "text": "Token and Cost Controls"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Agentic loops can consume 10x more tokens than single-turn calls. The golden path enforces explicit guardrails: a per-session token budget, a maximum turn count, and Haiku for tool-result summarization."
              }
            ]
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# agent/orchestrator.py  — token budget enforcement\nMAX_INPUT_TOKENS_PER_SESSION = 200_000   # ~100 pages of context\nMAX_TURNS = 20\n\ndef run_agent(task: str, session_id: str) -> str:\n    total_input_tokens = 0\n    ...\n    for turn in range(MAX_TURNS):\n        response = CLIENT.messages.create(...)\n        total_input_tokens += response.usage.input_tokens\n        if total_input_tokens > MAX_INPUT_TOKENS_PER_SESSION:\n            audit_tool_call(session_id, \"budget_exceeded\", {}, None, None)\n            return \"Task aborted: session token budget exceeded.\"\n        ...\n"
          }
        ]
      },
