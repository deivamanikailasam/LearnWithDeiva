{"format":"tiptap/v1","updatedAt":"2026-06-22T04:22:21.934Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Based on the official Claude documentation, Anthropic's \"Building Effective AI Agents\" research, and the Claude Code Harness pattern documentation, "},{"type":"text","marks":[{"type":"bold"}],"text":"\"Memory & State\""},{"type":"text","text":" is how agents "},{"type":"text","marks":[{"type":"bold"}],"text":"maintain continuity across turns and sessions"},{"type":"text","text":", enabling them to remember past interactions and preserve context rather than starting from scratch each time."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","text":"Memory & State encompasses "},{"type":"text","marks":[{"type":"bold"}],"text":"state, persistence, and knowledge across sessions"},{"type":"text","text":" — the mechanisms that allow agents to remember what happened in previous turns, retain knowledge from past interactions, and maintain context across sessions spanning days or weeks."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Two Components"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Component"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"What It Handles"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Memory"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Long-term knowledge retention across sessions (user preferences, project context, past interactions)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"State"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Short-term conversation state within a session (mutable messages, file cache, token usage, permission denials)"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Session Memory (State)"}]},{"type":"paragraph","content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"bold"}],"text":"QueryEngine"},{"type":"text","text":" is the primary state container holding complete conversation history:"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"export class QueryEngine {\n  private mutableMessages: Message[] // Full conversation history\n  private totalUsage: NonNullableUsage // Cumulative token usage\n  private permissionDenials: SDKPermissionDenial[] // Audit trail\n  private discoveredSkillNames: Set<string> // Telemetry\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key aspects of session state:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"mutableMessages"},{"type":"text","text":" — Every user message, assistant response, tool result, and system message appended incrementally"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cross-turn persistence"},{"type":"text","text":" — State (messages, file cache, usage) carries over between "},{"type":"text","marks":[{"type":"code"}],"text":"submitMessage()"},{"type":"text","text":" calls"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mutable & incremental"},{"type":"text","text":" — Messages added as conversation progresses, not reset between turns"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Session Persistence via Transcripts"}]},{"type":"paragraph","content":[{"type":"text","text":"Conversations are "},{"type":"text","marks":[{"type":"bold"}],"text":"persisted to disk for recovery"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Pre-emptive persistence — before entering query loop\nif (persistSession && messagesFromUserInput.length > 0) {\n  const transcriptPromise = recordTranscript(messages)\n  await transcriptPromise // Block for durability in interactive mode\n}"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Persistence Strategy"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"When Used"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Trade-off"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fire-and-forget"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Bare mode"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Speed prioritized over durability"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Block & flush"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Interactive/cowork mode"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Durability prioritized over speed"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"This enables "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"--resume"},{"type":"text","marks":[{"type":"bold"}],"text":" functionality"},{"type":"text","text":" — without pre-emptive persistence, a kill between user message and API response makes resume fail with \"No conversation found\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Memory Hierarchy (Long-Term)"}]},{"type":"paragraph","content":[{"type":"text","text":"Claude Code implements a "},{"type":"text","marks":[{"type":"bold"}],"text":"six-tier memory hierarchy"},{"type":"text","text":":"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"System prompt"},{"type":"text","text":" — Agent's job description/identity"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"CLAUDE.md files"},{"type":"text","text":" — Project-level and user-level instructions"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Memory directory"},{"type":"text","text":" — Persistent attachments attached automatically"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Conversation history"},{"type":"text","text":" — mutableMessages in QueryEngine"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"File state cache"},{"type":"text","text":" — Cached file reads to avoid redundant reads"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Transcripts"},{"type":"text","text":" — Persisted conversation state on disk"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key behaviors:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"CLAUDE.md paths tracked"},{"type":"text","text":" — "},{"type":"text","marks":[{"type":"code"}],"text":"loadedNestedMemoryPaths"},{"type":"text","text":" set avoids re-injecting same file dozens of times\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"File cache evicts"},{"type":"text","text":" — But CLAUDE.md files remain in memory directory\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Preserved segments"},{"type":"text","text":" — Ensure resume works correctly after compaction"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why Memory & State Matters"}]},{"type":"paragraph","content":[{"type":"text","text":"Without memory, each conversation starts from scratch — users must re-explain preferences, project context, and ongoing work every time."}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Benefit"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Explanation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Continuity"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Agents build on past conversations, remember preferences, maintain context across sessions"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Attribution"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Memory provides attribution for learned information (where knowledge came from)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Self-correction"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Agents can learn from past mistakes recorded in memory"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"State management"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Cumulative token usage tracked to enforce budgets and warn before exceeding limits"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of Memory & State like a "},{"type":"text","marks":[{"type":"bold"}],"text":"developer's workspace"},{"type":"text","text":":"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"State"},{"type":"text","text":" = Open files, terminal history, current working directory (what's in front of them right now)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Memory"},{"type":"text","text":" = Notes, documentation, project README, past decisions (what they've learned and stored)"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Both are needed: state for immediate work, memory for long-term context."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Memory & State = state, persistence, and knowledge across sessions"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"QueryEngine is the primary state container holding complete conversation history (mutableMessages)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Every message (user, assistant, tool result, system) appended to mutableMessages incrementally"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"State persists across "},{"type":"text","marks":[{"type":"code"}],"text":"submitMessage()"},{"type":"text","text":" calls — enables multi-turn conversations"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Transcripts persisted to disk for crash/restart recovery and "},{"type":"text","marks":[{"type":"code"}],"text":"--resume"},{"type":"text","text":" functionality"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Claude Code implements six-tier memory hierarchy: system prompt → CLAUDE.md → memory dir → conversation → file cache → transcripts"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Pre-emptive persistence ensures transcript is resumable even if killed before API responds"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Memory provides attribution for learned information and turns errors into learning assets"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"The basic agentic building block is LLM + augmentations (retrieval, tools, memory)"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Memory systems are fundamental to creating AI agents that feel continuous and coherent rather than amnesiac."}]}]}}
