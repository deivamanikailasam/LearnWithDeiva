{"format":"tiptap/v1","updatedAt":"2026-06-21T01:06:58.435Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prompting for code"},{"type":"text","text":" requires specifying the programming language and version, providing context about the existing codebase, clearly defining functionality, and asking for comments and explanations."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key goals for code prompts:"},{"type":"text","text":" Correctness, readability, testability, and performance."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Core Structure for Code Prompts"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Essential Components"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Effective code prompts contain three key elements:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Context:"},{"type":"text","text":" Project or technical background\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Specification:"},{"type":"text","text":" What must accomplish\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Constraints:"},{"type":"text","text":" Technical/performance requirements"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Context: This code will run in a Flask app using SQLite.\nSpecification: Create a function to validate user email addresses.\nConstraints: Python 3.11, use the `re` module only, no external dependencies."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Role and Context"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Role and context: 'You are a senior software engineer.'\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"You are a senior software engineer specializing in Python development.\nYour code should follow PEP 8 standards and include comprehensive docstrings."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Role definition"},{"type":"text","text":" — Focuses knowledge base\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Expertise"},{"type":"text","text":" — Industry standards applied\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Style"},{"type":"text","text":" — PEP 8 compliance baseline"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Task Description"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Task description: 'Write a Python function that...'\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Write a Python function that:\n1. Takes a list of dictionaries as input\n2. Filters entries where age > 30\n3. Returns filtered list sorted by name"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best practices:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Be explicit"},{"type":"text","text":" — What code should do\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Numbered requirements"},{"type":"text","text":" — Processed reliably\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Atomic"},{"type":"text","text":" — Each requirement testable"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. Input/Output Specification"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Input/output spec: Clearly define parameters and return types.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Expected inputs:\n- data: list[dict], required, list of user records\n- min_age: int, optional, default=30\n\nExpected outputs:\n- filtered_data: list[dict], filtered and sorted users\n\nError handling:\n- Raise ValueError if data is empty\n- Raise TypeError if data is not a list"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key elements:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Name"},{"type":"text","text":" — Parameter identifier\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Type"},{"type":"text","text":" — Data type\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Format"},{"type":"text","text":" — Structure/constraints\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Required"},{"type":"text","text":" — Mandatory or optional"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"4. Constraints"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Constraints: Time/space complexity, version requirements, library restrictions.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Constraints:\n- Language: Python 3.11\n- Libraries: Only use built-in modules (re, datetime)\n- Performance: O(n) time complexity\n- No external dependencies\n- Memory: Handle up to 1M records"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Types:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Language/Version"},{"type":"text","text":" — Tech stack\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Dependencies"},{"type":"text","text":" — Libraries or none\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Performance"},{"type":"text","text":" — Time/space\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Style"},{"type":"text","text":" — Formatting rules"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"5. Testing Requirements"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Testing and Validation: A complete prompt requests the code "},{"type":"text","marks":[{"type":"bold"},{"type":"italic"}],"text":"and"},{"type":"text","marks":[{"type":"bold"}],"text":" the means to prove it works.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Include:\n1. The main function\n2. Unit tests using pytest\n3. Example calls demonstrating usage\n\nTests should cover:\n- Normal cases\n- Edge cases (empty list, None)\n- Error cases (invalid input)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best practices:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Test with code"},{"type":"text","text":" — Write and test\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Example calls"},{"type":"text","text":" — Prove functionality\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Unit tests"},{"type":"text","text":" — Validate correctness"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"6. Comments and Style"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Comment and style: Specify idiomatic style or docstring format.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Style requirements:\n- Follow PEP 8 conventions\n- Include type hints for all parameters\n- Add Google-style docstrings\n- Use meaningful variable names\n- Include inline comments for complex logic"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key elements:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Style guide"},{"type":"text","text":" — PEP 8, ESLint\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Type hints"},{"type":"text","text":" — Parameter types\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Docstrings"},{"type":"text","text":" — Function documentation\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Comments"},{"type":"text","text":" — Inline explanations"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Code Generation Templates"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template 1: Basic Function Generation"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"You are a senior Python developer.\n\nTask: Write a function to parse dates from European format to ISO format.\n\nContext:\n- Input: String in \"DD/MM/YYYY\" format (e.g., \"25/12/2024\")\n- Output: String in \"YYYY-MM-DD\" format (e.g., \"2024-12-25\")\n- Purpose: API compatibility with international system\n\nConstraints:\n- Python 3.11\n- Use datetime module only\n- No external dependencies\n- Handle invalid dates by raising ValueError\n\nRequirements:\n1. Include type hints for all parameters\n2. Add Google-style docstring\n3. Include inline comments for logic\n4. Follow PEP 8\n5. Include 3 example calls showing usage\n\nOutput: Only the function code with examples."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template 2: Complex Component (Two-Step)"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"For complex code, I've found tremendous success with a two-step approach: Design signature first, then implement.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 1: Function Signature"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"I need to create a data validation utility.\n\nBefore writing the full implementation, please:\n1. Suggest an appropriate function signature with parameter types\n2. Define return types\n3. Write a detailed docstring clarifying purpose and behavior\n\nOnce we agree on the signature, I'll ask for the implementation."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 2: Full Implementation"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Now implement the function using this signature:\n{{ACCEPTED_SIGNATURE}}\n\nInclude:\n- Type hints\n- Full docstring\n- Error handling\n- Unit tests"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template 3: Code Review"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"You are a senior code reviewer.\n\nTask: Review the following Python code for:\n1. Syntax errors\n2. Logical errors\n3. Performance issues\n4. Security vulnerabilities\n5. Style violations (PEP 8)\n\nCode:\n{{CODE_TO_REVIEW}}\n\nRequirements:\n- List each issue with line number\n- Provide explanation for why it's problematic\n- Suggest specific fix\n- Rate severity (Critical/High/Medium/Low)\n- Include corrected code snippet\n\nOutput format:\n## Issues Found\n| Line | Issue | Severity | Fix |"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template 4: Debugging"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"When you ask an LLM for help with debugging, it is important to include both your code and the relevant part of the traceback.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"I'm getting an error in my Python code.\n\nBackground:\n- Language: Python 3.11\n- Framework: Flask\n- Error type: TypeError\n\nMy code:\n{{CODE_WITH_ERROR}}\n\nError traceback:\n{{LAST_FEW_LINES_OF_TRACEBACK}}\n especially the error type and exact line"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key elements:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Background"},{"type":"text","text":" — Language, frameworks\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Error type"},{"type":"text","text":" — What's happening\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Conditions"},{"type":"text","text":" — What triggers it\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Traceback"},{"type":"text","text":" — Relevant lines only"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template 5: Refactoring"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"You are a senior developer optimizing code.\n\nTask: Refactor the following code for:\n1. Better performance\n2. Improved readability\n3. Reduced complexity\n4. Better error handling\n\nOriginal code:\n{{CODE_TO_REFACTOR}}\n\nRequirements:\n- Maintain same functionality\n- Improve time complexity from O(n²) to O(n)\n- Add type hints\n- Add docstrings\n- Include before/after comparison\n- Include unit tests showing same behavior\n\nOutput:\n1. Refactored code\n2. Explanation of changes\n3. Performance comparison\n4. Unit tests"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template 6: Code Translation"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"You are a polyglot developer.\n\nTask: Translate the following JavaScript code to Python.\n\nOriginal (JavaScript):\n{{JAVASCRIPT_CODE}}\n\nRequirements:\n- Python 3.11\n- Follow PEP 8\n- Include type hints\n- Add docstrings\n- Maintain same functionality\n- Convert ES6 syntax to Python idioms\n- Adapt library calls to Python equivalents\n\nOutput:\n1. Translated Python code\n2. List of syntax changes made\n3. Library mapping (JS → Python)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Advanced Techniques"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Technique 1: Show, Don't Just Tell (Examples)"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"When dealing with complex logic, custom inputs, or a particular code style, providing an example input and the expected output drastically improves the LLM's aim.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Write a function to sanitize user input.\n\nExample 1:\nInput: \"Hello<script>alert('x')</script>World\"\nOutput: \"HelloWorld\"\n\nExample 2:\nInput: \"Test&lt;data&gt;Here\"\nOutput: \"TestDataHere\"\n\nExample 3:\nInput: \"Normal text\"\nOutput: \"Normal text\"\n\nNow implement the function following this pattern."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Improves aim"},{"type":"text","text":" — Better adherence\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Pattern learning"},{"type":"text","text":" — Model internalizes\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Style consistency"},{"type":"text","text":" — Coherent output"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Technique 2: Chain-of-Thought for Algorithms"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"For tricky algorithms or multi-step tasks, ask the LLM to explain its solution strategy first. This forces the model to structure its thinking, which often catches logical bugs.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Task: Implement a binary search algorithm.\n\nBefore writing the code:\n1. Explain the algorithm's logic step-by-step\n2. Describe the preconditions and postconditions\n3. Outline the time and space complexity\n4. Identify edge cases to handle\n\nThen implement the code with:\n- Type hints\n- Docstring\n- Comments for each step\n- Unit tests"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Catches bugs"},{"type":"text","text":" — Before implementation\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Structured thinking"},{"type":"text","text":" — Logical flow\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Visible reasoning"},{"type":"text","text":" — Checkable path"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Technique 3: Leading Words"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Code Generation Specific - Use 'leading words' to nudge the model toward a particular pattern.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Write a Flask API endpoint.\n\nUse this pattern:"}]},{"type":"paragraph","content":[{"type":"text","text":"@app.route('/api/users', methods=['GET'])\ndef get_users(): \"\"\"Retrieve all users.\"\"\" try: # Your implementation here except Exception as e: return jsonify({'error': str(e)}), 500"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\nFollow this structure and implement the logic."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Technique 4: Mental Model Transformation"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"For particularly complex code, I use 'mental model transformation' — asking the LLM to create an analogy or visualization that makes the code's purpose intuitive.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"After explaining the technical details of this code:\n{{CODE_TO_EXPLAIN}}\n\nPlease create a real-world analogy or visualization that would help a junior developer understand the underlying concept.\n\nThe analogy should make the purpose and behavior intuitive even for someone unfamiliar with technical details."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Technique 5: Iterative Refinement"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Prompt engineering is rarely one-shot. Generate, review, test, and refine iteratively. Feedback from test results or linters can inform the next version.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Process:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Generate"},{"type":"text","text":" — Initial code\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Review"},{"type":"text","text":" — Check for issues\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Test"},{"type":"text","text":" — Run tests/linters\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Refine"},{"type":"text","text":" — Next version\n5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Repeat"},{"type":"text","text":" — Until stable"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Treat like agile development"},{"type":"text","text":" — Each cycle improves stability"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Technique 6: Component Building"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Recommendation: Define a moderately complex component, then use the function signature first approach.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Process:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Define component"},{"type":"text","text":" — Data structure or utility class\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Signature first"},{"type":"text","text":" — Parameter types, return types, docstring\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Agree on signature"},{"type":"text","text":" — Review and validate\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Implement"},{"type":"text","text":" — Full component"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Technique 7: Prompt Flows"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Advanced teams design prompt flows—linked steps orchestrated across multiple LLM calls.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example flow:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Step 1: Design schema\n→ Output: Database schema\n\nStep 2: Generate models\n→ Input: Schema from Step 1\n→ Output: SQLAlchemy models\n\nStep 3: Create API endpoints\n→ Input: Models from Step 2\n→ Output: Flask routes\n\nStep 4: Write tests\n→ Input: Endpoints from Step 3\n→ Output: pytest tests"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices for Code Prompts"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Be Explicit About Context and Constraints"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Be explicit about context and constraints: Always specify these explicitly.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What to specify:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Environment"},{"type":"text","text":" — Where code runs\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Libraries"},{"type":"text","text":" — Available dependencies\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Performance"},{"type":"text","text":" — Requirements\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Version"},{"type":"text","text":" — Language/framework"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Explain Why, Not Just What"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Explain why, not just what: Including the purpose and rationale behind code dramatically improves relevance.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Examples:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Bad:"},{"type":"text","text":" \"I need a function to parse dates\"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Good:"},{"type":"text","text":" \"I need a function to parse dates from European format to ISO format for API compatibility\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. Structure Requirements"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Structure your requirements: Numbered lists of specific requirements are processed more reliably than paragraphs of description. Make each requirement atomic and testable.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Template:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Requirements:\n1. Accept input as list of dicts\n2. Filter where age > min_age\n3. Sort by name alphabetically\n4. Return filtered list\n5. Raise ValueError if empty\n6. Raise TypeError if not list"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"4. Iterate on Complex Requests"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Iterate on complex requests: For complex features, break the process into stages (design, implement core logic, add error handling, optimize, etc.) rather than trying to get everything in one generation.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Stages:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Design"},{"type":"text","text":" — Signature/schema\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Core logic"},{"type":"text","text":" — Main functionality\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Error handling"},{"type":"text","text":" — Exceptions\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Optimize"},{"type":"text","text":" — Performance\n5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Test"},{"type":"text","text":" — Validation"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"5. Use Examples"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Use examples: Few-shot examples in your domain help models internalize conventions.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Pattern recognition"},{"type":"text","text":" — Significantly improves\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Style consistency"},{"type":"text","text":" — Coherent output\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Internalize conventions"},{"type":"text","text":" — Better understanding"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"6. Provide Surrounding Context"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"When debugging or extending a project, the LLM needs to see the relevant code. Always give it the surrounding context to guarantee the new code integrates smoothly.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What to include:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Related files"},{"type":"text","text":" — Context for integration\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Function calls"},{"type":"text","text":" — How used\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Data structures"},{"type":"text","text":" — Types/formats"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"7. Test Specific Methods"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Test specific prompt engineering methods to overcome the issues.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Methods to test:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Different models"},{"type":"text","text":" — GPT-4, Claude, Gemini\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Various prompts"},{"type":"text","text":" — Structure variations\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Examples"},{"type":"text","text":" — Few-shot vs zero-shot"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"8. Validate Outputs Through Tests"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Validate outputs through tests.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Process:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Generate code"},{"type":"text","text":" — LLM output\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Run tests"},{"type":"text","text":" — pytest, unittest\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Check linters"},{"type":"text","text":" — Pylint, flake8\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Refine"},{"type":"text","text":" — Based on feedback"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"9. Keep it Focused and Specific"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Make sure to keep it focused and specific.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Do:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Clear"},{"type":"text","text":" — What code does\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Specific"},{"type":"text","text":" — Language, constraints\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":" — Expected output"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Don't:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Vague"},{"type":"text","text":" — Ambiguous requirements\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Overly broad"},{"type":"text","text":" — Entire system\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Missing context"},{"type":"text","text":" — No background"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"10. Track Prompts in Version Control"},{"type":"text","text":" ⭐"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Track prompts in version control.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Reproducibility"},{"type":"text","text":" — Regenerate code\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Collaboration"},{"type":"text","text":" — Share patterns\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Iteration"},{"type":"text","text":" — Improve over time"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Summary"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prompting for code"},{"type":"text","text":" requires clarity, specificity, and context to generate correct, readable, testable, and performant code:"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key goals:"},{"type":"text","text":" Correctness, readability, testability, performance"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"6 essential components:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Role and context"},{"type":"text","text":" — Senior engineer, standards\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Task description"},{"type":"text","text":" — What to build\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Input/Output spec"},{"type":"text","text":" — Parameters, returns, errors\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Constraints"},{"type":"text","text":" — Language, libraries, performance\n5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Testing requirements"},{"type":"text","text":" — Unit tests, examples\n6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Comments and style"},{"type":"text","text":" — PEP 8, type hints, docstrings"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"7 code generation templates:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Basic function"},{"type":"text","text":" — Single purpose function\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Complex component (two-step)"},{"type":"text","text":" — Signature first, then implement\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Code review"},{"type":"text","text":" — Issues, fixes, severity\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Debugging"},{"type":"text","text":" — Code + traceback\n5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Refactoring"},{"type":"text","text":" — Performance, readability\n6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Code translation"},{"type":"text","text":" — Language conversion\n7. "},{"type":"text","marks":[{"type":"bold"}],"text":"Prompt flows"},{"type":"text","text":" — Multi-step orchestration"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"7 advanced techniques:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Show, don't just tell"},{"type":"text","text":" — Examples improve aim\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Chain-of-thought"},{"type":"text","text":" — Explain strategy first\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Leading words"},{"type":"text","text":" — Nudge toward pattern\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Mental model transformation"},{"type":"text","text":" — Analogy/visualization\n5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Iterative refinement"},{"type":"text","text":" — Generate, review, test, refine\n6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Component building"},{"type":"text","text":" — Define, signature, implement\n7. "},{"type":"text","marks":[{"type":"bold"}],"text":"Prompt flows"},{"type":"text","text":" — Linked multi-call steps"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"10 best practices:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Be explicit"},{"type":"text","text":" — Context, constraints, environment\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Explain why"},{"type":"text","text":" — Purpose and rationale\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Structure requirements"},{"type":"text","text":" — Numbered, atomic, testable\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Iterate on complex"},{"type":"text","text":" — Break into stages\n5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Use examples"},{"type":"text","text":" — Few-shot patterns\n6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Provide surrounding context"},{"type":"text","text":" — Integration smoothness\n7. "},{"type":"text","marks":[{"type":"bold"}],"text":"Test specific methods"},{"type":"text","text":" — Evaluate variations\n8. "},{"type":"text","marks":[{"type":"bold"}],"text":"Validate through tests"},{"type":"text","text":" — Run, lint, refine\n9. "},{"type":"text","marks":[{"type":"bold"}],"text":"Keep focused and specific"},{"type":"text","text":" — Clear, concise\n10. "},{"type":"text","marks":[{"type":"bold"}],"text":"Track in version control"},{"type":"text","text":" — Reproducibility"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"Effective code prompts contain three key elements: Context, Specification, and Constraints.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"You don't have to get everything into your first prompt. Try starting with a basic question and building from there.\""}]}]}}
