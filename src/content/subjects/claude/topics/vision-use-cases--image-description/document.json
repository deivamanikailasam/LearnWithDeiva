tent":[{"type":"text","text":"Why it matters"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Image tagging"},{"type":"text","text":": Create descriptive metadata to improve content discoverability in repositories"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Accessibility"},{"type":"text","text":": Generate captions for visually impaired users"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Automation"},{"type":"text","text":": Enable bots to analyze customer-uploaded images (product recognition, issue reporting)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Insight extraction"},{"type":"text","text":": Answer questions about charts, documents, screenshots without manual reading"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How to use: Image Description"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Basic prompt:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"Describe this image in detail.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Expected output format:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"The image shows a group of 10 dogs of various breeds sitting together in a grassy field with flowers in the background.\n\nThe breeds appear to include Border Collies, an Australian Shepherd, and a Terrier mix, though I can't say for certain.\n\nThe dogs have different colored coats including black, white, brown, and gray. They are all attentively facing the camera, likely posing for the photo. [web:20]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best practices for descriptions:"},{"type":"text","text":"\n- Be specific about what you want: \"Describe the main objects, colors, and setting\"\n- Ask for structured output: \"List all detected elements with descriptions\"\n- Use role assignment for accuracy: \"You are a professional photographer describing this scene\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How to use: Visual Q&A"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example prompts:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"What is the restaurant name on this receipt?\"\n\"What's the difference between these two numbers?\"\n\"How many dogs are in this image?\"\n\"Read the speedometer value from this image.\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example outputs:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"The name of the restaurant is The Breakfast Club and the total amount on the receipt is $78.86. [web:20]\n\nThe difference between North America's net sales for the twelve months ended December 31, 2023 ($352,828) and December 31, 2022 ($315,880) is $36,948. [web:20]\n\nThe speedometer in the image is showing a speed of 140 kilometers/hour (or about 87 miles/hour). [web:20]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Prompt Engineering Techniques"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Technique"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"How It Works"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Example"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Role assignment"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Fix hallucination by assigning expertise"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"You are a UI designer comparing these versions\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step-by-step reasoning"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Force Claude to scan systematically"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"I'll visually scan left to right, focusing on each dog\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Few-shot examples"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Show examples to improve accuracy"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Provide speedometer reading examples to learn the format"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colsp