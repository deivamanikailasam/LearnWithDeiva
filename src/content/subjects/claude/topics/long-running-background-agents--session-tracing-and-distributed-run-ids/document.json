{"format":"tiptap/v1","updatedAt":"2026-06-22T04:49:28.063Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Based on the official documentation and industry best practices for long-running agent workflows, "},{"type":"text","marks":[{"type":"bold"}],"text":"\"Session tracing and distributed run IDs\""},{"type":"text","text":" is the observability pattern that "},{"type":"text","marks":[{"type":"bold"}],"text":"assigns unique identifiers to every agent execution and propagates them across all services, enabling you to trace an agent's complete lifecycle from start to finish—even across async background tasks, checkpoints, and service boundaries"},{"type":"text","text":" — turning debugging from \"what happened?\" to \"here's exactly where and why it failed.\""}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","text":"The pattern combines "},{"type":"text","marks":[{"type":"bold"}],"text":"two complementary mechanisms"},{"type":"text","text":":"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Mechanism"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Purpose"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Session Tracing"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Record the sequence of steps, tool calls, and decisions in an agent run"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Distributed Run IDs"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Unique identifier that follows a request as it flows through your system across services"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Core Goal"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tracing an agent run means you can answer three questions quickly"},{"type":"text","text":":"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What happened?"},{"type":"text","text":" The sequence of steps, tool calls and decisions"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why did it happen?"},{"type":"text","text":" The versioned configuration and policy that drove choices"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Can we reproduce it?"},{"type":"text","text":" Safe replay of the run inputs and outcomes"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Run ID Model"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Stable ID Hierarchy"}]},{"type":"paragraph","content":[{"type":"text","text":"Define identifiers that you can use across logs, traces and dashboards:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"ID Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Purpose"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"request_id"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Unique per inbound request"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"run_id"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Unique per agent execution (can differ from "},{"type":"text","marks":[{"type":"code"}],"text":"request_id"},{"type":"text","text":" if fork/retry)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"step_id"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Monotonic step counter for the run"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_call_id"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Unique per tool invocation"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Purpose"},{"type":"text","text":": These IDs become the backbone for reliability metrics and incident analysis."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Trace ID in Distributed Systems"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"A trace ID is a unique identifier that follows a request as it flows through your system"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"User request → Service A → Service B → Agent → Tool → Database\n    ↓\nSame trace_id propagates across all services\n    ↓\nReconstruct full request lifecycle"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key insight"},{"type":"text","text":": \"In distributed systems, trace IDs enable you to correlate operations across multiple services and reconstruct the full request lifecycle\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Distributed Tracing"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Hard Part: Trace Context Propagation"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"\"The hardest part of distributed tracing is not instrumentation — it's trace context propagation across service boundaries\""},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"How Propagation Works"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"OpenTelemetry uses W3C Trace Context standard:\n    ↓\ntrace parent header carries traceId and spanId from one service to the next\n    ↓\nWhen trace parent header is missing (or not forwarded), each service starts a new trace\n    ↓\nWaterfall disappears (disconnected fragments)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Most tracing issues"},{"type":"text","text":": \"Not caused by missing instrumentation, but by missing propagation\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Span Taxonomy for Agent Runs"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Represent each step as a span"},{"type":"text","text":" with practical span taxonomy:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Span Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"What It Represents"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"agent.plan"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Planning step, route selection"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"agent.retrieve"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"RAG retrieval, ranking, filtering"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"agent.model"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"LLM call, tokens, latency"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"agent.tool"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tool call, inputs, outputs, errors"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"agent.validate"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Schema validation, policy checks"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key"},{"type":"text","text":": Use consistent attribute names so you can aggregate across tools and routes."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Implementation in Agent Workflows"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Service-Level Propagation"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# OpenTelemetry: inject/extract pattern\n# Service A (producer)\nfrom opentelemetry.trace import set_span_in_context\nfrom opentelemetry.exporter.otlp.proto.http.trace_exporter import OTLPSpanExporter\n\n# Create trace context\nspan = tracer.start_span(\"agent.plan\")\ncontext = set_span_in_context(span)\n\n# Inject trace parent into outgoing request\nheaders = {}\ntext_encoder.inject(headers, context)\n\n# Service B (consumer)\n# Extract trace context from incoming request\ncontext = text_encoder.extract(headers)\nspan = tracer.start_span(\"agent.tool\", context=context)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Result"},{"type":"text","text":": \"All spans across the three services share the same "},{"type":"text","marks":[{"type":"code"}],"text":"traceId"},{"type":"text","text":", forming a single trace instead of disconnected fragments\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Standalone Execution (No HTTP)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Agentuity: standalone code gets same infrastructure\nctx = createAgentContext()\n\n# ctx.run() executes agent with full infrastructure support:\n# - Tracing: OpenTelemetry spans with proper hierarchy\n# - Sessions: Automatic save/restore via providers\n# - Threads: Conversation state management\n# - Storage: Full access to kv, stream, vector\n# - Background tasks: waitUntil support for fire-and-forget work\n# - Session events: Start/complete events for observability\n\nctx.run(agent, input)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key insight"},{"type":"text","text":": \"Each "},{"type":"text","marks":[{"type":"code"}],"text":"ctx.run()"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"code"}],"text":"ctx.invoke()"},{"type":"text","text":" call provides the same infrastructure as HTTP request handlers\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Async Work with Trace Continuity"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Proactive messaging (async work)\n# Extracted context is passed through context.with() so spans still join the right trace\n\nasync def background_task(ctx, input):\n    # Continue with inherited trace context\n    await ctx.run(agent, input)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Purpose"},{"type":"text","text":": \"Without trace continuity, these workflows become difficult to debug and reason about\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Benefits for Long-Running Agents"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What Tracing Enables"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Case"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"How Tracing Helps"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Find slow steps"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Reduce latency by identifying bottlenecks"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Find repetitive tool calls"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Improve caching or planning"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Find validation failures"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Improve tool contracts"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Correlate complaints"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Map to specific versions and routes"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Incident analysis"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Replay inputs and outcomes"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key"},{"type":"text","text":": \"Tracing is not only for incidents. It also drives improvement\"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Session Persistence"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Agent Sessions persist conversation and event history\n    ↓\nPin to custom session ID that maps to your own CRM or DB record\n    ↓\nTrack agent lifecycle across multiple invocations"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Purpose"},{"type":"text","text":": \"You can pin them to a custom session ID that maps to your own CRM or DB record, so the agent's context persists across multiple interactions\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Version Metadata"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Attach Version Metadata to Every Run"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Most incidents are caused by change. Make change visible by recording version metadata on each run"},{"type":"text","text":":"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Metadata"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Source"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"prompt_version"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"From your prompt registry"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"policy_version"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Which policy module or ruleset applied"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"tool_contract_version"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"For tools and schemas"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"route_config_version"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Routing and fallback config"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Result"},{"type":"text","text":": \"This is what turns debugging into 'compare before and after' instead of guesswork\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Data Capture for Replay"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Capture Minimum Data Needed for Safe Replay"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Replay is powerful, but it can also create privacy and security risk. Store only what you need"},{"type":"text","text":":"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Normalized user input"},{"type":"text","text":" (with PII redacted where required)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tool call arguments and results"},{"type":"text","text":" (with sensitive fields masked)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Retrieval IDs and snippets"},{"type":"text","text":" (not entire documents, where feasible)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Model route and parameter settings"},{"type":"text","text":" (temperature, max tokens)"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best practice"},{"type":"text","text":": \"Apply data minimisation and retention policies\"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Decision Logging"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Traces vs. Decision Logs"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Traces tell you what happened. Decision logs tell you why it was allowed"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"For agentic systems, you often need both:\n    ↓\nRecord approvals and policy blocks\n    ↓\nRecord key routing decisions and fallbacks\n    ↓\nKeep audit trails for sensitive tool actions"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Purpose"},{"type":"text","text":": Create audit trails for compliance and incident investigation."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of session tracing and distributed run IDs like "},{"type":"text","marks":[{"type":"bold"}],"text":"airline tracking numbers"},{"type":"text","text":": when you book a flight (agent request), you get a unique tracking number (run ID). Every time you check-in, board, or fly (service A → service B → agent → tool), the same tracking number is recorded. If something goes wrong (flight delayed), you can look up the tracking number and see the entire journey: where it departed, where it stopped, where it was delayed. Without the tracking number, you'd have to guess which flight you were talking about."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Tracing = answer what happened, why it happened, can we reproduce it"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Run ID model: request_id (per request), run_id (per execution), step_id (monotonic counter), tool_call_id (per tool)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Trace ID: unique identifier that follows request across services, correlates operations"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Hardest part: trace context propagation across service boundaries (not instrumentation)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Propagation: W3C Trace Context standard - trace parent header carries traceId and spanId"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Missing propagation = disconnected fragments (most tracing issues)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Span taxonomy: agent.plan, agent.retrieve, agent.model, agent.tool, agent.validate"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Async work: use context.with() so spans still join the right trace"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Standalone execution: ctx.run() provides same infrastructure as HTTP (tracing, sessions, storage)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Version metadata: prompt_version, policy_version, tool_contract_version, route_config_version"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Replay: capture minimum data (redacted input, masked tool args, retrieval snippets, model params)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Traces tell what happened, decision logs tell why it was allowed"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Benefits: find slow steps, repetitive calls, validation failures, correlate complaints"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"\"Tracing agent runs with run IDs, spans for tools and retrieval, version metadata, and safe replay for debugging incidents\"."}]}]}}
