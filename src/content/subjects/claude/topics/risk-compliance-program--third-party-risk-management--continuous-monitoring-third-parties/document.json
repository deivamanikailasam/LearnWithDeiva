      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "API Health Monitoring"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Track the live health of the Anthropic API to detect degradation before it impacts production workloads:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic, time, statistics\nfrom datetime import datetime, timezone\nfrom collections import deque\nfrom pathlib import Path\nimport json\n\nclient = anthropic.Anthropic()\n\nclass APIHealthMonitor:\n    \"\"\"Track latency and error rate for the Anthropic API.\"\"\"\n\n    def __init__(self, window_size: int = 100):\n        self._latencies: deque[float] = deque(maxlen=window_size)\n        self._errors: deque[bool] = deque(maxlen=window_size)\n        self._log = Path(\"evidence/tprm/api_health.jsonl\")\n        self._log.parent.mkdir(parents=True, exist_ok=True)\n\n    def probe(self) -> dict:\n        \"\"\"Send a minimal probe request and record result.\"\"\"\n        start = time.monotonic()\n        error = None\n        status = \"ok\"\n        try:\n            client.messages.create(\n                model=\"claude-haiku-4-5-20251001\",\n                max_tokens=10,\n                messages=[{\"role\": \"user\", \"content\": \"ping\"}],\n            )\n        except Exception as exc:\n            error = str(exc)\n            status = \"error\"\n\n        latency_ms = round((time.monotonic() - start) * 1000, 1)\n        self._latencies.append(latency_ms)\n        self._errors.append(status == \"error\")\n\n        record = {\n            \"ts_utc\": datetime.now(timezone.utc).isoformat(),\n            \"latency_ms\": latency_ms,\n            \"status\": status,\n            \"error\": error,\n            \"p95_latency_ms\": self._p95(),\n            \"error_rate_pct\": self._error_rate(),\n        }\n        with self._log.open(\"a\") as f:\n            f.write(json.dumps(record) + \"\\n\")\n        return record\n\n    def _p95(self) -> float:\n        if not self._latencies:\n            return 0.0\n        sorted_l = sorted(self._latencies)\n        idx = int(len(sorted_l) * 0.95)\n        return sorted_l[min(idx, len(sorted_l) - 1)]\n\n    def _error_rate(self) -> float:\n        if not self._errors:\n            return 0.0\n        return sum(self._errors) / len(self._errors) * 100\n\n    def health_summary(self) -> dict:\n        return {\n            \"p50_latency_ms\": round(statistics.median(self._latencies), 1) if self._latencies else 0,\n            \"p95_latency_ms\": round(self._p95(), 1),\n            \"error_rate_pct\": round(self._error_rate(), 2),\n            \"sample_count\": len(self._latencies),\n        }\n\n# Run hourly probe; alert if p95 > 5000ms or error_rate > 1%\nmonitor = APIHealthMonitor()\nresult = monitor.probe()\nsummary = monitor.health_summary()\nif summary[\"p95_latency_ms\"] > 5000 or summary[\"error_rate_pct\"] > 1:\n    print(f\"[TPRM ALERT] API health degraded: {summary}\")\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Security Advisory Monitoring"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "CVEs and security advisories affecting the Anthropic API infrastructure require a triage workflow to determine whether firm data is at risk:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import json\nfrom dataclasses import dataclass\nfrom datetime import datetime, timezone\nfrom pathlib import Path\n\nADVISORY_LOG = Path(\"evidence/tprm/security_advisories.jsonl\")\nADVISORY_LOG.parent.mkdir(parents=True, exist_ok=True)\n\n@dataclass\nclass SecurityAdvisory:\n    source: str         # \"anthropic_status\", \"cve_db\", \"news\"\n    title: str\n    severity: str       # \"critical\" | \"high\" | \"medium\" | \"low\"\n    published_date: str # ISO date\n    affects_api: bool\n    affects_data: bool  # could firm data be exposed?\n    firm_action: str    # \"monitor\" | \"remediate\" | \"escalate\"\n    notes: str = \"\"\n\ndef triage_advisory(advisory: SecurityAdvisory) -> str:\n    \"\"\"\n    Return the recommended triage action based on advisory characteristics.\n    Critical + data exposure = escalate to CISO immediately.\n    High + API impact = remediate within 48h.\n    Everything else = monitor in next weekly review.\n    \"\"\"\n    if advisory.severity == \"critical\" and advisory.affects_data:\n        return \"ESCALATE: notify CISO within 2h; consider API suspension\"\n    if advisory.severity in (\"critical\", \"high\") and advisory.affects_api:\n        return \"REMEDIATE: assess impact within 48h; test fallback provider\"\n    if advisory.severity == \"high\":\n        return \"REMEDIATE: review at next weekly TPRM meeting\"\n    return \"MONITOR: log and include in monthly TPRM report\"\n\ndef log_advisory(advisory: SecurityAdvisory) -> None:\n    record = {\n        \"logged_utc\": datetime.now(timezone.utc).isoformat(),\n        \"triage_action\": triage_advisory(advisory),\n        **advisory.__dict__,\n    }\n    with ADVISORY_LOG.open(\"a\") as f:\n        f.write(json.dumps(record) + \"\\n\")\n    print(f\"[{record['triage_action'][:8]}] {advisory.title}\")\n\n# Example\nlog_advisory(SecurityAdvisory(\n    source=\"anthropic_status\",\n    title=\"Elevated API error rate affecting inference endpoints (resolved)\",\n    severity=\"medium\",\n    published_date=\"2026-06-15\",\n    affects_api=True,\n    affects_data=False,\n    firm_action=\"monitor\",\n    notes=\"Incident resolved within 2h; firm SLA not breached. No evidence of data exposure.\",\n))\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
