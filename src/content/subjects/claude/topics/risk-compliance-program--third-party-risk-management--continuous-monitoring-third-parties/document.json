            "type": "text",
            "text": "Model Change Monitoring"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Anthropic releases new model versions and deprecates old ones on a rolling basis. For regulated deployments, an unplanned model version change can invalidate a MRM validation without the firm's knowledge."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Version Pinning Verification"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\nfrom pathlib import Path\nimport json\n\nclient = anthropic.Anthropic()\n\nEXPECTED_PINS: dict[str, str] = {\n    \"MDL-2026-047\": \"claude-opus-4-8-20251101\",\n    \"MDL-2026-052\": \"claude-haiku-4-5-20251001\",\n}\n\ndef verify_model_pins() -> list[dict]:\n    \"\"\"\n    Confirm that each production deployment is using its registered model version.\n    Sends a probe to verify the model header in the API response.\n    Returns a list of mismatches.\n    \"\"\"\n    mismatches = []\n    for record_id, expected_model in EXPECTED_PINS.items():\n        try:\n            resp = client.messages.create(\n                model=expected_model,\n                max_tokens=5,\n                messages=[{\"role\": \"user\", \"content\": \"ok\"}],\n            )\n            # The API echoes back the model used in the response object\n            actual_model = resp.model\n            if actual_model != expected_model:\n                mismatches.append({\n                    \"record_id\": record_id,\n                    \"expected\": expected_model,\n                    \"actual\": actual_model,\n                    \"action\": \"UPDATE_INVENTORY: model resolved to a different version\",\n                })\n        except anthropic.BadRequestError as exc:\n            if \"model\" in str(exc).lower():\n                mismatches.append({\n                    \"record_id\": record_id,\n                    \"expected\": expected_model,\n                    \"actual\": \"UNKNOWN\",\n                    \"action\": \"INVESTIGATE: model ID rejected by API — may be deprecated\",\n                })\n    return mismatches\n\nmismatches = verify_model_pins()\nif mismatches:\n    print(f\"[TPRM] Model pin verification FAILED — {len(mismatches)} mismatch(es):\")\n    for m in mismatches:\n        print(f\"  {m['record_id']}: {m['expected']} -> {m['actual']} | {m['action']}\")\nelse:\n    print(\"[TPRM] All model pins verified.\")\n"
          }
        ]
      },
