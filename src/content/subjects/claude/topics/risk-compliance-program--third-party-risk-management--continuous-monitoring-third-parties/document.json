        "content": [
          {
            "type": "text",
            "text": "Automated Compliance Calendar"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass, field\nfrom datetime import date, timedelta\nimport json\nfrom pathlib import Path\n\n@dataclass\nclass ComplianceDate:\n    vendor: str\n    event_type: str       # \"soc2_expiry\" | \"iso_expiry\" | \"dpa_review\" | \"reassessment\"\n    due_date: str         # ISO date\n    alert_days_before: int = 60\n    assigned_to: str = \"TPRM Analyst\"\n    status: str = \"pending\"   # \"pending\" | \"in_progress\" | \"complete\"\n\ndef upcoming_alerts(calendar: list[ComplianceDate], horizon_days: int = 90) -> list[dict]:\n    today = date.today()\n    alerts = []\n    for item in calendar:\n        due = date.fromisoformat(item.due_date)\n        alert_date = due - timedelta(days=item.alert_days_before)\n        days_until_due = (due - today).days\n        days_until_alert = (alert_date - today).days\n\n        if item.status == \"pending\" and days_until_due <= horizon_days:\n            alerts.append({\n                \"vendor\": item.vendor,\n                \"event\": item.event_type,\n                \"due_date\": item.due_date,\n                \"days_until_due\": days_until_due,\n                \"alert_fired\": days_until_alert <= 0,\n                \"assigned_to\": item.assigned_to,\n                \"urgency\": \"critical\" if days_until_due <= 14 else (\"high\" if days_until_due <= 30 else \"medium\"),\n            })\n    return sorted(alerts, key=lambda x: x[\"days_until_due\"])\n\ncalendar = [\n    ComplianceDate(\"Anthropic\", \"soc2_expiry\", \"2026-09-30\", alert_days_before=60),\n    ComplianceDate(\"Anthropic\", \"dpa_review\", \"2026-12-31\", alert_days_before=30),\n    ComplianceDate(\"RAG Platform Vendor\", \"reassessment\", \"2026-10-15\", alert_days_before=60),\n    ComplianceDate(\"RAG Platform Vendor\", \"soc2_expiry\", \"2026-08-15\", alert_days_before=60),\n]\n\nalerts = upcoming_alerts(calendar, horizon_days=120)\nfor a in alerts:\n    flag = \"[ALERT]\" if a[\"alert_fired\"] else \"[UPCOMING]\"\n    print(f\"{flag} {a['vendor']} — {a['event']} due {a['due_date']} ({a['days_until_due']}d) | {a['urgency']}\")\n"
          }
        ]
      },
