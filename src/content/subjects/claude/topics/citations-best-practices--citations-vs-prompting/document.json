tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cost"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Lower"},{"type":"text","text":": fewer output tokens"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Higher"},{"type":"text","text":": more tokens from quotes"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Robustness"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Reliable"},{"type":"text","text":": built-in system"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fragile"},{"type":"text","text":": prompt breaks easily"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Traceability"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Precise"},{"type":"text","text":": page/char/block indices"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Approximate"},{"type":"text","text":": numbered references"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Advantages of Citations:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"The built-in citation flow is intended to be more reliable than prompt-only citation patterns and can reduce the need for quoted output tokens.\""}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"API Citations (Built-in)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How it works"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import anthropic\n\nclient = anthropic.Anthropic()\n\nresponse = client.messages.create(\n    model=\"claude-3-5-sonnet-20241022\",\n    messages=[{\n        \"role\": \"user\",\n        \"content\": [\n            {\n                \"type\": \"document\",\n                \"source\": {\n                    \"type\": \"base64\",\n                    \"media_type\": \"application/pdf\",\n                    \"data\": encoded_pdf\n                },\n                \"citations\": {  # ← Enable Citations\n                    \"enabled\": True\n                }\n            },\n            {\n                \"type\": \"text\",\n                \"text\": \"What were the key findings?\"\n            }\n        ]\n    }]\n)\n\n# Response includes:\nresponse.content[0].text  # \"The methodology used a randomized controlled trial design [p. 45].\"\nresponse.citations        # [{\"cited_text\": \"...\", \"start_page_number\": 45, ...}]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key benefits:"},{"type":"text","text":"\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Document grounding"},{"type":"text","text":": Claude answers from supplied documents, not parametric memory\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Traceable references"},{"type":"text","text":": Citations point to specific source spans/pages/blocks\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Document-aware chunking"},{"type":"text","text":": Plain text = char locations, PDF = page numbers\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Structured responses"},{"type":"text","text":": Citations returned alongside text blocks\n5. "},{"type":"text","marks":[{"type":"bold"}],"text":"RAG-friendly"},{"type":"text","text":": Pairs naturally with retrieval systems"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output format:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"\"The methodology used a randomized controlled trial design [p. 45].\"\n\nCitations metadata:\n{\n  \"cited_text\": \"The methodology used a randomized controlled trial design.\",\n  \"start_page_number\": 45,\n  \"end_page_number\": 45,\n  \"document_title\": \"research_paper.pdf\"\n}"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Prompted Quotes (Manual)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How it works"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Complex prompt template:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"You are an expert research assistant. Here is a document you will answer questions about:\n\nFirst, find the quotes from the document that are most relevant to answering the question,\nand then print them in numbered order. Quotes should be relatively short.\n\nIf there are no relevant quotes, write \"No relevant quotes\" instead.\n\nThen, answer the question, starting with \"Answer:\".\n\nDo not include or reference quoted content verbatim in the answer.\nDon't say \"According to Quote  [docs.claude](https://docs.claude.com/en/resources/prompt-library/cite-your-sources)\" when answering.\nInstead make references to quotes relevant to each section of the answer solely by adding\ntheir bracketed numbers at the end of relevant sentences.\n\nThus, the format of your overall response should look like what's shown between the\n<example></example> tags.\n\n<example>\nQuotes:\n [docs.claude](https://docs.claude.com/en/resources/prompt-library/cite-your-sources) \"Company X reported revenue of $12 million in 2021.\"\n [promptlayer](https://www.promptlayer.com/glossary/claude-citations/) \"Almost 90% of revenue came from widget sales, with gadget sales making up the remaining 10%.\"\n\nAnswer:\nCompany X earned $12 million.  [docs.claude](https://docs.claude.com/en/resources/prompt-library/cite-your-sources)\nAlmost 90% of it was from widget sales.  [promptlayer](https://www.promptlayer.com/glossary/claude-citations/)\n</example>"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output format:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Quotes:\n [docs.claude](https://docs.claude.com/en/resources/prompt-library/cite-your-sources) \"Company X reported revenue of $12 million in 2021.\"\n [promptlayer](https://www.promptlayer.com/glossary/claude-citations/) \"Almost 90% of revenue came from widget sales, with gadget sales making up the remaining 10%.\"\n\nAnswer:\nCompany X earned $12 million.  [docs.claude](https://docs.claude.com/en/resources/prompt-library/cite-your-sources)\nAlmost 90% of it was from widget sales.  [promptlayer](https://www.promptlayer.com/glossary/claude-citations/)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problems:"},{"type":"text","text":"\n- Requires verbose prompt with extensive formatting rules\n- Must output full quotes (increases tokens)\n- Easy to break formatting\n- Inconsistent citation quality\n- Can hallucinate general knowledge"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Differences"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Token Usage"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Approach"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tokens"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"API Citations"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Text only: \"The methodology used a randomized controlled trial design [p. 45].\""}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prompted Quotes"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Text + quotes: Must output full quote text + reference"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Impact:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Prompt-based techniques often require Claude to output full quotes from the source document it intends to cite. This increases output tokens.\""}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Cost Savings"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Approach"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Cost"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"API Citations"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Lower: fewer output tokens, no quotes"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prompted Quotes"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Higher: more tokens from quotes"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Advantage:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Cost savings: If your prompt-based approach asks Claude to output full quotes before answering, that increases output tokens and costs. Citations reduces the need for those quoted output tokens.\""}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Citation Quality"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Approach"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Quality"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"API Citations"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Higher quality"},{"type":"text","text":": guaranteed valid citations"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prompted Quotes"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Lower quality"},{"type":"text","text":": fragile, inconsistent"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Result:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Using the API citation feature will improve citation quality, ensure that all returned citations are valid.\""}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Fabrication Risk"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Approach"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Risk"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"API Citations"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Low"},{"type":"text","text":": enforced by system"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prompted Quotes"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"High"},{"type":"text","text":": can hallucinate/fabricate"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"If you request sources, the model will generate them, but there's a high chance they could be fabricated due to its design, which compels it to produce relevant tokens based on the inquiry.\""}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Traceability"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Approach"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Precision"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"API Citations"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Precise"},{"type":"text","text":": page numbers, char indices, block indices"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prompted Quotes"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Approximate"},{"type":"text","text":": numbered references,"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Advantage:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"Returned citations point to specific source spans, page numbers, or content blocks.\""}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practice Recommendation"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use API Citations:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Recommended\nresponse = client.messages.create(\n    messages=[{\n        \"content\": [\n            {\n                \"type\": \"document\",\n                \"citations\": {\"enabled\": True}  # ← Built-in Citations\n            }\n        ]\n    }]\n)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Don't use Prompted Quotes:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ❌ Avoid\nresponse = client.messages.create(\n    messages=[{\n        \"content\": [\n            {\n                \"type\": \"text\",\n                \"text\": \"\"\"\n                First find the quotes from the document...\n                [complex prompt with formatting rules]\n                \"\"\"\n            }\n        ]\n    }]\n)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"\"We recommend using the citation feature built into the API instead of a prompt-based approach. Using the API citation feature will improve citation quality, ensure that all returned citations are valid, and potentially reduce the number of needed output tokens.\""}]}]},{"type":"paragraph"}]}}
