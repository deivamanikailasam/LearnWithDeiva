      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Testing on a simulator. "
                  },
                  {
                    "type": "text",
                    "text": "The iOS Simulator and Android Emulator do not receive real push notifications. Always test push flows on a physical device. Use "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "Device.isDevice"
                  },
                  {
                    "type": "text",
                    "text": " to skip registration gracefully in the simulator."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Stale tokens not cleaned up. "
                  },
                  {
                    "type": "text",
                    "text": "Tokens expire when users reinstall the app or revoke permissions. If you keep sending to stale tokens, your error rate inflates and Expo may throttle your account. Process "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "DeviceNotRegistered"
                  },
                  {
                    "type": "text",
                    "text": " receipts daily."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Putting Claude output in the push payload. "
                  },
                  {
                    "type": "text",
                    "text": "APNs and FCM impose a 4 KB payload limit. Claude responses are often much larger. Keep the push payload minimal (title, body excerpt, jobId) and let the app fetch the full result after the user taps."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "No permission check before registration. "
                  },
                  {
                    "type": "text",
                    "text": "Calling "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "getExpoPushTokenAsync()"
                  },
                  {
                    "type": "text",
                    "text": " without checking permission status first will throw on Android 13+. Always call "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "requestPermissionsAsync()"
                  },
                  {
                    "type": "text",
                    "text": " and verify "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "status === 'granted'"
                  },
                  {
                    "type": "text",
                    "text": " before proceeding."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Missing EAS projectId. "
                  },
                  {
                    "type": "text",
                    "text": "Since SDK 46, "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "getExpoPushTokenAsync()"
                  },
                  {
                    "type": "text",
                    "text": " requires an explicit "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "projectId"
                  },
                  {
                    "type": "text",
                    "text": ". Without it the call fails with an opaque error. Always pass "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "{ projectId: Constants.expoConfig?.extra?.eas?.projectId }"
                  },
                  {
                    "type": "text",
                    "text": " explicitly."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Use an async job pattern for long Claude tasks: submit \u2192 get jobId \u2192 background worker runs Claude \u2192 push notifies user \u2192 app fetches full result."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Register for push tokens at app startup using "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "expo-notifications"
                  },
                  {
                    "type": "text",
                    "text": " and store "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "(userId, pushToken)"
                  },
                  {
                    "type": "text",
                    "text": " on your backend."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Send pushes from the backend worker using "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "expo-server-sdk"
                  },
                  {
                    "type": "text",
                    "text": " after Claude finishes. Keep the payload small (title + jobId); fetch the full result after tap."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Handle notification taps with "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "addNotificationResponseReceivedListener"
                  },
                  {
                    "type": "text",
                    "text": " for foreground/background, and "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "getLastNotificationResponseAsync()"
                  },
                  {
                    "type": "text",
                    "text": " for cold-start."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Poll delivery receipts to catch stale tokens and remove them from your database. Implement a polling fallback in the Results screen for users who miss the push."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}