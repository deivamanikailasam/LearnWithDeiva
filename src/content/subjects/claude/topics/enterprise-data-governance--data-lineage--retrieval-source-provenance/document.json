      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def retract_source(source_id: str, provenance_log: str = \"logs/rag_provenance.jsonl\"):\n    \"\"\"Remove source from vector store and flag dependent responses.\"\"\"\n    # 1. Delete from vector store\n    results = collection.get(where={\"source_id\": source_id})\n    if results[\"ids\"]:\n        collection.delete(ids=results[\"ids\"])\n        print(f\"Deleted {len(results['ids'])} chunks for source {source_id}\")\n\n    # 2. Find dependent responses in provenance log\n    affected_responses = []\n    for line in Path(provenance_log).read_text().splitlines():\n        record = json.loads(line)\n        if source_id in record.get(\"source_ids_used\", []):\n            affected_responses.append(record[\"response_id\"])\n\n    # 3. Flag them\n    flag_store = Path(\"logs/retracted_responses.jsonl\")\n    with flag_store.open(\"a\") as f:\n        for resp_id in affected_responses:\n            f.write(json.dumps({\n                \"response_id\": resp_id,\n                \"retracted_source\": source_id,\n                \"retracted_at\": datetime.now(timezone.utc).isoformat(),\n            }) + \"\\n\")\n\n    print(f\"{len(affected_responses)} responses flagged for retraction review\")\n    return affected_responses\n"
          }
        ]
