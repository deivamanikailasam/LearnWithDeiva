        "content": [
          {
            "type": "text",
            "text": "class Counter {\n  private count = 0; // internal state \u2014 hidden from consumers\n\n  increment(): void { this.count++; }\n  decrement(): void { this.count--; }\n  value(): number { return this.count; }\n}\n\nclass ResettableCounter extends Counter {\n  reset(): void {\n    // this.count = 0; // Error: Property 'count' is private\n    // Must use the public API:\n    while (this.value() > 0) { this.decrement(); }\n  }\n}\n"
          }
        ]
