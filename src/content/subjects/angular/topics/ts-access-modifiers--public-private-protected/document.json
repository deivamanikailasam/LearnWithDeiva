      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Default to private. Promote to protected only when a subclass needs it. Make public only what consumers genuinely need. Restrict access as much as the design allows."
              }
            ]
          }
        ]
