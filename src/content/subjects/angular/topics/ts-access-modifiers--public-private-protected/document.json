        "content": [
          {
            "type": "text",
            "text": "The private Modifier"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A "
          },
          {
            "type": "text",
            "text": "private",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " member is accessible only within the class body that declares it. Subclasses cannot see it \u2014 this forces subclasses to use the public API, preventing tight coupling to internal state."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
