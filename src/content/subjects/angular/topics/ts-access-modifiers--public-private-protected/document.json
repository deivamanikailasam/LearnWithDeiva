      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "class Token {\n  #secret: string;         // ECMAScript private field\n\n  constructor(secret: string) { this.#secret = secret; }\n\n  verify(input: string): boolean { return input === this.#secret; }\n}\n\nconst tok = new Token('xyz');\n// (tok as any).#secret  // SyntaxError \u2014 not reachable even via cast\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "The protected Modifier"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A "
          },
          {
            "type": "text",
            "text": "protected",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " member is accessible within the class and in any class that extends it, but not from outside the hierarchy. This is the right choice for implementation details that subclasses legitimately need to customise."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "abstract class HttpService {\n  protected baseUrl = 'https://api.example.com';\n\n  // Subclasses use baseUrl; consumers don't see it\n  protected get<T>(path: string): Observable<T> {\n    return this.http.get<T>(\\`\\${this.baseUrl}\\${path}\\`);\n  }\n\n  constructor(protected readonly http: HttpClient) {}\n}\n\n@Injectable({ providedIn: 'root' })\nclass UserService extends HttpService {\n  getUsers(): Observable<User[]> {\n    return this.get<User[]>('/users'); // accesses protected method\n  }\n}\n\n// Outside:\n// new UserService(http).baseUrl;  // Error: protected\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Constructor Parameter Shorthand"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "TypeScript lets you declare and assign class fields directly in the constructor signature by adding an access modifier. This removes the boilerplate of separate field declaration and assignment."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Without shorthand\nclass Point {\n  public x: number;\n  protected y: number;\n  private label: string;\n\n  constructor(x: number, y: number, label: string) {\n    this.x = x;\n    this.y = y;\n    this.label = label;\n  }\n}\n\n// Equivalent with shorthand \u2014 much less ceremony\nclass Point {\n  constructor(\n    public x: number,\n    protected y: number,\n    private label: string\n  ) {}\n}\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Angular services that inject HttpClient commonly use this pattern:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "@Injectable({ providedIn: 'root' })\nclass ProductService {\n  constructor(\n    private readonly http: HttpClient,\n    private readonly router: Router\n  ) {}\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Angular-Specific Patterns"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Service State \u2014 private Fields with Signals"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Angular Signals make reactive state management straightforward. The signal itself is private; the read-only view is public. This prevents consumers from calling .set() on internal state."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "@Injectable({ providedIn: 'root' })\nexport class CartService {\n  private readonly _items = signal<CartItem[]>([]);\n\n  // Public read-only view \u2014 consumers can read, not write\n  readonly items = this._items.asReadonly();\n  readonly count = computed(() => this._items().length);\n\n  addItem(item: CartItem): void {\n    this._items.update(prev => [...prev, item]);\n  }\n\n  removeItem(id: string): void {\n    this._items.update(prev => prev.filter(i => i.id !== id));\n  }\n}\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Template Access \u2014 public is Required"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The Angular template compiler accesses component class members by their public API. Marking a field or method "
          },
          {
            "type": "text",
            "text": "private",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " or "
          },
          {
            "type": "text",
            "text": "protected",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " causes a template compilation error (with strict mode enabled)."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "@Component({\n  template: `\n    <p>{{ title }}</p>      <!-- OK \u2014 public -->\n    <p>{{ subtitle }}</p>   <!-- Error: 'subtitle' is protected -->\n    <button (click)=\"save()\">Save</button>  <!-- OK \u2014 public -->\n  `\n})\nexport class ArticleComponent {\n  public title = 'Hello';\n  protected subtitle = 'World';  // template cannot access protected\n\n  public save(): void { /* ... */ }\n}\n"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Convention: prefix private Angular component state with an underscore (_count, _isOpen) to signal that it is internal, even though TypeScript already enforces it."
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Access Modifiers and Structural Typing"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "TypeScript uses "
          },
          {
            "type": "text",
            "text": "structural typing",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": ": two types are compatible if they have the same shape, regardless of their class names. Access modifiers are part of that shape. A "
          },
          {
            "type": "text",
            "text": "private",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " member makes a type structurally incompatible with any other type, even if both classes declare a field with the same name and modifier."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "class Dog {\n  private name: string;\n  constructor(name: string) { this.name = name; }\n}\n\nclass Cat {\n  private name: string;\n  constructor(name: string) { this.name = name; }\n}\n\nlet d: Dog = new Dog('Rex');\n// d = new Cat('Whiskers'); // Error: Types have separate declarations of 'name'\n\n// By contrast, public members allow structural compatibility:\nclass A { public x = 1; }\nclass B { public x = 1; }\nconst a: A = new B(); // OK \u2014 same public shape\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "This is why private fields stiffen the type \u2014 two classes with private fields of the same name are NOT assignable to each other, even if the runtime values would be identical."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Override and Access Modifiers"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When overriding a method in a subclass, you can "
          },
          {
            "type": "text",
            "text": "widen",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " the access modifier but not narrow it. Widening is safe because the subclass adds access; narrowing would violate Liskov Substitution Principle."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "class Base {\n  protected greet(): string { return 'hello'; }\n}\n\nclass Child extends Base {\n  // OK \u2014 widening from protected to public\n  public override greet(): string { return 'hi'; }\n}\n\nclass Broken extends Base {\n  // Error \u2014 cannot narrow from protected to private\n  // private override greet(): string { return '...'; }\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Combining with readonly"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "readonly",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " can be combined with any access modifier. A "
          },
          {
            "type": "text",
            "text": "private readonly",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " field is set once (in the constructor or initialiser) and can never change, even within the class. This is the strictest invariant you can express."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "class Config {\n  // Set once at construction; the class itself cannot mutate it later\n  private readonly apiKey: string;\n\n  // Public readonly \u2014 consumers can read but not write\n  public readonly version = '1.0.0';\n\n  constructor(key: string) {\n    this.apiKey = key;\n  }\n\n  getHeaders() {\n    return { 'X-Api-Key': this.apiKey };\n    // this.apiKey = 'other'; // Error: readonly\n  }\n}\n\nconst cfg = new Config('abc123');\nconsole.log(cfg.version); // '1.0.0'\n// cfg.version = '2.0.0'; // Error: readonly\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Angular services often pair private readonly with injected dependencies to prevent accidental re-assignment of services after construction."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Accessing private at Runtime"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "TypeScript "
          },
          {
            "type": "text",
            "text": "private",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " is compile-time only. At runtime the property exists on the plain JavaScript object. Code that bypasses TypeScript (dynamic access, JSON serialisation, or a cast to "
          },
          {
            "type": "text",
            "text": "any",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ") can still reach it."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "class Secret {\n  private password = 'hunter2';\n}\n\nconst s = new Secret();\n// TypeScript blocks this:\n// s.password;               // Error: private\n\n// But at runtime JavaScript has no guards:\nconsole.log((s as any).password); // 'hunter2' \u2014 still accessible!\nconsole.log(JSON.stringify(s));   // {\"password\":\"hunter2\"} \u2014 serialised!\n\n// Use ECMAScript # for true runtime privacy:\nclass HardSecret {\n  #password = 'hunter2';\n}\nconsole.log(JSON.stringify(new HardSecret())); // {} \u2014 not serialised\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "private vs protected in Abstract Base Classes"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A common mistake is marking shared implementation helpers as "
          },
          {
            "type": "text",
            "text": "private",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " inside an abstract class \u2014 subclasses then cannot call them. If a method is meant to be used by subclasses but hidden from consumers, it must be "
          },
          {
            "type": "text",
            "text": "protected",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": "."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "abstract class FormValidator {\n  // BUG: private \u2014 subclass cannot call buildError()\n  private buildError(field: string, msg: string) {\n    return { field, message: msg };\n  }\n\n  abstract validate(data: Record<string, unknown>): object[];\n}\n\nclass RequiredValidator extends FormValidator {\n  validate(data: Record<string, unknown>) {\n    return Object.entries(data)\n      .filter(([, v]) => v == null || v === '')\n      // .map(([k]) => this.buildError(k, 'required')); // Error: private\n      .map(([k]) => ({ field: k, message: 'required' }));\n  }\n}\n\n// Fix: change private to protected in FormValidator\n"
          }
        ]
      },
