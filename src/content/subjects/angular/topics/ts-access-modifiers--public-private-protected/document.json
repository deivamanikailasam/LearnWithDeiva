            "type": "text",
            "text": "public, private & protected"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "TypeScript access modifiers \u2014 "
          },
          {
            "type": "text",
            "text": "public",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "text": "protected",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ", and "
          },
          {
            "type": "text",
            "text": "private",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " \u2014 control which parts of a class are visible to the outside world. They are a compile-time guarantee: the TypeScript compiler rejects code that violates them, even though they disappear from the emitted JavaScript."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "class BankAccount {\n  public owner: string;        // accessible everywhere (the default)\n  protected balance: number;   // accessible inside class and subclasses\n  private pin: string;         // accessible only inside BankAccount\n\n  constructor(owner: string, balance: number, pin: string) {\n    this.owner   = owner;\n    this.balance = balance;\n    this.pin     = pin;\n  }\n\n  public deposit(amount: number): void {\n    this.balance += amount;     // OK \u2014 same class\n  }\n\n  private validatePin(input: string): boolean {\n    return input === this.pin;  // OK \u2014 private field accessed inside class\n  }\n}\n\nconst acct = new BankAccount('Alice', 1000, '1234');\nconsole.log(acct.owner);    // OK \u2014 public\n// console.log(acct.balance); // Error: protected\n// console.log(acct.pin);     // Error: private\n"
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Access modifier visibility grid: public/protected/private vs same class/subclass/outside",
