      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Members are "
          },
          {
            "type": "text",
            "text": "public",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " by default. Writing "
          },
          {
            "type": "text",
            "text": "public",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " explicitly is optional but improves readability in code that mixes access levels. Angular component @Input and @Output properties are always public \u2014 the template binding compiler requires it."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "@Component({ selector: 'app-card', template: '...' })\nexport class CardComponent {\n  @Input() public title = '';   // explicit public \u2014 valid and readable\n  @Input() subtitle = '';       // implicit public \u2014 same effect\n\n  // Template can call this; explicit public signals intent\n  public onClick(): void { console.log('clicked'); }\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
