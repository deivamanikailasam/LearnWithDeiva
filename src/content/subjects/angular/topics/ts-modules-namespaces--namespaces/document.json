    "content": [
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Namespaces"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "TypeScript namespaces (formerly "
          },
          {
            "type": "text",
            "text": "internal modules",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": ") are a TypeScript-specific way to group related declarations under a shared name. They compile to an immediately-invoked function expression (IIFE) that populates a global object. Unlike ES modules, namespaces do not require imports \u2014 all code in the same compilation sees the namespace's exported members directly."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Namespace (legacy) vs ES Module (modern) comparison: namespace pollutes global scope, no tree shaking; ES modules have isolated scope and are tree-shakable",
          "title": null
        }
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Namespace Syntax"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "namespace Validation {\n  export interface StringValidator {\n    isValid(s: string): boolean;\n  }\n\n  const emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;  // not exported \u2014 private to namespace\n\n  export class EmailValidator implements StringValidator {\n    isValid(s: string): boolean {\n      return emailRegex.test(s);\n    }\n  }\n\n  export class LengthValidator implements StringValidator {\n    constructor(private min: number, private max: number) {}\n\n    isValid(s: string): boolean {\n      return s.length >= this.min && s.length <= this.max;\n    }\n  }\n}\n\n// Usage \u2014 no import needed (in same file or concatenated output)\nconst email = new Validation.EmailValidator();\nconsole.log(email.isValid('alice@example.com')); // true\n\n// TypeScript also allows aliases:\nconst EmailV = Validation.EmailValidator;\nconst v = new EmailV();\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Multi-File Namespaces"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A namespace can span multiple files using the "
          },
          {
            "type": "text",
            "text": "/// <reference path=\"...\">",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " directive. TypeScript's "
          },
          {
            "type": "text",
            "text": "--outFile",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " flag concatenates the files in dependency order. This approach was common before ES modules became standard."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// validators.ts\nnamespace Validation {\n  export interface StringValidator {\n    isValid(s: string): boolean;\n  }\n}\n\n// email-validator.ts\n/// <reference path=\"validators.ts\" />\nnamespace Validation {\n  export class EmailValidator implements StringValidator {\n    isValid(s: string): boolean { return s.includes('@'); }\n  }\n}\n\n// main.ts\n/// <reference path=\"validators.ts\" />\n/// <reference path=\"email-validator.ts\" />\nconst v = new Validation.EmailValidator();\n"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "The multi-file reference path approach with --outFile is obsolete in modern Angular projects. Angular uses a module bundler (esbuild) that resolves ES module imports \u2014 never reference path directives."
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Nested Namespaces"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "namespace App {\n  export namespace Services {\n    export class AuthService {\n      login(user: string): boolean { return !!user; }\n    }\n  }\n\n  export namespace Models {\n    export interface User { id: string; name: string; }\n  }\n}\n\nconst auth = new App.Services.AuthService();\nconst user: App.Models.User = { id: '1', name: 'Alice' };\n\n// Alias long nested path\nimport AuthService = App.Services.AuthService;\nconst svc = new AuthService();\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Namespaces in Declaration Files"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Namespaces are still "
          },
          {
            "type": "text",
            "text": "relevant today",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " in one specific context: "
          },
          {
            "type": "text",
            "text": ".d.ts",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " declaration files for legacy UMD (Universal Module Definition) or non-module libraries that expose a global object. If you use a CDN-loaded library, the types live in a "
          },
          {
            "type": "text",
            "text": "declare namespace",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": "."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// typings/jquery.d.ts \u2014 simplified JQuery declaration\ndeclare namespace $ {\n  function ajax(url: string, settings?: object): void;\n  function get(url: string): Promise<unknown>;\n\n  interface JQuery {\n    addClass(name: string): JQuery;\n    hide(): JQuery;\n    show(): JQuery;\n  }\n}\n\n// Usage (when jQuery is loaded via a <script> tag, not npm)\n$.ajax('/api/users');\n$('#app').hide();\n\n// Dual declaration \u2014 works both as global and as ES module import\ndeclare namespace Lib {\n  function doThing(): void;\n}\ndeclare module 'some-lib' {\n  export = Lib; // CommonJS/UMD form\n}\n"
          }
        ]
      },
