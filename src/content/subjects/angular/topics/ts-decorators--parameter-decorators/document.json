                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Allow null if no provider \u2014 no error thrown"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {
