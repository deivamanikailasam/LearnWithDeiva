      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "@Component({\n  selector: 'app-tooltip',\n  template: '...',\n  standalone: true\n})\nexport class TooltipComponent {\n  constructor(\n    // Optional \u2014 component works even if LoggingService is not provided\n    @Optional() private logger: LoggingService | null,\n    // Read the static 'placement' attribute from <app-tooltip placement=\"top\">\n    @Attribute('placement') placement: string | null,\n    // Only look up in this component's injector, not the hierarchy\n    @Self() private ref: ElementRef,\n  ) {}\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "emitDecoratorMetadata and Type Inference"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When "
          },
          {
            "type": "text",
            "text": "emitDecoratorMetadata: true",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " is set in tsconfig and "
          },
          {
            "type": "text",
            "text": "reflect-metadata",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " is imported, the TypeScript compiler automatically records the TypeScript type of each constructor parameter as "
          },
          {
            "type": "text",
            "text": "Reflect.metadata('design:paramtypes', [Type, ...])",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". Angular's DI system reads this to determine "
          },
          {
            "type": "text",
            "text": "which service class to inject",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " without explicit "
          },
          {
            "type": "text",
            "text": "@Inject()",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " tokens."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// With emitDecoratorMetadata: true and reflect-metadata imported:\n\n@Injectable()\nclass AuthService {\n  constructor(private http: HttpClient) {}\n  // Compiler emits: Reflect.metadata('design:paramtypes', [HttpClient])\n  // Angular reads this to know: inject HttpClient at index 0\n}\n\n// Without emitDecoratorMetadata (e.g. Angular 19 standalone without legacy config):\n// Angular uses the TC39 class field decorators and the inject() function instead:\n@Injectable()\nclass ModernAuthService {\n  private http = inject(HttpClient); // no constructor needed\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Pitfalls"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  "Parameter decorators cannot intercept or change the runtime value of the argument. They only store metadata."
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "methodKey",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " is "
                  },
                  {
                    "type": "text",
                    "text": "undefined",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " for constructor parameters \u2014 test for this before using it as a metadata key."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  "Stacking multiple parameter decorators on the same argument: they are called right-to-left (last decorator in source is applied first)."
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  "Parameter decorators only work with ",
                  {
                    "type": "text",
                    "text": "experimentalDecorators: true",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  ". They are not part of the TC39 stage-3 decorator spec (which does not include parameter decorators as of TypeScript 5.x)."
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Practical Custom Example: Audit Logging"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Mark which parameters should be included in an audit log, then wrap the method to capture them:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "const AUDIT_PARAMS_KEY = Symbol('auditParams');\n\nfunction AuditField(target: object, key: string | symbol | undefined, paramIndex: number): void {\n  const list: number[] = Reflect.getMetadata(AUDIT_PARAMS_KEY, target, key!) ?? [];\n  Reflect.defineMetadata(AUDIT_PARAMS_KEY, [...list, paramIndex], target, key!);\n}\n\nfunction Audit(target: object, key: string | symbol, descriptor: PropertyDescriptor): PropertyDescriptor {\n  const original = descriptor.value as (...args: unknown[]) => unknown;\n\n  descriptor.value = function (...args: unknown[]) {\n    const indices: number[] = Reflect.getMetadata(AUDIT_PARAMS_KEY, target, key) ?? [];\n    const logged: Record<number, unknown> = {};\n    indices.forEach(i => { logged[i] = args[i]; });\n    console.log(\\`[AUDIT] \\${String(key)}\\`, logged);\n    return original.apply(this, args);\n  };\n\n  return descriptor;\n}\n\nclass PaymentService {\n  @Audit\n  charge(\n    @AuditField userId: string,\n    amount: number,         // not logged \u2014 no @AuditField\n    @AuditField method: string\n  ): void {\n    // process payment\n  }\n}\n\nconst pay = new PaymentService();\npay.charge('user-42', 99.9, 'card');\n// Console: [AUDIT] charge { '0': 'user-42', '2': 'card' }\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Building a Validation Framework with Parameter Decorators"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A richer validation example using multiple constraint decorators per parameter, combining parameter and method decorators:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import 'reflect-metadata';\n\nconst VALIDATORS_KEY = Symbol('validators');\ntype Validator = (value: unknown) => string | null;\n\nfunction addValidator(target: object, key: string, index: number, validator: Validator): void {\n  const map: Map<number, Validator[]> =\n    Reflect.getMetadata(VALIDATORS_KEY, target, key) ?? new Map();\n  const list = map.get(index) ?? [];\n  map.set(index, [...list, validator]);\n  Reflect.defineMetadata(VALIDATORS_KEY, map, target, key);\n}\n\n// Parameter decorator factories\nfunction IsString(target: object, key: string, index: number): void {\n  addValidator(target, key, index, v => typeof v !== 'string' ? 'Must be a string' : null);\n}\n\nfunction MinLength(n: number) {\n  return (target: object, key: string, index: number) => {\n    addValidator(target, key, index, v =>\n      typeof v === 'string' && v.length < n ? \\`Min length \\${n}\\` : null\n    );\n  };\n}\n\nfunction IsEmail(target: object, key: string, index: number): void {\n  addValidator(target, key, index, v =>\n    typeof v === 'string' && !v.includes('@') ? 'Must be a valid email' : null\n  );\n}\n\n// Method decorator that reads and runs all validators\nfunction ValidateArgs(target: object, key: string, descriptor: PropertyDescriptor): PropertyDescriptor {\n  const original = descriptor.value as (...args: unknown[]) => unknown;\n\n  descriptor.value = function (...args: unknown[]) {\n    const map: Map<number, Validator[]> =\n      Reflect.getMetadata(VALIDATORS_KEY, target, key) ?? new Map();\n\n    const errors: string[] = [];\n    map.forEach((validators, index) => {\n      validators.forEach(validate => {\n        const err = validate(args[index]);\n        if (err) errors.push(\\`Param[\\${index}]: \\${err}\\`);\n      });\n    });\n\n    if (errors.length) throw new Error(errors.join('; '));\n    return original.apply(this, args);\n  };\n\n  return descriptor;\n}\n\nclass AuthController {\n  @ValidateArgs\n  register(\n    @IsString @MinLength(3) username: string,\n    @IsEmail email: string,\n    @IsString @MinLength(8) password: string\n  ): void {\n    console.log('Registered:', username, email);\n  }\n}\n\nconst ctrl = new AuthController();\nctrl.register('alice', 'alice@example.com', 'securePass');     // OK\n// ctrl.register('al', 'alice@example.com', 'securePass'); // Param[0]: Min length 3\n// ctrl.register('alice', 'not-email', 'securePass');       // Param[1]: Must be a valid email\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Parameter Decorator Stacking Order"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When multiple decorators are applied to the same parameter they are "
          },
          {
            "type": "text",
            "text": "evaluated right-to-left",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " (innermost first). This mirrors how function composition works \u2014 the decorator closest to the parameter name runs first."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "function A(target: object, key: string | undefined, idx: number) { console.log(\\`A idx=\\${idx}\\`); }\nfunction B(target: object, key: string | undefined, idx: number) { console.log(\\`B idx=\\${idx}\\`); }\nfunction C(target: object, key: string | undefined, idx: number) { console.log(\\`C idx=\\${idx}\\`); }\n\nclass Example {\n  demo(\n    @A @B @C param0: string,   // C runs first, then B, then A for param 0\n    @A param1: number           // A runs for param 1\n  ): void {}\n}\n\n// Output:\n// C idx=0\n// B idx=0\n// A idx=0\n// A idx=1\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "@SkipSelf vs @Self \u2014 Injector Hierarchy"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "@Self()",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " and "
          },
          {
            "type": "text",
            "text": "@SkipSelf()",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " are Angular parameter decorators that control "
          },
          {
            "type": "text",
            "text": "how Angular walks the injector tree",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": ". They are critical in component libraries and multi-level lazy modules."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// In a component that may have its own LOCAL theme provider,\n// but should fall back to the parent's theme if not present.\n\n@Injectable()\nabstract class ThemeService { abstract color: string; }\n\n@Component({\n  selector: 'app-card',\n  template: '...',\n  providers: [\n    // This component can optionally provide its own ThemeService\n  ]\n})\nexport class CardComponent {\n  constructor(\n    // Try this component's injector first; if not found, throw\n    @Self() @Optional() private localTheme: ThemeService | null,\n    // Always use the parent's ThemeService, never local\n    @SkipSelf() private parentTheme: ThemeService\n  ) {}\n\n  get activeColor(): string {\n    return this.localTheme?.color ?? this.parentTheme.color;\n  }\n}\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "@Host \u2014 Directive Use Case"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "@Directive({ selector: '[appTooltip]', standalone: true })\nexport class TooltipDirective {\n  constructor(\n    // Must be provided on the host element \u2014 not from a parent injector\n    @Host() private config: TooltipConfig\n  ) {}\n}\n\n// Correct usage:\n@Component({\n  selector: 'app-button',\n  template: '<button appTooltip>...</button>',\n  providers: [TooltipConfig],  // <-- provided at host\n  standalone: true,\n})\nexport class ButtonComponent {}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing Parameter Decorators"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Test the metadata first, then test the combined behaviour through the method decorator:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "describe('Parameter decorator validation', () => {\n  it('@Required records parameter index in metadata', () => {\n    class Svc {\n      create(@Required name: string, age: number) {}\n    }\n    const indices: number[] = Reflect.getMetadata(REQUIRED_PARAMS_KEY, Svc.prototype, 'create') ?? [];\n    expect(indices).toContain(0);\n    expect(indices).not.toContain(1); // age is not decorated\n  });\n\n  it('@ValidateParams throws for missing required arg', () => {\n    class Svc {\n      @ValidateParams\n      create(@Required name: string): void {}\n    }\n    const svc = new Svc();\n    expect(() => svc.create('')).toThrowError(/index 0 is required/);\n  });\n\n  it('@ValidateParams passes for valid args', () => {\n    class Svc {\n      @ValidateParams\n      create(@Required name: string): void {}\n    }\n    expect(() => new Svc().create('Alice')).not.toThrow();\n  });\n});\n\n// Angular DI parameter decorator testing is done via TestBed:\ndescribe('CardComponent injector priorities', () => {\n  it('prefers local ThemeService when provided', () => {\n    const local = { color: 'blue' };\n    TestBed.configureTestingModule({\n      imports: [CardComponent],\n      providers: [\n        { provide: ThemeService, useValue: { color: 'red' } }, // parent\n      ]\n    });\n    // Override at component level\n    const fixture = TestBed.overrideComponent(CardComponent, {\n      set: { providers: [{ provide: ThemeService, useValue: local }] }\n    }).createComponent(CardComponent);\n\n    expect(fixture.componentInstance.activeColor).toBe('blue');\n  });\n});\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  "Parameter decorators receive (target, methodKey, paramIndex) \u2014 they record metadata only, cannot change the argument value."
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "methodKey",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " is "
                  },
                  {
                    "type": "text",
                    "text": "undefined",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " for constructor parameters; "
                  },
                  {
                    "type": "text",
                    "text": "target",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " is the constructor function, not the prototype."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  "Angular's @Inject(), @Optional(), @Self(), @SkipSelf(), @Host(), and @Attribute() are all built-in parameter decorators."
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "emitDecoratorMetadata: true",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " lets the compiler emit type metadata for constructor params \u2014 Angular's DI reads this to infer which services to inject."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  "Parameter decorators are legacy (experimentalDecorators) \u2014 the TC39 stage-3 spec uses inject() instead in Angular 17+."
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}