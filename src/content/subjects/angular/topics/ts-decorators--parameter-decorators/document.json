{
  "format": "tiptap/v1",
  "doc": {
    "type": "doc",
    "content": [
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Parameter Decorators"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A "
          },
          {
            "type": "text",
            "text": "parameter decorator",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " decorates a single parameter of a constructor or method. It receives three arguments: the class prototype (or constructor for static methods), the method name (or "
          },
          {
            "type": "text",
            "text": "undefined",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " for constructor parameters), and the zero-based index of the parameter. Parameter decorators "
          },
          {
            "type": "text",
            "text": "cannot change the value",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " of the parameter \u2014 they can only record metadata, which is typically consumed by a companion method decorator or a DI container."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Signature of a parameter decorator\ntype ParameterDecorator = (\n  target: object,               // prototype (or constructor for static)\n  methodKey: string | symbol | undefined, // method name; undefined for constructor params\n  parameterIndex: number        // 0-based index\n) => void;\n"
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Parameter decorator receives target, methodKey, paramIndex \u2014 shown for two decorated parameters of processOrder",
          "title": null
        }
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Recording Parameter Metadata"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The primary use of parameter decorators is to attach metadata via "
          },
          {
            "type": "text",
            "text": "Reflect.defineMetadata",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". A companion method decorator then reads that metadata and uses it to validate or transform the arguments before calling the original method."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import 'reflect-metadata';\n\nconst REQUIRED_PARAMS_KEY = Symbol('requiredParams');\n\n// Parameter decorator \u2014 marks the parameter as required\nfunction Required(target: object, methodKey: string | symbol | undefined, paramIndex: number): void {\n  const existing: number[] = Reflect.getMetadata(REQUIRED_PARAMS_KEY, target, methodKey!) ?? [];\n  Reflect.defineMetadata(REQUIRED_PARAMS_KEY, [...existing, paramIndex], target, methodKey!);\n}\n\n// Method decorator \u2014 reads metadata and validates before calling\nfunction ValidateParams(target: object, key: string | symbol, descriptor: PropertyDescriptor): PropertyDescriptor {\n  const original = descriptor.value as (...args: unknown[]) => unknown;\n\n  descriptor.value = function (...args: unknown[]) {\n    const requiredIndexes: number[] = Reflect.getMetadata(REQUIRED_PARAMS_KEY, target, key) ?? [];\n    for (const idx of requiredIndexes) {\n      if (args[idx] == null || args[idx] === '') {\n        throw new Error(\\`Argument at index \\${idx} is required.\\`);\n      }\n    }\n    return original.apply(this, args);\n  };\n\n  return descriptor;\n}\n\nclass UserService {\n  @ValidateParams\n  createUser(\n    @Required name: string,\n    @Required email: string,\n    role = 'viewer'             // optional \u2014 not decorated\n  ): void {\n    console.log('Creating user:', name, email, role);\n  }\n}\n\nconst svc = new UserService();\nsvc.createUser('Alice', 'alice@example.com'); // OK\n// svc.createUser('', 'alice@example.com');   // Error: Argument at index 0 is required.\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Constructor Parameter Decorators"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When applied to a constructor parameter, "
          },
          {
            "type": "text",
            "text": "methodKey",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " is "
          },
          {
            "type": "text",
            "text": "undefined",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " and "
          },
          {
            "type": "text",
            "text": "target",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " is the "
          },
          {
            "type": "text",
            "text": "class constructor",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " itself (not the prototype). Angular uses this exact mechanism for "
          },
          {
            "type": "text",
            "text": "@Inject()",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " to specify which DI token to use when the type is not inferrable."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "const TOKEN_META_KEY = Symbol('inject-token');\n\n// Custom @Inject analog\nfunction Inject(token: unknown) {\n  return (target: Function, _key: string | symbol | undefined, paramIndex: number): void => {\n    const existing: Array<{ index: number; token: unknown }> =\n      Reflect.getMetadata(TOKEN_META_KEY, target) ?? [];\n    Reflect.defineMetadata(TOKEN_META_KEY, [...existing, { index: paramIndex, token }], target);\n  };\n}\n\n// InjectionToken equivalent\nconst HTTP_BASE_URL = 'HTTP_BASE_URL';\n\n@Injectable()\nclass ApiService {\n  constructor(\n    private http: HttpClient,\n    @Inject(HTTP_BASE_URL) private baseUrl: string // string type \u2014 can't infer token\n  ) {}\n}\n\n// Angular's DI reads the Reflect metadata and supplies the right value\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
