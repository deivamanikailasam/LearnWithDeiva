      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": ""
          },
          {
            "type": "text",
            "text": "Record<K, V>",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " creates an object type where every key in "
          },
          {
            "type": "text",
            "text": "K",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " maps to the same value type "
          },
          {
            "type": "text",
            "text": "V",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". It is implemented as "
          },
          {
            "type": "text",
            "text": "{ [P in K]: V }",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " and is "
          },
          {
            "type": "text",
            "text": "non-homomorphic",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " \u2014 it does not inherit modifiers from any source type. "
          },
          {
            "type": "text",
            "text": "K",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " must be "
