            "type": "text",
            "text": "Record vs Index Signature"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "An index signature ("
          },
          {
            "type": "text",
            "text": "{ [key: string]: V }",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ") and "
          },
          {
            "type": "text",
            "text": "Record<string, V>",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " are semantically identical \u2014 both allow any string key with value type "
          },
          {
            "type": "text",
            "text": "V",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". However, Record has two advantages: it can use a "
          },
          {
            "type": "text",
            "text": "literal union",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " as the key type (enforcing exhaustiveness), and it expresses intent more clearly in code."
          }
        ]
      },
