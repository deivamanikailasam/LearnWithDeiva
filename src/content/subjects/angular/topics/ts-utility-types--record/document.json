      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Index signature \u2014 allows any key, no exhaustiveness\ninterface AnyMap { [key: string]: number }\nconst m1: AnyMap = { a: 1 }; // ok \u2014 no required keys\n\n// Record<string, number> \u2014 identical at runtime but signals 'this is a map'\ntype NumMap = Record<string, number>;\nconst m2: NumMap = { a: 1 }; // ok\n\n// Record<Literal, V> \u2014 enforces exhaustiveness\ntype Status = 'pending' | 'active' | 'closed';\ntype StatusMap = Record<Status, string>;\nconst sm: StatusMap = {\n  pending: 'Awaiting',\n  active:  'In Progress',\n  // closed missing \u2192 Error: Property 'closed' is missing\n};\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Record with Object Values"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "interface RouteConfig {\n  component: string;\n  guards: string[];\n  lazy: boolean;\n}\n\ntype AppRoutes = Record<string, RouteConfig>;\n\nconst routes: AppRoutes = {\n  '/home':    { component: 'HomeComponent',    guards: [],             lazy: false },\n  '/admin':   { component: 'AdminComponent',   guards: ['AuthGuard'],  lazy: true  },\n  '/profile': { component: 'ProfileComponent', guards: ['AuthGuard'],  lazy: true  },\n};\n\n// Process all routes generically\nfunction getPublicRoutes(routes: AppRoutes): string[] {\n  return Object.entries(routes)\n    .filter(([, cfg]) => cfg.guards.length === 0)\n    .map(([path]) => path);\n}\n// ['home'] \u2014 /admin and /profile require AuthGuard\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Angular Patterns"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Translation / i18n Lookup Tables"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "type Locale = 'en' | 'de' | 'fr' | 'es';\ntype TranslationKey = 'save' | 'cancel' | 'delete' | 'confirm' | 'loading';\n\n// All locales and all keys must be covered \u2014 Record ensures exhaustiveness\nconst translations: Record<Locale, Record<TranslationKey, string>> = {\n  en: { save: 'Save', cancel: 'Cancel', delete: 'Delete', confirm: 'Confirm', loading: 'Loading...' },\n  de: { save: 'Speichern', cancel: 'Abbrechen', delete: 'L\u00f6schen', confirm: 'Best\u00e4tigen', loading: 'Laden...' },\n  fr: { save: 'Enregistrer', cancel: 'Annuler', delete: 'Supprimer', confirm: 'Confirmer', loading: 'Chargement...' },\n  es: { save: 'Guardar', cancel: 'Cancelar', delete: 'Eliminar', confirm: 'Confirmar', loading: 'Cargando...' },\n};\n\n// Adding a new locale (e.g., 'it') now forces you to add its translations\n// \u2014 TypeScript errors until all TranslationKey entries are present\n\n// Service\n@Injectable({ providedIn: 'root' })\nclass I18nService {\n  private locale: Locale = 'en';\n  translate(key: TranslationKey): string {\n    return translations[this.locale][key]; // always defined \u2014 no undefined check needed\n  }\n}\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "HTTP Status Code Map"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "type HttpMethod = 'GET' | 'POST' | 'PUT' | 'PATCH' | 'DELETE';\n\ninterface MethodConfig {\n  hasBody: boolean;\n  idempotent: boolean;\n  safe: boolean;\n}\n\nconst METHOD_CONFIG: Record<HttpMethod, MethodConfig> = {\n  GET:    { hasBody: false, idempotent: true,  safe: true  },\n  POST:   { hasBody: true,  idempotent: false, safe: false },\n  PUT:    { hasBody: true,  idempotent: true,  safe: false },\n  PATCH:  { hasBody: true,  idempotent: false, safe: false },\n  DELETE: { hasBody: false, idempotent: true,  safe: false },\n};\n\nfunction buildRequest(method: HttpMethod, url: string, body?: unknown): Request {\n  const config = METHOD_CONFIG[method]; // always MethodConfig \u2014 no undefined check\n  return new Request(url, {\n    method,\n    body: config.hasBody && body ? JSON.stringify(body) : undefined,\n    headers: { 'Content-Type': 'application/json' },\n  });\n}\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Component State Flag Map"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { signal, Signal } from '@angular/core';\n\ntype LoadableEntity = 'users' | 'products' | 'orders';\n\n// Each entity has its own loading signal\ntype LoadingState = Record<LoadableEntity, Signal<boolean>>;\n\n@Injectable({ providedIn: 'root' })\nclass LoadingService {\n  readonly loading: LoadingState = {\n    users:    signal(false),\n    products: signal(false),\n    orders:   signal(false),\n  };\n\n  // When a new LoadableEntity is added to the union, TypeScript errors here\n  // if loading is missing the new key \u2014 forces the developer to add it\n\n  setLoading(entity: LoadableEntity, isLoading: boolean): void {\n    // Signals are not writable from outside \u2014 use a WritableSignal internally\n    // (simplified example: using (this.loading[entity] as WritableSignal<boolean>).set(isLoading))\n  }\n}\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Form Error Messages"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { ValidationErrors } from '@angular/forms';\n\n// Map Angular validator names to user-readable error messages\ntype AngularValidator = 'required' | 'minlength' | 'maxlength' | 'pattern' | 'email' | 'min' | 'max';\n\ntype ErrorMessages = Partial<Record<AngularValidator, string>>;\n// Partial because not every field uses every validator\n\nfunction getFieldErrors(errors: ValidationErrors | null, messages: ErrorMessages): string[] {\n  if (!errors) return [];\n  return Object.keys(errors)\n    .filter((key): key is AngularValidator => key in messages)\n    .map(key => messages[key]!)\n    .filter(Boolean);\n}\n\n// Usage in a component\nconst passwordErrors: ErrorMessages = {\n  required:  'Password is required.',\n  minlength: 'Password must be at least 8 characters.',\n  pattern:   'Password must contain a number and a special character.',\n};\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Nested Record Patterns"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Two-level Record \u2014 matrix of combinations\ntype Permission = 'read' | 'write' | 'delete';\ntype Resource   = 'users' | 'products' | 'orders';\ntype Role       = 'admin' | 'manager' | 'viewer';\n\ntype AccessMatrix = Record<Role, Record<Resource, Permission[]>>;\n\nconst ACCESS: AccessMatrix = {\n  admin:   {\n    users:    ['read', 'write', 'delete'],\n    products: ['read', 'write', 'delete'],\n    orders:   ['read', 'write', 'delete'],\n  },\n  manager: {\n    users:    ['read'],\n    products: ['read', 'write'],\n    orders:   ['read', 'write'],\n  },\n  viewer:  {\n    users:    ['read'],\n    products: ['read'],\n    orders:   ['read'],\n  },\n};\n\nfunction canDo(role: Role, resource: Resource, action: Permission): boolean {\n  return ACCESS[role][resource].includes(action);\n}\n\ncanDo('manager', 'products', 'write');  // true\ncanDo('viewer',  'users',    'delete'); // false\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Record<string, V> Allows Unsafe Access"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Pitfall: Record<string, V> does not mark values as possibly undefined\n// even though any random key lookup might not exist at runtime\nconst lookup: Record<string, number> = { a: 1, b: 2 };\nconst val = lookup['unknown']; // TypeScript says: number\nval.toFixed(2);                // but at runtime: TypeError \u2014 val is undefined\n\n// Fix 1: use a type assertion to express that it might be undefined\nconst lookup2: Record<string, number | undefined> = { a: 1 };\nconst val2 = lookup2['unknown']; // number | undefined \u2014 must check before use\n\n// Fix 2: enable noUncheckedIndexedAccess in tsconfig \u2014 makes all index access return T | undefined\n// { \"compilerOptions\": { \"noUncheckedIndexedAccess\": true } }\n// With this flag: lookup['unknown'] is number | undefined even for Record<string, number>\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Record vs object \u2014 The Subtle Difference"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// 'object' is the type of all non-primitive values \u2014 too wide\nconst a: object = { x: 1 };\n// a.x;  // Error: Property 'x' does not exist on type 'object'\n\n// Record<string, unknown> is what you usually want for 'any object with string keys'\nconst b: Record<string, unknown> = { x: 1 };\nb.x; // unknown \u2014 must narrow before use\n\n// For a typed dict with specific value type:\nconst c: Record<string, number> = { count: 1, total: 5 };\nc.count; // number\n\n// Do NOT use Record<string, any> \u2014 it silences all type errors\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Record<K, V>",
                    "marks": [
                      {
