            "type": "text",
            "text": "Basic Usage"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Map a union of literals to a value type\ntype Color = 'red' | 'green' | 'blue';\ntype ColorHex = Record<Color, string>;\n// { red: string; green: string; blue: string }\n\nconst hexMap: ColorHex = {\n  red:   '#ef4444',\n  green: '#22c55e',\n  blue:  '#3b82f6',\n};\n\n// TypeScript enforces ALL keys are present:\nconst incomplete: ColorHex = { red: '#ef4444', green: '#22c55e' };\n// Error: Property 'blue' is missing\n\n// Access is non-nullable \u2014 no need to check for undefined\nconsole.log(hexMap.red.startsWith('#')); // ok \u2014 hexMap.red is string, not string | undefined\n\n// Record with string (open-ended key set)\ntype StringMap = Record<string, unknown>;\nconst data: StringMap = { foo: 1, bar: 'hello', baz: true }; // any keys allowed\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
