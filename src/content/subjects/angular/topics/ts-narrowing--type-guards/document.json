    "content": [
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Type Guards"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A type guard is a runtime check that narrows a union or broad type to a more specific type within a code branch. TypeScript analyses the guard and adjusts the type of the variable on each side of the branch automatically — no cast required."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "function format(value: string | number): string {\n  if (typeof value === 'string') {\n    // TypeScript knows value: string here\n    return value.toUpperCase();\n  }\n  // TypeScript knows value: number here\n  return value.toFixed(2);\n}\n\nconsole.log(format('hello')); // 'HELLO'\nconsole.log(format(3.14159)); // '3.14'\n"
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Type guard narrowing flow: union type enters a condition, true branch narrows to string, false branch narrows to number",
          "title": null
        }
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Built-in Type Guards"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "typeof"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// typeof narrows to: string | number | boolean | bigint | symbol | object | function | undefined\nfunction describe(value: unknown): string {\n  if (typeof value === 'string')   return `string: \"${value}\"`;\n  if (typeof value === 'number')   return `number: ${value.toFixed(2)}`;\n  if (typeof value === 'boolean')  return `boolean: ${value}`;\n  if (typeof value === 'object' && value !== null) return `object`;\n  return `other: ${typeof value}`;\n}\n\n// Note: typeof null === 'object' — always null-check after object guard\nfunction processObj(x: object | null): string {\n  if (typeof x === 'object' && x !== null) {\n    return JSON.stringify(x);\n  }\n  return 'null';\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "instanceof"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// instanceof narrows to the class type\nclass HttpError extends Error {\n  constructor(public statusCode: number, message: string) {\n    super(message);\n    this.name = 'HttpError';\n  }\n}\n\nclass ValidationError extends Error {\n  constructor(public field: string, message: string) {\n    super(message);\n    this.name = 'ValidationError';\n  }\n}\n\nfunction handleError(err: Error): string {\n  if (err instanceof HttpError) {\n    // err: HttpError — statusCode is accessible\n    return `HTTP ${err.statusCode}: ${err.message}`;\n  }\n  if (err instanceof ValidationError) {\n    // err: ValidationError — field is accessible\n    return `Validation on \"${err.field}\": ${err.message}`;\n  }\n  return `Unknown error: ${err.message}`;\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "in operator"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "interface Cat { meow(): void; purr(): void }\ninterface Dog { bark(): void; fetch(): void }\ntype Pet = Cat | Dog;\n\nfunction makeSound(pet: Pet): void {\n  if ('meow' in pet) {\n    // pet: Cat — meow is present\n    pet.meow();\n  } else {\n    // pet: Dog — meow is absent\n    pet.bark();\n  }\n}\n\n// in works for non-overlapping interfaces\ninterface ApiSuccess { data: unknown; status: number }\ninterface ApiError   { error: string; code: number }\n\nfunction handle(response: ApiSuccess | ApiError): void {\n  if ('data' in response) {\n    // response: ApiSuccess\n    console.log(response.data);\n  } else {\n    // response: ApiError\n    console.error(response.error);\n  }\n}"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "User-Defined Type Predicates"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A user-defined type guard is a function whose return type annotation is value is Type. When the function returns true, TypeScript narrows the argument to that type at the call site."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "interface User   { kind: 'user';   id: number; name: string }\ninterface Admin  { kind: 'admin';  id: number; name: string; permissions: string[] }\n\ntype Principal = User | Admin;\n\n// Type predicate — return type is \"value is Admin\"\nfunction isAdmin(p: Principal): p is Admin {\n  return p.kind === 'admin';\n}\n\nfunction describeRole(p: Principal): string {\n  if (isAdmin(p)) {\n    // p: Admin — permissions is available\n    return `Admin with ${p.permissions.length} permission(s)`;\n  }\n  // p: User — no permissions property\n  return `User: ${p.name}`;\n}\n\n// Validate unknown data from an API response\nfunction isUser(value: unknown): value is User {\n  return (\n    typeof value === 'object' &&\n    value !== null &&\n    'kind' in value &&\n    (value as Record<string, unknown>).kind === 'user' &&\n    typeof (value as Record<string, unknown>).id === 'number' &&\n    typeof (value as Record<string, unknown>).name === 'string'\n  );\n}\n\nconst raw: unknown = JSON.parse('{\"kind\":\"user\",\"id\":1,\"name\":\"Alice\"}');\nif (isUser(raw)) {\n  // raw: User — fully typed\n  console.log(raw.name);\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Generic Type Predicates"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Generic predicate — works for any type T when given a guard function\nfunction isArrayOf<T>(value: unknown, guard: (item: unknown) => item is T): value is T[] {\n  return Array.isArray(value) && value.every(guard);\n}\n\nfunction isString(v: unknown): v is string { return typeof v === 'string'; }\nfunction isNumber(v: unknown): v is number { return typeof v === 'number'; }\n\nconst maybeStrings: unknown = ['a', 'b', 'c'];\nif (isArrayOf(maybeStrings, isString)) {\n  // maybeStrings: string[]\n  console.log(maybeStrings.join(', '));\n}\n\n// Compose guards for nested structures\ninterface Config { host: string; port: number; debug: boolean }\n\nfunction isConfig(v: unknown): v is Config {\n  if (typeof v !== 'object' || v === null) return false;\n  const rec = v as Record<string, unknown>;\n  return (\n    typeof rec.host  === 'string'  &&\n    typeof rec.port  === 'number'  &&\n    typeof rec.debug === 'boolean'\n  );\n}"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Discriminated Unions — Tagged Type Guards"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A discriminated union is a set of types that each carry a literal \"discriminant\" property. TypeScript narrows based on the value of that property — no explicit type predicate needed."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "type Shape =\n  | { kind: 'circle';    radius: number }\n  | { kind: 'rectangle'; width: number; height: number }\n  | { kind: 'triangle';  base: number;  height: number };\n\nfunction area(shape: Shape): number {\n  switch (shape.kind) {\n    case 'circle':\n      // shape: { kind: 'circle'; radius: number }\n      return Math.PI * shape.radius ** 2;\n    case 'rectangle':\n      return shape.width * shape.height;\n    case 'triangle':\n      return 0.5 * shape.base * shape.height;\n  }\n}\n\n// Exhaustiveness check with never\nfunction assertNever(x: never): never {\n  throw new Error(`Unhandled case: ${JSON.stringify(x)}`);\n}\n\nfunction areaExhaustive(shape: Shape): number {\n  switch (shape.kind) {\n    case 'circle':    return Math.PI * shape.radius ** 2;\n    case 'rectangle': return shape.width * shape.height;\n    case 'triangle':  return 0.5 * shape.base * shape.height;\n    default: return assertNever(shape); // Error if a new kind is added but not handled\n  }\n}"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Type Guards in Angular"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Narrowing HTTP Response Variants"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { Injectable } from '@angular/core';\nimport { HttpClient } from '@angular/common/http';\nimport { Observable, map } from 'rxjs';\n\ntype ApiResult<T> =\n  | { ok: true;  data: T }\n  | { ok: false; error: string; code: number };\n\n@Injectable({ providedIn: 'root' })\nclass ApiService {\n  constructor(private http: HttpClient) {}\n\n  getUser(id: number): Observable<ApiResult<User>> {\n    return this.http.get<ApiResult<User>>(`/api/users/${id}`);\n  }\n}\n\ninterface User { id: number; name: string }\n\n// In a component\nfunction handleResult(result: ApiResult<User>): void {\n  if (result.ok) {\n    // result: { ok: true; data: User }\n    console.log(`Welcome, ${result.data.name}`);\n  } else {\n    // result: { ok: false; error: string; code: number }\n    console.error(`Error ${result.code}: ${result.error}`);\n  }\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Angular Route Guard with Type Predicate"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { CanActivateFn, Router } from '@angular/router';\nimport { inject } from '@angular/core';\n\ninterface AuthenticatedUser { id: number; role: 'admin' | 'user' }\ntype CurrentUser = AuthenticatedUser | null;\n\nfunction isAuthenticated(user: CurrentUser): user is AuthenticatedUser {\n  return user !== null && typeof user.id === 'number';\n}\n\nfunction hasRole(user: AuthenticatedUser, role: 'admin' | 'user'): boolean {\n  return user.role === role;\n}\n\nexport const adminGuard: CanActivateFn = () => {\n  // In a real app, inject the auth service and get the current user\n  const currentUser: CurrentUser = null; // placeholder\n  const router = inject(Router);\n\n  if (!isAuthenticated(currentUser)) {\n    router.navigate(['/login']);\n    return false;\n  }\n\n  // currentUser: AuthenticatedUser — narrowed\n  if (!hasRole(currentUser, 'admin')) {\n    router.navigate(['/forbidden']);\n    return false;\n  }\n\n  return true; // currentUser: AuthenticatedUser with role 'admin'\n};"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Narrowing Signal Values"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { signal, computed } from '@angular/core';\n\ntype LoadState<T> =\n  | { status: 'idle' }\n  | { status: 'loading' }\n  | { status: 'error'; message: string }\n  | { status: 'loaded'; data: T };\n\nconst state = signal<LoadState<User[]>>({ status: 'idle' });\n\n// Type-safe computed values using discriminated union narrowing\nconst isLoaded = computed(() => state().status === 'loaded');\nconst data     = computed(() => {\n  const s = state();\n  return s.status === 'loaded' ? s.data : [];\n  // s.data is only accessible after the status check narrows s to the 'loaded' variant\n});\n\nconst errorMsg = computed(() => {\n  const s = state();\n  return s.status === 'error' ? s.message : null;\n});\n\ninterface User { id: number; name: string }"
          }
        ]
      },
