{
  "format": "tiptap/v1",
  "doc": {
    "type": "doc",
    "content": [
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "async/await execution model compared to Promise chains"
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "What Are async and await?"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "async/await",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " is syntactic sugar over Promises, introduced in ES2017. An "
          },
          {
            "type": "text",
            "text": "async",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " function always returns a Promise; "
          },
          {
            "type": "text",
            "text": "await",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " pauses execution of the surrounding async function until a Promise settles, then resumes with the resolved value or throws the rejection reason."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The key insight: "
          },
          {
            "type": "text",
            "text": "await",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " suspends the "
          },
          {
            "type": "text",
            "text": "function",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": ", not the "
          },
          {
            "type": "text",
            "text": "thread",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": ". The JavaScript event loop remains free to process other events while the awaited Promise is pending."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "The async Keyword"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Marking a function with "
          },
          {
            "type": "text",
            "text": "async",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " does two things: it wraps the return value in a Promise, and it enables the use of "
          },
          {
            "type": "text",
            "text": "await",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " inside the function body."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Always returns Promise<number>\nasync function add(a: number, b: number): Promise<number> {\n  return a + b;   // equivalent to Promise.resolve(a + b)\n}\n\nconst result = await add(2, 3);   // 5\n\n// Throwing inside async rejects the returned Promise\nasync function fail(): Promise<never> {\n  throw new Error('Something went wrong');\n  // equivalent to Promise.reject(new Error(...))\n}\n\n// Async arrow functions\nconst fetchJson = async (url: string): Promise<unknown> => {\n  const res = await fetch(url);\n  return res.json();\n};\n\n// Async class methods\nclass UserService {\n  async getUser(id: number): Promise<User> {\n    const res = await fetch(`/api/users/${id}`);\n    if (!res.ok) throw new Error(`HTTP ${res.status}`);\n    return res.json() as Promise<User>;\n  }\n}"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "The await Keyword"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "await",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " can appear in front of any expression. If the expression is a Promise, execution pauses until it settles. If it is a non-Promise value, it is wrapped in "
          },
          {
            "type": "text",
            "text": "Promise.resolve()",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " and the function continues on the next microtask."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "async function demo() {\n  // Await a Promise\n  const user = await fetch('/api/user').then(r => r.json());\n\n  // Await a plain value \u2014 works but unnecessary\n  const x = await 42;   // x === 42\n\n  // Sequential loop \u2014 each iteration waits for the previous\n  const results: string[] = [];\n  for (const id of [1, 2, 3]) {\n    const name = await fetchName(id);\n    results.push(name);\n  }\n\n  // Await inside a conditional\n  if (await isAuthenticated()) {\n    return await loadDashboard();\n  }\n}"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Gotcha: ",
                "marks": [
                  {
                    "type": "bold"
                  }
                ]
              },
              {
                "type": "text",
                "text": "await",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " inside "
              },
              {
                "type": "text",
                "text": "forEach",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " does NOT make the loop sequential. "
              },
              {
                "type": "text",
                "text": "forEach",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " ignores the returned Promise from each callback. Use "
              },
              {
                "type": "text",
                "text": "for...of",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " for sequential execution or "
              },
              {
                "type": "text",
                "text": "Promise.all(.map())",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " for parallel."
              }
            ]
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// WRONG \u2014 forEach ignores Promises\nids.forEach(async id => {\n  await process(id);   // all start simultaneously; errors swallowed\n});\n\n// CORRECT \u2014 sequential with for...of\nfor (const id of ids) {\n  await process(id);\n}\n\n// CORRECT \u2014 parallel with Promise.all\nawait Promise.all(ids.map(id => process(id)));"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Error Handling"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Errors propagate the same way as rejected Promises. Wrap awaited calls in "
          },
          {
            "type": "text",
            "text": "try/catch",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " to handle them. A single "
          },
          {
            "type": "text",
            "text": "catch",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " block covers all awaited operations inside it."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "async function loadProfile(id: number): Promise<Profile> {\n  try {\n    const user  = await fetchUser(id);\n    const posts = await fetchPosts(user.id);\n    return buildProfile(user, posts);\n  } catch (err) {\n    // catches any rejection from fetchUser, fetchPosts, or buildProfile\n    console.error('Failed to load profile:', err);\n    throw err;   // re-throw so callers know it failed\n  } finally {\n    hideSpinner();   // always runs\n  }\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Granular error handling"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "async function loadDashboard(id: number) {\n  const user = await fetchUser(id);   // must succeed\n\n  let posts: Post[] = [];\n  try {\n    posts = await fetchPosts(user.id);   // optional\n  } catch {\n    console.warn('Posts unavailable, showing empty feed');\n  }\n\n  let prefs = DEFAULT_PREFS;\n  try {\n    prefs = await fetchPrefs(user.id);\n  } catch {\n    // fall back to defaults silently\n  }\n\n  return { user, posts, prefs };\n}"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Sequential vs Parallel Execution"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Sequential "
          },
          {
            "type": "text",
            "text": "await",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " is the default \u2014 each line waits for the previous. When operations are independent, start them simultaneously with "
          },
          {
            "type": "text",
            "text": "Promise.all",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": "."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// SEQUENTIAL \u2014 total ~900 ms\nasync function sequential(id: number) {\n  const user  = await fetchUser(id);    // ~300 ms\n  const posts = await fetchPosts(id);   // ~300 ms\n  const prefs = await fetchPrefs(id);   // ~300 ms\n  return { user, posts, prefs };\n}\n\n// PARALLEL \u2014 total ~300 ms\nasync function parallel(id: number) {\n  const [user, posts, prefs] = await Promise.all([\n    fetchUser(id),\n    fetchPosts(id),\n    fetchPrefs(id),\n  ]);\n  return { user, posts, prefs };\n}\n\n// WATERFALL \u2014 second depends on first\nasync function waterfall(id: number) {\n  const user  = await fetchUser(id);\n  const posts = await fetchPosts(user.id);   // needs user.id\n  return { user, posts };\n}\n\n// PARALLEL with partial failure tolerance\nasync function parallelSafe(id: number) {\n  const [userResult, postsResult] = await Promise.allSettled([\n    fetchUser(id),\n    fetchPosts(id),\n  ]);\n  return {\n    user:  userResult.status  === 'fulfilled' ? userResult.value  : null,\n    posts: postsResult.status === 'fulfilled' ? postsResult.value : [],\n  };\n}"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Top-Level await"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "In ES modules and "
          },
          {
            "type": "text",
            "text": ".mjs",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " files, "
          },
          {
            "type": "text",
            "text": "await",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " can appear outside any "
          },
          {
            "type": "text",
            "text": "async",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " function at the module top level. Angular bootstrapping code supports this."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// main.ts \u2014 top-level await before Angular bootstraps\nimport { bootstrapApplication } from '@angular/platform-browser';\nimport { AppComponent } from './app/app.component';\nimport { appConfig } from './app/app.config';\n\nconst remoteConfig = await fetch('/api/config').then(r => r.json());\nObject.assign(appConfig, remoteConfig);\n\nbootstrapApplication(AppComponent, appConfig)\n  .catch(err => console.error(err));"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "async/await in Angular"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Components, services, guards, and resolvers can all use async/await. The main consideration is change detection: async functions may bypass Zone.js in OnPush components."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Services"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { inject, Injectable } from '@angular/core';\nimport { HttpClient } from '@angular/common/http';\nimport { firstValueFrom } from 'rxjs';\n\n@Injectable({ providedIn: 'root' })\nexport class OrderService {\n  private http = inject(HttpClient);\n\n  async placeOrder(cart: Cart): Promise<Order> {\n    const order = await firstValueFrom(\n      this.http.post<Order>('/api/orders', cart)\n    );\n    await this.notifyInventory(order.id);\n    return order;\n  }\n\n  private async notifyInventory(orderId: string): Promise<void> {\n    await firstValueFrom(\n      this.http.post('/api/inventory/reserve', { orderId })\n    );\n  }\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Components with OnPush change detection"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "@Component({\n  changeDetection: ChangeDetectionStrategy.OnPush,\n  template: `\n    @for (order of orders; track order.id) {\n      <div>{{ order.total | currency }}</div>\n    }\n  `\n})\nexport class OrdersComponent implements OnInit {\n  orders: Order[] = [];\n  private svc = inject(OrderService);\n  private cdr = inject(ChangeDetectorRef);\n\n  async ngOnInit() {\n    this.orders = await this.svc.getOrders();\n    this.cdr.markForCheck();   // required: async bypasses Zone in OnPush\n  }\n}"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Angular tip: ",
                "marks": [
                  {
                    "type": "bold"
                  }
                ]
              },
              {
                "type": "text",
                "text": "In the default Zone.js change detection strategy, "
              },
              {
                "type": "text",
                "text": "async ngOnInit",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " works without calling "
              },
              {
                "type": "text",
                "text": "markForCheck()",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " because Zone.js patches microtasks. With "
              },
              {
                "type": "text",
                "text": "ChangeDetectionStrategy.OnPush",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " you must call "
              },
              {
                "type": "text",
                "text": "cdr.markForCheck()",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " after mutating state, or use the async pipe with an Observable instead."
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Route guards and resolvers"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { CanActivateFn, ResolveFn } from '@angular/router';\nimport { inject } from '@angular/core';\n\nexport const authGuard: CanActivateFn = async (route, state) => {\n  const auth = inject(AuthService);\n  const user = await auth.currentUser();\n  if (!user) {\n    inject(Router).navigate(['/login']);\n    return false;\n  }\n  return true;\n};\n\nexport const userResolver: ResolveFn<User> = async (route) => {\n  const id = route.paramMap.get('id')!;\n  return inject(UserService).getUser(Number(id));\n};"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "table",
        "content": [
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableHeader",
                "attrs": {},
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Pitfall"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableHeader",
                "attrs": {},
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Problem"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableHeader",
                "attrs": {},
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Fix"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "attrs": {},
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "await inside forEach"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {},
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Each callback returns a Promise that forEach ignores; errors swallowed"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {},
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Use for...of for sequential or Promise.all(.map()) for parallel"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "attrs": {},
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Sequential awaits for independent requests"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {},
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Unnecessary latency: requests run one at a time"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {},
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Use Promise.all([...]) to run them in parallel"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "attrs": {},
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Missing try/catch"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {},
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Unhandled Promise rejection if awaited call rejects"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {},
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Wrap in try/catch or attach .catch() to the returned Promise"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "attrs": {},
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Forgetting async keyword"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {},
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "SyntaxError: await is only valid in async functions"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {},
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Add async to the containing function"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "attrs": {},
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "await inside new Promise executor"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {},
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Errors inside async executor are unhandled"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {},
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Convert to plain async/await instead of mixing"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing async/await in Angular"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Jasmine supports async test functions natively. Use "
          },
          {
            "type": "text",
            "text": "fakeAsync",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " + "
          },
          {
            "type": "text",
            "text": "tick()",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " for timer-based code, or the async helper with "
          },
          {
            "type": "text",
            "text": "whenStable()",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " for component tests."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "describe('OrdersComponent', () => {\n  let component: OrdersComponent;\n  let fixture: ComponentFixture<OrdersComponent>;\n  let http: HttpTestingController;\n\n  beforeEach(async () => {\n    await TestBed.configureTestingModule({\n      imports: [OrdersComponent],\n      providers: [provideHttpClient(), provideHttpClientTesting()],\n    }).compileComponents();\n\n    fixture = TestBed.createComponent(OrdersComponent);\n    component = fixture.componentInstance;\n    http = TestBed.inject(HttpTestingController);\n  });\n\n  afterEach(() => http.verify());\n\n  it('loads orders on init', async () => {\n    const mockOrders: Order[] = [{ id: '1', total: 99.99 }];\n    fixture.detectChanges();\n    http.expectOne('/api/orders').flush(mockOrders);\n    await fixture.whenStable();\n    expect(component.orders).toEqual(mockOrders);\n  });\n\n  it('handles load failure gracefully', async () => {\n    fixture.detectChanges();\n    http.expectOne('/api/orders')\n      .flush('Error', { status: 500, statusText: 'Server Error' });\n    await fixture.whenStable();\n    expect(component.orders).toEqual([]);\n    expect(component.error).toBeTruthy();\n  });\n});"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Testing an async service method\ndescribe('OrderService.placeOrder', () => {\n  it('calls notifyInventory after placing order', async () => {\n    const svc  = TestBed.inject(OrderService);\n    const http = TestBed.inject(HttpTestingController);\n\n    const promise = svc.placeOrder({ items: [] });\n\n    http.expectOne('/api/orders').flush({ id: 'ord-1', total: 0 });\n    http.expectOne('/api/inventory/reserve').flush({});\n\n    const order = await promise;\n    expect(order.id).toBe('ord-1');\n  });\n});"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "async",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " marks a function as asynchronous \u2014 it always returns a Promise."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "await",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " pauses the containing function until a Promise settles, without blocking the event loop."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Use try/catch around await expressions; a single block covers multiple awaited calls."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Sequential "
                  },
                  {
                    "type": "text",
                    "text": "await",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " is simple but slow for independent work \u2014 use "
                  },
                  {
                    "type": "text",
                    "text": "Promise.all",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " to run them in parallel."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Never use "
                  },
                  {
                    "type": "text",
                    "text": "await",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " inside "
                  },
                  {
                    "type": "text",
                    "text": "forEach",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 use "
                  },
                  {
                    "type": "text",
                    "text": "for...of",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " or "
                  },
                  {
                    "type": "text",
                    "text": "Promise.all(.map())",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " instead."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "In Angular OnPush components, call "
                  },
                  {
                    "type": "text",
                    "text": "cdr.markForCheck()",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " after mutating state in an async function."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Test with Jasmine async functions or "
