    "content": [
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Pick & Omit"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": ""
          },
          {
            "type": "text",
            "text": "Pick<T, K>",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " creates a new type by selecting only the properties named in "
          },
          {
            "type": "text",
            "text": "K",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " from "
          },
          {
            "type": "text",
            "text": "T",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". "
          },
          {
            "type": "text",
            "text": "Omit<T, K>",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " creates a new type by removing the properties in "
          },
          {
            "type": "text",
            "text": "K",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " and keeping everything else. They are inverses of each other \u2014 use "
          },
          {
            "type": "text",
            "text": "Pick",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " when the kept set is small, "
          },
          {
            "type": "text",
            "text": "Omit",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " when the removed set is small."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Pick includes only listed properties; Omit excludes listed properties, keeping the rest",
          "title": null
        }
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Pick<T, K>"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Implemented as "
          },
          {
            "type": "text",
            "text": "{ [P in K]: T[P] }",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " where "
          },
          {
            "type": "text",
            "text": "K extends keyof T",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". It is a "
          },
          {
            "type": "text",
            "text": "non-homomorphic",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " mapped type \u2014 it does not preserve modifiers from the original type, so "
          },
          {
            "type": "text",
            "text": "readonly",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " and "
          },
          {
            "type": "text",
            "text": "?",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " are not automatically carried over (though in practice the source type's modifiers come through via "
          },
          {
            "type": "text",
            "text": "T[P]",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ")."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "interface User {\n  id: string;\n  name: string;\n  email: string;\n  passwordHash: string;\n  role: 'admin' | 'user';\n  createdAt: Date;\n}\n\n// Pick just the fields needed for a user profile card\ntype UserCard = Pick<User, 'id' | 'name'>;\n// { id: string; name: string }\n\n// Pick the publicly safe subset for an API response\ntype PublicUser = Pick<User, 'id' | 'name' | 'role'>;\n// { id: string; name: string; role: 'admin' | 'user' }\n// passwordHash and createdAt are excluded\n\n// Use a union of keys\ntype AuthFields = Pick<User, 'email' | 'passwordHash'>;\n// { email: string; passwordHash: string }\n\n// TypeScript enforces that keys exist in T\ntype Bad = Pick<User, 'id' | 'unknown'>; // Error: 'unknown' does not exist in User\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Omit<T, K>"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Omit is implemented as "
          },
          {
            "type": "text",
            "text": "Pick<T, Exclude<keyof T, K>>",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " \u2014 it picks all keys except those in "
          },
          {
            "type": "text",
            "text": "K",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". The keys to omit do "
          },
          {
            "type": "text",
            "text": "not",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " need to be "
          },
          {
            "type": "text",
            "text": "keyof T",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " \u2014 this is intentional to allow omitting keys from a union type (though it behaves differently than you might expect in union contexts)."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "interface Product {\n  id: string;\n  name: string;\n  price: number;\n  stock: number;\n  createdAt: Date;\n  updatedAt: Date;\n}\n\n// Remove server-managed fields for a create payload\ntype CreateProduct = Omit<Product, 'id' | 'createdAt' | 'updatedAt'>;\n// { name: string; price: number; stock: number }\n\n// Remove only price for a display-only view\ntype ProductDisplay = Omit<Product, 'price'>;\n// { id: string; name: string; stock: number; createdAt: Date; updatedAt: Date }\n\n// Omit keys that don't need to match exactly (no constraint error for non-existent keys)\ntype AlmostAll = Omit<Product, 'thisKeyDoesNotExist'>; // same as Product (no error)\n// Unlike Pick, Omit's K is 'string | number | symbol', not 'keyof T'\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
