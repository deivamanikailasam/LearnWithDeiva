      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Combining Pick and Omit with Other Utilities"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "interface Employee {\n  id: string;\n  name: string;\n  email: string;\n  department: string;\n  salary: number;\n  managerId: string | null;\n  startDate: Date;\n  endDate: Date | null;\n}\n\n// Read model (API GET response) \u2014 all fields\ntype EmployeeView = Readonly<Employee>;\n\n// Create payload \u2014 omit server fields, require the rest\ntype CreateEmployee = Required<Omit<Employee, 'id' | 'endDate'>>;\n// { name: string; email: string; department: string; salary: number; managerId: string | null; startDate: Date }\n\n// Update payload \u2014 omit server fields, make rest optional\ntype UpdateEmployee = Partial<Omit<Employee, 'id' | 'startDate'>>;\n\n// Summary for a list view \u2014 pick and make readonly\ntype EmployeeSummary = Readonly<Pick<Employee, 'id' | 'name' | 'department'>>;\n// { readonly id: string; readonly name: string; readonly department: string }\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Angular Patterns"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "API Shape Derivation"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { HttpClient } from '@angular/common/http';\nimport { Observable } from 'rxjs';\n\ninterface User {\n  id: string;\n  name: string;\n  email: string;\n  passwordHash: string;  // server-side only\n  createdAt: Date;       // server-managed\n  updatedAt: Date;       // server-managed\n}\n\n// Shapes derived from the canonical User type\ntype CreateUserPayload = Pick<User, 'name' | 'email'> & { password: string };\ntype UpdateUserPayload = Partial<Pick<User, 'name' | 'email'>>;\ntype UserResponse      = Omit<User, 'passwordHash'>; // safe to send to client\n\n@Injectable({ providedIn: 'root' })\nclass UserService {\n  constructor(private http: HttpClient) {}\n\n  create(payload: CreateUserPayload): Observable<UserResponse> {\n    return this.http.post<UserResponse>('/api/users', payload);\n  }\n\n  update(id: string, payload: UpdateUserPayload): Observable<UserResponse> {\n    return this.http.patch<UserResponse>(`/api/users/${id}`, payload);\n  }\n\n  get(id: string): Observable<UserResponse> {\n    return this.http.get<UserResponse>(`/api/users/${id}`);\n  }\n}\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Component @Input Slicing"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "interface Article {\n  id: string;\n  title: string;\n  body: string;\n  author: { name: string; avatar: string };\n  tags: string[];\n  publishedAt: Date;\n  viewCount: number;\n}\n\n// List item only needs summary fields\n@Component({ selector: 'app-article-card', standalone: true, template: '...' })\nexport class ArticleCardComponent {\n  @Input({ required: true }) article!: Pick<Article, 'id' | 'title' | 'author' | 'publishedAt'>;\n}\n\n// Detail view needs everything except internal fields\n@Component({ selector: 'app-article-detail', standalone: true, template: '...' })\nexport class ArticleDetailComponent {\n  @Input({ required: true }) article!: Omit<Article, 'viewCount'>; // viewCount is internal analytics\n}\n\n// Editor needs only the editable fields, all optional for drafts\n@Component({ selector: 'app-article-editor', standalone: true, template: '...' })\nexport class ArticleEditorComponent {\n  @Input() draft: Partial<Pick<Article, 'title' | 'body' | 'tags'>> = {};\n}\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "NgRx Selector Shape Mapping"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { createSelector } from '@ngrx/store';\n\ninterface AppState {\n  user: {\n    id: string;\n    name: string;\n    email: string;\n    preferences: { theme: string; language: string };\n    cart: { itemCount: number; total: number };\n  };\n}\n\nconst selectUser = (state: AppState) => state.user;\n\n// Selector returns only the fields needed by the header component\ntype HeaderData = Pick<AppState['user'], 'name' | 'cart'>;\nconst selectHeaderData = createSelector(\n  selectUser,\n  (user): HeaderData => ({ name: user.name, cart: user.cart })\n);\n\n// Selector returns preferences without identifying info\ntype PreferenceData = Omit<AppState['user'], 'id' | 'name' | 'email' | 'cart'>;\nconst selectPreferences = createSelector(\n  selectUser,\n  (user): PreferenceData => ({ preferences: user.preferences })\n);\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Pick and Omit on Union Types"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When "
          },
          {
            "type": "text",
            "text": "T",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " is a union, Pick and Omit behave differently from what you might expect. "
          },
          {
            "type": "text",
            "text": "Pick",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " distributes and keeps only the keys shared by all union members; "
          },
          {
            "type": "text",
            "text": "Omit",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " also distributes but removes from each member independently."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "type Shape =\n  | { kind: 'circle';    radius: number; color: string }\n  | { kind: 'rectangle'; width: number; height: number; color: string };\n\n// Omit distributes correctly over discriminated unions\ntype ShapeWithoutColor = Omit<Shape, 'color'>;\n// { kind: 'circle'; radius: number } | { kind: 'rectangle'; width: number; height: number }\n// The discriminant 'kind' is preserved \u2014 union is still discriminated\n\n// BUT: Pick on a union only keeps SHARED keys\ntype ShapeKinds = Pick<Shape, 'kind' | 'color'>;\n// { kind: 'circle' | 'rectangle'; color: string }\n// radius, width, height are NOT shared \u2192 excluded from Pick result\n\n// To pick from each union member independently, use a distributive trick:\ntype DistributivePick<T, K extends keyof T> = T extends unknown ? Pick<T, K> : never;\ntype CircleOrRect = DistributivePick<Shape, 'kind'>;\n// { kind: 'circle' } | { kind: 'rectangle' }\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Custom StrictOmit"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The built-in "
          },
          {
            "type": "text",
            "text": "Omit",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " accepts any string key \u2014 even keys that do not exist in "
          },
          {
            "type": "text",
            "text": "T",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". This lenient constraint can hide typos. A "
          },
          {
            "type": "text",
            "text": "StrictOmit",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " variant constrains the excluded keys to "
          },
          {
            "type": "text",
            "text": "keyof T",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ":"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Built-in Omit \u2014 does NOT error on unknown keys\ntype A = Omit<{ a: string }, 'unknown'>; // same as { a: string } \u2014 silent\n\n// StrictOmit \u2014 errors on unknown keys (recommended for library authors)\ntype StrictOmit<T, K extends keyof T> = Pick<T, Exclude<keyof T, K>>;\n\ntype B = StrictOmit<{ a: string; b: number }, 'a'>;  // { b: number } \u2014 ok\ntype C = StrictOmit<{ a: string }, 'unknown'>;       // Error: 'unknown' is not keyof { a: string }\n\n// Most codebases use StrictOmit over the built-in when they want compile-time safety\n// on the excluded keys. Add it to your shared types utility file.\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "PickByValue and OmitByValue"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Standard Pick and Omit work on "
          },
          {
            "type": "text",
            "text": "key names",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": ". Sometimes you want to pick or omit properties based on their "
          },
          {
            "type": "text",
            "text": "value type",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " instead. These are common custom utilities built on top of mapped types:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Pick only properties whose value matches a specific type\ntype PickByValue<T, V> = {\n  [K in keyof T as T[K] extends V ? K : never]: T[K]\n};\n\ninterface Mixed {\n  id: string;\n  count: number;\n  name: string;\n  active: boolean;\n  weight: number;\n}\n\ntype Strings = PickByValue<Mixed, string>;  // { id: string; name: string }\ntype Numbers = PickByValue<Mixed, number>;  // { count: number; weight: number }\n\n// Omit only properties of a specific value type\ntype OmitByValue<T, V> = {\n  [K in keyof T as T[K] extends V ? never : K]: T[K]\n};\n\ntype NoNumbers = OmitByValue<Mixed, number>; // { id: string; name: string; active: boolean }\n\n// Angular: pick only Signal properties from a component state\nimport { Signal } from '@angular/core';\ntype SignalProps<T> = PickByValue<T, Signal<unknown>>;\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Building a Typed Update Function"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A common pattern is a generic update function where the caller provides an object ID plus a partial update of only the mutable fields. Pick and Omit help express this precisely:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Generic entity update \u2014 server manages id and timestamps\ntype ServerManaged = 'id' | 'createdAt' | 'updatedAt';\ntype UpdatePayload<T> = Partial<Omit<T, ServerManaged>>;\n\nfunction updateEntity<T extends { id: string }>(\n  id: string,\n  patch: UpdatePayload<T>,\n  endpoint: string\n): Promise<T> {\n  return fetch(`${endpoint}/${id}`, {\n    method: 'PATCH',\n    body: JSON.stringify(patch),\n    headers: { 'Content-Type': 'application/json' },\n  }).then(r => r.json());\n}\n\n// Usage with any entity\ninterface Order {\n  id: string;\n  status: 'pending' | 'shipped' | 'delivered';\n  items: { productId: string; qty: number }[];\n  total: number;\n  createdAt: Date;\n  updatedAt: Date;\n}\n\nconst result = updateEntity<Order>('order-1', { status: 'shipped' }, '/api/orders');\n// TypeScript infers patch as Partial<Omit<Order, 'id' | 'createdAt' | 'updatedAt'>>\n// Prevents setting id/timestamps in the patch object\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Intersection of Pick Results"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When you need several separate subsets of a type \u2014 perhaps for different contexts \u2014 you can define them individually with Pick and intersect them where you need everything:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "interface BlogPost {\n  id: string;\n  title: string;\n  slug: string;\n  body: string;\n  summary: string;\n  authorId: string;\n  tags: string[];\n  publishedAt: Date | null;\n  viewCount: number;\n  featuredImage: string | null;\n}\n\n// Purpose-specific shapes\ntype PostListItem  = Pick<BlogPost, 'id' | 'title' | 'slug' | 'summary' | 'publishedAt'>;\ntype PostMetadata  = Pick<BlogPost, 'id' | 'authorId' | 'tags' | 'publishedAt'>;\ntype PostContent   = Pick<BlogPost, 'id' | 'title' | 'body' | 'featuredImage'>;\n\n// Combine for a specific view that needs two subsets\ntype PostDetailView = PostContent & PostMetadata;\n// All fields from both Pick types \u2014 no duplication of field names\n\n// Angular: each component uses only its required shape\n@Component({ selector: 'app-post-list-item', template: '...' })\nexport class PostListItemComponent {\n  @Input({ required: true }) post!: PostListItem;\n}\n\n@Component({ selector: 'app-post-detail', template: '...' })\nexport class PostDetailComponent {\n  @Input({ required: true }) post!: PostDetailView;\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing with Pick and Omit"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Precise test fixtures using Pick \u2014 only include relevant fields\nfunction createUserFixture(overrides: Partial<Pick<User, 'name' | 'email' | 'role'>> = {}): User {\n  return {\n    id: 'test-id',\n    name: 'Test User',\n    email: 'test@example.com',\n    passwordHash: 'hash',\n    role: 'user',\n    createdAt: new Date('2024-01-01'),\n    updatedAt: new Date('2024-01-01'),\n    ...overrides,\n  };\n}\n\n// Test an update service \u2014 use Omit to avoid requiring server fields\nconst updatePayload: Partial<Omit<User, 'id' | 'createdAt' | 'updatedAt'>> = {\n  name: 'Updated Name',\n};\n\nit('updates user name', async () => {\n  const user = createUserFixture();\n  const result = await userService.update(user.id, updatePayload);\n  expect(result.name).toBe('Updated Name');\n  expect(result.id).toBe(user.id); // server field unchanged\n});\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Pick<T, K>",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " selects a subset of properties by name \u2014 use when the kept set is small."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Omit<T, K>",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " removes properties by name \u2014 use when the excluded set is small."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  "They are inverses: Pick<T, K> \u2261 Omit<T, Exclude<keyof T, K>> for a non-union T."
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  "Combine with Partial, Required, Readonly to express any API payload shape from a single canonical model."
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  "In Angular: Pick creates view models and component input shapes; Omit creates create/update payloads by removing server-managed fields."
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "On union types, "
                  },
                  {
                    "type": "text",
                    "text": "Omit",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " distributes correctly; "
                  },
                  {
                    "type": "text",
                    "text": "Pick",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " only keeps shared keys \u2014 use a distributive helper for per-member picking."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}