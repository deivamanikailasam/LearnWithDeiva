    "content": [
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "keyof & typeof Operators"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "TypeScript provides two reflection operators that work at the type level. "
          },
          {
            "type": "text",
            "text": "keyof",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " takes a type and produces a union of its property key names. "
          },
          {
            "type": "text",
            "text": "typeof",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " (in type position) takes a value and produces its TypeScript type. Together they allow you to derive types from existing code, keeping types in sync automatically when the underlying code changes."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "keyof takes a TYPE and returns a union of key names; typeof takes a VALUE and returns its TypeScript type",
          "title": null
        }
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "The keyof Operator"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "interface Product {\n  id: string;\n  name: string;\n  price: number;\n  inStock: boolean;\n}\n\n// keyof on an interface \u2192 union of string literal keys\ntype ProductKey = keyof Product; // 'id' | 'name' | 'price' | 'inStock'\n\n// Use in a generic constraint \u2014 K must be a key of T\nfunction getField<T, K extends keyof T>(obj: T, key: K): T[K] {\n  return obj[key];\n}\n\nconst p: Product = { id: 'p1', name: 'Widget', price: 9.99, inStock: true };\nconst name  = getField(p, 'name');    // string\nconst price = getField(p, 'price');   // number\n// getField(p, 'unknown'); // Error: 'unknown' is not keyof Product\n\n// keyof on a type with index signature \u2192 string | number\ninterface Dict { [key: string]: number }\ntype DictKey = keyof Dict; // string | number  (number for JS obj[0] \u2261 obj['0'])\n\n// keyof any \u2192 string | number | symbol (all possible key types)\ntype AnyKey = keyof any; // string | number | symbol\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "The typeof Operator (Type Position)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "JavaScript's "
          },
          {
            "type": "text",
            "text": "typeof",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " at runtime returns a string like "
          },
          {
            "type": "text",
            "text": "'string'",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " or "
          },
          {
            "type": "text",
            "text": "'object'",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". TypeScript overloads this with a compile-time "
          },
          {
            "type": "text",
            "text": "typeof",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " that works in type position \u2014 it captures the full static type of a variable, parameter, or return value."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// typeof a primitive\nconst count = 42;\ntype CountType = typeof count; // number (or 42 with as const)\n\nconst count2 = 42 as const;\ntype CountType2 = typeof count2; // 42  (literal type)\n\n// typeof an object \u2014 captures its shape\nconst defaultConfig = {\n  host: 'localhost',\n  port: 3000,\n  debug: false,\n};\n\ntype Config = typeof defaultConfig;\n// { host: string; port: number; debug: boolean }\n\n// typeof a function \u2014 captures its signature\nfunction greet(name: string, formal: boolean): string {\n  return formal ? `Good day, ${name}.` : `Hey, ${name}!`;\n}\n\ntype GreetFn = typeof greet; // (name: string, formal: boolean) => string\n\n// typeof a class (constructor type, not instance type)\nclass Logger {\n  log(msg: string): void { console.log(msg); }\n}\n\ntype LoggerConstructor = typeof Logger; // typeof Logger (class constructor)\ntype LoggerInstance    = InstanceType<typeof Logger>; // Logger (instance)\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Combining keyof and typeof"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The combination "
          },
          {
            "type": "text",
            "text": "keyof typeof value",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " is a very common pattern \u2014 it derives a union of the literal keys of a runtime value. This is the idiomatic way to get a type for the keys of a const object or enum-like object."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Const object as enum replacement\nconst Direction = {\n  Up:    'UP',\n  Down:  'DOWN',\n  Left:  'LEFT',\n  Right: 'RIGHT',\n} as const;\n\ntype DirectionKey   = keyof typeof Direction;  // 'Up' | 'Down' | 'Left' | 'Right'\ntype DirectionValue = typeof Direction[keyof typeof Direction]; // 'UP' | 'DOWN' | 'LEFT' | 'RIGHT'\n\nfunction move(dir: DirectionValue): void {\n  console.log(`Moving ${dir}`);\n}\n\nmove(Direction.Up);    // ok: 'UP'\nmove('UP');            // ok: literal matches\nmove('up');            // Error: not in the union\n\n// The pattern works for any const object:\nconst HTTP_STATUS = { OK: 200, NOT_FOUND: 404, SERVER_ERROR: 500 } as const;\ntype StatusCode = typeof HTTP_STATUS[keyof typeof HTTP_STATUS]; // 200 | 404 | 500\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "keyof with Generics"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Pick: select a subset of properties (from TypeScript stdlib)\ntype Pick<T, K extends keyof T> = { [P in K]: T[P] };\n\ninterface User { id: number; name: string; email: string; role: string }\ntype UserSummary = Pick<User, 'id' | 'name'>; // { id: number; name: string }\n\n// OmitBy: remove properties whose value matches a type\ntype OmitByValue<T, V> = {\n  [K in keyof T as T[K] extends V ? never : K]: T[K]\n};\ntype OnlyStrings = OmitByValue<User, number>; // { name: string; email: string; role: string }\n\n// Restrict function params to writable (non-readonly) keys only\ntype WritableKeys<T> = {\n  [K in keyof T]-?: Equal<{ [P in K]: T[P] }, { -readonly [P in K]: T[P] }> extends true ? K : never\n}[keyof T];\ntype Equal<A, B> = [A] extends [B] ? [B] extends [A] ? true : false : false;\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "typeof with ReturnType and Parameters"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Infer types from existing functions without importing their explicit type\nfunction createUser(name: string, role: 'admin' | 'user') {\n  return { id: crypto.randomUUID(), name, role, createdAt: new Date() };\n}\n\n// Derive the return type without a separate interface\ntype NewUser = ReturnType<typeof createUser>;\n// { id: string; name: string; role: 'admin' | 'user'; createdAt: Date }\n\n// Derive parameter types\ntype CreateUserParams = Parameters<typeof createUser>;\n// [name: string, role: 'admin' | 'user']\n\n// Derive first argument type\ntype UserName = Parameters<typeof createUser>[0]; // string\n\n// Pattern: use typeof to build a factory type from an existing function\ntype ServiceFactory<T> = (...args: Parameters<T extends (...a: never[]) => unknown ? T : never>) =>\n  ReturnType<T extends (...a: never[]) => unknown ? T : never>;\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Angular Patterns"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Typed Component Inputs from Interface"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Derive @Input property names from the component's public interface\ninterface ButtonProps {\n  label: string;\n  variant: 'primary' | 'secondary' | 'danger';\n  disabled?: boolean;\n  size?: 'sm' | 'md' | 'lg';\n}\n\n// All valid input keys \u2014 safe to iterate\ntype ButtonInputKey = keyof ButtonProps;\n// 'label' | 'variant' | 'disabled' | 'size'\n\n@Component({ selector: 'app-button', template: '...' })\nexport class ButtonComponent implements ButtonProps {\n  @Input({ required: true }) label!: string;\n  @Input({ required: true }) variant!: 'primary' | 'secondary' | 'danger';\n  @Input() disabled?: boolean;\n  @Input() size?: 'sm' | 'md' | 'lg';\n}\n\n// Utility: programmatically set any input\nfunction setInput<T, K extends keyof T>(component: T, key: K, value: T[K]): void {\n  component[key] = value;\n}\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "typeof for Service Injection Tokens"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { InjectionToken } from '@angular/core';\n\n// Create a typed injection token from an existing const object\nconst DEFAULT_THEME = {\n  primary:   '#3b82f6',\n  secondary: '#64748b',\n  danger:    '#ef4444',\n} as const;\n\n// The token's type is derived from the value \u2014 no separate interface needed\ntype Theme = typeof DEFAULT_THEME;\nconst THEME_TOKEN = new InjectionToken<Theme>('THEME');\n\n// In a component \u2014 injection type matches the const structure\nclass ThemeService {\n  readonly theme = inject(THEME_TOKEN);\n  // theme.primary is typed as '#3b82f6' (literal), not just string\n}\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "keyof for Route Data Typing"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { Route } from '@angular/router';\n\n// Extend Route with known custom data keys\nconst ROUTE_META_KEYS = ['title', 'requiredRoles', 'breadcrumb'] as const;\ntype RouteMetaKey = typeof ROUTE_META_KEYS[number];\n// 'title' | 'requiredRoles' | 'breadcrumb'\n\n// Guard service only checks known keys\nclass RouteGuardService {\n  checkMeta(route: Route, key: RouteMetaKey): unknown {\n    return route.data?.[key];\n  }\n}\n\n// Usage in route config \u2014 TypeScript can check known keys\nconst routes: Route[] = [\n  {\n    path: 'admin',\n    data: { title: 'Admin Panel', requiredRoles: ['admin'], breadcrumb: 'Admin' },\n    component: AdminComponent\n  }\n];\n"
          }
        ]
