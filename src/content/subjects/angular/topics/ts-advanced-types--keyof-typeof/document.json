      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "TypeScript enums are both values and types. "
          },
          {
            "type": "text",
            "text": "typeof",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " on an enum gives you the constructor type (an object with all enum members as properties), not the instance type. This is useful when you want to accept the enum object itself rather than one of its values."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "enum Role {\n  Admin   = 'admin',\n  User    = 'user',\n  Guest   = 'guest',\n}\n\n// typeof Role = the class/object type (has Admin, User, Guest as properties)\n// Role       = the union of its value types ('admin' | 'user' | 'guest')\n\ntype RoleEnum  = typeof Role;\n// { Admin: 'admin'; User: 'user'; Guest: 'guest' }\n// (+ prototype members)\n\n// Function that accepts the enum object and validates a value against it\nfunction isValidRole(value: string, enumObj: typeof Role): value is Role {\n  return Object.values(enumObj).includes(value as Role);\n}\n\nisValidRole('admin', Role); // true\nisValidRole('root',  Role); // false\n\n// keyof typeof Role = the key names (not values)\ntype RoleKey = keyof typeof Role; // 'Admin' | 'User' | 'Guest'\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "typeof in Function Overloads"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "In overloaded functions, "
          },
          {
            "type": "text",
            "text": "typeof",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " lets you check the type of an argument at runtime while keeping the static type precisely narrowed. This bridges runtime and compile-time type information."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Overloaded function with typeof guard\nfunction process(input: string): string;\nfunction process(input: number): number;\nfunction process(input: string | number): string | number {\n  if (typeof input === 'string') {\n    return input.trim().toLowerCase();\n  }\n  return Math.round(input);\n}\n\nconst s = process('  Hello  '); // string\nconst n = process(3.14);        // number\n\n// typeof in type predicate for union narrowing\ntype StringOrArray = string | string[];\n\nfunction ensureArray(val: StringOrArray): string[] {\n  if (typeof val === 'string') {\n    return [val];  // TypeScript knows val is string here\n  }\n  return val;      // TypeScript knows val is string[] here\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "keyof string \u2192 string | number | symbol Surprises"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Pitfall: keyof on a primitive type produces its prototype methods\ntype StringKeys = keyof string;\n// 'length' | 'toString' | 'charAt' | 'charCodeAt' | ... (all string prototype methods)\n\n// This is rarely what you want\n// Constrain with '& string' to keep only string keys:\nfunction getKey<T, K extends keyof T & string>(obj: T, key: K): T[K] {\n  return obj[key];\n}\n\n// Pitfall: keyof on a union picks SHARED keys only\ntype A = { x: number; y: string };\ntype B = { x: number; z: boolean };\ntype C = A | B;\ntype CKeys = keyof C; // 'x' only \u2014 y and z not shared between A and B\n// To get ALL keys: keyof A | keyof B\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "typeof on Mutable Variables Loses Literals"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Pitfall: typeof on a let variable gives the wide type\nlet status = 'active';\ntype StatusType = typeof status; // string (NOT 'active')\n\n// Fix 1: use const\nconst STATUS = 'active';\ntype StatusType2 = typeof STATUS; // 'active'\n\n// Fix 2: use as const on a let (less common)\nlet status2 = 'active' as const;\ntype StatusType3 = typeof status2; // 'active'\n\n// Fix 3: provide a type annotation\nlet status3: 'active' | 'inactive' = 'active';\ntype StatusType4 = typeof status3; // 'active' | 'inactive'\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing keyof and typeof Types"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Type tests \u2014 compile-time only\ntype Expect<T extends true> = T;\ntype Equal<A, B> = [A] extends [B] ? [B] extends [A] ? true : false : false;\n\ninterface TestModel { a: number; b: string; c: boolean }\n\ntype Tests = [\n  Expect<Equal<keyof TestModel, 'a' | 'b' | 'c'>>,\n  Expect<Equal<typeof 42, number>>,\n];\n\n// Runtime test: verify that keyof-derived keys match Object.keys\nit('keyof matches Object.keys at runtime', () => {\n  const obj: TestModel = { a: 1, b: 'x', c: true };\n  // At runtime, TypeScript's keyof == Object.keys for plain objects\n  const keys = Object.keys(obj) as (keyof TestModel)[];\n  expect(keys.sort()).toEqual(['a', 'b', 'c']);\n});\n\n// Runtime test: typeof-derived function works correctly\nfunction pick<T, K extends keyof T>(obj: T, keys: K[]): Pick<T, K> {\n  return Object.fromEntries(\n    keys.map(k => [k, obj[k]])\n  ) as Pick<T, K>;\n}\n\nit('pick() returns correct subset', () => {\n  const result = pick({ a: 1, b: 'x', c: true }, ['a', 'b']);\n  expect(result).toEqual({ a: 1, b: 'x' });\n});\n"
          }
        ]
      },
