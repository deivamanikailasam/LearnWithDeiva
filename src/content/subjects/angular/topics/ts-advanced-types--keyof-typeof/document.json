        "content": [
          {
            "type": "text",
            "text": "class UserService {\n  private cache: Map<string, User> = new Map();\n  protected config = { baseUrl: '/api' };\n  public readonly version = '1.0';\n\n  getUser(id: string): Promise<User | undefined> {\n    return Promise.resolve(this.cache.get(id));\n  }\n\n  updateUser(id: string, patch: Partial<User>): void {\n    // ...\n  }\n}\n\ntype PublicAPI = keyof UserService;\n// 'version' | 'getUser' | 'updateUser'\n// private 'cache' and protected 'config' are excluded\n\n// Use in a spy utility that mocks only public members\ntype MockService<T> = { [K in keyof T]: T[K] extends (...a: never[]) => unknown\n  ? jest.MockedFunction<T[K] & ((...a: never[]) => unknown)>\n  : T[K]\n};\n"
          }
