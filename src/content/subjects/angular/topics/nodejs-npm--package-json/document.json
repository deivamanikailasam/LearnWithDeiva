{"format": "tiptap/v1", "doc": {"type": "doc", "content": [{"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "What Is package.json?"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "package.json is the manifest file at the root of every Node.js project. It records project identity, the packages it depends on, runnable scripts, and metadata for tooling. Angular CLI generates one automatically in every new workspace and updates it as you add packages and configure libraries."}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Create a new package.json interactively with "}, {"type": "text", "marks": [{"type": "code"}], "text": "npm init"}, {"type": "text", "text": " or generate a minimal one immediately with "}, {"type": "text", "marks": [{"type": "code"}], "text": "npm init -y"}, {"type": "text", "text": "."}]}, {"type": "image", "attrs": {"src": "data:image/svg+xml;base64,", "alt": "package.json field map"}}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Identity Fields"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The identity fields describe what the package is. They matter for published libraries but are also useful convention for application projects."}]}, {"type": "codeBlock", "attrs": {"language": "json"}, "content": [{"type": "text", "text": "{\n  \"name\": \"@myorg/my-angular-app\",  // unique id on npm; scoped = @org/name\n  \"version\": \"1.0.0\",               // semver: MAJOR.MINOR.PATCH\n  \"description\": \"Admin dashboard\",\n  \"keywords\": [\"angular\", \"dashboard\"],\n  \"author\": \"Deiva <dev@example.com>\",\n  \"license\": \"MIT\",\n  \"private\": true                   // prevents accidental publish of an app\n}\n"}]}, {"type": "blockquote", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Always set "}, {"type": "text", "marks": [{"type": "code"}], "text": "\"private\": true"}, {"type": "text", "marks": [{"type": "bold"}], "text": " for Angular applications. "}, {"type": "text", "text": "It prevents accidentally running npm publish on an app \u2014 only library packages should be publishable."}]}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Dependency Fields"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Dependencies are version-ranged references to npm packages. npm resolves the ranges at install time and locks the exact resolved version in package-lock.json."}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Field"}]}]}, {"type": "tableHeader", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Installed in production?"}]}]}, {"type": "tableHeader", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Purpose"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "dependencies"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Yes"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Packages required at runtime \u2014 Angular framework, RxJS, shared libs"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "devDependencies"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "No (--omit=dev)"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Build and test tools \u2014 CLI, compilers, test runners, linters"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "peerDependencies"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "No (host provides)"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Compatibility contract for libraries \u2014 declares required Angular version"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "optionalDependencies"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Best-effort"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Non-critical add-ons \u2014 install fails are silently ignored"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "overrides"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "n/a"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Force a specific version for any transitive consumer"}]}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Typical Angular Application"}]}, {"type": "codeBlock", "attrs": {"language": "json"}, "content": [{"type": "text", "text": "{\n  \"dependencies\": {\n    \"@angular/animations\": \"^18.0.0\",\n    \"@angular/common\":     \"^18.0.0\",\n    \"@angular/compiler\":   \"^18.0.0\",\n    \"@angular/core\":       \"^18.0.0\",\n    \"@angular/forms\":      \"^18.0.0\",\n    \"@angular/platform-browser\":          \"^18.0.0\",\n    \"@angular/platform-browser-dynamic\":  \"^18.0.0\",\n    \"@angular/router\":     \"^18.0.0\",\n    \"rxjs\":                \"~7.8.0\",\n    \"tslib\":               \"^2.3.0\",\n    \"zone.js\":             \"~0.14.3\"\n  },\n  \"devDependencies\": {\n    \"@angular-devkit/build-angular\": \"^18.0.0\",\n    \"@angular/cli\":          \"^18.0.0\",\n    \"@angular/compiler-cli\": \"^18.0.0\",\n    \"typescript\":            \"~5.4.0\",\n    \"@types/node\":           \"^18.0.0\",\n    \"karma\":                 \"~6.4.0\",\n    \"karma-chrome-launcher\": \"~3.2.0\",\n    \"karma-jasmine\":         \"~5.1.0\",\n    \"jasmine-core\":          \"~5.1.0\"\n  }\n}\n"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Typical Angular Library"}]}, {"type": "codeBlock", "attrs": {"language": "json"}, "content": [{"type": "text", "text": "{\n  \"peerDependencies\": {\n    \"@angular/core\": \">=17.0.0 <19.0.0\"\n  },\n  \"peerDependenciesMeta\": {\n    \"@angular/animations\": { \"optional\": true }  // mark a peer as optional\n  }\n}\n"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "The scripts Field"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The "}, {"type": "text", "marks": [{"type": "code"}], "text": "scripts"}, {"type": "text", "text": " field maps short command names to shell commands. npm recognises pre and post hooks, so you can chain setup and teardown steps automatically."}]}, {"type": "codeBlock", "attrs": {"language": "json"}, "content": [{"type": "text", "text": "{\n  \"scripts\": {\n    \"ng\":        \"ng\",\n    \"start\":     \"ng serve\",\n    \"start:prod\":\"ng serve --configuration production\",\n    \"build\":     \"ng build\",\n    \"test\":      \"ng test\",\n    \"lint\":      \"ng lint\",\n    \"e2e\":       \"ng e2e\",\n    \"prebuild\":  \"node scripts/check-env.js\",   // auto-runs before 'build'\n    \"postbuild\": \"node scripts/copy-robots.js\", // auto-runs after 'build'\n    \"analyze\":   \"ng build --stats-json && npx webpack-bundle-analyzer dist/stats.json\",\n    \"format\":    \"prettier --write \"src/**/*.{ts,html,scss}\"\"\n  }\n}\n"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Running Scripts"}]}, {"type": "codeBlock", "attrs": {"language": "bash"}, "content": [{"type": "text", "text": "npm start           # 'start' skips the 'run' keyword\nnpm test            # same for 'test' and 'stop'\nnpm run build       # all other scripts need 'run'\nnpm run analyze\nnpm run build -- --configuration staging   # pass extra args after --\n"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Script Variables"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Scripts can access the package version via "}, {"type": "text", "marks": [{"type": "code"}], "text": "$npm_package_version"}, {"type": "text", "text": " and all other package.json fields via the "}, {"type": "text", "marks": [{"type": "code"}], "text": "npm_package_*"}, {"type": "text", "text": " environment prefix:"}]}, {"type": "codeBlock", "attrs": {"language": "json"}, "content": [{"type": "text", "text": "{\n  \"version\": \"2.1.0\",\n  \"scripts\": {\n    \"version-check\": \"echo Building version $npm_package_version\"\n  }\n}\n"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Module System Fields"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "When publishing an Angular library as an npm package, these fields tell consuming build tools which module format to use."}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Field"}]}]}, {"type": "tableHeader", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Format"}]}]}, {"type": "tableHeader", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Purpose"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "main"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "CommonJS"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Node.js require() entry point"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "module"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "ESM"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Tree-shaking-friendly entry for bundlers (Webpack, Rollup, esbuild)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "exports"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Conditional"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Modern entry-point map with conditional subpath exports"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "type"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "module | commonjs"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Default module format for .js files in the package"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "typings"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "TypeScript"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Path to the generated .d.ts declaration file"}]}]}]}]}, {"type": "codeBlock", "attrs": {"language": "json"}, "content": [{"type": "text", "text": "{\n  \"main\":    \"dist/my-lib/index.js\",\n  \"module\":  \"dist/my-lib/esm2022/my-lib.mjs\",\n  \"typings\": \"dist/my-lib/index.d.ts\",\n  \"exports\": {\n    \".\": {\n      \"types\":   \"./dist/my-lib/index.d.ts\",\n      \"default\": \"./dist/my-lib/index.js\",\n      \"module\":  \"./dist/my-lib/esm2022/my-lib.mjs\"\n    },\n    \"./testing\": {\n      \"default\": \"./dist/my-lib/testing/index.js\"\n    }\n  }\n}\n"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "engines and browserslist"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "engines"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The "}, {"type": "text", "marks": [{"type": "code"}], "text": "engines"}, {"type": "text", "text": " field documents the minimum Node.js and npm versions the project requires. npm does not enforce this by default, but CI tools and package managers like Yarn/pnpm do."}]}, {"type": "codeBlock", "attrs": {"language": "json"}, "content": [{"type": "text", "text": "{\n  \"engines\": {\n    \"node\": \">=20.0.0\",\n    \"npm\":  \">=10.0.0\"\n  }\n}\n"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "browserslist"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The "}, {"type": "text", "marks": [{"type": "code"}], "text": "browserslist"}, {"type": "text", "text": " field (or a separate "}, {"type": "text", "marks": [{"type": "code"}], "text": ".browserslistrc"}, {"type": "text", "text": " file) tells Angular's build tools which browsers to support. It drives PostCSS autoprefixer and differential loading."}]}, {"type": "codeBlock", "attrs": {"language": "json"}, "content": [{"type": "text", "text": "{\n  \"browserslist\": [\n    \"last 1 Chrome version\",\n    \"last 1 Firefox version\",\n    \"last 2 Edge major versions\",\n    \"last 2 Safari major versions\",\n    \"last 2 iOS major versions\",\n    \"Firefox ESR\"\n  ]\n}\n"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Overrides Field"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The "}, {"type": "text", "marks": [{"type": "code"}], "text": "overrides"}, {"type": "text", "text": " field (npm 8.3+) forces all consumers in the dependency tree to use a specific version, regardless of what they request. Use it to patch security vulnerabilities in transitive dependencies when the direct dependency has not yet released a fix."}]}, {"type": "codeBlock", "attrs": {"language": "json"}, "content": [{"type": "text", "text": "{\n  \"overrides\": {\n    \"semver\": \">=7.5.2\",          // force all semver usages to >=7.5.2\n    \"tough-cookie\": \"^4.1.3\",\n    \"lodash\": {\n      \"lodash.merge\": \">=4.6.2\"   // nest to scope the override to one consumer\n    }\n  }\n}\n"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Config and Workspaces Fields"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "config"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The "}, {"type": "text", "marks": [{"type": "code"}], "text": "config"}, {"type": "text", "text": " field sets environment variables accessible to scripts via "}, {"type": "text", "marks": [{"type": "code"}], "text": "$npm_package_config_<key>"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "json"}, "content": [{"type": "text", "text": "{\n  \"config\": {\n    \"port\": \"4200\"\n  },\n  \"scripts\": {\n    \"start\": \"ng serve --port $npm_package_config_port\"\n  }\n}\n"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "workspaces"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The "}, {"type": "text", "marks": [{"type": "code"}], "text": "workspaces"}, {"type": "text", "text": " field enables npm monorepo support \u2014 multiple packages managed from a single root "}, {"type": "text", "marks": [{"type": "code"}], "text": "package.json"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "json"}, "content": [{"type": "text", "text": "{\n  \"workspaces\": [\n    \"packages/*\",    // all directories under packages/\n    \"apps/admin\",    // an explicit path\n    \"apps/portal\"\n  ]\n}\n"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Validating package.json"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Malformed package.json files fail silently or produce hard-to-diagnose errors. Validate and inspect the resolved manifest with these commands."}]}, {"type": "codeBlock", "attrs": {"language": "bash"}, "content": [{"type": "text", "text": "# Validate JSON syntax\nnode -e \"require('./package.json')\"\n\n# Print the fully resolved npm config for this package\nnpm pkg get name version description\n\n# Set or delete a field from the CLI (avoids manual JSON editing)\nnpm pkg set config.port=4300\nnpm pkg delete config.port\n\n# List all scripts\nnpm run\n\n# Check for unmet peer dependencies\nnpm ls\n"}]}, {"type": "horizontalRule"}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Version Ranges in Depth"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Version strings in dependency fields are not just exact numbers \u2014 they are "}, {"type": "text", "marks": [{"type": "bold"}], "text": "semver range expressions"}, {"type": "text", "text": ". npm resolves each range to the highest matching version available on the registry at install time."}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Expression"}]}]}, {"type": "tableHeader", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Matches"}]}]}, {"type": "tableHeader", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Common use"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "1.2.3"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Exactly 1.2.3"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Pinning a known-good version"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "^1.2.3"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": ">=1.2.3 <2.0.0 (same major)"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Most packages \u2014 allow minor & patch updates"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "~1.2.3"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": ">=1.2.3 <1.3.0 (same minor)"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "RxJS in Angular \u2014 conservative patch-only"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": ">=1.2.3 <2.0.0"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Explicit range"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Peer dependencies to allow multiple majors"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "1.x"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": ">=1.0.0 <2.0.0"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Shorthand for same-major"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "*"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Any version"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Avoid \u2014 installs latest major including breaking changes"}]}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Resolving Ranges"}]}, {"type": "codeBlock", "attrs": {"language": "bash"}, "content": [{"type": "text", "text": "# Check which version npm would actually install\nnpm info rxjs dist-tags     # see latest, next, beta tags\nnpm install rxjs@~7.8.0     # install constrained by ~\nnpm ls rxjs                  # confirm installed version\n"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Pinning with package-lock.json"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Range expressions in package.json allow updates. The "}, {"type": "text", "marks": [{"type": "code"}], "text": "package-lock.json"}, {"type": "text", "text": " is what actually pins the install. When you run "}, {"type": "text", "marks": [{"type": "code"}], "text": "npm ci"}, {"type": "text", "text": " in CI it installs the exact versions recorded in the lockfile, ignoring the ranges entirely."}]}, {"type": "blockquote", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Design intent: "}, {"type": "text", "text": "package.json ranges tell npm what is acceptable; package-lock.json records what was actually chosen. Always commit both."}]}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Lifecycle Scripts"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "npm defines a full set of lifecycle events that fire automatically around install, publish, and version bump operations. Angular CLI hooks into some of these automatically."}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Script"}]}]}, {"type": "tableHeader", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "When it runs"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "prepare"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "After npm install and before npm publish \u2014 ideal for build steps"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "prepublishOnly"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Only before npm publish (not on install) \u2014 safer than prepare for publish guards"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "preinstall"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Before dependencies are installed"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "postinstall"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "After dependencies are installed \u2014 used by some packages for native compilation"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "prepack"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Before npm pack / npm publish \u2014 useful for final validation"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "preversion"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Before npm version \u2014 good for running tests"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "postversion"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "After npm version \u2014 auto-push the generated git tag"}]}]}]}]}, {"type": "codeBlock", "attrs": {"language": "json"}, "content": [{"type": "text", "text": "{\n  \"scripts\": {\n    \"prepare\":       \"husky install\",      // set up git hooks (Husky)\n    \"prepublishOnly\":\"npm test && npm run lint\",\n    \"preversion\":    \"npm test\",\n    \"version\":       \"npm run build\",\n    \"postversion\":   \"git push && git push --tags\"\n  }\n}\n"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "files Field"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "When publishing a library, the "}, {"type": "text", "marks": [{"type": "code"}], "text": "files"}, {"type": "text", "text": " field is an allowlist of files and directories to include in the published tarball. Everything not listed is excluded, which keeps the tarball small and prevents shipping source maps, test files, and config files."}]}, {"type": "codeBlock", "attrs": {"language": "json"}, "content": [{"type": "text", "text": "{\n  \"files\": [\n    \"dist/my-lib\",   // the compiled output directory\n    \"README.md\",\n    \"CHANGELOG.md\"\n    // .gitignore, tsconfig.json, src/ etc. are automatically excluded\n  ]\n}\n"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Run "}, {"type": "text", "marks": [{"type": "code"}], "text": "npm pack --dry-run"}, {"type": "text", "text": " to see the exact list of files that would be included before publishing \u2014 essential for catching accidentally included secrets or build artifacts."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Angular-Specific package.json Sections"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "schematics"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Angular libraries that provide schematics (code generators) register them via the "}, {"type": "text", "marks": [{"type": "code"}], "text": "schematics"}, {"type": "text", "text": " or "}, {"type": "text", "marks": [{"type": "code"}], "text": "ng-add"}, {"type": "text", "text": " fields. The Angular CLI reads these when you run "}, {"type": "text", "marks": [{"type": "code"}], "text": "ng add"}, {"type": "text", "text": " or "}, {"type": "text", "marks": [{"type": "code"}], "text": "ng generate"}, {"type": "text", "text": "."}]}, {"type": "codeBlock", "attrs": {"language": "json"}, "content": [{"type": "text", "text": "{\n  \"schematics\": \"./schematics/collection.json\",\n  \"ng-add\": {\n    \"save\": \"dependencies\"\n  }\n}\n"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "builders"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Custom Angular builders register via the "}, {"type": "text", "marks": [{"type": "code"}], "text": "builders"}, {"type": "text", "text": " field, which points to a builders.json manifest."}]}, {"type": "codeBlock", "attrs": {"language": "json"}, "content": [{"type": "text", "text": "{\n  \"builders\": \"./builders.json\"\n}\n"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Resolving Angular Package Format (APF) Fields"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Angular publishes its own packages using the Angular Package Format, which specifies a set of exports for different module consumers. Understanding APF helps when debugging build issues."}]}, {"type": "codeBlock", "attrs": {"language": "json"}, "content": [{"type": "text", "text": "{\n  \"exports\": {\n    \".\": {\n      \"types\": \"./index.d.ts\",\n      \"esm2022\": \"./esm2022/index.mjs\",\n      \"esm\": \"./esm2022/index.mjs\",\n      \"default\": \"./fesm2022/index.mjs\"\n    },\n    \"./testing\": {\n      \"types\": \"./testing/index.d.ts\",\n      \"esm2022\": \"./esm2022/testing/index.mjs\",\n      \"default\": \"./fesm2022/testing.mjs\"\n    }\n  },\n  \"esm2022\": \"./esm2022/index.mjs\",\n  \"fesm2022\": \"./fesm2022/index.mjs\",\n  \"typings\": \"./index.d.ts\",\n  \"sideEffects\": false\n}\n"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "\"sideEffects\": false"}, {"type": "text", "text": " tells the bundler that all exports are pure and unused exports can be safely tree-shaken \u2014 important for keeping Angular app bundle sizes small."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Common Mistakes and How to Fix Them"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Mistake"}]}]}, {"type": "tableHeader", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Symptom"}]}]}, {"type": "tableHeader", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Fix"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Adding runtime package to devDependencies"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Works in dev; crashes in production (module not found)"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Move to dependencies"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Committing without package-lock.json"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Different versions in CI and local"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Always commit the lockfile"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Using * version range"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Breaking changes on next npm install"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use ^ or ~ with a known-good version"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Missing 'private: true' on an app"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Accidental npm publish"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Add \"private\": true"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Running postinstall script that modifies source files"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "CI differs from local"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Move to prepare or a manual npm run step"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Encoding JSON incorrectly (trailing commas)"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "npm ERR! JSON parse error"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use a JSON linter; npm init validates for you"}]}]}]}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Programmatic Access with npm pkg"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The "}, {"type": "text", "marks": [{"type": "code"}], "text": "npm pkg"}, {"type": "text", "text": " command reads and writes package.json fields from the command line without requiring manual JSON editing. This is useful in build scripts, CI pipelines, and schematics."}]}, {"type": "codeBlock", "attrs": {"language": "bash"}, "content": [{"type": "text", "text": "# Read fields\nnpm pkg get name\nnpm pkg get version\nnpm pkg get dependencies.rxjs\n\n# Set fields\nnpm pkg set name=\"@myorg/my-app\"\nnpm pkg set engines.node=\">=20.0.0\"\nnpm pkg set scripts.format=\"prettier --write src/**/*.ts\"\n\n# Delete fields\nnpm pkg delete config.port\n\n# Output as JSON (machine-readable)\nnpm pkg get --json dependencies\n"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Keeping package.json in Sync"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Checking for Outdated Packages"}]}, {"type": "codeBlock", "attrs": {"language": "bash"}, "content": [{"type": "text", "text": "# Show packages with available updates (respects semver range)\nnpm outdated\n\n# Output:\n# Package            Current  Wanted  Latest  Location\n# @angular/core       17.3.0  17.3.5  18.2.0  my-app\n# rxjs                 7.8.0   7.8.1   7.8.1  my-app\n"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Current"}, {"type": "text", "text": ": installed version. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Wanted"}, {"type": "text", "text": ": highest version within your semver range. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Latest"}, {"type": "text", "text": ": latest published version (may require a range update)."}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Interactive Update Tool"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "npm-check-updates"}, {"type": "text", "text": " (ncu) extends npm outdated by rewriting the ranges in package.json to the latest versions \u2014 including across major version boundaries."}]}, {"type": "codeBlock", "attrs": {"language": "bash"}, "content": [{"type": "text", "text": "# Preview what would change (does not modify anything)\nnpx npm-check-updates\n\n# Apply the updates to package.json then install\nnpx npm-check-updates -u && npm install\n\n# Update only Angular packages\nnpx npm-check-updates --filter @angular/* -u && npm install\n"}]}, {"type": "blockquote", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Run ng update instead of ncu for Angular packages. "}, {"type": "text", "text": "ng update runs Angular migration schematics that rename deprecated APIs, adjust module imports, and fix breaking changes in templates. A plain version bump without migrations will break Angular code."}]}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Security Considerations"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Supply-Chain Risks"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Every package you add brings its own dependency tree. A malicious package deep in your tree can execute arbitrary code during npm install via postinstall scripts. Mitigation:"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use "}, {"type": "text", "marks": [{"type": "code"}], "text": "npm audit"}, {"type": "text", "text": " regularly \u2014 it flags known CVEs in your tree."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Pin critical packages to exact versions using "}, {"type": "text", "marks": [{"type": "code"}], "text": "overrides"}, {"type": "text", "text": " when a transitive fix is unavailable."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Enable "}, {"type": "text", "marks": [{"type": "code"}], "text": "--ignore-scripts"}, {"type": "text", "text": " for trusted-install contexts where you only need files, not build steps."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Review the source of any package before adding it \u2014 check the GitHub repo, downloads, and maintainers on npmjs.com."}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Using npm audit in CI"}]}, {"type": "codeBlock", "attrs": {"language": "json"}, "content": [{"type": "text", "text": "{\n  \"scripts\": {\n    \"audit:ci\": \"npm audit --audit-level=moderate --json | tee audit-report.json\"\n  }\n}\n"}]}, {"type": "codeBlock", "attrs": {"language": "yaml"}, "content": [{"type": "text", "text": "# In GitHub Actions:\n- name: Security audit\n  run: npm audit --audit-level=high\n  # Only fails the build on high or critical vulnerabilities\n"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Summary"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "package.json is the single source of truth for your Angular project's identity, dependencies, build commands, and publishing metadata. Key points to remember:"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Set "}, {"type": "text", "marks": [{"type": "code"}], "text": "\"private\": true"}, {"type": "text", "text": " on applications to prevent accidental publish."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Split packages between "}, {"type": "text", "marks": [{"type": "code"}], "text": "dependencies"}, {"type": "text", "text": " (runtime) and "}, {"type": "text", "marks": [{"type": "code"}], "text": "devDependencies"}, {"type": "text", "text": " (build/test)."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Angular libraries declare a "}, {"type": "text", "marks": [{"type": "code"}], "text": "peerDependencies"}, {"type": "text", "text": " range for "}, {"type": "text", "marks": [{"type": "code"}], "text": "@angular/core"}, {"type": "text", "text": " \u2014 apps install the peer."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use "}, {"type": "text", "marks": [{"type": "code"}], "text": "pre/post"}, {"type": "text", "text": " script hooks to chain setup and teardown automatically."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "overrides"}, {"type": "text", "text": " patches transitive vulnerabilities without waiting for upstream fixes."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "engines"}, {"type": "text", "text": " documents Node.js version requirements; "}, {"type": "text", "marks": [{"type": "code"}], "text": "browserslist"}, {"type": "text", "text": " drives differential loading."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "exports"}, {"type": "text", "text": " is the modern way to expose multiple entry points from a published library."}]}]}]}]}}