            "type": "text",
            "text": "satisfies Operator"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The "
          },
          {
            "type": "text",
            "text": "satisfies",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " operator (TypeScript 4.9+) validates that a value conforms to a type, "
          },
          {
            "type": "text",
            "text": "without widening the inferred type",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " to that constraint. The difference from a type annotation is subtle but important: a type annotation replaces the inferred type with the annotation; "
          },
          {
            "type": "text",
            "text": "satisfies",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " keeps the inferred type while still performing the constraint check."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "satisfies vs type annotation: annotation widens type to constraint, satisfies validates constraint but preserves inferred type",
          "title": null
        }
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "The Problem satisfies Solves"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Problem: type annotation widens \u2014 you lose the specific inferred type\ninterface Config {\n  host: string | null;\n  port: number;\n}\n\n// With annotation \u2014 cfg.host is widened to string | null\nconst cfg1: Config = { host: 'localhost', port: 3000 };\ncfg1.host.toUpperCase(); // Error! string | null has no .toUpperCase()\n// Even though the actual value is a string, TypeScript sees string | null\n\n// With satisfies \u2014 cfg.host stays string\nconst cfg2 = { host: 'localhost', port: 3000 } satisfies Config;\ncfg2.host.toUpperCase(); // OK \u2014 TypeScript infers host as string\ncfg2.port.toFixed(2);   // OK \u2014 TypeScript infers port as number\n// The Config constraint is STILL checked:\nconst cfg3 = { host: 123, port: 3000 } satisfies Config; // Error: 123 is not string | null\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "satisfies with Union Values"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The most compelling use case is when a type has properties of different types within a union, and you want "
          },
          {
            "type": "text",
            "text": "per-property narrowing",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " without losing the discriminated union information."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "type ThemeValue = string | [number, number, number]; // hex string or RGB tuple\n\ninterface Theme {\n  primary:    ThemeValue;\n  background: ThemeValue;\n  accent:     ThemeValue;\n}\n\n// With type annotation \u2014 every property is string | [number, number, number]\n// TypeScript can't tell which branch each property uses\nconst themeAnnotated: Theme = {\n  primary:    '#3b82f6',\n  background: [15, 23, 42],\n  accent:     '#34d399',\n};\nthemeAnnotated.primary.toUpperCase();     // Error: ThemeValue has no .toUpperCase()\nthemeAnnotated.background[0].toFixed(0); // Error: ThemeValue has no [0]\n\n// With satisfies \u2014 TypeScript infers each property's specific type\nconst theme = {\n  primary:    '#3b82f6',\n  background: [15, 23, 42],\n  accent:     '#34d399',\n} satisfies Theme;\n\ntheme.primary.toUpperCase();      // OK \u2014 inferred as string\ntheme.background[0].toFixed(0);  // OK \u2014 inferred as [number, number, number]\ntheme.accent.startsWith('#');     // OK \u2014 inferred as string\n"
          }
        ]
      },
