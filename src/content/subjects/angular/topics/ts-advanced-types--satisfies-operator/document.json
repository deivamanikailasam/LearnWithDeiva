      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "const ROUTES = {\n  home:    '/',\n  about:   '/about',\n  profile: '/profile/:id',\n} satisfies Record<string, `/${string}`>;\n// Each value stays its specific string literal (not widened to string)\n// Extra keys with non-path values would error\n\nROUTES.home;    // '/'  (literal type)\nROUTES.about;   // '/about' (literal type)\n\n// Combine with as const for maximum narrowness:\nconst COLORS = {\n  red:   '#ef4444',\n  green: '#22c55e',\n  blue:  '#3b82f6',\n} as const satisfies Record<string, `#${string}`>;\n\ntype ColorName = keyof typeof COLORS;   // 'red' | 'green' | 'blue'\ntype ColorHex  = typeof COLORS[ColorName]; // '#ef4444' | '#22c55e' | '#3b82f6' (literals!)\n"
          }
        ]
      },
