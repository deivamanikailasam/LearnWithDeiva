      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "satisfies",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " validates a value against a type without widening the inferred type to that constraint."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  "Use satisfies when you want the constraint checked but need to use the specific inferred types downstream (string methods, tuple indexing, etc.)."
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The trifecta: "
                  },
                  {
                    "type": "text",
                    "text": "as const",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " for literal narrowing, "
                  },
                  {
                    "type": "text",
                    "text": ": Type",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " annotation for explicit widening, "
                  },
                  {
                    "type": "text",
                    "text": "satisfies",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
