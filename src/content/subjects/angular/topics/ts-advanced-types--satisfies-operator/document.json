      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Typed Route Config"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { Routes } from '@angular/router';\n\ninterface ExtendedRoute {\n  path: string;\n  title?: string;\n  data?: { roles?: string[]; breadcrumb?: string };\n}\n\n// satisfies validates each route matches ExtendedRoute\n// but the inferred type preserves specific path strings for refactoring\nconst APP_ROUTES = [\n  { path: '',          loadComponent: () => import('./home.component').then(m => m.HomeComponent) },\n  { path: 'about',     loadComponent: () => import('./about.component').then(m => m.AboutComponent), title: 'About' },\n  { path: 'dashboard', loadComponent: () => import('./dashboard.component').then(m => m.DashboardComponent),\n    data: { roles: ['user', 'admin'], breadcrumb: 'Dashboard' } },\n] satisfies ExtendedRoute[];\n// TypeScript checks: every object has path: string, optional title, valid data shape\n// Inferred type: literal path strings are preserved for typeof APP_ROUTES[number]['path']\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Signal Store State"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { signal, computed } from '@angular/core';\n\ninterface UserState {\n  users: User[];\n  loading: boolean;\n  error: string | null;\n  selectedUserId: string | null;\n}\n\n// satisfies UserState validates the initial shape and specific types\nconst initialState = {\n  users:          [],\n  loading:        false,\n  error:          null,\n  selectedUserId: null,\n} satisfies UserState;\n\n// initialState.users is inferred as never[] (empty array literal)\n// \u2014 to keep it as User[] use the annotation form or cast:\nconst initialState2 = {\n  users:          [] as User[],\n  loading:        false,\n  error:          null,\n  selectedUserId: null,\n} satisfies UserState;\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Component Metadata Validation"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { Component } from '@angular/core';\n\n// Validate metadata while keeping specific inferred selector type\nconst COMPONENT_META = {\n  selector: 'app-user-card',\n  standalone: true,\n  changeDetection: 0, // ChangeDetectionStrategy.OnPush\n} satisfies Partial<Component>;\n\n// selector is still 'app-user-card' (literal), not just string\n// Works with object spread in @Component:\n@Component({\n  ...COMPONENT_META,\n  templateUrl: './user-card.component.html',\n})\nexport class UserCardComponent {}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "satisfies Does Not Narrow Unions"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "type Result = { ok: true; data: string } | { ok: false; error: string };\n\nconst r = { ok: true, data: 'hello' } satisfies Result;\n// r.ok is boolean, not true \u2014 satisfies checks against the union but doesn't narrow\n\n// To narrow, use a discriminant check:\nif (r.ok) {\n  r.data; // OK \u2014 TypeScript now knows r is the { ok: true } branch\n}\n\n// Or use as const to preserve the literal:\nconst r2 = { ok: true as const, data: 'hello' } satisfies Result;\n// r2.ok is now true (literal)\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Extra Properties Are Still Rejected"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "interface Minimal { name: string }\n\n// satisfies \u2014 extra keys ARE rejected (same as annotation in this respect)\nconst obj = {\n  name: 'Alice',\n  age: 30,       // Error: 'age' does not exist in type 'Minimal'\n} satisfies Minimal;\n\n// satisfies only differs from annotation in what type the variable gets\n// \u2014 the excess property check is identical\n"
          }
        ]
      },
