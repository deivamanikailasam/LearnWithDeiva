      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "satisfies for Configuration Objects"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Configuration objects are the most natural use case. You want TypeScript to verify every key and value type, but you also need the specific inferred types for IDE autocomplete and downstream type checking."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "interface AppConfig {\n  api: {\n    baseUrl: string;\n    timeout: number;\n    retries: number;\n  };\n  features: {\n    darkMode: boolean;\n    analytics: boolean;\n    betaFeatures: boolean;\n  };\n  logging: {\n    level: 'debug' | 'info' | 'warn' | 'error';\n    destinations: ('console' | 'file' | 'remote')[];\n  };\n}\n\n// satisfies validates shape and specific value types\nexport const config = {\n  api: {\n    baseUrl:  'https://api.myapp.com',\n    timeout:  5000,\n    retries:  3,\n  },\n  features: {\n    darkMode:     true,\n    analytics:    true,\n    betaFeatures: false,\n  },\n  logging: {\n    level:        'info',\n    destinations: ['console', 'remote'],\n  },\n} satisfies AppConfig;\n\n// Inferred type is precise \u2014 no need to cast:\nconfig.logging.level.toUpperCase();     // OK \u2014 'info' is a string\nconfig.api.timeout.toFixed(0);          // OK \u2014 5000 is a number\nconfig.features.betaFeatures.valueOf(); // OK \u2014 false is a boolean\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
