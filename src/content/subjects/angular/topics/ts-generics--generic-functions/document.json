          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Generic Functions"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A generic function is a function that accepts a type parameter — a placeholder resolved at each call site. The compiler infers the type from the arguments or uses an explicit type argument provided by the caller. This keeps code flexible without sacrificing type safety."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Non-generic — only works for strings\nfunction firstString(arr: string[]): string { return arr[0]; }\n\n// Generic — works for any type T\nfunction first<T>(arr: T[]): T { return arr[0]; }\n\nconst s = first(['a', 'b', 'c']); // T inferred as string; s: string\nconst n = first([1, 2, 3]);        // T inferred as number; n: number\nconst b = first([true, false]);    // T inferred as boolean\n\n// Explicit type argument — use when inference would widen the type\nconst x = first<string>(['hello']); // x: string, not 'hello'\n"
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Generic function anatomy diagram showing type parameter, parameter, and return type",
          "title": null
        }
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Type Parameter Syntax"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Function Declaration vs Arrow Function"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Function declaration — standard syntax\nfunction wrap<T>(value: T): { value: T } {\n  return { value };\n}\n\n// Arrow function — comma after T is needed in .tsx to avoid JSX ambiguity\nconst wrapArrow = <T,>(value: T): { value: T } => ({ value });\n\n// Method on a class — same angle-bracket syntax\nclass Box<T> {\n  constructor(private item: T) {}\n\n  map<U>(fn: (item: T) => U): Box<U> {\n    return new Box(fn(this.item));\n  }\n}\n\n// Method on an object literal\nconst utils = {\n  identity<T>(value: T): T { return value; },\n};"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Multiple Type Parameters"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Two type parameters — map from one type to another\nfunction zipWith<A, B, C>(\n  a: A[],\n  b: B[],\n  fn: (itemA: A, itemB: B) => C,\n): C[] {\n  const length = Math.min(a.length, b.length);\n  const result: C[] = [];\n  for (let i = 0; i < length; i++) {\n    result.push(fn(a[i], b[i]));\n  }\n  return result;\n}\n\nconst sums = zipWith([1, 2, 3], [10, 20, 30], (a, b) => a + b);\n// sums: number[] = [11, 22, 33]\n\nconst pairs = zipWith(['x', 'y'], [1, 2], (s, n) => ({ s, n }));\n// pairs: { s: string; n: number }[]\n\n// Three parameters — useful for type-safe pick\nfunction pick<T, K extends keyof T>(obj: T, ...keys: K[]): Pick<T, K> {\n  return keys.reduce((acc, k) => ({ ...acc, [k]: obj[k] }), {} as Pick<T, K>);\n}\n\nconst user = { id: 1, name: 'Alice', role: 'admin' };\nconst subset = pick(user, 'id', 'name'); // { id: number; name: string }"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Type Inference Rules"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "TypeScript infers type arguments from the concrete types of the arguments passed to the function. When multiple parameters share a type parameter, TypeScript unifies their types."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Single parameter — inference is direct\nfunction echo<T>(x: T): T { return x; }\necho(42);        // T = number\necho('hello');   // T = string\necho([1, 2]);    // T = number[]\n\n// Union inference when types differ\nfunction pair<T>(a: T, b: T): [T, T] { return [a, b]; }\npair(1, 2);           // T = number\npair('a', 'b');       // T = string\n// pair(1, 'a');      // Error: Argument of type 'string' is not assignable to T (inferred as number)\n\n// Contextual typing — inference from callback return\nconst mapped = [1, 2, 3].map(n => n * 2);\n// map<number, number>(callbackFn): number[]\n// TypeScript infers T=number from the array, U=number from the callback return type\n\n// Inference from nested generics\nfunction head<T>(arr: [T, ...unknown[]]): T { return arr[0]; }\nconst first = head([42, 'hello', true]); // first: number\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "When Inference Falls Through — Partial Inference"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// TypeScript infers ALL or NONE — no partial type argument inference\nfunction create<T, U>(value: T, transform: (v: T) => U): U {\n  return transform(value);\n}\n\n// Fully inferred — TypeScript knows T from value, U from the callback\nconst result = create(42, n => n.toFixed(2));\n// T = number, U = string; result: string\n\n// If you provide one, you must provide all explicitly\n// create<number>(42, n => n.toFixed(2));  // Error: Expected 2 type arguments\n\n// Workaround: curry the type parameters\nfunction createWith<T>(value: T) {\n  return <U>(transform: (v: T) => U): U => transform(value);\n}\n\nconst doubled = createWith(5)<number>(n => n * 2);\n// or let TypeScript infer U\nconst asString = createWith(5)(n => n.toFixed(2)); // string"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Constraints with extends"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A constraint limits which types may be substituted for a type parameter. The syntax is T extends SomeType — TypeScript only accepts types that are assignable to SomeType."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Constrain T to types that have a length property\nfunction longest<T extends { length: number }>(a: T, b: T): T {\n  return a.length >= b.length ? a : b;\n}\n\nlongest('hello', 'hi');           // T = string\nlongest([1, 2, 3], [4, 5]);       // T = number[]\nlongest({ length: 3 }, { length: 1 }); // T = { length: number }\n// longest(1, 2);  // Error: number has no 'length'\n\n// Constrain to a keyof type\nfunction getProperty<T, K extends keyof T>(obj: T, key: K): T[K] {\n  return obj[key];\n}\n\nconst name = getProperty({ id: 1, name: 'Alice' }, 'name'); // string\nconst id   = getProperty({ id: 1, name: 'Alice' }, 'id');   // number\n// getProperty({}, 'missing'); // Error: 'missing' is not a key\n\n// Constrain to an interface (class constraint)\ninterface HasId { id: number }\n\nfunction findById<T extends HasId>(items: T[], id: number): T | undefined {\n  return items.find(item => item.id === id);\n}\n\ninterface Product extends HasId { name: string; price: number }\nconst products: Product[] = [{ id: 1, name: 'Widget', price: 9.99 }];\nconst found = findById(products, 1); // found: Product | undefined\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Generic Functions in Angular"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Generic HTTP Service Methods"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { Injectable } from '@angular/core';\nimport { HttpClient } from '@angular/common/http';\nimport { Observable } from 'rxjs';\nimport { map } from 'rxjs/operators';\n\ninterface ApiResponse<T> {\n  data: T;\n  message: string;\n  status: number;\n}\n\n@Injectable({ providedIn: 'root' })\nexport class ApiService {\n  constructor(private http: HttpClient) {}\n\n  // Generic GET — caller specifies the expected response shape\n  get<T>(url: string): Observable<T> {\n    return this.http.get<ApiResponse<T>>(url).pipe(map(res => res.data));\n  }\n\n  post<T, B = unknown>(url: string, body: B): Observable<T> {\n    return this.http.post<ApiResponse<T>>(url, body).pipe(map(res => res.data));\n  }\n\n  // Paginated list — returns a generic Page wrapper\n  getPage<T>(url: string, page: number, size: number): Observable<Page<T>> {\n    return this.http.get<ApiResponse<Page<T>>>(url, {\n      params: { page: page.toString(), size: size.toString() },\n    }).pipe(map(res => res.data));\n  }\n}\n\ninterface Page<T> {\n  items: T[];\n  total: number;\n  page: number;\n  pageSize: number;\n}\n\n// Usage in a component\ninterface User { id: number; name: string; role: string }\n\n@Injectable({ providedIn: 'root' })\nexport class UserService {\n  constructor(private api: ApiService) {}\n\n  getUser(id: number): Observable<User> {\n    return this.api.get<User>(`/api/users/${id}`);\n  }\n\n  listUsers(page: number): Observable<Page<User>> {\n    return this.api.getPage<User>('/api/users', page, 20);\n  }\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Generic Signal Utility Functions"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { Signal, computed, signal } from '@angular/core';\n\n// Generic computed that derives from an array signal\nfunction computedArray<T, U>(\n  source: Signal<T[]>,\n  transform: (item: T) => U,\n): Signal<U[]> {\n  return computed(() => source().map(transform));\n}\n\n// Generic filter-by-id signal\nfunction findSignal<T extends { id: number }>(\n  source: Signal<T[]>,\n  idSignal: Signal<number | null>,\n): Signal<T | undefined> {\n  return computed(() => {\n    const id = idSignal();\n    return id === null ? undefined : source().find(item => item.id === id);\n  });\n}\n\n// Usage\nconst users = signal<User[]>([]);\nconst selectedId = signal<number | null>(null);\n\nconst names = computedArray(users, u => u.name);          // Signal<string[]>\nconst selected = findSignal(users, selectedId);            // Signal<User | undefined>\n\n// Generic debounced input utility\nfunction debouncedSignal<T>(source: Signal<T>, delayMs: number): Signal<T> {\n  // Implementation omitted; return type is Signal<T>\n  return computed(() => source()); // simplified placeholder\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Generic Guard and Validator Utilities"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Generic type predicate — narrow unknown to a typed value\nfunction hasShape<T extends object>(\n  value: unknown,\n  keys: (keyof T)[],\n): value is T {\n  if (typeof value !== 'object' || value === null) return false;\n  return keys.every(k => k in value);\n}\n\n// Usage in an HTTP interceptor or route guard\nconst raw: unknown = JSON.parse(response.body);\nif (hasShape<User>(raw, ['id', 'name', 'role'])) {\n  // raw: User — narrowed\n  console.log(raw.name);\n}\n\n// Angular route guard with generic required-role check\nfunction requireRole<T extends string>(allowedRoles: T[]) {\n  return (userRole: T): boolean => allowedRoles.includes(userRole);\n}\n\ntype AppRole = 'admin' | 'editor' | 'viewer';\nconst isAdmin  = requireRole<AppRole>(['admin']);\nconst canEdit  = requireRole<AppRole>(['admin', 'editor']);\n\nisAdmin('admin');  // true\ncanEdit('viewer'); // false"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Returning T from Inside a Callback"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Problem: returning any from JSON.parse defeats T\nfunction parseAs<T>(json: string): T {\n  return JSON.parse(json); // JSON.parse returns any — no real safety\n}\n\n// parseAs<User>('{\"id\": 1}')  — compiles but T is not validated at runtime\n\n// Better: validate with a type guard\nfunction parseAs2<T>(\n  json: string,\n  guard: (v: unknown) => v is T,\n): T | null {\n  try {\n    const parsed = JSON.parse(json);\n    return guard(parsed) ? parsed : null;\n  } catch {\n    return null;\n  }\n}\n\nfunction isUser(v: unknown): v is User {\n  return typeof v === 'object' && v !== null && 'id' in v && 'name' in v;\n}\n\nconst user = parseAs2('{\"id\":1,\"name\":\"Alice\"}', isUser);\n// user: User | null — safe"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Using any Inside a Generic — Defeating the Purpose"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// BAD — T becomes meaningless if cast to any inside\nfunction badWrap<T>(value: T): T {\n  const x: any = value;\n  return x.toString(); // any — TypeScript cannot catch the string return mismatch\n}\n\n// GOOD — keep types consistent\nfunction toString<T extends { toString(): string }>(value: T): string {\n  return value.toString();\n}\n\n// BAD — widening the return with unknown and casting\nfunction unsafeCast<T>(value: unknown): T {\n  return value as T; // no runtime check — callers can pass wrong types\n}\n\n// GOOD — pair with a type guard\nfunction safeCast<T>(value: unknown, guard: (v: unknown) => v is T): T | null {\n  return guard(value) ? value : null;\n}"
          }
        ]
      },
