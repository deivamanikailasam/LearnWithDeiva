{
  "format": "tiptap/v1",
  "doc": {
    "type": "doc",
    "content": [
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "ES Modules"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Every TypeScript file is an "
          },
          {
            "type": "text",
            "text": "ES module",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " \u2014 an isolated scope where top-level declarations are private unless exported with the "
          },
          {
            "type": "text",
            "text": "export",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " keyword. Files that contain at least one "
          },
          {
            "type": "text",
            "text": "import",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " or "
          },
          {
            "type": "text",
            "text": "export",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " are treated as modules. Files with neither are "
          },
          {
            "type": "text",
            "text": "scripts",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " where declarations leak into the global scope (which you typically want to avoid)."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "ES module export/import: user.service.ts exports named symbols and one default; app.component.ts imports selectively",
          "title": null
        }
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Named Exports"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Named exports let you export multiple values from a single file. The consumer picks which ones to import using destructuring syntax. The names "
          },
          {
            "type": "text",
            "text": "must match",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " between the export and the import (aliasing with "
          },
          {
            "type": "text",
            "text": "as",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " is the exception)."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// math.ts\nexport function add(a: number, b: number): number { return a + b; }\nexport function subtract(a: number, b: number): number { return a - b; }\nexport const PI = 3.14159;\nexport type Point = { x: number; y: number };\n\n// Alternatively, export all at the bottom of the file:\nfunction multiply(a: number, b: number): number { return a * b; }\nexport { multiply };\n\n// consumer.ts\nimport { add, PI, Point } from './math';\nimport { subtract as sub } from './math';  // rename on import\nimport * as math from './math';            // namespace import\n\nconsole.log(add(2, 3));       // 5\nconsole.log(math.PI);         // 3.14159\nconsole.log(sub(10, 4));      // 6\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Default Exports"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A module can have at most one "
          },
          {
            "type": "text",
            "text": "default",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " export. The consumer can import it under any name \u2014 no curly braces needed. Default exports are common for the "
          },
          {
            "type": "text",
            "text": "primary thing",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " a module provides (e.g. a single component or a single class)."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// logger.ts\nexport default class Logger {\n  log(message: string): void { console.log(message); }\n}\n\n// consumer.ts \u2014 name is chosen by the importer\nimport Logger from './logger';\nimport MyLog from './logger'; // also valid \u2014 same module default\n\nconst log = new Logger();\nlog.log('Hello');\n"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Prefer named exports in Angular apps. They give better tooling support (auto-import, rename refactoring) and make the module's API explicit. Default exports are harder to rename across a codebase."
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Re-exports and Barrel Files"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A "
          },
          {
            "type": "text",
            "text": "barrel file",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " (often "
          },
          {
            "type": "text",
            "text": "index.ts",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ") re-exports multiple modules through a single entry point. This simplifies import paths for consumers \u2014 they import from a folder, not deep file paths."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// src/app/services/index.ts \u2014 barrel\nexport { UserService } from './user.service';\nexport { AuthService } from './auth.service';\nexport { ProductService } from './product.service';\nexport type { User, Product } from './models';\n\n// consumer \u2014 clean import from the barrel\nimport { UserService, AuthService } from './services';\n// instead of:\nimport { UserService } from './services/user.service';\nimport { AuthService } from './services/auth.service';\n\n// Re-export everything from another module:\nexport * from './utils';\n// Re-export with rename:\nexport { default as MyComponent } from './my.component';\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Type-Only Imports and Exports"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "TypeScript 3.8+ added "
          },
          {
            "type": "text",
            "text": "import type",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " and "
          },
          {
            "type": "text",
            "text": "export type",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " to declare that an import or export is used only as a type \u2014 it is completely erased at compile time and never appears in the JavaScript output. This prevents accidental runtime side effects from importing a module just for its types."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Only types \u2014 erased at runtime, no module side-effect\nimport type { User, Role } from './user.model';\n\n// Mixed: value import + type import\nimport { UserService, type UserEvent } from './user.service';\n\n// Export only types\nexport type { User, Role } from './user.model';\n\n// The --verbatimModuleSyntax tsconfig flag (Angular 17+) enforces\n// that you MUST use 'import type' for type-only imports \u2014 the compiler\n// errors if you import a type without the type keyword.\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Module Resolution"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "TypeScript resolves module paths using the "
          },
          {
            "type": "text",
            "text": "moduleResolution",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " setting in tsconfig. Angular projects use "
          },
          {
            "type": "text",
            "text": "\"moduleResolution\": \"bundler\"",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " (Angular 17+) or "
          },
          {
            "type": "text",
            "text": "\"node\"",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " / "
          },
          {
            "type": "text",
            "text": "\"node16\"",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". The resolution order for a bare specifier like "
          },
          {
            "type": "text",
            "text": "'./auth'",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ":"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "./auth.ts",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 exact file"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "./auth/index.ts",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 directory index"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "TypeScript-specific paths from "
                  },
                  {
                    "type": "text",
                    "text": "tsconfig.json paths",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " mapping"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// tsconfig.json \u2014 path aliases for clean imports\n{\n  \"compilerOptions\": {\n    \"paths\": {\n      \"@app/*\": [\"src/app/*\"],\n      \"@shared/*\": [\"src/shared/*\"],\n      \"@env/*\": [\"src/environments/*\"]\n    }\n  }\n}\n\n// Component using aliases\nimport { AuthService } from '@app/services/auth.service';\nimport { ButtonComponent } from '@shared/components/button';\nimport { environment } from '@env/environment';\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Dynamic Imports"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Dynamic "
          },
          {
            "type": "text",
            "text": "import()",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " loads a module asynchronously \u2014 it returns a "
          },
          {
            "type": "text",
            "text": "Promise<module>",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". Angular uses this pattern for "
          },
          {
            "type": "text",
            "text": "lazy-loaded routes",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " so a feature's JavaScript is only downloaded when the user navigates there."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Lazy route in Angular router\nconst routes: Routes = [\n  {\n    path: 'admin',\n    // loadChildren returns a Promise \u2014 Angular downloads this chunk on demand\n    loadChildren: () => import('./admin/admin.routes').then(m => m.ADMIN_ROUTES)\n  },\n  {\n    path: 'dashboard',\n    loadComponent: () => import('./dashboard/dashboard.component')\n      .then(m => m.DashboardComponent)\n  }\n];\n\n// Manual dynamic import \u2014 code-split on demand\nasync function loadHeavyFeature(): Promise<void> {\n  const { HeavyService } = await import('./heavy-feature');\n  const svc = new HeavyService();\n  svc.run();\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Angular's Standalone Module System"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Standalone Components"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Angular 15+ standalone components use ES module imports directly in the "
          },
          {
            "type": "text",
            "text": "imports",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " array of "
          },
          {
            "type": "text",
            "text": "@Component",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". The component file acts as its own NgModule \u2014 you import what you need right where you need it."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { Component } from '@angular/core';\nimport { CommonModule } from '@angular/common';\nimport { ReactiveFormsModule } from '@angular/forms';\nimport { RouterModule } from '@angular/router';\nimport { ButtonComponent } from '@shared/components/button';\n\n@Component({\n  selector: 'app-login',\n  standalone: true,\n  imports: [\n    CommonModule,        // ngIf, ngFor, async\n    ReactiveFormsModule, // formGroup, formControl\n    RouterModule,        // routerLink\n    ButtonComponent      // your own component\n  ],\n  templateUrl: './login.component.html',\n})\nexport class LoginComponent {}\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Public API and Index Exports"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For shared libraries, always export through an index.ts barrel so consumers don't import internal paths:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// shared/index.ts\nexport { ButtonComponent } from './components/button/button.component';\nexport { InputComponent } from './components/input/input.component';\nexport { CardComponent } from './components/card/card.component';\nexport type { ButtonVariant } from './components/button/button.types';\n\n// app.component.ts \u2014 clean consumer-facing import\nimport { ButtonComponent, InputComponent } from '@shared'; // mapped to shared/index.ts\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Circular Imports"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "ES modules handle circular references but the behaviour is subtle. TypeScript compiles each file to CommonJS or ESM \u2014 in CommonJS, a circular import can produce an "
          },
          {
            "type": "text",
            "text": "undefined",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " value if the imported value has not been assigned yet at the time of import. In ESM native, circular imports are resolved via live bindings."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// a.ts\nimport { b } from './b';\nexport const a = 'A';\nconsole.log('a imports b:', b); // may be undefined in CommonJS if b hasn't finished loading\n\n// b.ts\nimport { a } from './a';\nexport const b = 'B';\nconsole.log('b imports a:', a); // may be undefined\n\n// To break cycles: extract shared code to a third file\n// shared.ts\nexport const SHARED = 'shared';\n\n// a.ts \u2014 import from shared, not from b\nimport { SHARED } from './shared';\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Script vs Module Files"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A TypeScript file with "
          },
          {
            "type": "text",
            "text": "no top-level imports or exports",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " is treated as a "
          },
          {
            "type": "text",
            "text": "script",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " \u2014 its declarations go into the global scope. This can cause unexpected name collisions. Adding "
          },
          {
            "type": "text",
            "text": "export {}",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " at the bottom turns any file into a module without exporting anything."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// types.ts \u2014 SCRIPT mode (no import/export)\ninterface User { id: string; name: string; }\n// User is now global \u2014 accessible in every file without importing!\n\n// types.ts \u2014 MODULE mode (add empty export)\ninterface User { id: string; name: string; }\nexport {};\n// Now User is local \u2014 you must import it where needed\n// This avoids accidental global pollution\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Ambient Modules and Declaration Files"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When importing a package that has no TypeScript types, you can declare an "
          },
          {
            "type": "text",
            "text": "ambient module",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " to silence the 'no type declarations' error and provide minimal types for your usage."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// typings/some-legacy-lib.d.ts\ndeclare module 'some-legacy-lib' {\n  export function doThing(config: object): void;\n  export const VERSION: string;\n}\n\n// After this declaration, TypeScript accepts:\nimport { doThing, VERSION } from 'some-legacy-lib';\ndoThing({ mode: 'fast' });\n\n// Wildcard ambient module \u2014 matches any path starting with the pattern\ndeclare module '*.svg' {\n  const content: string;\n  export default content;\n}\n\n// Allows importing SVG files (common in Vite/webpack apps)\nimport logoUrl from './logo.svg';\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Tree Shaking and Side-Effect Imports"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Modern bundlers (esbuild, Webpack, Rollup) remove dead exports through "
          },
          {
            "type": "text",
            "text": "tree shaking",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " \u2014 if you never import a function, it is not included in the bundle. To enable this, the bundler needs the "
          },
          {
            "type": "text",
            "text": "sideEffects",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " field in "
          },
          {
            "type": "text",
            "text": "package.json",
            "marks": [
              {
                "type": "code"
              }
            ]
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Side-effect import \u2014 no exported binding needed; imported for effect only\nimport 'reflect-metadata';        // sets up global Reflect polyfill\nimport '@angular/common/locales/en-GB'; // registers locale data\n\n// Pure value import \u2014 tree-shakable if unused\nimport { add } from './math';\n\n// Angular standalone components use tree shaking naturally:\n// If DashboardComponent never uses ButtonComponent, the bundler can drop it\n// (as long as ButtonComponent is in the imports array conditionally or not at all)\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Module Augmentation"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Module augmentation lets you "
          },
          {
            "type": "text",
            "text": "add to an existing module's types",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " without modifying the original file. This is the correct way to extend third-party library types."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Augment Angular's Router to add a custom property to Route\nimport { Route } from '@angular/router';\n\ndeclare module '@angular/router' {\n  interface Route {\n    // Add custom metadata accessible via ActivatedRoute.routeConfig.data\n    requiredRoles?: string[];\n  }\n}\n\n// Now this is valid:\nconst routes: Route[] = [\n  { path: 'admin', component: AdminComponent, requiredRoles: ['admin'] }\n];\n\n// Augment a third-party type\ndeclare module 'some-library' {\n  interface Config {\n    myCustomOption?: boolean;\n  }\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Importing Before the Module Finishes Loading"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Pitfall: using a singleton before it is initialised\n// services/singleton.ts\nlet instance: MyService | null = null;\nexport function getInstance(): MyService {\n  if (!instance) instance = new MyService();\n  return instance;\n}\n// Safe \u2014 uses a factory function, not an exported value initialised at module top-level\n\n// Unsafe pattern \u2014 circular dependency may produce undefined:\nexport const INSTANCE = new MyService(); // if MyService imports from a circular dep\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Namespace Imports Override Tree Shaking"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// BAD \u2014 namespace import forces the entire module into the bundle\nimport * as _ from 'lodash';\n_.debounce(() => {}, 300); // only debounce needed but entire lodash bundled\n\n// GOOD \u2014 named import; bundler can tree-shake other lodash functions\nimport { debounce } from 'lodash-es';\ndebounce(() => {}, 300);\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "tsconfig Module Settings"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// tsconfig.json relevant settings for Angular 17+ projects\n{\n  \"compilerOptions\": {\n    \"module\": \"ES2022\",           // emit native ESM syntax\n    \"moduleResolution\": \"bundler\", // Angular + esbuild resolution strategy\n    \"target\": \"ES2022\",\n    \"strict\": true,\n    \"verbatimModuleSyntax\": true,   // enforce import type for type-only imports\n    \"paths\": {\n      \"@app/*\": [\"src/app/*\"],\n      \"@shared/*\": [\"src/shared/*\"]\n    }\n  }\n}\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  "Every .ts file with an import or export is its own module scope \u2014 top-level names are private by default."
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  "Named exports: explicit names, must match on import, support multiple per file."
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  "Default export: one per module, consumer can choose any name."
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  "Barrel files (index.ts) re-export multiple symbols under a clean import path."
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "import type",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " / "
                  },
                  {
                    "type": "text",
                    "text": "export type",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " erases at compile time \u2014 no runtime side effect."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  "Dynamic import() is how Angular lazy-loads routes and heavy features."
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  "Standalone Angular components use the imports array \u2014 essentially an inline NgModule using ES module semantics."
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}