    "content": [
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Class Basics"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "TypeScript extends JavaScript classes with access modifiers, field declarations, constructor parameter shorthand, and readonly — all erased at compile time. Classes in TypeScript are both a value (a runtime constructor) and a type (the shape of instances). Understanding the basics here applies directly to Angular components, services, and directives, which are all classes."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "class Point {\n  x: number;\n  y: number;\n\n  constructor(x: number, y: number) {\n    this.x = x;\n    this.y = y;\n  }\n\n  distanceTo(other: Point): number {\n    return Math.sqrt((this.x - other.x) ** 2 + (this.y - other.y) ** 2);\n  }\n\n  toString(): string {\n    return `(${this.x}, ${this.y})`;\n  }\n}\n\nconst a = new Point(0, 0);\nconst b = new Point(3, 4);\nconsole.log(a.distanceTo(b)); // 5\nconsole.log(b.toString());    // (3, 4)\n"
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "TypeScript class anatomy showing field declarations with access modifiers, constructor with shorthand parameter properties, and methods",
          "title": null
        }
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Field Declarations"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Explicit Field vs Assigned in Constructor"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Option A: declare the field then assign in the constructor\nclass Explicit {\n  name: string;      // field declaration — required if strictPropertyInitialization is on\n\n  constructor(name: string) {\n    this.name = name; // assignment\n  }\n}\n\n// Option B: parameter property shorthand — declare + assign in one step\nclass Shorthand {\n  constructor(public name: string) {\n    // TypeScript generates: this.name = name;\n    // No separate field declaration needed\n  }\n}\n\n// Option C: class field initialiser — initialise directly\nclass WithDefault {\n  count = 0;            // initialised to 0\n  items: string[] = []; // initialised to []\n  label = 'default';\n}\n\n// Combining all three is valid\nclass Mixed {\n  createdAt = new Date(); // initialiser\n\n  constructor(\n    public readonly id: number,  // parameter property (public + readonly)\n    private name: string,        // parameter property (private)\n  ) {}\n\n  getCreatedAt(): Date { return this.createdAt; }\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Definite Assignment Assertion"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// TypeScript's strictPropertyInitialization requires every field\n// to be initialised in the constructor or have an explicit initialiser.\n// When you know initialisation happens outside the constructor (e.g. via DI),\n// use the ! postfix to suppress the error.\n\nclass UserComponent {\n  users!: string[];   // ! = \"I guarantee this will be initialised before use\"\n\n  ngOnInit(): void {\n    this.users = [];  // Angular lifecycle hook initialises it\n  }\n}\n\n// Angular-idiomatic — use inject() instead; avoid ! where possible\nimport { inject } from '@angular/core';\nimport { HttpClient } from '@angular/common/http';\n\nclass DataComponent {\n  private readonly http = inject(HttpClient); // always initialised — no !\n}"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Access Modifiers"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "TypeScript adds three access modifiers to JavaScript classes. They are compile-time only — the emitted JavaScript has no runtime enforcement."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "class BankAccount {\n  // public (default) — accessible from anywhere\n  public readonly owner: string;\n\n  // private — only accessible within this class body\n  private balance: number;\n\n  // protected — accessible within this class and subclasses\n  protected transactionCount = 0;\n\n  constructor(owner: string, initialBalance: number) {\n    this.owner = owner;\n    this.balance = initialBalance;\n  }\n\n  deposit(amount: number): void {\n    if (amount <= 0) throw new RangeError('Amount must be positive');\n    this.balance += amount;\n    this.transactionCount++;\n  }\n\n  withdraw(amount: number): void {\n    if (amount > this.balance) throw new RangeError('Insufficient funds');\n    this.balance -= amount;\n    this.transactionCount++;\n  }\n\n  getBalance(): number { return this.balance; }\n}\n\nconst account = new BankAccount('Alice', 1000);\naccount.deposit(500);\nconsole.log(account.getBalance()); // 1500\nconsole.log(account.owner);        // 'Alice' — public\n// account.balance; // Error: Property 'balance' is private"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "ECMAScript Private Fields (#)"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// TypeScript private is compile-time only\n// ECMAScript private fields (# prefix) are enforced at runtime in JS too\n\nclass SafeCounter {\n  #count = 0; // runtime-private — not accessible from outside even in JS\n\n  increment(): void { this.#count++; }\n  get value(): number { return this.#count; }\n}\n\nconst c = new SafeCounter();\nc.increment();\nc.increment();\nconsole.log(c.value); // 2\n// console.log(c.#count); // SyntaxError in JS, Error in TS\n\n// TypeScript private vs # — use TypeScript private for DI-related code\n// where Angular's metadata reflection needs to see constructors.\n// Use # for model classes where true runtime encapsulation matters."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "readonly"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "class Config {\n  readonly apiUrl: string;\n  readonly maxRetries = 3;  // initialiser — no constructor needed\n\n  constructor(apiUrl: string) {\n    this.apiUrl = apiUrl;\n    // this.maxRetries = 5; // Error: cannot assign to readonly property\n  }\n\n  // Method cannot mutate readonly either\n  // setUrl(url: string): void { this.apiUrl = url; } // Error\n}\n\nconst cfg = new Config('https://api.example.com');\nconsole.log(cfg.apiUrl);     // 'https://api.example.com'\n// cfg.apiUrl = 'other';    // Error: readonly\n\n// readonly only prevents reassignment of the property itself —\n// it does NOT deep-freeze arrays or objects\nclass Store {\n  readonly items: string[] = [];\n\n  add(item: string): void {\n    this.items.push(item); // OK — mutating the array, not reassigning the property\n    // this.items = [];    // Error — reassignment\n  }\n}"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Methods, Getters, and Setters"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "class Temperature {\n  private _celsius: number;\n\n  constructor(celsius: number) {\n    this._celsius = celsius;\n  }\n\n  // Getter — accessed as a property, not a method call\n  get fahrenheit(): number {\n    return this._celsius * 9 / 5 + 32;\n  }\n\n  // Setter — validates before assigning\n  set fahrenheit(f: number) {\n    this._celsius = (f - 32) * 5 / 9;\n  }\n\n  get celsius(): number { return this._celsius; }\n  set celsius(c: number) {\n    if (c < -273.15) throw new RangeError('Below absolute zero');\n    this._celsius = c;\n  }\n\n  toString(): string {\n    return `${this._celsius.toFixed(1)}°C / ${this.fahrenheit.toFixed(1)}°F`;\n  }\n}\n\nconst t = new Temperature(100);\nconsole.log(t.toString());    // '100.0°C / 212.0°F'\nt.fahrenheit = 32;            // sets via setter\nconsole.log(t.celsius);       // 0\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Static Members"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "class IdGenerator {\n  private static nextId = 1;\n\n  static generate(): number {\n    return IdGenerator.nextId++;\n  }\n\n  static reset(): void {\n    IdGenerator.nextId = 1;\n  }\n}\n\nconsole.log(IdGenerator.generate()); // 1\nconsole.log(IdGenerator.generate()); // 2\nIdGenerator.reset();\nconsole.log(IdGenerator.generate()); // 1\n\n// Static factory method — common pattern\nclass Color {\n  private constructor(\n    public readonly r: number,\n    public readonly g: number,\n    public readonly b: number,\n  ) {}\n\n  static fromHex(hex: string): Color {\n    const r = parseInt(hex.slice(1, 3), 16);\n    const g = parseInt(hex.slice(3, 5), 16);\n    const b = parseInt(hex.slice(5, 7), 16);\n    return new Color(r, g, b);\n  }\n\n  static readonly WHITE = new Color(255, 255, 255);\n  static readonly BLACK = new Color(0, 0, 0);\n\n  toHex(): string {\n    return `#${[this.r, this.g, this.b].map(n => n.toString(16).padStart(2, '0')).join('')}`;\n  }\n}\n\nconst red = Color.fromHex('#ff0000');\nconsole.log(red.toHex());    // '#ff0000'\nconsole.log(Color.WHITE.r);  // 255"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Classes as Types"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A TypeScript class defines both a value (the constructor function) and a type (the shape of instances). You can use a class name as a type annotation — the variable must satisfy the class's structural shape."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "class Point { constructor(public x: number, public y: number) {} }\n\n// Using Point as a type annotation\nfunction printPoint(p: Point): void {\n  console.log(`(${p.x}, ${p.y})`);\n}\n\nconst origin = new Point(0, 0);\nprintPoint(origin); // OK\n\n// Structural compatibility — TypeScript checks shape, not nominal identity\nconst raw = { x: 3, y: 4 };\nprintPoint(raw); // OK — raw satisfies the shape of Point\n\n// typeof ClassName — refers to the constructor type, not the instance type\nfunction makePoint(Ctor: typeof Point, x: number, y: number): Point {\n  return new Ctor(x, y);\n}\n\nconst p = makePoint(Point, 1, 2); // p: Point"
          }
        ]
      },
