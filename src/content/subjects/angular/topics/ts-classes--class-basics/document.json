      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Class in Angular Context"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Every Angular component, directive, pipe, and service is a class. Understanding class fundamentals directly translates to how Angular classes are structured."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { Component, OnInit, inject, signal } from '@angular/core';\nimport { HttpClient } from '@angular/common/http';\n\ninterface User { id: number; name: string }\n\n@Component({\n  selector: 'app-user-list',\n  template: `\n    @if (loading()) { <p>Loading…</p> }\n    @for (user of users(); track user.id) {\n      <p>{{ user.name }}</p>\n    }\n  `,\n})\nexport class UserListComponent implements OnInit {\n  // Public readonly fields (parameter-style via inject)\n  private readonly http = inject(HttpClient);\n\n  // Signal fields — class fields with initial value\n  readonly users   = signal<User[]>([]);\n  readonly loading = signal(false);\n\n  // Lifecycle hook — a method TypeScript enforces via OnInit interface\n  ngOnInit(): void {\n    this.loading.set(true);\n    this.http.get<User[]>('/api/users').subscribe({\n      next: data => { this.users.set(data); this.loading.set(false); },\n      error: ()  => this.loading.set(false),\n    });\n  }\n\n  // Private method — internal helper\n  private trackById(_: number, user: User): number { return user.id; }\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Service Class Structure"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { Injectable, inject } from '@angular/core';\nimport { HttpClient } from '@angular/common/http';\nimport { Observable } from 'rxjs';\n\n@Injectable({ providedIn: 'root' })\nexport class UserService {\n  // Fields initialised at declaration via inject()\n  private readonly http = inject(HttpClient);\n\n  // Private constant — could also be static\n  private readonly baseUrl = '/api/users';\n\n  // Public methods — the service's API\n  getUsers(): Observable<User[]> {\n    return this.http.get<User[]>(this.baseUrl);\n  }\n\n  getUserById(id: number): Observable<User> {\n    return this.http.get<User>(`${this.baseUrl}/${id}`);\n  }\n\n  createUser(user: Omit<User, 'id'>): Observable<User> {\n    return this.http.post<User>(this.baseUrl, user);\n  }\n\n  updateUser(id: number, patch: Partial<User>): Observable<User> {\n    return this.http.patch<User>(`${this.baseUrl}/${id}`, patch);\n  }\n\n  deleteUser(id: number): Observable<void> {\n    return this.http.delete<void>(`${this.baseUrl}/${id}`);\n  }\n}\n\ninterface User { id: number; name: string }"
          }
        ]
      },
