      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "class Timer {\n  private count = 0;\n\n  start(): void {\n    // BAD — regular function loses 'this' binding when called by setInterval\n    // setInterval(function() { this.count++; }, 1000); // this is undefined in strict mode\n\n    // GOOD — arrow function captures 'this' from the enclosing context\n    setInterval(() => { this.count++; }, 1000);\n  }\n\n  // GOOD — class method stored in a property is an arrow, so 'this' is always bound\n  readonly handleClick = (): void => {\n    this.count++;\n  };\n}\n\n// Angular: passing methods as event handlers\n@Component({\n  selector: 'app-btn',\n  template: '<button (click)=\"handleSave()\">Save</button>',\n})\nclass BtnComponent {\n  // Angular binds (click) via a template expression — 'this' is always the component\n  handleSave(): void { /* this works — Angular calls it correctly */ }\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Class Field vs Prototype Method — Memory"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Prototype method — ONE copy shared by all instances (efficient)\nclass SharedMethod {\n  greet(): string { return 'hello'; }\n}\n// SharedMethod.prototype.greet is the single function\n\n// Arrow class field — a NEW function per instance (higher memory usage)\nclass PerInstance {\n  greet = (): string => 'hello';\n}\n// Each new PerInstance() gets its own greet function\n\n// Rule of thumb:\n// - Use prototype methods for Angular class methods (default)\n// - Use arrow class fields ONLY when you pass the method as a callback\n//   and need guaranteed 'this' binding without .bind()"
          }
        ]
      },
