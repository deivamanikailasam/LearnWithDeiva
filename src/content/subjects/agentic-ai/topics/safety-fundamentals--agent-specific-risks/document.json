      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Mitigation requires explicit scope constraints in the system prompt and, for high-stakes tasks, a human confirmation step before broad actions:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\n\nclient = anthropic.Anthropic()\n\ndef scoped_agent(\n    task: str,\n    allowed_paths: list[str],\n    allowed_tools: list[str],\n    tools: list[dict],\n) -> str:\n    \"\"\"\n    Run agent with explicit scope constraints baked into the system prompt.\n    The agent is told exactly what it may and may not touch.\n    \"\"\"\n    scope_constraint = (\n        f\"You may only modify files under these paths: {allowed_paths}. \"\n        f\"You may only use these tools: {allowed_tools}. \"\n        \"If the task seems to require going outside this scope, STOP and explain \"\n        \"what additional scope you would need rather than proceeding without permission.\"\n    )\n\n    response = client.messages.create(\n        model=\"claude-haiku-4-5-20251001\",\n        max_tokens=2048,\n        system=f\"You are a coding assistant.\\n\\nScope constraints: {scope_constraint}\",\n        tools=[t for t in tools if t[\"name\"] in allowed_tools],\n        messages=[{\"role\": \"user\", \"content\": task}],\n    )\n    return response.content[0].text if response.content else \"\"\n"
          }
        ]
      },
