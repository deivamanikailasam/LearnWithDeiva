      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "How to implement"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from pydantic_settings import BaseSettings\n\nclass AgentSettings(BaseSettings):\n    model: str = \"gpt-4o\"\n    max_turns: int = 20\n\n    model_config = {\"env_file\": \".env\", \"extra\": \"ignore\"}\n\nsettings = AgentSettings()  # env + optional .env file"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Examples"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Convert CSV snippet to markdown table for prompt\ndef csv_to_markdown(rows: list[dict], limit: int = 10) -> str:\n    if not rows:\n        return \"\"\n    headers = list(rows[0].keys())\n    lines = [\"| \" + \" | \".join(headers) + \" |\", \"| \" + \" | \".join([\"---\"] * len(headers)) + \" |\"]\n    for row in rows[:limit]:\n        lines.append(\"| \" + \" | \".join(str(row[h]) for h in headers) + \" |\")\n    return \"\\n\".join(lines)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Real-world example"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Deployment pipeline: agent behavior defined in YAML (prompt templates, tool list), secrets in env/vault. At startup, load YAML with safe_load, validate with Pydantic Settings model, inject secrets from environment — never store keys in YAML committed to git."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common mistakes"
