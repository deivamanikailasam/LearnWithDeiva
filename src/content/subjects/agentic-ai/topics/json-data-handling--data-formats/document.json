      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "How it works"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "YAML (PyYAML)"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import yaml\n\nwith open(\"agent_config.yaml\", encoding=\"utf-8\") as f:\n    config = yaml.safe_load(f)  # never yaml.load without SafeLoader\n\nmodel = config[\"agent\"][\"model\"]\ntools = config[\"agent\"].get(\"tools\", [])"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "CSV"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import csv\n\nrows = []\nwith open(\"leads.csv\", newline=\"\", encoding=\"utf-8\") as f:\n    reader = csv.DictReader(f)\n    for row in reader:\n        rows.append(dict(row))\n\n# summarize for model context\nsummary = json.dumps(rows[:20], ensure_ascii=False)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "XML (ElementTree)"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import xml.etree.ElementTree as ET\n\nroot = ET.fromstring(xml_text)\nitems = [\n    {\"id\": el.get(\"id\"), \"title\": el.findtext(\"title\")}\n    for el in root.findall(\".//item\")\n]"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "JSONL"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "records = []\nwith open(\"events.jsonl\", encoding=\"utf-8\") as f:\n    for line in f:\n        line = line.strip()\n        if line:\n            records.append(json.loads(line))"
          }
        ]
      },
