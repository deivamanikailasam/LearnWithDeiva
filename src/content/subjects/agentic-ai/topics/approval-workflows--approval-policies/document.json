      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Policy Data Model"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from enum import StrEnum\nfrom dataclasses import dataclass, field\nfrom typing import Callable, Any\n\nclass PolicyDecision(StrEnum):\n    ALLOW         = \"allow\"\n    REQUIRE_HUMAN = \"require_human\"\n    DENY          = \"deny\"\n\n@dataclass\nclass PolicyContext:\n    tool_name:    str\n    params:       dict[str, Any]\n    actor_id:     str          # who is invoking the agent\n    actor_roles:  list[str]    # e.g. [\"engineer\", \"on-call\"]\n    environment:  str          # \"production\" | \"staging\" | \"development\"\n    session_id:   str\n    session_approved: set[str] = field(default_factory=set)  # keys already OKd this session\n\n@dataclass\nclass PolicyRule:\n    name:     str\n    priority: int              # lower = evaluated first\n    decision: PolicyDecision\n    # predicate: True \u2192 this rule fires\n    matches:  Callable[[PolicyContext], bool]\n    reason:   str = \"\"         # surfaced to approvers / audit log\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Built-in Rule Helpers"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import re\n\ndef tool_is(name: str):\n    return lambda ctx: ctx.tool_name == name\n\ndef tool_matches(pattern: str):\n    rx = re.compile(pattern)\n    return lambda ctx: bool(rx.search(ctx.tool_name))\n\ndef param_matches(key: str, pattern: str):\n    rx = re.compile(pattern, re.IGNORECASE)\n    return lambda ctx: bool(rx.search(str(ctx.params.get(key, \"\"))))\n\ndef in_environment(*envs: str):\n    return lambda ctx: ctx.environment in envs\n\ndef actor_has_role(*roles: str):\n    role_set = set(roles)\n    return lambda ctx: bool(role_set & set(ctx.actor_roles))\n\ndef session_already_approved(key_fn: Callable[[PolicyContext], str]):\n    return lambda ctx: key_fn(ctx) in ctx.session_approved\n\ndef always():\n    return lambda ctx: True\n\ndef combine_and(*predicates):\n    return lambda ctx: all(p(ctx) for p in predicates)\n\ndef combine_or(*predicates):\n    return lambda ctx: any(p(ctx) for p in predicates)\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Policy Registry"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Ordered list of rules \u2014 lower priority number = evaluated first\nPOLICY_RULES: list[PolicyRule] = [\n    # --- Global deny-list (priority 0) ---\n    PolicyRule(\n        name=\"deny-drop-table\",\n        priority=0,\n        decision=PolicyDecision.DENY,\n        matches=tool_is(\"drop_table\"),\n        reason=\"Schema destruction is always blocked by policy\",\n    ),\n    PolicyRule(\n        name=\"deny-exec-shell-in-prod\",\n        priority=0,\n        decision=PolicyDecision.DENY,\n        matches=combine_and(tool_is(\"exec_shell\"), in_environment(\"production\")),\n        reason=\"Shell execution disabled in production\",\n    ),\n\n    # --- Environment policy (priority 10) ---\n    PolicyRule(\n        name=\"allow-all-in-dev\",\n        priority=10,\n        decision=PolicyDecision.ALLOW,\n        matches=in_environment(\"development\"),\n        reason=\"Development environment \u2014 all actions auto-approved\",\n    ),\n\n    # --- Role policy (priority 20) ---\n    PolicyRule(\n        name=\"allow-deploy-for-release-engineer\",\n        priority=20,\n        decision=PolicyDecision.ALLOW,\n        matches=combine_and(\n            tool_is(\"deploy_service\"),\n            actor_has_role(\"release-engineer\"),\n        ),\n        reason=\"Release engineers may deploy without extra approval\",\n    ),\n\n    # --- Session bypass (priority 30) ---\n    PolicyRule(\n        name=\"session-bypass-send-email\",\n        priority=30,\n        decision=PolicyDecision.ALLOW,\n        matches=session_already_approved(lambda ctx: f\"send_email:{ctx.actor_id}\"),\n        reason=\"send_email already approved this session\",\n    ),\n\n    # --- Default: require human for any unresolved action (priority 100) ---\n    PolicyRule(\n        name=\"default-require-human\",\n        priority=100,\n        decision=PolicyDecision.REQUIRE_HUMAN,\n        matches=always(),\n        reason=\"Default policy: unclassified actions require human review\",\n    ),\n]\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Policy Evaluator"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def evaluate_policy(ctx: PolicyContext) -> tuple[PolicyDecision, str]:\n    \"\"\"\n    Evaluate all rules in priority order.\n    First DENY wins immediately.\n    First non-DENY decision wins after scanning all DENY-priority rules.\n    \"\"\"\n    sorted_rules = sorted(POLICY_RULES, key=lambda r: r.priority)\n\n    first_match: tuple[PolicyDecision, str] | None = None\n\n    for rule in sorted_rules:\n        if not rule.matches(ctx):\n            continue\n        if rule.decision == PolicyDecision.DENY:\n            # Hard deny: stop immediately, no bypass possible\n            return PolicyDecision.DENY, rule.reason\n        if first_match is None:\n            first_match = (rule.decision, rule.reason)\n        # Continue scanning for DENY rules at higher priority numbers\n        # (they could still veto even after an ALLOW matched earlier)\n\n    if first_match:\n        return first_match\n    # No rule matched at all \u2014 default deny for safety\n    return PolicyDecision.DENY, \"No matching policy rule \u2014 blocked by default\"\n\n\n# Example usage\nctx = PolicyContext(\n    tool_name=\"send_email\",\n    params={\"recipients\": \"all@company.com\"},\n    actor_id=\"user-123\",\n    actor_roles=[\"engineer\"],\n    environment=\"production\",\n    session_id=\"sess-abc\",\n    session_approved=set(),\n)\ndecision, reason = evaluate_policy(ctx)\nprint(f\"{decision}: {reason}\")\n# \u2192 require_human: Default policy: unclassified actions require human review\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Integrating Policy into the Agent Loop"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\n\nclient = anthropic.Anthropic()\n\nasync def run_agent_with_policy(\n    system: str,\n    messages: list[dict],\n    tools: list[dict],\n    actor_id: str,\n    actor_roles: list[str],\n    environment: str,\n    session_id: str,\n    max_iters: int = 20,\n) -> str:\n    session_approved: set[str] = set()\n\n    for _ in range(max_iters):\n        resp = client.messages.create(\n            model=\"claude-opus-4-8\",\n            max_tokens=4096,\n            system=system,\n            messages=messages,\n            tools=tools,\n        )\n        if resp.stop_reason == \"end_turn\":\n            return \" \".join(b.text for b in resp.content if hasattr(b, \"text\"))\n\n        results = []\n        for block in resp.content:\n            if block.type != \"tool_use\":\n                continue\n\n            ctx = PolicyContext(\n                tool_name=block.name,\n                params=block.input,\n                actor_id=actor_id,\n                actor_roles=actor_roles,\n                environment=environment,\n                session_id=session_id,\n                session_approved=session_approved,\n            )\n            decision, reason = evaluate_policy(ctx)\n\n            if decision == PolicyDecision.DENY:\n                results.append({\n                    \"type\": \"tool_result\",\n                    \"tool_use_id\": block.id,\n                    \"content\": f\"Action blocked by policy: {reason}\",\n                    \"is_error\": True,\n                })\n                continue\n\n            if decision == PolicyDecision.REQUIRE_HUMAN:\n                approved = await _request_human_approval(block.name, block.input, reason)\n                if not approved:\n                    results.append({\n                        \"type\": \"tool_result\",\n                        \"tool_use_id\": block.id,\n                        \"content\": \"Human denied the action.\",\n                        \"is_error\": True,\n                    })\n                    continue\n                # Cache session approval for session-bypass rules\n                session_approved.add(f\"{block.name}:{actor_id}\")\n\n            result = await _execute_tool(block.name, block.input)\n            results.append({\n                \"type\": \"tool_result\",\n                \"tool_use_id\": block.id,\n                \"content\": result,\n            })\n\n        messages = messages + [\n            {\"role\": \"assistant\", \"content\": resp.content},\n            {\"role\": \"user\", \"content\": results},\n        ]\n\n    return \"max_iterations reached\"\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Environment-Specific Overrides"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Policies often need to behave differently across environments. The recommended pattern is to load environment-specific rule overrides at startup rather than scattering environment checks across business logic:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import os\n\ndef load_environment_overrides(env: str) -> list[PolicyRule]:\n    if env == \"development\":\n        return [PolicyRule(\n            name=\"dev-allow-all\",\n            priority=5,     # before any real rules\n            decision=PolicyDecision.ALLOW,\n            matches=always(),\n            reason=\"Dev environment: all actions auto-approved\",\n        )]\n    if env == \"staging\":\n        return [PolicyRule(\n            name=\"staging-deny-financial\",\n            priority=5,\n            decision=PolicyDecision.DENY,\n            matches=tool_matches(r\"charge|refund|transfer\"),\n            reason=\"Financial actions disabled in staging\",\n        )]\n    return []   # production: no overrides, full policy stack applies\n\ndef build_policy_stack(env: str = None) -> list[PolicyRule]:\n    env = env or os.getenv(\"APP_ENV\", \"production\")\n    return load_environment_overrides(env) + POLICY_RULES\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Policy Testing"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Policies are code \u2014 they need unit tests. Test each rule in isolation and then test the full evaluation stack:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import pytest\n\ndef make_ctx(**kwargs) -> PolicyContext:\n    defaults = {\n        \"tool_name\": \"read_records\",\n        \"params\": {},\n        \"actor_id\": \"user-1\",\n        \"actor_roles\": [\"engineer\"],\n        \"environment\": \"production\",\n        \"session_id\": \"sess-1\",\n        \"session_approved\": set(),\n    }\n    return PolicyContext(**{**defaults, **kwargs})\n\ndef test_drop_table_always_denied():\n    ctx = make_ctx(tool_name=\"drop_table\", environment=\"development\")\n    decision, _ = evaluate_policy(ctx)\n    assert decision == PolicyDecision.DENY\n\ndef test_dev_environment_allows_all():\n    ctx = make_ctx(tool_name=\"send_email\", environment=\"development\")\n    decision, _ = evaluate_policy(ctx)\n    assert decision == PolicyDecision.ALLOW\n\ndef test_session_bypass_after_approval():\n    ctx = make_ctx(\n        tool_name=\"send_email\",\n        actor_id=\"user-1\",\n        environment=\"production\",\n        session_approved={\"send_email:user-1\"},\n    )\n    decision, _ = evaluate_policy(ctx)\n    assert decision == PolicyDecision.ALLOW\n\ndef test_release_engineer_can_deploy():\n    ctx = make_ctx(tool_name=\"deploy_service\", actor_roles=[\"release-engineer\"])\n    decision, _ = evaluate_policy(ctx)\n    assert decision == PolicyDecision.ALLOW\n\ndef test_default_requires_human():\n    ctx = make_ctx(tool_name=\"unknown_tool\")\n    decision, _ = evaluate_policy(ctx)\n    assert decision == PolicyDecision.REQUIRE_HUMAN\n"
          }
        ]
      },
      {
