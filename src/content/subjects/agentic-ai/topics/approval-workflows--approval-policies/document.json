                    "type": "text",
                    "text": "Rules",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 predicates that match an (action, context) pair and return ALLOW, DENY, or REQUIRE_HUMAN."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
