                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 ordered sets of rules evaluated in priority sequence; first DENY wins."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Context",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 runtime data passed to rules: current user, environment, session state, action parameters."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Policies answer 'should this action need approval?' \u2014 not 'is this action allowed?' That distinction matters: a policy can require human approval for legal operations while still blocking clearly forbidden ones."
              }
            ]
          }
        ]
