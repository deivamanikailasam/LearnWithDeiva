                },
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Hardcoding environment in rules"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {
                  "colspan": 1,
                  "rowspan": 1
                },
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Rules scattered, hard to audit"
                      }
                    ]
                  }
                ]
