    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Static type checking analyzes Python type hints without running code. For agent systems, types document tool inputs/outputs, orchestrator state, and API contracts — catching mismatches before a bad tool payload reaches production."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "What it is"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Type hints (PEP 484) annotate variables, parameters, and returns. "
          },
          {
            "type": "text",
            "text": "mypy",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " or "
          },
          {
            "type": "text",
            "text": "pyright",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " (via Pylance/Pyright CLI) verify consistency: wrong types, missing attributes, incompatible unions. Pydantic models add runtime validation aligned with static types in FastAPI agent APIs."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from typing import TypedDict\n\nclass SearchArgs(TypedDict):\n    q: str\n    limit: int\n\ndef run_search(args: SearchArgs) -> list[dict]:\n    ...\n\ndef handle_tool_call(name: str, raw: dict) -> list[dict]:\n    if name == \"search\":\n        args: SearchArgs = {\"q\": raw[\"q\"], \"limit\": raw.get(\"limit\", 5)}\n        return run_search(args)\n    raise ValueError(name)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Why it matters"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Agent orchestrators pass dicts between LLM JSON, tool functions, and HTTP layers. Without types, a renamed field fails silently at runtime. Static checking flags tool_args.get(\"query\") when schema expects \"q\" — before deploy."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Benefits"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Early errors",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " — IDE and CI catch type bugs pre-runtime"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
