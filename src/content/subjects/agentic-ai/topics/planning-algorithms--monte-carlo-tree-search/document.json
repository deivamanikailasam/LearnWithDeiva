                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "MCTS"
                  },
                  {
                    "type": "text",
                    "text": " builds a search tree via four phases: Selection (UCB), Expansion (new node), Simulation (rollout), Backpropagation (update scores)."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "UCB"
                  },
                  {
                    "type": "text",
                    "text": " balances exploitation (high mean score) and exploration (low visit count) with a single tunable constant "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "c"
                  },
