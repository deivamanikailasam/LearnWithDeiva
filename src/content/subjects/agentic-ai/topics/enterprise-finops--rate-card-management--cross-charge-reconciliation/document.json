                        "text": "Usage not in internal ledger"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "API calls bypassed the gateway (direct provider calls)"
                      }
                    ]
                  }
