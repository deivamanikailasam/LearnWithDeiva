        "content": [
          {
            "type": "text",
            "text": "class PIIGuardedAgent:\n    def __init__(self, model_fn, session_id: str):\n        self._model = model_fn\n        self._session_id = session_id\n        self._vault = PIITokenVault()\n        self._pmap = PseudonymMap()\n        self._registry = PIIRegistry()\n\n    def run(self, user_message: str) -> str:\n        # Ingestion: protect PII before LLM sees it\n        clean_message = ingest_with_pii_protection(user_message, self._vault, self._pmap)\n\n        # Run the model with the cleaned message\n        raw_response = self._model(clean_message)\n\n        # Output scan: catch any PII that re-entered the pipeline\n        scan = scan_output_for_pii(raw_response, auto_redact=True)\n        if scan.pii_found:\n            _audit_log(\"OUTPUT_PII_REDACTED\", session_id=self._session_id,\n                       types=[m.pii_type for m in scan.pii_found])\n\n        return scan.sanitised_text\n\n    def close(self) -> None:\n        self._vault.purge()\n        self._pmap.purge()\n        _audit_log(\"SESSION_PII_PURGED\", session_id=self._session_id)"
          }
