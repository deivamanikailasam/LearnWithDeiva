      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Step 3: Protection Mechanisms"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Pseudonymisation"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Pseudonymisation replaces PII with a consistent fake value that preserves the "
          },
          {
            "type": "text",
            "text": "structure",
            "marks": [
              {
                "type": "italic"
              }
            ]
          },
          {
            "type": "text",
            "text": " of the original \u2014 useful when the LLM needs to reason about a person's record across multiple turns without knowing the real identity."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import hashlib, secrets\nfrom dataclasses import dataclass, field\n\n@dataclass\nclass PseudonymMap:\n    _fwd: dict[str, str] = field(default_factory=dict, init=False)\n    _rev: dict[str, str] = field(default_factory=dict, init=False)\n    _salt: str = field(default_factory=lambda: secrets.token_hex(16), init=False)\n\n    def pseudonymise(self, real_value: str, pii_type: str) -> str:\n        \"\"\"Returns a consistent pseudonym for the same real_value within this map.\"\"\"\n        if real_value in self._fwd:\n            return self._fwd[real_value]\n        # Deterministic within this session (same real\u2192same pseudo) but not reversible\n        # without the _salt\n        digest = hashlib.sha256((self._salt + real_value).encode()).hexdigest()[:8]\n        pseudo = f\"[{pii_type}:{digest}]\"\n        self._fwd[real_value] = pseudo\n        self._rev[pseudo] = real_value\n        return pseudo\n\n    def restore(self, pseudo: str) -> str | None:\n        return self._rev.get(pseudo)\n\n    def purge(self) -> None:\n        self._fwd.clear()\n        self._rev.clear()\n\ndef apply_pseudonymisation(text: str, matches: list[PIIMatch], pmap: PseudonymMap) -> str:\n    # Replace from right to left so indices don't shift\n    for match in sorted(matches, key=lambda m: m.start, reverse=True):\n        pseudo = pmap.pseudonymise(match.text, match.pii_type)\n        text = text[:match.start] + pseudo + text[match.end:]\n    return text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Tokenisation for High-Risk PII"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For HIGH-risk PII that must never enter the LLM context, tokenise it "
          },
          {
            "type": "text",
            "text": "before",
            "marks": [
              {
                "type": "italic"
              }
            ]
          },
          {
            "type": "text",
            "text": " any processing and de-tokenise only when writing to an authorised output \u2014 for example when returning a record to a verified user interface, never when constructing a prompt or a tool argument."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import secrets\n\nclass PIITokenVault:\n    \"\"\"\n    One-way tokenisation vault for HIGH-risk PII.\n    Tokens are random; there is no deterministic mapping from value to token \u2014\n    the same SSN tokenised twice produces two different tokens.\n    \"\"\"\n    def __init__(self):\n        self._store: dict[str, tuple[str, str]] = {}  # token \u2192 (pii_type, real_value)\n\n    def tokenise(self, value: str, pii_type: str) -> str:\n        token = f\"PIItok_{secrets.token_urlsafe(12)}\"\n        self._store[token] = (pii_type, value)\n        return token\n\n    def detokenise(self, token: str) -> tuple[str, str]:\n        \"\"\"Returns (pii_type, real_value). Raises KeyError if not found.\"\"\"\n        return self._store[token]\n\n    def purge(self) -> None:\n        self._store.clear()\n\n# Usage: ingestion point\ndef ingest_with_pii_protection(\n    text: str,\n    vault: PIITokenVault,\n    pmap: PseudonymMap,\n) -> str:\n    matches = detect_pii(text)\n    for match in sorted(matches, key=lambda m: m.start, reverse=True):\n        if match.pii_type in (\"SSN\", \"CARD\"):\n            # HIGH: tokenise \u2014 never pass to LLM\n            token = vault.tokenise(match.text, match.pii_type)\n            text = text[:match.start] + token + text[match.end:]\n        else:\n            # MEDIUM: pseudonymise for in-context use\n            pseudo = pmap.pseudonymise(match.text, match.pii_type)\n            text = text[:match.start] + pseudo + text[match.end:]\n    return text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Step 4: Enforcement \u2014 Output and Context Scanning"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Even after ingestion-side protection, PII can re-enter the pipeline through tool results, retrieved documents, or multi-turn context accumulation. An output scanner runs on every response and tool argument before they leave the trusted boundary."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "@dataclass\nclass OutputScanResult:\n    safe: bool\n    pii_found: list[PIIMatch]\n    sanitised_text: str\n\ndef scan_output_for_pii(\n    text: str,\n    threshold: float = 0.5,\n    auto_redact: bool = True,\n) -> OutputScanResult:\n    matches = detect_pii(text, confidence_threshold=threshold)\n    if not matches:\n        return OutputScanResult(safe=True, pii_found=[], sanitised_text=text)\n\n    if not auto_redact:\n        return OutputScanResult(safe=False, pii_found=matches, sanitised_text=text)\n\n    # Auto-redact: replace detected PII with type labels\n    result = text\n    for match in sorted(matches, key=lambda m: m.start, reverse=True):\n        result = result[:match.start] + f\"[{match.pii_type} REDACTED]\" + result[match.end:]\n\n    return OutputScanResult(safe=True, pii_found=matches, sanitised_text=result)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Retention and Right-to-Erasure"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Under GDPR and similar regulations, individuals have the right to request deletion of their personal data. In an agentic system this means you must know exactly where every piece of PII was stored \u2014 in which conversation logs, vector store embeddings, fine-tuning datasets, and audit records \u2014 and be able to purge or anonymise it on request."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass, field\nimport time\n\n@dataclass\nclass PIIRecord:\n    record_id: str\n    pii_type: str\n    token: str              # token or pseudonym \u2014 never the real value\n    purpose: str            # e.g. \"customer_support_session\"\n    lawful_basis: str       # e.g. \"consent\", \"legitimate_interest\"\n    created_at: float\n    retention_days: int     # 0 = purge on session end\n\n    @property\n    def expires_at(self) -> float:\n        return self.created_at + self.retention_days * 86400\n\n    @property\n    def expired(self) -> bool:\n        return self.retention_days > 0 and time.time() > self.expires_at\n\nclass PIIRegistry:\n    \"\"\"Central register of all PII tokens held in this deployment.\"\"\"\n    def __init__(self):\n        self._records: dict[str, PIIRecord] = {}\n\n    def register(self, record: PIIRecord) -> None:\n        self._records[record.record_id] = record\n\n    def purge_expired(self) -> int:\n        expired = [r for r in self._records.values() if r.expired]\n        for r in expired:\n            del self._records[r.record_id]\n        return len(expired)\n\n    def respond_to_erasure_request(self, subject_token: str) -> list[str]:\n        \"\"\"\n        Find all records associated with a subject token and mark them for deletion.\n        Returns a list of record IDs purged (for the audit log).\n        \"\"\"\n        to_delete = [\n            r.record_id for r in self._records.values()\n            if r.token == subject_token\n        ]\n        for rid in to_delete:\n            del self._records[rid]\n        return to_delete"
          }
        ]
