            "text": "Context Assembly"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "An "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "AgentContext"
          },
          {
            "type": "text",
            "text": " class assembles all memory types into a single system prompt, ordered from most stable (base instructions) to most dynamic (episodic lessons). This ensures the model always has the right context without manual prompt engineering per run."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass\n\n@dataclass\nclass AgentContext:\n    \"\"\"Assembles all memory types into a system prompt.\"\"\"\n    semantic: SemanticMemory\n    episodic: 'EpisodicMemory'\n    base_instructions: str\n\n    def build_system_prompt(self, current_goal: str) -> str:\n        sections = [self.base_instructions]\n        facts = self.semantic.as_context()\n        if facts:\n            sections.append(facts)\n        lessons = self.episodic.context_block(current_goal)\n        if lessons:\n            sections.append(lessons)\n        return '\\n\\n'.join(sections)\n\n# Usage:\nimport anthropic\nclient = anthropic.Anthropic()\n\nsem = SemanticMemory()\nsem.set('output_format', 'JSON', source='user preference')\nsem.set('max_results', 10, source='system config')\n\nctx = AgentContext(\n    semantic=sem,\n    episodic=memory,  # EpisodicMemory from previous episodes\n    base_instructions='You are an agentic assistant. Use tools to complete the goal.',\n)\n\nsystem_prompt = ctx.build_system_prompt(current_goal='Research competitor pricing')\nresponse = client.messages.create(\n    model='claude-sonnet-4-6',\n    max_tokens=1024,\n    system=system_prompt,\n    messages=[{'role': 'user', 'content': current_goal}],\n)\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Updating Semantic Memory from Runs"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "After a run, ask the model to identify any durable facts from the findings \u2014 not lessons (those go to episodic memory) but stable domain facts: \"the API endpoint changed\", \"the user prefers metric units\", \"the database schema has column X\"."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Updating semantic memory from tool results and agent conclusions.\n\nEXTRACT_FACTS_PROMPT = (\n    'Review the following agent run and extract any durable facts '\n    'that should be remembered for future runs.\\n\\n'\n    'Goal: {goal}\\n'\n    'Key findings: {findings}\\n\\n'\n    'Return facts as key: value pairs, one per line. '\n    'Only include facts that are stable across runs (not transient data). '\n    'Return NONE if there are no durable facts.'\n)\n\ndef extract_and_store_facts(\n    client,\n    goal: str,\n    findings: str,\n    sem: SemanticMemory,\n) -> int:\n    \"\"\"Ask the model to extract durable facts; store them. Returns count.\"\"\"\n    prompt = EXTRACT_FACTS_PROMPT.format(goal=goal, findings=findings)\n    r = client.messages.create(\n        model='claude-sonnet-4-6',\n        max_tokens=256,\n        messages=[{'role': 'user', 'content': prompt}],\n    )\n    text = r.content[0].text.strip()\n    if text.upper() == 'NONE':\n        return 0\n    count = 0\n    for line in text.splitlines():\n        if ':' in line:\n            key, _, value = line.partition(':')\n            sem.set(key.strip(), value.strip(), source=f'run: {goal[:40]}')\n            count += 1\n    return count\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Fact Decay and TTL"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Not all facts are permanent. API endpoints change, credentials rotate, prices update. A "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "TimestampedFact"
          },
          {
            "type": "text",
            "text": " with a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "ttl_seconds"
          },
          {
            "type": "text",
            "text": " field automatically expires stale data. Set "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "ttl_seconds=0"
          },
          {
            "type": "text",
            "text": " for permanent facts (user preferences, domain constants)."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import time\nfrom dataclasses import dataclass, field\n\n@dataclass\nclass TimestampedFact(Fact):\n    created_at: float = field(default_factory=time.time)\n    ttl_seconds: float = 86400  # 24h default; 0 = never expires\n\n    @property\n    def expired(self) -> bool:\n        if self.ttl_seconds == 0:\n            return False\n        return (time.time() - self.created_at) > self.ttl_seconds\n\n@dataclass\nclass DecayingSemanticMemory(SemanticMemory):\n    def as_context(self) -> str:\n        active = {\n            k: f for k, f in self._facts.items()\n            if not (isinstance(f, TimestampedFact) and f.expired)\n        }\n        if not active:\n            return ''\n        lines = ['Known facts:']\n        for f in active.values():\n            lines.append(f'  {f.key}: {f.value}')\n        return '\\n'.join(lines)\n\n    def purge_expired(self) -> int:\n        before = len(self._facts)\n        self._facts = {\n            k: f for k, f in self._facts.items()\n            if not (isinstance(f, TimestampedFact) and f.expired)\n        }\n        return before - len(self._facts)\n"
          }
        ]
      },
