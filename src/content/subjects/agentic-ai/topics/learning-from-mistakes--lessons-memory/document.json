            "type": "text",
            "text": "Memory Types"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Each memory type has a different lifetime, update mechanism, and role in the system prompt."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass, field\nfrom typing import Any\n\n# ---- Working Memory ----\n# The live conversation messages list. Ephemeral \u2014 resets each run.\nWorkingMemory = list[dict]  # same shape as Anthropic messages param\n\n# ---- Episodic Memory ----\n# (Defined in Episodic Reflection topic)\n# EpisodicMemory: sliding window of past episodes + extracted lessons\n\n# ---- Semantic Memory ----\n@dataclass\nclass Fact:\n    key: str          # unique identifier, e.g. 'default_output_dir'\n    value: Any        # the fact\n    source: str = ''  # where this came from\n    confidence: float = 1.0\n\n@dataclass\nclass SemanticMemory:\n    _facts: dict[str, Fact] = field(default_factory=dict)\n\n    def set(self, key: str, value: Any, source: str = '') -> None:\n        self._facts[key] = Fact(key=key, value=value, source=source)\n\n    def get(self, key: str, default: Any = None) -> Any:\n        f = self._facts.get(key)\n        return f.value if f else default\n\n    def as_context(self) -> str:\n        if not self._facts:\n            return ''\n        lines = ['Known facts:']\n        for f in self._facts.values():\n            lines.append(f'  {f.key}: {f.value}')\n        return '\\n'.join(lines)\n\n# ---- Procedural Memory ----\n# Tool schemas and system prompt. Loaded at startup; does not change.\nProceduralMemory = list[dict]  # list of tool definitions\n"
          }
        ]
      },
