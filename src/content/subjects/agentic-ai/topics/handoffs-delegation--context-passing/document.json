                    "text": " for conversation history."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Always merge additively: ",
                    "marks": []
                  },
                  {
                    "type": "text",
                    "text": "{**state[\"context\"], \"new_key\": value}",
