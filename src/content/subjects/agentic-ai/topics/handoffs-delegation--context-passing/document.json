      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Context passes between agents through a shared state field \u2014 either a ",
                    "marks": []
                  },
                  {
                    "type": "text",
                    "text": "dict[str, Any]",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
