        "content": [
          {
            "type": "text",
            "text": "Testing Context Passing"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import pytest\nfrom unittest.mock import patch, MagicMock\nfrom langchain_core.messages import HumanMessage, AIMessage\n\n\ndef test_researcher_writes_findings_to_context():\n    state: ContextState = {\n        \"goal\": \"research AI agents\",\n        \"context\": {},\n        \"messages\": [HumanMessage(content=\"research AI agents\")],\n        \"final_output\": \"\",\n    }\n    with patch(\"__main__.llm\") as mock_llm:\n        mock_llm.invoke.return_value = MagicMock(content=\"Key finding: agents are cool\")\n        result = researcher(state)\n\n    assert result[\"context\"][\"research_findings\"] == \"Key finding: agents are cool\"\n    assert result[\"context\"][\"research_done\"] is True\n    assert len(result[\"messages\"]) == 1\n    assert result[\"messages\"][0].name == \"researcher\"\n\n\ndef test_analyst_reads_researcher_findings():\n    state: ContextState = {\n        \"goal\": \"research AI agents\",\n        \"context\": {\"research_findings\": \"Agents use LLMs\", \"research_done\": True},\n        \"messages\": [HumanMessage(content=\"research AI\"), AIMessage(content=\"Agents use LLMs\", name=\"researcher\")],\n        \"final_output\": \"\",\n    }\n    with patch(\"__main__.llm\") as mock_llm:\n        mock_llm.invoke.return_value = MagicMock(content=\"Pattern: LLMs enable reasoning\")\n        result = analyst(state)\n\n    # Analyst must preserve existing context and add its own keys\n    assert result[\"context\"][\"research_findings\"] == \"Agents use LLMs\"  # preserved\n    assert \"analysis\" in result[\"context\"]  # added\n\n\ndef test_context_not_overwritten_between_agents():\n    ctx = {\"research_findings\": \"original findings\"}\n    # Simulate what analyst returns\n    new_ctx = {**ctx, \"analysis\": \"new analysis\"}\n    assert new_ctx[\"research_findings\"] == \"original findings\"  # not lost"
          }
        ]
      },
