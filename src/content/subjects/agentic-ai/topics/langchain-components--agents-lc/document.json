      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "What Is a LangChain Agent?"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A LangChain agent is an LLM that autonomously decides which tool to call, calls it, observes the result, and repeats until it can produce a final answer. The LLM acts as the controller; tools are its actuators. This Reason-Act (ReAct) loop is the foundation of most agentic systems."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "LangChain Agent ReAct loop diagram",
          "title": "The LLM reasons, calls tools, observes results, and loops until a final answer is ready"
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "create_react_agent \u2014 The Standard Agent"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "LangGraph's "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "create_react_agent"
          },
          {
            "type": "text",
            "text": " is the recommended way to build agents. It constructs a pre-configured graph with an LLM node and a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "ToolNode"
          },
          {
            "type": "text",
            "text": " connected in a ReAct loop."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langgraph.prebuilt import create_react_agent\nfrom langchain_anthropic import ChatAnthropic\nfrom langchain_core.tools import tool\n\nllm = ChatAnthropic(model=\"claude-haiku-4-5-20251001\")\n\n@tool\ndef get_weather(city: str) -> str:\n    \"\"\"Return current weather for a city.\"\"\"\n    return f\"18C, sunny in {city}\"\n\n@tool\ndef calculate(expression: str) -> float:\n    \"\"\"Evaluate a safe mathematical expression.\"\"\"\n    allowed = {k: v for k, v in __import__(\"math\").__dict__.items() if not k.startswith(\"_\")}\n    return eval(expression, {\"__builtins__\": {}}, allowed)\n\ntools = [get_weather, calculate]\nagent = create_react_agent(llm, tools)\n\nresult = agent.invoke({\n    \"messages\": [{\"role\": \"user\", \"content\": \"Weather in Paris and what is 7 * 8?\"}]\n})\nprint(result[\"messages\"][-1].content)\n\n# Stream intermediate steps\nfor step in agent.stream(\n    {\"messages\": [{\"role\": \"user\", \"content\": \"What is sqrt(144)?\"}]},\n    stream_mode=\"values\",\n):\n    step[\"messages\"][-1].pretty_print()"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Adding a System Prompt"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Pass "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "state_modifier"
          },
          {
            "type": "text",
            "text": " to give the agent a persona, constrain its behaviour, or inject background context."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_core.messages import SystemMessage\n\nagent = create_react_agent(\n    llm,\n    tools,\n    state_modifier=SystemMessage(\n        content=(\n            \"You are a concise assistant specialising in data analysis. \"\n            \"Always show your reasoning before giving a final answer.\"\n        )\n    ),\n)\n\n# String shorthand also works\nagent = create_react_agent(llm, tools, prompt=\"Answer in three sentences or fewer.\")"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Persistent Memory with Checkpointing"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Add a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "checkpointer"
          },
          {
            "type": "text",
            "text": " for multi-turn memory. Each "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "thread_id"
          },
          {
            "type": "text",
            "text": " in the config identifies one independent conversation."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langgraph.checkpoint.memory import MemorySaver\n\nmemory = MemorySaver()\nagent  = create_react_agent(llm, tools, checkpointer=memory)\n\nconfig = {\"configurable\": {\"thread_id\": \"session-alice\"}}\n\nr1 = agent.invoke({\"messages\": [{\"role\": \"user\", \"content\": \"My name is Alice.\"}]}, config=config)\nprint(r1[\"messages\"][-1].content)   # \"Nice to meet you, Alice!\"\n\nr2 = agent.invoke({\"messages\": [{\"role\": \"user\", \"content\": \"What is my name?\"}]}, config=config)\nprint(r2[\"messages\"][-1].content)   # \"Your name is Alice.\"\n\n# Inspect the full conversation\nstate = agent.get_state(config)\nprint(f\"{len(state.values['messages'])} messages in history\")"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Human-in-the-Loop with interrupt_before"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For sensitive tools, pause the agent before execution and require human approval. "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "interrupt_before=[\"tools\"]"
          },
          {
            "type": "text",
            "text": " stops the graph just before the "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "ToolNode"
          },
          {
            "type": "text",
            "text": " runs."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "memory = MemorySaver()\nagent  = create_react_agent(llm, tools, checkpointer=memory, interrupt_before=[\"tools\"])\n\nconfig = {\"configurable\": {\"thread_id\": \"review-1\"}}\n\n# Step 1: LLM decides to call a tool \u2014 agent PAUSES before executing\nresult = agent.invoke(\n    {\"messages\": [{\"role\": \"user\", \"content\": \"What is the weather in Paris?\"}]},\n    config=config,\n)\nlast = result[\"messages\"][-1]\nprint(\"Pending calls:\", last.tool_calls)\n# [{'name': 'get_weather', 'args': {'city': 'Paris'}, 'id': 'call_abc'}]\n\n# Step 2a: Human approves \u2014 resume with None input\nfinal = agent.invoke(None, config=config)\nprint(final[\"messages\"][-1].content)\n\n# Step 2b: Human rejects \u2014 inject a rejection ToolMessage\nfrom langchain_core.messages import ToolMessage\nagent.update_state(config, {\n    \"messages\": [ToolMessage(\n        content=\"Request denied by reviewer.\",\n        tool_call_id=last.tool_calls[0][\"id\"],\n    )]\n})\nfinal = agent.invoke(None, config=config)\nprint(final[\"messages\"][-1].content)   # agent acknowledges the rejection"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Controlling Loop Depth"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Always set "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "recursion_limit"
          },
          {
            "type": "text",
            "text": " to prevent runaway agents. The default is 25 steps; override in the config dict."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langgraph.errors import GraphRecursionError\n\ntry:\n    result = agent.invoke(\n        {\"messages\": [{\"role\": \"user\", \"content\": \"Research everything about AI.\"}]},\n        config={\"configurable\": {\"thread_id\": \"t1\"}, \"recursion_limit\": 10},\n    )\nexcept GraphRecursionError:\n    state = agent.get_state({\"configurable\": {\"thread_id\": \"t1\"}})\n    partial_answer = state.values[\"messages\"][-1].content\n    print(f\"Hit step limit. Partial: {partial_answer}\")"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "AgentExecutor \u2014 Legacy API"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Before LangGraph, agents used "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "AgentExecutor"
          },
          {
            "type": "text",
            "text": ". It is still supported for backwards compatibility but "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "create_react_agent"
          },
          {
            "type": "text",
            "text": " is preferred for new code."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain.agents import AgentExecutor, create_tool_calling_agent\nfrom langchain_core.prompts import ChatPromptTemplate, MessagesPlaceholder\n\nprompt = ChatPromptTemplate.from_messages([\n    (\"system\", \"You are a helpful assistant.\"),\n    (\"human\", \"{input}\"),\n    MessagesPlaceholder(\"agent_scratchpad\"),\n])\n\nagent_runnable = create_tool_calling_agent(llm, tools, prompt)\nexecutor = AgentExecutor(\n    agent=agent_runnable,\n    tools=tools,\n    verbose=True,\n    max_iterations=10,\n    handle_parsing_errors=True,\n)\n\nresult = executor.invoke({\"input\": \"What is 99 * 99?\"})\nprint(result[\"output\"])   # '9801'"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Structured Output from Agents"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "By default an agent returns free text. Pass "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "response_format"
          },
          {
            "type": "text",
            "text": " to force the final response into a Pydantic model \u2014 useful when downstream code needs a typed object rather than a string."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from pydantic import BaseModel, Field\nfrom langgraph.prebuilt import create_react_agent\n\nclass WeatherReport(BaseModel):\n    city: str = Field(description=\"City name\")\n    temperature_c: float = Field(description=\"Temperature in Celsius\")\n    condition: str = Field(description=\"Weather condition, e.g. sunny, rainy\")\n    summary: str = Field(description=\"One-sentence human-readable summary\")\n\nagent = create_react_agent(\n    llm,\n    tools,\n    response_format=WeatherReport,\n)\n\nresult = agent.invoke({\n    \"messages\": [{\"role\": \"user\", \"content\": \"What is the weather in London?\"}]\n})\n\n# The structured response is in result[\"structured_response\"]\nreport: WeatherReport = result[\"structured_response\"]\nprint(report.city)           # 'London'\nprint(report.temperature_c)  # 12.5\nprint(report.condition)      # 'cloudy'\nprint(report.summary)        # 'London is currently 12.5C and cloudy.'"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Multi-Step Research Agent Example"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A realistic agent uses several tools in sequence. Below is a research agent that searches the web, fetches pages, and summarises findings \u2014 all autonomously."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_core.tools import tool\nfrom langchain_community.tools import DuckDuckGoSearchRun\nfrom langchain_community.document_loaders import WebBaseLoader\nfrom langgraph.prebuilt import create_react_agent\nfrom langgraph.checkpoint.memory import MemorySaver\nfrom langchain_anthropic import ChatAnthropic\n\nllm = ChatAnthropic(model=\"claude-haiku-4-5-20251001\")\nsearch = DuckDuckGoSearchRun()\n\n@tool\ndef web_search(query: str) -> str:\n    \"\"\"Search the web for information on a topic.\"\"\"\n    return search.invoke(query)\n\n@tool\ndef fetch_page(url: str) -> str:\n    \"\"\"Fetch and extract text from a web page URL.\"\"\"\n    try:\n        docs = WebBaseLoader(url).load()\n        return docs[0].page_content[:3000] if docs else \"Could not load page.\"\n    except Exception as e:\n        return f\"Error loading {url}: {e}\"\n\n@tool\ndef summarise(text: str) -> str:\n    \"\"\"Summarise a long text into three bullet points.\"\"\"\n    from langchain_core.messages import HumanMessage\n    response = llm.invoke([\n        HumanMessage(f\"Summarise in three bullet points:\\n{text[:4000]}\")\n    ])\n    return response.content\n\nresearch_agent = create_react_agent(\n    llm,\n    [web_search, fetch_page, summarise],\n    state_modifier=\"You are a research assistant. Gather information from multiple sources before answering.\",\n    checkpointer=MemorySaver(),\n)\n\nresult = research_agent.invoke(\n    {\"messages\": [{\"role\": \"user\", \"content\": \"What are the key features of LangGraph?\"}]},\n    config={\"configurable\": {\"thread_id\": \"research-1\"}, \"recursion_limit\": 15},\n)\nprint(result[\"messages\"][-1].content)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing Agents"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Test agents deterministically by using "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "FakeListChatModel"
          },
          {
            "type": "text",
            "text": " to control the LLM's sequence of responses, and mock tools that return predictable values."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import json\nimport pytest\nfrom langchain_community.chat_models.fake import FakeListChatModel\nfrom langchain_core.messages import AIMessage\nfrom langgraph.prebuilt import create_react_agent\nfrom langchain_core.tools import tool\n\n@tool\ndef get_price(item: str) -> str:\n    \"\"\"Return the price of an item.\"\"\"\n    prices = {\"apple\": \"$0.50\", \"banana\": \"$0.30\"}\n    return prices.get(item.lower(), \"Item not found\")\n\ndef make_tool_call_message(name: str, args: dict, call_id: str = \"call_1\") -> str:\n    \"\"\"Produce the JSON that FakeListChatModel emits for a tool call.\"\"\"\n    return json.dumps({\"name\": name, \"args\": args, \"id\": call_id})\n\ndef test_agent_calls_tool_and_returns_answer():\n    # Sequence: first response triggers a tool call, second gives the final answer\n    fake_llm = FakeListChatModel(responses=[\n        # Turn 1: LLM decides to call get_price\n        AIMessage(\n            content=\"\",\n            tool_calls=[{\"name\": \"get_price\", \"args\": {\"item\": \"apple\"}, \"id\": \"c1\"}],\n        ),\n        # Turn 2: LLM produces final answer using the ToolMessage\n        AIMessage(content=\"An apple costs $0.50.\"),\n    ])\n\n    agent = create_react_agent(fake_llm, [get_price])\n    result = agent.invoke({\"messages\": [{\"role\": \"user\", \"content\": \"How much is an apple?\"}]})\n    assert \"0.50\" in result[\"messages\"][-1].content\n\ndef test_agent_handles_unknown_item():\n    fake_llm = FakeListChatModel(responses=[\n        AIMessage(content=\"\", tool_calls=[{\"name\": \"get_price\", \"args\": {\"item\": \"durian\"}, \"id\": \"c1\"}]),\n        AIMessage(content=\"I could not find the price for durian.\"),\n    ])\n    agent = create_react_agent(fake_llm, [get_price])\n    result = agent.invoke({\"messages\": [{\"role\": \"user\", \"content\": \"Price of durian?\"}]})\n    assert \"not found\" in result[\"messages\"][-1].content.lower() or \"durian\" in result[\"messages\"][-1].content.lower()"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Agent vs Chain \u2014 When to Use Each"
          }
        ]
      },
