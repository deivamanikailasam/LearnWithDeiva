            "type": "text",
            "text": "import os\nos.environ[\"LANGSMITH_TRACING\"] = \"true\"\nos.environ[\"LANGSMITH_API_KEY\"] = \"lsv2_...\"\nos.environ[\"LANGSMITH_PROJECT\"] = \"my-agent\"\n\n# Every invoke/stream call is now automatically traced to LangSmith.\n# Traces show: graph topology, each node's input/output, token usage, latency.\n\n# Tag individual runs for filtering in the dashboard\nresult = agent.invoke(\n    {\"messages\": [{\"role\": \"user\", \"content\": \"Research LangGraph\"}]},\n    config={\n        \"configurable\": {\"thread_id\": \"t1\"},\n        \"tags\": [\"production\", \"research\"],\n        \"metadata\": {\"user_id\": \"u_42\"},\n        \"run_name\": \"research-agent-run\",\n    },\n)\n\n# Print agent steps without LangSmith \u2014 use stream_mode=\"updates\"\nfor update in agent.stream(\n    {\"messages\": [{\"role\": \"user\", \"content\": \"What is 17 squared?\"}]},\n    config={\"configurable\": {\"thread_id\": \"t2\"}},\n    stream_mode=\"updates\",\n):\n    for node_name, node_output in update.items():\n        last_msg = node_output.get(\"messages\", [])[-1] if node_output.get(\"messages\") else None\n        if last_msg:\n            print(f\"[{node_name}] {last_msg.__class__.__name__}: {str(last_msg.content)[:100]}\")"
          }
