  "doc": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Swarm intelligence in multi-agent systems achieves complex, adaptive behavior through a large number of simple, homogeneous agents following local rules \u2014 with no central controller. Each agent independently polls for work, claims a task, executes it, and pushes the result back. Emergent coordination arises from the shared task queue and result pool, not from any orchestrating authority."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Swarm pattern: homogeneous agents independently polling a shared task queue"
        }
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "When to Use Swarm Agents"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "High-volume parallel tasks: "
                  },
                  {
                    "type": "text",
                    "text": "thousands of independent items to process (document embeddings, code review checks, data transformations)."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Unknown task volume: "
                  },
                  {
                    "type": "text",
                    "text": "the number of tasks isn't known at graph compile time \u2014 agents poll until the queue is empty."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Fault tolerance: "
                  },
                  {
                    "type": "text",
                    "text": "if an agent crashes, other agents continue processing. The failed task re-enters the queue automatically."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Avoid: "
                  },
                  {
                    "type": "text",
                    "text": "tasks that must execute in a strict order (use a pipeline), tasks where agents need each other's output as input (use blackboard or supervisor), or when task count is tiny (overhead outweighs benefit)."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "SwarmState: Shared Task Queue and Result Pool"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The swarm's shared state holds a task queue that agents claim from and a result pool they push to. The key design: use "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "Annotated[list, operator.add]"
          },
          {
            "type": "text",
            "text": " for results, and a separate "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "claimed"
          },
          {
            "type": "text",
            "text": " set to prevent two agents from claiming the same task."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import operator\nfrom typing import Annotated, Any\nfrom typing_extensions import TypedDict\nfrom dataclasses import dataclass\n\n@dataclass\nclass SwarmTask:\n    task_id: str\n    payload: Any\n    priority: int = 0\n\n@dataclass\nclass SwarmResult:\n    task_id: str\n    output: Any\n    agent_id: str\n    success: bool\n\nclass SwarmState(TypedDict):\n    tasks: list[SwarmTask]          # all tasks (never mutated after init)\n    claimed: list[str]              # task_ids claimed by agents\n    results: Annotated[list[SwarmResult], operator.add]   # append-only\n    done: bool\n\ndef init_swarm(tasks: list[SwarmTask]) -> SwarmState:\n    return {\n        \"tasks\": tasks,\n        \"claimed\": [],\n        \"results\": [],\n        \"done\": False,\n    }"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "The Worker Agent Node"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Each worker agent follows the same local rule: find the next unclaimed task, claim it atomically, execute it, and return the result. The agent does not know about other agents \u2014 it only interacts with the shared state."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import uuid\nfrom langchain_anthropic import ChatAnthropic\nfrom langchain_core.messages import SystemMessage, HumanMessage\n\nworker_llm = ChatAnthropic(model=\"claude-haiku-4-5-20251001\")\n\ndef make_worker_agent(agent_id: str):\n    \"\"\"Factory: returns a worker node function with a fixed agent_id.\"\"\"    \n    def worker_node(state: SwarmState) -> dict:\n        # Find first unclaimed task\n        claimed_ids = set(state[\"claimed\"])\n        available = [t for t in state[\"tasks\"] if t.task_id not in claimed_ids]\n        \n        if not available:\n            # No work left \u2014 this agent is idle\n            return {}\n        \n        # Claim the highest-priority task\n        task = max(available, key=lambda t: t.priority)\n        \n        # Execute the task\n        try:\n            response = worker_llm.invoke([\n                SystemMessage(content=f\"You are worker agent {agent_id}. Complete the assigned task concisely.\"),\n                HumanMessage(content=f\"Task {task.task_id}: {task.payload}\")\n            ])\n            result = SwarmResult(\n                task_id=task.task_id,\n                output=response.content,\n                agent_id=agent_id,\n                success=True,\n            )\n        except Exception as e:\n            result = SwarmResult(\n                task_id=task.task_id,\n                output=str(e),\n                agent_id=agent_id,\n                success=False,\n            )\n        \n        return {\n            \"claimed\": state[\"claimed\"] + [task.task_id],\n            \"results\": [result],\n        }\n    \n    worker_node.__name__ = f\"worker_{agent_id}\"\n    return worker_node\n\n# Create a pool of 4 homogeneous workers\nworkers = {f\"agent_{i}\": make_worker_agent(f\"agent_{i}\") for i in range(4)}"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Wiring the Swarm with LangGraph Send API"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The most efficient swarm implementation in LangGraph uses the "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "Send"
          },
          {
            "type": "text",
            "text": " API to fan out all tasks to workers concurrently. A dispatcher node creates one "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "Send"
          },
          {
            "type": "text",
            "text": " per task, and LangGraph runs them all in parallel, collecting results via the "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "operator.add"
          },
          {
            "type": "text",
            "text": " reducer."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langgraph.graph import StateGraph, END\nfrom langgraph.types import Send\nfrom typing import TypedDict\n\n# Per-task state for individual worker invocations\nclass SingleTaskState(TypedDict):\n    task: SwarmTask\n    agent_id: str\n\ndef dispatcher(state: SwarmState) -> list[Send]:\n    \"\"\"Fan out: one Send per task, distributed round-robin across agents.\"\"\"    agent_ids = list(workers.keys())\n    sends = []\n    for i, task in enumerate(state[\"tasks\"]):\n        agent_id = agent_ids[i % len(agent_ids)]\n        sends.append(Send(\"execute_task\", {\"task\": task, \"agent_id\": agent_id}))\n    return sends\n\ndef execute_task(state: SingleTaskState) -> dict:\n    \"\"\"Single-task worker node (used with Send API).\"\"\"    task = state[\"task\"]\n    agent_id = state[\"agent_id\"]\n    \n    try:\n        response = worker_llm.invoke([\n            SystemMessage(content=f\"You are worker {agent_id}. Complete the task.\"),\n            HumanMessage(content=f\"Task {task.task_id}: {task.payload}\")\n        ])\n        result = SwarmResult(task.task_id, response.content, agent_id, True)\n    except Exception as e:\n        result = SwarmResult(task.task_id, str(e), agent_id, False)\n    \n    return {\"results\": [result]}\n\ndef check_done(state: SwarmState) -> dict:\n    \"\"\"Mark swarm complete when all tasks have results.\"\"\"    done = len(state[\"results\"]) >= len(state[\"tasks\"])\n    return {\"done\": done}\n\n# Build the swarm graph\nbuilder = StateGraph(SwarmState)\nbuilder.add_node(\"dispatcher\", dispatcher)\nbuilder.add_node(\"execute_task\", execute_task)\nbuilder.add_node(\"check_done\", check_done)\n\nbuilder.set_entry_point(\"dispatcher\")\nbuilder.add_conditional_edges(\"dispatcher\", dispatcher)\nbuilder.add_edge(\"execute_task\", \"check_done\")\nbuilder.add_edge(\"check_done\", END)\n\nswarm_graph = builder.compile()"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Running the Swarm"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Create tasks\ntasks = [\n    SwarmTask(task_id=\"t1\", payload=\"Summarize the concept of gradient descent.\", priority=2),\n    SwarmTask(task_id=\"t2\", payload=\"List 3 use cases for vector databases.\", priority=1),\n    SwarmTask(task_id=\"t3\", payload=\"Explain CAP theorem in one paragraph.\", priority=2),\n    SwarmTask(task_id=\"t4\", payload=\"Write a Python hello-world function.\", priority=0),\n    SwarmTask(task_id=\"t5\", payload=\"What is a transformer model?\", priority=1),\n]\n\ninitial = init_swarm(tasks)\nfinal = swarm_graph.invoke(initial)\n\nprint(f\"Tasks submitted: {len(tasks)}\")\nprint(f\"Results collected: {len(final['results'])}\")\nprint(f\"Success rate: {sum(1 for r in final['results'] if r.success) / len(final['results']):.0%}\")\n\nfor result in sorted(final[\"results\"], key=lambda r: r.task_id):\n    status = \"OK\" if result.success else \"FAIL\"\n    print(f\"  [{status}] {result.task_id} (by {result.agent_id}): {result.output[:80]}...\")"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Task Prioritization and Adaptive Load Balancing"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A simple priority-based dispatcher assigns higher-priority tasks to the most-capable agents. For dynamic load balancing \u2014 where faster agents pick up more tasks \u2014 use a polling loop instead of a one-shot Send fan-out."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\n\nasync def adaptive_worker(agent_id: str, task_queue: asyncio.Queue, result_queue: asyncio.Queue):\n    \"\"\"Worker coroutine that polls the queue until empty.\"\"\"    while True:\n        try:\n            task = task_queue.get_nowait()\n        except asyncio.QueueEmpty:\n            break   # no more tasks\n        \n        try:\n            response = await worker_llm.ainvoke([\n                SystemMessage(content=f\"You are worker {agent_id}.\"),\n                HumanMessage(content=f\"{task.task_id}: {task.payload}\")\n            ])\n            result = SwarmResult(task.task_id, response.content, agent_id, True)\n        except Exception as e:\n            result = SwarmResult(task.task_id, str(e), agent_id, False)\n        \n        await result_queue.put(result)\n        task_queue.task_done()\n\nasync def run_adaptive_swarm(tasks: list[SwarmTask], n_workers: int = 8) -> list[SwarmResult]:\n    \"\"\"Adaptive swarm: faster workers naturally pick up more tasks.\"\"\"    # Sort by priority (high first)\n    task_queue = asyncio.Queue()\n    for task in sorted(tasks, key=lambda t: -t.priority):\n        await task_queue.put(task)\n    \n    result_queue: asyncio.Queue[SwarmResult] = asyncio.Queue()\n    \n    # Spawn all workers; they stop when the queue empties\n    await asyncio.gather(*[\n        adaptive_worker(f\"w{i}\", task_queue, result_queue)\n        for i in range(n_workers)\n    ])\n    \n    results = []\n    while not result_queue.empty():\n        results.append(await result_queue.get())\n    return results\n\n# Run the adaptive swarm\nimport asyncio\nresults = asyncio.run(run_adaptive_swarm(tasks, n_workers=4))\nprint(f\"Collected {len(results)} results\")"
          }
        ]
      },
