        "content": [
          {
            "type": "text",
            "text": "Handling Failures: Retry and Dead Letter Queue"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Failed tasks should not silently disappear. Track failed results separately and retry them with a different worker or a more capable model."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def retry_failed_tasks(state: SwarmState) -> dict:\n    \"\"\"Re-queue failed tasks for a second attempt with a stronger model.\"\"\"    failed_ids = {r.task_id for r in state[\"results\"] if not r.success}\n    if not failed_ids:\n        return {\"done\": True}\n    \n    retry_tasks = [t for t in state[\"tasks\"] if t.task_id in failed_ids]\n    \n    # Use a stronger model for retries\n    retry_llm = ChatAnthropic(model=\"claude-sonnet-5\")\n    \n    retry_results = []\n    for task in retry_tasks:\n        try:\n            response = retry_llm.invoke([\n                SystemMessage(content=\"You are a fallback agent for failed tasks. Be thorough.\"),\n                HumanMessage(content=f\"{task.task_id}: {task.payload}\")\n            ])\n            retry_results.append(SwarmResult(task.task_id, response.content, \"retry_agent\", True))\n        except Exception as e:\n            # Dead letter: log and skip\n            print(f\"DEAD LETTER: {task.task_id} failed after retry: {e}\")\n    \n    return {\"results\": retry_results, \"done\": True}\n\n# Add retry node to the graph\nbuilder.add_node(\"retry_failed\", retry_failed_tasks)\n\ndef after_check_done(state: SwarmState) -> str:\n    has_failures = any(not r.success for r in state[\"results\"])\n    return \"retry_failed\" if has_failures else \"__end__\"\n\n# Replace the direct edge with conditional routing\nbuilder.add_conditional_edges(\"check_done\", after_check_done, {\n    \"retry_failed\": \"retry_failed\",\n    \"__end__\": END,\n})\nbuilder.add_edge(\"retry_failed\", END)"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing the Swarm"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import pytest\nfrom unittest.mock import patch, AsyncMock, MagicMock\n\nclass TestSwarmDispatcher:\n    def test_dispatcher_creates_one_send_per_task(self):\n        tasks = [SwarmTask(f\"t{i}\", f\"payload {i}\") for i in range(5)]\n        state = init_swarm(tasks)\n        sends = dispatcher(state)\n        assert len(sends) == 5\n    \n    def test_dispatcher_distributes_round_robin(self):\n        tasks = [SwarmTask(f\"t{i}\", \"payload\") for i in range(4)]\n        state = init_swarm(tasks)\n        sends = dispatcher(state)\n        agent_ids = [s.arg[\"agent_id\"] for s in sends]\n        # Each agent_id should appear at most once for 4 tasks and 4 workers\n        assert len(set(agent_ids)) == 4\n\nclass TestExecuteTask:\n    @patch(\"worker_llm\")\n    def test_successful_task(self, mock_llm):\n        mock_llm.invoke.return_value = MagicMock(content=\"result text\")\n        task = SwarmTask(\"t1\", \"What is AI?\")\n        result_state = execute_task({\"task\": task, \"agent_id\": \"agent_0\"})\n        assert len(result_state[\"results\"]) == 1\n        assert result_state[\"results\"][0].success is True\n        assert result_state[\"results\"][0].task_id == \"t1\"\n    \n    @patch(\"worker_llm\")\n    def test_failed_task_returns_success_false(self, mock_llm):\n        mock_llm.invoke.side_effect = RuntimeError(\"API timeout\")\n        task = SwarmTask(\"t2\", \"some task\")\n        result_state = execute_task({\"task\": task, \"agent_id\": \"agent_1\"})\n        assert result_state[\"results\"][0].success is False\n\nclass TestCheckDone:\n    def test_done_when_all_tasks_have_results(self):\n        tasks = [SwarmTask(f\"t{i}\", \"x\") for i in range(3)]\n        state = init_swarm(tasks)\n        state[\"results\"] = [SwarmResult(f\"t{i}\", \"out\", \"a\", True) for i in range(3)]\n        out = check_done(state)\n        assert out[\"done\"] is True\n    \n    def test_not_done_when_partial_results(self):\n        tasks = [SwarmTask(f\"t{i}\", \"x\") for i in range(3)]\n        state = init_swarm(tasks)\n        state[\"results\"] = [SwarmResult(\"t0\", \"out\", \"a\", True)]\n        out = check_done(state)\n        assert out[\"done\"] is False"
          }
        ]
      },
