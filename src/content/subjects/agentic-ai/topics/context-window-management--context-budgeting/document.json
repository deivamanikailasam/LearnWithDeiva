        "content": [
          {
            "type": "text",
            "text": "# Summarize large tool results before inserting into context\n# Prevents a single tool call from consuming the entire tool budget\nimport anthropic\n\nclient = anthropic.Anthropic()\n\nMAX_TOOL_RESULT_TOKENS = 2_000  # per result\n\ndef summarize_if_large(\n    tool_name: str,\n    result: str,\n    max_tokens: int = MAX_TOOL_RESULT_TOKENS,\n) -> str:\n    import tiktoken\n    enc = tiktoken.get_encoding('cl100k_base')\n    if len(enc.encode(result)) <= max_tokens:\n        return result  # already fits, no summarization needed\n\n    # Summarize to fit within budget\n    response = client.messages.create(\n        model='claude-haiku-4-5-20251001',  # cheap fast model for summarization\n        max_tokens=max_tokens,\n        messages=[{\n            'role': 'user',\n            'content': (\n                f'Summarize the following {tool_name} result in under '\n                f'{max_tokens // 4} words. Preserve key facts, numbers, '\n                f'and status codes.\\n\\n{result[:8000]}'\n            ),\n        }],\n    )\n    return f'[SUMMARIZED] {response.content[0].text}'\n\n# Usage in tool-call loop:\n# raw_result = run_tool(tool_name, tool_input)\n# compact_result = summarize_if_large(tool_name, raw_result)\n# messages.append({'role': 'tool', 'content': compact_result, ...})\n"
