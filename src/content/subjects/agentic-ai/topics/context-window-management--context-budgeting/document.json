        "content": [
          {
            "type": "text",
            "text": "# Adaptive budget: shift allocation based on turn type\n# Tool-heavy turns need more tool budget; retrieval-heavy turns need more memory budget\n\nfrom enum import Enum\nfrom dataclasses import dataclass\n\nclass TurnType(Enum):\n    CONVERSATIONAL = 'conversational'   # simple Q&A\n    RETRIEVAL      = 'retrieval'         # RAG-heavy\n    TOOL_CALL      = 'tool_call'         # multi-step tool use\n    SUMMARIZATION  = 'summarization'     # long doc processing\n\n@dataclass\nclass AdaptiveBudget:\n    window_size:    int = 200_000\n    output_reserve: int =  24_000  # constant regardless of turn type\n\n    # Per-turn-type allocations for the remaining input budget\n    _PROFILES: dict = None\n\n    def __post_init__(self):\n        input_budget = self.window_size - self.output_reserve\n        self._PROFILES = {\n            TurnType.CONVERSATIONAL: {\n                'system': int(input_budget * 0.12),\n                'history': int(input_budget * 0.50),\n                'memory':  int(input_budget * 0.20),\n                'tools':   int(input_budget * 0.10),\n                'docs':    int(input_budget * 0.08),\n            },\n            TurnType.RETRIEVAL: {\n                'system': int(input_budget * 0.08),\n                'history': int(input_budget * 0.15),\n                'memory':  int(input_budget * 0.25),\n                'tools':   int(input_budget * 0.08),\n                'docs':    int(input_budget * 0.44),\n            },\n            TurnType.TOOL_CALL: {\n                'system': int(input_budget * 0.08),\n                'history': int(input_budget * 0.20),\n                'memory':  int(input_budget * 0.10),\n                'tools':   int(input_budget * 0.52),\n                'docs':    int(input_budget * 0.10),\n            },\n        }\n\n    def get(self, turn_type: TurnType) -> dict:\n        return self._PROFILES[turn_type]\n\nbudget = AdaptiveBudget()\nprint(budget.get(TurnType.RETRIEVAL))\n# {'system': 14080, 'history': 26400, 'memory': 44000, 'tools': 14080, 'docs': 77440}\n"
          }
