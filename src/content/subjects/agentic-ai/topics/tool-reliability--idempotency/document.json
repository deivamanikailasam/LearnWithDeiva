          {
            "type": "text",
            "text": "Testing Idempotent Tools"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import pytest\n\ndef test_send_invoice_exactly_once(monkeypatch):\n    call_count = 0\n    def fake_send(to, order_id):\n        nonlocal call_count\n        call_count += 1\n        return {\"ok\": True, \"message_id\": f\"msg_{order_id}\"}\n\n    monkeypatch.setattr(\"__main__._do_send_email\", fake_send)\n    key = \"test-key-001\"\n\n    r1 = send_invoice_email(\"ord_1\", \"user@example.com\", key)\n    r2 = send_invoice_email(\"ord_1\", \"user@example.com\", key)\n    r3 = send_invoice_email(\"ord_1\", \"user@example.com\", key)\n\n    assert r1[\"ok\"]\n    assert r2[\"idempotent_replay\"] is True\n    assert r3[\"idempotent_replay\"] is True\n    assert call_count == 1, \"Email must be sent exactly once\"\n\ndef test_different_keys_send_independently(monkeypatch):\n    sent = []\n    def fake_send(to, order_id):\n        sent.append(order_id)\n        return {\"ok\": True, \"message_id\": f\"msg_{order_id}\"}\n\n    monkeypatch.setattr(\"__main__._do_send_email\", fake_send)\n\n    send_invoice_email(\"ord_1\", \"a@example.com\", \"key-A\")\n    send_invoice_email(\"ord_2\", \"b@example.com\", \"key-B\")\n\n    assert len(sent) == 2, \"Different keys must execute independently\"\n\ndef test_failure_is_not_cached(monkeypatch):\n    attempts = 0\n    def flaky_send(to, order_id):\n        nonlocal attempts\n        attempts += 1\n        if attempts == 1:\n            raise RuntimeError(\"network blip\")\n        return {\"ok\": True, \"message_id\": f\"msg_{order_id}\"}\n\n    monkeypatch.setattr(\"__main__._do_send_email\", flaky_send)\n    key = \"key-flaky\"\n\n    r1 = send_invoice_email(\"ord_3\", \"c@example.com\", key)\n    assert \"error\" in r1  # first attempt fails\n    r2 = send_invoice_email(\"ord_3\", \"c@example.com\", key)\n    assert r2[\"ok\"]       # retry succeeds\n    assert attempts == 2  # real call on retry, not cache\n"
          }
        ]
      },
