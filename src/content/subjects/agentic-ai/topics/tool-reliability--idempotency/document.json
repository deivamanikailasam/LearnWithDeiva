            "type": "text",
            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "An idempotent tool produces the same outcome on repeated calls with the same inputs — essential for safe retries in an agentic context."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "GET"
                  },
                  {
                    "type": "text",
                    "text": ", "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "PUT"
                  },
                  {
                    "type": "text",
                    "text": ", and "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "DELETE"
                  },
                  {
                    "type": "text",
                    "text": " are idempotent by HTTP semantics; "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "POST"
                  },
                  {
                    "type": "text",
                    "text": " requires an explicit idempotency key."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Generate the idempotency key before the first attempt and derive it from the logical identity of the operation — not from time or randomness — so retries reuse the same key."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Cache only successful results; failed calls should remain retryable."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "For distributed systems, use a unique database constraint on the key rather than an in-memory cache — process restarts and horizontal scaling will clear in-memory state."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Return "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "idempotent_replay: true"
                  },
                  {
                    "type": "text",
                    "text": " in replayed responses so the caller and the agent can distinguish a fresh result from a cached one."
                  }
                ]
              }
            ]
          }
        ]
      }
