      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Avoiding Common Nesting Mistakes"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Shared mutable state"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 subgraph state is passed by value. If a worker inside the subgraph modifies a list in place ("
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "state['items'].append(...)"
                  },
                  {
                    "type": "text",
                    "text": "), those changes do not appear in the outer graph's copy. Always return new dicts."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Forgetting to map errors"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 subgraph errors live in the subgraph's "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "errors"
                  },
                  {
                    "type": "text",
                    "text": " field. If the wrapper node doesn't copy them to the outer "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "errors"
                  },
                  {
                    "type": "text",
                    "text": " field, failures become invisible."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Deep nesting without clear ownership"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 more than three layers (outer \u2192 inner \u2192 inner-inner) makes tracing failures impractical. Flatten to two levels if possible; use structured logging at each layer boundary."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Re-compiling subgraphs on every call"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "sg.compile()"
                  },
                  {
                    "type": "text",
                    "text": " is not free. Compile once at module level and share the compiled instance."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "marks": [
                  {
                    "type": "bold"
                  }
                ],
                "text": "Nesting readiness checklist"
              }
            ]
          },
          {
            "type": "bulletList",
            "content": [
              {
                "type": "listItem",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Subgraph compiled once at module level (not inside a node)"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "listItem",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Wrapper node explicitly maps all needed fields from outer \u2192 inner and inner \u2192 outer"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "listItem",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Inner errors surfaced to outer errors field in wrapper node"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "listItem",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Tests mock the subgraph.invoke so outer routing tests are fast"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "listItem",
                "content": [
                  {
