      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Checkpointing Nested Graphs"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When an outer graph uses a checkpointer, each invocation of a subgraph node is checkpointed as a single atomic step \u2014 the subgraph's internal states are not persisted separately by the outer checkpointer. If you need to resume the inner subgraph mid-run (e.g., it crashed partway through), attach a separate checkpointer to the subgraph at compile time with a distinct thread namespace."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langgraph.checkpoint.sqlite import SqliteSaver\n\n# Outer checkpointer \u2014 checkpoints the outer graph after each outer node\nouter_checkpointer = SqliteSaver.from_conn_string(\"outer.db\")\n\n# Inner checkpointer \u2014 enables resuming the subgraph independently\ninner_checkpointer = SqliteSaver.from_conn_string(\"inner.db\")\n\nretrieval_subgraph = build_retrieval_subgraph()\nretrieval_subgraph_checkpointed = retrieval_subgraph.compile(\n    checkpointer=inner_checkpointer,\n)\n\n# Wrapper node uses the checkpointed subgraph with a scoped thread id\ndef call_retrieval_checkpointed(state: OuterState) -> dict:\n    # Scope inner thread id under the outer thread id to avoid collisions\n    inner_thread = f\"retrieval::{state.get('run_id', 'default')}\"\n    result = retrieval_subgraph_checkpointed.invoke(\n        {\n            \"query\": state[\"task\"],\n            \"web_result\": \"\", \"doc_result\": \"\", \"errors\": [],\n        },\n        config={\"configurable\": {\"thread_id\": inner_thread}},\n    )\n    return {\n        \"retrieval_web\": result[\"web_result\"],\n        \"retrieval_doc\": result[\"doc_result\"],\n        \"errors\": result.get(\"errors\", []),\n    }\n\n# Outer graph uses its own checkpointer\nouter_pipeline = build_outer_graph().compile(checkpointer=outer_checkpointer)\nconfig = {\"configurable\": {\"thread_id\": \"run-42\"}}\nresult = outer_pipeline.invoke(\n    {\"task\": \"explain nested agents\", \"retrieval_web\": \"\", \"retrieval_doc\": \"\",\n     \"answer\": \"\", \"errors\": [], \"run_id\": \"run-42\"},\n    config=config,\n)\n"
          }
        ]
      },
