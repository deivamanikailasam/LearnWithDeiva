      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Reusing Subgraphs Across Pipelines"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A compiled subgraph is a plain Python object \u2014 store it in a module and import it wherever needed. Multiple outer pipelines can share the same inner subgraph instance, which is read-only from the subgraph's perspective (state is passed by value, not by reference)."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# subgraphs.py \u2014 shared subgraph definitions\nfrom langgraph.graph import StateGraph, END\nfrom typing import TypedDict, Annotated\nimport operator\n\n# Build once at module level; import where needed\nretrieval_subgraph = build_retrieval_subgraph()\nanalysis_subgraph  = build_analysis_subgraph()   # defined similarly\n\n# pipeline_a.py\nfrom subgraphs import retrieval_subgraph, analysis_subgraph\n\ndef build_pipeline_a():\n    builder = StateGraph(PipelineAState)\n    builder.add_node(\"retrieve\", lambda s: retrieval_subgraph.invoke({\n        \"query\": s[\"task\"], \"web_result\": \"\", \"doc_result\": \"\", \"errors\": [],\n    }))\n    # ...\n    return builder.compile()\n\n# pipeline_b.py  \u2014 reuses the same retrieval_subgraph\nfrom subgraphs import retrieval_subgraph\n\ndef build_pipeline_b():\n    builder = StateGraph(PipelineBState)\n    builder.add_node(\"fetch\", lambda s: retrieval_subgraph.invoke({\n        \"query\": s[\"question\"], \"web_result\": \"\", \"doc_result\": \"\", \"errors\": [],\n    }))\n    # ...\n    return builder.compile()\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing Nested Agents"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from unittest.mock import MagicMock, patch\n\ndef test_outer_graph_uses_subgraph_result():\n    \"\"\"Mock the subgraph so the outer graph test is fast and isolated.\"\"\"\n    mock_subgraph = MagicMock()\n    mock_subgraph.invoke.return_value = {\n        \"web_result\": \"web content\",\n        \"doc_result\": \"doc content\",\n        \"errors\": [],\n    }\n    mock_resp = MagicMock()\n    mock_resp.content = \"final answer\"\n\n    with (\n        patch(\"my_pipeline.retrieval_subgraph\", mock_subgraph),\n        patch(\"my_pipeline.sonnet\") as mock_llm,\n    ):\n        mock_llm.invoke.return_value = mock_resp\n        pipeline = build_outer_graph()\n        result = pipeline.invoke({\n            \"task\": \"explain X\", \"retrieval_web\": \"\", \"retrieval_doc\": \"\",\n            \"answer\": \"\", \"errors\": [],\n        })\n\n    assert result[\"answer\"] == \"final answer\"\n    # Verify subgraph was called with the right query\n    mock_subgraph.invoke.assert_called_once()\n    call_args = mock_subgraph.invoke.call_args[0][0]\n    assert call_args[\"query\"] == \"explain X\"\n\ndef test_inner_subgraph_error_surfaces_in_outer():\n    mock_subgraph = MagicMock()\n    mock_subgraph.invoke.return_value = {\n        \"web_result\": \"\", \"doc_result\": \"\", \"errors\": [\"web:timeout\"],\n    }\n    with patch(\"my_pipeline.retrieval_subgraph\", mock_subgraph):\n        out = call_retrieval({\"task\": \"test\", \"retrieval_web\": \"\",\n                              \"retrieval_doc\": \"\", \"answer\": \"\", \"errors\": []})\n    assert \"web:timeout\" in out[\"errors\"]\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
