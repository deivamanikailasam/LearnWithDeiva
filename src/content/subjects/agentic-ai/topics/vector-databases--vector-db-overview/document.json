      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Deleting and Updating Vectors"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Vectors are immutable in Qdrant \u2014 updating a vector means upserting with the same id. Deleting removes the point from both the HNSW index and the payload store."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from qdrant_client.models import PointIdsList\n\n\ndef delete_point(point_id: str) -> None:\n    _QC.delete(\n        collection_name=COLLECTION,\n        points_selector=PointIdsList(points=[point_id]),\n    )\n\n\ndef update_point(point_id: str, new_text: str, new_payload: dict) -> None:\n    \"\"\"Re-embed and upsert with the same id.\"\"\"\n    new_vec = _VC.embed([new_text], model=\"voyage-3\", input_type=\"document\").embeddings[0]\n    _QC.upsert(\n        collection_name=COLLECTION,\n        points=[\n            PointStruct(\n                id=point_id,\n                vector=new_vec,\n                payload={\"text\": new_text, **new_payload},\n            )\n        ],\n    )\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Collections, Shards, and Replication"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "In Qdrant a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "collection"
          },
          {
            "type": "text",
            "text": " can be distributed across multiple "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "shards"
          },
          {
            "type": "text",
            "text": " for horizontal scaling, and each shard can be "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "replicated"
          },
          {
            "type": "text",
            "text": " across nodes for fault tolerance. For single-node agent deployments these settings are irrelevant \u2014 the defaults (1 shard, 1 replica) are fine."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from qdrant_client import QdrantClient\nfrom qdrant_client.models import Distance, VectorParams\n\nclient = QdrantClient(url=\"http://localhost:6333\")\n\n# Single-node: default sharding (fine for agent memory)\nclient.create_collection(\n    collection_name=\"docs\",\n    vectors_config=VectorParams(size=1024, distance=Distance.COSINE),\n    # shard_number=1, replication_factor=1  \u2190 defaults\n)\n\n# Multi-node cluster: 4 shards, 2 replicas each\nclient.create_collection(\n    collection_name=\"docs_scaled\",\n    vectors_config=VectorParams(size=1024, distance=Distance.COSINE),\n    shard_number=4,\n    replication_factor=2,\n)\n\n# Check collection info\ninfo = client.get_collection(\"docs\")\nprint(info.config.params.vectors)          # VectorParams(size=1024, ...)\nprint(info.vectors_count)                  # number of vectors stored\nprint(info.indexed_vectors_count)          # vectors in the HNSW index\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Scrolling and Bulk Export"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "scroll"
          },
          {
            "type": "text",
            "text": " API iterates through all points in a collection \u2014 useful for bulk export, re-embedding after a model switch, or debugging."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def scroll_all(collection: str, batch_size: int = 100) -> list[dict]:\n    \"\"\"Return all payloads in a collection via cursor pagination.\"\"\"\n    records, offset = [], None\n    while True:\n        batch, next_offset = _QC.scroll(\n            collection_name=collection,\n            limit=batch_size,\n            offset=offset,\n            with_payload=True,\n            with_vectors=False,   # skip vectors for payload-only export\n        )\n        records.extend([{\"id\": r.id, **r.payload} for r in batch])\n        if next_offset is None:\n            break\n        offset = next_offset\n    return records\n\n\n# Export all memories for a user\nall_records = scroll_all(COLLECTION)\nalice_records = [r for r in all_records if r.get(\"user_id\") == \"alice\"]\nprint(f\"Alice has {len(alice_records)} memory records\")\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "pgvector: Embeddings Inside PostgreSQL"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "If your agent already uses PostgreSQL for relational data, "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "pgvector"
          },
          {
            "type": "text",
            "text": " adds a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "vector"
          },
          {
            "type": "text",
            "text": " column type and ANN index support. This avoids running a second database process \u2014 a strong advantage for small-to-medium deployments."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import psycopg2\nfrom psycopg2.extras import execute_values\nimport voyageai\n\nCONN_STR = \"postgresql://user:pass@localhost/agentdb\"\n\n\ndef setup_pgvector(conn_str: str) -> None:\n    with psycopg2.connect(conn_str) as con:\n        with con.cursor() as cur:\n            cur.execute(\"CREATE EXTENSION IF NOT EXISTS vector\")\n            cur.execute(\"\"\"\n                CREATE TABLE IF NOT EXISTS memories (\n                    id         SERIAL PRIMARY KEY,\n                    user_id    TEXT NOT NULL,\n                    body       TEXT NOT NULL,\n                    embedding  vector(1024),\n                    created_at REAL NOT NULL DEFAULT extract(epoch from now())\n                )\n            \"\"\")\n            cur.execute(\"\"\"\n                CREATE INDEX IF NOT EXISTS memories_vec_idx\n                ON memories USING ivfflat (embedding vector_cosine_ops)\n                WITH (lists = 100)\n            \"\"\")\n        con.commit()\n\n\ndef pg_search(query: str, user_id: str, k: int = 5) -> list[dict]:\n    vc     = voyageai.Client()\n    q_vec  = vc.embed([query], model=\"voyage-3\", input_type=\"query\").embeddings[0]\n    vec_str = \"[\" + \",\".join(str(x) for x in q_vec) + \"]\"\n    with psycopg2.connect(CONN_STR) as con:\n        with con.cursor() as cur:\n            cur.execute(\"\"\"\n                SELECT id, body, 1-(embedding <=> %s::vector) AS score\n                FROM memories\n                WHERE user_id = %s\n                ORDER BY embedding <=> %s::vector\n                LIMIT %s\n            \"\"\", (vec_str, user_id, vec_str, k))\n            return [\n                {\"id\": row[0], \"body\": row[1], \"score\": row[2]}\n                for row in cur.fetchall()\n            ]\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Choosing Between Qdrant and pgvector"
          }
        ]
      },
      {
        "type": "table",
        "content": [
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableHeader",
