            "type": "text",
            "text": "import pytest\nfrom unittest.mock import patch, MagicMock\n\n\ndef test_merge_findings_deduplication():\n    existing = [Finding(\"a\", \"SQL injection risk\", 0.7)]\n    new = [Finding(\"a\", \"SQL injection risk\", 0.9)]  # higher confidence\n    result = merge_findings(existing, new)\n    assert len(result) == 1\n    assert result[0].confidence == 0.9\n\n\ndef test_merge_findings_different_agents():\n    existing = [Finding(\"agent1\", \"claim X\", 0.8)]\n    new = [Finding(\"agent2\", \"claim X\", 0.8)]  # same claim, different agent\n    result = merge_findings(existing, new)\n    assert len(result) == 2  # both kept \u2014 different agents\n\n\ndef test_controller_routes_to_researcher_when_few_findings():\n    state: BlackboardState = {\n        \"findings\": [],\n        \"hypotheses\": [],\n        \"critiques\": [],\n        \"control_flags\": {},\n        \"final_report\": \"\",\n        \"iteration\": 0,\n    }\n    assert controller(state) == \"researcher\"\n\n\ndef test_controller_stops_when_flag_set():\n    state: BlackboardState = {\n        \"findings\": [Finding(\"a\", \"x\", 0.9)] * 6,\n        \"hypotheses\": [\"h1\", \"h2\", \"h3\"],\n        \"critiques\": [\"c1\", \"c2\"],\n        \"control_flags\": {\"stop\": True},\n        \"final_report\": \"\",\n        \"iteration\": 3,\n    }\n    assert controller(state) == \"reporter\"\n\n\n@patch(\"__main__.researcher_llm\")\ndef test_researcher_writes_findings(mock_llm):\n    mock_llm.invoke.return_value = MagicMock(content=\"Finding: XSS risk in login form\")\n    state: BlackboardState = {\n        \"findings\": [],\n        \"hypotheses\": [],\n        \"critiques\": [],\n        \"control_flags\": {\"focus\": \"security\"},\n        \"final_report\": \"\",\n        \"iteration\": 0,\n    }\n    result = researcher(state)\n    assert \"findings\" in result\n    assert result[\"iteration\"] == 1"
          }
