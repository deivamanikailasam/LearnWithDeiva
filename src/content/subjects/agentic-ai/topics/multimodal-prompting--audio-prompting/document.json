  "format": "tiptap/v1",
  "updatedAt": "2026-06-22T17:46:43.950Z",
  "doc": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Audio prompting provides "
          },
          {
            "type": "text",
            "text": "speech or sound",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " as input to speech-capable models. Agents transcribe calls, analyze tone, extract action items from meetings, and power voice interfaces where users speak instead of type."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "What it is"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Audio files (WAV, MP3) or streaming speech are sent to models with speech-to-text or native audio understanding. Prompts specify language, desired transcript format, diarization needs, and downstream tasks (summarize, classify intent)."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Why it matters"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Support and field-service agents increasingly process phone recordings. Audio prompting avoids brittle separate STT + LLM handoffs when integrated models handle both, though dedicated STT may still win on accuracy or cost."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "How to implement"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "text"
        },
        "content": [
          {
            "type": "text",
            "text": "Audio: [support_call.mp3]\nTask: Transcribe, then extract {\"issue\": \"\", \"resolution\": \"\", \"follow_up_required\": bool}\nUse speaker labels if multiple speakers detected."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Trade-offs"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Background noise and accents increase error rates"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Long recordings exceed model limits — segment first"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Key takeaways"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Specify transcript format and post-transcription task clearly"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Segment long audio; validate PII handling on recordings"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Choose integrated vs. separate STT based on accuracy and cost"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
