          {
            "type": "text",
            "text": "Running BFCL Evaluation"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "bash"
        },
        "content": [
          {
            "type": "text",
            "text": "# Clone the Gorilla repo which hosts BFCL\ngit clone https://github.com/ShishirPatil/gorilla.git\ncd gorilla/berkeley-function-call-leaderboard\n\npip install -r requirements.txt\n\n# Set your model handler (Anthropic example)\nexport ANTHROPIC_API_KEY=...\n\n# Run evaluation on Simple FC category\npython openfunctions_evaluation.py \\\n    --model claude-haiku-4-5-20251001 \\\n    --test-category simple \\\n    --num-gpus 0        # CPU-only for API models\n\n# Results saved to result/claude-haiku-4-5-20251001/simple_fc.json\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Checking BFCL Results Programmatically"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import json\nfrom pathlib import Path\n\ndef load_bfcl_results(result_dir: str, category: str) -> dict:\n    path = Path(result_dir) / f\"{category}_fc.json\"\n    data = json.loads(path.read_text())\n\n    total = len(data)\n    correct = sum(1 for r in data if r[\"valid\"])\n    accuracy = correct / total\n\n    # Break down by error type\n    errors = {}\n    for r in data:\n        if not r[\"valid\"]:\n            err = r.get(\"error_type\", \"unknown\")\n            errors[err] = errors.get(err, 0) + 1\n\n    return {\n        \"accuracy\": accuracy,\n        \"total\": total,\n        \"correct\": correct,\n        \"errors\": dict(sorted(errors.items(), key=lambda x: -x[1])),\n    }\n\nstats = load_bfcl_results(\"result/claude-haiku-4-5-20251001\", \"simple\")\nprint(f\"Simple FC accuracy: {stats['accuracy']:.2%}\")\nprint(\"Error breakdown:\", stats[\"errors\"])\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "API-Bank"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "API-Bank structures evaluation as three difficulty tiers. Level 1 tests single API calls; Level 2 tests multi-call plans; Level 3 requires the model to both "
          },
          {
            "type": "text",
            "text": "retrieve",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " the right API from a large pool and then "
          },
          {
            "type": "text",
            "text": "plan",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " a multi-step call sequence. It directly tests retrieval-augmented tool use — a realistic scenario where the agent is given a large API catalogue and must find the right tools before calling them."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from datasets import load_dataset\n\napi_bank = load_dataset(\"liminghao1630/API-Bank\", split=\"test\")\n\n# Filter by level\nlevel3 = [t for t in api_bank if t[\"level\"] == 3]\nprint(f\"Level 3 tasks: {len(level3)}\")\nprint(level3[0][\"user_request\"])          # natural language goal\nprint(level3[0][\"ground_truth_apis\"])     # list of APIs to call\nprint(level3[0][\"api_pool\"][:3])          # candidate APIs to choose from\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Retrieval-Augmented Tool Selection"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\nimport json\n\nclient = anthropic.Anthropic()\n\ndef select_apis(user_request: str, api_pool: list[dict], model=\"claude-haiku-4-5-20251001\") -> list[str]:\n    \"\"\"Step 1: retrieve relevant APIs from the pool before calling.\"\"\"\n    pool_text = json.dumps(\n        [{\"name\": a[\"name\"], \"description\": a[\"description\"]} for a in api_pool],\n        indent=2,\n    )\n    resp = client.messages.create(\n        model=model,\n        max_tokens=512,\n        system=(\n            \"Given a user request and a list of APIs, return a JSON array \"\n            \"of the API names needed to fulfill the request. \"\n            \"Return only the array, nothing else.\"\n        ),\n        messages=[{\n            \"role\": \"user\",\n            \"content\": f\"Request: {user_request}\\n\\nAPIs:\\n{pool_text}\"\n        }],\n    )\n    try:\n        return json.loads(resp.content[0].text)\n    except json.JSONDecodeError:\n        return []\n\n\ndef execute_plan(\n    user_request: str,\n    selected_apis: list[dict],\n    model=\"claude-haiku-4-5-20251001\",\n) -> list[dict]:\n    \"\"\"Step 2: call the selected APIs in the right order.\"\"\"\n    tools = [\n        {\n            \"name\": api[\"name\"],\n            \"description\": api[\"description\"],\n            \"input_schema\": api.get(\"parameters\", {\"type\":\"object\",\"properties\":{}}),\n        }\n        for api in selected_apis\n    ]\n    messages = [{\"role\": \"user\", \"content\": user_request}]\n    calls = []\n\n    for _ in range(5):\n        resp = client.messages.create(\n            model=model, max_tokens=1024,\n            tools=tools, messages=messages,\n        )\n        messages.append({\"role\": \"assistant\", \"content\": resp.content})\n\n        results = []\n        for block in resp.content:\n            if block.type == \"tool_use\":\n                calls.append({\"name\": block.name, \"args\": block.input})\n                results.append({\n                    \"type\": \"tool_result\",\n                    \"tool_use_id\": block.id,\n                    \"content\": json.dumps({\"status\": \"ok\"}),\n                })\n        if not results:\n            break\n        messages.append({\"role\": \"user\", \"content\": results})\n\n    return calls\n\n\ndef solve_api_bank_task(task: dict) -> dict:\n    selected_names = select_apis(task[\"user_request\"], task[\"api_pool\"])\n    selected_apis = [a for a in task[\"api_pool\"] if a[\"name\"] in selected_names]\n    calls = execute_plan(task[\"user_request\"], selected_apis)\n\n    ground_truth = {a[\"name\"] for a in task[\"ground_truth_apis\"]}\n    predicted = {c[\"name\"] for c in calls}\n\n    return {\n        \"precision\": len(predicted & ground_truth) / len(predicted) if predicted else 0,\n        \"recall\": len(predicted & ground_truth) / len(ground_truth) if ground_truth else 0,\n        \"exact_match\": predicted == ground_truth,\n    }\n"
          }
        ]
      },
