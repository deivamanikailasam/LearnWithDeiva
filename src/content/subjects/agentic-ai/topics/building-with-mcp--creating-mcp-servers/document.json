                      }
                    ],
                    "text": "Server name"
                  },
                  {
                    "type": "text",
                    "text": " is sent in the "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "initialize"
                  },
                  {
                    "type": "text",
                    "text": " response and displayed in host UIs."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "list_tools"
                  },
                  {
                    "type": "text",
                    "text": " runs once at session start; the client caches the result."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "call_tool"
                  },
                  {
                    "type": "text",
                    "text": " receives the tool name and a dict of validated-but-unchecked arguments. Always validate inputs inside the handler."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
