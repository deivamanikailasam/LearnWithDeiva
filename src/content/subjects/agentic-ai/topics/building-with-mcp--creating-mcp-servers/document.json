      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "A Realistic Multi-Tool Server"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Real servers expose several tools and call external services. The following GitHub issues server shows the complete pattern \u2014 argument validation, credential handling from environment variables, structured error returns, and async HTTP calls."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio, os\nimport httpx\nimport mcp.server.stdio\nfrom mcp.server import Server\nfrom mcp.types import Tool, TextContent\n\nTOKEN = os.environ.get(\"GITHUB_TOKEN\", \"\")   # never hardcode\nBASE = \"https://api.github.com\"\nHEADERS = {\"Authorization\": f\"Bearer {TOKEN}\", \"Accept\": \"application/vnd.github+json\"}\n\napp = Server(\"github-issues\")\n\n@app.list_tools()\nasync def list_tools() -> list[Tool]:\n    return [\n        Tool(\n            name=\"list_issues\",\n            description=\"List open issues for a GitHub repository\",\n            inputSchema={\n                \"type\": \"object\",\n                \"properties\": {\n                    \"owner\": {\"type\": \"string\"},\n                    \"repo\": {\"type\": \"string\"},\n                    \"limit\": {\"type\": \"integer\", \"default\": 10, \"maximum\": 50},\n                },\n                \"required\": [\"owner\", \"repo\"],\n            },\n        ),\n        Tool(\n            name=\"create_issue\",\n            description=\"Open a new GitHub issue\",\n            inputSchema={\n                \"type\": \"object\",\n                \"properties\": {\n                    \"owner\": {\"type\": \"string\"},\n                    \"repo\": {\"type\": \"string\"},\n                    \"title\": {\"type\": \"string\"},\n                    \"body\": {\"type\": \"string\", \"default\": \"\"},\n                },\n                \"required\": [\"owner\", \"repo\", \"title\"],\n            },\n        ),\n    ]\n\n@app.call_tool()\nasync def call_tool(name: str, arguments: dict) -> list[TextContent]:\n    async with httpx.AsyncClient(headers=HEADERS) as client:\n        if name == \"list_issues\":\n            limit = min(arguments.get(\"limit\", 10), 50)\n            url = f\"{BASE}/repos/{arguments['owner']}/{arguments['repo']}/issues\"\n            r = await client.get(url, params={\"state\": \"open\", \"per_page\": limit})\n            if r.status_code != 200:\n                return [TextContent(type=\"text\", text=f\"GitHub error {r.status_code}: {r.text}\")]\n            issues = r.json()\n            lines = [f\"#{i['number']} {i['title']} (@{i['user']['login']})\" for i in issues]\n            return [TextContent(type=\"text\", text=\"\\n\".join(lines) or \"No open issues.\")]\n\n        if name == \"create_issue\":\n            url = f\"{BASE}/repos/{arguments['owner']}/{arguments['repo']}/issues\"\n            payload = {\"title\": arguments[\"title\"], \"body\": arguments.get(\"body\", \"\")}\n            r = await client.post(url, json=payload)\n            if r.status_code == 201:\n                issue = r.json()\n                return [TextContent(type=\"text\", text=f\"Created #{issue['number']}: {issue['html_url']}\")]\n            return [TextContent(type=\"text\", text=f\"Error {r.status_code}: {r.text}\")]\n\n    raise ValueError(f\"Unknown tool: {name}\")\n\nasync def main():\n    async with mcp.server.stdio.stdio_server() as (r, w):\n        await app.run(r, w, app.create_initialization_options())\n\nif __name__ == \"__main__\":\n    asyncio.run(main())\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Error Handling"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "MCP distinguishes two kinds of errors. "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Transport errors"
          },
          {
            "type": "text",
            "text": " (raised exceptions in "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "call_tool"
          },
          {
            "type": "text",
            "text": ") are returned as JSON-RPC error responses; the client sees them as protocol-level failures. "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Tool errors"
          },
          {
            "type": "text",
            "text": " \u2014 the tool ran successfully but the operation failed \u2014 are returned as content with "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "isError=True"
          },
          {
            "type": "text",
            "text": ". The model can read the error message and reason about it."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from mcp.types import TextContent, CallToolResult\n\n@app.call_tool()\nasync def call_tool(name: str, arguments: dict):\n    if name == \"fetch_url\":\n        url = arguments.get(\"url\", \"\")\n        if not url.startswith(\"https://\"):\n            # Tool-level error: model can see the message\n            return CallToolResult(\n                content=[TextContent(type=\"text\", text=\"Only HTTPS URLs are allowed\")],\n                isError=True,\n            )\n        try:\n            async with httpx.AsyncClient() as client:\n                r = await client.get(url, timeout=10.0)\n            return [TextContent(type=\"text\", text=r.text[:4000])]\n        except httpx.TimeoutException:\n            return CallToolResult(\n                content=[TextContent(type=\"text\", text=f\"Request timed out after 10 seconds\")],\n                isError=True,\n            )\n        except httpx.RequestError as exc:\n            return CallToolResult(\n                content=[TextContent(type=\"text\", text=f\"Network error: {exc}\")],\n                isError=True,\n            )\n    raise ValueError(f\"Unknown tool: {name}\")   # protocol error \u2014 unknown tool\n"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Use "
              },
              {
                "type": "text",
                "marks": [
                  {
                    "type": "code"
                  }
                ],
                "text": "CallToolResult(isError=True)"
              },
              {
                "type": "text",
                "text": " for any expected failure the model should recover from (invalid input, resource not found, rate limit). Reserve raised exceptions for true programming errors like unknown tool names."
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Adding Resources"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Resources are read-only data exposed at a URI. A client fetches them with "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "session.read_resource(uri)"
          },
          {
            "type": "text",
            "text": "; the model cannot modify them. Resources are ideal for configuration files, database schemas, API documentation, or any reference data a model needs for context."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from mcp.types import Resource, TextContent\nfrom mcp.server.models import InitializationOptions\n\nDOCS = {\n    \"myapp://config/schema\": '{\"version\": 2, \"fields\": [\"name\", \"email\", \"role\"]}',\n    \"myapp://config/readme\": \"MyApp configuration guide: set MYAPP_TOKEN in your environment.\",\n}\n\n@app.list_resources()\nasync def list_resources() -> list[Resource]:\n    return [\n        Resource(uri=uri, name=uri.split(\"/\")[-1], mimeType=\"application/json\" if uri.endswith(\"schema\") else \"text/plain\")\n        for uri in DOCS\n    ]\n\n@app.read_resource()\nasync def read_resource(uri: str) -> list[TextContent]:\n    if uri in DOCS:\n        return [TextContent(type=\"text\", text=DOCS[uri])]\n    raise ValueError(f\"Unknown resource URI: {uri}\")\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Configuration and Deployment"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Hosts discover servers via a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": ".mcp.json"
          },
          {
            "type": "text",
            "text": " file. Place it in the project root or the user's home directory:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "json"
        },
        "content": [
          {
            "type": "text",
            "text": "{\n  \"servers\": {\n    \"github-issues\": {\n      \"command\": \"python\",\n      \"args\": [\"/path/to/server.py\"],\n      \"env\": {\n        \"GITHUB_TOKEN\": \"${GITHUB_TOKEN}\"\n      }\n    }\n  }\n}\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "env"
          },
          {
            "type": "text",
            "text": " block controls exactly which environment variables the subprocess sees. Use "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "${VAR}"
          },
          {
            "type": "text",
            "text": " to forward variables from the host environment without embedding credentials in the config file."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For distribution, package the server as a pip-installable module with a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "console_scripts"
          },
          {
            "type": "text",
            "text": " entry point in "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "pyproject.toml"
          },
          {
            "type": "text",
            "text": ":"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "toml"
        },
        "content": [
          {
            "type": "text",
            "text": "[build-system]\nrequires = [\"setuptools\"]\nbuild-backend = \"setuptools.backends.legacy:build\"\n\n[project]\nname = \"my-mcp-server\"\nversion = \"0.1.0\"\ndependencies = [\"mcp\", \"httpx\"]\n\n[project.scripts]\nmy-mcp-server = \"my_mcp_server.server:main_sync\"\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Add a synchronous entry point that calls "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "asyncio.run(main())"
          },
          {
            "type": "text",
            "text": ". After "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "pip install my-mcp-server"
          },
          {
            "type": "text",
            "text": ", the "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": ".mcp.json"
          },
          {
            "type": "text",
            "text": " command becomes simply "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "my-mcp-server"
          },
          {
            "type": "text",
            "text": "."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing MCP Servers"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Integration-test the server by spawning it as a subprocess from the test suite using "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "stdio_client"
          },
          {
            "type": "text",
            "text": ". This exercises the full JSON-RPC stack without mocking the transport layer."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# tests/test_server.py\nimport sys, pytest\nfrom mcp import ClientSession, StdioServerParameters\nfrom mcp.client.stdio import stdio_client\n\nSERVER = StdioServerParameters(command=sys.executable, args=[\"server.py\"])\n\n@pytest.mark.asyncio\nasync def test_list_tools():\n    async with stdio_client(SERVER) as (r, w):\n        async with ClientSession(r, w) as session:\n            await session.initialize()\n            tools = await session.list_tools()\n            names = {t.name for t in tools.tools}\n            assert \"add\" in names\n\n@pytest.mark.asyncio\nasync def test_add_tool():\n    async with stdio_client(SERVER) as (r, w):\n        async with ClientSession(r, w) as session:\n            await session.initialize()\n            result = await session.call_tool(\"add\", {\"a\": 3, \"b\": 4})\n            assert result.isError is False\n            assert result.content[0].text == \"7\"\n\n@pytest.mark.asyncio\nasync def test_unknown_tool_returns_error():\n    async with stdio_client(SERVER) as (r, w):\n        async with ClientSession(r, w) as session:\n            await session.initialize()\n            # Unknown tool should raise a protocol error, not hang\n            try:\n                await session.call_tool(\"nonexistent\", {})\n                assert False, \"Expected an error\"\n            except Exception:\n                pass   # expected\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For unit-testing individual handlers without a subprocess, call "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "call_tool"
          },
          {
            "type": "text",
            "text": " directly \u2014 it is an ordinary async function. Use "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "pytest-asyncio"
          },
          {
            "type": "text",
            "text": " ("
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "pip install pytest-asyncio"
          },
          {
            "type": "text",
            "text": ") and mark tests with "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "@pytest.mark.asyncio"
          },
          {
            "type": "text",
            "text": "."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Unit-test the handler in isolation\nfrom unittest.mock import AsyncMock, patch\nimport pytest\nfrom server import call_tool   # import the decorated function\n\n@pytest.mark.asyncio\nasync def test_list_issues_unit():\n    fake_response = AsyncMock()\n    fake_response.status_code = 200\n    fake_response.json.return_value = [\n        {\"number\": 1, \"title\": \"Bug in login\", \"user\": {\"login\": \"alice\"}},\n    ]\n    with patch(\"httpx.AsyncClient.get\", return_value=fake_response):\n        result = await call_tool(\"list_issues\", {\"owner\": \"acme\", \"repo\": \"app\"})\n    assert \"#1 Bug in login (@alice)\" in result[0].text\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
