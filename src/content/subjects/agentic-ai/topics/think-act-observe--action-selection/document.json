      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import pytest\nfrom unittest.mock import MagicMock\n\n\nclass TestParseAction:\n    def _make_response(self, stop_reason, content):\n        r = MagicMock()\n        r.stop_reason = stop_reason\n        r.content = content\n        return r\n\n    def test_end_turn_returns_text_choice(self):\n        block = MagicMock(type=\"text\", text=\"The answer is 42.\")\n        resp = self._make_response(\"end_turn\", [block])\n        choices = parse_action(resp)\n        assert len(choices) == 1\n        assert choices[0].kind == ActionKind.TEXT\n        assert \"42\" in choices[0].text\n\n    def test_tool_use_returns_tool_choice(self):\n        block = MagicMock(type=\"tool_use\", name=\"search\",\n                          id=\"tu_1\", input={\"query\": \"Paris\"})\n        resp = self._make_response(\"tool_use\", [block])\n        choices = parse_action(resp)\n        assert choices[0].kind == ActionKind.TOOL\n        assert choices[0].tool_name == \"search\"\n        assert choices[0].args == {\"query\": \"Paris\"}\n\n    def test_max_tokens_returns_wait(self):\n        resp = self._make_response(\"max_tokens\", [])\n        choices = parse_action(resp)\n        assert choices[0].kind == ActionKind.WAIT\n\n    def test_multiple_tool_calls_parsed(self):\n        blocks = [\n            MagicMock(type=\"tool_use\", name=\"a\", id=\"tu_1\", input={}),\n            MagicMock(type=\"tool_use\", name=\"b\", id=\"tu_2\", input={}),\n        ]\n        resp = self._make_response(\"tool_use\", blocks)\n        choices = parse_action(resp)\n        assert len(choices) == 2\n\n\nclass TestActionValidator:\n    def test_valid_args_returns_none(self):\n        v = ActionValidator({\"tool\": {\"required\": [\"x\"], \"properties\": {\"x\": {}}}})\n        c = ActionChoice.tool(\"tool\", \"tu_1\", {\"x\": 1})\n        assert v.validate(c) is None\n\n    def test_missing_required_returns_error(self):\n        v = ActionValidator({\"tool\": {\"required\": [\"x\"], \"properties\": {\"x\": {}}}})\n        c = ActionChoice.tool(\"tool\", \"tu_1\", {})\n        assert \"Missing required\" in v.validate(c)\n\n    def test_unknown_tool_returns_error(self):\n        v = ActionValidator({})\n        c = ActionChoice.tool(\"nonexistent\", \"tu_1\", {})\n        assert \"Unknown tool\" in v.validate(c)\n\n\nclass TestSafetyFilter:\n    def test_blocked_tool_is_filtered(self):\n        c = ActionChoice.tool(\"delete_database\", \"tu_1\", {})\n        approved, blocked = safety_filter([c])\n        assert len(approved) == 0\n        assert len(blocked) == 1\n\n    def test_unblocked_tool_passes(self):\n        c = ActionChoice.tool(\"search\", \"tu_1\", {\"query\": \"x\"})\n        approved, blocked = safety_filter([c])\n        assert len(approved) == 1\n        assert len(blocked) == 0\n"
          }
        ]
