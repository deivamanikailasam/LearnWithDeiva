  "doc": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Action selection is the "
          },
          {
            "type": "text",
            "text": "decision layer",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " between the model's raw response and the execution stage. When the model returns a message, it signals its intent through the "
          },
          {
            "type": "text",
            "text": "stop_reason",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " field: "
          },
          {
            "type": "text",
            "text": "\"tool_use\"",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " means it wants to call one or more tools; "
          },
          {
            "type": "text",
            "text": "\"end_turn\"",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " means it has a final answer; "
          },
          {
            "type": "text",
            "text": "\"max_tokens\"",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " means generation was cut off. The action selection layer parses this signal into a typed "
          },
          {
            "type": "text",
            "text": "ActionChoice",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ", validates arguments, applies safety rules, and hands off to the executor \u2014 all before any side effect occurs."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Action selection flow \u2014 from model response to typed ActionChoice to dispatch"
        }
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "The ActionChoice Type"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Rather than passing raw response blocks to the executor, wrap the intent in a typed "
          },
          {
            "type": "text",
            "text": "ActionChoice",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " dataclass. This makes the selection stage "
          },
          {
            "type": "text",
            "text": "explicit and testable",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " \u2014 each downstream handler knows exactly what kind of action it is dealing with:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass\nfrom enum import Enum\nfrom typing import Any\n\n\nclass ActionKind(Enum):\n    TOOL = \"tool\"\n    TEXT = \"text\"\n    WAIT = \"wait\"\n\n\n@dataclass\nclass ActionChoice:\n    kind: ActionKind\n    # For TOOL\n    tool_name: str | None = None\n    tool_use_id: str | None = None\n    args: dict | None = None\n    # For TEXT\n    text: str | None = None\n    # For WAIT\n    reason: str | None = None\n\n    @classmethod\n    def tool(cls, name: str, use_id: str, args: dict) -> \"ActionChoice\":\n        return cls(kind=ActionKind.TOOL, tool_name=name,\n                   tool_use_id=use_id, args=args)\n\n    @classmethod\n    def text(cls, content: str) -> \"ActionChoice\":\n        return cls(kind=ActionKind.TEXT, text=content)\n\n    @classmethod\n    def wait(cls, reason: str = \"\") -> \"ActionChoice\":\n        return cls(kind=ActionKind.WAIT, reason=reason)\n"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "ActionKind.TOOL",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 dispatch a named tool with the model's arguments and "
                  },
                  {
                    "type": "text",
                    "text": "tool_use_id",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " (needed to match the tool result back)."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "ActionKind.TEXT",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 the model has a final text answer; no tool execution needed. Surface this to the user and end the loop."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "ActionKind.WAIT",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 generation was cut off, a required confirmation is pending, or a safety rule blocked the action. The loop must handle this before continuing."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Parsing the Model Response"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The "
          },
          {
            "type": "text",
            "text": "parse_action",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " function inspects "
          },
          {
            "type": "text",
            "text": "response.stop_reason",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " and "
          },
          {
            "type": "text",
            "text": "response.content",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " to produce a list of "
          },
          {
            "type": "text",
            "text": "ActionChoice",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " objects. A single response may contain "
          },
          {
            "type": "text",
            "text": "multiple",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " tool calls \u2014 all must be answered in the same next user turn:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\n\n\ndef parse_action(response: anthropic.types.Message) -> list[ActionChoice]:\n    \"\"\"\n    Extract one or more ActionChoice objects from a model response.\n    A single response may request multiple tool calls in parallel.\n    \"\"\"\n    choices: list[ActionChoice] = []\n\n    if response.stop_reason == \"end_turn\":\n        # Model finished \u2014 extract text\n        for block in response.content:\n            if block.type == \"text\" and block.text.strip():\n                choices.append(ActionChoice.text(block.text))\n\n    elif response.stop_reason == \"tool_use\":\n        # Model wants to call one or more tools\n        for block in response.content:\n            if block.type == \"tool_use\":\n                choices.append(\n                    ActionChoice.tool(\n                        name=block.name,\n                        use_id=block.id,\n                        args=block.input,\n                    )\n                )\n\n    elif response.stop_reason == \"max_tokens\":\n        # Generation was cut off \u2014 treat as WAIT (needs recovery)\n        choices.append(ActionChoice.wait(\n            reason=\"max_tokens: response was truncated\"\n        ))\n\n    return choices\n\n\n# Multiple tool calls can appear in one response;\n# ALL must be answered before the next reasoning step.\ndef dispatch_all(choices: list[ActionChoice], registry) -> list[dict]:\n    results = []\n    for c in choices:\n        if c.kind == ActionKind.TOOL:\n            result = registry.dispatch(c.tool_name, c.args)\n            results.append({\n                \"type\": \"tool_result\",\n                \"tool_use_id\": c.tool_use_id,\n                \"content\": str(result.output) if result.success else result.error,\n                \"is_error\": not result.success,\n            })\n    return results\n"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "The Anthropic API allows the model to request multiple tool calls in a single assistant turn. Each "
              },
              {
                "type": "text",
                "text": "tool_use",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " block has a unique "
              },
              {
                "type": "text",
                "text": "id",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": ". You must return "
              },
              {
                "type": "text",
                "text": "one",
                "marks": [
                  {
                    "type": "bold"
                  }
                ]
              },
              {
                "type": "text",
                "text": " "
              },
              {
                "type": "text",
                "text": "tool_result",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " block per "
              },
              {
                "type": "text",
                "text": "tool_use",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " block, all inside the same user-role message. Answering them across separate turns causes a validation error."
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Argument Validation"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Before dispatching, validate that the model's arguments match the tool's declared schema. Catching bad arguments early produces a clear error message that the model can correct \u2014 whereas dispatching invalid arguments may trigger cryptic failures deep inside the tool:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from typing import Any\n\n\nclass ActionValidator:\n    \"\"\"\n    Validates that the model's chosen arguments conform to the\n    tool's declared schema before dispatching.\n    \"\"\"\n    def __init__(self, tool_schemas: dict[str, dict]) -> None:\n        self._schemas = tool_schemas  # name -> JSON Schema dict\n\n    def validate(self, choice: ActionChoice) -> str | None:\n        \"\"\"\n        Returns an error message if validation fails, None if OK.\n        Only validates TOOL choices.\n        \"\"\"\n        if choice.kind != ActionKind.TOOL:\n            return None\n\n        schema = self._schemas.get(choice.tool_name)\n        if schema is None:\n            return f\"Unknown tool: {choice.tool_name!r}\"\n\n        required = schema.get(\"required\", [])\n        properties = schema.get(\"properties\", {})\n        args = choice.args or {}\n\n        for field in required:\n            if field not in args:\n                return f\"Missing required argument '{field}' for tool '{choice.tool_name}'\"\n\n        for key in args:\n            if key not in properties:\n                return f\"Unexpected argument '{key}' for tool '{choice.tool_name}'\"\n\n        return None  # valid\n\n\n# Example: validate before dispatch\nvalidator = ActionValidator({\n    \"search\": {\n        \"required\": [\"query\"],\n        \"properties\": {\"query\": {}, \"limit\": {}}\n    }\n})\n\nchoice = ActionChoice.tool(\"search\", \"tu_1\", {\"query\": \"Paris\", \"typo_key\": \"x\"})\nerror = validator.validate(choice)\n# \u2192 \"Unexpected argument 'typo_key' for tool 'search'\"\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The validator checks two things: all "
          },
          {
            "type": "text",
            "text": "required fields",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " are present, and no "
          },
          {
            "type": "text",
            "text": "unexpected fields",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " were hallucinated. Both types of mismatch are common \u2014 the model occasionally omits a required parameter or invents a key that was never in the schema. Return the validation error as a "
          },
          {
            "type": "text",
            "text": "tool_result",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " with "
          },
          {
            "type": "text",
            "text": "is_error=True",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " so the model can self-correct on the next turn."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Safety Filtering"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Some tools are too dangerous to execute without guardrails. A "
          },
          {
            "type": "text",
            "text": "safety filter",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " sits between selection and dispatch and enforces two kinds of policy: "
          },
          {
            "type": "text",
            "text": "permanently blocked",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " tools that can never be called by the agent, and "
          },
          {
            "type": "text",
            "text": "confirmation-required",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " tools that need explicit user approval before the first execution:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "BLOCKED_TOOLS = frozenset([\"delete_database\", \"shutdown_server\"])\nREQUIRE_CONFIRMATION = frozenset([\"send_email\", \"publish_post\"])\n\n\ndef safety_filter(\n    choices: list[ActionChoice],\n    confirmed_ids: set[str] | None = None,\n) -> tuple[list[ActionChoice], list[str]]:\n    \"\"\"\n    Returns (approved, blocked_reasons).\n    Blocked choices are replaced with WAIT so the loop can surface\n    the reason to the user before retrying.\n    \"\"\"\n    approved: list[ActionChoice] = []\n    blocked: list[str] = []\n    confirmed_ids = confirmed_ids or set()\n\n    for c in choices:\n        if c.kind != ActionKind.TOOL:\n            approved.append(c)\n            continue\n        if c.tool_name in BLOCKED_TOOLS:\n            blocked.append(f\"Tool '{c.tool_name}' is permanently disabled\")\n        elif c.tool_name in REQUIRE_CONFIRMATION and c.tool_use_id not in confirmed_ids:\n            blocked.append(\n                f\"Tool '{c.tool_name}' requires user confirmation \"\n                f\"(id={c.tool_use_id})\"\n            )\n        else:\n            approved.append(c)\n\n    return approved, blocked\n"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Blocked list",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 destructive or high-risk operations (drop table, delete account) that should never be exposed to an autonomous agent. Blocking at the selection layer prevents any path to execution, even if the model is manipulated."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Confirmation required",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 write-side effects visible to third parties (send email, publish post) that a human should approve. The filter passes the "
                  },
                  {
                    "type": "text",
                    "text": "tool_use_id",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " back; once confirmed, add it to "
                  },
                  {
                    "type": "text",
                    "text": "confirmed_ids",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " and re-run the loop turn."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Approved list passes through",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 most tools need no special handling. The filter is a narrow gate, not a general permission system."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Parallel Tool Execution"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When the model selects multiple tools in one turn, execute them "
          },
          {
            "type": "text",
            "text": "concurrently",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " to reduce round-trip latency. The results must still be collected and returned in a single user message:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\nfrom concurrent.futures import ThreadPoolExecutor\n\n\ndef execute_parallel(\n    choices: list[ActionChoice],\n    registry,\n    max_workers: int = 4,\n) -> list[dict]:\n    \"\"\"\n    Execute multiple tool calls from the same assistant turn in parallel.\n    The model may request several tools at once; we must answer all of them\n    in a single user-role tool_result turn.\n    \"\"\"\n    tool_choices = [c for c in choices if c.kind == ActionKind.TOOL]\n\n    def run_one(c: ActionChoice) -> dict:\n        result = registry.dispatch(c.tool_name, c.args)\n        return {\n            \"type\": \"tool_result\",\n            \"tool_use_id\": c.tool_use_id,\n            \"content\": str(result.output) if result.success else result.error,\n            \"is_error\": not result.success,\n        }\n\n    with ThreadPoolExecutor(max_workers=max_workers) as pool:\n        return list(pool.map(run_one, tool_choices))\n\n\n# The Anthropic API allows multiple tool_use blocks in one assistant turn.\n# All matching tool_result blocks must appear in the SAME next user turn.\n# Do not split them across multiple user turns.\n"
          }
        ]
      },
      {
