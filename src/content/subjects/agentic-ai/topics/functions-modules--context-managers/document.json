                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " — returning "
                  },
                  {
                    "type": "text",
                    "text": "True",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
