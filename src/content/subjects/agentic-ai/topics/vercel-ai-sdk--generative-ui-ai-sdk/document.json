{"format": "tiptap/v1", "doc": {"type": "doc", "content": [{"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Generative UI"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Generative UI describes a pattern where the model does not return plain text — it selects and parameterises "}, {"type": "text", "text": "React components", "marks": [{"type": "bold"}]}, {"type": "text", "text": " to render directly in the stream. The Vercel AI SDK makes this possible with its data-stream protocol: tool results carry structured data that the client maps to purpose-built components instead of serialising everything to a string."}]}, {"type": "image", "attrs": {"src": "data:image/svg+xml;base64,", "alt": "Generative UI data flow — browser → route handler → LLM → tool execute → data stream → React component"}}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Project Setup"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Generative UI works in any React framework, but pairs naturally with Next.js App Router because route handlers can stream directly via "}, {"type": "text", "text": "toDataStreamResponse()", "marks": [{"type": "code"}]}, {"type": "text", "text": "."}]}, {"type": "codeBlock", "attrs": {"language": "bash"}, "content": [{"type": "text", "text": "# Install AI SDK + Next.js RSC bindings\nnpm install ai @ai-sdk/openai react\n\n# In a Next.js 14+ (App Router) project\n# Requires React 18+ with Server Component support"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The "}, {"type": "text", "text": "ai/react", "marks": [{"type": "code"}]}, {"type": "text", "text": " package provides "}, {"type": "text", "text": "useChat", "marks": [{"type": "code"}]}, {"type": "text", "text": " and "}, {"type": "text", "text": "useCompletion", "marks": [{"type": "code"}]}, {"type": "text", "text": " hooks that consume the data-stream protocol. The "}, {"type": "text", "text": "ai", "marks": [{"type": "code"}]}, {"type": "text", "text": " package provides all server-side primitives."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Streaming Text and Tool Results with useChat"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The minimal Generative UI pattern has two pieces: a route handler that returns "}, {"type": "text", "text": "streamText().toDataStreamResponse()", "marks": [{"type": "code"}]}, {"type": "text", "text": " and a client component that maps tool results to React components."}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Route Handler"}]}, {"type": "codeBlock", "attrs": {"language": "typescript"}, "content": [{"type": "text", "text": "// app/api/chat/route.ts\nimport { streamText } from 'ai';\nimport { openai } from '@ai-sdk/openai';\nimport { tool } from 'ai';\nimport { z } from 'zod';\n\nexport async function POST(req: Request) {\n  const { messages } = await req.json();\n\n  const result = streamText({\n    model: openai('gpt-4o-mini'),\n    messages,\n    tools: {\n      getWeather: tool({\n        description: 'Get the current weather for a city',\n        parameters: z.object({ city: z.string() }),\n        execute: async ({ city }) => ({\n          city,\n          temperature: 22,\n          condition: 'Sunny',\n        }),\n      }),\n    },\n  });\n\n  return result.toDataStreamResponse();\n}"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Client Component"}]}, {"type": "codeBlock", "attrs": {"language": "tsx"}, "content": [{"type": "text", "text": "// app/page.tsx  (Client Component)\n'use client';\nimport { useChat } from 'ai/react';\n\nexport default function Chat() {\n  const { messages, input, handleInputChange, handleSubmit } = useChat({\n    api: '/api/chat',\n  });\n\n  return (\n    <div>\n      {messages.map(msg => (\n        <div key={msg.id}>\n          <strong>{msg.role}:</strong>\n          {/* Render text */}\n          {msg.parts\n            .filter(p => p.type === 'text')\n            .map((p, i) => <span key={i}>{p.text}</span>)}\n          {/* Render tool results as UI */}\n          {msg.parts\n            .filter(p => p.type === 'tool-invocation' && p.toolInvocation.state === 'result')\n            .map((p, i) => (\n              <WeatherCard key={i} data={p.toolInvocation.result} />\n            ))}\n        </div>\n      ))}\n      <form onSubmit={handleSubmit}>\n        <input value={input} onChange={handleInputChange} />\n        <button type=\"submit\">Send</button>\n      </form>\n    </div>\n  );\n}"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The "}, {"type": "text", "text": "messages", "marks": [{"type": "code"}]}, {"type": "text", "text": " array exposed by "}, {"type": "text", "text": "useChat", "marks": [{"type": "code"}]}, {"type": "text", "text": " now uses a "}, {"type": "text", "text": "parts-based structure", "marks": [{"type": "bold"}]}, {"type": "text", "text": ": each message carries a "}, {"type": "text", "text": "parts", "marks": [{"type": "code"}]}, {"type": "text", "text": " array instead of a flat "}, {"type": "text", "text": "content", "marks": [{"type": "code"}]}, {"type": "text", "text": " string. Parts may be "}, {"type": "text", "text": "text", "marks": [{"type": "code"}]}, {"type": "text", "text": ", "}, {"type": "text", "text": "tool-invocation", "marks": [{"type": "code"}]}, {"type": "text", "text": ", or "}, {"type": "text", "text": "reasoning", "marks": [{"type": "code"}]}, {"type": "text", "text": "."}]}, {"type": "blockquote", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "The "}, {"type": "text", "text": "toolInvocation.state", "marks": [{"type": "code"}]}, {"type": "text", "text": " field transitions through "}, {"type": "text", "text": "partial-call", "marks": [{"type": "code"}]}, {"type": "text", "text": " → "}, {"type": "text", "text": "call", "marks": [{"type": "code"}]}, {"type": "text", "text": " → "}, {"type": "text", "text": "result", "marks": [{"type": "code"}]}, {"type": "text", "text": " as the stream progresses. Only render heavy components at the "}, {"type": "text", "text": "result", "marks": [{"type": "code"}]}, {"type": "text", "text": " state; show a skeleton at "}, {"type": "text", "text": "call", "marks": [{"type": "code"}]}, {"type": "text", "text": " for immediate feedback."}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Rendering a Custom Component"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The "}, {"type": "text", "text": "WeatherCard", "marks": [{"type": "code"}]}, {"type": "text", "text": " referenced above is a plain React component. Because tool results are typed, you can add full TypeScript interfaces with no extra plumbing."}]}, {"type": "codeBlock", "attrs": {"language": "tsx"}, "content": [{"type": "text", "text": "// components/WeatherCard.tsx\ninterface WeatherData {\n  city: string;\n  temperature: number;\n  condition: string;\n}\n\nexport function WeatherCard({ data }: { data: WeatherData }) {\n  return (\n    <div style={{ border: '1px solid #ccc', padding: 12, borderRadius: 8 }}>\n      <h3>{data.city}</h3>\n      <p>{data.temperature}°C — {data.condition}</p>\n    </div>\n  );\n}"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "This separation — structured data in the stream, display logic in components — keeps the LLM output schema stable while letting you iterate on the visual design independently."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Attaching Custom Data to the Stream"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Beyond tool results you can append arbitrary data payloads to the stream using "}, {"type": "text", "text": "createDataStreamResponse", "marks": [{"type": "code"}]}, {"type": "text", "text": " and "}, {"type": "text", "text": "appendDataStreamPart", "marks": [{"type": "code"}]}, {"type": "text", "text": ". Clients receive these as "}, {"type": "text", "text": "data", "marks": [{"type": "code"}]}, {"type": "text", "text": " from "}, {"type": "text", "text": "useChat", "marks": [{"type": "code"}]}, {"type": "text", "text": "."}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Server"}]}, {"type": "codeBlock", "attrs": {"language": "typescript"}, "content": [{"type": "text", "text": "// app/api/chat/route.ts — attaching custom data to the stream\nimport { streamText, createDataStreamResponse, appendDataStreamPart } from 'ai';\nimport { openai } from '@ai-sdk/openai';\n\nexport async function POST(req: Request) {\n  const { messages } = await req.json();\n\n  return createDataStreamResponse({\n    execute: async dataStream => {\n      // Attach arbitrary data visible to the client as msg.data\n      appendDataStreamPart(dataStream, 'data', { source: 'db', rows: 42 });\n\n      const result = streamText({\n        model: openai('gpt-4o-mini'),\n        messages,\n      });\n\n      result.mergeIntoDataStream(dataStream);\n    },\n  });\n}"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Client"}]}, {"type": "codeBlock", "attrs": {"language": "typescript"}, "content": [{"type": "text", "text": "// Access the appended data in the client\nconst { messages, data } = useChat({ api: '/api/chat' });\n\n// `data` is an array of all appended data parts across the session\nconsole.log(data);  // [{ source: 'db', rows: 42 }, ...]"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Typical uses: database lookup metadata (row counts, cache hit/miss), A/B experiment identifiers, source citations, or cost estimates sent alongside the response."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Client-Side Tools"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Some tools need browser access — geolocation, clipboard, screen dimensions. Declare them with "}, {"type": "text", "text": "experimental_onToolCall", "marks": [{"type": "code"}]}, {"type": "text", "text": " in "}, {"type": "text", "text": "useChat", "marks": [{"type": "code"}]}, {"type": "text", "text": "; execution happens in the browser and the result is injected back into the stream via "}, {"type": "text", "text": "addToolResult", "marks": [{"type": "code"}]}, {"type": "text", "text": "."}]}, {"type": "codeBlock", "attrs": {"language": "tsx"}, "content": [{"type": "text", "text": "// Client-side tool: the model requests it but execution happens in the browser\n'use client';\nimport { useChat } from 'ai/react';\nimport { tool } from 'ai';\nimport { z } from 'zod';\n\nexport default function Chat() {\n  const { messages, input, handleInputChange, handleSubmit, addToolResult } = useChat({\n    api: '/api/chat',\n    // Declare client-side tools — execution is deferred to addToolResult()\n    experimental_onToolCall: async (toolCall, addResult) => {\n      if (toolCall.toolName === 'getScreenSize') {\n        addResult({\n          width: window.innerWidth,\n          height: window.innerHeight,\n        });\n      }\n    },\n  });\n\n  // ...render as before\n}"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The model's request arrives as a "}, {"type": "text", "text": "tool-invocation", "marks": [{"type": "code"}]}, {"type": "text", "text": " part with "}, {"type": "text", "text": "state === 'call'", "marks": [{"type": "code"}]}, {"type": "text", "text": ". Once "}, {"type": "text", "text": "addResult()), is called the model can continue generating based on that result.", "marks": [{"type": "code"}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Message Annotations and Metadata"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The "}, {"type": "text", "text": "toDataStreamResponse", "marks": [{"type": "code"}]}, {"type": "text", "text": " options gate which protocol fields are sent to the client: usage tokens, reasoning traces, and custom message IDs."}]}, {"type": "codeBlock", "attrs": {"language": "typescript"}, "content": [{"type": "text", "text": "// Route: send a message annotation mid-stream\nimport { streamText, appendResponseMessages } from 'ai';\nimport { openai } from '@ai-sdk/openai';\n\nexport async function POST(req: Request) {\n  const { messages } = await req.json();\n  const result = streamText({\n    model: openai('gpt-4o-mini'),\n    messages,\n    experimental_generateMessageId: () => crypto.randomUUID(),\n    onFinish: async ({ response }) => {\n      // Persist to DB, add citations, etc.\n      const updated = appendResponseMessages({ messages, responseMsgs: response.messages });\n      await saveConversation(updated);\n    },\n  });\n\n  return result.toDataStreamResponse({\n    sendUsage: true,   // appends token usage to the stream\n    sendReasoning: false,\n  });\n}"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "sendUsage: true", "marks": [{"type": "code"}]}, {"type": "text", "text": " appends an "}, {"type": "text", "text": "8:", "marks": [{"type": "code"}]}, {"type": "text", "text": " annotation part containing "}, {"type": "text", "text": "{ promptTokens, completionTokens }", "marks": [{"type": "code"}]}, {"type": "text", "text": " so you can display cost estimates or enforce client-side rate limits. "}, {"type": "text", "text": "experimental_generateMessageId", "marks": [{"type": "code"}]}, {"type": "text", "text": " lets you assign stable IDs for database persistence."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "useCompletion for Single-Turn Streams"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "When there is no conversation history — autocomplete, document summarisation, one-off generation — "}, {"type": "text", "text": "useCompletion", "marks": [{"type": "code"}]}, {"type": "text", "text": " is lighter than "}, {"type": "text", "text": "useChat", "marks": [{"type": "code"}]}, {"type": "text", "text": ". It returns "}, {"type": "text", "text": "completion", "marks": [{"type": "code"}]}, {"type": "text", "text": " as a plain string, incrementally appended."}]}, {"type": "codeBlock", "attrs": {"language": "tsx"}, "content": [{"type": "text", "text": "// useCompletion — single-turn text completion (no conversation history)\n'use client';\nimport { useCompletion } from 'ai/react';\n\nexport default function CodeCompletion() {\n  const { completion, complete, isLoading } = useCompletion({\n    api: '/api/complete',\n  });\n\n  return (\n    <div>\n      <button onClick={() => complete('Write a haiku about TypeScript')}>\n        Generate\n      </button>\n      {isLoading && <p>Generating…</p>}\n      <pre>{completion}</pre>\n    </div>\n  );\n}"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The "}, {"type": "text", "text": "complete(prompt)", "marks": [{"type": "code"}]}, {"type": "text", "text": " function triggers a POST to the configured "}, {"type": "text", "text": "api", "marks": [{"type": "code"}]}, {"type": "text", "text": " route. Server-side use "}, {"type": "text", "text": "streamText().toTextStreamResponse()", "marks": [{"type": "code"}]}, {"type": "text", "text": " (not "}, {"type": "text", "text": "toDataStreamResponse", "marks": [{"type": "code"}]}, {"type": "text", "text": ") for this simpler client."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Optimistic UI While Tools Execute"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Tools take time. Rendering a skeleton at "}, {"type": "text", "text": "state === 'call'", "marks": [{"type": "code"}]}, {"type": "text", "text": " and the real component at "}, {"type": "text", "text": "state === 'result'", "marks": [{"type": "code"}]}, {"type": "text", "text": " avoids an empty gap in the UI."}]}, {"type": "codeBlock", "attrs": {"language": "tsx"}, "content": [{"type": "text", "text": "// Optimistic UI: show a spinner while tool state is 'call', result when 'result'\n{msg.parts\n  .filter(p => p.type === 'tool-invocation')\n  .map((p, i) => {\n    const inv = p.toolInvocation;\n    if (inv.toolName === 'getWeather') {\n      if (inv.state === 'call' || inv.state === 'partial-call') {\n        return <WeatherSkeleton key={i} city={inv.args?.city} />;\n      }\n      if (inv.state === 'result') {\n        return <WeatherCard key={i} data={inv.result} />;\n      }\n    }\n    return null;\n  })}"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The "}, {"type": "text", "text": "partial-call", "marks": [{"type": "code"}]}, {"type": "text", "text": " state is emitted when "}, {"type": "text", "text": "streamText", "marks": [{"type": "code"}]}, {"type": "text", "text": " is still accumulating the tool arguments JSON. You can inspect "}, {"type": "text", "text": "inv.args", "marks": [{"type": "code"}]}, {"type": "text", "text": " for partial data (e.g., to show a city name placeholder before the full argument set arrives)."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Comparison: Patterns for Dynamic AI UI"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Pattern"}]}]}, {"type": "tableHeader", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "When to use"}]}]}, {"type": "tableHeader", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Key API"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "useChat + tool results"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Conversational interfaces, multi-turn"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "useChat, toolInvocation.state"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "useCompletion"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "One-shot text generation, autocomplete"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "useCompletion, complete()"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Custom stream data"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Metadata, citations, cost info alongside response"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "createDataStreamResponse, appendDataStreamPart"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Client-side tools"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Browser API access (geo, clipboard, screen)"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "experimental_onToolCall, addToolResult"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Message annotations"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Token usage display, stable IDs, DB persistence"}]}]}, {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "sendUsage, experimental_generateMessageId"}]}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Common Pitfalls"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Rendering at 'call' state: ", "marks": [{"type": "bold"}]}, {"type": "text", "text": "accessing "}, {"type": "text", "text": "inv.result", "marks": [{"type": "code"}]}, {"type": "text", "text": " when "}, {"type": "text", "text": "inv.state === 'call'", "marks": [{"type": "code"}]}, {"type": "text", "text": " returns "}, {"type": "text", "text": "undefined", "marks": [{"type": "code"}]}, {"type": "text", "text": ". Always branch on state first."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Using toTextStreamResponse with useChat: ", "marks": [{"type": "bold"}]}, {"type": "text", "text": "useChat expects the data-stream protocol ("}, {"type": "text", "text": "toDataStreamResponse", "marks": [{"type": "code"}]}, {"type": "text", "text": "). Mixing them causes parse errors. Use "}, {"type": "text", "text": "toTextStreamResponse", "marks": [{"type": "code"}]}, {"type": "text", "text": " only with "}, {"type": "text", "text": "useCompletion", "marks": [{"type": "code"}]}, {"type": "text", "text": "."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Blocking the route on tool execution: ", "marks": [{"type": "bold"}]}, {"type": "text", "text": "heavy tool work delays the first token. Run tool execution concurrently with "}, {"type": "text", "text": "maxSteps", "marks": [{"type": "code"}]}, {"type": "text", "text": " rather than waiting on it before the stream starts."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Mutable tool result objects: ", "marks": [{"type": "bold"}]}, {"type": "text", "text": "React re-renders on reference equality. If the same tool result is sent twice with different content, use the "}, {"type": "text", "text": "toolCallId", "marks": [{"type": "code"}]}, {"type": "text", "text": " as a stable key rather than array index."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Stale data parts: ", "marks": [{"type": "bold"}]}, {"type": "text", "text": "data appended via "}, {"type": "text", "text": "appendDataStreamPart", "marks": [{"type": "code"}]}, {"type": "text", "text": " accumulates across turns in the "}, {"type": "text", "text": "data", "marks": [{"type": "code"}]}, {"type": "text", "text": " array. Clear or slice it between sessions to avoid stale metadata leaking into later displays."}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Error Handling and Stream Interruption"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The "}, {"type": "text", "text": "useChat", "marks": [{"type": "code"}]}, {"type": "text", "text": " hook exposes an "}, {"type": "text", "text": "error", "marks": [{"type": "code"}]}, {"type": "text", "text": " state and a "}, {"type": "text", "text": "reload", "marks": [{"type": "code"}]}, {"type": "text", "text": " function. If the stream fails mid-response the hook surfaces the error and stops updating "}, {"type": "text", "text": "messages", "marks": [{"type": "code"}]}, {"type": "text", "text": "."}]}, {"type": "codeBlock", "attrs": {"language": "tsx"}, "content": [{"type": "text", "text": "'use client';\nimport { useChat } from 'ai/react';\n\nexport default function Chat() {\n  const { messages, input, handleInputChange, handleSubmit, error, reload } = useChat({\n    api: '/api/chat',\n    onError: err => {\n      console.error('Stream error:', err);\n    },\n  });\n\n  return (\n    <div>\n      {error && (\n        <div style={{ color: 'red' }}>\n          <p>Error: {error.message}</p>\n          <button onClick={() => reload()}>Retry</button>\n        </div>\n      )}\n      {messages.map(msg => (\n        <div key={msg.id}>{/* render as before */}</div>\n      ))}\n      <form onSubmit={handleSubmit}>\n        <input value={input} onChange={handleInputChange} disabled={!!error} />\n        <button type=\"submit\">Send</button>\n      </form>\n    </div>\n  );\n}"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The "}, {"type": "text", "text": "status", "marks": [{"type": "code"}]}, {"type": "text", "text": " field cycles through "}, {"type": "text", "text": "idle", "marks": [{"type": "code"}]}, {"type": "text", "text": " → "}, {"type": "text", "text": "submitted", "marks": [{"type": "code"}]}, {"type": "text", "text": " → "}, {"type": "text", "text": "streaming", "marks": [{"type": "code"}]}, {"type": "text", "text": " → "}, {"type": "text", "text": "idle", "marks": [{"type": "code"}]}, {"type": "text", "text": ". Use it to conditionally show a "}, {"type": "text", "text": "Stop", "marks": [{"type": "bold"}]}, {"type": "text", "text": " button that calls "}, {"type": "text", "text": "stop()", "marks": [{"type": "code"}]}, {"type": "text", "text": " to abort the in-flight request."}]}, {"type": "codeBlock", "attrs": {"language": "tsx"}, "content": [{"type": "text", "text": "'use client';\nimport { useChat } from 'ai/react';\n\nexport default function Chat() {\n  const { messages, input, handleInputChange, handleSubmit, stop, status } = useChat({\n    api: '/api/chat',\n  });\n\n  return (\n    <div>\n      {messages.map(msg => <div key={msg.id}>{/* ... */}</div>)}\n      <form onSubmit={handleSubmit}>\n        <input value={input} onChange={handleInputChange} />\n        {status === 'streaming' ? (\n          <button type=\"button\" onClick={stop}>Stop</button>\n        ) : (\n          <button type=\"submit\">Send</button>\n        )}\n      </form>\n    </div>\n  );\n}"}]}, {"type": "blockquote", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "After "}, {"type": "text", "text": "stop()", "marks": [{"type": "code"}]}, {"type": "text", "text": " the partial response remains in "}, {"type": "text", "text": "messages", "marks": [{"type": "code"}]}, {"type": "text", "text": ". The model's message appears as-is up to the point of interruption — the "}, {"type": "text", "text": "finish_reason", "marks": [{"type": "code"}]}, {"type": "text", "text": " on the server will be "}, {"type": "text", "text": "'stop'", "marks": [{"type": "code"}]}, {"type": "text", "text": " rather than "}, {"type": "text", "text": "'length'", "marks": [{"type": "code"}]}, {"type": "text", "text": " or "}, {"type": "text", "text": "'end_turn'", "marks": [{"type": "code"}]}, {"type": "text", "text": "."}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Seeding Initial Messages"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Pass "}, {"type": "text", "text": "initialMessages", "marks": [{"type": "code"}]}, {"type": "text", "text": " to "}, {"type": "text", "text": "useChat", "marks": [{"type": "code"}]}, {"type": "text", "text": " to pre-populate the conversation — useful for resuming persisted chat sessions or providing context that does not need to go through the API."}]}, {"type": "codeBlock", "attrs": {"language": "tsx"}, "content": [{"type": "text", "text": "// Pre-populate the chat with a system message and a starter response\nconst { messages, input, handleInputChange, handleSubmit } = useChat({\n  api: '/api/chat',\n  initialMessages: [\n    {\n      id: 'system-1',\n      role: 'system',\n      content: 'You are a helpful coding assistant.',\n      parts: [{ type: 'text', text: 'You are a helpful coding assistant.' }],\n    },\n    {\n      id: 'ai-intro',\n      role: 'assistant',\n      content: 'Hi! Ask me anything about code.',\n      parts: [{ type: 'text', text: 'Hi! Ask me anything about code.' }],\n    },\n  ],\n});"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Each message must include both "}, {"type": "text", "text": "content", "marks": [{"type": "code"}]}, {"type": "text", "text": " (legacy string field) and "}, {"type": "text", "text": "parts", "marks": [{"type": "code"}]}, {"type": "text", "text": " (required for tool invocations and reasoning). When loading from a database, use "}, {"type": "text", "text": "appendResponseMessages", "marks": [{"type": "code"}]}, {"type": "text", "text": " on the server to produce the correct shape from "}, {"type": "text", "text": "response.messages", "marks": [{"type": "code"}]}, {"type": "text", "text": "."}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "id: ", "marks": [{"type": "bold"}]}, {"type": "text", "text": "stable identifier, used as React key — generate with "}, {"type": "text", "text": "crypto.randomUUID()", "marks": [{"type": "code"}]}, {"type": "text", "text": " on the server or a short uuid library on the client"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "role: ", "marks": [{"type": "bold"}]}, {"type": "text", "text": "one of "}, {"type": "text", "text": "'user'", "marks": [{"type": "code"}]}, {"type": "text", "text": ", "}, {"type": "text", "text": "'assistant'", "marks": [{"type": "code"}]}, {"type": "text", "text": ", "}, {"type": "text", "text": "'system'", "marks": [{"type": "code"}]}, {"type": "text", "text": ", or "}, {"type": "text", "text": "'tool'", "marks": [{"type": "code"}]}, {"type": "text", "text": " — system/tool messages are typically hidden from the UI but included for context"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "parts: ", "marks": [{"type": "bold"}]}, {"type": "text", "text": "required array — always include even for text-only messages so the AI SDK's reconciler does not fall back to legacy parsing"}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Summary"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Generative UI maps LLM tool results to React components via the AI SDK's data-stream protocol."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "useChat", "marks": [{"type": "code"}]}, {"type": "text", "text": " exposes a "}, {"type": "text", "text": "parts", "marks": [{"type": "code"}]}, {"type": "text", "text": "-based message structure: "}, {"type": "text", "text": "text", "marks": [{"type": "code"}]}, {"type": "text", "text": ", "}, {"type": "text", "text": "tool-invocation", "marks": [{"type": "code"}]}, {"type": "text", "text": " (with "}, {"type": "text", "text": "partial-call → call → result", "marks": [{"type": "code"}]}, {"type": "text", "text": " states), and "}, {"type": "text", "text": "reasoning", "marks": [{"type": "code"}]}, {"type": "text", "text": "."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Route handlers return "}, {"type": "text", "text": "streamText().toDataStreamResponse()", "marks": [{"type": "code"}]}, {"type": "text", "text": "; clients consume with "}, {"type": "text", "text": "useChat", "marks": [{"type": "code"}]}, {"type": "text", "text": " or "}, {"type": "text", "text": "useCompletion", "marks": [{"type": "code"}]}, {"type": "text", "text": "."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Custom data can be injected alongside the text stream using "}, {"type": "text", "text": "createDataStreamResponse", "marks": [{"type": "code"}]}, {"type": "text", "text": " and "}, {"type": "text", "text": "appendDataStreamPart", "marks": [{"type": "code"}]}, {"type": "text", "text": "."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Client-side tools defer browser-API calls to the client via "}, {"type": "text", "text": "experimental_onToolCall", "marks": [{"type": "code"}]}, {"type": "text", "text": " and "}, {"type": "text", "text": "addToolResult", "marks": [{"type": "code"}]}, {"type": "text", "text": "."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Always branch on "}, {"type": "text", "text": "toolInvocation.state", "marks": [{"type": "code"}]}, {"type": "text", "text": " before accessing "}, {"type": "text", "text": "result", "marks": [{"type": "code"}]}, {"type": "text", "text": "; show skeletons at "}, {"type": "text", "text": "call", "marks": [{"type": "code"}]}, {"type": "text", "text": " for optimistic UI."}]}]}]}]}}