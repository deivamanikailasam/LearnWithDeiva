            "type": "text",
            "text": "import anthropic\n\nclient = anthropic.Anthropic()\nWEB_SEARCH = [{\"type\": \"web_search_20250305\", \"name\": \"web_search\"}]\n\ndef research_topic(topic: str, subtopics: list[str]) -> str:\n    \"\"\"Search each subtopic then ask Claude to write a structured summary.\"\"\"\"\"\n    messages = []\n\n    for subtopic in subtopics:\n        query = f\"Recent developments in {topic}: {subtopic}\"\n        messages.append({\"role\": \"user\", \"content\": query})\n\n        resp = client.messages.create(\n            model=\"claude-3-5-sonnet-20241022\",\n            max_tokens=512,\n            tools=WEB_SEARCH,\n            messages=messages\n        )\n        messages.append({\"role\": \"assistant\", \"content\": resp.content})\n\n    # Final synthesis request \u2014 no new search needed\n    messages.append({\n        \"role\": \"user\",\n        \"content\": (\n            f\"Based on everything above, write a structured 3-paragraph summary \"\n            f\"of the current state of {topic}. Include key trends and notable projects.\"\n        )\n    })\n    final = client.messages.create(\n        model=\"claude-3-5-sonnet-20241022\",\n        max_tokens=1024,\n        messages=messages          # no tools \u2014 pure synthesis\n    )\n    return \"\".join(b.text for b in final.content if b.type == \"text\")\n\nsummary = research_topic(\n    topic=\"open-source LLMs\",\n    subtopics=[\"model releases\", \"fine-tuning tools\", \"inference frameworks\"]\n)\nprint(summary)\n"
