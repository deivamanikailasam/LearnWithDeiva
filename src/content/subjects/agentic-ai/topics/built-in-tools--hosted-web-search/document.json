      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Multi-Turn Conversations with Search Context"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Web search results become part of the conversation history automatically. In multi-turn exchanges Claude can reference earlier search results without re-searching, saving tokens and reducing latency."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\n\nclient = anthropic.Anthropic()\nWEB_SEARCH = [{\"type\": \"web_search_20250305\", \"name\": \"web_search\"}]\n\nmessages = []\n\ndef chat(user_input: str) -> str:\n    messages.append({\"role\": \"user\", \"content\": user_input})\n    response = client.messages.create(\n        model=\"claude-3-5-sonnet-20241022\",\n        max_tokens=1024,\n        tools=WEB_SEARCH,\n        messages=messages\n    )\n    messages.append({\"role\": \"assistant\", \"content\": response.content})\n    # Extract only text for display\n    return \"\".join(b.text for b in response.content if b.type == \"text\")\n\n# First turn \u2014 Claude may search for the latest info\nreply1 = chat(\"What is the latest version of Node.js LTS?\")\nprint(\"Turn 1:\", reply1)\n\n# Second turn \u2014 Claude can reference the first answer without re-searching\nreply2 = chat(\"What changed between that version and the previous LTS?\")\nprint(\"Turn 2:\", reply2)\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Error Handling and Fallbacks"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The hosted search tool can fail if the search backend is unavailable or the query returns no results. Always handle "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "anthropic.APIError"
          },
          {
            "type": "text",
            "text": " and inspect "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "stop_reason"
          },
          {
            "type": "text",
            "text": " to detect when Claude could not complete a search."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\n\nclient = anthropic.Anthropic()\n\ndef search_with_fallback(query: str, fallback_answer: str = \"\") -> str:\n    \"\"\"Run a web-search query; return fallback text on error.\"\"\"\"\"\n    try:\n        response = client.messages.create(\n            model=\"claude-3-5-sonnet-20241022\",\n            max_tokens=1024,\n            tools=[{\"type\": \"web_search_20250305\", \"name\": \"web_search\"}],\n            messages=[{\"role\": \"user\", \"content\": query}]\n        )\n    except anthropic.APIStatusError as e:\n        print(f\"API error {e.status_code}: {e.message}\")\n        return fallback_answer\n    except anthropic.APIConnectionError:\n        print(\"Connection error \u2014 check network\")\n        return fallback_answer\n\n    text_parts = [b.text for b in response.content if b.type == \"text\"]\n    if not text_parts:\n        return fallback_answer or \"No answer available.\"\n\n    return \"\".join(text_parts)\n\nanswer = search_with_fallback(\n    \"What is the current release date of Python 3.14?\",\n    fallback_answer=\"Python 3.14 release date is unavailable offline.\"\n)\nprint(answer)\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Caching Search Responses"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For high-traffic applications, repeated queries for the same information waste tokens and incur extra search charges. A simple in-memory cache keyed on a normalised query string eliminates duplicate searches within a session."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic, re\n\nclient = anthropic.Anthropic()\n\n_cache: dict[str, str] = {}\n\ndef normalise(query: str) -> str:\n    return re.sub(r\"\\s+\", \" \", query.strip().lower())\n\ndef cached_search(query: str) -> str:\n    key = normalise(query)\n    if key in _cache:\n        print(f\"[cache hit] {key[:50]}\")\n        return _cache[key]\n\n    response = client.messages.create(\n        model=\"claude-3-5-sonnet-20241022\",\n        max_tokens=1024,\n        tools=[{\"type\": \"web_search_20250305\", \"name\": \"web_search\"}],\n        messages=[{\"role\": \"user\", \"content\": query}]\n    )\n    answer = \"\".join(b.text for b in response.content if b.type == \"text\")\n    _cache[key] = answer\n    return answer\n\n# First call hits the API\nr1 = cached_search(\"What is the latest stable release of Rust?\")\nprint(r1[:120])\n\n# Second identical call returns from cache\nr2 = cached_search(\"What is the latest stable release of Rust?\")\nprint(r2[:120])\n"
