      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "When Not to Decompose"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Simple single-turn tasks: "
                  },
                  {
                    "type": "text",
                    "text": "A task answerable in one LLM call does not benefit from decomposition overhead. The coordination cost (decompose, schedule, pass context) is higher than the task itself."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Highly sequential tasks with no parallelism: "
                  },
                  {
                    "type": "text",
                    "text": "If every subtask depends on the previous, decomposition adds management overhead without enabling concurrency."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "When subtask boundaries are unclear: "
                  },
                  {
                    "type": "text",
                    "text": "Forcing decomposition on ill-defined tasks produces subtask lists that overlap or leave gaps. Clarify the goal first."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Ask the model to decompose with a flat DAG structure "
                  },
                  {
                    "type": "text",
                    "text": "\u2014 ids and depends_on edges \u2014 rather than a nested tree; flat lists are easier to schedule and execute."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Use topological sort to group subtasks into waves "
                  },
                  {
                    "type": "text",
                    "text": "and run each wave in parallel with ThreadPoolExecutor for I/O-bound LLM calls."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Pass only the relevant prior context "
                  },
                  {
                    "type": "text",
                    "text": "to each subtask (only its dependencies' results), not the full history, to avoid context bloat."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Validate each subtask result "
                  },
                  {
                    "type": "text",
                    "text": "before marking it complete; retry with failure context on the first few attempts before escalating to re-decomposition."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}