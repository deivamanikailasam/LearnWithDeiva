      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Use Cases"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Missing Required Parameter"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "@app.call_tool()\nasync def call_tool(name: str, arguments: dict):\n    if name == \"send_email\":\n        # Model provided subject and body but forgot the recipient\n        if \"to\" not in arguments or not arguments[\"to\"]:\n            ctx = app.request_context\n            result = await ctx.session.elicit(\n                message=\"Recipient address is required to send the email.\",\n                requestedSchema={\n                    \"type\": \"object\",\n                    \"properties\": {\n                        \"to\": {\n                            \"type\": \"string\",\n                            \"title\": \"Recipient\",\n                            \"format\": \"email\",\n                            \"description\": \"Who should receive this email?\"\n                        }\n                    },\n                    \"required\": [\"to\"]\n                }\n            )\n            if result.action != \"accept\":\n                return [types.TextContent(type=\"text\", text=\"Email not sent \u2014 no recipient provided.\")]\n            arguments[\"to\"] = result.content[\"to\"]\n\n        # Proceed with sending\n        return await send_email(arguments)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Disambiguation"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "@app.call_tool()\nasync def call_tool(name: str, arguments: dict):\n    if name == \"schedule_meeting\":\n        candidates = await find_slots(arguments[\"duration_minutes\"])\n        if len(candidates) > 1:\n            ctx = app.request_context\n            result = await ctx.session.elicit(\n                message=\"Multiple time slots are available.\",\n                requestedSchema={\n                    \"type\": \"object\",\n                    \"properties\": {\n                        \"slot\": {\n                            \"type\": \"string\",\n                            \"title\": \"Choose a time slot\",\n                            \"enum\": [s[\"label\"] for s in candidates],\n                            \"description\": \"Which slot should be booked?\"\n                        }\n                    },\n                    \"required\": [\"slot\"]\n                }\n            )\n            if result.action != \"accept\":\n                return [types.TextContent(type=\"text\", text=\"Meeting not booked.\")]\n            chosen = next(s for s in candidates if s[\"label\"] == result.content[\"slot\"])\n            return await book_slot(chosen)\n        return await book_slot(candidates[0])"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing Elicitation Handlers"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The MCP Python SDK provides a test harness for exercising elicitation without a real host. You create a mock session that supplies predefined responses:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
