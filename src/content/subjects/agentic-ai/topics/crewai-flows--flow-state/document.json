                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": ": breaking \u2014 old checkpoints raise a Pydantic validation error. Always provide a default."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Renaming fields",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": ": breaking \u2014 old checkpoints still have the old name. Add a Pydantic "
                  },
                  {
                    "type": "text",
                    "text": "@model_validator",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " to migrate."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Changing field types",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": ": risky \u2014 if existing values can't be coerced to the new type, loading fails. Use "
                  },
                  {
                    "type": "text",
                    "text": "Union[OldType, NewType]",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " during transition."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Safe field addition\nclass ResearchStateV2(BaseModel):\n    topic: str = \"\"\n    summary: str = \"\"\n    # New field with default \u2014 existing checkpoints load fine\n    confidence: float = 0.5\n\n# Safe migration via validator\nfrom pydantic import model_validator\n\nclass ResearchStateV3(BaseModel):\n    topic: str = \"\"\n    summary: str = \"\"\n    # Renamed from 'summary' to 'abstract' \u2014 migrate old data\n    abstract: str = \"\"\n\n    @model_validator(mode=\"before\")\n    @classmethod\n    def migrate(cls, data):\n        if \"summary\" in data and \"abstract\" not in data:\n            data[\"abstract\"] = data.pop(\"summary\")\n        return data"
          }
        ]
