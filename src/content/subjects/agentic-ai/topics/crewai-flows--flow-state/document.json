      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "class MultiStageState(BaseModel):\n    topic: str = \"\"\n    research: str = \"\"\n    keywords: list[str] = []\n    draft: str = \"\"\n\nclass MultiStageFlow(Flow[MultiStageState]):\n\n    @start()\n    def research_step(self):\n        # Bridge: state \u2192 crew inputs\n        result = research_crew.kickoff(inputs={\"topic\": self.state.topic})\n        # Bridge: crew output \u2192 state\n        self.state.research = result.raw\n\n    @listen(research_step)\n    def keyword_step(self):\n        result = keyword_crew.kickoff(inputs={\"text\": self.state.research})\n        self.state.keywords = result.raw.split(\",\")\n\n    @listen(keyword_step)\n    def draft_step(self):\n        result = writing_crew.kickoff(inputs={\n            \"research\": self.state.research,\n            \"keywords\": \", \".join(self.state.keywords),\n            \"topic\": self.state.topic,\n        })\n        self.state.draft = result.raw"
          }
        ]
