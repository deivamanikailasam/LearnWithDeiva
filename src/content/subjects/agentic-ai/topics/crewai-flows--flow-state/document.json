        },
        "content": [
          {
            "type": "text",
            "text": "class DebugFlow(Flow[ResearchState]):\n\n    @start()\n    def step_one(self):\n        print(f\"[step_one] state before: {self.state.model_dump()}\")\n        self.state.topic = \"fusion\"\n        print(f\"[step_one] state after: {self.state.topic}\")\n\n    @listen(step_one)\n    def step_two(self):\n        # Assert invariants\n        assert self.state.topic, \"topic must be set before step_two\"\n        print(f\"[step_two] processing topic: {self.state.topic}\")"
          }
