            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Closed, single-team system"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 a lightweight "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "AgentMessage"
                  },
                  {
                    "type": "text",
                    "text": " dataclass with typed performatives is sufficient. No external standard needed."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Cross-team or cross-org agents"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 adopt A2A or ACP so each team can implement against a published spec without coordinating data schema changes."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Negotiation and resource allocation"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 implement Contract Net on top of whichever envelope you chose; it is protocol-agnostic."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Security-sensitive deployments"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 add capability tokens and mTLS from day one; retrofitting authentication into a running system is much harder than starting with it."
                  }
                ]
              }
            ]
          }
