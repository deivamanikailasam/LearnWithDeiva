      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Implementing a Minimal ACP-Style Envelope"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "You don't need to adopt a full external protocol to get the benefits. A minimal envelope implemented in Python gives you interoperability at the cost of a single dataclass:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass, field\nfrom typing import Any, Literal\nimport uuid\nfrom datetime import datetime, timezone\n\n\nPerformative = Literal[\n    \"REQUEST\", \"INFORM\", \"PROPOSE\", \"ACCEPT\",\n    \"REJECT\", \"QUERY\", \"FAILURE\", \"CANCEL\",\n]\n\n\n@dataclass\nclass AgentMessage:\n    \"\"\"Minimal ACP-compatible message envelope.\"\"\"\n    # Routing\n    msg_id: str = field(default_factory=lambda: str(uuid.uuid4()))\n    conversation_id: str = \"\"       # groups messages in one task flow\n    in_reply_to: str | None = None  # msg_id this is a response to\n    sender: str = \"\"\n    receiver: str = \"\"\n    # Intent\n    performative: Performative = \"INFORM\"\n    # Payload\n    content_type: str = \"application/json\"  # or \"text/plain\"\n    content: Any = None\n    # Metadata\n    timestamp: str = field(\n        default_factory=lambda: datetime.now(timezone.utc).isoformat()\n    )\n    ttl_seconds: int = 300          # message expires if not processed\n\n\ndef make_request(\n    sender: str, receiver: str, task: dict, conversation_id: str = \"\"\n) -> AgentMessage:\n    return AgentMessage(\n        sender=sender,\n        receiver=receiver,\n        performative=\"REQUEST\",\n        content=task,\n        conversation_id=conversation_id or str(uuid.uuid4()),\n    )\n\n\ndef make_inform(\n    sender: str,\n    receiver: str,\n    result: Any,\n    reply_to_msg: AgentMessage,\n) -> AgentMessage:\n    return AgentMessage(\n        sender=sender,\n        receiver=receiver,\n        performative=\"INFORM\",\n        content=result,\n        conversation_id=reply_to_msg.conversation_id,\n        in_reply_to=reply_to_msg.msg_id,\n    )\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Conversation Patterns"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Protocols define not only message format but the "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "sequence"
          },
          {
            "type": "text",
            "text": " in which messages are exchanged. Three canonical patterns cover most multi-agent use cases:"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "1. Request-Inform (single round-trip)"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Coordinator \u2192 Worker: REQUEST\n# Worker \u2192 Coordinator: INFORM\n\nasync def request_inform(coordinator_id: str, worker_id: str, task: dict, mailbox):\n    req = make_request(coordinator_id, worker_id, task)\n    await mailbox.send(worker_id, req)\n\n    # worker processes and replies\n    reply: AgentMessage = await mailbox.receive(coordinator_id)\n    assert reply.performative == \"INFORM\"\n    assert reply.in_reply_to == req.msg_id\n    return reply.content\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "2. Contract Net (negotiation)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The Contract Net Protocol (CNP) is a three-phase negotiation: announce the task, collect bids (PROPOSE), select the winner (ACCEPT / REJECT). It generalises the auction pattern:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\n\n\nasync def contract_net(\n    coordinator_id: str,\n    worker_ids: list[str],\n    task: dict,\n    mailbox,\n    bid_timeout: float = 10.0,\n) -> AgentMessage | None:\n    convo = str(uuid.uuid4())\n\n    # Phase 1: broadcast REQUEST to all workers\n    for wid in worker_ids:\n        await mailbox.send(wid, AgentMessage(\n            sender=coordinator_id, receiver=wid,\n            performative=\"REQUEST\",\n            content=task, conversation_id=convo,\n        ))\n\n    # Phase 2: collect PROPOSALs within timeout\n    proposals: list[AgentMessage] = []\n    deadline = asyncio.get_event_loop().time() + bid_timeout\n    while len(proposals) < len(worker_ids):\n        remaining = deadline - asyncio.get_event_loop().time()\n        if remaining <= 0:\n            break\n        try:\n            msg = await asyncio.wait_for(\n                mailbox.receive(coordinator_id), timeout=remaining\n            )\n            if msg.performative == \"PROPOSE\" and msg.conversation_id == convo:\n                proposals.append(msg)\n        except asyncio.TimeoutError:\n            break\n\n    if not proposals:\n        return None\n\n    # Phase 3: pick winner (lowest quoted cost)\n    winner = min(proposals, key=lambda m: m.content.get(\"cost\", float(\"inf\")))\n\n    for p in proposals:\n        perf = \"ACCEPT\" if p.msg_id == winner.msg_id else \"REJECT\"\n        await mailbox.send(p.sender, AgentMessage(\n            sender=coordinator_id, receiver=p.sender,\n            performative=perf, conversation_id=convo,\n            in_reply_to=p.msg_id, content={},\n        ))\n\n    return winner\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Wiring into LangGraph"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Protocol-aware agents store received messages in state so the graph checkpoint captures the full conversation. Each node reads its inbox, checks the performative to decide what to do, and writes the reply back:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import operator\nfrom typing import Annotated\nfrom typing_extensions import TypedDict\nfrom langgraph.graph import StateGraph, END\nfrom langchain_anthropic import ChatAnthropic\n\n\nclass ProtocolState(TypedDict):\n    inbox: list[AgentMessage]           # messages arriving this step\n    outbox: Annotated[list[AgentMessage], operator.add]\n    conversation_log: Annotated[list[AgentMessage], operator.add]\n    result: str\n\n\n_llm = ChatAnthropic(model=\"claude-haiku-4-5-20251001\")\n\n\ndef worker_node(state: ProtocolState) -> dict:\n    out_msgs = []\n    for msg in state[\"inbox\"]:\n        if msg.performative == \"REQUEST\":\n            resp = _llm.invoke(str(msg.content))\n            reply = make_inform(\n                sender=\"worker\",\n                receiver=msg.sender,\n                result={\"answer\": resp.content},\n                reply_to_msg=msg,\n            )\n            out_msgs.append(reply)\n        elif msg.performative == \"CANCEL\":\n            # acknowledge cancellation\n            out_msgs.append(AgentMessage(\n                sender=\"worker\", receiver=msg.sender,\n                performative=\"INFORM\",\n                content={\"status\": \"cancelled\"},\n                conversation_id=msg.conversation_id,\n                in_reply_to=msg.msg_id,\n            ))\n    return {\n        \"outbox\": out_msgs,\n        \"conversation_log\": state[\"inbox\"],\n        \"result\": out_msgs[0].content.get(\"answer\", \"\") if out_msgs else \"\",\n    }\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Protocol Security: Identity and Capability Tokens"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "In an open multi-agent system any process can claim to be any agent. Two mechanisms address this: "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "mutual TLS (mTLS)"
          },
          {
            "type": "text",
            "text": " authenticates the transport layer, while "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "signed capability tokens"
          },
          {
            "type": "text",
            "text": " constrain what an authenticated agent is allowed to request. A capability token is a signed JSON object the orchestrator issues to an agent after verifying its identity:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import hmac, hashlib, json, base64, time\n\nSECRET_KEY = b\"shared-orchestrator-secret\"   # in production: rotate & vault\n\n\ndef issue_capability_token(\n    agent_id: str,\n    capabilities: list[str],\n    ttl: int = 3600,\n) -> str:\n    \"\"\"Issue a signed token granting named capabilities to an agent.\"\"\"\n    payload = {\n        \"sub\": agent_id,\n        \"caps\": capabilities,    # e.g. [\"search\", \"write_file\"]\n        \"iat\": int(time.time()),\n        \"exp\": int(time.time()) + ttl,\n    }\n    body = base64.urlsafe_b64encode(json.dumps(payload).encode()).decode()\n    sig = hmac.new(SECRET_KEY, body.encode(), hashlib.sha256).hexdigest()\n    return f\"{body}.{sig}\"\n\n\ndef verify_capability_token(token: str, required_cap: str) -> bool:\n    \"\"\"Return True only if token is valid and grants the required capability.\"\"\"\n    try:\n        body, sig = token.rsplit(\".\", 1)\n        expected = hmac.new(SECRET_KEY, body.encode(), hashlib.sha256).hexdigest()\n        if not hmac.compare_digest(sig, expected):\n            return False\n        payload = json.loads(base64.urlsafe_b64decode(body + \"==\"))\n        if payload[\"exp\"] < time.time():\n            return False\n        return required_cap in payload[\"caps\"]\n    except Exception:\n        return False\n\n\n# Worker node: verify before executing a request\ndef secure_worker_node(state: ProtocolState) -> dict:\n    out = []\n    for msg in state[\"inbox\"]:\n        token = msg.content.get(\"_cap_token\", \"\")\n        if not verify_capability_token(token, \"analyse\"):\n            out.append(AgentMessage(\n                sender=\"worker\", receiver=msg.sender,\n                performative=\"FAILURE\",\n                content={\"reason\": \"insufficient capabilities\"},\n                conversation_id=msg.conversation_id,\n                in_reply_to=msg.msg_id,\n            ))\n            continue\n        # ... normal processing ...\n    return {\"outbox\": out, \"conversation_log\": state[\"inbox\"], \"result\": \"\"}\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Agent Discovery with Agent Cards"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The A2A protocol popularised the "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "AgentCard"
          },
          {
            "type": "text",
            "text": " \u2014 a self-describing JSON document an agent publishes at "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "/.well-known/agent.json"
          },
          {
            "type": "text",
            "text": ". A coordinator fetches agent cards at startup to build its routing table dynamically, rather than hard-coding agent addresses:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass\n\n\n@dataclass\nclass AgentCard:\n    agent_id: str\n    display_name: str\n    endpoint: str                  # e.g. \"http://worker-a:8080/tasks\"\n    capabilities: list[str]        # e.g. [\"search\", \"summarise\", \"code\"]\n    supported_performatives: list[str]\n    version: str = \"1.0\"\n\n\n# In-memory registry \u2014 replace with Redis or a service-discovery sidecar\nclass AgentRegistry:\n    def __init__(self):\n        self._cards: dict[str, AgentCard] = {}\n\n    def register(self, card: AgentCard):\n        self._cards[card.agent_id] = card\n\n    def find_by_capability(self, cap: str) -> list[AgentCard]:\n        return [c for c in self._cards.values() if cap in c.capabilities]\n\n    def get(self, agent_id: str) -> AgentCard | None:\n        return self._cards.get(agent_id)\n\n\nregistry = AgentRegistry()\nregistry.register(AgentCard(\n    agent_id=\"search-agent\",\n    display_name=\"Web Search Specialist\",\n    endpoint=\"http://search:8080\",\n    capabilities=[\"search\", \"scrape\"],\n    supported_performatives=[\"REQUEST\", \"CANCEL\"],\n))\n\n# Coordinator: find any agent that can \"search\"\ncandidates = registry.find_by_capability(\"search\")\nif candidates:\n    target = candidates[0]\n    print(f\"Routing to {target.agent_id} at {target.endpoint}\")\n"
          }
        ]
      },
