      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Validating a Fine-Tuned Checkpoint"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Never ship a fine-tuned checkpoint without running it against the held-out eval set and comparing pass rates to the production baseline. Also run a regression suite across dimensions not targeted by the training data \u2014 fine-tuning on accuracy examples can inadvertently change tone or safety behaviour."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic, json\nfrom pathlib import Path\n\n\ndef validate_checkpoint(\n    fine_tuned_model: str,\n    baseline_model: str,\n    eval_path: str,\n    judge_model: str = \"claude-haiku-4-5-20251001\",\n    regression_threshold: float = 0.02,\n) -> dict:\n    \"\"\"\n    Run both models on the eval set and return a comparison report.\n    Returns a dict with per-model pass rates and a go/no-go verdict.\n    \"\"\"\n    client = anthropic.Anthropic()\n\n    def score_model(model_id: str) -> tuple[float, list]:\n        passed, failures = 0, []\n        with open(eval_path) as f:\n            cases = [json.loads(l) for l in f]\n        for case in cases:\n            resp = client.messages.create(\n                model=model_id, max_tokens=512, messages=case[\"messages\"],\n            )\n            output = resp.content[0].text\n            verdict = client.messages.create(\n                model=judge_model,\n                max_tokens=8,\n                messages=[{\"role\": \"user\", \"content\":\n                    f\"Is this response correct? Yes or no only.\\n\\n{output}\"}],\n            )\n            if \"yes\" in verdict.content[0].text.lower():\n                passed += 1\n            else:\n                failures.append({\"messages\": case[\"messages\"], \"output\": output})\n        return passed / len(cases), failures[:3]\n\n    print(f\"Evaluating baseline: {baseline_model}\")\n    base_rate, _ = score_model(baseline_model)\n    print(f\"Evaluating fine-tuned: {fine_tuned_model}\")\n    ft_rate, ft_failures = score_model(fine_tuned_model)\n\n    delta = ft_rate - base_rate\n    verdict = \"DEPLOY\" if delta >= 0 and delta >= -regression_threshold else \"ROLLBACK\"\n    if delta < -regression_threshold:\n        verdict = \"ROLLBACK\"\n    elif delta < 0:\n        verdict = \"INVESTIGATE\"\n\n    return {\n        \"baseline_pass_rate\": round(base_rate, 3),\n        \"ft_pass_rate\": round(ft_rate, 3),\n        \"delta\": round(delta, 3),\n        \"verdict\": verdict,\n        \"ft_failures\": ft_failures,\n    }\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Shadow Rollout Pattern"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Before routing live traffic to the fine-tuned model, run it in shadow mode: send every request to both the production model and the fine-tuned model, log both outputs, but only serve the production output to the user. This reveals regression patterns against real traffic at zero user risk."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\nimport anthropic\n\nclient = anthropic.AsyncAnthropic()\n\n\nasync def shadow_request(\n    messages: list[dict],\n    system: str,\n    production_model: str,\n    shadow_model: str,\n    shadow_log_path: str,\n) -> str:\n    \"\"\"\n    Send request to both models concurrently.\n    Return only the production response; log the shadow response for analysis.\n    \"\"\"\n    async def call(model: str) -> str:\n        resp = await client.messages.create(\n            model=model, max_tokens=1024, system=system, messages=messages,\n        )\n        return resp.content[0].text\n\n    prod_out, shadow_out = await asyncio.gather(\n        call(production_model),\n        call(shadow_model),\n    )\n\n    import json, time\n    with open(shadow_log_path, \"a\") as f:\n        f.write(json.dumps({\n            \"ts\": time.time(),\n            \"messages\": messages,\n            \"production\": prod_out,\n            \"shadow\": shadow_out,\n        }) + \"\\n\")\n\n    return prod_out   # only prod output reaches the user\n\n\nasync def analyse_shadow_log(log_path: str, judge_model: str = \"claude-haiku-4-5-20251001\") -> dict:\n    \"\"\"Compare production vs shadow quality on the shadow log.\"\"\"\n    client_sync = anthropic.Anthropic()\n    prod_wins = shadow_wins = ties = 0\n    with open(log_path) as f:\n        for line in f:\n            item = json.loads(line)\n            resp = client_sync.messages.create(\n                model=judge_model, max_tokens=4,\n                messages=[{\"role\": \"user\", \"content\":\n                    f\"Which response is better? A or B or tie.\\n\\nA: {item['production']}\\n\\nB: {item['shadow']}\"}],\n            )\n            choice = resp.content[0].text.strip().lower()\n            if \"a\" in choice: prod_wins += 1\n            elif \"b\" in choice: shadow_wins += 1\n            else: ties += 1\n    total = prod_wins + shadow_wins + ties or 1\n    return {\"prod_win_rate\": prod_wins/total, \"shadow_win_rate\": shadow_wins/total, \"ties\": ties/total}\n"
          }
        ]
      },
