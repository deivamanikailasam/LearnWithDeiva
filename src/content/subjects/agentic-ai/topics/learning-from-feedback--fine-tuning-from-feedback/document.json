      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Preparing SFT Data from Corrections"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "SFT trains on (input, ideal_output) pairs. Each correction record in the feedback store is a natural SFT example: the messages field is the input, and the human-corrected text is the ideal output. Filter aggressively \u2014 only include corrections with a high edit-distance ratio (the human changed a meaningful fraction) and mark the dimension so the training run can be scoped."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import json, sqlite3\nfrom difflib import SequenceMatcher\n\n\nMIN_EDIT_RATIO = 0.15   # human changed at least 15% of the output\n\n\ndef export_sft_jsonl(\n    corrections_db: sqlite3.Connection,\n    output_path: str,\n    dimension: str | None = None,\n    min_edit_ratio: float = MIN_EDIT_RATIO,\n) -> int:\n    \"\"\"\n    Export (messages, completion) pairs from the corrections table in JSONL\n    format compatible with the Anthropic fine-tuning API.\n\n    Each line:\n      {\"messages\": [...conversation turns...], \"completion\": \"<ideal output>\"}\n    \"\"\"\n    query = \"\"\"\n        SELECT messages, agent_output, human_output, dimension\n        FROM corrections\n        WHERE edit_distance_ratio >= ?\n    \"\"\"\n    params = [min_edit_ratio]\n    if dimension:\n        query += \" AND dimension = ?\"\n        params.append(dimension)\n\n    rows = corrections_db.execute(query, params).fetchall()\n    written = 0\n    with open(output_path, \"w\") as f:\n        for messages_json, agent_out, human_out, dim in rows:\n            # Double-check edit ratio against live values (db value may be stale)\n            ratio = 1 - SequenceMatcher(None, agent_out, human_out).ratio()\n            if ratio < min_edit_ratio:\n                continue\n            messages = json.loads(messages_json)\n            # Ensure messages end on a user turn\n            if not messages or messages[-1][\"role\"] != \"user\":\n                continue\n            f.write(json.dumps({\n                \"messages\": messages,\n                \"completion\": human_out,\n            }) + \"\\n\")\n            written += 1\n    print(f\"Exported {written} SFT examples to {output_path}\")\n    return written\n\n\ndef deduplicate_sft(input_path: str, output_path: str) -> int:\n    \"\"\"\n    Remove duplicate prompt hashes to avoid overfitting on repeated examples.\n    \"\"\"\n    import hashlib\n    seen = set()\n    kept = 0\n    with open(input_path) as fin, open(output_path, \"w\") as fout:\n        for line in fin:\n            item = json.loads(line)\n            key = hashlib.sha256(\n                json.dumps(item[\"messages\"], sort_keys=True).encode()\n            ).hexdigest()\n            if key in seen:\n                continue\n            seen.add(key)\n            fout.write(line)\n            kept += 1\n    print(f\"Deduplication: {kept} unique examples retained\")\n    return kept\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Preparing DPO Data from Preference Pairs"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "DPO trains on (messages, chosen, rejected) triples. Export from the preference_pairs table, filter out ties, and require confidence >= 2 so only clear preferences enter the dataset. Shuffle and split 90/10 for training and validation before any training run."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import json, random, sqlite3\n\n\ndef export_dpo_jsonl(\n    preferences_db: sqlite3.Connection,\n    train_path: str,\n    val_path: str,\n    min_confidence: int = 2,\n    val_fraction: float = 0.10,\n    seed: int = 42,\n) -> dict:\n    \"\"\"\n    Export (messages, chosen, rejected) triples from the preference_pairs table.\n    Splits into train/val at val_fraction.\n    \"\"\"\n    rows = preferences_db.execute(\n        \"\"\"\n        SELECT messages, output_a, output_b, chosen, confidence\n        FROM preference_pairs\n        WHERE chosen != 'tie' AND confidence >= ?\n        \"\"\",\n        (min_confidence,),\n    ).fetchall()\n\n    examples = []\n    for messages_json, a, b, chosen, conf in rows:\n        messages  = json.loads(messages_json)\n        chosen_t  = a if chosen == \"A\" else b\n        rejected_t = b if chosen == \"A\" else a\n        examples.append({\n            \"messages\": messages,\n            \"chosen\":   chosen_t,\n            \"rejected\": rejected_t,\n        })\n\n    random.seed(seed)\n    random.shuffle(examples)\n    n_val   = max(1, int(len(examples) * val_fraction))\n    val_set = examples[:n_val]\n    train_set = examples[n_val:]\n\n    def write_jsonl(path: str, items: list) -> None:\n        with open(path, \"w\") as f:\n            for item in items:\n                f.write(json.dumps(item) + \"\\n\")\n\n    write_jsonl(train_path, train_set)\n    write_jsonl(val_path, val_set)\n    print(f\"DPO export: {len(train_set)} train / {len(val_set)} val\")\n    return {\"train\": len(train_set), \"val\": len(val_set)}\n"
          }
        ]
      },
