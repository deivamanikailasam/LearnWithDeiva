        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "The goal of plan adaptation is to keep as much of the existing plan intact as possible. Each preserved step represents execution context, tool calls, and LLM inference already paid for."
              }
            ]
          }
        ]
