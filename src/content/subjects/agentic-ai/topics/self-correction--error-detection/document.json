      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Run cheap detection first. Rule-based checks cost nothing; LLM-based semantic checks cost a full inference call. Filtering structural errors with rules means the LLM layer only sees outputs that are syntactically valid \u2014 improving detection precision."
              }
            ]
          }
        ]
