        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Errors fall into three layers: execution/structural (rules, free), schema/format (Pydantic, negligible), and semantic (LLM call, expensive)."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Run cheaper layers first and short-circuit \u2014 if a structural error is found, skip schema and semantic checks."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "DetectedError carries layer, error_type, message, and recoverable to give self-correction code enough context to choose the right repair strategy."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Pydantic validators with custom field_validator methods catch domain-specific constraints (score ranges, enum values) without LLM overhead."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The semantic detector returns is_correct alongside the error list \u2014 a clean True means no further detection is needed."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "run_semantic=False disables the LLM layer for latency-sensitive paths where structural correctness is sufficient."
                  }
                ]
              }
            ]
          }
        ]
      }
