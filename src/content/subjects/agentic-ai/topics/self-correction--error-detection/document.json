      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Layer 1: Rule-Based Detection"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Rule-based detectors are pure Python \u2014 no LLM calls. They catch the most common structural problems instantly and prevent malformed outputs from reaching expensive downstream steps."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass\nfrom typing import Any, Optional\n\n@dataclass\nclass DetectedError:\n    layer: str           # 'rule', 'schema', 'semantic'\n    error_type: str      # e.g. 'missing_field', 'type_mismatch', 'factual_error'\n    message: str\n    recoverable: bool = True\n\n\ndef detect_structural_errors(\n    output: Any,\n    required_keys: list[str] | None = None,\n    expected_type: type | None = None,\n    min_length: int = 0,\n) -> list[DetectedError]:\n    errors = []\n\n    if expected_type and not isinstance(output, expected_type):\n        errors.append(DetectedError(\n            layer=\"rule\",\n            error_type=\"type_mismatch\",\n            message=f\"Expected {expected_type.__name__}, got {type(output).__name__}\",\n        ))\n        return errors  # no point checking keys on wrong type\n\n    if required_keys and isinstance(output, dict):\n        missing = [k for k in required_keys if k not in output]\n        if missing:\n            errors.append(DetectedError(\n                layer=\"rule\",\n                error_type=\"missing_field\",\n                message=f\"Missing required keys: {missing}\",\n            ))\n\n    if isinstance(output, str) and len(output) < min_length:\n        errors.append(DetectedError(\n            layer=\"rule\",\n            error_type=\"too_short\",\n            message=f\"Output length {len(output)} < minimum {min_length}\",\n        ))\n\n    return errors\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Layer 2: Schema Validation"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Pydantic provides declarative schema validation with automatic type coercion and meaningful error messages. For agents that produce structured outputs, parsing through a Pydantic model catches field-level errors with no LLM overhead."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from pydantic import BaseModel, ValidationError, field_validator\nimport json\n\nclass StepResult(BaseModel):\n    status: str\n    output: str\n    tool_used: str\n    confidence: float\n\n    @field_validator(\"status\")\n    @classmethod\n    def status_valid(cls, v: str) -> str:\n        allowed = {\"success\", \"failure\", \"partial\"}\n        if v not in allowed:\n            raise ValueError(f\"status must be one of {allowed}\")\n        return v\n\n    @field_validator(\"confidence\")\n    @classmethod\n    def confidence_range(cls, v: float) -> float:\n        if not 0.0 <= v <= 1.0:\n            raise ValueError(\"confidence must be between 0.0 and 1.0\")\n        return v\n\n\ndef detect_schema_errors(\n    raw_output: str,\n) -> list[DetectedError]:\n    try:\n        data = json.loads(raw_output)\n        StepResult.model_validate(data)\n        return []\n    except json.JSONDecodeError as e:\n        return [DetectedError(\"schema\", \"invalid_json\", str(e))]\n    except ValidationError as e:\n        return [\n            DetectedError(\"schema\", err[\"type\"], err[\"msg\"])\n            for err in e.errors()\n        ]\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Layer 3: Semantic Error Detection"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Semantic errors pass structural checks but fail on meaning \u2014 wrong answer, goal misalignment, or subtle factual errors. An LLM evaluator detects these by comparing the output to the step's objective and success criteria."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic, re\n\nSEMANTIC_CHECK_PROMPT = \"\"\"Check whether this step output is semantically correct.\n\nStep objective: {objective}\nSuccess criteria:\n{criteria}\n\nOutput to check:\n{output}\n\nFind any semantic errors:\n- Factual claims that are wrong\n- Output that contradicts the objective\n- Missing information required by the criteria\n\nRespond with JSON:\n{{\"errors\": [{{\"type\": str, \"message\": str, \"recoverable\": bool}}],\n  \"is_correct\": bool}}\n\"\"\"\n\ndef detect_semantic_errors(\n    client: anthropic.Anthropic,\n    objective: str,\n    criteria: list[str],\n    output: str,\n) -> list[DetectedError]:\n    prompt = SEMANTIC_CHECK_PROMPT.format(\n        objective=objective,\n        criteria=\"\\n\".join(f\"  - {c}\" for c in criteria),\n        output=output,\n    )\n    resp = client.messages.create(\n        model=\"claude-sonnet-4-6\",\n        max_tokens=512,\n        messages=[{\"role\":\"user\",\"content\":prompt}],\n    )\n    raw = resp.content[0].text\n    m = re.search(r\"\\{.*\\}\", raw, re.DOTALL)\n    data = json.loads(m.group()) if m else {}\n    if data.get(\"is_correct\", True):\n        return []\n    return [\n        DetectedError(\n            layer=\"semantic\",\n            error_type=e.get(\"type\", \"semantic_error\"),\n            message=e.get(\"message\", \"\"),\n            recoverable=e.get(\"recoverable\", True),\n        )\n        for e in data.get(\"errors\", [])\n    ]\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Composing the Detection Pipeline"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def detect_errors(\n    client: anthropic.Anthropic,\n    output: Any,\n    raw_output: str,\n    objective: str,\n    criteria: list[str],\n    required_keys: list[str] | None = None,\n    run_semantic: bool = True,\n) -> list[DetectedError]:\n    # Layer 1: rules (free)\n    errors = detect_structural_errors(output, required_keys)\n    if errors:\n        return errors  # structural errors block semantic check\n\n    # Layer 2: schema (negligible cost)\n    if isinstance(raw_output, str):\n        schema_errors = detect_schema_errors(raw_output)\n        if schema_errors:\n            return schema_errors\n\n    # Layer 3: semantic (1 LLM call)\n    if run_semantic:\n        return detect_semantic_errors(client, objective, criteria, str(output))\n\n    return []\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The pipeline short-circuits: structural errors abort before schema validation, which aborts before the semantic LLM call. This means the expensive layer only runs on outputs that are structurally sound \u2014 avoiding wasting an inference call on an output the schema would have caught for free."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Error Recovery Strategies"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Detecting an error is only half the work \u2014 the pipeline must decide what to do next. The choice depends on the error's layer, its "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "recoverable"
          },
          {
            "type": "text",
            "text": " flag, and how many retries have already occurred."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Error Recovery Decision Tree",
          "title": "Error recovery routing"
        }
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from enum import Enum\nfrom dataclasses import dataclass, field\nfrom typing import Callable, Any\n\nclass RecoveryAction(Enum):\n    RETRY       = 'retry'\n    SUBSTITUTE  = 'substitute'\n    SKIP        = 'skip'\n    ABORT       = 'abort'\n\ndef choose_recovery(error: DetectedError, attempt: int) -> RecoveryAction:\n    if not error.recoverable:\n        return RecoveryAction.ABORT\n    if error.layer in ('rule', 'schema') and attempt < 2:\n        return RecoveryAction.RETRY\n    if error.layer == 'semantic' and attempt < 1:\n        return RecoveryAction.SUBSTITUTE  # try different tool\n    return RecoveryAction.SKIP\n\ndef execute_with_recovery(\n    client,\n    step_fn: Callable[[], Any],\n    detect_fn: Callable[[Any], list[DetectedError]],\n    substitute_fn: Callable[[], Any] | None = None,\n    max_retries: int = 2,\n) -> tuple[Any, list[DetectedError]]:\n    \"\"\"Runs step_fn, detects errors, and applies recovery.\"\"\"\n    all_errors: list[DetectedError] = []\n    for attempt in range(max_retries + 1):\n        result = step_fn()\n        errors = detect_fn(result)\n        if not errors:\n            return result, []\n        all_errors.extend(errors)\n        action = choose_recovery(errors[0], attempt)\n        if action == RecoveryAction.ABORT:\n            raise RuntimeError(f'Unrecoverable error: {errors[0].message}')\n        if action == RecoveryAction.SUBSTITUTE and substitute_fn:\n            result = substitute_fn()\n            return result, all_errors\n        if action == RecoveryAction.SKIP:\n            return None, all_errors  # caller handles None\n        # RETRY: loop continues\n    return result, all_errors\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Circuit Breakers and Rate Limiting"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A naive retry loop can amplify errors \u2014 if a tool is consistently returning malformed output, retrying 50 times makes things worse, not better. A "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "circuit breaker"
          },
          {
            "type": "text",
            "text": " tracks the consecutive failure count for a tool and opens (stops retrying) once a threshold is crossed."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "@dataclass\nclass CircuitBreaker:\n    name: str\n    failure_threshold: int = 3\n    _failures: int = 0\n    _open: bool = False\n\n    def record_failure(self) -> None:\n        self._failures += 1\n        if self._failures >= self.failure_threshold:\n            self._open = True\n\n    def record_success(self) -> None:\n        self._failures = 0\n        self._open = False\n\n    @property\n    def is_open(self) -> bool:\n        return self._open\n\n# Usage: one breaker per tool\n_breakers: dict[str, CircuitBreaker] = {}\n\ndef get_breaker(tool_name: str) -> CircuitBreaker:\n    if tool_name not in _breakers:\n        _breakers[tool_name] = CircuitBreaker(name=tool_name)\n    return _breakers[tool_name]\n\ndef run_with_circuit_breaker(tool_name: str, fn: Callable[[], Any]) -> Any:\n    breaker = get_breaker(tool_name)\n    if breaker.is_open:\n        raise RuntimeError(f'Circuit open for {tool_name}: too many failures')\n    try:\n        result = fn()\n        breaker.record_success()\n        return result\n    except Exception as exc:\n        breaker.record_failure()\n        raise\n"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "marks": [
                  {
                    "type": "bold"
                  }
                ],
                "text": "Design note:"
              },
              {
                "type": "text",
                "text": " Circuit breakers work at the tool level, not the step level. A broken search API should open its breaker and be substituted \u2014 it should not block unrelated file-read steps."
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Observability: Logging and Metrics"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Detection without instrumentation is a black box. Every "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "DetectedError"
          },
          {
            "type": "text",
            "text": " should be logged with enough context to replay the failure: the step id, the raw output excerpt, and the recovery action taken."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import logging\nfrom collections import Counter\n\nlogger = logging.getLogger('agent.error_detection')\n\n@dataclass\nclass ErrorMetrics:\n    counts: Counter = field(default_factory=Counter)\n\n    def record(self, error: DetectedError) -> None:\n        self.counts[f'{error.layer}:{error.error_type}'] += 1\n\n    def report(self) -> dict:\n        return dict(self.counts.most_common())\n\n_metrics = ErrorMetrics()\n\ndef detect_and_log(\n    client, output, raw_output, objective, criteria,\n    step_id: str = 'unknown',\n) -> list[DetectedError]:\n    errors = detect_errors(client, output, raw_output, objective, criteria)\n    for err in errors:\n        _metrics.record(err)\n        logger.warning(\n            'Error detected',\n            extra={\n                'step_id': step_id,\n                'layer': err.layer,\n                'error_type': err.error_type,\n                'message': err.message,\n                'recoverable': err.recoverable,\n            }\n        )\n    return errors\n\n# At end of run:\n# print(_metrics.report())\n# {'semantic:incorrect_answer': 3, 'schema:parse_failure': 1}\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Aggregated metrics reveal systemic problems: a high "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "semantic:incorrect_answer"
          },
          {
            "type": "text",
            "text": " rate points to prompt drift; a high "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "schema:parse_failure"
          },
          {
            "type": "text",
            "text": " rate suggests the output format instructions need tightening."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Over-using semantic detection: "
                  },
                  {
                    "type": "text",
                    "text": "LLM-based checks cost tokens and latency. Reserve them for outputs that pass structural checks but are plausibly wrong \u2014 not as a default first layer."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Silent swallowing: "
                  },
                  {
                    "type": "text",
                    "text": "returning "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "None"
                  },
                  {
                    "type": "text",
                    "text": " or an empty dict on error without logging makes post-mortem debugging nearly impossible."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Infinite retry on semantic errors: "
                  },
                  {
                    "type": "text",
                    "text": "semantic errors often stem from ambiguous instructions, not transient failures \u2014 retrying the same prompt rarely helps."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Coupling detection to correction: "
                  },
                  {
                    "type": "text",
                    "text": "keep detection logic separate from recovery. Mixing them makes each harder to test and harder to evolve independently."
                  }
                ]
              }
            ]
          }
        ]
