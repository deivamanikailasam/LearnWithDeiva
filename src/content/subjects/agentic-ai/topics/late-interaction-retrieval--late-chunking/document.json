      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Full Pipeline: Late Chunking + FAISS + LangChain"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The following end-to-end snippet wraps the late chunking encoder behind a LangChain-compatible custom embedding class, making it usable with any LangChain retriever or chain without further changes."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_core.embeddings import Embeddings\nfrom langchain_community.vectorstores import FAISS\nfrom langchain_core.documents import Document\nfrom typing import List\n\nclass LateChunkingEmbeddings(Embeddings):\n    \"\"\"LangChain Embeddings wrapper around the Jina late-chunking API.\"\"\"\n\n    def embed_documents(self, texts: List[str]) -> List[List[float]]:\n        # For doc indexing \u2014 each \"text\" is a chunk; for late chunking we treat\n        # each as an independent short passage (context already baked in at index time)\n        results = []\n        for text in texts:\n            data = jina_late_chunking_embed(text)\n            # If one sentence, return its vector; otherwise mean-pool all\n            if len(data) == 1:\n                results.append(data[0][\"embedding\"])\n            else:\n                import numpy as np\n                pooled = np.mean([d[\"embedding\"] for d in data], axis=0).tolist()\n                results.append(pooled)\n        return results\n\n    def embed_query(self, text: str) -> List[float]:\n        import httpx, os\n        response = httpx.post(\n            \"https://api.jina.ai/v1/embeddings\",\n            headers={\"Authorization\": f\"Bearer {os.environ['JINA_API_KEY']}\"},\n            json={\"model\": \"jina-embeddings-v3\", \"input\": [text], \"task\": \"retrieval.query\"},\n        )\n        return response.json()[\"data\"][0][\"embedding\"]\n\n# Build FAISS index with late-chunked embeddings\nembedding_model = LateChunkingEmbeddings()\ndocs = [Document(page_content=chunk) for chunk in chunks]\nvectorstore = FAISS.from_documents(docs, embedding_model)\nretriever = vectorstore.as_retriever(search_kwargs={\"k\": 5})\n"
          }
        ]
