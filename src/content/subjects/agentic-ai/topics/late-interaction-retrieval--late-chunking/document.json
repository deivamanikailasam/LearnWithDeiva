        "content": [
          {
            "type": "text",
            "text": "import concurrent.futures\nfrom pathlib import Path\nfrom langchain_community.vectorstores import FAISS\nfrom langchain_core.documents import Document\n\ndef process_document(file_path: str) -> list[tuple[str, list[float], dict]]:\n    \"\"\"Returns list of (chunk_text, embedding, metadata) for one document.\"\"\"\n    text = Path(file_path).read_text(encoding=\"utf-8\")\n    splitter = RecursiveCharacterTextSplitter(chunk_size=512, chunk_overlap=50)\n    chunks = splitter.split_text(text)\n    boundaries = get_chunk_boundaries(text, chunks)\n    embeddings = late_chunking_embed(text, boundaries)\n    return [\n        (chunk, emb, {\"source\": file_path, \"chunk_idx\": i})\n        for i, (chunk, emb) in enumerate(zip(chunks, embeddings))\n    ]\n\ndoc_paths = list(Path(\"./documents\").glob(\"**/*.txt\"))\n\nall_texts, all_embeds, all_metas = [], [], []\nwith concurrent.futures.ThreadPoolExecutor(max_workers=4) as pool:\n    for results in pool.map(process_document, doc_paths):\n        for text, emb, meta in results:\n            all_texts.append(text)\n            all_embeds.append(emb)\n            all_metas.append(meta)\n\n# Batch-insert into FAISS\nvectorstore = FAISS.from_embeddings(\n    text_embeddings=list(zip(all_texts, all_embeds)),\n    embedding=None,\n    metadatas=all_metas\n)\nvectorstore.save_local(\"late_chunked_index\")\nprint(f\"Indexed {len(all_texts)} chunks from {len(doc_paths)} documents\")\n"
          }
