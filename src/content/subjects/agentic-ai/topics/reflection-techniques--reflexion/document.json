      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Core Data Structures"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass, field\nfrom typing import Any\n\n@dataclass\nclass TrajectoryStep:\n    action: str\n    observation: str\n    reward: float = 0.0\n\n@dataclass\nclass Trial:\n    task: str\n    steps: list[TrajectoryStep] = field(default_factory=list)\n    final_reward: float = 0.0\n    reflection: str = \"\"   # written after the trial completes\n\n    @property\n    def success(self) -> bool:\n        return self.final_reward >= 1.0\n\n    def trajectory_text(self) -> str:\n        lines = []\n        for i, step in enumerate(self.steps):\n            lines.append(f\"Step {i+1}: Action: {step.action}\")\n            lines.append(f\"         Observation: {step.observation}\")\n        return \"\\n\".join(lines)\n\n\n@dataclass\nclass EpisodicMemory:\n    reflections: list[str] = field(default_factory=list)\n    max_entries: int = 5   # sliding window \u2014 keep most recent\n\n    def add(self, reflection: str) -> None:\n        self.reflections.append(reflection)\n        if len(self.reflections) > self.max_entries:\n            self.reflections = self.reflections[-self.max_entries:]\n\n    def context(self) -> str:\n        if not self.reflections:\n            return \"\"\n        lines = [\"Lessons from previous attempts:\"]\n        for i, r in enumerate(self.reflections):\n            lines.append(f\"  Attempt {i+1}: {r}\")\n        return \"\\n\".join(lines)\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "The Actor"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The Actor generates the next action given the current task state and the episodic memory context. When memory is empty (first trial), it acts purely from the task description. On subsequent trials, it reads previous reflections as standing instructions \u2014 a form of in-context reinforcement."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\n\nACTOR_PROMPT = \"\"\"You are an agent solving a task step by step.\n\nTask: {task}\n\n{memory_context}\n\nCurrent trajectory so far:\n{trajectory}\n\nWhat is your next action? Be specific and concrete.\nIf the task is complete, respond with: DONE: <final answer>\n\"\"\"\n\ndef actor_step(\n    client: anthropic.Anthropic,\n    task: str,\n    memory: EpisodicMemory,\n    trial: Trial,\n) -> str:\n    traj = trial.trajectory_text() or \"  (no steps yet)\"\n    prompt = ACTOR_PROMPT.format(\n        task=task,\n        memory_context=memory.context(),\n        trajectory=traj,\n    )\n    resp = client.messages.create(\n        model=\"claude-sonnet-4-6\",\n        max_tokens=256,\n        messages=[{\"role\":\"user\",\"content\":prompt}],\n    )\n    return resp.content[0].text.strip()\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "The Evaluator"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The Evaluator scores a completed trial trajectory. For tasks with an external oracle (unit tests, database queries, API calls), the reward is binary: pass/fail. For open-ended tasks, the Evaluator LLM estimates quality on a 0\u20131 scale."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "EVALUATOR_PROMPT = \"\"\"Evaluate whether an agent solved the following task.\n\nTask: {task}\nSuccess criteria: {criteria}\n\nAgent trajectory:\n{trajectory}\n\nFinal answer (if any): {final_answer}\n\nScore the attempt:\n  1.0 = fully solved\n  0.5 = partially solved\n  0.0 = failed\n\nRespond with JSON: {{\"reward\": float, \"reason\": str}}\n\"\"\"\n\ndef evaluate_trial(\n    client: anthropic.Anthropic,\n    task: str,\n    criteria: list[str],\n    trial: Trial,\n    final_answer: str = \"\",\n) -> float:\n    import json, re\n    prompt = EVALUATOR_PROMPT.format(\n        task=task,\n        criteria=\"\\n\".join(f\"  - {c}\" for c in criteria),\n        trajectory=trial.trajectory_text(),\n        final_answer=final_answer,\n    )\n    resp = client.messages.create(\n        model=\"claude-sonnet-4-6\",\n        max_tokens=256,\n        messages=[{\"role\":\"user\",\"content\":prompt}],\n    )\n    raw = resp.content[0].text\n    m = re.search(r\"\\{.*\\}\", raw, re.DOTALL)\n    data = json.loads(m.group()) if m else {}\n    return float(data.get(\"reward\", 0.0))\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "The Self-Reflector"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When a trial fails (reward < 1.0), the Self-Reflector analyses the trajectory and writes a concise verbal lesson that explains what went wrong and how to avoid the same mistake. This lesson is added to episodic memory and injected into the next trial."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "REFLECT_PROMPT = \"\"\"An agent failed to solve a task. Analyse the failure and write a\nlesson for the next attempt.\n\nTask: {task}\nReward: {reward:.2f} (1.0 = success, 0.0 = failure)\n\nFailed trajectory:\n{trajectory}\n\nWrite a 2-3 sentence lesson in the second person (\"You should...\", \"Avoid...\",\n\"Next time...\"). Be specific about what went wrong and what to do differently.\nDo not repeat the task description. Focus on the mistake, not the goal.\n\"\"\"\n\ndef self_reflect(\n    client: anthropic.Anthropic,\n    task: str,\n    trial: Trial,\n) -> str:\n    prompt = REFLECT_PROMPT.format(\n        task=task,\n        reward=trial.final_reward,\n        trajectory=trial.trajectory_text(),\n    )\n    resp = client.messages.create(\n        model=\"claude-sonnet-4-6\",\n        max_tokens=256,\n        messages=[{\"role\":\"user\",\"content\":prompt}],\n    )\n    return resp.content[0].text.strip()\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "The Full Reflexion Loop"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The outer loop runs trials until the task is solved or the maximum trial count is reached. After each failed trial, the Self-Reflector writes a lesson into episodic memory. The next trial's Actor reads that memory as context."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def reflexion(\n    client: anthropic.Anthropic,\n    task: str,\n    criteria: list[str],\n    environment_fn,      # callable(action: str) -> observation: str\n    max_trials: int = 5,\n    max_steps_per_trial: int = 10,\n) -> Trial:\n    memory = EpisodicMemory()\n    best_trial: Trial | None = None\n\n    for trial_num in range(max_trials):\n        trial = Trial(task=task)\n        final_answer = \"\"\n\n        for _ in range(max_steps_per_trial):\n            action = actor_step(client, task, memory, trial)\n            if action.startswith(\"DONE:\"):\n                final_answer = action[5:].strip()\n                break\n            observation = environment_fn(action)\n            trial.steps.append(TrajectoryStep(\n                action=action, observation=observation\n            ))\n\n        trial.final_reward = evaluate_trial(\n            client, task, criteria, trial, final_answer\n        )\n        if best_trial is None or trial.final_reward > best_trial.final_reward:\n            best_trial = trial\n\n        if trial.success:\n            break\n\n        reflection = self_reflect(client, task, trial)\n        trial.reflection = reflection\n        memory.add(reflection)\n\n    return best_trial\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The loop returns the best trial (highest reward) rather than the last trial, since later trials that miss the success threshold may still be worse than an earlier partial success. best_trial tracks this across all attempts."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
