                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Reflexion improves agent performance across trials by storing verbal lessons in episodic memory \u2014 no weight updates or fine-tuning required."
                  }
                ]
              }
            ]
          },
