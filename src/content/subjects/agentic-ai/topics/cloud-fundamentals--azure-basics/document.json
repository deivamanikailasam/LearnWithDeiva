      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "bash"
        },
        "content": [
          {
            "type": "text",
            "text": "# Container App accesses Key Vault secret without stored password\n# Assign \"Key Vault Secrets User\" role to app's managed identity\n# Reference secret in env as Key Vault URI"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Azure OpenAI call (OpenAI SDK compatible)"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from openai import AzureOpenAI\n\nclient = AzureOpenAI(\n    azure_endpoint=\"https://myresource.openai.azure.com/\",\n    api_key=os.environ[\"AZURE_OPENAI_KEY\"],\n    api_version=\"2024-02-15-preview\",\n)\nresponse = client.chat.completions.create(\n    model=\"gpt-4o-deployment-name\",\n    messages=[{\"role\": \"user\", \"content\": \"Summarize ticket #991\"}],\n)"
          }
        ]
      },
