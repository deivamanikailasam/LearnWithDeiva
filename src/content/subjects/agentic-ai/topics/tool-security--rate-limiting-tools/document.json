            "type": "text",
            "text": "Testing Rate Limits"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import pytest\nfrom mytools.ratelimit import TokenBucket, SessionBudget\n\ndef test_bucket_allows_burst():\n    bucket = TokenBucket(capacity=5, refill_rate=1.0)\n    for _ in range(5):\n        allowed, _ = bucket.consume()\n        assert allowed\n\ndef test_bucket_blocks_after_burst():\n    bucket = TokenBucket(capacity=3, refill_rate=1.0)\n    for _ in range(3):\n        bucket.consume()\n    allowed, retry_after = bucket.consume()\n    assert not allowed\n    assert retry_after > 0\n\ndef test_session_budget_total_calls():\n    budget = SessionBudget(max_total_calls=3, max_write_calls=10, max_cost_usd=100)\n    for _ in range(3):\n        assert budget.check_and_record(\"get_customer\") is None\n    err = budget.check_and_record(\"get_customer\")\n    assert err is not None\n    assert err[\"error\"] == \"RATE_LIMITED\"\n\ndef test_session_budget_write_limit():\n    budget = SessionBudget(max_total_calls=100, max_write_calls=2, max_cost_usd=100)\n    assert budget.check_and_record(\"create_refund\") is None\n    assert budget.check_and_record(\"create_refund\") is None\n    err = budget.check_and_record(\"create_refund\")\n    assert err is not None\n    assert \"write budget\" in err[\"message\"]\n\ndef test_session_budget_read_not_counted_as_write():\n    budget = SessionBudget(max_total_calls=100, max_write_calls=1, max_cost_usd=100)\n    # reads do not consume write budget\n    for _ in range(10):\n        assert budget.check_and_record(\"get_customer\") is None\n    # first write OK, second blocked\n    assert budget.check_and_record(\"create_refund\") is None\n    assert budget.check_and_record(\"create_refund\") is not None"
          }
        ]
      },
