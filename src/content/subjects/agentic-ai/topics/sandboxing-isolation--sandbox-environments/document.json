          {
            "type": "text",
            "text": "# Stateful session using a persistent Docker container\nimport subprocess\nimport uuid\n\nclass StatefulSandbox:\n    def __init__(self, image: str = \"python:3.12-slim\"):\n        self.container_id = None\n        self.image = image\n\n    def start(self):\n        result = subprocess.run(\n            [\"docker\", \"run\", \"-d\", \"--rm\",\n             \"--network\", \"none\", \"--memory\", \"256m\",\n             \"--pids-limit\", \"64\", \"--read-only\",\n             \"--tmpfs\", \"/tmp:size=64m\",\n             self.image, \"sleep\", \"3600\"],\n            capture_output=True, text=True\n        )\n        self.container_id = result.stdout.strip()\n\n    def run(self, code: str, timeout: int = 20) -> dict:\n        if not self.container_id:\n            raise RuntimeError(\"Sandbox not started\")\n        proc = subprocess.run(\n            [\"docker\", \"exec\", self.container_id,\n             \"python3\", \"-c\", code],\n            capture_output=True, text=True, timeout=timeout\n        )\n        return {\"stdout\": proc.stdout[:8192],\n                \"stderr\": proc.stderr[:2048],\n                \"error\": None if proc.returncode == 0 else proc.stderr[:1024]}\n\n    def stop(self):\n        if self.container_id:\n            subprocess.run([\"docker\", \"kill\", self.container_id], capture_output=True)\n            self.container_id = None\n\n    def __enter__(self):\n        self.start(); return self\n\n    def __exit__(self, *_):\n        self.stop()\n\n# Usage\nwith StatefulSandbox() as sbx:\n    sbx.run(\"import numpy as np; data = np.arange(1000)\")\n    result = sbx.run(\"print(data.mean(), data.std())\")\n    print(result[\"stdout\"])"
          }
