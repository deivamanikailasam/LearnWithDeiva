      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Recursive Tree Construction"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Build the tree top-down: start from the root goal, classify each node as compound or primitive, and decompose compound nodes into children. Recurse until all leaves are primitive or a depth limit is hit:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic, json, re\nfrom dataclasses import dataclass, field\n\nclient = anthropic.Anthropic()\n\n@dataclass\nclass TaskNode:\n    id: str\n    title: str\n    description: str\n    level: int = 0\n    children: list[\"TaskNode\"] = field(default_factory=list)\n    is_primitive: bool = False   # True when no further decomposition needed\n    result: str | None = None\n\nCLASSIFY_PROMPT = \"\"\"Is this task directly executable by an AI agent in a single LLM call\n(with access to common tools like web search, code execution, file I/O)?\n\nTask: {title} \u2014 {description}\n\nReply with PRIMITIVE if yes, COMPOUND if it needs to be broken into subtasks.\nOne word only.\"\"\"\n\nDECOMPOSE_PROMPT = \"\"\"Break this task into 2-5 concrete subtasks.\n\nParent task: {title}\nDescription: {description}\nContext: This is level {level} in a decomposition tree.\n\nReturn ONLY a JSON array:\n[{{\"id\": \"{parent_id}.1\", \"title\": \"...\", \"description\": \"...\", \"is_primitive\": true/false}}, ...]\nSet is_primitive=true if the subtask can be executed directly.\nNo markdown.\"\"\"\n\ndef classify_task(node: TaskNode) -> bool:\n    resp = client.messages.create(\n        model=\"claude-sonnet-4-6\",\n        max_tokens=10,\n        messages=[{\"role\": \"user\", \"content\": CLASSIFY_PROMPT.format(\n            title=node.title, description=node.description,\n        )}],\n    ).content[0].text.strip().upper()\n    return \"PRIMITIVE\" in resp\n\ndef decompose_node(node: TaskNode) -> list[TaskNode]:\n    raw = client.messages.create(\n        model=\"claude-sonnet-4-6\",\n        max_tokens=2048,\n        messages=[{\"role\": \"user\", \"content\": DECOMPOSE_PROMPT.format(\n            title=node.title,\n            description=node.description,\n            level=node.level,\n            parent_id=node.id,\n        )}],\n    ).content[0].text\n    clean = re.sub(r\"^```[a-z]*\\n|```$\", \"\", raw.strip(), flags=re.M).strip()\n    data = json.loads(clean)\n    return [TaskNode(\n        id=d[\"id\"],\n        title=d[\"title\"],\n        description=d[\"description\"],\n        level=node.level + 1,\n        is_primitive=d.get(\"is_primitive\", False),\n    ) for d in data]"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Building the Full Tree"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The tree-building loop recursively classifies and decomposes each node. A max_depth parameter provides a hard stop to prevent unbounded recursion on ambiguous tasks:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def build_tree(\n    root: TaskNode,\n    max_depth: int = 3,\n) -> TaskNode:\n    \"\"\"\n    Recursively decompose the tree until all nodes are primitive\n    or the max depth is reached.\n    \"\"\"\n    if root.level >= max_depth:\n        root.is_primitive = True  # treat as leaf at depth limit\n        return root\n\n    # Check classification (or trust the flag from parent decomposition)\n    if not root.is_primitive:\n        root.is_primitive = classify_task(root)\n\n    if root.is_primitive:\n        return root  # leaf node \u2014 stop recursing\n\n    # Compound node: decompose and recurse into children\n    root.children = decompose_node(root)\n    for child in root.children:\n        build_tree(child, max_depth)\n    return root\n\ndef print_tree(node: TaskNode, indent: int = 0) -> None:\n    kind = \"leaf\" if node.is_primitive else \"compound\"\n    print(\"  \" * indent + f\"[{node.id}] ({kind}) {node.title}\")\n    for child in node.children:\n        print_tree(child, indent + 1)\n\n# Build the tree for a complex goal\nroot = TaskNode(\n    id=\"root\",\n    title=\"Build and deploy a web app\",\n    description=(\n        \"Create a REST API backend (Python/FastAPI), a React frontend, \"\n        \"containerise with Docker, and deploy to a cloud VM.\"\n    ),\n)\ntree = build_tree(root, max_depth=3)\nprint_tree(tree)"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Level-Aware Execution with Ancestor Context"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Each leaf node receives its full ancestor path as context. This tells the executor why the task exists and how it fits into the larger goal, which improves output quality:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def collect_leaves(node: TaskNode) -> list[TaskNode]:\n    \"\"\"Return all primitive (leaf) nodes in DFS order.\"\"\"\n    if node.is_primitive:\n        return [node]\n    leaves = []\n    for child in node.children:\n        leaves.extend(collect_leaves(child))\n    return leaves\n\ndef ancestors_context(node: TaskNode, tree: TaskNode) -> str:\n    \"\"\"Walk up the tree to collect titles of ancestor nodes for context.\"\"\"\n    # Simple BFS to find path from root to node\n    def find_path(current, target_id, path):\n        if current.id == target_id:\n            return path + [current]\n        for child in current.children:\n            result = find_path(child, target_id, path + [current])\n            if result:\n                return result\n        return None\n    path = find_path(tree, node.id, [])\n    if not path:\n        return \"\"\n    return \" -> \".join(n.title for n in path)\n\nEXEC_PROMPT = \"\"\"You are executing one atomic subtask as part of a larger plan.\n\nGoal hierarchy: {hierarchy}\nYour task: {title}\nDescription: {description}\n\nExecute this task. Return your output concisely.\"\"\"\n\ndef execute_tree(tree: TaskNode) -> None:\n    \"\"\"Execute all leaf nodes sequentially (parallelise as needed).\"\"\"\n    leaves = collect_leaves(tree)\n    for leaf in leaves:\n        hierarchy = ancestors_context(leaf, tree)\n        result = client.messages.create(\n            model=\"claude-sonnet-4-6\",\n            max_tokens=2048,\n            messages=[{\"role\": \"user\", \"content\": EXEC_PROMPT.format(\n                hierarchy=hierarchy,\n                title=leaf.title,\n                description=leaf.description,\n            )}],\n        ).content[0].text\n        leaf.result = result\n        print(f\"[{leaf.id}] done: {result[:80]}\")"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Bottom-Up Result Aggregation"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "After all leaves are executed, aggregate results bottom-up: each internal node summarises its children's outputs into a concise status, propagating up to the root for a final summary of the entire task:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def aggregate_results(node: TaskNode) -> str:\n    \"\"\"\n    Bottom-up aggregation: combine children results into a\n    summary for the parent node.\n    \"\"\"\n    if node.is_primitive:\n        return node.result or \"\"\n\n    child_summaries = []\n    for child in node.children:\n        child_result = aggregate_results(child)\n        child_summaries.append(f\"[{child.id}] {child.title}: {child_result[:200]}\")\n\n    aggregate_prompt = (\n        f\"Summarise the following completed subtasks into a brief status for the parent task.\\n\\n\"\n        f\"Parent task: {node.title}\\n\\n\"\n        + \"\\n\".join(child_summaries)\n    )\n    summary = client.messages.create(\n        model=\"claude-sonnet-4-6\",\n        max_tokens=512,\n        messages=[{\"role\": \"user\", \"content\": aggregate_prompt}],\n    ).content[0].text\n    node.result = summary\n    return summary\n\n# After execute_tree(tree), aggregate bottom-up\n# execute_tree(tree)\n# final_summary = aggregate_results(tree)\n# print(\"Final summary:\", final_summary)"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Adaptive Depth: Decompose Only When Needed"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Full recursion to a fixed depth wastes API calls on simple sub-tasks. An adaptive strategy estimates the complexity of each node and stops decomposing when a node is simple enough to execute directly:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def depth_limited_decompose(\n    goal: str,\n    max_depth: int = 2,\n    complexity_threshold: int = 3,  # min subtasks to justify deeper decomposition\n) -> TaskNode:\n    \"\"\"\n    Decompose only when needed: stop if the task is simple enough\n    to handle in one LLM call, even if max_depth not reached.\n    \"\"\"\n    COMPLEXITY_PROMPT = (\n        \"How many distinct steps does this task require? \"\n        \"Reply with a single integer (1-10).\\n\\nTask: {task}\"\n    )\n    def estimated_steps(title: str, desc: str) -> int:\n        resp = client.messages.create(\n            model=\"claude-sonnet-4-6\",\n            max_tokens=5,\n            messages=[{\"role\": \"user\", \"content\": COMPLEXITY_PROMPT.format(\n                task=f\"{title}: {desc}\",\n            )}],\n        ).content[0].text.strip()\n        try:\n            return int(re.search(r\"\\d+\", resp).group())\n        except Exception:\n            return 5\n\n    root = TaskNode(id=\"root\", title=goal, description=goal)\n\n    def recurse(node: TaskNode) -> None:\n        if node.level >= max_depth:\n            node.is_primitive = True\n            return\n        steps = estimated_steps(node.title, node.description)\n        if steps < complexity_threshold:\n            node.is_primitive = True  # simple enough; handle in one call\n            return\n        node.children = decompose_node(node)\n        for child in node.children:\n            recurse(child)\n\n    recurse(root)\n    return root\n\ntree = depth_limited_decompose(\"Write a technical overview of WebAssembly\", max_depth=2)\nprint_tree(tree)"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Hierarchical vs Flat Decomposition"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Choose hierarchical when: "
                  },
                  {
                    "type": "text",
                    "text": "the task has natural sub-goal structure that itself requires planning (e.g. 'build a product' decomposes into modules, each into files, each into functions). The nested structure makes the plan readable and enables level-aware context."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Choose flat (DAG) when: "
                  },
                  {
                    "type": "text",
                    "text": "all subtasks are roughly at the same level of abstraction with clear dependencies between them. Flat decomposition is simpler to schedule and execute."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Mixing both: "
                  },
                  {
                    "type": "text",
                    "text": "in practice, use hierarchical for the top levels (goal \u2192 tasks \u2192 subtasks) and switch to a flat dependency list at the leaf level where explicit ordering matters more than nesting."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Decomposing too deep: "
                  },
                  {
                    "type": "text",
                    "text": "unnecessary nesting adds latency and API calls without improving output quality. Set max_depth=2 as the default and increase only when leaf tasks remain too broad."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Inconsistent granularity: "
                  },
                  {
                    "type": "text",
                    "text": "siblings at the same level should be similar in complexity. A mix of \"Write one function\" and \"Build the whole auth system\" at the same level leads to uneven execution."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Losing goal context at leaves: "
                  },
                  {
                    "type": "text",
                    "text": "a leaf executor that only sees its immediate task without the ancestor hierarchy produces outputs that don't fit the larger plan. Always pass the ancestor chain."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "No aggregation step: "
                  },
                  {
                    "type": "text",
                    "text": "without bottom-up aggregation, the final result is a collection of independent leaf outputs with no narrative. Always aggregate up to the root."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Model the task as a tree: "
                  },
                  {
                    "type": "text",
                    "text": "compound nodes decompose into children; primitive leaf nodes execute directly. The tree terminates when all nodes are primitive or max_depth is reached."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Pass ancestor context to leaves: "
                  },
                  {
                    "type": "text",
                    "text": "the full path from root to leaf tells each executor why the task exists, improving coherence of outputs."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
