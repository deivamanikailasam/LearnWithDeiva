      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "FeedbackRecord Data Model"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass, field\nfrom enum import StrEnum\nfrom typing import Any\nfrom datetime import datetime, UTC\nimport uuid\n\nclass SignalType(StrEnum):\n    THUMBS = \"thumbs\"    # value: True (up) | False (down)\n    STAR   = \"star\"      # value: 1\u20135 int\n    LIKERT = \"likert\"    # value: 1\u20135 int per dimension (stored as dict)\n    LABEL  = \"label\"     # value: one of a fixed label set\n    TEXT   = \"text\"      # value: free-form string\n\nclass FeedbackDimension(StrEnum):\n    ACCURACY    = \"accuracy\"\n    HELPFULNESS = \"helpfulness\"\n    SAFETY      = \"safety\"\n    COMPLETENESS = \"completeness\"\n    TONE        = \"tone\"\n\n@dataclass\nclass FeedbackRecord:\n    id:          str = field(default_factory=lambda: str(uuid.uuid4()))\n    session_id:  str = \"\"\n    turn_index:  int = 0\n    signal_type: SignalType = SignalType.THUMBS\n    value:       Any = None\n    dimension:   FeedbackDimension | None = None\n    comment:     str | None = None\n    created_at:  str = field(default_factory=lambda: datetime.now(UTC).isoformat())\n    actor_id:    str | None = None   # anonymised user ID if available\n    # Denormalised for query convenience\n    agent_model:  str = \"\"\n    prompt_hash:  str = \"\"           # SHA-256[:16] of the input prompt\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Validation"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "VALID_LABELS = {\"wrong\", \"incomplete\", \"harmful\", \"off-topic\", \"format-error\", \"hallucination\"}\n\ndef validate_feedback(record: FeedbackRecord) -> list[str]:\n    errors = []\n    t = record.signal_type\n\n    if t == SignalType.THUMBS:\n        if not isinstance(record.value, bool):\n            errors.append(\"thumbs value must be bool\")\n\n    elif t == SignalType.STAR:\n        if not isinstance(record.value, int) or not (1 <= record.value <= 5):\n            errors.append(\"star value must be int 1\u20135\")\n\n    elif t == SignalType.LIKERT:\n        if not isinstance(record.value, dict):\n            errors.append(\"likert value must be dict of dimension \u2192 int\")\n        else:\n            for dim, score in record.value.items():\n                if not isinstance(score, int) or not (1 <= score <= 5):\n                    errors.append(f\"likert[{dim}] must be int 1-5\")\n\n    elif t == SignalType.LABEL:\n        if record.value not in VALID_LABELS:\n            errors.append(f\"label must be one of {VALID_LABELS}\")\n\n    elif t == SignalType.TEXT:\n        if not isinstance(record.value, str) or not record.value.strip():\n            errors.append(\"text value must be non-empty string\")\n\n    return errors\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Storage"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Feedback records are append-only. Never delete or mutate them \u2014 historical rating distributions are the basis for detecting quality regressions. Two simple options:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import json\nfrom pathlib import Path\nimport sqlite3\n\n# Option A: JSONL file (dev/small scale)\nFEEDBACK_LOG = Path(\"feedback.jsonl\")\n\ndef save_feedback_jsonl(record: FeedbackRecord):\n    import dataclasses\n    with FEEDBACK_LOG.open(\"a\") as f:\n        f.write(json.dumps(dataclasses.asdict(record)) + \"\\n\")\n\n# Option B: SQLite (local, queryable)\ndef init_db(path: str = \"feedback.db\") -> sqlite3.Connection:\n    conn = sqlite3.connect(path)\n    conn.execute(\"\"\"\n        CREATE TABLE IF NOT EXISTS feedback (\n            id           TEXT PRIMARY KEY,\n            session_id   TEXT NOT NULL,\n            turn_index   INTEGER NOT NULL,\n            signal_type  TEXT NOT NULL,\n            value        TEXT NOT NULL,   -- JSON-encoded\n            dimension    TEXT,\n            comment      TEXT,\n            created_at   TEXT NOT NULL,\n            actor_id     TEXT,\n            agent_model  TEXT,\n            prompt_hash  TEXT\n        )\n    \"\"\")\n    conn.commit()\n    return conn\n\ndef save_feedback_sqlite(conn: sqlite3.Connection, record: FeedbackRecord):\n    conn.execute(\n        \"\"\"INSERT INTO feedback VALUES (?,?,?,?,?,?,?,?,?,?,?)\"\"\",\n        (\n            record.id, record.session_id, record.turn_index,\n            record.signal_type, json.dumps(record.value),\n            record.dimension, record.comment, record.created_at,\n            record.actor_id, record.agent_model, record.prompt_hash,\n        )\n    )\n    conn.commit()\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "FastAPI Feedback Endpoint"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from fastapi import FastAPI, HTTPException\nfrom pydantic import BaseModel\nfrom typing import Any, Optional\n\napp = FastAPI()\nconn = init_db()\n\nclass FeedbackBody(BaseModel):\n    session_id:  str\n    turn_index:  int\n    signal_type: str\n    value:       Any\n    dimension:   Optional[str] = None\n    comment:     Optional[str] = None\n    actor_id:    Optional[str] = None\n\n@app.post(\"/feedback\", status_code=201)\ndef submit_feedback(body: FeedbackBody):\n    record = FeedbackRecord(\n        session_id=body.session_id,\n        turn_index=body.turn_index,\n        signal_type=SignalType(body.signal_type),\n        value=body.value,\n        dimension=FeedbackDimension(body.dimension) if body.dimension else None,\n        comment=body.comment,\n        actor_id=body.actor_id,\n    )\n    errors = validate_feedback(record)\n    if errors:\n        raise HTTPException(400, {\"errors\": errors})\n\n    save_feedback_sqlite(conn, record)\n    return {\"id\": record.id, \"status\": \"recorded\"}\n\n@app.get(\"/feedback/summary\")\ndef feedback_summary(session_id: str | None = None):\n    clause = \"WHERE session_id = ?\" if session_id else \"\"\n    args = (session_id,) if session_id else ()\n    rows = conn.execute(\n        f\"SELECT signal_type, value, COUNT(*) FROM feedback {clause} GROUP BY signal_type, value\",\n        args,\n    ).fetchall()\n    return [{\"signal_type\": r[0], \"value\": json.loads(r[1]), \"count\": r[2]} for r in rows]\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Inline Prompt Hashing"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Storing the hash of the input prompt alongside each feedback record lets you group ratings by the prompt that triggered them \u2014 essential for identifying which types of request the agent struggles with:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import hashlib\n\ndef hash_prompt(messages: list[dict]) -> str:\n    \"\"\"Stable hash of the user-visible prompt for grouping feedback.\"\"\"\n    # Use only the user turns, not the system prompt (which rarely changes)\n    user_content = \" \".join(\n        str(m.get(\"content\", \"\"))\n        for m in messages\n        if m.get(\"role\") == \"user\"\n    )\n    return hashlib.sha256(user_content.encode()).hexdigest()[:16]\n\n# Attach to FeedbackRecord before saving\nrecord.prompt_hash = hash_prompt(messages)\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Metrics and Alerting"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def compute_thumbs_ratio(conn: sqlite3.Connection, window_hours: int = 24) -> float:\n    \"\"\"\n    Return the fraction of thumbs-up ratings in the last window_hours.\n    A drop below a threshold signals a quality regression.\n    \"\"\"\n    from datetime import timedelta\n    cutoff = (datetime.now(UTC) - timedelta(hours=window_hours)).isoformat()\n    rows = conn.execute(\n        \"\"\"\n        SELECT value, COUNT(*) FROM feedback\n        WHERE signal_type = 'thumbs' AND created_at >= ?\n        GROUP BY value\n        \"\"\",\n        (cutoff,),\n    ).fetchall()\n    counts = {json.loads(r[0]): r[1] for r in rows}\n    total = sum(counts.values())\n    if total == 0:\n        return 1.0   # no data \u2014 no regression detected\n    return counts.get(True, 0) / total\n\nTHUMBS_UP_ALERT_THRESHOLD = 0.70\n\ndef check_quality_regression(conn: sqlite3.Connection):\n    ratio = compute_thumbs_ratio(conn)\n    if ratio < THUMBS_UP_ALERT_THRESHOLD:\n        print(f\"ALERT: thumbs-up ratio {ratio:.1%} is below {THUMBS_UP_ALERT_THRESHOLD:.0%}\")\n        # send to PagerDuty / Slack / monitoring system\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Reducing Survey Fatigue"
