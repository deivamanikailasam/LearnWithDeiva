        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Binary thumbs + optional comment is the highest-ROI combination for most agents: low collection friction for the common case, rich signal for the cases that matter enough to comment on."
              }
            ]
          }
        ]
