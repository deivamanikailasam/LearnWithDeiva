{
  "format": "tiptap/v1",
  "updatedAt": "2026-06-22T17:21:36.457Z",
  "doc": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Agents store conversation history, tool registries, retrieved documents, and execution traces in Python collections. Choosing the right structure \u2014 list, tuple, set, or dict \u2014 affects ordering guarantees, lookup speed, deduplication, and whether state can be accidentally mutated across steps."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "What it is"
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Python built-in collections: list, dict, set, and tuple compared"
        }
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Collections are container types that hold multiple values. The four core built-ins for agent code are:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "list",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 ordered, mutable sequence"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "tuple",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 ordered, immutable sequence"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "set",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 unordered collection of unique hashable items"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "dict",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 mapping from hashable keys to arbitrary values"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Why it matters"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Message history is typically a "
          },
          {
            "type": "text",
            "text": "list",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " of "
          },
          {
            "type": "text",
            "text": "dict",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " objects. Tool allowlists are "
          },
          {
            "type": "text",
            "text": "set",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " for O(1) membership. Fixed routing keys may use "
          },
          {
            "type": "text",
            "text": "tuple",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". Wrong structure choice leads to duplicate tool calls, lost ordering, or unhashable-key errors."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Benefits"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Lists",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 preserve order for conversation turns and plan steps"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Dicts",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 fast key lookup for configs, tool results keyed by call ID"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Sets",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 deduplicate URLs, document IDs, visited nodes in search agents"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Tuples",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 lightweight immutable records; hashable when all elements are hashable"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Trade-offs"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Lists",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 O(n) membership test; use set when checking many times"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Dicts",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 keys must be hashable (no lists as keys); insertion-ordered since Python 3.7"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Sets",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 unordered; no indexing"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Mutability",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 shared references to lists/dicts mutate across aliases"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "How it works"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Lists"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "history = []\nhistory.append({\"role\": \"user\", \"content\": \"Hi\"})\nhistory.append({\"role\": \"assistant\", \"content\": \"Hello\"})\n\nlast = history[-1]\nhistory.extend(more_turns)  # add multiple\nhistory.pop()                 # remove last"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Dicts"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "tool_results = {}\ntool_results[\"call_001\"] = {\"status\": \"ok\", \"data\": [1, 2]}\n\n# Safe access with default\nlimit = config.get(\"max_retries\", 3)\n\n# Iterate keys and values\nfor call_id, result in tool_results.items():\n    log_result(call_id, result)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Sets"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "allowed_tools = {\"search\", \"calculator\", \"browser\"}\n\"search\" in allowed_tools  # True \u2014 fast membership\n\nseen_urls = set()\nfor url in fetched:\n    if url not in seen_urls:\n        seen_urls.add(url)\n        process(url)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Tuples"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "route = (\"planner\", \"executor\")  # fixed pipeline pair\nlat_lon = (40.7, -74.0)\n\n# unpacking\nmodel, fallback = (\"gpt-4o\", \"gpt-4o-mini\")"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "When to use it"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "List",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 ordered sequences: messages, steps, batch jobs"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Dict",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 labeled fields: tool args, config, JSON-like objects"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Set",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 uniqueness and fast membership: permissions, visited IDs"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Tuple",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 fixed-size records, dict keys, return multiple values"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "How to implement"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Conversation store\nmessages: list[dict[str, str]] = [\n    {\"role\": \"system\", \"content\": \"You are a coding agent.\"},\n]\n\ndef add_turn(role: str, content: str) -> None:\n    messages.append({\"role\": role, \"content\": content})\n\n# Tool registry\ntools: dict[str, callable] = {\n    \"search\": search_fn,\n    \"run_code\": run_code_fn,\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Examples"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Nested structures \u2014 common in agent traces\ntrace = {\n    \"run_id\": \"abc\",\n    \"steps\": [\n        {\"tool\": \"search\", \"args\": {\"q\": \"python\"}, \"ms\": 120},\n        {\"tool\": \"summarize\", \"args\": {\"text\": \"...\"}, \"ms\": 890},\n    ],\n}\n\n# Copy vs. alias\nimport copy\nshallow = trace.copy()           # top-level dict copy\ndeep = copy.deepcopy(trace)      # full recursive copy"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Real-world example"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A retrieval agent deduplicates chunk IDs while preserving ranked order in a list:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def unique_ordered(ids: list[str]) -> list[str]:\n    seen: set[str] = set()\n    out: list[str] = []\n    for i in ids:\n        if i not in seen:\n            seen.add(i)\n            out.append(i)\n    return out"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common mistakes"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Using a list for membership checks",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " in hot paths \u2014 convert to set once"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Shallow copy surprises",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 nested lists mutate under "
                  },
                  {
                    "type": "text",
                    "text": ".copy()",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Unhashable dict keys",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 "
                  },
                  {
                    "type": "text",
                    "text": "{[\"a\"]: 1}",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " fails; use tuples or string keys"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Relying on set order",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " in older mental models \u2014 sets are unordered; sort explicitly when needed"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Best practices"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Use type hints like "
                  },
                  {
                    "type": "text",
                    "text": "list[dict[str, str]]",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " for message lists (details in Type Hints topic)"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Treat shared collections as owned by one layer; pass copies across agent boundaries when isolation matters"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Prefer dict comprehensions (Comprehensions topic) for transforming tool output maps"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Performance and scalability"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Dict and set average-case lookup is O(1). List append is amortized O(1); insert at front is O(n). For large conversation windows, truncate or summarize rather than letting lists grow unbounded in memory."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Comparison with alternatives"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For fixed-schema records, "
          },
          {
            "type": "text",
            "text": "dataclasses",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " (OOP topic) improve clarity over plain dicts. For ordered unique items, "
          },
          {
            "type": "text",
            "text": "dict.fromkeys",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " (Python 3.7+) preserves insertion order unlike set iteration sorting."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Mental model"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Lists are "
          },
          {
            "type": "text",
            "text": "queues of items",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": ", dicts are "
          },
          {
            "type": "text",
            "text": "labeled drawers",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": ", sets are "
          },
          {
            "type": "text",
            "text": "bags of unique tokens",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": ", tuples are "
          },
          {
            "type": "text",
            "text": "sealed envelopes",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": ". Pick the container that matches how you look up, order, and mutate data."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Key takeaways"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Messages and steps \u2192 lists; configs and results \u2192 dicts; allowlists \u2192 sets; fixed pairs \u2192 tuples"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Understand alias vs. copy for mutable nested state in agents"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Membership-heavy logic belongs in sets, not lists"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Nested JSON-like structures are idiomatic but need careful copying"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}