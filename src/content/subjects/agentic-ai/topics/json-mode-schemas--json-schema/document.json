  "doc": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "JSON Schema defines the "
          },
          {
            "type": "text",
            "text": "allowed shape",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " of JSON data — types, required fields, enums, nesting — and serves as both prompt documentation and validation spec for agent outputs."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "What it is"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A JSON Schema document describes objects, arrays, strings with patterns, numeric ranges, and "
          },
          {
            "type": "text",
            "text": "required",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " arrays. Orchestrators validate model output with schema validators (ajv, jsonschema, Pydantic)."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Why it matters"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Schemas are contracts between prompt authors and engineers. They enable automatic evals (\"does output validate?\") and self-healing retry prompts citing validation errors."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "json"
        },
        "content": [
          {
            "type": "text",
            "text": "{\n  \"type\": \"object\",\n  \"required\": [\"steps\"],\n  \"properties\": {\n    \"steps\": { \"type\": \"array\", \"items\": { \"type\": \"string\" } }\n  }\n}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Best practices"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Keep schemas minimal"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Attach schema to prompt or API structured output"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Return validation errors to model on retry"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Key takeaways"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "JSON Schema is the output contract"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Validate every production agent response"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Minimal schemas reduce model failure rates"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
