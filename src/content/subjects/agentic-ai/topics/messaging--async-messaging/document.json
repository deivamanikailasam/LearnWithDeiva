      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\n\n\nasync def safe_enqueue(\n    queue: asyncio.Queue,\n    msg: AsyncMessage,\n    timeout: float = 5.0,\n    on_drop=None,\n) -> bool:\n    \"\"\"Try to enqueue; drop with optional callback if the queue stays full.\"\"\"\n    try:\n        await asyncio.wait_for(queue.put(msg), timeout=timeout)\n        return True\n    except asyncio.TimeoutError:\n        if on_drop:\n            on_drop(msg)\n        return False\n\n\n# Usage: log dropped messages instead of crashing\nasync def publisher(queue: asyncio.Queue):\n    for item in generate_tasks():\n        dropped = await safe_enqueue(\n            queue, item,\n            on_drop=lambda m: print(f\"DROPPED {m.msg_id} \u2014 queue full\")\n        )\n        if not dropped:\n            # store to retry queue or dead-letter\n            pass\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Priority Queues for Task Urgency"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When tasks differ in urgency, a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "asyncio.PriorityQueue"
          },
          {
            "type": "text",
            "text": " delivers the highest-priority item first. Items must be comparable; wrap messages in a tuple "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "(priority, message)"
          },
          {
            "type": "text",
            "text": " where lower integers are served first:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\nfrom dataclasses import dataclass, field\n\n\n@dataclass(order=True)\nclass PrioritisedMessage:\n    priority: int              # 0 = urgent, 9 = background\n    message: AsyncMessage = field(compare=False)\n\n\nasync def priority_demo():\n    pq: asyncio.PriorityQueue = asyncio.PriorityQueue()\n\n    # Add tasks out of urgency order\n    await pq.put(PrioritisedMessage(priority=5, message=AsyncMessage(topic=\"background\", sender=\"a\", payload={\"work\": \"low\"  })))\n    await pq.put(PrioritisedMessage(priority=0, message=AsyncMessage(topic=\"urgent\",     sender=\"b\", payload={\"work\": \"high\" })))\n    await pq.put(PrioritisedMessage(priority=3, message=AsyncMessage(topic=\"normal\",     sender=\"c\", payload={\"work\": \"medium\"})))\n\n    while not pq.empty():\n        item = await pq.get()\n        print(f\"priority={item.priority} topic={item.message.topic}\")\n        # Output order: 0 (urgent), 3 (normal), 5 (background)\n\nasyncio.run(priority_demo())\n"
          }
        ]
      },
