      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Core Primitives in Python"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Python's "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "asyncio.Queue"
          },
          {
            "type": "text",
            "text": " is the simplest in-process async queue. It is bounded (optional "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "maxsize"
          },
          {
            "type": "text",
            "text": "), FIFO, and safe to share across coroutines in the same event loop:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\nfrom dataclasses import dataclass, field\nfrom typing import Any\nimport uuid\n\n\n@dataclass\nclass AsyncMessage:\n    msg_id: str = field(default_factory=lambda: str(uuid.uuid4()))\n    topic: str = \"\"\n    sender: str = \"\"\n    payload: dict[str, Any] = field(default_factory=dict)\n    reply_to: str | None = None   # queue name to send the result back to\n\n\nasync def producer(queue: asyncio.Queue, sender_id: str, items: list[str]):\n    \"\"\"Enqueue tasks without waiting for them to be processed.\"\"\"\n    for item in items:\n        msg = AsyncMessage(\n            topic=\"process\",\n            sender=sender_id,\n            payload={\"item\": item},\n        )\n        await queue.put(msg)          # blocks only if queue is full (maxsize)\n        print(f\"[{sender_id}] enqueued: {item}\")\n    # sentinel \u2014 tells the consumer there are no more items\n    await queue.put(None)\n\n\nasync def consumer(queue: asyncio.Queue, consumer_id: str):\n    \"\"\"Process messages as they arrive; exit on sentinel.\"\"\"\n    while True:\n        msg = await queue.get()       # suspends until a message arrives\n        if msg is None:\n            break\n        print(f\"[{consumer_id}] processing: {msg.payload['item']}\")\n        await asyncio.sleep(0.1)      # simulate work\n        queue.task_done()\n\n\nasync def main():\n    q: asyncio.Queue = asyncio.Queue(maxsize=10)\n    await asyncio.gather(\n        producer(q, \"agent-A\", [\"task-1\", \"task-2\", \"task-3\"]),\n        consumer(q, \"worker-1\"),\n    )\n\nasyncio.run(main())\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Request-Reply over Async Queues"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Asynchronous messaging can still return a result \u2014 just not synchronously. The sender includes a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "reply_to"
          },
          {
            "type": "text",
            "text": " field pointing to its own inbox queue. The receiver processes the task and posts the result there; the sender polls or awaits that queue when it actually needs the answer:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\nfrom langchain_anthropic import ChatAnthropic\n\n\nclass AgentMailbox:\n    \"\"\"Per-agent inbox, keyed by agent id.\"\"\"\n    def __init__(self):\n        self._boxes: dict[str, asyncio.Queue] = {}\n\n    def inbox(self, agent_id: str) -> asyncio.Queue:\n        if agent_id not in self._boxes:\n            self._boxes[agent_id] = asyncio.Queue()\n        return self._boxes[agent_id]\n\n    async def send(self, to: str, msg: AsyncMessage):\n        await self.inbox(to).put(msg)\n\n    async def receive(self, agent_id: str) -> AsyncMessage:\n        return await self.inbox(agent_id).get()\n\n\nmailbox = AgentMailbox()\nllm = ChatAnthropic(model=\"claude-haiku-4-5-20251001\")\n\n\nasync def worker_agent(agent_id: str):\n    \"\"\"Wait for tasks, process them, reply to sender.\"\"\"\n    while True:\n        msg = await mailbox.receive(agent_id)\n        if msg is None:\n            break\n        response = await llm.ainvoke(msg.payload.get(\"prompt\", \"\"))\n        if msg.reply_to:\n            reply = AsyncMessage(\n                topic=\"result\",\n                sender=agent_id,\n                payload={\"answer\": response.content, \"original_id\": msg.msg_id},\n            )\n            await mailbox.send(msg.reply_to, reply)\n\n\nasync def coordinator(question: str, worker_id: str, coord_id: str):\n    task = AsyncMessage(\n        topic=\"analyse\",\n        sender=coord_id,\n        payload={\"prompt\": question},\n        reply_to=coord_id,   # send result back to coordinator's inbox\n    )\n    await mailbox.send(worker_id, task)\n    # ... do other work here ...\n    result_msg = await mailbox.receive(coord_id)  # await only when needed\n    return result_msg.payload[\"answer\"]\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Integrating with LangGraph"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "LangGraph graph steps run synchronously by default. Async messaging is layered on top via the "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "AgentMailbox"
          },
          {
            "type": "text",
            "text": " shared object. Nodes that need to receive messages call "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "mailbox.inbox(id).get_nowait()"
          },
          {
            "type": "text",
            "text": " to drain any waiting messages without blocking:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import operator\nfrom typing import Annotated\nfrom typing_extensions import TypedDict\nfrom langgraph.graph import StateGraph, END\nfrom langchain_anthropic import ChatAnthropic\n\n\nclass AsyncPipelineState(TypedDict):\n    inputs: list[str]\n    results: Annotated[list[str], operator.add]\n    final: str\n\n\n_mailbox = AgentMailbox()\n_llm = ChatAnthropic(model=\"claude-haiku-4-5-20251001\")\n\n\ndef dispatcher(state: AsyncPipelineState) -> dict:\n    \"\"\"Fan out: enqueue each input as an async message to worker inboxes.\"\"\"\n    loop = asyncio.new_event_loop()\n\n    async def _send_all():\n        for i, item in enumerate(state[\"inputs\"]):\n            worker_id = f\"worker-{i % 3}\"   # round-robin across 3 workers\n            msg = AsyncMessage(\n                topic=\"task\",\n                sender=\"dispatcher\",\n                payload={\"text\": item},\n                reply_to=\"dispatcher\",\n            )\n            await _mailbox.send(worker_id, msg)\n\n    loop.run_until_complete(_send_all())\n    loop.close()\n    return {}\n\n\ndef make_worker(worker_id: str):\n    def worker(state: AsyncPipelineState) -> dict:\n        loop = asyncio.new_event_loop()\n\n        async def _process():\n            results = []\n            q = _mailbox.inbox(worker_id)\n            while not q.empty():\n                msg = await q.get()\n                resp = await _llm.ainvoke(msg.payload[\"text\"])\n                results.append(resp.content)\n            return results\n\n        out = loop.run_until_complete(_process())\n        loop.close()\n        return {\"results\": out}\n    return worker\n\n\nbuilder = StateGraph(AsyncPipelineState)\nbuilder.add_node(\"dispatch\", dispatcher)\nfor i in range(3):\n    builder.add_node(f\"worker-{i}\", make_worker(f\"worker-{i}\"))\n    builder.add_edge(\"dispatch\", f\"worker-{i}\")\n    builder.add_edge(f\"worker-{i}\", END)\nbuilder.set_entry_point(\"dispatch\")\ngraph = builder.compile()\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Handling Message Ordering and Deduplication"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Async queues deliver messages in FIFO order within a single queue, but when multiple producers write to the same queue the interleaving order depends on scheduling. If downstream logic is order-sensitive, add a sequence number and sort on the consumer side:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "@dataclass\nclass OrderedMessage(AsyncMessage):\n    seq: int = 0   # monotonically increasing per sender\n\n\ndef sort_by_seq(messages: list[OrderedMessage]) -> list[OrderedMessage]:\n    return sorted(messages, key=lambda m: (m.sender, m.seq))\n\n\n# Idempotency: skip duplicates using a seen-set\n_seen_ids: set[str] = set()\n\ndef deduplicate(messages: list[AsyncMessage]) -> list[AsyncMessage]:\n    fresh = [m for m in messages if m.msg_id not in _seen_ids]\n    _seen_ids.update(m.msg_id for m in fresh)\n    return fresh\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Operational Considerations"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Bounded queues"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 always set "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "maxsize"
                  },
                  {
                    "type": "text",
                    "text": " on production queues. An unbounded queue masks a slow consumer by absorbing all back-pressure into memory until the process OOMs."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Timeouts"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 use "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "asyncio.wait_for(queue.get(), timeout=30)"
                  },
                  {
                    "type": "text",
                    "text": " when awaiting a reply so a crashed receiver doesn't deadlock the sender forever."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Checkpointing"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 in-process queues vanish if the process restarts. For durability, write messages to the LangGraph state ("
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "Annotated[list, operator.add]"
                  },
                  {
                    "type": "text",
                    "text": ") before enqueueing; a resumed run can re-hydrate the queue from state."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Observability"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 log "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "msg_id"
                  },
                  {
                    "type": "text",
                    "text": " and "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "sender"
                  },
                  {
                    "type": "text",
                    "text": " on every enqueue and dequeue. A queue that is growing without shrinking indicates a stalled consumer."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Scaling out"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 when agents move to separate processes, replace "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "asyncio.Queue"
                  },
                  {
                    "type": "text",
                    "text": " with Redis Streams ("
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "XADD"
                  },
                  {
                    "type": "text",
                    "text": " / "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "XREAD"
                  },
                  {
                    "type": "text",
                    "text": ") or Kafka; the "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "AsyncMessage"
                  },
                  {
                    "type": "text",
                    "text": " schema is JSON-serialisable and transfers unchanged."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Back-Pressure and Flow Control"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Back-pressure is the mechanism that prevents a fast producer from overwhelming a slow consumer. In an async queue, "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "await queue.put(msg)"
          },
          {
            "type": "text",
            "text": " suspends the producer coroutine when the queue is full, naturally throttling the send rate. Three strategies for handling a full queue:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Block (default)"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "await queue.put(msg)"
                  },
                  {
                    "type": "text",
                    "text": " suspends the sender until a slot opens. Safe but can cascade stalls through the pipeline."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Drop"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "queue.put_nowait(msg)"
                  },
                  {
                    "type": "text",
                    "text": " raises "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
