      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Routing Within an Agent Loop"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Routing can be applied at the per-step level inside an agent loop. The first step routes on the overall task description; subsequent steps route on the immediate context \u2014 what the model is currently doing:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\n\nclient = anthropic.Anthropic()\n\n\ndef routed_agent_step(\n    messages: list[dict],\n    tools: list[dict],\n    step: int,\n    task_description: str,\n) -> anthropic.types.Message:\n    \"\"\"\n    Agent loop step with per-step model routing.\n    - Step 0 (planning): route based on overall task difficulty\n    - Later steps: route based on what the current step is doing\n    \"\"\"\n    if step == 0:\n        # Initial planning \u2014 use the full task description\n        decision = route(task_description)\n    else:\n        # Look at the last assistant turn to understand current step\n        last_content = messages[-1].get(\"content\", \"\") if messages else \"\"\n        step_hint = str(last_content)[:300]  # first 300 chars as signal\n        decision = route(step_hint)\n\n    response = client.messages.create(\n        model=decision.model_id,\n        max_tokens=decision.max_tokens,\n        tools=tools,\n        messages=messages,\n    )\n    return response\n\n\ndef agent_loop(task: str, tools: list[dict]) -> str:\n    messages = [{\"role\": \"user\", \"content\": task}]\n\n    for step in range(30):\n        response = routed_agent_step(messages, tools, step, task)\n        messages.append({\"role\": \"assistant\", \"content\": response.content})\n\n        if response.stop_reason == \"end_turn\":\n            for block in response.content:\n                if hasattr(block, \"text\"):\n                    return block.text\n            return \"\"\n\n        tool_results = []\n        for block in response.content:\n            if block.type == \"tool_use\":\n                tool_results.append({\n                    \"type\": \"tool_result\",\n                    \"tool_use_id\": block.id,\n                    \"content\": f\"result of {block.name}\",\n                })\n        messages.append({\"role\": \"user\", \"content\": tool_results})\n\n    return \"Max steps reached.\"\n"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Plan on overall task, execute on step context",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 the planning step benefits from full task visibility; execution steps route on what tool is being used or what file is being read."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
