        },
        "content": [
          {
            "type": "text",
            "text": "Keyword-Based Router"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A keyword router is the simplest approach: scan the task string for signals that indicate simple or hard work, and default to the balanced tier for everything else. It adds no API latency and is easy to extend:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass\nfrom typing import Literal\n\n\nModelTier = Literal[\"haiku\", \"sonnet\", \"opus\"]\n\nMODEL_IDS: dict[ModelTier, str] = {\n    \"haiku\": \"claude-haiku-4-5-20251001\",\n    \"sonnet\": \"claude-sonnet-4-6\",\n    \"opus\": \"claude-opus-4-8\",\n}\n\nMAX_TOKENS: dict[ModelTier, int] = {\n    \"haiku\": 512,\n    \"sonnet\": 4096,\n    \"opus\": 8192,\n}\n\nSIMPLE_SIGNALS = [\n    \"yes or no\", \"true or false\", \"classify\", \"is this\", \"extract\",\n    \"what is the\", \"list the\", \"summarise in one sentence\",\n]\n\nHARD_SIGNALS = [\n    \"design\", \"architecture\", \"trade-off\", \"security\", \"proof\",\n    \"optimise\", \"compare approaches\", \"migration plan\", \"threat model\",\n]\n\n\n@dataclass\nclass RoutingDecision:\n    tier: ModelTier\n    model_id: str\n    max_tokens: int\n    reason: str\n\n\ndef route(task: str) -> RoutingDecision:\n    \"\"\"\n    Heuristic keyword router. Returns the model tier and configuration\n    for a given task string.\n    \"\"\"\n    task_lower = task.lower()\n\n    if any(s in task_lower for s in SIMPLE_SIGNALS):\n        tier: ModelTier = \"haiku\"\n        reason = \"simple task signal detected\"\n    elif any(s in task_lower for s in HARD_SIGNALS):\n        tier = \"opus\"\n        reason = \"complex task signal detected\"\n    else:\n        tier = \"sonnet\"\n        reason = \"default balanced tier\"\n\n    return RoutingDecision(\n        tier=tier,\n        model_id=MODEL_IDS[tier],\n        max_tokens=MAX_TOKENS[tier],\n        reason=reason,\n    )\n"
          }
        ]
      },
      {
