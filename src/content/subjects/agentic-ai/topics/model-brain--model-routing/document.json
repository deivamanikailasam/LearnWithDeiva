      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Meta-Router (Model-Classifies-Model)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For more accurate routing, use a fast, cheap model (Haiku) as a classifier that decides which tier to call. This costs a small amount on every call but produces more reliable routing than keyword heuristics on ambiguous tasks:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\nimport json\n\nclient = anthropic.Anthropic()\n\nROUTING_SCHEMA = {\n    \"type\": \"object\",\n    \"properties\": {\n        \"tier\": {\n            \"type\": \"string\",\n            \"enum\": [\"haiku\", \"sonnet\", \"opus\"],\n            \"description\": \"Model tier most appropriate for this task\",\n        },\n        \"reason\": {\n            \"type\": \"string\",\n            \"description\": \"One-sentence explanation for the routing decision\",\n        },\n    },\n    \"required\": [\"tier\", \"reason\"],\n}\n\nROUTING_TOOL = {\n    \"name\": \"select_model\",\n    \"description\": \"Select the model tier appropriate for a given task.\",\n    \"input_schema\": ROUTING_SCHEMA,\n}\n\n\ndef meta_route(task: str) -> tuple[str, str]:\n    \"\"\"\n    Use a fast model (Haiku) to classify the task and decide which tier\n    to route it to. Returns (model_id, reason).\n    \"\"\"\n    response = client.messages.create(\n        model=\"claude-haiku-4-5-20251001\",  # cheap classifier\n        max_tokens=256,\n        tools=[ROUTING_TOOL],\n        tool_choice={\"type\": \"auto\"},\n        messages=[{\n            \"role\": \"user\",\n            \"content\": (\n                f\"Classify this task and select the appropriate model tier.\\n\\n\"\n                f\"Task: {task[:500]}\"  # truncate to keep classifier cheap\n            ),\n        }],\n    )\n\n    for block in response.content:\n        if block.type == \"tool_use\" and block.name == \"select_model\":\n            tier = block.input[\"tier\"]\n            reason = block.input[\"reason\"]\n            model_id = {\n                \"haiku\": \"claude-haiku-4-5-20251001\",\n                \"sonnet\": \"claude-sonnet-4-6\",\n                \"opus\": \"claude-opus-4-8\",\n            }.get(tier, \"claude-sonnet-4-6\")\n            return model_id, reason\n\n    return \"claude-sonnet-4-6\", \"default \u2014 classifier did not return a tier\"\n"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "The meta-router adds one Haiku call per task, which costs a fraction of the cost savings achieved by routing correctly. The cost is almost always worth it when the router is handling dozens of tasks per agent run."
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Stateful Router with Usage Tracking"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A stateful router class wraps the routing logic, tracks which tiers are called how often, and supports a dry-run mode for testing routing decisions without making real API calls:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\nfrom dataclasses import dataclass, field\n\n\n@dataclass\nclass RouterStats:\n    calls: dict[str, int] = field(default_factory=lambda: {\"haiku\": 0, \"sonnet\": 0, \"opus\": 0})\n\n    def record(self, tier: str) -> None:\n        self.calls[tier] = self.calls.get(tier, 0) + 1\n\n    def summary(self) -> str:\n        total = sum(self.calls.values())\n        lines = [f\"Total routed calls: {total}\"]\n        for tier, count in sorted(self.calls.items()):\n            pct = 100 * count / total if total else 0\n            lines.append(f\"  {tier}: {count} ({pct:.0f}%)\")\n        return \"\\n\".join(lines)\n\n\nclass ModelRouter:\n    \"\"\"\n    Stateful router that routes tasks to model tiers, tracks usage,\n    and supports a dry-run mode for testing routing logic.\n    \"\"\"\n    def __init__(self, dry_run: bool = False):\n        self.client = anthropic.Anthropic()\n        self.stats = RouterStats()\n        self.dry_run = dry_run\n\n    def run(self, task: str) -> str:\n        decision = route(task)  # uses keyword router from above\n        self.stats.record(decision.tier)\n\n        if self.dry_run:\n            return f\"[DRY RUN] Would call {decision.model_id}: {decision.reason}\"\n\n        response = self.client.messages.create(\n            model=decision.model_id,\n            max_tokens=decision.max_tokens,\n            messages=[{\"role\": \"user\", \"content\": task}],\n        )\n        for block in response.content:\n            if hasattr(block, \"text\"):\n                return block.text\n        return \"\"\n\n    def routing_summary(self) -> str:\n        return self.stats.summary()\n"
          }
        ]
      },
