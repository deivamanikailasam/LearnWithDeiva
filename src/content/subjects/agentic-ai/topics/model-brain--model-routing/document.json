        "content": [
          {
            "type": "text",
            "text": "Testing the Router"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import pytest\n\n\nclass TestKeywordRouter:\n    def test_simple_signals_route_haiku(self):\n        cases = [\n            \"Yes or no: is this a valid email?\",\n            \"Classify this log line as ERROR or INFO.\",\n            \"Extract the date from this string.\",\n        ]\n        for task in cases:\n            d = route(task)\n            assert d.tier == \"haiku\", f\"Expected haiku for: {task}\"\n\n    def test_hard_signals_route_opus(self):\n        cases = [\n            \"Design the database schema for this SaaS platform.\",\n            \"Provide a threat model for this API.\",\n            \"Compare approaches to distributed rate limiting.\",\n        ]\n        for task in cases:\n            d = route(task)\n            assert d.tier == \"opus\", f\"Expected opus for: {task}\"\n\n    def test_default_routes_sonnet(self):\n        d = route(\"Read this file and summarise its contents.\")\n        assert d.tier == \"sonnet\"\n\n    def test_decision_has_model_id(self):\n        d = route(\"Fix the login bug.\")\n        assert d.model_id.startswith(\"claude-\")\n        assert d.max_tokens > 0\n\n\nclass TestRouterStats:\n    def test_records_calls(self):\n        stats = RouterStats()\n        stats.record(\"haiku\")\n        stats.record(\"sonnet\")\n        stats.record(\"sonnet\")\n        assert stats.calls[\"haiku\"] == 1\n        assert stats.calls[\"sonnet\"] == 2\n\n    def test_summary_shows_percentages(self):\n        stats = RouterStats()\n        stats.record(\"haiku\")\n        stats.record(\"sonnet\")\n        summary = stats.summary()\n        assert \"50%\" in summary or \"50\" in summary\n"
