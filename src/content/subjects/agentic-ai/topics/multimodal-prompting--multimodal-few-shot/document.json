  "format": "tiptap/v1",
  "updatedAt": "2026-06-22T17:46:43.951Z",
  "doc": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Multimodal few-shot prompting includes "
          },
          {
            "type": "text",
            "text": "example pairs with images, audio, or documents",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " plus text, teaching the model how to handle similar inputs. It anchors format and reasoning for visual or mixed-media tasks where zero-shot accuracy is insufficient."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "What it is"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Each example shows multimodal input (e.g., photo of a receipt) and desired structured output (vendor, total, line items). The live task follows the same pattern. Delimiters separate examples from the active input."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Why it matters"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Receipt layouts, form fields, and UI patterns vary widely. Few-shot multimodal examples encode organization-specific layout knowledge faster than custom vision models for many teams."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Examples"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "text"
        },
        "content": [
          {
            "type": "text",
            "text": "<example>\n  <image>receipt_sample_a.jpg</image>\n  <output>{\"vendor\":\"Acme\",\"total\":42.50,\"currency\":\"USD\"}</output>\n</example>\n<input>\n  <image>receipt_live.jpg</image>\n</input>"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Best practices"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Use diverse layout examples, not color variations of one template"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Keep image resolution consistent between examples and production"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Monitor token cost — images in few-shot multiply quickly"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Key takeaways"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Multimodal few-shot demonstrates input→output on real media types"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Essential for idiosyncratic layouts and formats"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Balance example count against context budget"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
