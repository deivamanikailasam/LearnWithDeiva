      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Implementing the Planning Step"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The planner calls an LLM with the original task and returns a structured list of sub-tasks. Using Pydantic output parsing makes the plan machine-readable without fragile string splitting."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from pydantic import BaseModel\nfrom langchain_anthropic import ChatAnthropic\nfrom langchain_core.output_parsers import PydanticOutputParser\n\nclass SubTask(BaseModel):\n    id: str\n    description: str\n    requires: list[str] = []   # ids of sub-tasks that must complete first\n\nclass TaskPlan(BaseModel):\n    sub_tasks: list[SubTask]\n\nplanner_llm = ChatAnthropic(model=\"claude-sonnet-5\")\nparser = PydanticOutputParser(pydantic_object=TaskPlan)\n\nPLANNER_PROMPT = \"\"\"\nDecompose the following task into independent sub-tasks suitable for parallel execution.\nEach sub-task should be self-contained. List prerequisites by id if ordering matters.\nReturn JSON matching this schema: {format_instructions}\n\nTask: {task}\n\"\"\".strip()\n\ndef plan_task(task: str) -> TaskPlan:\n    prompt = PLANNER_PROMPT.format(\n        format_instructions=parser.get_format_instructions(),\n        task=task,\n    )\n    response = planner_llm.invoke(prompt)\n    return parser.parse(response.content)\n\n# Example\nplan = plan_task(\"Write a technical report on quantum computing applications\")\nfor st in plan.sub_tasks:\n    print(f\"  [{st.id}] {st.description} (requires: {st.requires})\")\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Fan-Out with the Send API"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "LangGraph's "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "Send"
          },
          {
            "type": "text",
            "text": " API dispatches multiple worker invocations in parallel from a single conditional edge. Each "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "Send"
          },
          {
            "type": "text",
            "text": " carries a fresh state dict scoped to one sub-task, so workers run independently with no shared mutation."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langgraph.graph import StateGraph, END\nfrom langgraph.types import Send\nfrom typing import TypedDict, Annotated\nimport operator\n\nclass OrchestratorState(TypedDict):\n    task: str\n    plan: list[dict]           # list of SubTask dicts\n    results: Annotated[list[dict], operator.add]  # reducer merges all worker outputs\n    final: str\n    errors: Annotated[list[str], operator.add]\n\nclass WorkerState(TypedDict):\n    sub_task_id: str\n    description: str\n    result: str\n    errors: list[str]\n\ndef orchestrator_node(state: OrchestratorState) -> dict:\n    \"\"\"Plans and decomposes the task.\"\"\"\n    plan = plan_task(state[\"task\"])\n    return {\"plan\": [st.model_dump() for st in plan.sub_tasks]}\n\ndef dispatch_workers(state: OrchestratorState) -> list[Send]:\n    \"\"\"Fan-out: one Send per sub-task, all run in parallel.\"\"\"\n    return [\n        Send(\"worker\", {\n            \"sub_task_id\": st[\"id\"],\n            \"description\": st[\"description\"],\n            \"result\": \"\",\n            \"errors\": [],\n        })\n        for st in state[\"plan\"]\n    ]\n\nworker_llm = ChatAnthropic(model=\"claude-haiku-4-5-20251001\")\n\ndef worker_node(state: WorkerState) -> dict:\n    \"\"\"Executes one sub-task and returns its result.\"\"\"\n    try:\n        resp = worker_llm.invoke([\n            {\"role\": \"system\", \"content\": \"Complete this sub-task concisely and accurately.\"},\n            {\"role\": \"user\",   \"content\": state[\"description\"]},\n        ])\n        return {\"result\": resp.content, \"errors\": []}\n    except Exception as exc:\n        return {\"result\": \"\", \"errors\": [f\"{state['sub_task_id']}:{exc}\"]}\n\ndef synthesizer_node(state: OrchestratorState) -> dict:\n    \"\"\"Combines all worker results into a final output.\"\"\"\n    parts = \"\\n\\n\".join(\n        f\"## {r['sub_task_id']}\\n{r['result']}\"\n        for r in state[\"results\"]\n        if r.get(\"result\")\n    )\n    resp = worker_llm.invoke([\n        {\"role\": \"system\", \"content\": \"Synthesize these section outputs into a coherent final response.\"},\n        {\"role\": \"user\",   \"content\": parts},\n    ])\n    return {\"final\": resp.content}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Wiring the Orchestrator Graph"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def build_orchestrator() -> StateGraph:\n    builder = StateGraph(OrchestratorState)\n\n    builder.add_node(\"orchestrator\", orchestrator_node)\n    builder.add_node(\"worker\",       worker_node)\n    builder.add_node(\"synthesizer\",  synthesizer_node)\n\n    builder.set_entry_point(\"orchestrator\")\n\n    # After planning, fan-out to workers via Send API\n    builder.add_conditional_edges(\n        \"orchestrator\",\n        dispatch_workers,\n    )\n\n    # After all workers finish, synthesize\n    builder.add_edge(\"worker\", \"synthesizer\")\n    builder.add_edge(\"synthesizer\", END)\n\n    return builder.compile()\n\npipeline = build_orchestrator()\nresult = pipeline.invoke({\n    \"task\": \"Write a technical report on quantum computing applications\",\n    \"plan\": [], \"results\": [], \"final\": \"\", \"errors\": [],\n})\nprint(result[\"final\"])\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When all "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "worker"
          },
          {
            "type": "text",
            "text": " invocations complete, their results accumulate in the "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "results"
          },
          {
            "type": "text",
            "text": " list via the "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "operator.add"
          },
          {
            "type": "text",
            "text": " reducer before "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "synthesizer"
          },
          {
            "type": "text",
            "text": " runs."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Handling Dependency Ordering"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When the planner produces sub-tasks with prerequisites, the fan-out must respect ordering. A simple approach is to execute independent tasks first, wait for their results, then dispatch dependent tasks in a second wave."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def dispatch_independent_workers(state: OrchestratorState) -> list[Send]:\n    \"\"\"Only dispatch sub-tasks with no unfulfilled prerequisites.\"\"\"\n    completed_ids = {r[\"sub_task_id\"] for r in state[\"results\"]}\n    return [\n        Send(\"worker\", {\n            \"sub_task_id\": st[\"id\"],\n            \"description\": st[\"description\"],\n            \"result\": \"\",\n            \"errors\": [],\n        })\n        for st in state[\"plan\"]\n        if st[\"id\"] not in completed_ids                       # not already done\n        and all(req in completed_ids for req in st.get(\"requires\", []))  # deps met\n    ]\n\ndef should_continue(state: OrchestratorState) -> str:\n    \"\"\"Route back to dispatch if unfinished work remains, else synthesize.\"\"\"\n    completed = {r[\"sub_task_id\"] for r in state[\"results\"]}\n    pending = [st for st in state[\"plan\"] if st[\"id\"] not in completed]\n    return \"dispatch\" if pending else \"synthesizer\"\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Cost and Latency Tradeoffs"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The orchestrator trades cost for latency. Running N workers in parallel completes in the time of the slowest worker, not the sum \u2014 but you pay for all N calls simultaneously. Budget accordingly:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Cap plan size"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 prompt the planner with a maximum sub-task count (e.g., 'decompose into at most 6 sub-tasks') to prevent runaway fan-out."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Use cheap workers"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 each individual sub-task is usually simpler than the full task; Haiku is often sufficient."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Scope worker context"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 pass only the sub-task description, not the full original task, to workers to minimize input tokens."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Cache planner output"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 identical tasks produce identical plans; caching the planning step avoids repeated planner calls for known inputs."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing the Orchestrator"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import pytest\nfrom unittest.mock import MagicMock, patch\n\ndef test_dispatch_workers_creates_one_send_per_plan_item():\n    state = {\n        \"task\": \"test\",\n        \"plan\": [\n            {\"id\": \"a\", \"description\": \"step A\", \"requires\": []},\n            {\"id\": \"b\", \"description\": \"step B\", \"requires\": []},\n        ],\n        \"results\": [], \"final\": \"\", \"errors\": [],\n    }\n    sends = dispatch_workers(state)\n    assert len(sends) == 2\n    assert sends[0].node == \"worker\"\n    assert sends[0].arg[\"sub_task_id\"] == \"a\"\n\ndef test_dispatch_independent_skips_tasks_with_unmet_deps():\n    state = {\n        \"task\": \"test\",\n        \"plan\": [\n            {\"id\": \"a\", \"description\": \"step A\", \"requires\": []},\n            {\"id\": \"b\", \"description\": \"step B\", \"requires\": [\"a\"]},\n        ],\n        \"results\": [], \"final\": \"\", \"errors\": [],\n    }\n    # Only \"a\" should be dispatched \u2014 \"b\" requires \"a\" which is not done\n    sends = dispatch_independent_workers(state)\n    assert len(sends) == 1\n    assert sends[0].arg[\"sub_task_id\"] == \"a\"\n\ndef test_worker_node_returns_result_on_success():\n    state = {\"sub_task_id\": \"a\", \"description\": \"explain X\", \"result\": \"\", \"errors\": []}\n    mock_resp = MagicMock()\n    mock_resp.content = \"explanation of X\"\n    with patch(\"my_graph.worker_llm\") as mock_llm:\n        mock_llm.invoke.return_value = mock_resp\n        out = worker_node(state)\n    assert out[\"result\"] == \"explanation of X\"\n    assert out[\"errors\"] == []\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Error Handling in Fan-Out Pipelines"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When one worker in a parallel fan-out fails, the orchestrator must decide whether to fail the entire pipeline or synthesize from partial results. The two standard strategies are strict mode (any failure aborts synthesis) and lenient mode (failed workers contribute empty results and synthesis proceeds with whatever completed successfully)."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def synthesizer_node_lenient(state: OrchestratorState) -> dict:\n    \"\"\"Synthesize from successful workers only; surface errors but don't abort.\"\"\"\n    successful = [r for r in state[\"results\"] if r.get(\"result\")]\n    failed_ids  = [r[\"sub_task_id\"] for r in state[\"results\"] if not r.get(\"result\")]\n\n    if not successful:\n        return {\n            \"final\": \"\",\n            \"errors\": [\"synthesizer:no_successful_workers\"],\n        }\n\n    parts = \"\\n\\n\".join(\n        f\"## {r['sub_task_id']}\\n{r['result']}\"\n        for r in successful\n    )\n    resp = worker_llm.invoke([\n        {\"role\": \"system\", \"content\": (\n            \"Synthesize these completed sections into a coherent response. \"\n            f\"Note: sections {failed_ids} were unavailable.\"\n        )},\n        {\"role\": \"user\", \"content\": parts},\n    ])\n    return {\n        \"final\": resp.content,\n        \"errors\": [f\"worker:{fid}:failed\" for fid in failed_ids],\n    }\n\ndef synthesizer_node_strict(state: OrchestratorState) -> dict:\n    \"\"\"Abort synthesis if any worker failed.\"\"\"\n    failed = [r for r in state[\"results\"] if not r.get(\"result\")]\n    if failed:\n        failed_ids = [r[\"sub_task_id\"] for r in failed]\n        return {\n            \"final\": \"\",\n            \"errors\": [f\"synthesizer:strict_abort:failed={failed_ids}\"],\n        }\n    return synthesizer_node(state)   # delegate to normal synthesizer\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Choose strict mode when partial output is misleading (e.g., a legal analysis missing a section is worse than no output at all). Use lenient mode for informational tasks where best-effort output is preferable to a total failure."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
