          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def search_docs(query: str, top_k: int = 5) -> list[str]:\n    \"\"\"Return document IDs matching query.\"\"\"\n    ...\n\ndef run_python(code: str, timeout: float = 30.0) -> dict[str, str]:\n    \"\"\"Execute code in sandbox; return stdout/stderr.\"\"\"\n    ..."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common mistakes"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Treating hints as validation",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " — runtime still accepts wrong types"
                  }
