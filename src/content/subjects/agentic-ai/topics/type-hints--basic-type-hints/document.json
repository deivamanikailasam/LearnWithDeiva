      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Literal for fixed string sets (roles, finish reasons)\nfrom typing import Literal\n\nRole = Literal[\"system\", \"user\", \"assistant\", \"tool\"]\n\ndef append_message(messages: list[dict], role: Role, content: str) -> None:\n    messages.append({\"role\": role, \"content\": content})"
          }
        ]
      },
