      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Type hints are "
          },
          {
            "type": "text",
            "text": "labels on shipping boxes",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " — they tell handlers what should be inside without opening every box at runtime. Enforcement happens at the warehouse gate (static checker) or with a scanner (Pydantic), not automatically when Python runs the code."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
