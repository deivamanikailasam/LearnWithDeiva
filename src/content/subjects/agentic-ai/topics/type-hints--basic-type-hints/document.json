      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "class LLMClient:\n    def __init__(self, api_key: str, base_url: str) -> None:\n        self.api_key = api_key\n        self.base_url = base_url\n\n    def chat(\n        self,\n        messages: list[dict[str, str]],\n        *,\n        temperature: float = 0.7,\n        max_tokens: int = 1024,\n    ) -> str:\n        ..."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
