            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "A subgoal tree makes planning state queryable: progress(), next_pending(), and failed_subtrees() answer the most common planning queries without re-reading history."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Status is maintained at the leaf level; parent status is always derived via rollup_status(), never set directly."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "complete_leaf() and fail_leaf() walk the parent chain and update roll-up status immediately after each leaf changes."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "build_goal_tree() recursively decomposes a root GoalNode until all leaves are primitive (single-tool-call sized)."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "verify_goal_completion() runs an LLM check against success criteria using leaf results as evidence \u2014 a separate gate from the tree's structural DONE state."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Failed subtrees can be re-planned by replacing failed leaves with new GoalNodes and re-running the executor from that point."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
