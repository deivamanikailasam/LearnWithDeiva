                    "type": "text",
                    "text": " \u2014 never call real APIs in tests."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Test the error path"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 verify that an unknown tool name raises "
                  },
