        "content": [
          {
            "type": "text",
            "text": "# Servers can send notifications to the host (client) without being asked.\n# Useful for progress updates on long-running tool calls.\n\nfrom mcp.server import Server\nfrom mcp.server.stdio import stdio_server\nfrom mcp import types\nimport asyncio\n\napp = Server('progress-server')\n\n@app.call_tool()\nasync def call_tool(name: str, arguments: dict) -> list[types.TextContent]:\n    if name == \"index_repository\":\n        total = arguments.get('file_count', 100)\n        for i in range(total):\n            await asyncio.sleep(0.01)   # simulate per-file work\n            if i % 10 == 0:\n                # Send progress notification to the host\n                await app.request_context.session.send_progress_notification(\n                    progress_token=arguments.get('_progress_token'),\n                    progress=i,\n                    total=total,\n                )\n        return [types.TextContent(type='text', text=f'Indexed {total} files.')]\n    raise ValueError(f'Unknown tool: {name}')\n"
          }
        ]
