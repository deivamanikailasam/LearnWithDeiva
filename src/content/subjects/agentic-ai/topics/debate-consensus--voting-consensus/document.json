      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "VotingState: Collecting Independent Ballots"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import operator\nfrom typing import Annotated, Literal\nfrom typing_extensions import TypedDict\nfrom dataclasses import dataclass\n\n@dataclass\nclass Vote:\n    agent_id: str\n    answer: str          # the voted answer/label\n    confidence: float    # 0.0\u20131.0\n    reasoning: str       # brief justification\n\nclass VotingState(TypedDict):\n    question: str\n    options: list[str]            # e.g. [\"YES\", \"NO\"] or [\"A\", \"B\", \"C\"]\n    votes: Annotated[list[Vote], operator.add]\n    decision: str\n    confidence: float\n    done: bool\n\ndef init_voting(question: str, options: list[str]) -> VotingState:\n    return {\n        \"question\": question,\n        \"options\": options,\n        \"votes\": [],\n        \"decision\": \"\",\n        \"confidence\": 0.0,\n        \"done\": False,\n    }"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Voter Agents: Blind Independent Evaluation"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_anthropic import ChatAnthropic\nfrom langchain_core.messages import SystemMessage, HumanMessage\nimport json, re\n\nvoter_llm = ChatAnthropic(model=\"claude-haiku-4-5-20251001\")\n\ndef make_voter(agent_id: str):\n    \"\"\"Factory: creates a blind voter node (does not see other votes).\"\"\"\n    def voter_node(state: VotingState) -> dict:\n        opts = \", \".join(state[\"options\"])\n        prompt = f\"\"\"Question: {state['question']}\n\nOptions: {opts}\n\nEvaluate independently. Choose the best option and state your confidence (0.0-1.0).\nReply as JSON only: {{\"answer\": \"YES\", \"confidence\": 0.85, \"reasoning\": \"...\"}}\"\"\"\n        response = voter_llm.invoke([\n            SystemMessage(content=f\"You are voter {agent_id}. Be accurate and concise.\"),\n            HumanMessage(content=prompt)\n        ])\n\n        raw = re.search(r'\\{.*?\\}', response.content, re.DOTALL)\n        data = json.loads(raw.group()) if raw else {}\n\n        # Validate the answer is one of the allowed options\n        answer = data.get(\"answer\", \"\").strip()\n        if answer not in state[\"options\"]:\n            answer = state[\"options\"][0]   # fallback to first option\n\n        vote = Vote(\n            agent_id=agent_id,\n            answer=answer,\n            confidence=float(data.get(\"confidence\", 0.5)),\n            reasoning=data.get(\"reasoning\", \"\")[:200],\n        )\n        return {\"votes\": [vote]}\n\n    voter_node.__name__ = f\"voter_{agent_id}\"\n    return voter_node\n\n# Create 5 independent voters\nvoters = {f\"voter_{i}\": make_voter(f\"v{i}\") for i in range(5)}"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Aggregator: Counting and Weighting Votes"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from collections import defaultdict\n\nQUORUM = 3   # minimum votes needed to declare a winner\n\ndef aggregate_votes(state: VotingState) -> dict:\n    \"\"\"Tallies votes; supports both simple majority and confidence-weighted.\"\"\"    votes = state[\"votes\"]\n    if not votes:\n        return {\"decision\": \"ABSTAIN\", \"confidence\": 0.0, \"done\": True}\n\n    # Simple count\n    counts: dict[str, int] = defaultdict(int)\n    conf_sums: dict[str, float] = defaultdict(float)\n    for v in votes:\n        counts[v.answer] += 1\n        conf_sums[v.answer] += v.confidence\n\n    # Find majority\n    winner = max(counts, key=lambda a: (counts[a], conf_sums[a]))\n    vote_count = counts[winner]\n    avg_conf = conf_sums[winner] / vote_count\n    vote_ratio = vote_count / len(votes)   # e.g. 4/5 = 0.8\n\n    # Quorum check \u2014 refuse to decide if no option meets the threshold\n    if vote_count < QUORUM:\n        return {\"decision\": \"INCONCLUSIVE\", \"confidence\": vote_ratio, \"done\": True}\n\n    return {\n        \"decision\": winner,\n        \"confidence\": avg_conf * vote_ratio,   # penalize split votes\n        \"done\": True,\n    }\n\ndef print_vote_summary(state: VotingState) -> None:\n    counts: dict[str, int] = defaultdict(int)\n    for v in state[\"votes\"]:\n        counts[v.answer] += 1\n    print(f\"Decision: {state['decision']} ({state['confidence']:.0%} confidence)\")\n    for answer, count in sorted(counts.items(), key=lambda x: -x[1]):\n        marker = \"\u2190 winner\" if answer == state[\"decision\"] else \"\"\n        print(f\"  {answer}: {count}/{len(state['votes'])} votes  {marker}\")"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Wiring the Voting Graph with Parallel Send"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langgraph.graph import StateGraph, END\nfrom langgraph.types import Send\n\ndef dispatch_voters(state: VotingState) -> list[Send]:\n    \"\"\"Fan out all voters simultaneously \u2014 they vote in parallel.\"\"\"    return [Send(name, state) for name in voters.keys()]\n\nbuilder = StateGraph(VotingState)\n\n# Add voter nodes\nfor name, node_fn in voters.items():\n    builder.add_node(name, node_fn)\n\nbuilder.add_node(\"aggregate\", aggregate_votes)\n\n# Entry: fan out voters in parallel\nbuilder.set_entry_point(\"dispatch\")\nbuilder.add_node(\"dispatch\", lambda s: {})  # no-op dispatcher\nbuilder.add_conditional_edges(\"dispatch\", dispatch_voters)\n\n# All voters converge to aggregator\nfor name in voters.keys():\n    builder.add_edge(name, \"aggregate\")\n\nbuilder.add_edge(\"aggregate\", END)\n\nvoting_graph = builder.compile()"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Running a Vote"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Binary decision\nstate = voting_graph.invoke(init_voting(\n    question=\"Is the following Python code free of security vulnerabilities? \"\n             \"def get_user(uid): return db.execute(f'SELECT * FROM users WHERE id={uid}')\",\n    options=[\"YES\", \"NO\"]\n))\nprint_vote_summary(state)\n# Decision: NO (91% confidence)\n# NO: 5/5 votes  \u2190 winner\n\n# Multi-option decision\nstate2 = voting_graph.invoke(init_voting(\n    question=\"Which sorting algorithm is best for nearly-sorted data of 10,000 items?\",\n    options=[\"QuickSort\", \"MergeSort\", \"TimSort\", \"HeapSort\"]\n))\nprint_vote_summary(state2)\n# Decision: TimSort (78% confidence)\n# TimSort: 4/5 votes  \u2190 winner\n# MergeSort: 1/5 votes"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Weighted Voting: Confidence and Expertise"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Simple majority treats all voters equally. Weighted voting assigns higher influence to voters with proven expertise or higher stated confidence. This is useful when agents have different specializations."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Per-voter expertise weights (pre-assigned or learned from past performance)\nVOTER_WEIGHTS = {\n    \"v0\": 1.0,   # generalist\n    \"v1\": 1.5,   # domain expert on security questions\n    \"v2\": 1.0,\n    \"v3\": 0.8,   # less reliable on technical topics\n    \"v4\": 1.2,\n}\n\ndef weighted_aggregate(state: VotingState) -> dict:\n    \"\"\"Confidence \u00d7 expertise weight determines winner.\"\"\"    weighted_scores: dict[str, float] = defaultdict(float)\n    vote_counts: dict[str, int] = defaultdict(int)\n\n    for v in state[\"votes\"]:\n        weight = VOTER_WEIGHTS.get(v.agent_id, 1.0)\n        weighted_scores[v.answer] += v.confidence * weight\n        vote_counts[v.answer] += 1\n\n    if not weighted_scores:\n        return {\"decision\": \"ABSTAIN\", \"confidence\": 0.0, \"done\": True}\n\n    winner = max(weighted_scores, key=lambda a: weighted_scores[a])\n    total_weight = sum(VOTER_WEIGHTS.get(v.agent_id, 1.0) for v in state[\"votes\"])\n    normalized_conf = weighted_scores[winner] / total_weight\n\n    return {\"decision\": winner, \"confidence\": normalized_conf, \"done\": True}"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Handling Ties and Low-Confidence Results"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_anthropic import ChatAnthropic\n\ntiebreaker_llm = ChatAnthropic(model=\"claude-opus-4-8\")\n\ndef tiebreaker_node(state: VotingState) -> dict:\n    \"\"\"Used when the vote is inconclusive (tie or low confidence).\"\"\"    vote_summary = \"\\n\".join(\n        f\"  {v.agent_id}: {v.answer} ({v.confidence:.0%}) \u2014 {v.reasoning}\"\n        for v in state[\"votes\"]\n    )\n    response = tiebreaker_llm.invoke([\n        SystemMessage(content=\"You are a tiebreaker judge. Review the split votes and make a final decision.\"),\n        HumanMessage(content=f\"Question: {state['question']}\\n\\nVotes:\\n{vote_summary}\\n\\nOptions: {state['options']}\\nDecide.\")\n    ])\n    import re\n    for opt in state[\"options\"]:\n        if opt.lower() in response.content.lower():\n            return {\"decision\": opt, \"confidence\": 0.6, \"done\": True}\n    return {\"decision\": state[\"options\"][0], \"confidence\": 0.5, \"done\": True}\n\ndef route_after_aggregate(state: VotingState) -> str:\n    if state[\"decision\"] == \"INCONCLUSIVE\":\n        return \"tiebreaker\"\n    return \"__end__\"\n\nbuilder.add_node(\"tiebreaker\", tiebreaker_node)\nbuilder.add_conditional_edges(\"aggregate\", route_after_aggregate, {\n    \"tiebreaker\": \"tiebreaker\",\n    \"__end__\": END,\n})\nbuilder.add_edge(\"tiebreaker\", END)"
          }
        ]
      },
