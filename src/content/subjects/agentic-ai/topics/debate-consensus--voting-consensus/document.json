      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import pytest\nfrom collections import defaultdict\n\nclass TestAggregateVotes:\n    def _state(self, votes):\n        return {\n            \"question\": \"Q?\", \"options\": [\"YES\", \"NO\"],\n            \"votes\": votes, \"decision\": \"\", \"confidence\": 0.0, \"done\": False,\n        }\n    \n    def test_majority_wins(self):\n        votes = [\n            Vote(\"v0\", \"YES\", 0.9, \"\"), Vote(\"v1\", \"YES\", 0.8, \"\"),\n            Vote(\"v2\", \"YES\", 0.7, \"\"), Vote(\"v3\", \"NO\", 0.6, \"\"),\n            Vote(\"v4\", \"NO\", 0.5, \"\"),\n        ]\n        result = aggregate_votes(self._state(votes))\n        assert result[\"decision\"] == \"YES\"\n    \n    def test_unanimous_gives_high_confidence(self):\n        votes = [Vote(f\"v{i}\", \"YES\", 0.9, \"\") for i in range(5)]\n        result = aggregate_votes(self._state(votes))\n        assert result[\"confidence\"] > 0.8\n    \n    def test_tie_returns_inconclusive(self):\n        votes = [\n            Vote(\"v0\", \"YES\", 0.7, \"\"), Vote(\"v1\", \"YES\", 0.7, \"\"),\n            Vote(\"v2\", \"NO\", 0.8, \"\"), Vote(\"v3\", \"NO\", 0.8, \"\"),\n        ]\n        result = aggregate_votes(self._state(votes))\n        # 2/4 = not enough for quorum of 3\n        assert result[\"decision\"] == \"INCONCLUSIVE\"\n    \n    def test_empty_votes_returns_abstain(self):\n        result = aggregate_votes(self._state([]))\n        assert result[\"decision\"] == \"ABSTAIN\"\n    \n    def test_invalid_answer_falls_back(self):\n        # Voter returns an option not in the allowed list\n        state = {\"question\": \"Q?\", \"options\": [\"A\", \"B\"], \"votes\": [], \"decision\": \"\", \"confidence\": 0.0, \"done\": False}\n        # Simulate voter with invalid answer\n        raw_answer = \"maybe\"\n        corrected = raw_answer if raw_answer in state[\"options\"] else state[\"options\"][0]\n        assert corrected == \"A\""
          }
