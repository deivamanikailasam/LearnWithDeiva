        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Comparing Multi-Agent vs Single-Agent Cost"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "@dataclass\nclass CostBenefit:\n    single_agent_calls: int = 1\n    multi_agent_calls: int = 0\n    quality_gain: float = 0.0     # estimated accuracy improvement\n    latency_ms: float = 0.0\n    cost_ratio: float = 0.0       # multi / single\n\ndef compute_cost_benefit(metrics: ReasoningMetrics) -> CostBenefit:\n    # Multi-agent costs: N voters + optional tiebreaker + optional debrief\n    total_calls = metrics.total_llm_calls\n    single_calls = 1\n\n    # Heuristic: quality gain is roughly correlated with agreement rate\n    # A unanimous 5-agent vote is more reliable than 1 agent\n    if metrics.agreement_rate >= 0.8 and metrics.avg_confidence >= 0.8:\n        quality_gain = 0.15   # ~15% fewer errors vs single agent (rough estimate)\n    elif metrics.agreement_rate >= 0.6:\n        quality_gain = 0.08\n    else:\n        quality_gain = 0.02   # contested \u2014 hard to say we did better\n\n    return CostBenefit(\n        single_agent_calls=single_calls,\n        multi_agent_calls=total_calls,\n        quality_gain=quality_gain,\n        cost_ratio=total_calls / single_calls,\n    )\n\ndef print_cost_benefit(cb: CostBenefit) -> None:\n    print(f\"Calls: {cb.single_agent_calls} (single) vs {cb.multi_agent_calls} (multi-agent)\")\n    print(f\"Cost ratio: {cb.cost_ratio:.1f}x\")\n    print(f\"Estimated quality gain: {cb.quality_gain:.0%}\")\n    if cb.cost_ratio <= 3 and cb.quality_gain >= 0.10:\n        print(\"Recommendation: WORTH IT\")\n    elif cb.cost_ratio > 5 and cb.quality_gain < 0.05:\n        print(\"Recommendation: MARGINAL \u2014 consider single-agent + retry\")\n    else:\n        print(\"Recommendation: CONTEXT-DEPENDENT\")"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Logging Metrics to LangSmith"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langsmith import Client\n\nls_client = Client()\n\ndef log_reasoning_metrics(run_id: str, metrics: ReasoningMetrics, task: str) -> None:\n    \"\"\"Log aggregate metrics to LangSmith for a completed reasoning run.\"\"\"    ls_client.create_feedback(\n        run_id=run_id,\n        key=\"agreement_rate\",\n        score=metrics.agreement_rate,\n        comment=f\"Winning answer: {metrics.winning_answer}\"\n    )\n    ls_client.create_feedback(\n        run_id=run_id,\n        key=\"avg_confidence\",\n        score=metrics.avg_confidence,\n    )\n    if metrics.failing_dimensions:\n        ls_client.create_feedback(\n            run_id=run_id,\n            key=\"failing_critics\",\n            score=0,\n            comment=\", \".join(metrics.failing_dimensions),\n        )\n    if metrics.min_critic_score > 0:\n        ls_client.create_feedback(\n            run_id=run_id,\n            key=\"min_critic_score\",\n            score=metrics.min_critic_score / 10,\n        )"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing Metric Computation"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import pytest\nfrom dataclasses import dataclass\n\n@dataclass\nclass MockVote:\n    answer: str\n    confidence: float\n\n@dataclass\nclass MockCritique:\n    dimension: str\n    score: int\n\nclass TestVotingMetrics:\n    def test_unanimous_vote_gives_full_agreement(self):\n        votes = [MockVote(\"YES\", 0.9) for _ in range(5)]\n        m = compute_voting_metrics(votes)\n        assert m.agreement_rate == 1.0\n        assert m.dissent_ratio == 0.0\n        assert m.winning_answer == \"YES\"\n\n    def test_split_vote_computes_ratio(self):\n        votes = [MockVote(\"YES\", 0.8)] * 3 + [MockVote(\"NO\", 0.7)] * 2\n        m = compute_voting_metrics(votes)\n        assert abs(m.agreement_rate - 0.6) < 0.01\n        assert abs(m.dissent_ratio - 0.4) < 0.01\n\n    def test_confidence_is_averaged(self):\n        votes = [MockVote(\"YES\", 0.8), MockVote(\"YES\", 0.6)]\n        m = compute_voting_metrics(votes)\n        assert abs(m.avg_confidence - 0.7) < 0.01\n\nclass TestCritiqueMetrics:\n    def test_detects_failing_dimensions(self):\n        critiques = [\n            MockCritique(\"accuracy\", 8),\n            MockCritique(\"safety\", 5),   # below 7\n            MockCritique(\"style\", 7),\n        ]\n        m = compute_critique_metrics(critiques, revision_count=1)\n        assert \"safety\" in m.failing_dimensions\n        assert m.min_critic_score == 5\n\n    def test_no_failures_when_all_above_threshold(self):\n        critiques = [MockCritique(\"accuracy\", 8), MockCritique(\"safety\", 9)]\n        m = compute_critique_metrics(critiques, revision_count=0)\n        assert m.failing_dimensions == []\n\nclass TestQualityClassification:\n    def test_high_agreement_high_confidence_is_high(self):\n        m = ReasoningMetrics(agreement_rate=0.9, avg_confidence=0.85)\n        assert classify_quality(m) == QualityLevel.HIGH\n\n    def test_low_agreement_is_low(self):\n        m = ReasoningMetrics(agreement_rate=0.4, avg_confidence=0.5)\n        assert classify_quality(m) == QualityLevel.LOW"
          }
        ]
      },
