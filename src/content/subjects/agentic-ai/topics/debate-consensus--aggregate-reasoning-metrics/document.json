      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "ReasoningMetrics Dataclass"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass, field\nfrom typing import Optional\nfrom collections import Counter\n\n@dataclass\nclass ReasoningMetrics:\n    # Voting metrics\n    agreement_rate: float = 0.0       # 0.0\u20131.0\n    avg_confidence: float = 0.0\n    dissent_ratio: float = 0.0\n    winning_answer: str = \"\"\n    vote_distribution: dict[str, int] = field(default_factory=dict)\n\n    # Critique metrics\n    min_critic_score: int = 0\n    avg_critic_score: float = 0.0\n    failing_dimensions: list[str] = field(default_factory=list)\n    revision_count: int = 0\n\n    # Debate metrics\n    debate_rounds: int = 0\n    consensus_reached: bool = False\n    judge_confidence: float = 0.0\n\n    # Cost / efficiency\n    total_llm_calls: int = 0\n    agent_count: int = 0\n\ndef compute_voting_metrics(votes: list) -> ReasoningMetrics:\n    \"\"\"Compute metrics from a completed voting round.\"\"\"    if not votes:\n        return ReasoningMetrics()\n\n    # Vote distribution\n    distribution = Counter(v.answer for v in votes)\n    winner = distribution.most_common(1)[0][0]\n    winner_count = distribution[winner]\n    total = len(votes)\n\n    return ReasoningMetrics(\n        agreement_rate=winner_count / total,\n        avg_confidence=sum(v.confidence for v in votes) / total,\n        dissent_ratio=1 - (winner_count / total),\n        winning_answer=winner,\n        vote_distribution=dict(distribution),\n        agent_count=total,\n        total_llm_calls=total,\n    )\n\ndef compute_critique_metrics(critiques: list, revision_count: int) -> ReasoningMetrics:\n    \"\"\"Compute metrics from a critique loop.\"\"\"    if not critiques:\n        return ReasoningMetrics()\n\n    scores = [c.score for c in critiques]\n    failing = [c.dimension for c in critiques if c.score < 7]\n\n    return ReasoningMetrics(\n        min_critic_score=min(scores),\n        avg_critic_score=sum(scores) / len(scores),\n        failing_dimensions=failing,\n        revision_count=revision_count,\n        agent_count=len(critiques),\n        total_llm_calls=len(critiques) * (revision_count + 1),\n    )"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Tracking Metrics Across Revisions"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from typing_extensions import TypedDict\nimport operator\nfrom typing import Annotated\n\nclass MetricsState(TypedDict):\n    # Extend any existing state with a metrics history\n    metrics_history: Annotated[list[ReasoningMetrics], operator.add]\n\ndef metrics_node(state: dict) -> dict:\n    \"\"\"Snapshot metrics after each revision cycle.\"\"\"    critiques = state.get(\"critiques\", [])\n    revision_count = state.get(\"revision_count\", 0)\n    votes = state.get(\"votes\", [])\n\n    if votes:\n        m = compute_voting_metrics(votes)\n    elif critiques:\n        m = compute_critique_metrics(critiques, revision_count)\n    else:\n        return {}\n\n    return {\"metrics_history\": [m]}\n\ndef print_metrics_trend(history: list[ReasoningMetrics]) -> None:\n    \"\"\"Print how metrics evolved across revisions.\"\"\"    print(f\"{'Rev':>4} {'MinScore':>9} {'AvgScore':>9} {'Failing':>20} {'Calls':>6}\")\n    print(\"-\" * 55)\n    for i, m in enumerate(history):\n        failing = \", \".join(m.failing_dimensions) if m.failing_dimensions else \"none\"\n        print(f\"{i:>4} {m.min_critic_score:>9} {m.avg_critic_score:>9.1f} {failing:>20} {m.total_llm_calls:>6}\")"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Quality Thresholds and Escalation Rules"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from enum import Enum\n\nclass QualityLevel(Enum):\n    HIGH = \"high\"       # ship it\n    MEDIUM = \"medium\"   # flag for review\n    LOW = \"low\"         # block or escalate\n\ndef classify_quality(metrics: ReasoningMetrics) -> QualityLevel:\n    \"\"\"Classify overall reasoning quality from aggregate metrics.\"\"\"    # Voting-based classification\n    if metrics.agreement_rate > 0:\n        if metrics.agreement_rate >= 0.8 and metrics.avg_confidence >= 0.8:\n            return QualityLevel.HIGH\n        elif metrics.agreement_rate >= 0.6 or metrics.avg_confidence >= 0.6:\n            return QualityLevel.MEDIUM\n        else:\n            return QualityLevel.LOW\n\n    # Critique-based classification\n    if metrics.min_critic_score > 0:\n        if metrics.min_critic_score >= 8 and not metrics.failing_dimensions:\n            return QualityLevel.HIGH\n        elif metrics.min_critic_score >= 6:\n            return QualityLevel.MEDIUM\n        else:\n            return QualityLevel.LOW\n\n    return QualityLevel.LOW\n\ndef escalation_action(level: QualityLevel, metrics: ReasoningMetrics) -> str:\n    \"\"\"Decide what to do based on quality level.\"\"\"    if level == QualityLevel.HIGH:\n        return \"approve\"\n    elif level == QualityLevel.MEDIUM:\n        if metrics.dissent_ratio > 0.3:\n            return \"human_review\"   # significant minority \u2014 flag for human\n        return \"approve_with_note\"\n    else:\n        if metrics.revision_count >= 3:\n            return \"human_escalate\"   # critique loop exhausted\n        return \"retry\"\n\n# Example decision pipeline\ndef make_shipping_decision(state: dict) -> dict:\n    critiques = state.get(\"critiques\", [])\n    revision_count = state.get(\"revision_count\", 0)\n\n    metrics = compute_critique_metrics(critiques, revision_count)\n    level = classify_quality(metrics)\n    action = escalation_action(level, metrics)\n\n    print(f\"Quality: {level.value}  Action: {action}\")\n    print(f\"  Min score: {metrics.min_critic_score}  Avg: {metrics.avg_critic_score:.1f}\")\n    print(f\"  Failing: {metrics.failing_dimensions or 'none'}\")\n\n    return {\"shipping_action\": action, \"quality_level\": level.value}"
          }
        ]
      },
