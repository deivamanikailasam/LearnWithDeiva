      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing Zapier-Backed Agents"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Mock the "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "requests"
          },
          {
            "type": "text",
            "text": " layer \u2014 never call real Zapier actions in tests. Patch both "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "requests.get"
          },
          {
            "type": "text",
            "text": " (for listing tools) and "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "requests.post"
          },
          {
            "type": "text",
            "text": " (for executing) independently."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import unittest\nfrom unittest.mock import patch, MagicMock\n\nclass TestZapierAgent(unittest.TestCase):\n\n    @patch(\"requests.get\")\n    def test_list_tools_returns_claude_schema(self, mock_get):\n        mock_get.return_value.json.return_value = {\n            \"results\": [\n                {\n                    \"id\": \"01ABC_send_gmail\",\n                    \"description\": \"Send an email via Gmail.\",\n                    \"params\": {\n                        \"type\": \"object\",\n                        \"properties\": {\"instructions\": {\"type\": \"string\"}},\n                        \"required\": [\"instructions\"],\n                    },\n                }\n            ]\n        }\n        mock_get.return_value.raise_for_status = MagicMock()\n\n        tools = list_zapier_tools()\n        self.assertEqual(len(tools), 1)\n        self.assertEqual(tools[0][\"name\"], \"01ABC_send_gmail\")\n        self.assertIn(\"input_schema\", tools[0])\n\n    @patch(\"requests.post\")\n    def test_execute_success(self, mock_post):\n        mock_post.return_value.json.return_value = {\n            \"status\": \"success\",\n            \"result\": \"Email sent.\",\n            \"action_used\": \"Gmail: Send Email\",\n        }\n        mock_post.return_value.raise_for_status = MagicMock()\n\n        result = execute_zapier_action(\"01ABC_send_gmail\", \"Send hello to bob@example.com\")\n        self.assertEqual(result[\"status\"], \"success\")\n        self.assertEqual(result[\"result\"], \"Email sent.\")\n\n    @patch(\"requests.post\")\n    def test_execute_rate_limit_retry(self, mock_post):\n        rate_resp = MagicMock()\n        rate_resp.status_code = 429\n        rate_resp.headers = {\"Retry-After\": \"0\"}\n\n        ok_resp = MagicMock()\n        ok_resp.status_code = 200\n        ok_resp.json.return_value = {\"status\": \"success\", \"result\": \"Done.\"}\n        ok_resp.raise_for_status = MagicMock()\n\n        mock_post.side_effect = [rate_resp, ok_resp]\n\n        result = execute_with_retry(\"01ABC_send_gmail\", \"Send hello\")\n        self.assertEqual(result[\"status\"], \"success\")\n        self.assertEqual(mock_post.call_count, 2)\n\nif __name__ == \"__main__\":\n    unittest.main()\n"
          }
        ]
      },
