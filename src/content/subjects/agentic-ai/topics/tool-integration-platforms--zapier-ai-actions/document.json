    "content": [
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Zapier AI Actions"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Zapier AI Actions (NLA \u2014 Natural Language Actions) lets Claude trigger automations across 6,000+ connected apps using plain-English instructions. Instead of writing app-specific API clients, you enable a set of Zapier actions in a dashboard and receive one REST endpoint that Claude can call with a single "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "instructions"
          },
          {
            "type": "text",
            "text": " string per action."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Zapier AI Actions architecture diagram"
        }
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "NLA is user-scoped: each user enables their own apps and receives their own API key. The key is never held by the model \u2014 only by your server-side tool dispatcher."
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Installation and Setup"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Zapier AI Actions requires no additional Python packages beyond "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "anthropic"
          },
          {
            "type": "text",
            "text": " and "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "requests"
          },
          {
            "type": "text",
            "text": ". Authentication is a per-user API key obtained from the Zapier dashboard ("
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "zapier.com/l/natural-language-actions"
          },
          {
            "type": "text",
            "text": ") after enabling desired actions."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "bash"
        },
        "content": [
          {
            "type": "text",
            "text": "pip install anthropic requests\n"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Zapier NLA uses per-user API keys obtained from the Zapier dashboard.\n# Store them in an environment variable or secret manager \u2014 never in code.\n\nimport os\n\ndef get_nla_key(user_id: str) -> str:\n    \"\"\"\n    Retrieve the Zapier NLA API key for a given user.\n    In production, fetch from your secret store (Vault, AWS SSM, etc.).\n    \"\"\"\n    # For single-user scripts:\n    key = os.environ.get(\"ZAPIER_NLA_API_KEY\")\n    if not key:\n        raise EnvironmentError(\"ZAPIER_NLA_API_KEY is not set.\")\n    return key\n\n# For multi-user applications, map user IDs to keys stored in your database:\n# key = db.query(\"SELECT zapier_nla_key FROM users WHERE id = %s\", [user_id])\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Listing Available Actions"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "GET /api/v1/exposed/"
          },
          {
            "type": "text",
            "text": " endpoint returns one entry per enabled action, already formatted as a Claude "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "tool"
          },
          {
            "type": "text",
            "text": " dict with "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "name"
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "description"
          },
          {
            "type": "text",
            "text": ", and "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "input_schema"
          },
          {
            "type": "text",
            "text": "."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import os\nimport requests\n\nNLA_KEY = os.environ[\"ZAPIER_NLA_API_KEY\"]\nBASE_URL = \"https://actions.zapier.com/api/v1\"\n\ndef list_zapier_tools() -> list[dict]:\n    \"\"\"Return Claude-ready tool dicts for every enabled Zapier action.\"\"\"\n    resp = requests.get(\n        f\"{BASE_URL}/exposed/\",\n        headers={\"x-api-key\": NLA_KEY},\n        timeout=10,\n    )\n    resp.raise_for_status()\n    actions = resp.json().get(\"results\", [])\n\n    tools = []\n    for action in actions:\n        # Each action already ships with an input_schema Zapier generates\n        tools.append({\n            \"name\": action[\"id\"],           # e.g. \"01HXYZABC_send_gmail\"\n            \"description\": action[\"description\"],\n            \"input_schema\": action.get(\"params\", {\n                \"type\": \"object\",\n                \"properties\": {\n                    \"instructions\": {\n                        \"type\": \"string\",\n                        \"description\": \"Plain-English instruction for the action.\"\n                    }\n                },\n                \"required\": [\"instructions\"]\n            }),\n        })\n    return tools\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Each action's "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "id"
          },
          {
            "type": "text",
            "text": " is a Zapier-assigned stable identifier (e.g. "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "01HXYZABC_send_gmail"
          },
          {
            "type": "text",
            "text": "). The description is auto-generated by Zapier from the action's template."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Executing a Single Action"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "To execute an action, POST to "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "/api/v1/exposed/{action_id}/execute/"
          },
          {
            "type": "text",
            "text": " with an "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "instructions"
          },
          {
            "type": "text",
            "text": " string. Zapier parses the instruction, maps fields to the underlying app's API, calls it, and returns a structured result."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def execute_zapier_action(action_id: str, instructions: str) -> dict:\n    \"\"\"Call a single Zapier NLA action by its ID.\"\"\"\n    resp = requests.post(\n        f\"{BASE_URL}/exposed/{action_id}/execute/\",\n        headers={\"x-api-key\": NLA_KEY, \"Content-Type\": \"application/json\"},\n        json={\"instructions\": instructions},\n        timeout=30,\n    )\n    resp.raise_for_status()\n    result = resp.json()\n    # result[\"action_used\"] \u2014 what Zapier actually ran\n    # result[\"result\"]     \u2014 the action outcome (string or dict)\n    # result[\"status\"]     \u2014 \"success\" | \"error\"\n    return {\n        \"status\": result.get(\"status\"),\n        \"result\": result.get(\"result\"),\n        \"action\": result.get(\"action_used\"),\n    }\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "instructions"
          },
          {
            "type": "text",
            "text": " field drives Zapier's NLP layer. Pass only the action-relevant instruction, not the entire conversation \u2014 this reduces ambiguity and keeps the call focused."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Building the Agent Loop"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Wire "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "list_zapier_tools()"
          },
          {
            "type": "text",
            "text": " and "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "execute_zapier_action()"
          },
          {
            "type": "text",
            "text": " into a standard Claude tool-use loop. The agent receives tool schemas on each turn, emits "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "tool_use"
          },
          {
            "type": "text",
            "text": " blocks when it decides to act, and your handler dispatches to Zapier."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\nimport json\n\nclient = anthropic.Anthropic()\n\ndef run_zapier_agent(user_message: str, user_id: str) -> str:\n    \"\"\"Run an agent that can call any enabled Zapier action for this user.\"\"\"\n    tools = list_zapier_tools()     # fetch per-user enabled actions\n    messages = [{\"role\": \"user\", \"content\": user_message}]\n\n    while True:\n        resp = client.messages.create(\n            model=\"claude-sonnet-4-6\",\n            max_tokens=2048,\n            tools=tools,\n            messages=messages,\n        )\n\n        if resp.stop_reason == \"end_turn\":\n            return next(\n                b.text for b in resp.content if hasattr(b, \"text\")\n            )\n\n        if resp.stop_reason != \"tool_use\":\n            break\n\n        # Process all tool_use blocks\n        tool_results = []\n        for block in resp.content:\n            if block.type != \"tool_use\":\n                continue\n            instructions = block.input.get(\"instructions\", json.dumps(block.input))\n            try:\n                outcome = execute_zapier_action(block.id_or_name or block.name, instructions)\n            except requests.HTTPError as exc:\n                outcome = {\"status\": \"error\", \"result\": str(exc)}\n\n            tool_results.append({\n                \"type\": \"tool_result\",\n                \"tool_use_id\": block.id,\n                \"content\": json.dumps(outcome),\n            })\n\n        messages.append({\"role\": \"assistant\", \"content\": resp.content})\n        messages.append({\"role\": \"user\", \"content\": tool_results})\n\n    return \"Agent loop ended unexpectedly.\"\n\n# Example\nreply = run_zapier_agent(\n    \"Send an email to alice@example.com with subject 'Meeting Notes' \"\n    \"and the body 'Thanks for joining today!'\",\n    user_id=\"user_99\"\n)\nprint(reply)\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Multi-User Applications"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "In a product serving many users, each user authenticates separately with Zapier and has a distinct API key. Store those keys in your database and look them up at request time \u2014 never share one user's key with another."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass\n\n@dataclass\nclass UserContext:\n    user_id: str\n    nla_api_key: str   # user-specific key from Zapier dashboard\n\ndef run_agent_for_user(ctx: UserContext, prompt: str) -> str:\n    \"\"\"Run the agent using a specific user's Zapier key.\"\"\"\n    # Temporarily override BASE headers for this request\n    headers = {\"x-api-key\": ctx.nla_api_key}\n\n    resp = requests.get(f\"{BASE_URL}/exposed/\", headers=headers, timeout=10)\n    resp.raise_for_status()\n    actions = resp.json().get(\"results\", [])\n\n    tools = [\n        {\n            \"name\": a[\"id\"],\n            \"description\": a[\"description\"],\n            \"input_schema\": {\n                \"type\": \"object\",\n                \"properties\": {\"instructions\": {\"type\": \"string\"}},\n                \"required\": [\"instructions\"],\n            },\n        }\n        for a in actions\n    ]\n\n    # ... rest of agent loop using ctx.nla_api_key in execute_zapier_action\n    return run_agent_loop(tools, prompt, ctx.nla_api_key)\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The per-user scoping means that when user A asks the agent to send email, only user A's Gmail account is accessible. There is no cross-user data leakage at the Zapier layer."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Error Handling and Rate Limits"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Zapier NLA returns HTTP 429 with a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "Retry-After"
          },
          {
            "type": "text",
            "text": " header when rate-limited. Application-level errors from the underlying app arrive as "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "{\"status\": \"error\"}"
          },
          {
            "type": "text",
            "text": " in the JSON body. Distinguish these two failure modes and handle them separately:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import time\n\ndef execute_with_retry(action_id: str, instructions: str, max_retries: int = 3) -> dict:\n    delay = 1.0\n    for attempt in range(max_retries):\n        try:\n            resp = requests.post(\n                f\"{BASE_URL}/exposed/{action_id}/execute/\",\n                headers={\"x-api-key\": NLA_KEY, \"Content-Type\": \"application/json\"},\n                json={\"instructions\": instructions},\n                timeout=30,\n            )\n            if resp.status_code == 429:\n                retry_after = int(resp.headers.get(\"Retry-After\", delay))\n                time.sleep(retry_after)\n                delay *= 2\n                continue\n            resp.raise_for_status()\n            result = resp.json()\n            if result.get(\"status\") == \"error\":\n                # Application-level error from Zapier \u2014 don't retry\n                return {\"status\": \"error\", \"result\": result.get(\"result\")}\n            return {\"status\": \"success\", \"result\": result.get(\"result\")}\n        except requests.ConnectionError:\n            if attempt == max_retries - 1:\n                raise\n            time.sleep(delay)\n            delay *= 2\n    raise RuntimeError(\"Max retries exceeded\")\n"
          }
        ]
      },
