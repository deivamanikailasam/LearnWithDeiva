              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Default k=60 is robust; adjust downward for top-rank bias, upward for presence-based merging."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
