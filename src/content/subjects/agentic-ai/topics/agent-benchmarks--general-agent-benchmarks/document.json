                    "content": [
                      {
                        "type": "text",
                        "text": "varies"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Retail + airline APIs"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Pass rate % per domain"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Policy constraints + grounding"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Benchmark Limitations and Pitfalls"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Test set contamination"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 if the benchmark tasks appear in model training data, reported scores overstate real capability. Check dataset release dates against model training cutoffs."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Single-run variance"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 agent performance has high variance across runs due to sampling. Report averages over at least 3 independent runs when comparing models."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Environment version drift"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 WebArena web apps and GAIA questions are occasionally updated. Pin the version used when reporting so results are reproducible."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Prompt sensitivity"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 scores can vary significantly with system prompt wording. Publish the exact system prompt used alongside any reported result."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Cost"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 a full WebArena evaluation (812 tasks, 12 steps each) costs roughly 9,700 LLM calls. Use random subsamples during development; run the full suite only for final reporting."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Single-metric reductionism"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 the overall score hides per-domain strengths and weaknesses. Always inspect per-task-type breakdowns, not just the headline number."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Choosing the Right Benchmark for Your Use Case"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Building a web automation agent?"
                  },
                  {
                    "type": "text",
                    "text": " \u2192 WebArena is the primary reference; also run on VisualWebArena if your agent uses vision."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Building a research assistant?"
                  },
                  {
                    "type": "text",
                    "text": " \u2192 GAIA Level 1\u20132 tests the core skill; Level 3 is a stretch goal."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Claiming broad agent capability?"
                  },
                  {
                    "type": "text",
                    "text": " \u2192 AgentBench; the eight-environment breadth makes cherry-picking harder."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Building a customer-service or API-calling agent?"
                  },
                  {
                    "type": "text",
                    "text": " \u2192 tau-bench is the closest to your production task distribution."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "WebArena (812 tasks, 5 web apps) measures long-horizon web navigation; task success requires exact final state match."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "GAIA (466 questions, 3 levels) measures multi-step general QA; Level 3 accuracy below 10% is the frontier today."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "AgentBench (1091 tasks, 8 environments) measures breadth; OS, SQL, and embodied environments in one score."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "tau-bench measures tool-calling accuracy and policy compliance under realistic API schemas."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Report averages over multiple runs, pin environment versions, publish the exact system prompt, and inspect per-domain breakdowns rather than only the headline score."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}