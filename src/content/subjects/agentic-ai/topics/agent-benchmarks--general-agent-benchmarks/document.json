      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Comparing Benchmark Results"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Collecting results across benchmarks in a structured format makes it easy to compare models and track progress over time:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import json\nfrom dataclasses import dataclass\nfrom typing import List, Optional\n\n\n@dataclass\nclass BenchmarkResult:\n    benchmark: str\n    model: str\n    score: float          # primary metric (task success rate or accuracy)\n    n_tasks: int\n    metadata: dict\n\n\ndef compare_results(results: List[BenchmarkResult]) -> None:\n    \"\"\"Print a sorted leaderboard from a list of benchmark results.\"\"\"\n    by_bench: dict = {}\n    for r in results:\n        by_bench.setdefault(r.benchmark, []).append(r)\n\n    for bench, entries in sorted(by_bench.items()):\n        print(f\"\\n=== {bench} ===\")\n        for entry in sorted(entries, key=lambda e: -e.score):\n            print(f\"  {entry.model:30s}  {entry.score:.1%}  (n={entry.n_tasks})\")\n\n\n# Example usage\nresults = [\n    BenchmarkResult(\"WebArena\", \"claude-haiku-4-5-20251001\", 0.152, 812, {}),\n    BenchmarkResult(\"WebArena\", \"gpt-4o\", 0.141, 812, {}),\n    BenchmarkResult(\"GAIA-L1\",  \"claude-haiku-4-5-20251001\", 0.731, 165, {}),\n    BenchmarkResult(\"GAIA-L2\",  \"claude-haiku-4-5-20251001\", 0.432, 223, {}),\n    BenchmarkResult(\"GAIA-L3\",  \"claude-haiku-4-5-20251001\", 0.065,  78, {}),\n]\ncompare_results(results)\n"
          }
        ]
      },
