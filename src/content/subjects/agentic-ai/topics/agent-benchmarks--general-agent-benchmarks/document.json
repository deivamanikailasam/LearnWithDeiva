      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "AgentBench"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "AgentBench evaluates agents across eight environments simultaneously: OS shell, database manipulation, knowledge graph traversal, digital card game, lateral thinking puzzles, web shopping, HouseholdEnv (embodied instructions), and web browsing. The overall score is the weighted average across all environments."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# AgentBench ships its own evaluation harness:\n# git clone https://github.com/THUDM/AgentBench\n# pip install -r requirements.txt\n\n# Each environment is a separate Docker container.\n# The harness calls your model via a standard interface.\n\n# Minimal agent adapter (agentbench expects this interface):\nclass MyAgent:\n    def __init__(self, client):\n        self.client = client\n        self.history = []\n\n    def reset(self, system_prompt: str) -> None:\n        self.history = [{\"role\": \"user\", \"content\": system_prompt}]\n\n    def step(self, observation: str) -> str:\n        self.history.append({\"role\": \"user\", \"content\": observation})\n        response = self.client.messages.create(\n            model=\"claude-haiku-4-5-20251001\",\n            max_tokens=512,\n            messages=self.history,\n        )\n        reply = response.content[0].text\n        self.history.append({\"role\": \"assistant\", \"content\": reply})\n        return reply\n\n\n# Run evaluation:\n# python eval.py --agent my_agent --task os --split test\n# Results appear in results/<task>/<timestamp>/summary.json\n# \"overall_score\" is the weighted average across all 8 environments.\n"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
