      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "tau-bench"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "tau-bench focuses specifically on tool-calling accuracy in customer service scenarios. Agents interact with simulated retail or airline APIs to complete requests from a synthetic customer. The benchmark tests grounding: does the agent call the right API with the right parameters, in the right order, without violating stated policies?"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# tau-bench: https://github.com/sierra-research/tau-bench\n# pip install tau-bench\n\nfrom tau_bench.envs import RetailEnv\nfrom tau_bench.types import Action\nimport anthropic\n\nclient = anthropic.Anthropic()\n\ndef run_tau_task(env_name: str = \"retail\", task_id: int = 0) -> dict:\n    env = RetailEnv(task_id=task_id)\n    obs = env.reset()\n    done = False\n    reward = 0.0\n\n    while not done:\n        # obs contains the customer message and available API docs\n        response = client.messages.create(\n            model=\"claude-haiku-4-5-20251001\",\n            max_tokens=256,\n            messages=[{\"role\": \"user\", \"content\": obs.content}],\n            tools=obs.tools,  # tau-bench provides tool schemas\n        )\n        # extract tool call or text response\n        action = Action.from_anthropic_response(response)\n        obs, reward, done = env.step(action)\n\n    return {\"task_id\": task_id, \"reward\": reward, \"success\": reward == 1.0}\n\n\ndef batch_evaluate_tau(num_tasks: int = 50) -> dict:\n    results = [run_tau_task(task_id=i) for i in range(num_tasks)]\n    pass_rate = sum(r[\"success\"] for r in results) / len(results)\n    return {\"pass_rate\": pass_rate, \"n\": num_tasks}\n"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
