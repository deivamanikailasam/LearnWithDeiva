      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "How to implement"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def build_context(docs: list[dict], token_budget: int) -> list[dict]:\n    ranked = sorted(docs, key=lambda d: d[\"score\"], reverse=True)\n    selected, used = [], 0\n    for doc in ranked:\n        t = doc[\"tokens\"]\n        if used + t > token_budget:\n            break\n        selected.append(doc)\n        used += t\n    return selected"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Examples"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Two-pointer merge of sorted message timelines\ndef merge_timelines(a: list[dict], b: list[dict]) -> list[dict]:\n    i = j = 0\n    out = []\n    while i < len(a) and j < len(b):\n        if a[i][\"ts\"] <= b[j][\"ts\"]:\n            out.append(a[i]); i += 1\n        else:\n            out.append(b[j]); j += 1\n    return out + a[i:] + b[j:]"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Real-world example"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A research agent collects citations from multiple tools, deduplicates by URL, sorts by relevance score, and takes top-k for the prompt:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def consolidate(hits: list[dict], k: int) -> list[dict]:\n    by_url: dict[str, dict] = {}\n    for h in hits:\n        url = h[\"url\"]\n        if url not in by_url or h[\"score\"] > by_url[url][\"score\"]:\n            by_url[url] = h\n    return heapq.nlargest(k, by_url.values(), key=lambda x: x[\"score\"])"
          }
        ]
      },
