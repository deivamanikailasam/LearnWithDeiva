      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Sorting and top-k"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "docs = [{\"id\": \"a\", \"score\": 0.9}, {\"id\": \"b\", \"score\": 0.7}]\n\n# Full sort O(n log n)\nranked = sorted(docs, key=lambda d: d[\"score\"], reverse=True)\n\n# Top-k O(n log k)\nimport heapq\ntop3 = heapq.nlargest(3, docs, key=lambda d: d[\"score\"])"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Linear and binary search"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Linear O(n) — unsorted tool list\nfor t in tools:\n    if t.name == target:\n        return t\n\n# Binary search O(log n) — sorted ids\nimport bisect\nids = sorted(doc_ids)\ni = bisect.bisect_left(ids, target_id)\nif i < len(ids) and ids[i] == target_id:\n    ..."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "BFS and DFS on graphs"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from collections import deque\n\ndef bfs(start: str, graph: dict[str, list[str]]) -> list[str]:\n    order, seen, q = [], set(), deque([start])\n    while q:\n        node = q.popleft()\n        if node in seen:\n            continue\n        seen.add(node)\n        order.append(node)\n        q.extend(graph.get(node, []))\n    return order"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Merge sorted streams"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def merge_by_score(a: list[dict], b: list[dict], k: int) -> list[dict]:\n    merged = sorted(a + b, key=lambda x: x[\"score\"], reverse=True)\n    return merged[:k]"
          }
        ]
      },
