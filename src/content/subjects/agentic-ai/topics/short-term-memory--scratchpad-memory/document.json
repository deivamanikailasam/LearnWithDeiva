          {
            "type": "text",
            "text": "Testing Scratchpad Behaviour"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import pytest\n\ndef test_extract_answer_both_sections():\n    raw = \"\"\"\n<scratchpad>\nThought: Need sales data.\nPlan: Call search tool.\nObservation: Revenue $2.4M.\n</scratchpad>\n<answer>\nQ3 revenue was $2.4M.\n</answer>\"\"\".strip()\n    sp, ans = extract_answer(raw)\n    assert \"Revenue $2.4M\" in sp\n    assert \"Q3 revenue\" in ans\n\n\ndef test_extract_answer_missing_scratchpad():\n    raw = \"<answer>42</answer>\"\n    sp, ans = extract_answer(raw)\n    assert sp == \"\"\n    assert ans == \"42\"\n\n\ndef test_scratchpad_entry_roundtrip():\n    entry = ScratchpadEntry(\n        thought=\"Need Q3 data\",\n        plan=\"search(Q3 report)\",\n        observation=\"Revenue $2.4M\",\n    )\n    block = entry.to_prompt_block()\n    recovered = ScratchpadEntry.from_text(block)\n    assert recovered.thought == entry.thought\n    assert recovered.observation == entry.observation\n\n\ndef test_persistent_scratchpad_caps_at_five():\n    ps = PersistentScratchpad()\n    for i in range(8):\n        ps.add(ScratchpadEntry(partial_answer=f\"answer {i}\"))\n    assert len(ps.entries) == 5\n    assert ps.latest_partial_answer() == \"answer 7\"\n"
          }
        ]
