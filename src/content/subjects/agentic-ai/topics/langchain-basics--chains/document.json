      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Building a Basic Chain"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_anthropic import ChatAnthropic\nfrom langchain_core.prompts import ChatPromptTemplate\nfrom langchain_core.output_parsers import StrOutputParser\n\nllm = ChatAnthropic(model=\"claude-haiku-4-5-20251001\")\n\nprompt = ChatPromptTemplate.from_messages([\n    (\"system\", \"You are a concise technical writer.\"),\n    (\"human\", \"Explain {topic} in one paragraph.\"),\n])\n\n# Build the chain with the pipe operator\nchain = prompt | llm | StrOutputParser()\n\n# Synchronous invocation\nresult = chain.invoke({\"topic\": \"LangChain Expression Language\"})\nprint(result)  # str\n\n# Streaming \u2014 print each token as it arrives\nfor chunk in chain.stream({\"topic\": \"vector databases\"}):\n    print(chunk, end=\"\", flush=True)\nprint()  # newline after stream\n\n# Async\nimport asyncio\n\nasync def run_async():\n    result = await chain.ainvoke({\"topic\": \"embeddings\"})\n    return result\n\n# Batch \u2014 parallel inference for multiple inputs\nresults = chain.batch([\n    {\"topic\": \"LLMs\"},\n    {\"topic\": \"agents\"},\n    {\"topic\": \"RAG\"},\n])\nfor r in results:\n    print(r[:80])"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Injecting Custom Logic with RunnableLambda"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Wrap any Python function as a ",
            "marks": []
          },
          {
            "type": "text",
            "text": "Runnable",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " with ",
            "marks": []
          },
          {
            "type": "text",
            "text": "RunnableLambda",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". This lets ordinary functions participate in the pipe chain with the same streaming and async support:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_core.runnables import RunnableLambda\n\n\ndef clean_output(text: str) -> str:\n    \"\"\"Strip markdown fences and extra whitespace.\"\"\"\n    text = text.strip()\n    if text.startswith(\"```\"):\n        lines = text.split(\"\\n\")\n        text = \"\\n\".join(lines[1:-1])\n    return text\n\n\ndef add_metadata(text: str) -> dict:\n    \"\"\"Wrap output in a dict with metadata.\"\"\"\n    return {\n        \"content\": text,\n        \"length\": len(text),\n        \"word_count\": len(text.split()),\n    }\n\n\n# Chain with post-processing steps\nchain_with_meta = (\n    prompt\n    | llm\n    | StrOutputParser()\n    | RunnableLambda(clean_output)\n    | RunnableLambda(add_metadata)\n)\n\nresult = chain_with_meta.invoke({\"topic\": \"tokenisation\"})\nprint(result[\"word_count\"])  # int\nprint(result[\"content\"][:100])"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Parallel Branches with RunnableParallel"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Run multiple chains in parallel and merge their outputs with ",
            "marks": []
          },
          {
            "type": "text",
            "text": "RunnableParallel",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". All branches receive the same input; the result is a dict keyed by branch name:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_core.runnables import RunnableParallel\n\nsummary_prompt = ChatPromptTemplate.from_template(\"Summarise: {text}\")\nkeywords_prompt = ChatPromptTemplate.from_template(\n    \"List 5 keywords from: {text}. Output a comma-separated list only.\"\n)\nsentiment_prompt = ChatPromptTemplate.from_template(\n    \"Rate the sentiment of: {text}. Output: positive / neutral / negative\"\n)\n\nfast_llm = ChatAnthropic(model=\"claude-haiku-4-5-20251001\")\nparser = StrOutputParser()\n\n# Three parallel branches\nanalysis_chain = RunnableParallel(\n    summary=summary_prompt | fast_llm | parser,\n    keywords=keywords_prompt | fast_llm | parser,\n    sentiment=sentiment_prompt | fast_llm | parser,\n)\n\nresult = analysis_chain.invoke({\n    \"text\": \"LangChain makes it easy to compose LLM pipelines using a pipe operator.\"\n})\nprint(result[\"summary\"])\nprint(result[\"keywords\"])\nprint(result[\"sentiment\"])"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The three LLM calls run concurrently. Wall-clock time equals the slowest branch, not the sum of all three."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Passing Through Fields with RunnablePassthrough"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When a downstream step needs both the LLM output and the original input, use ",
            "marks": []
          },
          {
            "type": "text",
            "text": "RunnablePassthrough",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " to carry the input forward alongside the model's response:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_core.runnables import RunnablePassthrough\n\nqa_prompt = ChatPromptTemplate.from_template(\n    \"Answer the question using the context.\\nContext: {context}\\nQuestion: {question}\"\n)\n\n# Retrieve context from a fake retriever\ndef fake_retriever(query: str) -> str:\n    return f\"Relevant context about: {query}\"\n\nqa_chain = (\n    # Parallel: retrieve context AND pass the question through\n    RunnableParallel(\n        context=RunnableLambda(lambda x: fake_retriever(x[\"question\"])),\n        question=RunnablePassthrough(),  # passes input dict unchanged\n    )\n    | qa_prompt\n    | llm\n    | StrOutputParser()\n)\n\nanswer = qa_chain.invoke({\"question\": \"What is LCEL?\"})\nprint(answer)"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Configuring Chains at Runtime"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Use ",
            "marks": []
          },
          {
            "type": "text",
            "text": "configurable_fields",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " to allow callers to override specific parameters without rebuilding the chain:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_anthropic import ChatAnthropic\nfrom langchain_core.runnables import ConfigurableField\n\nconfigurable_llm = ChatAnthropic(model=\"claude-haiku-4-5-20251001\").configurable_fields(\n    model=ConfigurableField(\n        id=\"model\",\n        name=\"Model name\",\n        description=\"The Anthropic model to use\",\n    ),\n    max_tokens=ConfigurableField(\n        id=\"max_tokens\",\n        name=\"Max tokens\",\n    ),\n)\n\nchain = prompt | configurable_llm | StrOutputParser()\n\n# Override model at invocation time\nresult = chain.with_config(\n    configurable={\"model\": \"claude-sonnet-5\", \"max_tokens\": 1024}\n).invoke({\"topic\": \"complex reasoning\"})\nprint(result)"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Error Handling with RunnableWithFallbacks"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_core.runnables import RunnableWithFallbacks\n\n# Primary: fast and cheap\nprimary_chain = prompt | ChatAnthropic(model=\"claude-haiku-4-5-20251001\") | StrOutputParser()\n# Fallback: slower but more reliable in error conditions\nfallback_chain = prompt | ChatAnthropic(model=\"claude-sonnet-5\") | StrOutputParser()\n\nresilient_chain = primary_chain.with_fallbacks([fallback_chain])\n\n# If primary raises an exception, fallback runs automatically\nresult = resilient_chain.invoke({\"topic\": \"fault tolerance\"})"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Chaining Multiple LLM Calls"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Complex pipelines often need multiple LLM steps in sequence \u2014 each step refines, transforms, or validates the previous output. LCEL handles this naturally: the output of one chain becomes the input dict for the next:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_anthropic import ChatAnthropic\nfrom langchain_core.prompts import ChatPromptTemplate\nfrom langchain_core.output_parsers import StrOutputParser\nfrom langchain_core.runnables import RunnableLambda\n\nllm = ChatAnthropic(model=\"claude-haiku-4-5-20251001\")\nparser = StrOutputParser()\n\n# Step 1: draft\ndraft_prompt = ChatPromptTemplate.from_template(\"Write a draft paragraph about: {topic}\")\ndraft_chain = draft_prompt | llm | parser\n\n# Step 2: critique \u2014 receives {draft} key\ncritique_prompt = ChatPromptTemplate.from_template(\n    \"Critique this paragraph and suggest 2 improvements:\\n{draft}\"\n)\ncritique_chain = critique_prompt | llm | parser\n\n# Step 3: revise \u2014 receives {draft} and {critique}\nrevise_prompt = ChatPromptTemplate.from_template(\n    \"Revise this paragraph using these suggestions:\\nOriginal: {draft}\\nSuggestions: {critique}\"\n)\nrevise_chain = revise_prompt | llm | parser\n\n# Wire together: each lambda packs outputs into the right dict shape\nfull_pipeline = (\n    draft_chain\n    | RunnableLambda(lambda draft: {\"draft\": draft})\n    | RunnableLambda(lambda x: {**x, \"critique\": critique_chain.invoke(x)})\n    | revise_chain\n)\n\nfinal = full_pipeline.invoke({\"topic\": \"distributed systems\"})\nprint(final)"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Structured Output Parsing"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For machine-readable outputs, use ",
            "marks": []
          },
          {
            "type": "text",
            "text": "JsonOutputParser",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " or Pydantic-based parsers to get typed objects instead of raw strings:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_core.output_parsers import JsonOutputParser\nfrom langchain_core.pydantic_v1 import BaseModel, Field\nfrom typing import List\n\n\nclass TechSummary(BaseModel):\n    title: str = Field(description=\"Short title for the topic\")\n    key_points: List[str] = Field(description=\"3-5 key points\")\n    difficulty: str = Field(description=\"beginner / intermediate / advanced\")\n\n\njson_parser = JsonOutputParser(pydantic_object=TechSummary)\n\nstructured_prompt = ChatPromptTemplate.from_messages([\n    (\"system\", \"You output JSON only. No extra text.\"),\n    (\"human\", \"{format_instructions}\\n\\nTopic: {topic}\"),\n]).partial(format_instructions=json_parser.get_format_instructions())\n\nstructured_chain = structured_prompt | llm | json_parser\n\nresult: TechSummary = structured_chain.invoke({\"topic\": \"transformer attention\"})\nprint(result[\"title\"])\nprint(result[\"key_points\"])  # list[str]\nprint(result[\"difficulty\"])"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Adding Conversation Memory"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "To build a chain that remembers previous turns, include a message history placeholder in the prompt and bind it to a session store:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_core.prompts import MessagesPlaceholder\nfrom langchain_core.chat_history import InMemoryChatMessageHistory\nfrom langchain_core.runnables.history import RunnableWithMessageHistory\n\nchat_prompt = ChatPromptTemplate.from_messages([\n    (\"system\", \"You are a helpful assistant.\"),\n    MessagesPlaceholder(variable_name=\"history\"),\n    (\"human\", \"{input}\"),\n])\n\n# In-memory store keyed by session_id\nchat_history_store: dict[str, InMemoryChatMessageHistory] = {}\n\n\ndef get_session_history(session_id: str) -> InMemoryChatMessageHistory:\n    if session_id not in chat_history_store:\n        chat_history_store[session_id] = InMemoryChatMessageHistory()\n    return chat_history_store[session_id]\n\n\nbase_chain = chat_prompt | llm | parser\n\nchain_with_history = RunnableWithMessageHistory(\n    base_chain,\n    get_session_history,\n    input_messages_key=\"input\",\n    history_messages_key=\"history\",\n)\n\nconfig = {\"configurable\": {\"session_id\": \"user-abc\"}}\n\nr1 = chain_with_history.invoke({\"input\": \"My name is Dana.\"}, config=config)\nprint(r1)\nr2 = chain_with_history.invoke({\"input\": \"What is my name?\"}, config=config)\nprint(r2)  # Recalls: \"Your name is Dana.\""
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Debugging Chains with Callbacks"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_core.callbacks import StdOutCallbackHandler\nfrom langchain_core.runnables import RunnableConfig\n\n# Attach a verbose callback to print every step\nverbose_config = RunnableConfig(callbacks=[StdOutCallbackHandler()])\n\nresult = chain.invoke({\"topic\": \"callbacks\"}, config=verbose_config)\n# Prints: input tokens, output tokens, latency for each step\n\n# Custom callback to collect metrics\nfrom langchain_core.callbacks.base import BaseCallbackHandler\n\n\nclass LatencyTracker(BaseCallbackHandler):\n    def __init__(self):\n        self.latencies: list[float] = []\n        self._start: float = 0.0\n\n    def on_llm_start(self, *args, **kwargs) -> None:\n        import time\n        self._start = time.monotonic()\n\n    def on_llm_end(self, *args, **kwargs) -> None:\n        import time\n        self.latencies.append(time.monotonic() - self._start)\n\n\ntracker = LatencyTracker()\nchain.invoke({\"topic\": \"performance\"}, config={\"callbacks\": [tracker]})\nprint(f\"LLM latency: {tracker.latencies[0]:.2f}s\")"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "LCEL chains compose using the ",
                    "marks": []
                  },
                  {
                    "type": "text",
                    "text": "|",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " operator between any two ",
                    "marks": []
                  },
                  {
                    "type": "text",
                    "text": "Runnable",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " objects \u2014 prompts, models, parsers, and custom functions all implement the same interface."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
