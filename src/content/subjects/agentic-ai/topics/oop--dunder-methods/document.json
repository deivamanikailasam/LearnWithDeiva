      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "How it works"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "__repr__ and __str__"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "class ToolCall:\n    def __init__(self, name: str, args: dict):\n        self.name = name\n        self.args = args\n\n    def __repr__(self) -> str:\n        return f\"ToolCall(name={self.name!r}, args={self.args!r})\"\n\n    def __str__(self) -> str:\n        return f\"{self.name}({self.args})\""
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "__call__ — callable tools"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "class BoundTool:\n    def __init__(self, fn, schema: dict):\n        self.fn = fn\n        self.schema = schema\n\n    def __call__(self, **kwargs):\n        return self.fn(**kwargs)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "__len__, __getitem__, __iter__"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "class MessageBuffer:\n    def __init__(self):\n        self._items: list[dict] = []\n\n    def append(self, msg: dict) -> None:\n        self._items.append(msg)\n\n    def __len__(self) -> int:\n        return len(self._items)\n\n    def __getitem__(self, index: int) -> dict:\n        return self._items[index]\n\n    def __iter__(self):\n        return iter(self._items)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "When to use it"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "__repr__",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " on every domain object logged or inspected"
                  }
                ]
