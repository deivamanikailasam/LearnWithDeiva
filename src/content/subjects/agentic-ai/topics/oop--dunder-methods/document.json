          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "__call__",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " when a configured tool should behave like a function"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Avoid",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " overriding dunders without understanding the full protocol"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "How to implement"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "class AgentTrace:\n    def __init__(self, run_id: str):\n        self.run_id = run_id\n        self.steps: list[dict] = []\n\n    def record(self, step: dict) -> None:\n        self.steps.append(step)\n\n    def __len__(self) -> int:\n        return len(self.steps)\n\n    def __iter__(self):\n        return iter(self.steps)\n\n    def __repr__(self) -> str:\n        return f\"AgentTrace(run_id={self.run_id!r}, steps={len(self)})\""
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Real-world example"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A ToolCollection supports iteration for schema export, len for metrics, and getitem for lookup:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "class ToolCollection:\n    def __init__(self, tools: dict[str, callable]):\n        self._tools = tools\n\n    def __len__(self) -> int:\n        return len(self._tools)\n\n    def __getitem__(self, name: str) -> callable:\n        return self._tools[name]\n\n    def __iter__(self):\n        return iter(self._tools.values())"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common mistakes"
          }
        ]
