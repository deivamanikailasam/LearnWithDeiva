    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Double-underscore (\"dunder\") methods hook Python's built-in operations: printing, calling, indexing, iteration, and context management. Custom tool results, message objects, and agent events become more expressive when they behave like native types."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "What it is"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Dunder methods follow "
          },
          {
            "type": "text",
            "text": "__name__",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". Python invokes them implicitly — use "
          },
          {
            "type": "text",
            "text": "str(obj)",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " rather than "
          },
          {
            "type": "text",
            "text": "obj.__str__()",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " directly."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Commonly used dunders in agent code"
