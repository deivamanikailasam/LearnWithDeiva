      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Avoid for:"
                  },
                  {
                    "type": "text",
                    "text": " highly dynamic tasks where the correct next action cannot be known until the previous one completes. ReAct or a purely reactive loop is better in those cases."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Plan-and-Execute"
                  },
                  {
                    "type": "text",
                    "text": " separates planning (global reasoning about the goal) from execution (local, tool-using action on one step)."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "The planner"
                  },
                  {
                    "type": "text",
                    "text": " emits a structured JSON step list; the executor runs each step with prior results injected as context."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "The re-planner"
                  },
                  {
                    "type": "text",
                    "text": " revises remaining steps when completed steps reveal new information; it leaves the completed record intact."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Signal-driven re-planning"
                  },
                  {
                    "type": "text",
                    "text": " (REPLAN_NEEDED token) balances adaptability against LLM cost."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Compare to ReAct"
                  },
                  {
                    "type": "text",
                    "text": ": Plan-and-Execute is better for multi-step tasks with predictable structure; ReAct is better when each step depends tightly on the previous result."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}