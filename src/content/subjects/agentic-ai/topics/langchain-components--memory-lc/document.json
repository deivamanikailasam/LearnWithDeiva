            "type": "text",
            "text": "# Read the history for a given session\nhistory = get_session_history(\"user-123\")\nprint(f\"Turn count: {len(history.messages)}\")\nfor msg in history.messages:\n    role = \"User\" if isinstance(msg, HumanMessage) else \"AI\"\n    print(f\"{role}: {msg.content[:80]}\")\n\n# Seed a session with prior context (e.g. importing old logs)\nhistory.add_messages([\n    HumanMessage(content=\"I prefer Python over JavaScript.\"),\n    AIMessage(content=\"Noted! I'll use Python in my examples.\"),\n])\n\n# Delete a session (Redis example with TTL override)\nfrom langchain_community.chat_message_histories import RedisChatMessageHistory\n\nhist = RedisChatMessageHistory(\"user-old\", url=\"redis://localhost:6379/0\")\nhist.clear()   # deletes the key from Redis\n\n# List all sessions (SQLite example)\nimport sqlite3\nconn = sqlite3.connect(\"chat_history.db\")\nsessions = conn.execute(\n    \"SELECT DISTINCT session_id FROM message_store\"\n).fetchall()\nprint([s[0] for s in sessions])"
