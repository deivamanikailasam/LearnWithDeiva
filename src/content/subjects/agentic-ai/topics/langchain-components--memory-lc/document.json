      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "How LangChain Handles Conversation Memory"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "LLMs are stateless \u2014 each call is independent. LangChain provides memory components that persist conversation history and inject it into the prompt on every subsequent turn. The LLM then appears to 'remember' earlier exchanges."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "LangChain Memory conversation history flow",
          "title": "Messages are stored after each turn and injected via MessagesPlaceholder on the next"
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "InMemoryChatMessageHistory"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The simplest store is "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "InMemoryChatMessageHistory"
          },
          {
            "type": "text",
            "text": " \u2014 a list of messages held in process memory. It is fast and requires no external dependencies, but is lost when the process restarts and cannot be shared across servers."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_core.chat_history import InMemoryChatMessageHistory\nfrom langchain_core.messages import HumanMessage, AIMessage\n\n# Create a history store keyed by session ID\nstore: dict[str, InMemoryChatMessageHistory] = {}\n\ndef get_session_history(session_id: str) -> InMemoryChatMessageHistory:\n    if session_id not in store:\n        store[session_id] = InMemoryChatMessageHistory()\n    return store[session_id]\n\n# Manually inspect and manipulate\nhistory = get_session_history(\"user-123\")\nhistory.add_user_message(\"What is Python?\")\nhistory.add_ai_message(\"Python is a general-purpose programming language.\")\nhistory.add_user_message(\"Who created it?\")\n\nprint(history.messages)\n# [HumanMessage(content='What is Python?'),\n#  AIMessage(content='Python is a general-purpose programming language.'),\n#  HumanMessage(content='Who created it?')]\n\n# Clear history for a session\nhistory.clear()"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "RunnableWithMessageHistory \u2014 Wiring Memory into LCEL"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "RunnableWithMessageHistory"
          },
          {
            "type": "text",
            "text": " wraps any LCEL chain, loads the history for the given session ID before each call, and appends the new messages after. The chain itself stays stateless \u2014 the wrapper handles all persistence."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_core.prompts import ChatPromptTemplate, MessagesPlaceholder\nfrom langchain_core.runnables.history import RunnableWithMessageHistory\nfrom langchain_anthropic import ChatAnthropic\nfrom langchain_core.output_parsers import StrOutputParser\n\nllm = ChatAnthropic(model=\"claude-haiku-4-5-20251001\")\n\n# Prompt MUST include a MessagesPlaceholder for the history variable\nprompt = ChatPromptTemplate.from_messages([\n    (\"system\", \"You are a helpful assistant.\"),\n    MessagesPlaceholder(variable_name=\"history\"),\n    (\"human\", \"{input}\"),\n])\n\nchain = prompt | llm | StrOutputParser()\n\n# Wrap the chain with memory\nchain_with_memory = RunnableWithMessageHistory(\n    chain,\n    get_session_history,          # factory: session_id -> ChatMessageHistory\n    input_messages_key=\"input\",   # which key in the input dict holds the new message\n    history_messages_key=\"history\",  # which MessagesPlaceholder to fill\n)\n\nconfig = {\"configurable\": {\"session_id\": \"user-123\"}}\n\n# Turn 1\nresp1 = chain_with_memory.invoke({\"input\": \"My name is Alice.\"}, config=config)\nprint(resp1)   # \"Hello Alice! ...\"\n\n# Turn 2 \u2014 the model remembers Alice\nresp2 = chain_with_memory.invoke({\"input\": \"What is my name?\"}, config=config)\nprint(resp2)   # \"Your name is Alice.\"\n\n# Different session \u2014 no shared history\nconfig2 = {\"configurable\": {\"session_id\": \"user-456\"}}\nresp3 = chain_with_memory.invoke({\"input\": \"What is my name?\"}, config=config2)\nprint(resp3)   # \"I don't know your name yet.\"  "
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Persistent Storage with RedisChatMessageHistory"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For production deployments, replace "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "InMemoryChatMessageHistory"
          },
          {
            "type": "text",
            "text": " with a persistent backend. The interface is identical \u2014 only the factory function changes."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Redis \u2014 survives restarts, shareable across server instances\nfrom langchain_community.chat_message_histories import RedisChatMessageHistory\n\ndef get_redis_history(session_id: str) -> RedisChatMessageHistory:\n    return RedisChatMessageHistory(\n        session_id=session_id,\n        url=\"redis://localhost:6379/0\",\n        ttl=3600,   # expire sessions after 1 hour of inactivity\n    )\n\nchain_with_redis = RunnableWithMessageHistory(\n    chain,\n    get_redis_history,\n    input_messages_key=\"input\",\n    history_messages_key=\"history\",\n)\n\n# SQLite \u2014 local file, no external service\nfrom langchain_community.chat_message_histories import SQLChatMessageHistory\n\ndef get_sqlite_history(session_id: str) -> SQLChatMessageHistory:\n    return SQLChatMessageHistory(\n        session_id=session_id,\n        connection_string=\"sqlite:///chat_history.db\",\n    )\n\n# MongoDB \u2014 document store with flexible schema\nfrom langchain_mongodb.chat_message_histories import MongoDBChatMessageHistory\n\ndef get_mongo_history(session_id: str) -> MongoDBChatMessageHistory:\n    return MongoDBChatMessageHistory(\n        session_id=session_id,\n        connection_string=\"mongodb://localhost:27017\",\n        database_name=\"chatbot\",\n        collection_name=\"histories\",\n    )"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Trimming History to Fit the Context Window"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Uncapped history grows without bound and eventually exceeds the model's context window. LangChain provides "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "trim_messages()"
          },
          {
            "type": "text",
            "text": " to truncate the list before injecting it into the prompt."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_core.messages import trim_messages, SystemMessage\n\ntrimmer = trim_messages(\n    max_tokens=4096,          # keep at most 4 096 tokens of history\n    strategy=\"last\",          # keep the most recent messages (drop oldest)\n    token_counter=llm,        # use the LLM's tokenizer for counting\n    include_system=True,      # always keep the system message\n    allow_partial=False,      # never split a message in half\n    start_on=\"human\",         # ensure the first kept message is a human turn\n)\n\n# Insert trimmer into the chain\nchain_trimmed = (\n    {\n        \"history\": lambda x: trimmer.invoke(x[\"history\"]),\n        \"input\":   lambda x: x[\"input\"],\n    }\n    | prompt\n    | llm\n    | StrOutputParser()\n)\n\nchain_with_trim = RunnableWithMessageHistory(\n    chain_trimmed,\n    get_session_history,\n    input_messages_key=\"input\",\n    history_messages_key=\"history\",\n)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Summarisation Memory"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Instead of dropping old messages, a summarisation node compresses them into a single "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "SystemMessage"
          },
          {
            "type": "text",
            "text": " summary. This retains key facts across very long conversations without using the full token budget."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_core.messages import SystemMessage, HumanMessage, AIMessage\nfrom langchain_core.prompts import ChatPromptTemplate\nfrom langchain_core.output_parsers import StrOutputParser\n\nsummarise_prompt = ChatPromptTemplate.from_messages([\n    (\"system\",\n     \"Distil the conversation below into a concise summary. \"\n     \"Preserve names, key facts, and decisions.\"),\n    (\"human\", \"{history}\"),\n])\nsummarise_chain = summarise_prompt | llm | StrOutputParser()\n\ndef maybe_summarise(messages: list, threshold: int = 10) -> list:\n    \"\"\"If history exceeds `threshold` messages, compress the oldest half.\"\"\"\n    if len(messages) <= threshold:\n        return messages\n\n    mid = len(messages) // 2\n    old_messages = messages[:mid]\n    recent_messages = messages[mid:]\n\n    history_text = \"\\n\".join(\n        f\"{m.__class__.__name__}: {m.content}\" for m in old_messages\n    )\n    summary_text = summarise_chain.invoke({\"history\": history_text})\n    summary_msg  = SystemMessage(content=f\"Earlier conversation summary:\\n{summary_text}\")\n\n    return [summary_msg] + recent_messages\n\n# Use inside an LCEL chain\nchain_with_summary = (\n    {\n        \"history\": lambda x: maybe_summarise(x[\"history\"]),\n        \"input\":   lambda x: x[\"input\"],\n    }\n    | prompt\n    | llm\n    | StrOutputParser()\n)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Memory in LangGraph with MemorySaver"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "In LangGraph agents, memory is handled by the checkpointer rather than "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "RunnableWithMessageHistory"
          },
          {
            "type": "text",
            "text": ". "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "MemorySaver"
          },
          {
            "type": "text",
            "text": " stores the full graph state (including messages) after every node execution. Each "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "thread_id"
          },
          {
            "type": "text",
            "text": " in the config corresponds to one conversation."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langgraph.checkpoint.memory import MemorySaver\nfrom langgraph.graph import StateGraph, END\nfrom typing import Annotated\nimport operator\n\nclass State(dict):\n    messages: Annotated[list, operator.add]\n\ndef chat_node(state: State) -> State:\n    response = llm.invoke(state[\"messages\"])\n    return {\"messages\": [response]}\n\ngraph = StateGraph(State)\ngraph.add_node(\"chat\", chat_node)\ngraph.set_entry_point(\"chat\")\ngraph.add_edge(\"chat\", END)\n\n# Attach the in-process checkpointer\nmemory = MemorySaver()\nagent  = graph.compile(checkpointer=memory)\n\n# thread_id identifies the conversation \u2014 same as session_id in LCEL\nconfig = {\"configurable\": {\"thread_id\": \"convo-abc\"}}\n\nr1 = agent.invoke({\"messages\": [HumanMessage(\"My favourite colour is blue.\")]}, config=config)\nr2 = agent.invoke({\"messages\": [HumanMessage(\"What is my favourite colour?\")]}, config=config)\nprint(r2[\"messages\"][-1].content)   # 'Your favourite colour is blue.'\n\n# For persistence across restarts use SqliteSaver\nfrom langgraph.checkpoint.sqlite import SqliteSaver\nwith SqliteSaver.from_conn_string(\"checkpoints.db\") as sqlite_memory:\n    persistent_agent = graph.compile(checkpointer=sqlite_memory)"
          }
        ]
      },
