      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Async Memory Access"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "In async FastAPI or async LangGraph flows, use "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "ainvoke()"
          },
          {
            "type": "text",
            "text": " on the chain with memory \u2014 "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "RunnableWithMessageHistory"
          },
          {
            "type": "text",
            "text": " is fully async-compatible. Redis and SQLite backends also support async access."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\nfrom fastapi import FastAPI\nfrom langchain_core.runnables.history import RunnableWithMessageHistory\n\napp = FastAPI()\n\n@app.post(\"/chat\")\nasync def chat(session_id: str, message: str) -> dict:\n    config = {\"configurable\": {\"session_id\": session_id}}\n    response = await chain_with_memory.ainvoke(\n        {\"input\": message},\n        config=config,\n    )\n    return {\"reply\": response}\n\n# Streaming response via Server-Sent Events\nfrom fastapi.responses import StreamingResponse\n\n@app.post(\"/chat/stream\")\nasync def chat_stream(session_id: str, message: str):\n    config = {\"configurable\": {\"session_id\": session_id}}\n\n    async def event_generator():\n        async for chunk in chain_with_memory.astream(\n            {\"input\": message},\n            config=config,\n        ):\n            yield f\"data: {chunk}\\n\\n\"\n        yield \"data: [DONE]\\n\\n\"\n\n    return StreamingResponse(event_generator(), media_type=\"text/event-stream\")"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
