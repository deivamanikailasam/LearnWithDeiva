        "content": [
          {
            "type": "text",
            "text": "import pytest\nfrom langchain_core.chat_history import InMemoryChatMessageHistory\nfrom langchain_core.runnables.history import RunnableWithMessageHistory\nfrom langchain_community.chat_models.fake import FakeListChatModel\nfrom langchain_core.prompts import ChatPromptTemplate, MessagesPlaceholder\nfrom langchain_core.output_parsers import StrOutputParser\n\n@pytest.fixture\ndef memory_chain():\n    fake_llm = FakeListChatModel(responses=[\n        \"Hello! Nice to meet you, Alice.\",\n        \"Your name is Alice.\",\n    ])\n    prompt = ChatPromptTemplate.from_messages([\n        (\"system\", \"You are helpful.\"),\n        MessagesPlaceholder(\"history\"),\n        (\"human\", \"{input}\"),\n    ])\n    chain = prompt | fake_llm | StrOutputParser()\n    store = {}\n\n    def get_hist(sid):\n        if sid not in store:\n            store[sid] = InMemoryChatMessageHistory()\n        return store[sid]\n\n    return RunnableWithMessageHistory(\n        chain, get_hist,\n        input_messages_key=\"input\",\n        history_messages_key=\"history\",\n    ), store\n\ndef test_memory_retains_context(memory_chain):\n    chain, store = memory_chain\n    cfg = {\"configurable\": {\"session_id\": \"test\"}}\n\n    r1 = chain.invoke({\"input\": \"My name is Alice.\"}, config=cfg)\n    assert \"Alice\" in r1\n\n    r2 = chain.invoke({\"input\": \"What is my name?\"}, config=cfg)\n    assert \"Alice\" in r2\n\n    # Confirm both turns are stored\n    history = store[\"test\"]\n    assert len(history.messages) == 4   # 2 human + 2 AI"
