      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Benchmarking Models on Your Data"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "MTEB (Massive Text Embedding Benchmark) scores are a useful starting point, but the only reliable way to pick a model is to measure Recall@K on "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "your own queries and documents"
          },
          {
            "type": "text",
            "text": ". The following wrapper makes it easy to swap models and compare."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass\nfrom typing import Protocol\nimport numpy as np\n\n\nclass Embedder(Protocol):\n    def embed(self, texts: list[str], input_type: str) -> list[list[float]]:\n        ...\n\n\n@dataclass\nclass VoyageEmbedder:\n    model: str = \"voyage-3\"\n\n    def embed(self, texts: list[str], input_type: str = \"document\") -> list[list[float]]:\n        import voyageai\n        client = voyageai.Client()\n        return client.embed(texts, model=self.model, input_type=input_type).embeddings\n\n\n@dataclass\nclass OpenAIEmbedder:\n    model: str = \"text-embedding-3-small\"\n    dimensions: int | None = None\n\n    def embed(self, texts: list[str], input_type: str = \"document\") -> list[list[float]]:\n        from openai import OpenAI\n        client = OpenAI()\n        kwargs = {\"model\": self.model, \"input\": texts}\n        if self.dimensions:\n            kwargs[\"dimensions\"] = self.dimensions\n        resp = client.embeddings.create(**kwargs)\n        return [d.embedding for d in resp.data]\n\n\ndef benchmark(\n    embedder: Embedder,\n    queries: list[str],\n    expected_indices: list[int],\n    corpus: list[str],\n    k: int = 5,\n) -> float:\n    doc_vecs  = np.array(embedder.embed(corpus, \"document\"), dtype=np.float32)\n    q_vecs    = np.array(embedder.embed(queries, \"query\"),    dtype=np.float32)\n    hits = 0\n    for q_vec, expected in zip(q_vecs, expected_indices):\n        top_k = set(np.argsort(doc_vecs @ q_vec)[::-1][:k])\n        if expected in top_k:\n            hits += 1\n    return hits / len(queries)\n\n\n# Run the same benchmark across models\nfor embedder in [VoyageEmbedder(\"voyage-3\"), VoyageEmbedder(\"voyage-3-lite\")]:\n    score = benchmark(embedder, queries, expected_indices, corpus_texts)\n    print(f\"{embedder.model}: Recall@5 = {score:.3f}\")\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Matryoshka Representations in Practice"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "MRL models (OpenAI's "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "text-embedding-3-large"
          },
          {
            "type": "text",
            "text": ") embed information in a hierarchical way: the first 256 dimensions capture the most important signal, the next 256 refine it, and so on. Truncating to a lower dimension still produces a valid embedding \u2014 just less precise."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import numpy as np\n\n\ndef truncate_mrl(vec: list[float], target_dim: int) -> list[float]:\n    \"\"\"Truncate an MRL vector and re-normalise.\"\"\"\n    v = np.array(vec[:target_dim], dtype=np.float32)\n    norm = np.linalg.norm(v)\n    return (v / norm if norm > 0 else v).tolist()\n\n\n# Trade recall for speed: 3072 \u2192 512\nfull_3072 = openai_embed(\"some text\", dimensions=3072)\nvec_512   = truncate_mrl(full_3072, 512)\nprint(len(vec_512))   # 512\n\n# Typical recall trade-off for text-embedding-3-large on MTEB:\n# 3072 dims:  NDCG@10 \u2248 0.641\n#  512 dims:  NDCG@10 \u2248 0.622  (\u22123%)\n#  256 dims:  NDCG@10 \u2248 0.610  (\u22125%)\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Pitfalls When Switching Models"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Incompatible vector spaces."
                  },
                  {
                    "type": "text",
                    "text": " voyage-3 vectors cannot be compared to text-embedding-3-small vectors \u2014 their coordinate systems are unrelated. Re-embed the entire corpus when switching models."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Dimension mismatch in vector DB."
                  },
                  {
                    "type": "text",
                    "text": " If your vector index was created with 1536-dim vectors (OpenAI) and you switch to 1024-dim (Voyage), inserting new vectors will fail. Drop and recreate the collection."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Context window truncation."
                  },
                  {
                    "type": "text",
                    "text": " OpenAI models cap at 8192 tokens; chunks longer than this are silently truncated. Use "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "tiktoken"
                  },
                  {
                    "type": "text",
                    "text": " to count tokens before embedding if using OpenAI models."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Unified Embedder Abstraction"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "In production code, wrap all embedding backends behind a single interface. This lets you swap models in one place without touching retrieval, indexing, or search logic."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from abc import ABC, abstractmethod\nimport numpy as np\n\n\nclass Embedder(ABC):\n    @abstractmethod\n    def embed_documents(self, texts: list[str]) -> np.ndarray:\n        \"\"\"Return (N, D) float32 array, unit-normalised.\"\"\"\n        ...\n\n    @abstractmethod\n    def embed_query(self, text: str) -> np.ndarray:\n        \"\"\"Return (D,) float32 array, unit-normalised.\"\"\"\n        ...\n\n\nclass VoyageEmbedder(Embedder):\n    def __init__(self, model: str = \"voyage-3\"):\n        import voyageai\n        self._client = voyageai.Client()\n        self._model  = model\n\n    def embed_documents(self, texts: list[str]) -> np.ndarray:\n        res = self._client.embed(texts, model=self._model, input_type=\"document\")\n        return np.array(res.embeddings, dtype=np.float32)\n\n    def embed_query(self, text: str) -> np.ndarray:\n        res = self._client.embed([text], model=self._model, input_type=\"query\")\n        return np.array(res.embeddings[0], dtype=np.float32)\n\n\nclass LocalEmbedder(Embedder):\n    def __init__(self, model_name: str = \"BAAI/bge-m3\"):\n        from sentence_transformers import SentenceTransformer\n        self._model = SentenceTransformer(model_name)\n\n    def embed_documents(self, texts: list[str]) -> np.ndarray:\n        return self._model.encode(\n            texts, normalize_embeddings=True, show_progress_bar=False\n        ).astype(np.float32)\n\n    def embed_query(self, text: str) -> np.ndarray:\n        return self._model.encode(\n            text, normalize_embeddings=True, show_progress_bar=False\n        ).astype(np.float32)\n\n\n# Swap the backend with one line:\nembedder: Embedder = VoyageEmbedder(\"voyage-3\")\n# embedder = LocalEmbedder(\"BAAI/bge-m3\")   # no egress\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Handling Rate Limits and Retries"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Embedding API calls fail under high concurrency or large batch sizes. Wrap calls with exponential backoff so a transient 429 does not abort a long indexing job."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import time\nimport voyageai\n\n\ndef embed_with_retry(\n    texts: list[str],\n    model: str = \"voyage-3\",\n    input_type: str = \"document\",\n    max_retries: int = 4,\n) -> list[list[float]]:\n    client = voyageai.Client()\n    delay = 2.0\n    for attempt in range(max_retries):\n        try:\n            return client.embed(texts, model=model, input_type=input_type).embeddings\n        except voyageai.error.RateLimitError:\n            if attempt == max_retries - 1:\n                raise\n            time.sleep(delay)\n            delay *= 2\n    raise RuntimeError(\"unreachable\")\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Token Counting Before Embedding"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "OpenAI models truncate inputs silently at their context window. Count tokens first and skip or split any text that exceeds the limit."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# pip install tiktoken\nimport tiktoken\n\n_ENC = tiktoken.get_encoding(\"cl100k_base\")  # used by text-embedding-3-*\n_MAX_TOKENS = 8191\n\n\ndef safe_embed_openai(\n    texts: list[str],\n    model: str = \"text-embedding-3-small\",\n) -> list[list[float] | None]:\n    \"\"\"Return None for texts that exceed the token limit.\"\"\"\n    from openai import OpenAI\n    client = OpenAI()\n    results: list[list[float] | None] = []\n    valid_texts, valid_indices = [], []\n    for i, text in enumerate(texts):\n        tokens = len(_ENC.encode(text))\n        if tokens > _MAX_TOKENS:\n            print(f\"[skip] text[{i}] has {tokens} tokens (limit {_MAX_TOKENS})\")\n            results.append(None)\n        else:\n            valid_texts.append(text)\n            valid_indices.append(i)\n            results.append(None)   # placeholder\n    if valid_texts:\n        resp = client.embeddings.create(model=model, input=valid_texts)\n        for j, idx in enumerate(valid_indices):\n            results[idx] = resp.data[j].embedding\n    return results\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Monitoring Embedding Quality Over Time"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Embedding quality can degrade as your document corpus evolves. Log query vectors and retrieval scores in production and re-run your Recall@K evaluation monthly. A drop of more than 5 percentage points is a signal to re-index with a newer model."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import json\nfrom pathlib import Path\nfrom datetime import date\n\n\ndef log_retrieval_event(\n    query: str,\n    top_k_scores: list[float],\n    log_path: str = \".retrieval_log.jsonl\",\n) -> None:\n    event = {\n        \"date\": str(date.today()),\n        \"query_len\": len(query.split()),\n        \"top_1_score\": top_k_scores[0] if top_k_scores else None,\n        \"mean_top5\":   sum(top_k_scores[:5]) / min(5, len(top_k_scores)) if top_k_scores else None,\n    }\n    with open(log_path, \"a\") as f:\n        f.write(json.dumps(event) + \"\\n\")\n\n\ndef mean_top1_score(log_path: str) -> float:\n    scores = []\n    for line in Path(log_path).read_text().splitlines():\n        evt = json.loads(line)\n        if evt[\"top_1_score\"] is not None:\n            scores.append(evt[\"top_1_score\"])\n    return sum(scores) / len(scores) if scores else 0.0\n"
          }
        ]
      },
