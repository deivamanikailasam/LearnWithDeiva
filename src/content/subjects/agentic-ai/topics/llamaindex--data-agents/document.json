      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Streaming Agent Responses"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Stream the agent's final answer token-by-token. Intermediate tool calls are not streamed \u2014 only the final text response is."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from llama_index.core.agent import ReActAgent\n\nagent = ReActAgent.from_tools(tools, llm=llm, verbose=False)\n\nstreaming_response = agent.stream_chat(\"Summarise the company docs.\")\nstreaming_response.print_response_stream()\n# or\nfor token in streaming_response.response_gen:\n    print(token, end=\"\", flush=True)\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Agent Memory"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Agents maintain conversation memory across turns using "
          },
          {
            "type": "text",
            "text": "ChatMemoryBuffer",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " by default. The buffer stores the full message history up to a token limit, dropping the oldest messages when the limit is exceeded."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from llama_index.core.agent import ReActAgent\nfrom llama_index.core.memory import ChatMemoryBuffer\n\nmemory = ChatMemoryBuffer.from_defaults(token_limit=4096)\n\nagent = ReActAgent.from_tools(\n    tools,\n    llm=llm,\n    memory=memory,\n    verbose=False,\n)\n\nagent.chat(\"My name is Alice.\")\nresponse = agent.chat(\"What is my name?\")\nprint(response)  # \"Your name is Alice.\"\n\n# Reset memory for a new conversation\nagent.memory.reset()\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Vector memory for long conversations"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For long-running sessions, use "
          },
          {
            "type": "text",
            "text": "VectorMemory",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " to retrieve semantically relevant past messages rather than keeping the full history in context."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from llama_index.core.memory import VectorMemory\nfrom llama_index.embeddings.openai import OpenAIEmbedding\n\nvector_memory = VectorMemory.from_defaults(\n    vector_store=None,      # uses an in-memory vector store by default\n    embed_model=OpenAIEmbedding(),\n    retriever_kwargs={\"similarity_top_k\": 5},\n)\n\nagent = ReActAgent.from_tools(tools, llm=llm, memory=vector_memory)\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Inspecting Agent Steps"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The "
          },
          {
            "type": "text",
            "text": "AgentChatResponse",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " exposes the full list of tool calls made during the run, useful for debugging and audit logging."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from llama_index.core.agent import ReActAgent\n\nagent = ReActAgent.from_tools(tools, llm=llm, verbose=False)\nresponse = agent.chat(\"What is 15 * 8?\")\n\nprint(response.response)                # final answer\nprint(response.sources)                  # list of ToolOutput objects\nfor source in response.sources:\n    print(f\"  Tool: {source.tool_name}\")\n    print(f\"  Input: {source.raw_input}\")\n    print(f\"  Output: {source.raw_output}\")\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Controlling Max Iterations"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Set "
          },
          {
            "type": "text",
            "text": "max_iterations",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " to prevent runaway agent loops. The default is 10."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from llama_index.core.agent import ReActAgent\nfrom llama_index.core.agent.react.base import ReActAgentException\n\nagent = ReActAgent.from_tools(tools, llm=llm, max_iterations=5, verbose=True)\n\ntry:\n    response = agent.chat(\"Do something complex step by step.\")\n    print(response)\nexcept ReActAgentException as e:\n    print(f\"Agent exceeded max iterations: {e}\")\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Custom Tools"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Beyond "
          },
          {
            "type": "text",
            "text": "FunctionTool",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ", LlamaIndex lets you build custom tool classes that encapsulate richer logic \u2014 authentication, retry, rate-limiting \u2014 without polluting the function signature."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from llama_index.core.tools import BaseTool, ToolMetadata, ToolOutput\n\nclass WeatherTool(BaseTool):\n    @property\n    def metadata(self) -> ToolMetadata:\n        return ToolMetadata(\n            name=\"get_weather\",\n            description=(\n                \"Return the current weather for a city. \"\n                \"Input should be a JSON object with key 'city'.\"\n            ),\n        )\n\n    def __call__(self, city: str) -> ToolOutput:\n        # Replace with a real weather API call\n        result = f\"Sunny, 22\u00b0C in {city}\"\n        return ToolOutput(\n            content=result,\n            tool_name=self.metadata.name,\n            raw_input={\"city\": city},\n            raw_output=result,\n        )\n\n    async def acall(self, city: str) -> ToolOutput:\n        return self(city)  # or use async I/O here\n\nagent = ReActAgent.from_tools([WeatherTool()], llm=llm, verbose=True)\nprint(agent.chat(\"What is the weather in Tokyo?\"))\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Tool Specifications and Input Schema"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "LlamaIndex automatically derives a tool's JSON Schema from its function signature and docstring. For complex input shapes, use Pydantic models as parameter types."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from pydantic import BaseModel\nfrom llama_index.core.tools import FunctionTool\n\nclass SearchParams(BaseModel):\n    query: str\n    max_results: int = 5\n    include_metadata: bool = False\n\ndef search_documents(params: SearchParams) -> list[dict]:\n    \"\"\"Search the document store with structured parameters.\"\"\"\n    # The agent passes a JSON object; LlamaIndex deserialises it into SearchParams\n    return [{\"title\": f\"Result {i}\"} for i in range(params.max_results)]\n\ntool = FunctionTool.from_defaults(fn=search_documents)\nprint(tool.metadata.get_parameters_dict())  # shows the derived JSON schema\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Async Agents"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Use the async chat API when running agents inside an async web framework or when tools themselves are async."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\nfrom llama_index.core.agent import ReActAgent\nfrom llama_index.core.tools import FunctionTool\n\nasync def fetch_price(symbol: str) -> str:\n    \"\"\"Fetch the current price for a stock symbol. Returns a string.\"\"\"\n    # async HTTP call would go here\n    return f\"{symbol}: $150.00\"\n\ntools = [FunctionTool.from_defaults(async_fn=fetch_price)]\n\nagent = ReActAgent.from_tools(tools, llm=llm, verbose=False)\n\nasync def main():\n    response = await agent.achat(\"What is the price of AAPL?\")\n    print(response)\n\nasyncio.run(main())\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Note that "
          },
          {
            "type": "text",
            "text": "FunctionTool.from_defaults",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " accepts either "
          },
          {
            "type": "text",
            "text": "fn",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " (sync) or "
          },
          {
            "type": "text",
            "text": "async_fn",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " (async). If you pass an async function to "
          },
          {
            "type": "text",
            "text": "fn",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ", the agent will not await it correctly \u2014 always use "
          },
          {
            "type": "text",
            "text": "async_fn",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " for coroutines."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Agentic RAG: Combining Agents with Multiple Indexes"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A powerful pattern gives the agent access to multiple specialised indexes as separate tools. The agent decides which index to query based on the question."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from llama_index.core import VectorStoreIndex, SimpleDirectoryReader\nfrom llama_index.core.tools import QueryEngineTool\nfrom llama_index.core.agent import OpenAIAgent\nfrom llama_index.llms.openai import OpenAI\n\n# Two separate knowledge bases\nhr_docs = SimpleDirectoryReader(\"./hr_docs\").load_data()\ntech_docs = SimpleDirectoryReader(\"./tech_docs\").load_data()\n\nhr_index = VectorStoreIndex.from_documents(hr_docs)\ntech_index = VectorStoreIndex.from_documents(tech_docs)\n\nhr_tool = QueryEngineTool.from_defaults(\n    query_engine=hr_index.as_query_engine(),\n    name=\"hr_knowledge_base\",\n    description=\"Answers questions about HR policies, benefits, and onboarding.\",\n)\n\ntech_tool = QueryEngineTool.from_defaults(\n    query_engine=tech_index.as_query_engine(),\n    name=\"tech_knowledge_base\",\n    description=\"Answers questions about engineering processes and technical documentation.\",\n)\n\nagent = OpenAIAgent.from_tools(\n    [hr_tool, tech_tool],\n    llm=OpenAI(model=\"gpt-4o\"),\n    verbose=True,\n)\n\nresponse = agent.chat(\"What is the maternity leave policy, and how do I set up my dev environment?\")\nprint(response)\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Evaluating Agent Performance"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "LlamaIndex provides evaluation utilities that measure whether the agent's reasoning is correct and grounded."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from llama_index.core.evaluation import RelevancyEvaluator, FaithfulnessEvaluator\n\nrelevancy_eval = RelevancyEvaluator()\n\nquery = \"What are the engineering onboarding steps?\"\nresponse = agent.chat(query)\n\n# Convert agent response to an object the evaluator understands\nfrom llama_index.core.base.response.schema import Response\neval_response = Response(\n    response=str(response),\n    source_nodes=response.source_nodes if hasattr(response, \"source_nodes\") else [],\n)\n\nresult = await relevancy_eval.aevaluate_response(query=query, response=eval_response)\nprint(f\"Relevant: {result.passing}, Score: {result.score}\")\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Patterns"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Agent as a router"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Use an agent purely to decide which tool to invoke \u2014 the tools do the heavy lifting. Keep the agent's instructions simple and explicit: list which tool to use for which type of question."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Iterative refinement"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For document writing or code generation, let the agent call a draft tool, evaluate the draft, and refine iteratively. Set "
          },
          {
            "type": "text",
            "text": "max_iterations",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " generously (15\u201320) for multi-step refinement tasks."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Tool caching"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Wrap expensive tools (web search, database queries) with a simple in-memory cache keyed on the input. The agent may call the same tool multiple times in a session; caching prevents redundant API calls."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import functools\nfrom llama_index.core.tools import FunctionTool\n\n_cache: dict = {}\n\ndef cached_search(query: str) -> str:\n    \"\"\"Search the web for information. Expensive \u2014 uses a cached result if available.\"\"\"\n    if query in _cache:\n        return _cache[query]\n    result = f\"[Search result for: {query}]\"  # real API call here\n    _cache[query] = result\n    return result\n\ntool = FunctionTool.from_defaults(fn=cached_search)\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
