    "content": [
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "What Is Relationship Memory?"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Entity tracking records "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "what"
          },
          {
            "type": "text",
            "text": " an entity is. Relationship memory records "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "how entities relate to one another"
          },
          {
            "type": "text",
            "text": " \u2014 and how those relations change over time. A relation is a directed triple: (subject, predicate, object). The predicate is a typed label such as "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "MANAGES"
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "REPORTS_TO"
          },
          {
            "type": "text",
            "text": ", or "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "COLLABORATES_WITH"
          },
          {
            "type": "text",
            "text": "."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Where a knowledge graph stores the current state of relations, relationship memory also tracks their "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "lifecycle"
          },
          {
            "type": "text",
            "text": ": when a relation was first observed, when it was last confirmed, when it was updated or contradicted, and when it expired. This lifecycle makes relationship memory useful for conversations that span many sessions and weeks."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Relationship memory lifecycle diagram showing a relation being created at turn 1, updated at turn 3, and expired at turn 5, with an archived copy retained for audit",
          "title": "Relationship Memory: Lifecycle from Creation to Expiry"
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "The Relation Data Model"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Each relation is a structured record with provenance fields. Storing "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "confidence"
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "first_seen"
          },
          {
            "type": "text",
            "text": ", and "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "last_seen"
          },
          {
            "type": "text",
            "text": " allows the agent to favour recent, high-confidence facts and to age out stale ones."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from __future__ import annotations\nfrom dataclasses import dataclass, field\nfrom typing import Any\nimport time\n\n\n@dataclass\nclass Relation:\n    subject: str            # entity id\n    predicate: str          # SCREAMING_SNAKE_CASE label\n    obj: str                # entity id or literal value\n    confidence: float = 1.0 # 0.0\u20131.0; lower = less certain\n    first_seen: float = field(default_factory=time.time)\n    last_seen:  float = field(default_factory=time.time)\n    valid_until: float | None = None   # None = indefinite\n    attrs: dict[str, Any] = field(default_factory=dict)\n\n    @property\n    def is_active(self) -> bool:\n        if self.valid_until is None:\n            return True\n        return time.time() < self.valid_until\n\n    def to_text(self) -> str:\n        status = \"\" if self.is_active else \" [expired]\"\n        return f\"{self.subject} --[{self.predicate}]--> {self.obj}{status} (conf={self.confidence:.2f})\"\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Storing Relations in SQLite"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Two constraints make the schema useful: a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "UNIQUE"
          },
          {
            "type": "text",
            "text": " index on (subject, predicate, obj) for deduplication, and a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "valid_until"
          },
          {
            "type": "text",
            "text": " column for expiry. Active relations are queried with "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "WHERE valid_until IS NULL OR valid_until > unixepoch()"
          },
          {
            "type": "text",
            "text": "."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import sqlite3, json, time\n\nDDL = \"\"\"\nCREATE TABLE IF NOT EXISTS relations (\n    id          INTEGER PRIMARY KEY AUTOINCREMENT,\n    subject     TEXT NOT NULL,\n    predicate   TEXT NOT NULL,\n    obj         TEXT NOT NULL,\n    confidence  REAL NOT NULL DEFAULT 1.0,\n    first_seen  REAL NOT NULL,\n    last_seen   REAL NOT NULL,\n    valid_until REAL,\n    attrs       TEXT NOT NULL DEFAULT '{}',\n    UNIQUE (subject, predicate, obj)\n);\nCREATE INDEX IF NOT EXISTS idx_rel_subject   ON relations(subject);\nCREATE INDEX IF NOT EXISTS idx_rel_obj       ON relations(obj);\nCREATE INDEX IF NOT EXISTS idx_rel_predicate ON relations(predicate);\n\"\"\"\n\n\nclass RelationshipMemory:\n    def __init__(self, db_path: str = \":memory:\"):\n        self.con = sqlite3.connect(db_path)\n        self.con.executescript(DDL)\n        self.con.commit()\n\n    # \u2500\u2500 write \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    def upsert(self, rel: Relation) -> None:\n        self.con.execute(\n            \"\"\"INSERT INTO relations\n                   (subject, predicate, obj, confidence,\n                    first_seen, last_seen, valid_until, attrs)\n               VALUES (?,?,?,?,?,?,?,?)\n               ON CONFLICT(subject, predicate, obj) DO UPDATE SET\n                 confidence  = excluded.confidence,\n                 last_seen   = excluded.last_seen,\n                 valid_until = excluded.valid_until,\n                 attrs       = json_patch(attrs, excluded.attrs)\"\"\",\n            (\n                rel.subject, rel.predicate, rel.obj,\n                rel.confidence, rel.first_seen, rel.last_seen,\n                rel.valid_until, json.dumps(rel.attrs),\n            ),\n        )\n        self.con.commit()\n\n    def expire(self, subject: str, predicate: str, obj: str) -> None:\n        self.con.execute(\n            \"UPDATE relations SET valid_until=? WHERE subject=? AND predicate=? AND obj=?\",\n            (time.time(), subject, predicate, obj),\n        )\n        self.con.commit()\n\n    # \u2500\u2500 read \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    def get_active(\n        self,\n        subject: str | None = None,\n        predicate: str | None = None,\n        obj: str | None = None,\n    ) -> list[Relation]:\n        clauses = [\"(valid_until IS NULL OR valid_until > ?)\"]\n        params: list[Any] = [time.time()]\n        if subject:\n            clauses.append(\"subject=?\"); params.append(subject)\n        if predicate:\n            clauses.append(\"predicate=?\"); params.append(predicate)\n        if obj:\n            clauses.append(\"obj=?\"); params.append(obj)\n        where = \"WHERE \" + \" AND \".join(clauses)\n        rows = self.con.execute(\n            f\"SELECT subject, predicate, obj, confidence, first_seen, last_seen, valid_until, attrs \"\n            f\"FROM relations {where} ORDER BY confidence DESC\",\n            params,\n        ).fetchall()\n        return [\n            Relation(\n                r[0], r[1], r[2], r[3], r[4], r[5], r[6],\n                json.loads(r[7]),\n            )\n            for r in rows\n        ]\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Extracting Relations from Conversation"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Delegate extraction to Claude Haiku. The prompt constrains the output to a JSON array so no regex parsing is needed."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\n\n_CLIENT = anthropic.Anthropic()\n_PREDICATES = (\n    \"MANAGES, REPORTS_TO, WORKS_FOR, MEMBER_OF, COLLABORATES_WITH, \"\n    \"OWNS, SPONSORS, USES, HAS_FEATURE, KNOWS, MENTORS\"\n)\n_EXTRACT_PROMPT = \"\"\"\nExtract relationship facts from the text below.\nReturn JSON array: [{\"subject\": \"<id>\", \"predicate\": \"<PRED>\", \"obj\": \"<id>\", \"confidence\": 0.0-1.0}]\n\nAllowed predicates: {predicates}\nEntity ids: lowercase, underscores (\"alice\", \"acme_corp\").\nOnly include facts explicitly stated in the text. Confidence = 1.0 for direct assertion, 0.7 for implied.\n\nText: <text>{text}</text>\n\"\"\"\n\n\ndef extract_relations(text: str) -> list[Relation]:\n    resp = _CLIENT.messages.create(\n        model=\"claude-haiku-4-5-20251001\",\n        max_tokens=600,\n        messages=[{\n            \"role\": \"user\",\n            \"content\": _EXTRACT_PROMPT.format(\n                predicates=_PREDICATES, text=text\n            ),\n        }],\n    )\n    try:\n        raw = json.loads(resp.content[0].text)\n    except (json.JSONDecodeError, IndexError):\n        return []\n    return [\n        Relation(\n            subject=r[\"subject\"],\n            predicate=r[\"predicate\"],\n            obj=r[\"obj\"],\n            confidence=float(r.get(\"confidence\", 1.0)),\n        )\n        for r in raw\n        if isinstance(r, dict)\n    ]\n\n\ndef ingest_turn(mem: RelationshipMemory, text: str) -> list[Relation]:\n    rels = extract_relations(text)\n    for rel in rels:\n        mem.upsert(rel)\n    return rels\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Detecting Contradictions"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When a new relation contradicts an existing one (same subject and predicate, different object), the old relation should be expired rather than silently overwritten. This preserves the audit trail."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def upsert_with_contradiction_check(\n    mem: RelationshipMemory, new_rel: Relation\n) -> bool:\n    \"\"\"Expire old conflicting relations before upserting.\n    Returns True if a contradiction was resolved.\"\"\"\n    conflicts = mem.get_active(\n        subject=new_rel.subject,\n        predicate=new_rel.predicate,\n    )\n    contradicted = False\n    for old in conflicts:\n        if old.obj != new_rel.obj:\n            mem.expire(old.subject, old.predicate, old.obj)\n            contradicted = True\n    mem.upsert(new_rel)\n    return contradicted\n\n\n# Example:\n# mem has: Alice REPORTS_TO Carol (confidence 0.9)\n# New text: \"Alice now reports to Bob\"\n# \u2192 expire Alice REPORTS_TO Carol\n# \u2192 upsert  Alice REPORTS_TO Bob\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Injecting Relationship Context into the Prompt"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Before each model call, query the active relations for entities mentioned in the user's message and inject them as a structured context block."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def build_relationship_context(\n    mem: RelationshipMemory,\n    entity_ids: list[str],\n    min_confidence: float = 0.6,\n) -> str:\n    lines: list[str] = []\n    seen: set[tuple[str, str, str]] = set()\n    for eid in entity_ids:\n        for rel in mem.get_active(subject=eid):\n            if rel.confidence < min_confidence:\n                continue\n            key = (rel.subject, rel.predicate, rel.obj)\n            if key not in seen:\n                seen.add(key)\n                lines.append(rel.to_text())\n        for rel in mem.get_active(obj=eid):\n            if rel.confidence < min_confidence:\n                continue\n            key = (rel.subject, rel.predicate, rel.obj)\n            if key not in seen:\n                seen.add(key)\n                lines.append(rel.to_text())\n    if not lines:\n        return \"\"\n    body = \"\\n\".join(lines)\n    return f\"<relationships>\\n{body}\\n</relationships>\"\n\n\ndef agent_turn(\n    mem: RelationshipMemory,\n    conversation: list[dict],\n    user_text: str,\n    entity_ids: list[str],\n) -> str:\n    ctx = build_relationship_context(mem, entity_ids)\n    system = \"You are a helpful assistant.\"\n    if ctx:\n        system += f\"\\n\\n{ctx}\"\n\n    conversation.append({\"role\": \"user\", \"content\": user_text})\n    resp = _CLIENT.messages.create(\n        model=\"claude-haiku-4-5-20251001\",\n        max_tokens=1024,\n        system=system,\n        messages=conversation,\n    )\n    reply = resp.content[0].text\n    conversation.append({\"role\": \"assistant\", \"content\": reply})\n    ingest_turn(mem, user_text + \"\\n\" + reply)\n    return reply\n"
          }
        ]
      },
