        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing Relationship Memory"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def test_upsert_and_expire():\n    mem = RelationshipMemory()\n    r = Relation(\"alice\", \"REPORTS_TO\", \"carol\", confidence=0.9)\n    mem.upsert(r)\n    active = mem.get_active(subject=\"alice\", predicate=\"REPORTS_TO\")\n    assert len(active) == 1 and active[0].obj == \"carol\"\n\n    mem.expire(\"alice\", \"REPORTS_TO\", \"carol\")\n    active_after = mem.get_active(subject=\"alice\", predicate=\"REPORTS_TO\")\n    assert len(active_after) == 0\n\n\ndef test_contradiction_check():\n    mem = RelationshipMemory()\n    mem.upsert(Relation(\"alice\", \"REPORTS_TO\", \"carol\"))\n    new_rel = Relation(\"alice\", \"REPORTS_TO\", \"bob\")\n    contradicted = upsert_with_contradiction_check(mem, new_rel)\n    assert contradicted is True\n    active = mem.get_active(subject=\"alice\", predicate=\"REPORTS_TO\")\n    assert len(active) == 1 and active[0].obj == \"bob\"\n\n\ndef test_confidence_filter():\n    mem = RelationshipMemory()\n    mem.upsert(Relation(\"alice\", \"KNOWS\", \"bob\", confidence=0.4))\n    mem.upsert(Relation(\"alice\", \"MANAGES\", \"carol\", confidence=0.95))\n    ctx = build_relationship_context(mem, [\"alice\"], min_confidence=0.6)\n    assert \"MANAGES\" in ctx\n    assert \"KNOWS\" not in ctx\n"
          }
        ]
      },
