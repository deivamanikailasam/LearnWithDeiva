        },
        "content": [
          {
            "type": "text",
            "text": "weather_tool = {\n    \"name\": \"get_weather\",\n    \"description\": (\n        \"Get current weather for a city. \"\n        \"Returns temperature, conditions, and humidity. \"\n        \"Use this before suggesting outdoor activities.\"\n    ),\n    \"input_schema\": {\n        \"type\": \"object\",\n        \"properties\": {\n            \"city\": {\n                \"type\": \"string\",\n                \"description\": \"City name, e.g. 'New York City' or 'NYC'\",\n            },\n            \"units\": {\n                \"type\": \"string\",\n                \"enum\": [\"celsius\", \"fahrenheit\"],\n                \"description\": \"Temperature unit. Defaults to celsius.\",\n            },\n        },\n        \"required\": [\"city\"],\n    },\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Supported JSON Schema Types"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "input_schema"
          },
          {
            "type": "text",
            "text": " supports a subset of JSON Schema Draft 7. The most important property types:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "tool_with_all_types = {\n    \"name\": \"example_tool\",\n    \"description\": \"Demonstrates all supported parameter types.\",\n    \"input_schema\": {\n        \"type\": \"object\",\n        \"properties\": {\n            # Primitive types\n            \"text_param\": {\"type\": \"string\", \"description\": \"A plain string\"},\n            \"count_param\": {\"type\": \"integer\", \"description\": \"Whole number\"},\n            \"ratio_param\": {\"type\": \"number\", \"description\": \"Float or integer\"},\n            \"flag_param\": {\"type\": \"boolean\", \"description\": \"true or false\"},\n\n            # Constrained string\n            \"status\": {\n                \"type\": \"string\",\n                \"enum\": [\"active\", \"paused\", \"deleted\"],\n                \"description\": \"One of these exact values\",\n            },\n\n            # Array of strings\n            \"tags\": {\n                \"type\": \"array\",\n                \"items\": {\"type\": \"string\"},\n                \"description\": \"List of tag strings\",\n            },\n\n            # Array of objects\n            \"filters\": {\n                \"type\": \"array\",\n                \"items\": {\n                    \"type\": \"object\",\n                    \"properties\": {\n                        \"field\": {\"type\": \"string\"},\n                        \"value\": {\"type\": \"string\"},\n                    },\n                    \"required\": [\"field\", \"value\"],\n                },\n            },\n\n            # Nested object\n            \"pagination\": {\n                \"type\": \"object\",\n                \"properties\": {\n                    \"page\": {\"type\": \"integer\"},\n                    \"page_size\": {\"type\": \"integer\"},\n                },\n                \"required\": [\"page\"],\n            },\n        },\n        \"required\": [\"text_param\"],\n    },\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Writing Effective Descriptions"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "description"
          },
          {
            "type": "text",
            "text": " field at both the tool level and the property level directly influences model behaviour. Treat it as prompt engineering:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Tool description"
                  },
                  {
                    "type": "text",
                    "text": ": State what it does, what it returns, and when to prefer it over alternatives. Include negative guidance (\"do not call this for historical data \u2014 use "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "get_historical_weather"
                  },
                  {
                    "type": "text",
                    "text": " instead\")."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Property description"
                  },
                  {
                    "type": "text",
                    "text": ": Specify format (\"ISO 8601 date, e.g. 2024-03-15\"), valid ranges (\"1\u2013100\"), and examples. The model uses these to generate valid arguments."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Enum values"
                  },
                  {
                    "type": "text",
                    "text": ": If an enum value's meaning isn't obvious from its name, add a description explaining each option."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Poor: vague, no format guidance\nbad_tool = {\n    \"name\": \"search\",\n    \"description\": \"Search for things.\",\n    \"input_schema\": {\n        \"type\": \"object\",\n        \"properties\": {\n            \"q\": {\"type\": \"string\"},\n            \"from\": {\"type\": \"string\"},\n            \"to\": {\"type\": \"string\"},\n        },\n        \"required\": [\"q\"],\n    },\n}\n\n# Good: specific, includes format, examples, and scope\ngood_tool = {\n    \"name\": \"search_emails\",\n    \"description\": (\n        \"Search the user's email inbox by keyword. \"\n        \"Returns matching email subjects, senders, and dates. \"\n        \"Use this for finding specific emails or conversations. \"\n        \"Do not use this for calendar events \u2014 use search_calendar instead.\"\n    ),\n    \"input_schema\": {\n        \"type\": \"object\",\n        \"properties\": {\n            \"query\": {\n                \"type\": \"string\",\n                \"description\": \"Search terms, e.g. 'invoice from Acme'\",\n            },\n            \"start_date\": {\n                \"type\": \"string\",\n                \"description\": \"ISO 8601 date to search from, e.g. '2024-01-01'. Optional.\",\n            },\n            \"end_date\": {\n                \"type\": \"string\",\n                \"description\": \"ISO 8601 date to search to, e.g. '2024-03-31'. Optional.\",\n            },\n            \"max_results\": {\n                \"type\": \"integer\",\n                \"description\": \"Maximum results to return (1\u201350). Default 10.\",\n            },\n        },\n        \"required\": [\"query\"],\n    },\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Generating Schemas from Python Functions"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Keeping tool schemas in sync with function signatures is tedious. A helper that derives the schema from a Python function's type hints and docstring eliminates the duplication:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import inspect\nfrom typing import get_type_hints\n\nPYTHON_TO_JSON_TYPE = {\n    str: \"string\",\n    int: \"integer\",\n    float: \"number\",\n    bool: \"boolean\",\n    list: \"array\",\n    dict: \"object\",\n}\n\ndef schema_from_function(fn) -> dict:\n    \"\"\"Derive a tool schema from a typed Python function.\"\"\"\n    hints = get_type_hints(fn)\n    hints.pop(\"return\", None)  # exclude return type\n    sig = inspect.signature(fn)\n    doc = inspect.getdoc(fn) or fn.__name__\n\n    properties = {}\n    required = []\n    for param_name, param in sig.parameters.items():\n        json_type = PYTHON_TO_JSON_TYPE.get(hints.get(param_name), \"string\")\n        properties[param_name] = {\"type\": json_type, \"description\": param_name}\n        if param.default is inspect.Parameter.empty:\n            required.append(param_name)\n\n    return {\n        \"name\": fn.__name__,\n        \"description\": doc,\n        \"input_schema\": {\n            \"type\": \"object\",\n            \"properties\": properties,\n            \"required\": required,\n        },\n    }\n\n# Usage:\ndef get_weather(city: str, units: str = \"celsius\") -> dict:\n    \"\"\"Get current weather for a city. Returns temperature and conditions.\"\"\"\n    ...\n\nprint(schema_from_function(get_weather))\n# {'name': 'get_weather', 'description': 'Get current weather...',\n#  'input_schema': {'type': 'object',\n#    'properties': {'city': {'type': 'string', ...}, 'units': {'type': 'string', ...}},\n#    'required': ['city']}}\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "This approach works well for simple schemas. For production use consider "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "pydantic"
          },
          {
            "type": "text",
            "text": " \u2014 define your inputs as a Pydantic model and call "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "Model.model_json_schema()"
          },
          {
            "type": "text",
            "text": " to get a full JSON Schema including nested objects, field-level descriptions via "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "Field(description=...)"
          },
          {
            "type": "text",
            "text": ", and validation constraints."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Schema Mistakes"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Missing required field"
                  },
                  {
                    "type": "text",
                    "text": ": If a parameter is essential but not in "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "required"
                  },
                  {
                    "type": "text",
                    "text": ", the model may omit it \u2014 your implementation must handle a missing argument or the call will fail."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Wrong type annotation"
                  },
                  {
                    "type": "text",
                    "text": ": Declaring a parameter as "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "\"type\": \"integer\""
                  },
                  {
                    "type": "text",
                    "text": " when you need a float causes the model to round values. Use "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "\"number\""
                  },
                  {
                    "type": "text",
                    "text": " for floats."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "No description on properties"
                  },
                  {
                    "type": "text",
                    "text": ": The model cannot read your variable names as documentation. A parameter named "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "dt"
                  },
                  {
                    "type": "text",
                    "text": " without a description will produce inconsistent values. Always describe format, valid values, and examples."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Over-specifying constraints"
                  },
                  {
                    "type": "text",
                    "text": ": Using "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "minLength"
                  },
                  {
                    "type": "text",
                    "text": "/"
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "maxLength"
                  },
                  {
                    "type": "text",
                    "text": "/"
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "pattern"
                  },
                  {
                    "type": "text",
                    "text": " JSON Schema keywords is not guaranteed to be enforced by Claude. Use them as hints and validate server-side."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Validating Arguments with Pydantic"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Once Claude generates tool arguments, you should validate them before passing them to your implementation. Pydantic's "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "BaseModel"
          },
          {
            "type": "text",
            "text": " provides zero-boilerplate validation and type coercion \u2014 the same model can both generate the JSON Schema and validate incoming data:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from pydantic import BaseModel, Field\nfrom typing import Literal\nimport json\n\nclass WeatherInput(BaseModel):\n    city: str = Field(description=\"City name, e.g. 'New York City'\")\n    units: Literal[\"celsius\", \"fahrenheit\"] = Field(\n        default=\"celsius\",\n        description=\"Temperature unit\",\n    )\n\n# Generate tool schema directly from the Pydantic model\ndef pydantic_to_tool(name: str, description: str, model: type[BaseModel]) -> dict:\n    schema = model.model_json_schema()\n    # Pydantic includes $defs, title, etc. \u2014 strip to just what Claude needs\n    return {\n        \"name\": name,\n        \"description\": description,\n        \"input_schema\": {\n            \"type\": \"object\",\n            \"properties\": schema.get(\"properties\", {}),\n            \"required\": schema.get(\"required\", []),\n        },\n    }\n\nweather_tool = pydantic_to_tool(\n    \"get_weather\",\n    \"Get current weather for a city. Use before suggesting outdoor activities.\",\n    WeatherInput,\n)\n\n# In the agent loop \u2014 validate before dispatching:\ndef dispatch_tool(name: str, raw_input: dict) -> str:\n    if name == \"get_weather\":\n        try:\n            validated = WeatherInput.model_validate(raw_input)\n        except Exception as exc:\n            return json.dumps({\"error\": f\"Invalid arguments: {exc}\"})\n        return get_weather(validated.city, validated.units)\n    return json.dumps({\"error\": f\"Unknown tool: {name}\"})\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The key advantage: your validation model is the single source of truth. If you add a field to "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "WeatherInput"
          },
          {
            "type": "text",
            "text": ", the tool schema and the runtime validation both update automatically."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Dynamic Tool Sets and Conditional Exposure"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "You don't need to expose every tool on every API call. Sending only the tools relevant to the current context reduces the risk of the model calling something inappropriate and makes the schema simpler to reason about:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from enum import Enum\n\nclass AgentPhase(str, Enum):\n    RESEARCH = \"research\"\n    WRITE = \"write\"\n    REVIEW = \"review\"\n\nTOOLS_BY_PHASE = {\n    AgentPhase.RESEARCH: [web_search_tool, fetch_url_tool, read_file_tool],\n    AgentPhase.WRITE: [write_file_tool, create_directory_tool],\n    AgentPhase.REVIEW: [read_file_tool, lint_tool, run_tests_tool],\n}\n\ndef run_phase(user_message: str, phase: AgentPhase) -> str:\n    tools = TOOLS_BY_PHASE[phase]\n    messages = [{\"role\": \"user\", \"content\": user_message}]\n\n    for _ in range(15):\n        response = client.messages.create(\n            model=\"claude-sonnet-4-6\",\n            max_tokens=4096,\n            tools=tools,          # only expose phase-appropriate tools\n            messages=messages,\n        )\n        messages.append({\"role\": \"assistant\", \"content\": response.content})\n\n        if response.stop_reason == \"end_turn\":\n            return next(b.text for b in response.content if hasattr(b, \"text\"))\n\n        tool_results = []\n        for block in response.content:\n            if block.type == \"tool_use\":\n                result = dispatch_tool(block.name, block.input)\n                tool_results.append({\n                    \"type\": \"tool_result\",\n                    \"tool_use_id\": block.id,\n                    \"content\": result,\n                })\n        messages.append({\"role\": \"user\", \"content\": tool_results})\n\n    raise RuntimeError(\"Max turns exceeded\")\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Dynamic tool sets are especially useful for multi-stage agents (research \u2192 write \u2192 review) where different capabilities are needed at each stage. They also help when some tools require user authentication that isn't available in all contexts."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing Tool Schemas"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Before deploying, verify that Claude generates expected arguments for representative inputs. A simple test harness sends a message and checks which tool was called and what arguments were generated:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic, pytest\n\nclient = anthropic.Anthropic()\n\ndef get_tool_call(user_message: str, tools: list) -> dict | None:\n    \"\"\"Return the first tool_use block, or None if no tool was called.\"\"\"\n    response = client.messages.create(\n        model=\"claude-sonnet-4-6\",\n        max_tokens=512,\n        tools=tools,\n        messages=[{\"role\": \"user\", \"content\": user_message}],\n    )\n    for block in response.content:\n        if block.type == \"tool_use\":\n            return {\"name\": block.name, \"input\": block.input}\n    return None\n\ndef test_weather_tool_called_for_weather_query():\n    result = get_tool_call(\"What's the weather in Tokyo?\", [weather_tool])\n    assert result is not None\n    assert result[\"name\"] == \"get_weather\"\n    assert result[\"input\"].get(\"city\", \"\").lower() in (\"tokyo\", \"tokyo, japan\")\n\ndef test_units_default_when_not_specified():\n    result = get_tool_call(\"Is it warm in Paris right now?\", [weather_tool])\n    assert result is not None\n    # units should be absent (optional) or default to celsius\n    units = result[\"input\"].get(\"units\", \"celsius\")\n    assert units == \"celsius\"\n\ndef test_weather_tool_not_called_for_irrelevant_query():\n    result = get_tool_call(\"What is 2 + 2?\", [weather_tool])\n    assert result is None  # no tool call for math question\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "These tests act as a regression suite for your schema quality. If you update a description and a test breaks, it signals that the description changed the model's tool-calling behaviour \u2014 intentionally or not."
          }
        ]
      },
