            "text": "Testing Failure Detection"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Failure detection is pure logic \u2014 test it with synthetic tool results and mock responses:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import pytest\nfrom unittest.mock import MagicMock\n\n\ndef make_tool_result(is_error: bool, content: str) -> dict:\n    return {\"type\": \"tool_result\", \"tool_use_id\": \"tu_1\",\n            \"content\": content, \"is_error\": is_error}\n\n\ndef make_call(name: str) -> MagicMock:\n    c = MagicMock()\n    c.name = name\n    return c\n\n\nclass TestToolFailureDetector:\n    def test_no_failure_on_success(self):\n        detector = ToolFailureDetector()\n        results = [make_tool_result(False, \"ok\")]\n        calls = [make_call(\"search\")]\n        assert detector.process_results(results, calls, step=1) == []\n\n    def test_detects_error_result(self):\n        detector = ToolFailureDetector()\n        results = [make_tool_result(True, \"not found\")]\n        calls = [make_call(\"read_file\")]\n        failures = detector.process_results(results, calls, step=1)\n        assert len(failures) == 1\n        assert failures[0].tool_name == \"read_file\"\n\n    def test_hard_perm_from_json_content(self):\n        import json\n        detector = ToolFailureDetector()\n        content = json.dumps({\"error_type\": \"authentication_error\", \"message\": \"bad key\"})\n        results = [make_tool_result(True, content)]\n        calls = [make_call(\"api_call\")]\n        failures = detector.process_results(results, calls, step=2)\n        assert failures[0].severity == FailureSeverity.HARD_PERM\n\n\nclass TestErrorLog:\n    def test_consecutive_escalation(self):\n        log = ErrorLog(max_consecutive=2)\n        failure = FailureRecord(\"timeout\", \"timed out\", severity=FailureSeverity.TRANSIENT)\n        log.record(failure)\n        assert not log.should_escalate()\n        log.record(failure)\n        assert log.should_escalate()\n\n    def test_reset_consecutive(self):\n        log = ErrorLog(max_consecutive=2)\n        failure = FailureRecord(\"timeout\", \"timed out\", severity=FailureSeverity.TRANSIENT)\n        log.record(failure)\n        log.reset_consecutive()\n        log.record(failure)\n        assert not log.should_escalate()  # consecutive was reset\n\n    def test_hard_permanent_detection(self):\n        log = ErrorLog()\n        log.record(FailureRecord(\"authentication_error\", \"bad key\",\n                                 severity=FailureSeverity.HARD_PERM))\n        assert log.has_hard_permanent()\n"
          }
        ]
