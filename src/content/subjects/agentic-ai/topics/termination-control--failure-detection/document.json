    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "An agent loop runs in a complex environment: external APIs fail, tools return invalid data, the model runs out of output tokens, and network connections time out. Failure detection is the practice of "
          },
          {
            "type": "text",
            "text": "inspecting every loop step for errors",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": ", classifying them by severity, and deciding the appropriate response \u2014 retry, escalate, or stop \u2014 before the loop takes another step."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Failure detection \u2014 three failure classes and severity classification"
        }
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Failure Classification"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Not all failures are equal. A rate-limit error clears itself in seconds; an authentication error will never clear without operator action. Classifying failures at detection time lets the loop respond correctly without hard-coding per-error logic throughout the codebase:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass, field\nfrom enum import Enum\n\n\nclass FailureSeverity(Enum):\n    TRANSIENT   = \"transient\"    # retry; likely to succeed on next attempt\n    SOFT_PERM   = \"soft_perm\"    # escalate; retrying is unlikely to help\n    HARD_PERM   = \"hard_perm\"    # stop immediately; operator action required\n    RECOVERY    = \"recovery\"     # special handling (e.g. max_tokens \u2192 bigger budget)\n\n\n# Mapping from error type strings to severity\nFAILURE_SEVERITY: dict[str, FailureSeverity] = {\n    # Transient \u2014 network-level or rate limiting\n    \"rate_limit_error\":    FailureSeverity.TRANSIENT,\n    \"timeout\":             FailureSeverity.TRANSIENT,\n    \"service_unavailable\": FailureSeverity.TRANSIENT,\n    \"connection_error\":    FailureSeverity.TRANSIENT,\n\n    # Soft permanent \u2014 task premise is invalid; retrying won't fix it\n    \"not_found\":           FailureSeverity.SOFT_PERM,\n    \"invalid_input\":       FailureSeverity.SOFT_PERM,\n    \"tool_not_found\":      FailureSeverity.SOFT_PERM,\n\n    # Hard permanent \u2014 credentials / auth broken at the system level\n    \"authentication_error\": FailureSeverity.HARD_PERM,\n    \"permission_denied\":    FailureSeverity.HARD_PERM,\n    \"quota_exceeded\":       FailureSeverity.HARD_PERM,\n\n    # Recovery \u2014 model output truncated; needs a different retry strategy\n    \"max_tokens\":           FailureSeverity.RECOVERY,\n}\n\n\n@dataclass\nclass FailureRecord:\n    error_type: str\n    message: str\n    tool_name: str = \"\"\n    step: int = 0\n    severity: FailureSeverity = FailureSeverity.TRANSIENT\n\n    @classmethod\n    def from_tool_error(cls, tool_name: str, error_type: str, message: str, step: int):\n        severity = FAILURE_SEVERITY.get(error_type, FailureSeverity.TRANSIENT)\n        return cls(\n            error_type=error_type,\n            message=message,\n            tool_name=tool_name,\n            step=step,\n            severity=severity,\n        )\n"
          }
        ]
      },
