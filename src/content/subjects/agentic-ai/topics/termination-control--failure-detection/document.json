        "content": [
          {
            "type": "text",
            "text": "Failure detection classifies every error into four severity levels: transient (retry), soft permanent (escalate), hard permanent (stop), and recovery (special handling). A "
          },
          {
            "type": "text",
            "text": "ToolFailureDetector",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " inspects the "
          },
          {
            "type": "text",
            "text": "is_error",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " flag on every tool result and maps error types to severities. A "
          },
          {
            "type": "text",
            "text": "detect_model_failure",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
