      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "A single "
              },
              {
                "type": "text",
                "text": "FAILURE_SEVERITY",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " dict centralises the mapping so you can add new error types without touching loop logic. When an error type is "
              },
              {
                "type": "text",
                "text": "not in the dict",
                "marks": [
                  {
                    "type": "bold"
                  }
                ]
              },
              {
                "type": "text",
                "text": ", default to "
              },
              {
                "type": "text",
                "text": "TRANSIENT",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " \u2014 unknown errors are more likely to be transient than fatal, and the consecutive-error counter will escalate if they persist."
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Detecting Tool Failures"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Tool results carry a "
          },
          {
            "type": "text",
            "text": "is_error",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " flag. Parse it immediately after dispatch and classify each failure:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "class ToolFailureDetector:\n    \"\"\"\n    Inspects tool results for failures and classifies them.\n    Call after every round of tool dispatch.\n    \"\"\"\n\n    def process_results(\n        self,\n        tool_results: list[dict],\n        tool_calls,\n        step: int,\n    ) -> list[FailureRecord]:\n        \"\"\"\n        Returns a list of FailureRecords for any tool_result with is_error=True.\n        \"\"\"\n        failures = []\n        for result, call in zip(tool_results, tool_calls):\n            if result.get(\"is_error\"):\n                content = result.get(\"content\", \"\")\n                # Attempt to extract a typed error from JSON content\n                error_type = \"tool_error\"\n                try:\n                    import json\n                    parsed = json.loads(content)\n                    error_type = parsed.get(\"error_type\", \"tool_error\")\n                    message = parsed.get(\"message\", content)\n                except (json.JSONDecodeError, TypeError):\n                    message = content\n\n                failures.append(\n                    FailureRecord.from_tool_error(call.name, error_type, message, step)\n                )\n        return failures\n\n\n# Example: dispatch tools and detect failures\ndetector = ToolFailureDetector()\ntool_results = dispatch_all(tool_calls, registry)\nfailures = detector.process_results(tool_results, tool_calls, step=guard.step)\n\nfor f in failures:\n    if f.severity == FailureSeverity.HARD_PERM:\n        return {\"stop\": \"error\", \"reason\": f.message}\n"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Parse the content as JSON",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " to extract a structured error type when the tool provides one. Fall back to the raw string when parsing fails."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Hard-permanent failures stop the loop immediately",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 no consecutive-error threshold, no retry. The environment is broken and the caller must intervene."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Transient failures are recorded",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 the consecutive-error counter handles escalation after multiple soft failures in a row."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Detecting Model Failures"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Model failures are separate from tool failures and require different handling. The most important is "
          },
          {
            "type": "text",
            "text": "stop_reason == \"max_tokens\"",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ", which is a "
          },
          {
            "type": "text",
            "text": "recovery signal",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": ", not an error \u2014 the model's output was truncated mid-generation:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def detect_model_failure(response) -> FailureRecord | None:\n    \"\"\"\n    Check for model-level failures that are not tool errors.\n    Returns a FailureRecord if a failure is detected, else None.\n    \"\"\"\n    # Output truncated \u2014 not an error, but needs a different recovery path\n    if response.stop_reason == \"max_tokens\":\n        return FailureRecord(\n            error_type=\"max_tokens\",\n            message=\"Model output truncated \u2014 increase max_tokens or summarise context\",\n            severity=FailureSeverity.RECOVERY,\n        )\n\n    # Empty response \u2014 model returned nothing\n    if not response.content:\n        return FailureRecord(\n            error_type=\"empty_response\",\n            message=\"Model returned no content blocks\",\n            severity=FailureSeverity.TRANSIENT,\n        )\n\n    # All blocks are tool_use but stop_reason is end_turn \u2014 shouldn't happen\n    tool_calls = [b for b in response.content if b.type == \"tool_use\"]\n    text_blocks = [b for b in response.content if b.type == \"text\"]\n    if response.stop_reason == \"end_turn\" and tool_calls and not text_blocks:\n        # The model called a tool but declared end_turn \u2014 unusual; treat as soft failure\n        return FailureRecord(\n            error_type=\"ambiguous_completion\",\n            message=\"end_turn with pending tool calls \u2014 unclear completion state\",\n            severity=FailureSeverity.SOFT_PERM,\n        )\n\n    return None\n\n\n# In the agent loop, immediately after client.messages.create:\nmodel_failure = detect_model_failure(response)\nif model_failure:\n    if model_failure.severity == FailureSeverity.RECOVERY:\n        # max_tokens: double the budget and retry (do not advance step counter)\n        max_tokens = min(max_tokens * 2, 16_384)\n        continue\n    if model_failure.severity == FailureSeverity.HARD_PERM:\n        return {\"stop\": \"error\", \"reason\": model_failure.message}\n    # Transient: record and continue; the error counter will escalate if repeated\n"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "The "
              },
              {
                "type": "text",
                "text": "max_tokens",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " check must happen "
              },
              {
                "type": "text",
                "text": "before",
                "marks": [
                  {
                    "type": "bold"
                  }
                ]
              },
              {
                "type": "text",
                "text": " any other loop logic. If you advance the step counter or record the truncated response in the conversation before detecting the truncation, the loop gets confused: the next model call sees a half-finished assistant turn and may repeat or contradict itself."
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Error Log"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Track failures in an "
          },
          {
            "type": "text",
            "text": "ErrorLog",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " across the full loop run. It serves two purposes: (1) detecting "
          },
          {
            "type": "text",
            "text": "consecutive errors",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " for escalation, and (2) producing a structured summary when the loop terminates due to failure:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "@dataclass\nclass ErrorLog:\n    \"\"\"\n    Tracks failures across the full loop run.\n    Separates consecutive-error detection (for escalation)\n    from total error tracking (for diagnostics).\n    \"\"\"\n    records: list[FailureRecord] = field(default_factory=list)\n    consecutive: int = 0\n    max_consecutive: int = 3\n\n    def record(self, failure: FailureRecord) -> None:\n        self.records.append(failure)\n        self.consecutive += 1\n\n    def reset_consecutive(self) -> None:\n        self.consecutive = 0\n\n    def should_escalate(self) -> bool:\n        return self.consecutive >= self.max_consecutive\n\n    def has_hard_permanent(self) -> bool:\n        return any(f.severity == FailureSeverity.HARD_PERM for f in self.records)\n\n    def summary(self) -> str:\n        if not self.records:\n            return \"no errors\"\n        last = self.records[-1]\n        return (\n            f\"{len(self.records)} error(s); last: {last.error_type} \"\n            f\"on tool '{last.tool_name}' at step {last.step}: {last.message[:120]}\"\n        )\n\n\n# Usage in agent_loop:\nerror_log = ErrorLog(max_consecutive=3)\n\n# After tool dispatch:\nfor f in failures:\n    error_log.record(f)\n    if f.severity == FailureSeverity.HARD_PERM or error_log.has_hard_permanent():\n        return {\"stop\": \"error\", \"reason\": error_log.summary()}\n\nif error_log.should_escalate():\n    return {\"stop\": \"escalate\", \"reason\": error_log.summary()}\n\n# After a successful step (no failures):\nif not failures and not model_failure:\n    error_log.reset_consecutive()\n"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Reset consecutive on success",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 three isolated failures spread across many steps should not escalate. Only three "
                  },
                  {
                    "type": "text",
                    "text": "consecutive",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " failures should."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Check has_hard_permanent() after every record()",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 a hard permanent failure anywhere in the run should stop the loop immediately, even if the threshold has not been reached."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The summary() method",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " feeds the escalation message \u2014 include the error type, tool name, step number, and message so the user can diagnose without reading logs."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "API-Level Failures"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Failures can also occur at the "
          },
          {
            "type": "text",
            "text": "client.messages.create",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " call itself, before any tool is dispatched. The Anthropic Python SDK raises typed exceptions for different failure categories:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\nimport time\n\n\ndef call_with_retry(\n    client: anthropic.Anthropic,\n    max_retries: int = 3,\n    **kwargs,\n):\n    \"\"\"\n    Wrap client.messages.create with retry logic for transient API errors.\n    Exponential backoff: 1s, 2s, 4s.\n    \"\"\"\n    delay = 1.0\n    for attempt in range(max_retries + 1):\n        try:\n            return client.messages.create(**kwargs)\n        except anthropic.RateLimitError:\n            if attempt == max_retries:\n                raise\n            time.sleep(delay)\n            delay *= 2\n        except anthropic.APIStatusError as e:\n            if e.status_code >= 500 and attempt < max_retries:\n                # Server-side error \u2014 transient\n                time.sleep(delay)\n                delay *= 2\n            else:\n                raise  # 4xx client errors: don't retry\n        except anthropic.APIConnectionError:\n            if attempt == max_retries:\n                raise\n            time.sleep(delay)\n            delay *= 2\n\n    raise RuntimeError(\"Unreachable\")\n"
          }
        ]
      },
      {
        "type": "table",
        "content": [
          {
