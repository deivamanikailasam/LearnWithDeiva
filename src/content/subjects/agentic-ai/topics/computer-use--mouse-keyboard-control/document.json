        "content": [
          {
            "type": "text",
            "text": "Testing Input Actions"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Never run pyautogui against a real desktop in CI. Replace all pyautogui calls with a recording mock that stores the action sequence, then assert on the sequence rather than on visual output."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import pytest\nfrom unittest.mock import patch, call\n\nclass MockPyautogui:\n    \"\"\"Records every pyautogui call for assertion in tests.\"\"\"\n    def __init__(self):\n        self.calls: list[str] = []\n        self.PAUSE = 0\n        self.FAILSAFE = False\n\n    def moveTo(self, x, y, **kwargs):\n        self.calls.append(f\"moveTo({x},{y})\")\n\n    def click(self, **kwargs):\n        self.calls.append(f\"click(button={kwargs.get('button','left')})\")\n\n    def typewrite(self, text, **kwargs):\n        self.calls.append(f\"typewrite({text!r})\")\n\n    def press(self, key):\n        self.calls.append(f\"press({key!r})\")\n\n    def hotkey(self, *keys):\n        self.calls.append(f\"hotkey({','.join(keys)})\")\n\n    def scroll(self, clicks):\n        self.calls.append(f\"scroll({clicks})\")\n\n    def easeOutQuad(self, *a): return 1.0  # tween stub\n\n\n@pytest.fixture\ndef mock_gui():\n    mock = MockPyautogui()\n    with patch.dict(\"sys.modules\", {\"pyautogui\": mock}):\n        yield mock\n\n\ndef test_click_moves_before_clicking(mock_gui):\n    execute_action(ClickAction(x=100, y=200))\n    assert mock_gui.calls[0] == \"moveTo(100,200)\", \"should move before clicking\"\n    assert mock_gui.calls[1] == \"click(button=left)\"\n\n\ndef test_type_action_uses_clipboard(mock_gui):\n    with patch(\"pyperclip.copy\") as mock_copy:\n        execute_action(TypeAction(text=\"h\u00e9llo\"))\n        mock_copy.assert_called_once_with(\"h\u00e9llo\")\n        assert \"hotkey(ctrl,v)\" in mock_gui.calls\n\n\ndef test_fill_form_by_tab_sends_correct_sequence(mock_gui):\n    fill_form_by_tab([\"alice@example.com\", \"hunter2\"])\n    # Should type, tab, type, enter\n    assert \"press('tab')\" in mock_gui.calls\n    assert mock_gui.calls[-1] == \"press('enter')\" "
          }
        ]
      },
