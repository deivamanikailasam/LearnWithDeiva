      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "How it works"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Stack with list"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "stack: list[str] = []\nstack.append(\"analyze\")   # push\nstack.append(\"search\")\nnext_step = stack.pop()    # \"search\" — LIFO\n\n# nested context: pop restores previous scope\ncurrent_context = stack[-1] if stack else None"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Queue with deque"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from collections import deque\n\npending_tools: deque[dict] = deque()\npending_tools.append({\"name\": \"search\", \"args\": {}})\npending_tools.append({\"name\": \"summarize\", \"args\": {}})\n\ncall = pending_tools.popleft()  # FIFO — O(1)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Priority queue with heapq"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import heapq\n\n# (priority, tiebreaker, item) — lower priority number = higher urgency\nqueue: list[tuple[int, int, str]] = []\nheapq.heappush(queue, (1, 0, \"critical_alert\"))\nheapq.heappush(queue, (5, 0, \"background_index\"))\n\nurgent = heapq.heappop(queue)  # (1, 0, \"critical_alert\")"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Graph as adjacency list"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "plan_graph: dict[str, list[str]] = {\n    \"gather\": [\"analyze\"],\n    \"analyze\": [\"write\"],\n    \"write\": [],\n}\n\ndef dependents(step: str) -> list[str]:\n    return plan_graph.get(step, [])"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "When to use it"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "deque",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " for BFS, task queues, sliding context windows"
                  }
