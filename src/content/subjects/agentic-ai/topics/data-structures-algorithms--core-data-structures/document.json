                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "How to implement"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from collections import deque\n\nclass ToolQueue:\n    def __init__(self) -> None:\n        self._q: deque[dict] = deque()\n\n    def enqueue(self, call: dict) -> None:\n        self._q.append(call)\n\n    def dequeue(self) -> dict | None:\n        return self._q.popleft() if self._q else None\n\n    def __len__(self) -> int:\n        return len(self._q)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Examples"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Visited set prevents infinite loops in graph-walking agents\nvisited: set[str] = set()\n\ndef walk(node: str, graph: dict[str, list[str]]) -> None:\n    if node in visited:\n        return\n    visited.add(node)\n    process(node)\n    for nxt in graph.get(node, []):\n        walk(nxt, graph)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Real-world example"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A planning agent stores subtasks in a DAG and runs topological order — only executing a step when dependencies complete:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "deps = {\"draft\": [\"research\"], \"review\": [\"draft\"], \"publish\": [\"review\"]}\nin_degree = {n: 0 for n in deps}\nfor edges in deps.values():\n    for n in edges:\n        in_degree[n] = in_degree.get(n, 0) + 1\n\nready = deque([n for n, d in in_degree.items() if d == 0])\nwhile ready:\n    step = ready.popleft()\n    execute(step)\n    for nxt in dependents(step):\n        in_degree[nxt] -= 1\n        if in_degree[nxt] == 0:\n            ready.append(nxt)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common mistakes"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "list.pop(0) for queues",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " — O(n); use deque"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "No visited tracking",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " — cyclic graphs cause infinite agent loops"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Confusing stack and queue",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " — wrong order for plan expansion"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Best practices"
          }
