    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Best-of-N selects the single highest-scoring candidate from N independent samples, where a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "verifier"
          },
          {
            "type": "text",
            "text": " assigns a quality score to each. Unlike majority voting \u2014 which picks the most popular answer \u2014 Best-of-N picks the "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "best"
          },
          {
            "type": "text",
            "text": " answer according to an external quality signal. This makes it applicable to open-ended tasks (code generation, plan creation, long-form writing) where there is no single discrete answer to vote on."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Best-of-N: four samples each scored by a verifier, winner is the highest scorer"
        }
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Core Implementation"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\nfrom concurrent.futures import ThreadPoolExecutor\nfrom typing import Callable\n\nclient = anthropic.Anthropic()\n\ndef sample_once(prompt: str, temperature: float = 0.8) -> str:\n    response = client.messages.create(\n        model=\"claude-sonnet-4-6\",\n        max_tokens=2048,\n        temperature=temperature,\n        messages=[{\"role\": \"user\", \"content\": prompt}],\n    )\n    return response.content[0].text\n\ndef best_of_n(\n    prompt: str,\n    verifier: Callable[[str], float],  # returns 0.0\u20131.0\n    n: int = 4,\n) -> tuple[str, float]:\n    \"\"\"Sample n times, return (best_answer, best_score).\"\"\"\n    with ThreadPoolExecutor(max_workers=n) as pool:\n        candidates = list(pool.map(lambda _: sample_once(prompt), range(n)))\n\n    scored = [(c, verifier(c)) for c in candidates]\n    best_answer, best_score = max(scored, key=lambda x: x[1])\n    return best_answer, best_score\n\n# Example: simple length-and-completeness heuristic verifier\ndef heuristic_verifier(response: str) -> float:\n    score = 0.0\n    if len(response) > 100:\n        score += 0.3\n    if \"```\" in response:        # contains a code block\n        score += 0.4\n    if \"O(\" in response:         # mentions complexity\n        score += 0.3\n    return min(score, 1.0)\n\nanswer, score = best_of_n(\n    \"Implement a function to find two numbers in a list that sum to a target.\",\n    verifier=heuristic_verifier,\n    n=4,\n)\nprint(f\"Score: {score:.2f}\\nAnswer:\\n{answer[:300]}...\")"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Verifier 1: Execution-Based (Code Tasks)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For code generation, the most reliable verifier runs the generated code against test cases. The score is the fraction of tests passed:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import subprocess\nimport re\nimport tempfile\nimport os\n\ndef extract_python_code(text: str) -> str:\n    \"\"\"Extract the first Python code block from markdown response.\"\"\"\n    m = re.search(r'```python\\n(.*?)```', text, re.DOTALL)\n    if m:\n        return m.group(1)\n    # Fallback: treat entire response as code\n    return text\n\ndef execution_verifier(test_cases: list[tuple]) -> Callable[[str], float]:\n    \"\"\"Returns a verifier that runs code against test cases.\"\"\"\n    def verify(response: str) -> float:\n        code = extract_python_code(response)\n        passed = 0\n        for inputs, expected in test_cases:\n            test_script = (\n                code + \"\\n\"\n                f\"result = two_sum({inputs!r})\\n\"\n                f\"assert result == {expected!r}, f'Got {{result}}'\\n\"\n                \"print('PASS')\\n\"\n            )\n            try:\n                with tempfile.NamedTemporaryFile(mode='w', suffix='.py', delete=False) as f:\n                    f.write(test_script)\n                    fname = f.name\n                result = subprocess.run(\n                    ['python3', fname],\n                    capture_output=True, text=True, timeout=5,\n                )\n                os.unlink(fname)\n                if 'PASS' in result.stdout:\n                    passed += 1\n            except Exception:\n                pass\n        return passed / len(test_cases)\n    return verify\n\ntest_cases = [\n    ([2, 7, 11, 15], 9),    # inputs, expected output\n    ([3, 2, 4], 6),\n    ([3, 3], 6),\n]\n\ncode_verifier = execution_verifier(test_cases)\nanswer, score = best_of_n(\n    \"Write a Python function `two_sum(nums)` that returns the sum of any two distinct elements.\",\n    verifier=code_verifier,\n    n=5,\n)\nprint(f\"Tests passed: {score:.0%}\")\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Verifier 2: LLM Judge"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When automated testing is not possible (plans, explanations, essays), use a second LLM call as a judge. Ask it to rate the response on specific criteria:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "JUDGE_PROMPT = \"\"\"You are evaluating a response to the following question.\nQuestion: {question}\nResponse: {response}\n\nRate the response from 0 to 10 on these criteria:\n1. Correctness (is the content accurate?)\n2. Completeness (does it address all parts of the question?)\n3. Clarity (is the explanation easy to follow?)\n\nReply with ONLY a JSON object: {{\"score\": <0-10>, \"reason\": \"<one sentence>\"}}\n\"\"\"\n\ndef llm_judge(question: str) -> Callable[[str], float]:\n    \"\"\"Returns a verifier that uses an LLM to judge response quality.\"\"\"\n    def verify(response: str) -> float:\n        prompt = JUDGE_PROMPT.format(question=question, response=response[:2000])\n        raw = sample_once(prompt, temperature=0.0)\n        try:\n            import json, re\n            # Strip markdown fences if present\n            raw = re.sub(r'^```[a-z]*\\n|```$', '', raw.strip(), flags=re.M).strip()\n            data = json.loads(raw)\n            return float(data[\"score\"]) / 10.0\n        except Exception:\n            return 0.5  # fallback on parse error\n    return verify\n\nquestion = \"Explain how a hash table works and when to use one instead of a list.\"\njudge = llm_judge(question)\nanswer, score = best_of_n(question, verifier=judge, n=4)\nprint(f\"Best score: {score:.2f}\\n{answer[:400]}...\")"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Verifier 3: Mathematical Oracle"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For math problems, a symbolic verifier checks the final numerical answer without executing the reasoning trace:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import re\n\ndef math_oracle(correct_answer: float, tolerance: float = 0.01) -> Callable[[str], float]:\n    \"\"\"Returns a verifier that checks extracted numeric answer.\"\"\"\n    def verify(response: str) -> float:\n        # Extract all numbers from the last 3 lines\n        last_lines = \"\\n\".join(response.strip().split(\"\\n\")[-3:])\n        numbers = re.findall(r'-?\\d+\\.?\\d*', last_lines)\n        if not numbers:\n            return 0.0\n        for num_str in reversed(numbers):\n            try:\n                if abs(float(num_str) - correct_answer) <= tolerance:\n                    return 1.0\n            except ValueError:\n                continue\n        return 0.0\n    return verify\n\noracle = math_oracle(correct_answer=391.0)\nanswer, score = best_of_n(\n    \"What is 17 \u00d7 23? Show your full working.\",\n    verifier=oracle,\n    n=5,\n)\nprint(f\"Correct answer found: {score == 1.0}\\n{answer}\")"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Adaptive Best-of-N"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Fixed N wastes compute when a high-quality answer is found early. Adaptive Best-of-N stops sampling as soon as a candidate exceeds a confidence threshold:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def adaptive_best_of_n(\n    prompt: str,\n    verifier: Callable[[str], float],\n    min_samples: int = 2,\n    max_samples: int = 16,\n    early_stop_score: float = 0.95,\n) -> tuple[str, float, int]:\n    \"\"\"Returns (best_answer, best_score, samples_used).\"\"\"\n    best_answer, best_score = \"\", 0.0\n    samples_used = 0\n\n    for i in range(max_samples):\n        candidate = sample_once(prompt)\n        score = verifier(candidate)\n        samples_used += 1\n\n        if score > best_score:\n            best_answer, best_score = candidate, score\n\n        # Stop early if we have a high-confidence answer\n        if i + 1 >= min_samples and best_score >= early_stop_score:\n            break\n\n    return best_answer, best_score, samples_used\n\nanswer, score, n_used = adaptive_best_of_n(\n    prompt=\"Write a Python function to reverse a linked list iteratively.\",\n    verifier=heuristic_verifier,\n    min_samples=2,\n    max_samples=10,\n    early_stop_score=0.9,\n)\nprint(f\"Used {n_used} samples, score {score:.2f}\")"
          }
        ]
      },
