      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "DebateState: Shared History"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import operator\nfrom typing import Annotated\nfrom typing_extensions import TypedDict\nfrom dataclasses import dataclass\n\n@dataclass\nclass DebateMessage:\n    agent_id: str\n    round: int\n    content: str\n\nclass DebateState(TypedDict):\n    question: str\n    history: Annotated[list[DebateMessage], operator.add]\n    round: int\n    max_rounds: int\n    verdict: str\n    done: bool\n\ndef init_debate(question: str, max_rounds: int = 3) -> DebateState:\n    return {\n        \"question\": question,\n        \"history\": [],\n        \"round\": 0,\n        \"max_rounds\": max_rounds,\n        \"verdict\": \"\",\n        \"done\": False,\n    }"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Debater Agents"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_anthropic import ChatAnthropic\nfrom langchain_core.messages import SystemMessage, HumanMessage\n\ndebate_llm = ChatAnthropic(model=\"claude-sonnet-5\")\n\ndef format_history(history: list[DebateMessage], exclude_agent: str = \"\") -> str:\n    \"\"\"Format debate history for context, optionally excluding one agent's messages.\"\"\"    lines = []\n    for msg in history:\n        label = f\"[{msg.agent_id} - Round {msg.round}]\"\n        lines.append(f\"{label}\\n{msg.content}\\n\")\n    return \"\\n\".join(lines) if lines else \"(no previous messages)\"\n\ndef make_debater(agent_id: str, stance_instruction: str):\n    \"\"\"Factory: creates a debater with a given argumentative stance.\"\"\"\n    def debater_node(state: DebateState) -> dict:\n        prior = format_history(state[\"history\"])\n        \n        prompt = f\"\"\"Question: {state['question']}\n\nDebate history so far:\n{prior}\n\n{stance_instruction}\n\nRound {state['round'] + 1} of {state['max_rounds']}.\n- If you agree with a prior point, say so briefly and build on it.\n- If you disagree, state your objection clearly with reasoning.\n- Keep your response focused (2-4 paragraphs).\n- Do NOT just repeat what was already said.\"\"\"\n        \n        response = debate_llm.invoke([\n            SystemMessage(content=f\"You are {agent_id}, a rigorous debate participant.\"),\n            HumanMessage(content=prompt)\n        ])\n        \n        msg = DebateMessage(\n            agent_id=agent_id,\n            round=state[\"round\"] + 1,\n            content=response.content,\n        )\n        return {\"history\": [msg]}\n    \n    debater_node.__name__ = f\"debater_{agent_id}\"\n    return debater_node\n\n# Proponent: argues for the most direct/obvious solution\nproponent = make_debater(\n    \"proponent\",\n    \"You argue for the simplest effective solution. Defend your position against critiques.\"\n)\n\n# Critic: challenges assumptions and proposes alternatives  \ncritic = make_debater(\n    \"critic\",\n    \"You challenge the proponent's claims. Identify edge cases, failure modes, and hidden costs. Propose alternatives where warranted.\"\n)"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "The Judge Node"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "judge_llm = ChatAnthropic(model=\"claude-opus-4-8\")\n\ndef judge_node(state: DebateState) -> dict:\n    \"\"\"Synthesizes the debate into a final verdict.\"\"\"    history_text = format_history(state[\"history\"])\n    \n    prompt = f\"\"\"Question: {state['question']}\n\nComplete debate transcript:\n{history_text}\n\nYou are a neutral judge. Review the debate and produce a final answer:\n1. Identify where the debaters agreed.\n2. Identify the strongest points from each side.\n3. State your final verdict \u2014 the best answer to the question with caveats noted.\n4. Flag any claims that neither debater adequately supported.\"\"\"\n    \n    response = judge_llm.invoke([\n        SystemMessage(content=\"You are a neutral, rigorous judge synthesizing a technical debate.\"),\n        HumanMessage(content=prompt)\n    ])\n    \n    return {\"verdict\": response.content, \"done\": True}"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Wiring the Debate Graph"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langgraph.graph import StateGraph, END\n\ndef round_counter(state: DebateState) -> dict:\n    \"\"\"Increments the round counter after both debaters have spoken.\"\"\"    return {\"round\": state[\"round\"] + 1}\n\ndef should_continue(state: DebateState) -> str:\n    if state[\"round\"] >= state[\"max_rounds\"]:\n        return \"judge\"\n    return \"proponent\"\n\nbuilder = StateGraph(DebateState)\nbuilder.add_node(\"proponent\", proponent)\nbuilder.add_node(\"critic\", critic)\nbuilder.add_node(\"round_counter\", round_counter)\nbuilder.add_node(\"judge\", judge_node)\n\n# One round: proponent \u2192 critic \u2192 increment round \u2192 check\nbuilder.set_entry_point(\"proponent\")\nbuilder.add_edge(\"proponent\", \"critic\")\nbuilder.add_edge(\"critic\", \"round_counter\")\nbuilder.add_conditional_edges(\"round_counter\", should_continue, {\n    \"proponent\": \"proponent\",\n    \"judge\": \"judge\",\n})\nbuilder.add_edge(\"judge\", END)\n\ndebate_graph = builder.compile()"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Running a Debate"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "question = \"\"\"\nShould we use an in-process cache (e.g. Redis) or a distributed cache (e.g. Memcached)\nfor session data in a horizontally-scaled web application?\n\"\"\"\n\nstate = debate_graph.invoke(init_debate(question, max_rounds=2))\n\nprint(f\"Debate complete: {len(state['history'])} messages across {state['round']} rounds\")\nprint()\nfor msg in state[\"history\"]:\n    print(f\"--- [{msg.agent_id}] Round {msg.round} ---\")\n    print(msg.content[:200], \"...\")\n    print()\nprint(\"=== VERDICT ===\")\nprint(state[\"verdict\"])"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Early Termination on Consensus"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Running the full number of rounds is wasteful if both agents agree early. Add a consensus detector that checks whether the debaters have converged before scheduling the next round."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "consensus_llm = ChatAnthropic(model=\"claude-haiku-4-5-20251001\")\n\ndef check_consensus(state: DebateState) -> str:\n    \"\"\"Quickly check if the last two messages indicate agreement.\"\"\"    if len(state[\"history\"]) < 2:\n        return \"continue\"\n    \n    last_two = state[\"history\"][-2:]\n    excerpt = \"\\n\".join(f\"{m.agent_id}: {m.content[:300]}\" for m in last_two)\n    \n    response = consensus_llm.invoke([\n        SystemMessage(content=\"Reply AGREE if both sides have reached consensus, DISAGREE otherwise. One word only.\"),\n        HumanMessage(content=excerpt)\n    ])\n    \n    verdict = response.content.strip().upper()\n    if \"AGREE\" in verdict:\n        return \"judge\"   # skip remaining rounds\n    \n    if state[\"round\"] >= state[\"max_rounds\"]:\n        return \"judge\"\n    return \"proponent\"\n\n# Replace the fixed conditional edge with the consensus check\nbuilder.add_conditional_edges(\"round_counter\", check_consensus, {\n    \"proponent\": \"proponent\",\n    \"judge\": \"judge\",\n})"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "N-Way Debate with Multiple Debaters"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Two agents can form an echo chamber if both are initialized from the same model. Adding a third with a distinct role \u2014 devil's advocate, domain specialist, risk analyst \u2014 improves coverage."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "devil = make_debater(\n    \"devil_advocate\",\n    \"You argue the exact opposite of whatever the most recent speaker said. Find flaws in both proponent and critic.\"\n)\n\n# N-way wiring: rotate through all debaters each round\nDEBATERS = [\"proponent\", \"critic\", \"devil_advocate\"]\n\ndef make_round_router(debaters: list[str]):\n    \"\"\"Returns a routing function that cycles through debaters per round.\"\"\"    def router(state: DebateState) -> str:\n        msgs_this_round = [m for m in state[\"history\"] if m.round == state[\"round\"] + 1]\n        next_idx = len(msgs_this_round)\n        if next_idx < len(debaters):\n            return debaters[next_idx]\n        # All debaters spoken \u2014 increment round\n        return \"round_counter\"\n    return router"
          }
        ]
      },
