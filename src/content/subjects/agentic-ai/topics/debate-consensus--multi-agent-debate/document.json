          {
            "type": "text",
            "text": "Testing the Debate Graph"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import pytest\nfrom unittest.mock import patch, MagicMock\n\nclass TestDebateGraph:\n    def _init(self, max_rounds=2):\n        return init_debate(\"Is X better than Y?\", max_rounds=max_rounds)\n    \n    def test_history_appends_across_rounds(self):\n        state = self._init()\n        state[\"history\"] = [\n            DebateMessage(\"proponent\", 1, \"X is better because ...\"),\n        ]\n        # Critic reads proponent's message\n        history_text = format_history(state[\"history\"])\n        assert \"proponent\" in history_text\n        assert \"X is better\" in history_text\n    \n    def test_should_continue_routes_to_judge_at_max(self):\n        state = self._init(max_rounds=2)\n        state[\"round\"] = 2\n        assert should_continue(state) == \"judge\"\n    \n    def test_should_continue_routes_to_proponent_before_max(self):\n        state = self._init(max_rounds=3)\n        state[\"round\"] = 1\n        assert should_continue(state) == \"proponent\"\n    \n    @patch(\"debate_llm\")\n    def test_debater_returns_message(self, mock_llm):\n        mock_llm.invoke.return_value = MagicMock(content=\"My argument is X.\")\n        state = self._init()\n        result = proponent(state)\n        assert len(result[\"history\"]) == 1\n        assert result[\"history\"][0].agent_id == \"proponent\"\n        assert result[\"history\"][0].content == \"My argument is X.\"\n    \n    def test_round_counter_increments(self):\n        state = self._init()\n        state[\"round\"] = 1\n        result = round_counter(state)\n        assert result[\"round\"] == 2"
          }
        ]
      },
