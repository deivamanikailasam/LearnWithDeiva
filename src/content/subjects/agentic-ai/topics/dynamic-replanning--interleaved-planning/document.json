        "content": [
          {
            "type": "text",
            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Interleaved planning runs a plan-observe-act loop; the planner is called after each step (or batch of steps) using up-to-date execution history."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "One-step look-ahead maximises adaptability at the cost of one planning LLM call per step."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "K-step look-ahead batches planning to amortise cost across k steps while still adapting every k steps."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Observation-gated re-planning only triggers re-planning when a step's result is surprising, keeping token cost low on predictable sub-tasks."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "History compression prevents context overflow on long tasks by summarising older steps into a short digest."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Choose interleaved planning when environment feedback is essential to deciding the next action; choose Plan-Then-Act when the task is fully predictable upfront."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
