          {
            "type": "text",
            "text": "Testing Synchronization Correctness"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\nimport pytest\n\n\n@pytest.mark.asyncio\nasync def test_lock_prevents_concurrent_writes():\n    counter = 0\n    lock = asyncio.Lock()\n\n    async def increment():\n        nonlocal counter\n        async with lock:\n            val = counter\n            await asyncio.sleep(0)  # yield to event loop\n            counter = val + 1       # write-back\n\n    # Run 100 concurrent increments\n    await asyncio.gather(*[increment() for _ in range(100)])\n    assert counter == 100  # no lost updates\n\n\n@pytest.mark.asyncio\nasync def test_semaphore_limits_concurrency():\n    sem = asyncio.Semaphore(3)\n    active = 0\n    max_active = 0\n\n    async def task():\n        nonlocal active, max_active\n        async with sem:\n            active += 1\n            max_active = max(max_active, active)\n            await asyncio.sleep(0.01)\n            active -= 1\n\n    await asyncio.gather(*[task() for _ in range(20)])\n    assert max_active <= 3  # never exceeded the limit\n\n\n@pytest.mark.asyncio\nasync def test_event_wakes_all_waiters():\n    event = asyncio.Event()\n    results = []\n\n    async def waiter(n):\n        await event.wait()\n        results.append(n)\n\n    tasks = [asyncio.create_task(waiter(i)) for i in range(5)]\n    await asyncio.sleep(0)  # let waiters block\n    event.set()\n    await asyncio.gather(*tasks)\n    assert sorted(results) == [0, 1, 2, 3, 4]"
          }
        ]
