          {
            "type": "text",
            "text": "The messages List as Memory"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Each step of the agent loop appends at least two entries to the "
          },
          {
            "type": "text",
            "text": "messages",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " list: an assistant turn containing the model's "
          },
          {
            "type": "text",
            "text": "tool_use",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " block, and a user turn containing the "
          },
          {
            "type": "text",
            "text": "tool_result",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". The task prompt at "
          },
          {
            "type": "text",
            "text": "messages[0]",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " stays in memory for the entire run:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\n\nclient = anthropic.Anthropic()\n\n# The messages list is short-term memory \u2014 the model sees exactly these\n# messages on each call, nothing more.\n\nmessages: list[dict] = []\n\n# Step 1: task enters memory\nmessages.append({\n    \"role\": \"user\",\n    \"content\": \"Fix the login bug: POST /login with special chars in the password returns 500.\",\n})\n\n# Step 2: model responds with a tool call\nresponse = client.messages.create(\n    model=\"claude-sonnet-4-6\",\n    max_tokens=4096,\n    tools=tools,\n    messages=messages,\n)\nmessages.append({\"role\": \"assistant\", \"content\": response.content})\n\n# Step 3: tool result enters memory\nmessages.append({\n    \"role\": \"user\",\n    \"content\": [{\n        \"type\": \"tool_result\",\n        \"tool_use_id\": response.content[0].id,\n        \"content\": \"auth.py:42: def login(username: str, password: str) -> Session:\",\n    }],\n})\n\n# After N steps:\n# messages = [task, tool_use, tool_result, tool_use, tool_result, ...]\n# Every message is re-sent on every call. Short-term memory is cumulative.\nprint(f\"Messages in memory: {len(messages)}\")\nprint(f\"Approx tokens: {sum(len(str(m)) // 4 for m in messages)}\")\n"
          }
        ]
      },
