        "content": [
          {
            "type": "text",
            "text": "# When the run resets (e.g. a new phase starts or the agent is re-invoked),\n# short-term memory resets too. Persist what the next run needs before resetting.\n\nfrom dataclasses import dataclass\nimport json\n\n\n@dataclass\nclass RunHandoff:\n    \"\"\"Data extracted from short-term memory before a reset.\"\"\"\n    files_read: list[str]\n    findings: list[str]\n    completed_steps: list[str]\n    next_step: str\n\n\ndef extract_handoff(messages: list[dict]) -> RunHandoff:\n    \"\"\"\n    Extract a structured handoff from the current messages list.\n    Called at the end of a run to persist what the next run needs.\n    \"\"\"\n    # In a real implementation, ask the model to extract structured data\n    # from the messages list, or track state in a scratchpad during the run.\n    return RunHandoff(\n        files_read=[\"auth.py\", \"session.py\"],\n        findings=[\"password not URL-decoded at auth.py:42\"],\n        completed_steps=[\"read auth.py\", \"identified root cause\"],\n        next_step=\"apply fix to auth.py:42\",\n    )\n\n\ndef build_continuation_prompt(handoff: RunHandoff, task: str) -> str:\n    \"\"\"Build the initial user turn for the next run from the handoff.\"\"\"\n    return (\n        f\"{task}\\n\\n\"\n        f\"Previous run completed:\\n\"\n        + \"\\n\".join(f\"- {s}\" for s in handoff.completed_steps)\n        + f\"\\n\\nFindings:\\n\"\n        + \"\\n\".join(f\"- {f}\" for f in handoff.findings)\n        + f\"\\n\\nNext step: {handoff.next_step}\"\n    )\n"
          }
        ]
