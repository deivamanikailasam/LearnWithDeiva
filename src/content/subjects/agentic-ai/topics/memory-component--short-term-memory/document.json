      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "How Memory Grows"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Short-term memory grows linearly with the number of steps. The rate depends on the size of tool results \u2014 small results (test pass/fail, git status) grow slowly; large results (file reads, search output) can fill the context in tens of steps:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Each step adds at least two messages:\n#   assistant turn: one tool_use block (or more for parallel calls)\n#   user turn: one tool_result per tool_use\n\n# Token cost breakdown:\nTYPICAL_TOKEN_COSTS = {\n    \"task_prompt\":          500,   # initial user turn\n    \"tool_use_block\":       80,    # per tool call (name + arguments)\n    \"small_tool_result\":    200,   # e.g. git status, test pass/fail\n    \"file_read_result\":    2000,   # e.g. a 150-line Python file\n    \"search_result\":        800,   # e.g. 20 ripgrep matches\n    \"assistant_reasoning\":  300,   # model's explanation per step\n}\n\n# Example: a 20-step coding agent with file reads\ndef estimate_tokens(n_steps: int, result_size: int = 800) -> int:\n    return (\n        TYPICAL_TOKEN_COSTS[\"task_prompt\"]\n        + n_steps * (\n            TYPICAL_TOKEN_COSTS[\"tool_use_block\"]\n            + result_size\n            + TYPICAL_TOKEN_COSTS[\"assistant_reasoning\"]\n        )\n    )\n\n# 20 steps, 800 tokens per result \u2192 ~24,500 tokens (well within 200k)\n# 20 steps, 5000 tokens per result \u2192 ~107,000 tokens (approaching limit)\n# 60 steps, 5000 tokens per result \u2192 ~320,000 tokens (exceeds 200k)\nprint(estimate_tokens(20, 800))   # ~24,500\nprint(estimate_tokens(20, 5000))  # ~107,000\nprint(estimate_tokens(60, 5000))  # ~320,000\n"
          }
        ]
      },
