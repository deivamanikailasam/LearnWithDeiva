              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The model has no other memory",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 there is no background state. If a piece of information is not in "
                  },
                  {
                    "type": "text",
                    "text": "messages",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": ", the model cannot access it. Reading a file puts its contents in short-term memory; forgetting to add the result means the model has not read the file."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Tool results are the dominant cost",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 a 150-line Python file read costs ~2,000 tokens. A 30-step run with one file read per step adds ~60,000 tokens of tool results alone."
                  }
                ]
              }
            ]
          }
        ]
