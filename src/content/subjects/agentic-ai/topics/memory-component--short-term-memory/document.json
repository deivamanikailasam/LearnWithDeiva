        "content": [
          {
            "type": "text",
            "text": "import pytest\n\n\nclass TestCountMessages:\n    def test_counts_by_role(self):\n        messages = [\n            {\"role\": \"user\", \"content\": \"task\"},\n            {\"role\": \"assistant\", \"content\": \"response\"},\n            {\"role\": \"user\", \"content\": \"follow-up\"},\n        ]\n        stats = count_messages(messages)\n        assert stats[\"total_messages\"] == 3\n        assert stats[\"user_turns\"] == 2\n        assert stats[\"assistant_turns\"] == 1\n\n    def test_approx_tokens_positive(self):\n        messages = [{\"role\": \"user\", \"content\": \"hello world\"}]\n        stats = count_messages(messages)\n        assert stats[\"approx_tokens\"] > 0\n\n\nclass TestTrimOldestToolPairs:\n    def _make_messages(self, n_pairs: int) -> list[dict]:\n        msgs = [{\"role\": \"user\", \"content\": \"task\"}]\n        for _ in range(n_pairs):\n            msgs.append({\"role\": \"assistant\", \"content\": \"tool_use\"})\n            msgs.append({\"role\": \"user\", \"content\": \"tool_result\"})\n        return msgs\n\n    def test_trims_when_over_limit(self):\n        messages = self._make_messages(5)\n        original_len = len(messages)\n        # Set a very low limit so trimming is triggered\n        trimmed = trim_oldest_tool_pairs(messages, keep_first_n=1, max_tokens=10)\n        assert len(trimmed) < original_len\n\n    def test_always_keeps_first_message(self):\n        messages = self._make_messages(5)\n        trimmed = trim_oldest_tool_pairs(messages, keep_first_n=1, max_tokens=10)\n        assert trimmed[0][\"content\"] == \"task\"\n"
          }
