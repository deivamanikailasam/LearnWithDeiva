      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "External REST API and Webhook Risks"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Agents commonly call external REST APIs (Slack, Stripe, Jira, GitHub) with credentials scoped to the agent's service account. Two specific risks:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Credential over-scoping:",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " the agent's API token may hold org-admin permissions even though it only needs read access."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Webhook replay:",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " a webhook from an external service arrives over HTTP; without signature verification the agent may act on a replayed or forged payload."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import hashlib, hmac, time\n\n# \u2500\u2500 Principle of Least Privilege: scope tokens at call-time \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# Instead of a single god-token, derive scoped credentials per action.\n\nSLACK_SCOPES: dict[str, list[str]] = {\n    \"read_only\":    [\"channels:read\", \"users:read\"],\n    \"post_message\": [\"chat:write\"],\n    \"full\":         [\"channels:read\", \"chat:write\", \"files:write\"],\n}\n\ndef get_scoped_slack_token(capability: str) -> str:\n    required = SLACK_SCOPES.get(capability)\n    if required is None:\n        raise ValueError(f\"Unknown capability '{capability}'\")\n    # Exchange a long-lived refresh token for a short-lived token\n    # with exactly the needed scopes (Slack OAuth token exchange).\n    # Shown schematically \u2014 implementation depends on Slack SDK.\n    return _exchange_for_scoped_token(required)\n\n# \u2500\u2500 Webhook signature verification \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nSLACK_SIGNING_SECRET = b\"your-slack-signing-secret\"\n\ndef verify_slack_webhook(\n    body: bytes,\n    timestamp: str,\n    received_sig: str,\n) -> bool:\n    \"\"\"Reject replays older than 5 minutes and verify HMAC.\"\"\"\n    now = int(time.time())\n    if abs(now - int(timestamp)) > 300:\n        return False  # replay protection\n    base = f\"v0:{timestamp}:\".encode() + body\n    expected = \"v0=\" + hmac.new(\n        SLACK_SIGNING_SECRET, base, hashlib.sha256\n    ).hexdigest()\n    return hmac.compare_digest(expected, received_sig)\n"
          }
        ]
      },
