        "content": [
          {
            "type": "text",
            "text": "Telemetry and Monitoring Vendor Risks"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Observability vendors (Datadog, Splunk, LangSmith, Weights & Biases) receive structured logs from your agent, which often include prompt content and tool call arguments. This is one of the most overlooked data-exfiltration vectors: a compromised telemetry vendor has read access to every conversation your agent has had."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import re\nfrom typing import Any\n\n# Fields that must never leave the service boundary\n_SENSITIVE_FIELDS = frozenset({\"api_key\", \"password\", \"ssn\", \"credit_card\",\n                                \"token\", \"secret\", \"authorization\"})\n_VALUE_PATTERNS = [\n    re.compile(r'\\b\\d{4}[- ]\\d{4}[- ]\\d{4}[- ]\\d{4}\\b'),  # card number\n    re.compile(r'\\b\\d{3}-\\d{2}-\\d{4}\\b'),                    # SSN\n]\n\ndef sanitise_for_telemetry(obj: Any, depth: int = 0) -> Any:\n    \"\"\"Recursively strip sensitive values before shipping to a telemetry vendor.\"\"\"\n    if depth > 8:\n        return \"[truncated]\"\n    if isinstance(obj, dict):\n        return {\n            k: \"[REDACTED]\" if k.lower() in _SENSITIVE_FIELDS\n            else sanitise_for_telemetry(v, depth + 1)\n            for k, v in obj.items()\n        }\n    if isinstance(obj, list):\n        return [sanitise_for_telemetry(i, depth + 1) for i in obj]\n    if isinstance(obj, str):\n        for pat in _VALUE_PATTERNS:\n            obj = pat.sub(\"[REDACTED]\", obj)\n        return obj\n    return obj\n\n# Usage\ndef emit_trace(span_name: str, attributes: dict) -> None:\n    safe_attrs = sanitise_for_telemetry(attributes)\n    _telemetry_client.emit(span_name, safe_attrs)  # external vendor call\n"
          }
        ]
      },
