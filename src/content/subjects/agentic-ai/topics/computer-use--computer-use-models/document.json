      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def prune_old_screenshots(messages: list[dict]) -> list[dict]:\n    \"\"\"Replace all but the most recent screenshot image with a text placeholder.\n    \n    Keeps the message structure intact so tool_use / tool_result IDs stay aligned.\n    \"\"\"\n    # Find indices of all image blocks in tool_result messages\n    image_positions = []\n    for i, msg in enumerate(messages):\n        if msg[\"role\"] == \"user\":\n            for j, block in enumerate(msg.get(\"content\", [])):\n                if isinstance(block, dict) and block.get(\"type\") == \"tool_result\":\n                    for k, content_block in enumerate(block.get(\"content\", [])):\n                        if isinstance(content_block, dict) and content_block.get(\"type\") == \"image\":\n                            image_positions.append((i, j, k))\n\n    # Keep the last screenshot; replace earlier ones\n    for pos in image_positions[:-1]:\n        i, j, k = pos\n        messages[i][\"content\"][j][\"content\"][k] = {\n            \"type\": \"text\",\n            \"text\": \"[screenshot removed to reduce context size]\",\n        }\n    return messages"
          }
        ]
      },
