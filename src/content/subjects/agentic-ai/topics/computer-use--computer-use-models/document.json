      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import pytest\nfrom unittest.mock import patch, MagicMock, call\nimport base64, json\nfrom pathlib import Path\n\n# Fixture: saved API responses for a recorded agent run\nFIXTURES_DIR = Path(\"tests/fixtures/computer_use\")\n\ndef load_fixture_response(name: str) -> dict:\n    return json.loads((FIXTURES_DIR / f\"{name}.json\").read_text())\n\ndef dummy_screenshot_b64() -> str:\n    \"\"\"Return a minimal valid base64 PNG for tests (1x1 white pixel).\"\"\"\n    import io\n    from PIL import Image\n    buf = io.BytesIO()\n    Image.new(\"RGB\", (1, 1), (255, 255, 255)).save(buf, format=\"PNG\")\n    return base64.standard_b64encode(buf.getvalue()).decode()\n\n\nclass TestComputerUseLoop:\n    def test_screenshot_action_returns_image(self):\n        \"\"\"execute_action('screenshot') should return an image content block.\"\"\"\n        with patch(\"PIL.ImageGrab.grab\") as mock_grab:\n            from PIL import Image\n            mock_grab.return_value = Image.new(\"RGB\", (1280, 800))\n            result = execute_action({\"action\": \"screenshot\"})\n        assert result[\"type\"] == \"image\"\n        assert result[\"source\"][\"media_type\"] == \"image/png\"\n\n    def test_click_action_calls_pyautogui(self):\n        with patch(\"pyautogui.click\") as mock_click, \\\n             patch(\"pyautogui.moveTo\") as mock_move:\n            execute_action({\"action\": \"left_click\", \"coordinate\": [100, 200]})\n            mock_click.assert_called_once_with(100, 200)\n\n    def test_type_action_uses_clipboard(self):\n        with patch(\"pyperclip.copy\") as mock_copy, \\\n             patch(\"pyautogui.hotkey\") as mock_hotkey:\n            execute_action({\"action\": \"type\", \"text\": \"hello@example.com\"})\n            mock_copy.assert_called_once_with(\"hello@example.com\")\n            mock_hotkey.assert_called_once_with(\"ctrl\", \"v\")\n\n    def test_key_action_handles_hotkey_syntax(self):\n        with patch(\"pyautogui.hotkey\") as mock_hotkey:\n            execute_action({\"action\": \"key\", \"text\": \"ctrl+c\"})\n            mock_hotkey.assert_called_once_with(\"ctrl\", \"c\")\n\n    def test_agent_loop_terminates_on_end_turn(self):\n        \"\"\"Agent should stop when stop_reason == end_turn with no tool use.\"\"\"\n        mock_response = MagicMock()\n        mock_response.stop_reason = \"end_turn\"\n        mock_response.content = [MagicMock(type=\"text\", text=\"Done.\")]\n\n        with patch(\"anthropic.Anthropic\") as MockClient, \\\n             patch(\"PIL.ImageGrab.grab\") as mock_grab:\n            from PIL import Image\n            mock_grab.return_value = Image.new(\"RGB\", (1280, 800))\n            mock_client = MockClient.return_value\n            mock_client.messages.create.return_value = mock_response\n            result = run_computer_use_agent(\"open the browser\")\n\n        assert result == \"Done.\" "
          }
        ]
