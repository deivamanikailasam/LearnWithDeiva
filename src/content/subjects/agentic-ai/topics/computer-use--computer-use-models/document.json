      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Implementing the Agent Loop"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The loop runs until the model produces an "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "end_turn"
          },
          {
            "type": "text",
            "text": " stop reason with no pending tool calls. On each iteration: collect any tool use blocks from the response, execute each action on the real desktop, return the results (screenshots for "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "screenshot"
          },
          {
            "type": "text",
            "text": " actions; acknowledgements for others), and send back as a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "tool_result"
          },
          {
            "type": "text",
            "text": " user message."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic, base64, io, time\nfrom PIL import ImageGrab\nimport pyautogui\n\nclient = anthropic.Anthropic()\n\nSCREEN_W, SCREEN_H = 1280, 800\nCOMPUTER_TOOL = {\n    \"type\": \"computer_20251022\",\n    \"name\": \"computer\",\n    \"display_width_px\": SCREEN_W,\n    \"display_height_px\": SCREEN_H,\n    \"display_number\": 1,\n}\n\ndef take_screenshot() -> str:\n    \"\"\"Return base64-encoded PNG of the current screen.\"\"\"\n    buf = io.BytesIO()\n    ImageGrab.grab().resize((SCREEN_W, SCREEN_H)).save(buf, format=\"PNG\")\n    return base64.standard_b64encode(buf.getvalue()).decode()\n\ndef execute_action(action: dict) -> dict:\n    \"\"\"Execute one computer tool action and return a tool_result content block.\"\"\"\n    act = action[\"action\"]\n\n    if act == \"screenshot\":\n        img_b64 = take_screenshot()\n        return {\n            \"type\": \"image\",\n            \"source\": {\"type\": \"base64\", \"media_type\": \"image/png\", \"data\": img_b64},\n        }\n\n    # All non-screenshot actions return a simple text acknowledgement\n    if act == \"mouse_move\":\n        x, y = action[\"coordinate\"]\n        pyautogui.moveTo(x, y, duration=0.1)\n    elif act == \"left_click\":\n        x, y = action[\"coordinate\"]\n        pyautogui.click(x, y)\n    elif act == \"right_click\":\n        x, y = action[\"coordinate\"]\n        pyautogui.rightClick(x, y)\n    elif act == \"double_click\":\n        x, y = action[\"coordinate\"]\n        pyautogui.doubleClick(x, y)\n    elif act == \"left_click_drag\":\n        sx, sy = action[\"start_coordinate\"]\n        ex, ey = action[\"coordinate\"]\n        pyautogui.moveTo(sx, sy, duration=0.1)\n        pyautogui.dragTo(ex, ey, duration=0.3, button=\"left\")\n    elif act == \"type\":\n        import pyperclip\n        pyperclip.copy(action[\"text\"])\n        pyautogui.hotkey(\"ctrl\", \"v\")\n    elif act == \"key\":\n        # Model uses xdotool syntax: \"ctrl+c\", \"Return\", \"super\"\n        keys = action[\"text\"].split(\"+\")\n        pyautogui.hotkey(*keys)\n    elif act == \"scroll\":\n        x, y = action[\"coordinate\"]\n        direction = action.get(\"direction\", \"down\")\n        amount = int(action.get(\"amount\", 3))\n        pyautogui.moveTo(x, y, duration=0.1)\n        pyautogui.scroll(amount if direction == \"up\" else -amount)\n    time.sleep(0.3)  # let the UI settle\n    return {\"type\": \"text\", \"text\": f\"Action '{act}' executed.\"}\n\n\ndef run_computer_use_agent(task: str, max_steps: int = 30) -> str:\n    \"\"\"Full computer-use agent loop using Claude's built-in computer tool.\"\"\"\n    # Start with a screenshot so the model knows the initial screen state\n    initial_screenshot = take_screenshot()\n    messages = [\n        {\n            \"role\": \"user\",\n            \"content\": [\n                {\n                    \"type\": \"image\",\n                    \"source\": {\"type\": \"base64\", \"media_type\": \"image/png\", \"data\": initial_screenshot},\n                },\n                {\"type\": \"text\", \"text\": task},\n            ],\n        }\n    ]\n\n    for step in range(max_steps):\n        response = client.messages.create(\n            model=\"claude-opus-4-8\",\n            max_tokens=1024,\n            tools=[COMPUTER_TOOL],\n            messages=messages,\n            betas=[\"computer-use-2024-10-22\"],\n        )\n\n        # Collect text output from the model\n        text_parts = [b.text for b in response.content if b.type == \"text\"]\n        tool_uses  = [b for b in response.content if b.type == \"tool_use\"]\n\n        if response.stop_reason == \"end_turn\" or not tool_uses:\n            return \" \".join(text_parts) or \"Task completed.\"\n\n        # Execute each tool call\n        tool_results = []\n        for tu in tool_uses:\n            result_content = execute_action(tu.input)\n            tool_results.append({\n                \"type\": \"tool_result\",\n                \"tool_use_id\": tu.id,\n                \"content\": [result_content],\n            })\n\n        messages.append({\"role\": \"assistant\", \"content\": response.content})\n        messages.append({\"role\": \"user\", \"content\": tool_results})\n\n    return \"Reached max steps without completing task.\" "
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "System Prompt Engineering for Computer Use"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The model's default behaviour is already calibrated for computer use, but a well-crafted system prompt improves reliability for specific workflows. Key instructions to include:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Take a screenshot before acting"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 instruct the model to always call screenshot first if it has not seen the current state. This prevents stale-state mistakes."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Verify after each click"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 ask the model to take a screenshot after navigating to verify the expected page loaded before proceeding."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Describe failure clearly"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 if the task cannot be completed, the model should say so explicitly rather than clicking randomly."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Scope and safety"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 specify which applications and domains are in scope. Without constraints, the model may navigate to unintended sites."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "SYSTEM_PROMPT = \"\"\"You are a computer-use agent operating a Linux desktop.\n\nRules:\n1. Always take a screenshot before your first action to see the current screen state.\n2. After clicking a link or button that triggers navigation, take a screenshot to confirm the new page loaded.\n3. Prefer keyboard shortcuts over mouse actions when they are faster and less error-prone.\n4. If you cannot find an element after two attempts, report what you see and stop.\n5. Only interact with: the browser, the terminal, and text editors. Do not open system settings, email, or social media.\n6. If asked to enter credentials, use only the values provided in the task \u2014 do not invent them.\n\"\"\"\n\n# Pass system prompt to the API:\nresponse = client.messages.create(\n    model=\"claude-opus-4-8\",\n    max_tokens=1024,\n    system=SYSTEM_PROMPT,\n    tools=[COMPUTER_TOOL],\n    messages=messages,\n    betas=[\"computer-use-2024-10-22\"],\n)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Cost and Latency Characteristics"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Computer-use agents are token-intensive. Each screenshot is a large image (typically 1\u20134M tokens of image data depending on resolution), and multi-step tasks require many round-trips. Typical cost drivers:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Screenshot frequency"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 every screenshot call adds an image to the next request. A 20-step task with 1 screenshot per step sends 20 large images."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Message history growth"
                  },
                  {
                    "type": "text",
                    "text": " \u2014 messages accumulate with each step. Prune the history by replacing old screenshots with a placeholder text (\"[screenshot removed]\") after each step; keep only the most recent one."
