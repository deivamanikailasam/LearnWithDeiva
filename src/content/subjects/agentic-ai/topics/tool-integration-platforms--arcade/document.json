      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing Arcade-Backed Agents"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import pytest\nfrom unittest.mock import patch, MagicMock\n\ndef make_execution(requires_auth=False, requires_approval=False,\n                   status=\"completed\", output=None):\n    ex = MagicMock()\n    ex.requires_auth = requires_auth\n    ex.requires_approval = requires_approval\n    ex.authorization_url = \"https://auth.arcade.dev/connect/github\"\n    ex.approval_url = \"https://auth.arcade.dev/approve/xyz\"\n    ex.status = status\n    ex.output = output or {\"result\": \"ok\"}\n    return ex\n\ndef test_tool_result_returned_when_no_auth_needed():\n    mock_execution = make_execution(output={\"issues\": []})\n    with patch(\"arcadepy.Arcade\") as MockArcade:\n        mock_arcade = MockArcade.return_value\n        mock_arcade.tools.execute.return_value = mock_execution\n        mock_arcade.tools.list.return_value = [{\"name\": \"GitHub.ListIssues\"}]\n\n        arcade = MockArcade(api_key=\"test\")\n        result = arcade.tools.execute(\n            tool_name=\"GitHub.ListIssues\",\n            inputs={\"repo\": \"anthropics/sdk\"},\n            user_id=\"user_alice\",\n        )\n\n    assert result.requires_auth is False\n    assert result.output == {\"issues\": []}\n\ndef test_auth_required_returns_url():\n    mock_execution = make_execution(requires_auth=True)\n    with patch(\"arcadepy.Arcade\") as MockArcade:\n        mock_arcade = MockArcade.return_value\n        mock_arcade.tools.execute.return_value = mock_execution\n\n        arcade = MockArcade(api_key=\"test\")\n        result = arcade.tools.execute(\"GitHub.Star\", {}, user_id=\"user_bob\")\n\n    assert result.requires_auth is True\n    assert \"arcade.dev\" in result.authorization_url\n\ndef test_approval_timeout_returns_error():\n    mock_execution = make_execution(requires_approval=True)\n    pending = make_execution(status=\"pending\")\n\n    with patch(\"arcadepy.Arcade\") as MockArcade, patch(\"time.sleep\"):\n        mock_arcade = MockArcade.return_value\n        mock_arcade.tools.execute.return_value = mock_execution\n        mock_arcade.tools.get_execution.return_value = pending\n\n        arcade = MockArcade(api_key=\"test\")\n        result = execute_with_approval(\n            \"Google.SendEmail\", {}, \"user_alice\", timeout_seconds=0.01\n        )\n\n    assert result[\"error\"] == \"TIMEOUT\"\n"
          }
        ]
      },
