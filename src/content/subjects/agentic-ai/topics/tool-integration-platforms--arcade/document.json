        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import time\nfrom arcadepy import Arcade, ArcadeError\n\narcade = Arcade()\n\ndef safe_execute(tool_name: str, inputs: dict, user_id: str, max_retries: int = 3) -> dict:\n    delay = 1.0\n    for attempt in range(max_retries):\n        try:\n            ex = arcade.tools.execute(\n                tool_name=tool_name,\n                inputs=inputs,\n                user_id=user_id,\n            )\n        except ArcadeError:\n            if attempt == max_retries - 1:\n                raise\n            time.sleep(delay)\n            delay *= 2\n            continue\n\n        if ex.requires_auth:\n            return {\"error\": \"auth_required\", \"authorization_url\": ex.authorization_url}\n        if ex.error:\n            return {\"error\": ex.error.message, \"code\": ex.error.code}\n        return ex.output\n\n    raise RuntimeError(\"Unreachable\")\n"
          }
        ]
      },
