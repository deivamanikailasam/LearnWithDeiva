                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "The 'AllTrusted' virtual location ID aggregates every named location where isTrusted = true. Use it in the ExcludeLocations list to reduce MFA prompts for corporate office sign-ins without listing individual location IDs in every policy."
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Creating IP Named Locations"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "IP named locations match sign-in requests by comparing the user's source IP address against configured CIDR ranges. Setting isTrusted = true on a location makes it count as a 'compliant network' signal, which CA policies can exclude from MFA requirements \u2014 effectively trusting that network for reduced friction."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "powershell"
        },
        "content": [
          {
            "type": "text",
            "text": "# Create an IP named location for corporate offices\nConnect-MgGraph -Scopes 'Policy.Read.All', 'Policy.ReadWrite.ConditionalAccess'\n\n# Single-site corporate egress\n$body = @{\n    '@odata.type' = '#microsoft.graph.ipNamedLocation'\n    DisplayName = 'Corporate HQ - San Francisco'\n    IsTrusted = $true\n    IpRanges = @(\n        @{ '@odata.type' = '#microsoft.graph.iPv4CidrRange'; CidrAddress = '203.0.113.0/24' },\n        @{ '@odata.type' = '#microsoft.graph.iPv6CidrRange'; CidrAddress = '2001:db8::/32' }\n    )\n} | ConvertTo-Json -Depth 5\n\nInvoke-MgGraphRequest -Method POST \\\n    -Uri 'https://graph.microsoft.com/v1.0/identity/conditionalAccess/namedLocations' \\\n    -Body $body -ContentType 'application/json'\n\n# Create a non-trusted location for partner offices (used for targeting, not trust)\n$body = @{\n    '@odata.type' = '#microsoft.graph.ipNamedLocation'\n    DisplayName = 'Partner Network - NYC'\n    IsTrusted = $false\n    IpRanges = @(\n        @{ '@odata.type' = '#microsoft.graph.iPv4CidrRange'; CidrAddress = '198.51.100.0/24' }\n    )\n} | ConvertTo-Json -Depth 5\n\nInvoke-MgGraphRequest -Method POST \\\n    -Uri 'https://graph.microsoft.com/v1.0/identity/conditionalAccess/namedLocations' \\\n    -Body $body -ContentType 'application/json'"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "IPv4 ranges use iPv4CidrRange; IPv6 uses iPv6CidrRange \u2014 both can be combined in the same named location."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "A single named location supports up to 2000 IP ranges \u2014 use one location per physical site, with all egress IPs for that site in the same location."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Tenant limit: 195 IP named locations. Use broader CIDR ranges when the limit is approached rather than creating many small locations."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Updating a named location's IP ranges propagates to all CA policies that reference it within seconds \u2014 no policy edits required."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Creating Country Named Locations"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Country named locations match sign-ins by resolving the source IP to a country code using Entra ID's GeoIP database. They are commonly used to block access from sanctioned countries or restrict certain apps to specific regions. Country locations cannot be marked as trusted."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "powershell"
        },
        "content": [
          {
            "type": "text",
            "text": "# Create a country named location to block sanctioned countries\n$body = @{\n    '@odata.type' = '#microsoft.graph.countryNamedLocation'\n    DisplayName = 'Blocked Countries - Sanctions List'\n    CountriesAndRegions = @('CN', 'RU', 'KP', 'IR', 'BY')  # ISO 3166-1 alpha-2\n    IncludeUnknownCountriesAndRegions = $true  # catches satellite, proxy, VPN\n} | ConvertTo-Json -Depth 3\n\nInvoke-MgGraphRequest -Method POST \\\n    -Uri 'https://graph.microsoft.com/v1.0/identity/conditionalAccess/namedLocations' \\\n    -Body $body -ContentType 'application/json'\n\n# Use in CA policy to block access from these countries\n# (Assumes you saved the location ID from the POST response)\n$blockedCountriesId = '<location-id-from-response>'\n\nNew-MgIdentityConditionalAccessPolicy -BodyParameter @{\n    DisplayName = 'CA: Block Sanctioned Countries'\n    State = 'enabled'\n    Conditions = @{\n        Users = @{ IncludeUsers = @('all') }\n        Applications = @{ IncludeApplications = @('all') }\n        Locations = @{\n            IncludeLocations = @($blockedCountriesId)\n        }\n    }\n    GrantControls = @{\n        Operator = 'OR'\n        BuiltInControls = @('block')\n    }\n}"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Always set includeUnknownCountriesAndRegions = true on block policies. Unknown country means the IP address could not be mapped to any country \u2014 this includes Tor exit nodes, some VPN providers, and satellite internet providers. Leaving it false lets attackers route through these IPs to bypass the block."
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "MFA Outside Trusted Locations \u2014 Common Pattern"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The most widely deployed named-location CA policy requires MFA for all sign-ins except those originating from trusted corporate IP addresses. This reduces authentication friction for on-premises users while enforcing MFA for remote and unrecognized locations."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "powershell"
        },
        "content": [
          {
            "type": "text",
            "text": "# Classic pattern: require MFA for all sign-ins OUTSIDE trusted locations\n# This reduces MFA prompts for users in the office while enforcing it everywhere else\n\nNew-MgIdentityConditionalAccessPolicy -BodyParameter @{\n    DisplayName = 'CA: MFA Outside Trusted Locations'\n    State = 'enabled'\n    Conditions = @{\n        Users = @{ IncludeUsers = @('all') }\n        Applications = @{ IncludeApplications = @('all') }\n        Locations = @{\n            IncludeLocations = @('All')  # all locations\n            ExcludeLocations = @('AllTrusted')  # except trusted named locations\n        }\n    }\n    GrantControls = @{\n        Operator = 'OR'\n        BuiltInControls = @('mfa')\n    }\n}\n\n# Note: 'AllTrusted' is a special virtual location ID that aggregates\n# all named locations where isTrusted = true."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Infrastructure-as-Code with Terraform"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Named locations managed in Terraform prevent ad-hoc portal changes and make IP range updates auditable via Git pull requests. The azuread_named_location resource supports both ip and country blocks."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "hcl"
        },
        "content": [
          {
            "type": "text",
            "text": "# Terraform: IP named location (trusted corporate network)\nresource \"azuread_named_location\" \"corporate_hq\" {\n  display_name = \"Corporate HQ - Chicago\"\n\n  ip {\n    ip_ranges = [\n      \"203.0.113.0/24\",\n      \"2001:db8::/32\",\n    ]\n    trusted = true\n  }\n}\n\n# Terraform: Country named location (block list)\nresource \"azuread_named_location\" \"blocked_countries\" {\n  display_name = \"Blocked Countries\"\n\n  country {\n    countries_and_regions                = [\"CN\", \"RU\", \"KP\", \"IR\"]\n    include_unknown_countries_and_regions = true\n  }\n}\n\n# Reference in a CA policy\nresource \"azuread_conditional_access_policy\" \"mfa_outside_corp\" {\n  display_name = \"CA: MFA Outside Corp Network\"\n  state        = \"enabled\"\n\n  conditions {\n    users { included_users = [\"All\"] }\n    applications { included_applications = [\"All\"] }\n    locations {\n      included_locations = [\"All\"]\n      excluded_locations = [\"AllTrusted\", azuread_named_location.corporate_hq.id]\n    }\n  }\n\n  grant_controls {\n    operator          = \"OR\"\n    built_in_controls = [\"mfa\"]\n  }\n}"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Auditing Named Locations"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Named location configurations drift over time as offices move, VPNs change, or IP allocations are reassigned. Run periodic audits to verify that all trusted ranges are still owned by the organization and that no CA policies have become vacuous due to deleted locations."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "powershell"
        },
        "content": [
          {
            "type": "text",
            "text": "# Enumerate all named locations and report their type and trust state\n$locations = Invoke-MgGraphRequest -Method GET \\\n    -Uri 'https://graph.microsoft.com/v1.0/identity/conditionalAccess/namedLocations' \\\n    -OutputType PSObject\n\nforeach ($loc in $locations.value) {\n    $type = $loc.'@odata.type'\n    if ($type -eq '#microsoft.graph.ipNamedLocation') {\n        $ranges = $loc.ipRanges | ForEach-Object { $_.cidrAddress }\n        $trusted = $loc.isTrusted\n        [PSCustomObject]@{\n            Name = $loc.displayName\n            Type = 'IP'\n            Trusted = $trusted\n            Ranges = $ranges -join ', '\n            RangeCount = $ranges.Count\n        }\n    } elseif ($type -eq '#microsoft.graph.countryNamedLocation') {\n        [PSCustomObject]@{\n            Name = $loc.displayName\n            Type = 'Country'\n            Trusted = 'N/A'\n            Ranges = $loc.countriesAndRegions -join ', '\n            RangeCount = $loc.countriesAndRegions.Count\n        }\n    }\n} | Format-Table -AutoSize\n\n# Find any CA policy that does NOT exclude a trusted location for MFA\n# (signals a policy that prompts MFA even at corporate offices \u2014 potential UX issue)\n$allPolicies = Invoke-MgGraphRequest -Method GET \\\n    -Uri 'https://graph.microsoft.com/v1.0/identity/conditionalAccess/policies' \\\n    -OutputType PSObject\n\nforeach ($p in $allPolicies.value) {\n    $excludedLocs = $p.conditions.locations.excludeLocations\n    $hasGrantMfa = $p.grantControls.builtInControls -contains 'mfa'\n    $excludesTrusted = $excludedLocs -contains 'AllTrusted'\n    if ($hasGrantMfa -and -not $excludesTrusted) {\n        Write-Host \"Policy prompts MFA everywhere (no AllTrusted exclusion): $($p.displayName)\"\n    }\n}"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "table",
        "content": [
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableHeader",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Pitfall"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableHeader",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Risk"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableHeader",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Fix"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Overly broad CIDR (/8 or /16)"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Attackers from nearby IPs bypass MFA"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Use /24 or narrower for all corporate egress IPs"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Too many IPs marked Trusted"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Reduced MFA coverage for non-corp users at trusted IPs"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Audit isTrusted flag quarterly; only mark confirmed corporate IPs"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "includeUnknownCountriesAndRegions = false on block list"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "VPN and proxy users evade country block"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Always set includeUnknownCountriesAndRegions = true on block policies"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Deleting a location referenced by CA policies"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "CA policy silently ignores deleted location (condition vacuous)"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Check all policies referencing a location before deleting; update policies first"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Using location exclusion instead of MFA trusted-IP exclusion"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Legacy MFA per-user settings may conflict"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Prefer CA named-location exclusion over MFA service settings for new policies"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Not excluding break-glass accounts from country-block policies"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Break-glass locked out if operating from a blocked country"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Add break-glass accounts to exclusion group on all block policies"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "KQL Monitoring"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Sign-in logs capture which named network a sign-in matched. Use KQL queries in Log Analytics or Microsoft Sentinel to detect access from unexpected locations and to measure the distribution of sign-ins by named location."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "kusto"
        },
        "content": [
          {
            "type": "text",
            "text": "// KQL: sign-ins from named locations (breakdown by location name)\nSigninLogs\n| where TimeGenerated >= ago(7d)\n| extend LocationName = tostring(LocationDetails.city)\n| extend NetworkLocationId = tostring(NetworkLocationDetails[0].networkNames)\n| where isnotempty(NetworkLocationId)\n| summarize SignIns = count(), Users = dcount(UserPrincipalName)\n    by NetworkLocationId, ResultType\n| order by SignIns desc\n\n// KQL: sign-ins from unexpected countries (outside expected list)\nlet allowed_countries = dynamic(['US', 'GB', 'CA', 'DE', 'AU']);\nSigninLogs\n| where TimeGenerated >= ago(24h)\n| where ResultType == 0\n| where Location !in (allowed_countries)\n| summarize Count = count() by UserPrincipalName, Location, AppDisplayName\n| order by Count desc"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "IP named locations match by CIDR range; isTrusted = true grants the compliant-network signal and enables exclusion from MFA policies."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Country named locations match by GeoIP country code; they cannot be trusted and are used for blocking or regional targeting."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "'AllTrusted' is a virtual location ID that aggregates all trusted IP named locations \u2014 use it in ExcludeLocations to reduce corporate MFA prompts."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Always set includeUnknownCountriesAndRegions = true on block policies to catch Tor, VPN, and satellite IPs without country assignments."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Manage named locations in Terraform or Bicep so IP range changes are peer-reviewed and auditable via source control."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Audit trusted IP ranges quarterly \u2014 stale or overly broad CIDRs undermine the security value of location-based MFA exclusions."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}