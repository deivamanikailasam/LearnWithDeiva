                        "text": "Property"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableHeader",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "IP Named Location"
                      }
                    ]
                  }
                ]
              },
              {
