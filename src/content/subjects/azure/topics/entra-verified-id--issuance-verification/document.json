              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "An Azure subscription with Entra Verified ID enabled \u2014 set up via the Microsoft Entra admin center under Verified ID."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
