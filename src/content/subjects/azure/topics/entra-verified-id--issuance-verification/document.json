      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Session Polling Pattern (JavaScript)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The frontend polls your app's status endpoint every two seconds until a terminal status (success or error) is returned. This pattern decouples the Authenticator interaction from the browser session."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "javascript"
        },
        "content": [
          {
            "type": "text",
            "text": "// poll-vc-status.js \u2014 frontend polling for issuance or verification result\nasync function pollStatus(endpoint, intervalMs = 2000, maxAttempts = 90) {\n  for (let i = 0; i < maxAttempts; i++) {\n    await new Promise(r => setTimeout(r, intervalMs));\n    const resp   = await fetch(endpoint, { credentials: 'include' });\n    const result = await resp.json();\n\n    if (result.status === 'issuance_successful' || result.status === 'verified') {\n      return { success: true, data: result };\n    }\n    if (result.status === 'issuance_error' || result.status === 'presentation_error') {\n      return { success: false, error: result.status };\n    }\n    // 'pending' or 'request_retrieved' \u2014 keep polling\n  }\n  return { success: false, error: 'timeout' };\n}\n\n// Usage after showing the QR code:\nconst result = await pollStatus('/api/issuance/status');\nif (result.success) {\n  document.getElementById('status').textContent = 'Credential issued successfully!';\n} else {\n  document.getElementById('status').textContent = `Failed: ${result.error}`;\n}"
          }
        ]
      },
