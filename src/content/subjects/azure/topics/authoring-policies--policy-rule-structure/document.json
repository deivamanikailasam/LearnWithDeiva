              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Regex-style pattern (# = digit, ? = letter)"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "\"field\": \"name\", \"match\": \"vm-###\""
                      }
                    ]
                  }
                ]
              }
            ]
