              {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Mistral-7B-v0.3"}]}]},
              {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Mistral-7B-Instruct-v0.3"}]}]}
            ]
