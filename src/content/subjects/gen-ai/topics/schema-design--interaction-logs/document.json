    "content": [
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Schema Design for Interaction Logs"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Interaction logs are the permanent record of every exchange between a user and the LLM. They serve four distinct consumers: the application (reconstructing conversation history for the next API call), the analytics pipeline (quality and cost dashboards), the compliance team (GDPR erasure, audit trail), and the ML team (fine-tuning dataset export). A schema that serves all four without becoming a tangled monolith requires careful separation of concerns."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "This sub-subtopic presents a four-table design \u2014 "
          },
          {
            "type": "text",
            "text": "conversations",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "text": "messages",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "text": "message_context_chunks",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ", and "
          },
          {
            "type": "text",
            "text": "conversation_events",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " \u2014 along with the DDL, access patterns, encryption strategy, and retention approach."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Interaction logs schema: conversations \u2192 messages, message_context_chunks junction, conversation_events audit log"
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Full DDL"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "conversations"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "CREATE TABLE conversations (\n    id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    user_id     UUID NOT NULL,\n    tenant_id   UUID NOT NULL,\n    title       TEXT,\n    model       TEXT NOT NULL DEFAULT 'claude-haiku-4-5-20251001',\n    created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    updated_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    archived_at TIMESTAMPTZ,          -- soft archive; NOT a delete\n    metadata    JSONB                 -- e.g. {\"source\":\"web\",\"session_id\":\"...\"}\n);\n\nCREATE INDEX conv_user_updated  ON conversations (user_id, updated_at DESC)\n    WHERE archived_at IS NULL;        -- active conversations for sidebar listing\nCREATE INDEX conv_tenant        ON conversations (tenant_id);\nCREATE INDEX conv_metadata      ON conversations USING GIN (metadata jsonb_path_ops);"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "messages"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "CREATE TABLE messages (\n    id               UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    conversation_id  UUID NOT NULL REFERENCES conversations(id) ON DELETE CASCADE,\n    role             TEXT NOT NULL CHECK (role IN ('user', 'assistant', 'tool')),\n    content          TEXT NOT NULL,              -- Fernet-encrypted; see below\n    sequence_n       INT NOT NULL,               -- 0-based, monotonic per conversation\n    -- LLM telemetry (populated for role='assistant' only)\n    model            TEXT,\n    input_tokens     INT,\n    output_tokens    INT,\n    stop_reason      TEXT,\n    latency_ms       INT,\n    created_at       TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    CONSTRAINT messages_conv_seq_unique UNIQUE (conversation_id, sequence_n)\n);\n\nCREATE INDEX msg_conv_seq   ON messages (conversation_id, sequence_n);\nCREATE INDEX msg_created    ON messages (created_at DESC);"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Content encryption:",
                "marks": [
                  {
                    "type": "bold"
                  }
                ]
              },
              {
                "type": "text",
                "text": " store "
              },
              {
                "type": "text",
                "text": "content",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " as a Fernet-encrypted blob. The application decrypts on read. This way a raw DB backup exposes metadata (token counts, latency) but not conversation text. Rotate the Fernet key with a re-encryption job when required \u2014 keep previous keys available during transition."
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "message_context_chunks"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "-- Junction: which RAG chunks were retrieved for an assistant message\nCREATE TABLE message_context_chunks (\n    id           UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    message_id   UUID NOT NULL REFERENCES messages(id) ON DELETE CASCADE,\n    chunk_id     UUID NOT NULL REFERENCES chunks(id) ON DELETE SET NULL,\n    rank         INT NOT NULL,        -- 1 = highest similarity\n    score        REAL NOT NULL,       -- cosine similarity\n    used_in_ctx  BOOLEAN NOT NULL DEFAULT FALSE,  -- true if it fit in the prompt window\n    strategy     TEXT NOT NULL DEFAULT 'semantic',\n    retrieved_at TIMESTAMPTZ NOT NULL DEFAULT NOW()\n);\n\nCREATE INDEX mcc_message  ON message_context_chunks (message_id);\nCREATE INDEX mcc_chunk    ON message_context_chunks (chunk_id);"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "conversation_events (append-only audit)"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "CREATE TABLE conversation_events (\n    id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    conv_id     UUID NOT NULL REFERENCES conversations(id) ON DELETE CASCADE,\n    user_id     UUID NOT NULL,\n    kind        TEXT NOT NULL,       -- 'title_change', 'model_switch', 'archive', 'unarchive', 'share'\n    payload     JSONB NOT NULL DEFAULT '{}',  -- e.g. {\"old_title\":\"...\",\"new_title\":\"...\"}\n    created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW()\n);\n\nCREATE INDEX ce_conv    ON conversation_events (conv_id, created_at DESC);\n-- No UPDATE or DELETE on this table; it is append-only by convention."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Sequence Number Allocation"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The "
          },
          {
            "type": "text",
            "text": "sequence_n",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " column gives every message a deterministic position within its conversation. Gaps must not appear \u2014 the application reconstructs message history by ordering on "
          },
          {
            "type": "text",
            "text": "sequence_n",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". Allocate the next sequence number atomically inside a transaction:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncpg\n\nasync def save_exchange(\n    pool: asyncpg.Pool,\n    conversation_id: str,\n    user_content_encrypted: str,   # already Fernet-encrypted\n    assistant_content_encrypted: str,\n    model: str,\n    input_tokens: int,\n    output_tokens: int,\n    stop_reason: str,\n    latency_ms: int,\n    chunk_ids_with_scores: list[dict],   # [{\"chunk_id\":..., \"rank\":1, \"score\":0.9, \"used\":True}]\n) -> tuple[str, str]:\n    async with pool.acquire() as conn:\n        async with conn.transaction():\n            # Reserve two sequence numbers atomically\n            seq = await conn.fetchval(\n                \"\"\"SELECT COALESCE(MAX(sequence_n), -1)\n                   FROM messages WHERE conversation_id = $1\"\"\",\n                conversation_id,\n            )\n            user_seq      = seq + 1\n            assistant_seq = seq + 2\n\n            user_id = await conn.fetchval(\n                \"\"\"INSERT INTO messages\n                       (conversation_id, role, content, sequence_n)\n                   VALUES ($1, 'user', $2, $3) RETURNING id\"\"\",\n                conversation_id, user_content_encrypted, user_seq,\n            )\n\n            asst_id = await conn.fetchval(\n                \"\"\"INSERT INTO messages\n                       (conversation_id, role, content, sequence_n,\n                        model, input_tokens, output_tokens, stop_reason, latency_ms)\n                   VALUES ($1, 'assistant', $2, $3, $4, $5, $6, $7, $8) RETURNING id\"\"\",\n                conversation_id, assistant_content_encrypted, assistant_seq,\n                model, input_tokens, output_tokens, stop_reason, latency_ms,\n            )\n\n            # Link RAG chunks to the assistant message\n            for c in chunk_ids_with_scores:\n                await conn.execute(\n                    \"\"\"INSERT INTO message_context_chunks\n                           (message_id, chunk_id, rank, score, used_in_ctx)\n                       VALUES ($1, $2, $3, $4, $5)\"\"\",\n                    asst_id, c[\"chunk_id\"], c[\"rank\"], c[\"score\"], c[\"used\"],\n                )\n\n            # Update conversation updated_at\n            await conn.execute(\n                \"UPDATE conversations SET updated_at=NOW() WHERE id=$1\",\n                conversation_id,\n            )\n\n    return str(user_id), str(asst_id)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Reconstructing Conversation History"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The application must rebuild the "
          },
          {
            "type": "text",
            "text": "[{\"role\":...,\"content\":...}]",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " array for each API call. Query in sequence order, decrypt content, and respect the context window limit:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from cryptography.fernet import Fernet\n\nfernet = Fernet(FERNET_KEY)\n\nasync def get_conversation_history(\n    pool: asyncpg.Pool,\n    conversation_id: str,\n    max_messages: int = 40,\n) -> list[dict]:\n    async with pool.acquire() as conn:\n        rows = await conn.fetch(\n            \"\"\"SELECT role, content\n               FROM messages\n               WHERE conversation_id = $1\n               ORDER BY sequence_n DESC\n               LIMIT $2\"\"\",\n            conversation_id, max_messages,\n        )\n    # Reverse to chronological order; decrypt content\n    history = []\n    for r in reversed(rows):\n        history.append({\n            \"role\":    r[\"role\"],\n            \"content\": fernet.decrypt(r[\"content\"].encode()).decode(),\n        })\n    return history"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Encryption Pattern"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# encryption.py\nimport os\nfrom cryptography.fernet import Fernet\n\n_key  = os.environ[\"FERNET_KEY\"].encode()  # 32-byte URL-safe base64 from secrets manager\n_fern = Fernet(_key)\n\ndef encrypt(plaintext: str) -> str:\n    return _fern.encrypt(plaintext.encode()).decode()\n\ndef decrypt(ciphertext: str) -> str:\n    return _fern.decrypt(ciphertext.encode()).decode()"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Never store "
          },
          {
            "type": "text",
            "text": "FERNET_KEY",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " in version-controlled config files. Inject it via Kubernetes Secrets or your cloud secrets manager at runtime."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Retention and Partitioning"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Conversation logs grow without bound. For long-running applications, partition "
          },
          {
            "type": "text",
            "text": "messages",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " by month using PostgreSQL declarative partitioning so you can "
          },
          {
            "type": "text",
            "text": "DROP",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " old partitions without a long table scan:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "-- Convert messages to a partitioned table at schema creation (cannot convert in-place)\nCREATE TABLE messages (\n    id              UUID NOT NULL DEFAULT gen_random_uuid(),\n    conversation_id UUID NOT NULL,\n    role            TEXT NOT NULL CHECK (role IN ('user', 'assistant', 'tool')),\n    content         TEXT NOT NULL,\n    sequence_n      INT NOT NULL,\n    model           TEXT,\n    input_tokens    INT, output_tokens INT, stop_reason TEXT, latency_ms INT,\n    created_at      TIMESTAMPTZ NOT NULL DEFAULT NOW()\n) PARTITION BY RANGE (created_at);\n\n-- Create partitions for current and next month (automate with pg_partman)\nCREATE TABLE messages_2024_12 PARTITION OF messages\n    FOR VALUES FROM ('2024-12-01') TO ('2025-01-01');\nCREATE TABLE messages_2025_01 PARTITION OF messages\n    FOR VALUES FROM ('2025-01-01') TO ('2025-02-01');\n\n-- Drop a partition after the retention window (e.g. 12 months)\n-- DROP TABLE messages_2024_01;  -- instant; no rows scanned"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Analytical Queries"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Messages per day (engagement metric)"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "SELECT\n    DATE_TRUNC('day', created_at) AS day,\n    role,\n    COUNT(*) AS count\nFROM messages\nWHERE created_at > NOW() - INTERVAL '30 days'\nGROUP BY 1, 2\nORDER BY 1 DESC;"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Average conversation length by model"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "SELECT\n    c.model,\n    COUNT(DISTINCT m.conversation_id) AS conversations,\n    ROUND(AVG(msg_count))             AS avg_messages\nFROM conversations c\nJOIN (\n    SELECT conversation_id, COUNT(*) AS msg_count\n    FROM messages GROUP BY conversation_id\n) m ON m.conversation_id = c.id\nWHERE c.created_at > NOW() - INTERVAL '7 days'\nGROUP BY c.model\nORDER BY avg_messages DESC;"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "GDPR Erasure for Conversation Content"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "On a GDPR erasure request, nullify message content while preserving the skeleton rows so "
          },
          {
            "type": "text",
            "text": "sequence_n",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " stays gapless and foreign keys in "
          },
          {
            "type": "text",
            "text": "message_context_chunks",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " remain valid:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "async def erase_conversation_content(pool: asyncpg.Pool, user_id: str) -> None:\n    async with pool.acquire() as conn:\n        async with conn.transaction():\n            # Get all conversation IDs for this user\n            conv_ids = await conn.fetch(\n                \"SELECT id FROM conversations WHERE user_id=$1\", user_id\n            )\n            for row in conv_ids:\n                conv_id = row[\"id\"]\n                await conn.execute(\n                    \"\"\"UPDATE messages\n                       SET content = 'ERASED'\n                       WHERE conversation_id = $1\"\"\",\n                    conv_id,\n                )\n            # Archive conversations (don't delete; FK references remain consistent)\n            await conn.execute(\n                \"UPDATE conversations SET archived_at=NOW(), title='[erased]' WHERE user_id=$1\",\n                user_id,\n            )"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Four tables separate concerns cleanly: "
                  },
                  {
                    "type": "text",
                    "text": "conversations",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " (session metadata), "
                  },
                  {
                    "type": "text",
                    "text": "messages",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " (encrypted content + telemetry), "
                  },
                  {
                    "type": "text",
                    "text": "message_context_chunks",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " (RAG linkage), and "
                  },
                  {
                    "type": "text",
                    "text": "conversation_events",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " (append-only audit)."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Allocate "
                  },
                  {
                    "type": "text",
                    "text": "sequence_n",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " with "
                  },
                  {
                    "type": "text",
                    "text": "COALESCE(MAX,-1)+1",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " inside a transaction to guarantee a gapless, monotonic order."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Fernet-encrypt "
                  },
                  {
                    "type": "text",
                    "text": "messages.content",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": "; store only ciphertext in the database to protect conversation text in backups."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Partition "
                  },
                  {
                    "type": "text",
                    "text": "messages",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " by month with PostgreSQL declarative partitioning; drop old partitions for zero-cost retention enforcement."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "GDPR erasure overwrites content with a sentinel string, leaving skeleton rows intact so sequence numbering and foreign keys remain consistent."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}