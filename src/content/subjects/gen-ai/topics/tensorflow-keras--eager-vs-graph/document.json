d"}],"text":"Early model development"},{"type":"text","text":": Test architectures before scaling"}]},{"type":"paragraph","content":[{"type":"text","text":"❌ "},{"type":"text","marks":[{"type":"bold"}],"text":"Not for"},{"type":"text","text":":\n- Large-scale distributed training\n- Production deployment (TFLite, TF Serving)\n- Performance-critical inference"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Graph Execution (Static)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Graph execution"},{"type":"text","text":" first builds a computation graph by extracting tensor computations, then optimizes and runs the entire graph. Operations don't compute values until the graph runs."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How It Works"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import tensorflow as tf\n\n# Define graph (no execution yet)\n@tf.function\ndef graph_add(x, y):\n    return x + y  # Graph definition, not computed yet [web:69]\n\n# Execute graph\na = tf.constant(5)\nb = tf.constant(3)\nc = graph_add(a, b)  # Runs compiled graph, not Python [web:69]\n\nprint(c.numpy())  # 8 - computed by TensorFlow engine"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Characteristics"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Feature"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Description"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Graph-first"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Build graph → optimize → execute"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Optimized"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Removes redundant ops, fuses operations"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fast execution"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"22× faster than eager for large models"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Less Python overhead"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Runs in TensorFlow engine"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Serializable"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Export to TFLite, TFJS, TF Serving"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Harder to debug"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No Python values during graph execution"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Complete Example (Graph Mode)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import tensorflow as tf\n\n# Define model as graph\n@tf.function\ndef train_step(real_images, noise):\n    # Graph optimization happens here\n    fake_images = generator(noise, training=True)\n    real_pred = discriminator(real_images, training=True)\n    fake_pred = discriminator(fake_images, training=True)\n    loss = tf.reduce_mean(fake_pred - real_pred)\n    \n    # Gradients computed via graph\n    grads = tf.gradient(loss, generator.trainable_variables)\n    generator.optimizer.apply_gradients(grads)\n    \n    return loss\n\n# Training (graph mode)\nfor epoch in range(100):\n    for real_images in dataset:\n        noise = tf.random.normal([32, 128])\n        loss = train_step(real_images, noise)  # Optimized graph\n        # No print() inside - slower"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use Graph"}]},{"type":"paragraph","content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"bold"}],"text":"Best for"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Large-scale training"},{"type":"text","text":": Multi-GPU, distributed training\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Production"},{"type":"text","text":": Deploy to TFLite, TF Serving, TFJS\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Performance-critical"},{"type":"text","text":": Inference optimization\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Portability"},{"type":"text","text":": Run outside Python (C++, mobile)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Optimized inference"},{"type":"text","text":": 16× faster after compilation"}]},{"type":"paragraph","content":[{"type":"text","text":"❌ "},{"type":"text","marks":[{"type":"bold"}],"text":"Not for"},{"type":"text","text":":\n- Interactive debugging\n- Quick prototyping\n- Complex Python control flow during graph building"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"code"}],"text":"tf.function"},{"type":"text","text":": Best of Both Worlds"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How It Works"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"tf.function"},{"type":"text","text":" converts eager Python code into optimized graphs using "},{"type":"text","marks":[{"type":"bold"}],"text":"AutoGraph"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import tensorflow as tf\n\n# Eager by default (debuggable)\ndef add_eager(x, y):\n    return x + y\n\n# Graph mode (optimized)\n@tf.function\ndef add_graph(x, y):\n    return x + y\n\n# Call both\na = tf.constant(5)\nb = tf.constant(3)\n\nprint(add_eager(a, b).numpy())  # Eager: 8 [web:69]\nprint(add_graph(a, b).numpy())  # Graph: 8 [web:69]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Real Workflow: Eager for Dev, Graph for Training"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"class GANTrainer:\n    def __init__(self):\n        self.generator = build_generator()\n        self.discriminator = build_discriminator()\n    \n    # Eager mode: debuggable, easy to modify\n    def train_step_eager(self, real_images, noise):\n        fake = self.generator(noise, training=True)\n        real_pred = self.discriminator(real_images, training=True)\n        fake_pred = self.discriminator(fake, training=True)\n        \n        # Debug: print values\n        print(f\"Real: {real_pred.numpy().mean()}\")\n        \n        loss = tf.reduce_mean(fake_pred - real_pred)\n        return loss\n    \n    # Graph mode: optimized for production\n    @tf.function\n    def train_step_graph(self, real_images, noise):\n        fake = self.generator(noise, training=True)\n        real_pred = self.discriminator(real_images, training=True)\n        fake_pred = self.discriminator(fake, training=True)\n        \n        # No print() - runs as graph\n        loss = tf.reduce_mean(fake_pred - real_pred)\n        return loss\n\n# Usage\ntrainer = GANTrainer()\n\n# Phase 1: Debug with eager\nfor epoch in range(10):\n    for real in dataset:\n        loss = trainer.train_step_eager(real, noise)\n        print(f\"Eager loss: {loss.numpy()}\")\n\n# Phase 2: Train with graph (fast)\nfor epoch in range(100):\n    for real in dataset:\n        loss = trainer.train_step_graph(real, noise)  # 22× faster [web:73]"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Performance Comparison"}]},{"type":"paragraph","content":[{"type":"text","text":"From the test case (same model, 50 runs):"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Metric"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Eager Mode"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Graph Mode"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Single run"}]}]