      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Retry transient failures at the code level, silently. Surface logic errors to the LLM as tool results, clearly. Never retry a permanent failure \u2014 it wastes time and quota."
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Exponential Backoff with Jitter"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Exponential backoff is the standard retry strategy for transient failures: wait longer after each failed attempt, up to a maximum delay. Adding random jitter prevents thundering-herd problems when many clients retry simultaneously after a shared outage."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The wait time before attempt "
          },
          {
            "type": "text",
            "text": "k",
            "marks": [
              {
                "type": "italic"
              }
            ]
          },
          {
            "type": "text",
            "text": " (zero-indexed) is:"
          }
        ]
      },
      {
        "type": "blockMath",
        "attrs": {
          "latex": "\\text{wait}_k = \\min\\left(\\text{max\\_delay},\\, \\text{base} \\cdot 2^k + \\text{Uniform}(0, \\text{jitter})\\right)"
        }
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import time\nimport random\nimport logging\nfrom typing import TypeVar, Callable, Any\n\nlogger = logging.getLogger(__name__)\nT = TypeVar(\"T\")\n\ndef retry_with_backoff(\n    fn: Callable[[], T],\n    *,\n    max_attempts: int = 4,\n    base_delay: float = 1.0,\n    max_delay: float = 30.0,\n    jitter: float = 1.0,\n    retryable_exceptions: tuple = (Exception,),\n) -> T:\n    \"\"\"Call fn(), retrying on retryable_exceptions with exponential backoff.\"\"\"\n    last_exc: Exception | None = None\n    for attempt in range(max_attempts):\n        try:\n            return fn()\n        except retryable_exceptions as exc:\n            last_exc = exc\n            if attempt == max_attempts - 1:\n                break\n            wait = min(max_delay, base_delay * (2 ** attempt) + random.uniform(0, jitter))\n            logger.warning(\n                \"Attempt %d/%d failed (%s). Retrying in %.1fs.\",\n                attempt + 1, max_attempts, exc, wait,\n            )\n            time.sleep(wait)\n    raise last_exc   # re-raise after all attempts exhausted\n\n# Usage:\nimport httpx\n\ndef call_weather_api(city: str) -> dict:\n    resp = httpx.get(f\"https://api.weather.example.com/current?city={city}\", timeout=5)\n    resp.raise_for_status()\n    return resp.json()\n\nresult = retry_with_backoff(\n    lambda: call_weather_api(\"Paris\"),\n    retryable_exceptions=(httpx.TimeoutException, httpx.HTTPStatusError),\n    max_attempts=3,\n    base_delay=1.0,\n)"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Using tenacity"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The "
          },
          {
            "type": "text",
            "text": "tenacity",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " library provides a decorator-based retry interface that handles backoff, jitter, and stop conditions cleanly. It is the standard Python library for this pattern."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# pip install tenacity\nfrom tenacity import (\n    retry,\n    stop_after_attempt,\n    wait_exponential_jitter,\n    retry_if_exception_type,\n    before_sleep_log,\n)\nimport httpx\nimport logging\n\nlogger = logging.getLogger(__name__)\n\n@retry(\n    stop=stop_after_attempt(4),\n    wait=wait_exponential_jitter(initial=1, max=30, jitter=1),\n    retry=retry_if_exception_type((httpx.TimeoutException, httpx.HTTPStatusError)),\n    before_sleep=before_sleep_log(logger, logging.WARNING),\n    reraise=True,   # re-raise the last exception after all attempts\n)\ndef fetch_stock_price(ticker: str) -> dict:\n    resp = httpx.get(f\"https://api.finance.example.com/price/{ticker}\", timeout=5)\n    resp.raise_for_status()\n    return resp.json()\n\n# Rate-limit aware: only retry on 429 and 5xx, not 4xx\ndef is_retryable_http(exc: Exception) -> bool:\n    if isinstance(exc, httpx.HTTPStatusError):\n        return exc.response.status_code in (429, 500, 502, 503, 504)\n    return isinstance(exc, httpx.TimeoutException)\n\n@retry(\n    stop=stop_after_attempt(5),\n    wait=wait_exponential_jitter(initial=2, max=60),\n    retry=retry_if_exception_type(httpx.HTTPStatusError) | retry_if_exception_type(httpx.TimeoutException),\n    reraise=True,\n)\ndef call_llm_api(payload: dict) -> dict:\n    \"\"\"Retry LLM API calls on rate limits and server errors.\"\"\"\n    resp = httpx.post(\"https://api.openai.com/v1/chat/completions\", json=payload, timeout=30)\n    resp.raise_for_status()\n    return resp.json()"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Respecting Retry-After Headers"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Rate-limited APIs (OpenAI, HubSpot, Slack) return a "
          },
          {
            "type": "text",
            "text": "Retry-After",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " header specifying how many seconds to wait. Honour it instead of guessing \u2014 it avoids additional 429s and respects the API provider's limits."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import time\nimport httpx\nfrom tenacity import retry, stop_after_attempt, wait_base, RetryCallState\n\nclass WaitRetryAfter(wait_base):\n    \"\"\"tenacity wait strategy that reads the Retry-After header.\"\"\"\n    def __init__(self, fallback_seconds: float = 5.0):\n        self.fallback = fallback_seconds\n\n    def __call__(self, retry_state: RetryCallState) -> float:\n        exc = retry_state.outcome.exception()\n        if isinstance(exc, httpx.HTTPStatusError) and exc.response.status_code == 429:\n            header = exc.response.headers.get(\"Retry-After\")\n            if header:\n                return float(header)\n        return self.fallback\n\n@retry(\n    stop=stop_after_attempt(5),\n    wait=WaitRetryAfter(fallback_seconds=5.0),\n    reraise=True,\n)\ndef call_openai_with_rate_limit_respect(payload: dict) -> dict:\n    resp = httpx.post(\n        \"https://api.openai.com/v1/chat/completions\",\n        headers={\"Authorization\": f\"Bearer {OPENAI_API_KEY}\"},\n        json=payload,\n        timeout=30,\n    )\n    resp.raise_for_status()\n    return resp.json()"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "LLM-Level Retries \u2014 Tool Errors as Feedback"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When a tool returns an error because the LLM passed wrong arguments or called the wrong tool, the right retry is an "
          },
          {
            "type": "text",
            "text": "LLM retry",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": ": pass the error back as a tool result and let the LLM self-correct on its next turn. This is different from infrastructure retries \u2014 you do not repeat the exact same call; you give the LLM feedback."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from openai import OpenAI\nimport json\n\nclient = OpenAI()\n\ndef run_tool(name: str, args: dict) -> str:\n    \"\"\"Dispatch tool call; always return a string result (never raise).\"\"\"\n    try:\n        if name == \"get_order\":\n            result = get_order(**args)\n            if result is None:\n                return json.dumps({\"error\": f\"Order '{args.get('order_id')}' not found.\"})\n            return json.dumps(result)\n        elif name == \"list_orders_by_status\":\n            return json.dumps(list_orders_by_status(**args))\n        else:\n            return json.dumps({\"error\": f\"Unknown tool: {name}\"})\n    except TypeError as e:\n        # LLM passed wrong argument types\n        return json.dumps({\"error\": f\"Invalid arguments: {e}\"})\n    except Exception as e:\n        return json.dumps({\"error\": str(e)})\n\ndef run_agent_with_llm_retry(user_message: str, max_turns: int = 6) -> str:\n    messages = [{\"role\": \"user\", \"content\": user_message}]\n    for _ in range(max_turns):\n        response = client.chat.completions.create(\n            model=\"gpt-4o-mini\",\n            messages=messages,\n            tools=TOOLS,\n            tool_choice=\"auto\",\n        )\n        choice = response.choices[0]\n        messages.append(choice.message)\n\n        if choice.finish_reason == \"stop\":\n            return choice.message.content\n\n        # Pass all tool results (including errors) back to the LLM\n        for tc in choice.message.tool_calls:\n            args = json.loads(tc.function.arguments)\n            result = run_tool(tc.function.name, args)   # never raises\n            messages.append({\n                \"role\": \"tool\",\n                \"tool_call_id\": tc.id,\n                \"content\": result,   # error messages land here\n            })\n            # LLM sees the error and may call a different tool or correct the args\n\n    return \"Could not complete the request within the turn limit.\""
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When the tool result contains an error, the LLM reads it and typically:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Self-corrects arguments",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 if the error says 'order ID must start with ORD-', the LLM retries with the corrected format."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Calls a different tool",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 if the tool returned 'not found', the LLM may try a search tool to find the right ID."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Gives up and explains",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 if the error is a permanent failure (permission denied), the LLM tells the user instead of looping."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "LangGraph RetryPolicy"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "LangGraph has built-in retry support at the node level via "
          },
          {
            "type": "text",
            "text": "RetryPolicy",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". Attach it when adding a node to retry transient failures in any node (LLM calls, tool dispatchers, API calls) without writing retry logic in each node."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langgraph.graph import StateGraph, MessagesState, END\nfrom langgraph.pregel import RetryPolicy\nimport httpx\n\ndef call_external_api(state: MessagesState) -> dict:\n    resp = httpx.get(\"https://api.example.com/data\", timeout=5)\n    resp.raise_for_status()\n    data = resp.json()\n    from langchain_core.messages import AIMessage\n    return {\"messages\": [AIMessage(content=str(data))]}\n\ngraph = StateGraph(MessagesState)\n\ngraph.add_node(\n    \"api_call\",\n    call_external_api,\n    retry=RetryPolicy(\n        max_attempts=4,\n        retry_on=(httpx.HTTPError, httpx.TimeoutException),\n        backoff_factor=2.0,   # waits: 1s, 2s, 4s between attempts\n        initial_interval=1.0,\n        max_interval=30.0,\n    ),\n)\n\ngraph.set_entry_point(\"api_call\")\ngraph.add_edge(\"api_call\", END)\napp = graph.compile()"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Async Retries"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For async tool implementations (common with "
          },
          {
            "type": "text",
            "text": "AsyncOpenAI",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " or "
          },
          {
            "type": "text",
            "text": "httpx.AsyncClient",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": "), use "
          },
          {
            "type": "text",
            "text": "tenacity",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": "'s async-compatible "
          },
          {
            "type": "text",
            "text": "AsyncRetrying",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " context manager or the "
          },
          {
            "type": "text",
            "text": "@retry",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " decorator on an "
          },
          {
            "type": "text",
            "text": "async def",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " function."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\nimport httpx\nfrom tenacity import retry, stop_after_attempt, wait_exponential_jitter, retry_if_exception_type\n\n@retry(\n    stop=stop_after_attempt(4),\n    wait=wait_exponential_jitter(initial=1, max=30),\n    retry=retry_if_exception_type((httpx.TimeoutException, httpx.HTTPStatusError)),\n    reraise=True,\n)\nasync def fetch_async(url: str) -> dict:\n    async with httpx.AsyncClient() as client:\n        resp = await client.get(url, timeout=5)\n        resp.raise_for_status()\n        return resp.json()\n\nasync def call_tools_in_parallel(tool_calls: list) -> list:\n    tasks = [fetch_async(tc[\"url\"]) for tc in tool_calls]\n    results = await asyncio.gather(*tasks, return_exceptions=True)\n    return [\n        r if not isinstance(r, Exception) else {\"error\": str(r)}\n        for r in results\n    ]"
          }
        ]
      },
