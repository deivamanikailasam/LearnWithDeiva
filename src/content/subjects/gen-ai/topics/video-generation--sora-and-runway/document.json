      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Practical Batch Generation Pattern"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When generating many clips (e.g. for a storyboard or A/B evaluation), submit all jobs in parallel and poll them together rather than waiting sequentially:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import time\nfrom runwayml import RunwayML\n\nclient = RunwayML()\n\nPROMPTS = [\n    \"[DOLLY IN] A neon-lit Tokyo alley at midnight, rain-soaked cobblestones\",\n    \"[AERIAL SHOT] Cargo ship navigating through Arctic ice floes at dawn\",\n    \"[TRACKING SHOT] A cyclist racing through a mountain descent, pine forest blur\",\n]\n\n# Submit all jobs in parallel\ntasks = [\n    client.image_to_video.create(\n        model=\"gen3a_turbo\",\n        prompt_text=p,\n        duration=5,\n        ratio=\"1280:768\",\n    )\n    for p in PROMPTS\n]\ntask_ids = [t.id for t in tasks]\nprint(f\"Submitted {len(task_ids)} jobs:\", task_ids)\n\n# Poll until all complete\npending = set(task_ids)\nresults = {}\nwhile pending:\n    for tid in list(pending):\n        task = client.tasks.retrieve(tid)\n        if task.status == \"SUCCEEDED\":\n            results[tid] = task.output[0]\n            pending.discard(tid)\n            print(f\"✓ {tid}: {task.output[0]}\")\n        elif task.status == \"FAILED\":\n            print(f\"✗ {tid} failed: {task.failure}\")\n            pending.discard(tid)\n    if pending:\n        time.sleep(5)\n\nprint(f\"Done — {len(results)}/{len(task_ids)} succeeded\")"
