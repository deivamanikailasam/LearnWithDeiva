{"format": "tiptap/v1", "updatedAt": "2026-06-22T04:26:41.898Z", "doc": {"type": "doc", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Reinforcement Learning (RL)"}, {"type": "text", "text": " is a subset of machine learning where an AI system (called an "}, {"type": "text", "marks": [{"type": "bold"}], "text": "agent"}, {"type": "text", "text": ") learns through "}, {"type": "text", "marks": [{"type": "bold"}], "text": "trial and error"}, {"type": "text", "text": " by interacting with an environment and receiving "}, {"type": "text", "marks": [{"type": "bold"}], "text": "feedback"}, {"type": "text", "text": " as rewards or punishments, aiming to maximize cumulative reward over time."}]}, {"type": "blockquote", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Simple definition:"}, {"type": "text", "text": " “RL is the "}, {"type": "text", "marks": [{"type": "bold"}], "text": "science of decision-making"}, {"type": "text", "text": ". It’s about learning optimal behavior in an environment to obtain maximum reward through interactions with the environment.”"}]}]}, {"type": "horizontalRule"}, {"type": "image", "attrs": {"src": "data:image/svg+xml;base64,", "alt": "Reinforcement Learning — concept overview"}}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Core idea: learning from rewards, not labels"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "In RL:"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "You have an "}, {"type": "text", "marks": [{"type": "bold"}], "text": "agent"}, {"type": "text", "text": " (the learner) and an "}, {"type": "text", "marks": [{"type": "bold"}], "text": "environment"}, {"type": "text", "text": " (what it interacts with)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "The agent:"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "- Observes the current "}, {"type": "text", "marks": [{"type": "bold"}], "text": "state"}, {"type": "text", "text": " of the environment - Takes an "}, {"type": "text", "marks": [{"type": "bold"}], "text": "action"}, {"type": "text", "text": " - The environment transitions to a new state and gives a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "reward signal"}, {"type": "text", "text": " (positive or negative)\n- The agent learns a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "policy"}, {"type": "text", "text": " (strategy) that maps states to actions to "}, {"type": "text", "marks": [{"type": "bold"}], "text": "maximize total cumulative reward"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Key elements:"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Element"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Role"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Agent"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "The learner/decision-maker"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Environment"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "What the agent interacts with"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "State"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Current situation of the environment"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Action"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "What the agent does in a state"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Reward"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Feedback signal (positive/negative) for an action"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Policy"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "The strategy that determines actions based on states"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Unlike supervised learning, "}, {"type": "text", "marks": [{"type": "bold"}], "text": "RL has no “answer key”"}, {"type": "text", "text": " telling the agent what the correct action is; instead, it learns by exploring and seeing which actions lead to better rewards."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Reinforcement Learning in Classical Machine Learning"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "In "}, {"type": "text", "marks": [{"type": "bold"}], "text": "classical machine learning"}, {"type": "text", "text": ", RL is "}, {"type": "text", "marks": [{"type": "bold"}], "text": "not the dominant paradigm"}, {"type": "text", "text": ". Classical ML mostly uses:"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Supervised learning"}, {"type": "text", "text": " (labeled data):"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "- Classification: spam detection, fraud detection - Regression: price prediction, sales forecasting\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Unsupervised learning"}, {"type": "text", "text": " (no labels): - Clustering: K-Means, hierarchical clustering - Dimensionality reduction: PCA, t-SNE"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "RL is used in classical ML for "}, {"type": "text", "marks": [{"type": "bold"}], "text": "decision-making and control problems"}, {"type": "text", "text": ", such as:"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Robotics"}, {"type": "text", "text": ": learning how to move, grasp objects"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Game playing"}, {"type": "text", "text": ": chess, Go, Atari games (used as testbeds for RL)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Resource optimization"}, {"type": "text", "text": ": energy management, scheduling"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Autonomous systems"}, {"type": "text", "text": ": self-driving cars, drones"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "RL is especially useful for problems where:"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "There’s a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "sequence of decisions"}, {"type": "text", "text": " over time"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "The goal is "}, {"type": "text", "marks": [{"type": "bold"}], "text": "long-term cumulative reward"}, {"type": "text", "text": ", not just immediate accuracy"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Traditional ML algorithms can’t handle the problem structure"}]}]}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Reinforcement Learning in Generative AI"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "In "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Generative AI"}, {"type": "text", "text": ", RL has become a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "trending and powerful tool"}, {"type": "text", "text": " to improve generation models beyond standard training methods."}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Standard training for generative models"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The main paradigm for training generative models is:"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Maximum likelihood estimation"}, {"type": "text", "text": " (supervised/self-supervised):"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "- The model learns to approximate the target data distribution - It decreases the divergence between the model’s distribution and the real data distribution"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "This works well, but it’s "}, {"type": "text", "marks": [{"type": "bold"}], "text": "incapable of satisfying all user requirements"}, {"type": "text", "text": ", such as:"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Human preferences (e.g., “more helpful”, “less harmful”)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Ethical alignment"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "User satisfaction"}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "RL as a competitive option"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "RL is used to "}, {"type": "text", "marks": [{"type": "bold"}], "text": "inject new training signals"}, {"type": "text", "text": " by creating objectives that exploit novel signals, such as:"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Adversarial learning"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Hand-designed rules"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Learned reward models"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "RL can:\n- Address "}, {"type": "text", "marks": [{"type": "bold"}], "text": "non-differentiable learning issues"}, {"type": "text", "text": " (e.g., “user is happy”)\n- Infuse generative AI with "}, {"type": "text", "marks": [{"type": "bold"}], "text": "innovative training signals"}, {"type": "text", "text": "\n- Improve "}, {"type": "text", "marks": [{"type": "bold"}], "text": "sampling"}, {"type": "text", "text": " and neural architecture search\n- Optimize for "}, {"type": "text", "marks": [{"type": "bold"}], "text": "human or utility-driven objectives"}, {"type": "text", "text": ", not just data accuracy"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "RLHF: Reinforcement Learning from Human Feedback"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The most famous application of RL in Generative AI is "}, {"type": "text", "marks": [{"type": "bold"}], "text": "RLHF"}, {"type": "text", "text": ", the foundation behind "}, {"type": "text", "marks": [{"type": "bold"}], "text": "ChatGPT-style alignment"}, {"type": "text", "text": "."}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "How RLHF works (simplified)"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Pretrain the model"}, {"type": "text", "text": ":"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "- Use self-supervised learning on massive text data (e.g., next-token prediction)\n2. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Collect human preferences"}, {"type": "text", "text": ": - Humans rate multiple model responses for the same prompt (e.g., “more helpful” vs “less helpful”)\n3. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Train a reward model"}, {"type": "text", "text": ": - These preferences are used to train a separate "}, {"type": "text", "marks": [{"type": "bold"}], "text": "reward model"}, {"type": "text", "text": " that scores how satisfying or aligned a response is from a human perspective\n4. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Policy optimization"}, {"type": "text", "text": ": - Use algorithms like "}, {"type": "text", "marks": [{"type": "bold"}], "text": "PPO (Proximal Policy Optimization)"}, {"type": "text", "text": " to fine-tune the model - The model maximizes the learned reward while staying close to its original behavior (via KL divergence penalty)"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "This ensures the model becomes:\n- More aligned with "}, {"type": "text", "marks": [{"type": "bold"}], "text": "human preferences"}, {"type": "text", "text": "\n- Less likely to produce harmful or misleading content\n- Better at following instructions"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Newer methods like "}, {"type": "text", "marks": [{"type": "bold"}], "text": "DPO (Direct Preference Optimization)"}, {"type": "text", "text": " and "}, {"type": "text", "marks": [{"type": "bold"}], "text": "DivPO (Diverse Preference Optimization)"}, {"type": "text", "text": " are simpler, more efficient successors to RLHF."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Supervised vs. Unsupervised vs. Self-Supervised vs. Reinforcement Learning"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Aspect"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Supervised"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Unsupervised"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Self-Supervised"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Reinforcement"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Feedback"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Human-provided labels"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "No labels, just patterns"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Labels derived from data structure"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Reward signal"}, {"type": "text", "text": " (positive/negative)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type":