          {
            "type": "text",
            "text": "Base Markdown Renderer Component"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// MarkdownRenderer.tsx\nimport ReactMarkdown from \"react-markdown\";\nimport remarkGfm    from \"remark-gfm\";\nimport remarkMath   from \"remark-math\";\nimport rehypeKatex  from \"rehype-katex\";\nimport rehypeSanitize, { defaultSchema } from \"rehype-sanitize\";\nimport { Prism as SyntaxHighlighter } from \"react-syntax-highlighter\";\nimport { oneDark } from \"react-syntax-highlighter/dist/esm/styles/prism\";\nimport \"katex/dist/katex.min.css\";\n\n// Extend the default sanitization schema to allow math classes but nothing dangerous\nconst sanitizeSchema = {\n  ...defaultSchema,\n  attributes: {\n    ...defaultSchema.attributes,\n    span: [...(defaultSchema.attributes?.span ?? []), [\"className\", /^math/]],\n    div:  [...(defaultSchema.attributes?.div  ?? []), [\"className\", /^math/]],\n  },\n};\n\ninterface Props {\n  content:    string;\n  isStreaming?: boolean;\n}\n\nexport function MarkdownRenderer({ content, isStreaming = false }: Props) {\n  return (\n    <div className=\"prose prose-invert max-w-none\">\n      <ReactMarkdown\n        remarkPlugins={[remarkGfm, remarkMath]}\n        rehypePlugins={[\n          [rehypeSanitize, sanitizeSchema],\n          rehypeKatex,\n        ]}\n        components={{\n          code({ inline, className, children }) {\n            const language = /language-(\\w+)/.exec(className ?? \"\")?.[1] ?? \"\";\n            const code     = String(children).replace(/\\n$/, \"\");\n            if (inline) {\n              return <code className=\"rounded bg-gray-800 px-1 py-0.5 text-sm font-mono\">{children}</code>;\n            }\n            return (\n              <div className=\"relative group\">\n                <SyntaxHighlighter language={language || \"text\"} style={oneDark} PreTag=\"div\">\n                  {code}\n                </SyntaxHighlighter>\n                <CopyButton text={code} />\n              </div>\n            );\n          },\n          a({ href, children }) {\n            // Only allow safe URLs\n            const safe = href?.startsWith(\"https://\") || href?.startsWith(\"mailto:\");\n            return safe ? (\n              <a href={href} target=\"_blank\" rel=\"noopener noreferrer\">{children}</a>\n            ) : (\n              <span>{children}</span>\n            );\n          },\n        }}\n      >\n        {content}\n      </ReactMarkdown>\n      {isStreaming && <span className=\"animate-pulse text-gray-400\">\u258b</span>}\n    </div>\n  );\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Copy Button for Code Blocks"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// CopyButton.tsx\nimport { useState } from \"react\";\n\nexport function CopyButton({ text }: { text: string }) {\n  const [copied, setCopied] = useState(false);\n\n  const copy = async () => {\n    await navigator.clipboard.writeText(text);\n    setCopied(true);\n    setTimeout(() => setCopied(false), 2000);\n  };\n\n  return (\n    <button\n      onClick={copy}\n      className=\"absolute top-2 right-2 opacity-0 group-hover:opacity-100\n                 rounded bg-gray-700 px-2 py-1 text-xs text-gray-300\n                 transition-opacity hover:bg-gray-600\"\n      aria-label=\"Copy code\"\n    >\n      {copied ? \"Copied!\" : \"Copy\"}\n    </button>\n  );\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Streaming Strategy: Render-on-Done vs Incremental"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Strategy 1: Render Raw Text During Stream, Markdown on Done (Simplest)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Avoid mid-stream parsing complexity by showing raw text during streaming and switching to full markdown after the stream closes:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// StreamingMessage.tsx\ninterface Props {\n  content:     string;\n  isStreaming: boolean;\n}\n\nexport function StreamingMessage({ content, isStreaming }: Props) {\n  if (isStreaming) {\n    // Raw text \u2014 no markdown parsing, no flicker from partial fences\n    return (\n      <pre className=\"whitespace-pre-wrap font-sans text-gray-200\">\n        {content}\n        <span className=\"animate-pulse text-gray-400\">\u258b</span>\n      </pre>\n    );\n  }\n  // Stream complete \u2014 full markdown render\n  return <MarkdownRenderer content={content} />;\n}\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Strategy 2: Incremental Markdown (Progressive Rendering)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For a richer streaming experience, use a library that handles partial markdown tokens safely:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Using the \"streaming-markdown\" npm package (lightweight incremental parser)\n// npm install streaming-markdown\nimport { StreamingMarkdown } from \"streaming-markdown\";\nimport { useEffect, useRef } from \"react\";\n\nexport function IncrementalMarkdown({ chunks }: { chunks: string[] }) {\n  const containerRef = useRef<HTMLDivElement>(null);\n  const rendererRef  = useRef<StreamingMarkdown | null>(null);\n\n  useEffect(() => {\n    if (!containerRef.current) return;\n    rendererRef.current = new StreamingMarkdown(containerRef.current);\n  }, []);\n\n  useEffect(() => {\n    const renderer = rendererRef.current;\n    if (!renderer) return;\n    const lastChunk = chunks[chunks.length - 1];\n    if (lastChunk) renderer.write(lastChunk);\n  }, [chunks.length]);\n\n  return <div ref={containerRef} className=\"prose prose-invert max-w-none\" />;\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "XSS Sanitization in Depth"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The default "
          },
          {
            "type": "text",
            "text": "rehype-sanitize",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " schema is a solid baseline, but LLM-generated HTML needs extra hardening:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { defaultSchema } from \"rehype-sanitize\";\n\nexport const STRICT_SANITIZE_SCHEMA = {\n  ...defaultSchema,\n  // Disallow all event handlers (onclick, onerror, onload, etc.)\n  strip: [\"script\", \"style\", \"iframe\", \"form\", \"input\"],\n  attributes: {\n    ...defaultSchema.attributes,\n    // Only allow href on <a> if it starts with https:// or mailto:\n    a: [[\"href\", /^https?:\\/\\/|^mailto:/]],\n    // Allow code highlighting class names\n    code: [[\"className\", /^language-/]],\n    span: [[\"className\", /^(hljs|math)/]],\n    // Allow nothing on potentially dangerous tags\n    img: [[\"src\", /^https?:\\/\\//], \"alt\"],\n  },\n  // Explicitly remove any attribute that starts with \"on\"\n  clobber: [],\n};\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Performance: Memoizing the Rendered Output"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Markdown parsing is CPU-bound and happens on every render. Memoize with "
          },
          {
            "type": "text",
            "text": "useMemo",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " or "
          },
          {
            "type": "text",
            "text": "React.memo",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " so re-renders triggered by scroll or unrelated state don't re-parse unchanged messages:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { memo, useMemo } from \"react\";\n\nexport const MemoizedMarkdown = memo(function MemoizedMarkdown({\n  content,\n  isStreaming,\n}: {\n  content:     string;\n  isStreaming: boolean;\n}) {\n  return <MarkdownRenderer content={content} isStreaming={isStreaming} />;\n}, (prev, next) => prev.content === next.content && prev.isStreaming === next.isStreaming);\n\n// In the message list, use MemoizedMarkdown for completed messages.\n// Only the currently-streaming message needs to re-render on each chunk.\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Rendering HTML without sanitization: "
                  },
                  {
                    "type": "text",
                    "text": "never pass raw LLM output through dangerouslySetInnerHTML or skip rehype-sanitize. The model can emit <script> tags.",
                    "marks": [
                      {
                        "type": "italic"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Re-parsing every chunk: "
                  },
                  {
                    "type": "text",
                    "text": "if you call remarkParse on every incoming chunk during streaming, you'll parse a growing string O(n) times. Either defer markdown to after [DONE] or use a streaming parser.",
                    "marks": [
                      {
                        "type": "italic"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Missing KaTeX CSS: "
                  },
                  {
                    "type": "text",
                    "text": "without import 'katex/dist/katex.min.css' the LaTeX renders but the layout is broken. Include the stylesheet in your global CSS or bundle entrypoint.",
                    "marks": [
                      {
                        "type": "italic"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "No copy button on code blocks: "
                  },
                  {
                    "type": "text",
                    "text": "copy buttons on code blocks are expected UX in developer-facing tools. Without them users resort to manual selection, which is error-prone for long snippets.",
                    "marks": [
                      {
                        "type": "italic"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Prose class missing: "
                  },
                  {
                    "type": "text",
                    "text": "react-markdown renders plain HTML elements without styling. Pair it with Tailwind Typography's prose class (or equivalent CSS) to get readable heading hierarchy and list styling.",
                    "marks": [
                      {
                        "type": "italic"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing Markdown Rendering"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Test that the renderer handles all expected markdown variants correctly and that XSS vectors are neutralized:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// MarkdownRenderer.test.tsx\nimport { render, screen } from \"@testing-library/react\";\nimport { MarkdownRenderer } from \"./MarkdownRenderer\";\n\ndescribe(\"MarkdownRenderer\", () => {\n  test(\"renders headings with correct hierarchy\", () => {\n    const { container } = render(<MarkdownRenderer content=\"# H1\\n## H2\\n### H3\" />);\n    expect(container.querySelector(\"h1\")).toHaveTextContent(\"H1\");\n    expect(container.querySelector(\"h2\")).toHaveTextContent(\"H2\");\n    expect(container.querySelector(\"h3\")).toHaveTextContent(\"H3\");\n  });\n\n  test(\"renders fenced code blocks with language class\", () => {\n    const md = \"```python\\nprint('hello')\\n```\";\n    const { container } = render(<MarkdownRenderer content={md} />);\n    expect(container.querySelector(\"pre code.language-python\")).toBeTruthy();\n  });\n\n  test(\"strips <script> tags from LLM output (XSS prevention)\", () => {\n    const malicious = 'Click [here](<script>alert(1)</script>)';\n    const { container } = render(<MarkdownRenderer content={malicious} />);\n    expect(container.querySelector(\"script\")).toBeNull();\n    expect(container.textContent).not.toContain(\"alert(1)\");\n  });\n\n  test(\"strips onerror attributes from img tags\", () => {\n    const malicious = '<img src=\"x\" onerror=\"alert(1)\">';\n    const { container } = render(<MarkdownRenderer content={malicious} />);\n    const img = container.querySelector(\"img\");\n    expect(img?.getAttribute(\"onerror\")).toBeNull();\n  });\n\n  test(\"renders GFM table correctly\", () => {\n    const md = \"| Col A | Col B |\\n|-------|-------|\\n| val 1 | val 2 |\";\n    const { container } = render(<MarkdownRenderer content={md} />);\n    expect(container.querySelector(\"table\")).toBeTruthy();\n    expect(container.querySelectorAll(\"td\")).toHaveLength(2);\n  });\n\n  test(\"renders inline and block math (KaTeX)\", () => {\n    const md = \"Inline: $E=mc^2$ and block:\\n$$\\\\int_0^1 x\\\\,dx = \\\\frac{1}{2}$$\";\n    const { container } = render(<MarkdownRenderer content={md} />);\n    expect(container.querySelector(\".katex\")).toBeTruthy();\n  });\n\n  test(\"does not re-render memoized message on unrelated state change\", () => {\n    const renderSpy = jest.fn();\n    const Tracked = () => { renderSpy(); return <MarkdownRenderer content=\"**bold**\" />; };\n    const { rerender } = render(<Tracked />);\n    rerender(<Tracked />);\n    // If memoized, renderSpy should be called only once for the MarkdownRenderer internals\n    expect(renderSpy).toHaveBeenCalledTimes(2); // outer Tracked re-renders; inner memoized MarkdownRenderer does not\n  });\n});\n"
