            "type": "text",
            "text": "// rehype-safe-links.ts\nimport type { Root } from \"hast\";\nimport { visit } from \"unist-util-visit\";\n\nexport function rehypeSafeLinks() {\n  return (tree: Root) => {\n    visit(tree, \"element\", (node) => {\n      if (node.tagName !== \"a\") return;\n      const href = (node.properties?.href as string) ?? \"\";\n\n      if (!href.startsWith(\"https://\") && !href.startsWith(\"mailto:\")) {\n        // Replace unsafe href with # and add a data attribute for debugging\n        node.properties = {\n          ...node.properties,\n          href: \"#\",\n          \"data-unsafe-href\": href,\n          \"aria-disabled\": \"true\",\n        };\n      } else if (href.startsWith(\"https://\")) {\n        // External HTTPS link \u2014 open in new tab with noopener\n        node.properties = {\n          ...node.properties,\n          target: \"_blank\",\n          rel: \"noopener noreferrer\",\n        };\n      }\n    });\n  };\n}\n\n// Add to the renderer:\n// rehypePlugins={[[rehypeSanitize, STRICT_SCHEMA], rehypeKatex, rehypeSafeLinks]}\n"
          }
