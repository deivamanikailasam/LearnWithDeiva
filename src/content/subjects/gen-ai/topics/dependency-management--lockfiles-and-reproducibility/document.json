":[{"type":"text","marks":[{"type":"bold"}],"text":"Output ("},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"requirements.txt"},{"type":"text","marks":[{"type":"bold"}],"text":" with hashes):"}]},{"type":"codeBlock","attrs":{"language":"txt"},"content":[{"type":"text","text":"requests==2.32.3 \\\n    --hash=sha256:abc123... \\\n    --hash=sha256:def456...\nurllib3==2.2.2 \\\n    --hash=sha256:ghi789..."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Pipenv"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Create Pipfile (intent)\necho 'requests = \"==2.32.3\"' > Pipfile\n\n# Generate Pipfile.lock (lockfile)\npipenv lock\n\n# Install from lockfile\npipenv install --deploy"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"pip 25.1+ with "},{"type":"text","marks":[{"type":"code"}],"text":"pip lock"},{"type":"text","text":" (Experimental)"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Create lockfile (single-platform only)\npip lock --output-file pylock.toml requests\n\n# Install from lockfile\npip install pylock.toml"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices for Lockfiles"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Treat Lockfile as Source of Truth"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# pyproject.toml = your intent\n# poetry.lock = enforced reality\n\n# Poetry workflow\npoetry lock --no-update    # Resolve without upgrading\npoetry install --sync      # Install exactly what's locked"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Always Commit Lockfiles"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Git\ngit add poetry.lock\ngit commit -m \"Add lockfile for reproducible deps\"\n\n# Never: git ignore lockfiles!"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why:"},{"type":"text","text":" Ensures reproducible builds across machines and CI."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Lockfile-First Workflow"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# 1. Update dependency in pyproject.toml\npoetry add requests==2.32.3\n\n# 2. Update lockfile\npoetry lock\n\n# 3. Install from lockfile\npoetry install"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Never:"},{"type":"text","text":" "},{"type":"text","marks":[{"type":"code"}],"text":"poetry install --upgrade"},{"type":"text","text":" without updating lockfile first."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Use "},{"type":"text","marks":[{"type":"code"}],"text":"--sync"},{"type":"text","text":" to Remove Strays"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Remove packages not in lockfile\npoetry install --sync\n\n# Ensures environment matches lockfile exactly"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. Security: Scan Lockfile for Vulnerabilities"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Check for vulnerabilities in lockfile\nuv audit\npip-audit"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Workflow:"},{"type":"text","text":" Upgrade package → scan lockfile → confirm fix."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"6. Platform-Specific Lockfiles in CI"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Generate lockfile for current platform\n# (lockfiles are platform-specific due to different wheels)\n\n# CI workflow\npoetry lock   # Platform-specific\npoetry install --sync"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common Issues & Solutions"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Issue: Lockfile from Different Platform"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Error: Lockfile doesn't match current platform\n\n# Solution 1: Generate lockfile on same platform\n# (Most reliable)\n\n# Solution 2: Use platform-agnostic install\n# (May not work for all packages)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why:"},{"type":"text","text":" Lockfiles enumerate platform-specific wheels."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Issue: Dependency Conflict"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Error: Cannot resolve dependencies\n\n# Solution 1: Update lockfile\npoetry lock\n\n# Solution 2: Relax version constraints\n# pyproject.toml: requests>=2.28.0\npoetry lock"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Issue: Lockfile Drift"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Problem: pyproject.toml and poetry.lock mismatched\n\n# Solution: Re-resolve\npoetry lock --no-update"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Reproducibility in CI/CD"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Docker Example"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"# Dockerfile\nFROM python:3.10\n\n# Copy lockfile (not pyproject.toml)\nCOPY poetry.lock pyproject.toml ./\n\n# Install from lockfile (fast, no resolution)\nRUN poetry install --no-update --sync\n\n# Your app is now reproducible"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why:"},{"type":"text","text":" No dependency resolution = faster, consistent builds."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"GitHub Actions Example"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"name: CI\njobs:\n  test:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n      \n      - name: Install Poetry\n        run: pip install poetry\n      \n      - name: Install dependencies\n        run: poetry install --no-update --sync\n      \n      - name: Run tests\n        run: poetry run pytest"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Recommendation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use lockfiles"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Essential for reproducible builds"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Commit lockfiles"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Never ignore them in Git"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"p