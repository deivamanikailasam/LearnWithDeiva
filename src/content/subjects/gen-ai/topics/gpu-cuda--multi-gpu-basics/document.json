{"format":"tiptap/v1","updatedAt":"2026-06-22T09:16:49.951Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What Multi-GPU Basics Are"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multi-GPU computing"},{"type":"text","text":" is a hardware setup that uses multiple graphics processing units (GPUs) together to handle complex computational tasks, enabling faster training and inference of large deep learning models."}]},{"type":"paragraph","content":[{"type":"text","text":"By default, deep learning models only utilize a "},{"type":"text","marks":[{"type":"bold"}],"text":"single GPU"},{"type":"text","text":" for training, even if multiple GPUs are available. Multi-GPU training distributes the workload across all available GPUs to "},{"type":"text","marks":[{"type":"bold"}],"text":"shorten training time"},{"type":"text","text":" and enable training on more data."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why Multi-GPU Matters in Generative AI"}]},{"type":"paragraph","content":[{"type":"text","text":"Multi-GPU training is essential for modern AI models:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Benefit"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Impact"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Faster training"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Reduce training time by distributing data across GPUs"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Larger models"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Train models that don't fit on single GPU (e.g., 100B+ parameter LLMs)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Larger batches"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Process massive batches that exceed single GPU memory"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Faster iteration"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Enable faster application development and more experimentation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"10x performance"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Achieve up to 10x training performance improvements"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Two Main Parallelism Strategies"}]},{"type":"paragraph","content":[{"type":"text","text":"The two fundamental approaches to multi-GPU training:"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Model Parallelism"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it is"},{"type":"text","text":": Different parts (layers) of the model are placed on different GPUs"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Model (Too Large for Single GPU)\n├── Layer 1 → GPU 0\n├── Layer 2 → GPU 1\n├── Layer 3 → GPU 2\n└── Layer 4 → GPU 3"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Huge models"},{"type":"text","text":" that don't fit on a single GPU\n- Models with billions of parameters (e.g., GPT-3, LLaMA)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pros"},{"type":"text","text":":\n- Enables training models that exceed single GPU memory"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cons"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Severe bottlenecks"},{"type":"text","text":": Requires data flow between GPUs when activations transfer\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"1st GPU idle"},{"type":"text","text":" when data propagates through layers on 2nd GPU"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Data Parallelism"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it is"},{"type":"text","text":": Replicate the model across all GPUs, divide data into batches, each GPU processes its batch"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Data Parallelism\n├── GPU 0: Model → Batch 1 → Gradients\n├── GPU 1: Model → Batch 2 → Gradients\n├── GPU 2: Model → Batch 3 → Gradients\n├── GPU 3: Model → Batch 4 → Gradients\n└── All GPUs: Aggregate Gradients → Update Model"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Batch size too large"},{"type":"text","text":" for single GPU\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Accelerating training"},{"type":"text","text":" process\n- Most common approach for deep learning"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pros"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"No communication bottleneck"},{"type":"text","text":": Each GPU works independently\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Simpler to implement"},{"type":"text","text":": Just replicate model and split data"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cons"},{"type":"text","text":":\n- Limited by single GPU memory for model size"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Additional Multi-GPU Strategies"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Tensor Parallelism"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it is"},{"type":"text","text":": Distributes individual tensor operations (e.g., matrix multiplication) across multiple devices"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Large Matrix Multiplication\n├── Split matrix into smaller parts\n├── GPU 0: Compute part 1\n├── GPU 1: Compute part 2\n├── GPU 2: Compute part 3\n└── GPU 3: Compute part 4 → Combine results"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use"},{"type":"text","text":":\n- Large tensor operations that can be divided\n- Inherently built into PyTorch/TensorFlow"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Pipeline Parallelism"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it is"},{"type":"text","text":": Combination of data parallelism + model parallelism"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Pipeline Parallelism (Improves GPU Utilization)\nt=1: GPU 0 processes micro-batch 1 → GPU 1 idle\nt=2: GPU 1 processes micro-batch 1 → GPU 0 processes micro-batch 2\nt=3: GPU 2 processes micro-batch 1 → GPU 1 processes micro-batch 2 → GPU 0 processes micro-batch 3"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How it works"},{"type":"text","text":":\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"1st micro-batch"},{"type":"text","text":" passes through layers on 1st GPU\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"2nd GPU"},{"type":"text","text":" receives activations from 1st micro-batch\n3. While 2nd GPU processes, "},{"type":"text","marks":[{"type":"bold"}],"text":"another micro-batch"},{"type":"text","text":" loads on 1st GPU\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"GPU utilization drastically improves"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Multi-GPU in PyTorch"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. DataParallel (Simple Multi-GPU)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import torch\nimport torch.nn as nn\nfrom torch.nn import DataParallel\n\n# Model\nmodel = MyModel()\n\n# Wrap model for multi-GPU\nmodel = DataParallel(model, device_ids=[0, 1, 2, 3])  # Use GPUs 0-3\n\n# Training (automatic)\ninput = torch.randn(128, 784)  # Batch split across GPUs\noutput = model(input)  # Processes on all GPUs\nloss = compute_loss(output, target)\nloss.backward()\noptimizer.step()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best option in PyTorch"},{"type":"text","text":" for multiple GPUs on the same node"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. DistributedDataParallel (DDP) - Production Multi-GPU"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import torch\nimport torch.distributed as dist\nimport torch.nn.parallel as nn\n\n# Initialize distributed training\ndist.init_process_group(\"nccl\")  # NCCL backend for GPUs\n\n# Model\nmodel = MyModel()\n\n# Wrap for distributed training\nmodel = nn.DistributedDataParallel(model, device_ids=[0, 1, 2, 3])\n\n# Training (each GPU gets different batch)\ninput = torch.randn(32, 784)  # 32 per GPU (128 total / 4 GPUs)\noutput = model(input)\nloss = compute_loss(output, target)\nloss.backward()\noptimizer.step()"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Multi-GPU in TensorFlow"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"MirroredStrategy (Best for Multi-GPU)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import tensorflow as tf\n\n# MirroredStrategy for multi-GPU training on single node\nstrategy = tf.distribute.MirroredStrategy()  # Automatic multi-GPU [web:243]\n\n# Create model within strategy\nwith strategy.scope():\n    model = tf.keras.Sequential([\n        tf.keras.layers.Dense(256, activation='relu', input_shape=(784,)),\n        tf.keras.layers.Dense(10)\n    ])\n    \n    model.compile(\n        optimizer='adam',\n        loss='mse'\n    )\n\n# Training (automatic distribution)\nmodel.fit(train_data, train_labels, epochs=10)  # Auto distributes to all GPUs"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best option in TensorFlow"},{"type":"text","text":" for multiple GPUs on a single node"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"GPU Setups for Different Scales"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Setup"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"GPUs"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Case"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Single GPU"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"1"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Small models, prototyping, inference"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Workstation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"2–4"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Medium models, research"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Compute Server"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"8–10"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Large models, production training"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cluster"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"10–100+"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Massive models (LLMs), distributed training"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Multi-GPU Deployment Models"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. GPU Servers"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Definition"},{"type":"text","text":": Servers with GPUs + CPUs integrated"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"CPU role"},{"type":"text","text":": Central management for GPUs (task allocation, result collection)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use case"},{"type":"text","text":": Single-node multi-GPU training"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. GPU Clusters"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Definition"},{"type":"text","text":": Multiple nodes with GPUs (homogeneous or heterogeneous)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Communication"},{"type":"text","text":": Data transferred between nodes via interconnects"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use case"},{"type":"text","text":": Large-scale distributed training (100+ GPUs)"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Kubernetes"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Definition"},{"type":"text","text":": Open-source platform for orchestrating container deployments with GPU support"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Features"},{"type":"text","text":":"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- Heterogeneous clusters with specified resource requirements - Monitoring for reliable performance - Optimized GPU utilization"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Challenges and Solutions"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Challenge 1: Communication Bottleneck"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem"},{"type":"text","text":": GPU-to-GPU communication is slow (PCIe bandwidth limited)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Solution"},{"type":"text","text":": Use NCCL (NVIDIA Collective Communications Library) for optimized GPU communication"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Challenge 2: Load Balancing"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem"},{"type":"text","text":": Uneven workload distribution across GPUs"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Solution"},{"type":"text","text":": - Ensure batch size divisible by number of GPUs\n- Use data partitioning strategies"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Challenge 3: Memory Management"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem"},{"type":"text","text":": GPU memory not automatically shared"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Solution"},{"type":"text","text":":\n- Set memory growth per GPU: "},{"type":"text","marks":[{"type":"code"}],"text":"tf.config.experimental.set_memory_growth(gpu, True)"},{"type":"text","text":"\n- Use virtual device mechanism to split GPU into logical parts"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Start Simple"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Just use .cuda() or .to('cuda')\nmodel = MyModel().to('cuda')\ninput = data.to('cuda')"}]},{"type":"paragraph","content":[{"type":"text","text":"Simple "},{"type":"text","marks":[{"type":"code"}],"text":".cuda()"},{"type":"text","text":" call is enough to start using GPU"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Scale Up Gradually"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Single GPU → Multi-GPU Workstation (2-4 GPUs) → Multi-GPU Server (8-10 GPUs) → Cluster (100+ GPUs)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Use Framework Defaults"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PyTorch"},{"type":"text","text":": Start with "},{"type":"text","marks":[{"type":"code"}],"text":"DataParallel"},{"type":"text","text":" for simple cases"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"TensorFlow"},{"type":"text","text":": Use "},{"type":"text","marks":[{"type":"code"}],"text":"MirroredStrategy"},{"type":"text","text":" for single-node multi-GPU"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Optimize Batch Size"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rule"},{"type":"text","text":": Batch size should be divisible by number of GPUs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": 128 total batch on 4 GPUs = 32 per GPU"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of multi-GPU as "},{"type":"text","marks":[{"type":"bold"}],"text":"a team of workers"},{"type":"text","text":":"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Single GPU"},{"type":"text","text":": One worker doing all tasks (slow)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Model Parallelism"},{"type":"text","text":": Split one huge task among workers (each handles part)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Data Parallelism"},{"type":"text","text":": Each worker has same task, processes different data"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pipeline Parallelism"},{"type":"text","text":": Workers form a pipeline, passing work to each processor"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tensor Parallelism"},{"type":"text","text":": Split one big calculation among workers"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multi-GPU"},{"type":"text","text":": Uses multiple GPUs together for complex tasks"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Default"},{"type":"text","text":": Models use single GPU, even if multiple available"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Model parallelism"},{"type":"text","text":": Different model layers on different GPUs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use model parallelism"},{"type":"text","text":": Models too large for single GPU memory"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Data parallelism"},{"type":"text","text":": Replicate model, split data across GPUs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use data parallelism"},{"type":"text","text":": Large batches, accelerate training"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pipeline parallelism"},{"type":"text","text":": Combo of model + data parallelism"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tensor parallelism"},{"type":"text","text":": Split tensor operations across devices"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PyTorch DataParallel"},{"type":"text","text":": Best option for multi-GPU on single node"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"TensorFlow MirroredStrategy"},{"type":"text","text":": Best option for multi-GPU on single node"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"10x performance"},{"type":"text","text":": Multi-GPU can achieve up to 10x speedup"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"GPU servers"},{"type":"text","text":": Single-node setup with CPUs managing GPUs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"GPU clusters"},{"type":"text","text":": Multi-node setup with interconnects"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Kubernetes"},{"type":"text","text":": Orchestrates GPU containers with monitoring"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"NCCL backend"},{"type":"text","text":": Optimized GPU communication"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Batch size"},{"type":"text","text":": Should be divisible by number of GPUs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Memory growth"},{"type":"text","text":": Set to avoid pre-allocation on all GPUs"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Multi-GPU training is essential for "},{"type":"text","marks":[{"type":"bold"}],"text":"modern generative AI"},{"type":"text","text":" — enabling training of massive models (100B+ LLMs), faster iteration cycles, and up to "},{"type":"text","marks":[{"type":"bold"}],"text":"10x performance improvements"},{"type":"text","text":" by distributing workloads across multiple GPUs."}]}]}}
