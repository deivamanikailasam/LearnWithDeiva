{"format":"tiptap/v1","updatedAt":"2026-06-21T13:43:25.665Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fetch & API Calls"},{"type":"text","text":" in TypeScript/JavaScript are the standard way to call Gen AI APIs (OpenAI, Gemini, Anthropic, etc.) directly from your frontend or backend—using the native "},{"type":"text","marks":[{"type":"code"}],"text":"fetch()"},{"type":"text","text":" API instead of third-party libraries like Axios, with full TypeScript type safety for request/response data."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Concept"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Definition"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Gen AI Use Case"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"fetch()"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Native browser/Node JS API for HTTP requests"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"POST to LLM APIs ("},{"type":"text","marks":[{"type":"code"}],"text":"/v1/chat/completions"},{"type":"text","text":")"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Promise"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"fetch()"},{"type":"text","text":" returns "},{"type":"text","marks":[{"type":"code"}],"text":"Promise<Response>"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"await fetch()"},{"type":"text","text":" waits for API response"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"async/await"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Async function syntax for cleaner fetch calls"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"async function callAI() { await fetch() }"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Headers"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Request metadata (API keys, content type)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"headers: { Authorization: \"Bearer $API_KEY\" }"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Body"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Request payload (JSON stringified)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"body: JSON.stringify({ model, messages })"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"response.json()"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Parse JSON response"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"await response.json()"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why It Matters for Gen AI"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ❌ WITHOUT TypeScript: Runtime errors, no type checking\nconst response = await fetch(\"https://api.openai.com/v1/chat/completions\", {\n  method: \"POST\",\n  headers: { \"Authorization\": \"Bearer SECRET_KEY\" },\n  body: JSON.stringify({ model: \"gpt-4\", messages: [{ role: \"user\", content: \"Hello\" }] })\n});\nconst data = await response.json();\nconsole.log(data.choices[0].message.content);  // ❌ Could crash if structure differs\n\n// ✅ WITH TypeScript: Compile-time safety, clear contracts\ninterface AIRequest {\n  model: string;\n  messages: Array<{ role: \"system\" | \"user\" | \"assistant\"; content: string }>;\n}\n\ninterface AIResponse {\n  choices: Array<{\n    message: { content: string };\n    index: number;\n  }>;\n}\n\nasync function callOpenAI(request: AIRequest): Promise<AIResponse> {\n  const response = await fetch(\"https://api.openai.com/v1/chat/completions\", {\n    method: \"POST\",\n    headers: {\n      \"Authorization\": `Bearer ${process.env.OPENAI_API_KEY}`,\n      \"Content-Type\": \"application/json\"\n    },\n    body: JSON.stringify(request)\n  });\n  \n  if (!response.ok) throw new Error(`API error: ${response.status}`);\n  return await response.json() as Promise<AIResponse>;  // ✅ Type-safe\n}\n\nconst result = await callOpenAI({\n  model: \"gpt-4\",\n  messages: [{ role: \"user\", content: \"Explain quantum computing\" }]\n});\n\nconsole.log(result.choices[0].message.content);  // ✅ TypeScript knows structure [web:50][web:55]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"No dependencies"},{"type":"text","text":": Native in modern browsers + Node.js 18+\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Type safety"},{"type":"text","text":": TypeScript enforces request/response structure\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Async-native"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"async/await"},{"type":"text","text":" + Promises for non-blocking calls\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"LLM agnostic"},{"type":"text","text":": Works with OpenAI, Gemini, Anthropic, Cohere, local models"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How It Works (Core Patterns)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Basic GET Request"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// GET request to any API\nasync function fetchData(url: string): Promise<any> {\n  const response = await fetch(url);\n  \n  if (!response.ok) {\n    throw new Error(`Fetch failed: ${response.statusText}`);\n  }\n  \n  return await response.json();  // ✅ Parse JSON\n}\n\nconst data = await fetchData(\"https://jsonplaceholder.typicode.com/todos/1\");\nconsole.log(data);  // ✅ { id: 1, title: \"delectus aut autem\", ... }"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"POST Request with JSON Body (LLM API)"},{"type":"text","text":" ⭐ Most Common"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// POST to OpenAI Chat API\ninterface ChatRequest {\n  model: string;\n  messages: Array<{ role: \"system\" | \"user\" | \"assistant\"; content: string }>;\n  temperature?: number;\n}\n\ninterface ChatResponse {\n  id: string;\n  choices: Array<{\n    message: { role: string; content: string };\n    index: number;\n  }>;\n  usage: { total_tokens: number };\n}\n\nasync function chatWithOpenAI(request: ChatRequest): Promise<ChatResponse> {\n  const response = await fetch(\"https://api.openai.com/v1/chat/completions\", {\n    method: \"POST\",\n    headers: {\n      \"Authorization\": `Bearer ${process.env.OPENAI_API_KEY}`,\n      \"Content-Type\": \"application/json\"\n    },\n    body: JSON.stringify(request)  // ✅ Stringify JSON body\n  });\n  \n  if (!response.ok) {\n    throw new Error(`OpenAI API error: ${response.status}`);\n  }\n  \n  return await response.json() as Promise<ChatResponse>;  // ✅ Type assertion\n}\n\n// Usage\nconst result = await chatWithOpenAI({\n  model: \"gpt-4o-mini\",\n  messages: [\n    { role: \"system\", content: \"You are a helpful assistant.\" },\n    { role: \"user\", content: \"Who won the world series in 2020?\" }\n  ],\n  temperature: 0.7\n});\n\nconsole.log(result.choices[0].message.content);  // ✅ \"The Boston Red Sox won...\" [web:56]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Google Gemini API with Fetch"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// POST to Gemini API (no SDK needed)\nasync function callGemini(prompt: string): Promise<string> {\n  const response = await fetch(\n    `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${process.env.GEMINI_API_KEY}`,\n    {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({\n        contents: [{ parts: [{ text: prompt }] }]\n      })\n    }\n  );\n  \n  if (!response.ok) throw new Error(`Gemini error: ${response.status}`);\n  \n  const data = await response.json() as {\n    candidates: Array<{ content: { parts: Array<{ text: string }> } }>;\n  };\n  \n  return data.candidates[0].content.parts[0].text;  // ✅ Extract text\n}\n\nconst text = await callGemini(\"Explain quantum computing\");\nconsole.log(text);"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Anthropic Claude API with Fetch"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// POST to Anthropic API\nasync function callClaude(prompt: string): Promise<string> {\n  const response = await fetch(\"https://api.anthropic.com/v1/complete\", {\n    method: \"POST\",\n    headers: {\n      \"Authorization\": `Bearer ${process.env.ANTHROPIC_API_KEY}`,\n      \"Content-Type\": \"application/json\",\n      \"anthropic-version\": \"2023-06-01\"\n    },\n    body: JSON.stringify({\n      model: \"claude-3-sonnet-20240229\",\n      prompt: `\\n\\nHuman: ${prompt}\\n\\nAssistant:`,\n      max_tokens_to_sample: 1024\n    })\n  });\n  \n  if (!response.ok) throw new Error(`Claude error: ${response.status}`);\n  \n  const data = await response.json() as { completion: string };\n  return data.completion;  // ✅ Extract completion [web:54]\n}"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Local AI Models (Ollama) with Fetch"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// POST to local Ollama server (no API key needed)\nasync function callOllama(prompt: string): Promise<string> {\n  const response = await fetch(\"http://localhost:11434/api/generate\", {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({\n      model: \"llama3.1\",\n      prompt: prompt,\n      stream: false  // ✅ Non-streaming\n    })\n  });\n  \n  if (!response.ok) throw new Error(`Ollama error: ${response.status}`);\n  \n  const data = await response.json() as { response: string };\n  return data.response;  // ✅ Extract response [web:52]\n}\n\nconst text = await callOllama(\"Write a JS Fibonacci function\");\nconsole.log(text);"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Error Handling with try/catch"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"async function safeChatWithOpenAI(request: ChatRequest): Promise<ChatResponse | null> {\n  try {\n    const response = await fetch(\"https://api.openai.com/v1/chat/completions\", {\n      method: \"POST\",\n      headers: {\n        \"Authorization\": `Bearer ${process.env.OPENAI_API_KEY}`,\n        \"Content-Type\": \"application/json\"\n      },\n      body: JSON.stringify(request)\n    });\n    \n    if (!response.ok) {\n      throw new Error(`API error: ${response.status}`);\n    }\n    \n    return await response.json() as Promise<ChatResponse>;\n  } catch (error: unknown) {  // ✅ unknown requires type check\n    if (error instanceof Error) {\n      console.error(`Chat failed: ${error.message}`);\n      return null;\n    }\n    throw new Error(\"Unknown error occurred\");\n  }\n}\n\n// Usage\nconst result = await safeChatWithOpenAI({\n  model: \"gpt-4\",\n  messages: [{ role: \"user\", content: \"Hello\" }]\n});\n\nif (result) console.log(result.choices[0].message.content);\nelse console.log(\"Failed to get response\");"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"7. "},{"type":"text","marks":[{"type":"bold"}],"text":"Streaming Responses with Fetch"},{"type":"text","text":" ⭐ Critical for LLMs"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// Streaming to OpenAI (token-by-token)\nasync function* streamChatWithOpenAI(request: ChatRequest): AsyncGenerator<string> {\n  const response = await fetch(\"https://api.openai.com/v1/chat/completions\", {\n    method: \"POST\",\n    headers: {\n      \"Authorization\": `Bearer ${process.env.OPENAI_API_KEY}`,\n      \"Content-Type\": \"application/json\"\n    },\n    body: JSON.stringify({ ...request, stream: true })  // ✅ Enable streaming\n  });\n  \n  if (!response.ok) throw new Error(`Stream error: ${response.status}`);\n  \n  const reader = response.body!.getReader();\n  const decoder = new TextDecoder();\n  \n  while (true) {\n    const { done, value } = await reader.read();\n    if (done) break;\n    \n    const chunk = decoder.decode(value);\n    // Parse SSE (Server-Sent Events) format\n    const lines = chunk.split(\"\\n\").filter(line => line.trim());\n    \n    for (const line of lines) {\n      if (line.startsWith(\"data: \")) {\n        const data = JSON.parse(line.slice(6)) as {\n          choices: Array<{ delta: { content?: string } }>;\n        };\n        \n        const content = data.choices[0].delta.content;\n        if (content) yield content;  // ✅ Stream each token\n      }\n    }\n  }\n}\n\n// Usage: Real-time streaming\nasync function displayStreaming() {\n  const stream = streamChatWithOpenAI({\n    model: \"gpt-4\",\n    messages: [{ role: \"user\", content: \"Explain quantum computing\" }]\n  });\n  \n  for await (const token of stream) {  // ✅ for-await loop\n    console.log(token);  // ✅ Prints token immediately\n    updateUI(token);\n  }\n}"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use (Decision Criteria)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use "},{"type":"text","marks":[{"type":"code"}],"text":"fetch()"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use SDK"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Axios"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Simple API call"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Native, no deps"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Extra install"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Extra dep"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Type safety"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ TypeScript interfaces"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Built-in"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Need types"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"SDK-specific features"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Manual implementation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Streaming, tools"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Limited"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Legacy browser"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Need polyfill"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Need polyfill"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Works"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Retry logic"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Manual"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Built-in (some)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Built-in"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Local models"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Direct HTTP"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Not supported"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Possible"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rule of thumb:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"fetch()"},{"type":"text","text":": Default for simple API calls\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"SDK"},{"type":"text","text":": Use for advanced features (streaming, tools)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Axios"},{"type":"text","text":": Legacy projects or need retry/timeout features"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How to Implement (Step-by-Step)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 1: Define TypeScript Interfaces"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// types/ai.ts\nexport interface AIRequest {\n  model: string;\n  messages: Array<{ role: \"system\" | \"user\" | \"assistant\"; content: string }>;\n  temperature?: number;\n}\n\nexport interface AIResponse {\n  choices: Array<{\n    message: { role: string; content: string };\n    index: number;\n  }>;\n  usage: { total_tokens: number };\n}"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 2: Create API Client"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// api/openai.ts\nimport { AIRequest, AIResponse } from \"../types/ai\";\n\nexport async function callOpenAI(request: AIRequest): Promise<AIResponse> {\n  const response = await fetch(\"https://api.openai.com/v1/chat/completions\", {\n    method: \"POST\",\n    headers: {\n      \"Authorization\": `Bearer ${process.env.OPENAI_API_KEY}`,\n      \"Content-Type\": \"application/json\"\n    },\n    body: JSON.stringify(request)\n  });\n  \n  if (!response.ok) throw new Error(`API error: ${response.status}`);\n  return await response.json() as Promise<AIResponse>;\n}"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 3: Use in React Component"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// components/AIChat.tsx\nimport { callOpenAI } from \"../api/openai\";\nimport { AIRequest } from \"../types/ai\";\n\nexport function AIChat() {\n  const [response, setResponse] = useState<string | null>(null);\n  const [loading, setLoading] = useState(false);\n\n  const handleSubmit = async (prompt: string) => {\n    setLoading(true);\n    try {\n      const request: AIRequest = {\n        model: \"gpt-4o-mini\",\n        messages: [{ role: \"user\", content: prompt }]\n      };\n      \n      const result = await callOpenAI(request);  // ✅ Type-safe\n      setResponse(result.choices[0].message.content);\n    } catch (error) {\n      if (error instanceof Error) {\n        console.error(error.message);\n      }\n      setResponse(null);\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  return (\n    <div>\n      {loading ? <p>Loading...</p> : response && <p>{response}</p>}\n    </div>\n  );\n}"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Real-World Example: Production AI Backend with Fetch"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Scale"},{"type":"text","text":": 10K+ requests/day, Express + TypeScript\n"},{"type":"text","marks":[{"type":"bold"}],"text":"Architecture"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Backend (Node.js + Express):\n├── types/ai.ts (AIRequest, AIResponse interfaces)\n├── api/openai.ts (callOpenAI with fetch)\n├── routes/ai.ts (POST /chat endpoint)\n└── controllers/ai.ts (async handler)\n\nFrontend (React):\n├── api/client.ts (fetch wrapper)\n├── components/AIChat.tsx (async event handler)\n└── hooks/useAIChat.ts (streaming with AsyncGenerator)\n\nSecurity:\n- API keys in .env (LOADS from process.env)\n- CORS enabled for frontend\n- Rate limiting (express-rate-limit)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Outcome"},{"type":"text","text":": Secure AI backend calling LLM APIs with fetch, type-safe front-end integration."}]},{"type":"horizonta