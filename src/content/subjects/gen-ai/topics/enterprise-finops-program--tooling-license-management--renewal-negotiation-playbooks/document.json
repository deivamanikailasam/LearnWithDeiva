    "content": [
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Why AI Tool Renewals Need Dedicated Playbooks"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "AI tooling vendors \u2014 GitHub, Anthropic, OpenAI, Cursor, Perplexity \u2014 operate in a market where pricing is still volatile, competitive alternatives emerge rapidly, and utilization patterns differ sharply from traditional software. Standard software renewal playbooks (renew at last year's price with a 5% increase) underperform because they ignore two levers unique to AI tools: the rapidly falling cost of underlying models and the high variance in seat utilization across teams."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Negotiation timeline"
        }
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "The 90-day window is not optional. With less than 30 days to renewal, the vendor knows you are unlikely to switch \u2014 they have maximum leverage. Opening the conversation at T-60 or T-45 gives you time to request and receive competitor quotes, which is the single most effective negotiation lever."
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Playbook Data Model"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A renewal playbook encodes the target outcome, the BATNA (Best Alternative to a Negotiated Agreement), and the evidence package before any conversation with the vendor begins. The scenario classification drives which tactics apply."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass, field\nfrom datetime import date\nfrom enum import Enum\nfrom typing import Optional\n\nclass NegotiationScenario(Enum):\n    OVER_LICENSED    = \"over_licensed\"    # utilization < 50% \u2192 reduce seats\n    HEALTHY_RENEWAL  = \"healthy_renewal\"  # utilization 70\u201395% \u2192 maintain + discount\n    EXPANSION        = \"expansion\"        # utilization > 95% \u2192 negotiate block deal\n    COMPETITIVE      = \"competitive\"      # credible alternative exists\n    CANCEL           = \"cancel\"           # utilization < 10% or duplicate tool\n\n@dataclass\nclass VendorContact:\n    name: str\n    role: str            # \"Account Executive\" | \"Customer Success\" | \"VP Sales\"\n    email: str\n    escalation_path: str  # who to go to if AE is unresponsive\n\n@dataclass\nclass BATNA:\n    alternative: str        # name of competitor or alternative approach\n    est_annual_cost_usd: float\n    switching_cost_usd: float    # migration, retraining, integration work\n    readiness: str          # \"ready\" | \"could_be_ready_in_30d\" | \"hypothetical\"\n    notes: str = \"\"\n\n    @property\n    def total_switch_cost_usd(self) -> float:\n        return self.est_annual_cost_usd + self.switching_cost_usd\n\n@dataclass\nclass RenewalPlaybook:\n    tool_id: str\n    product_name: str\n    vendor: str\n    renewal_date: date\n    scenario: NegotiationScenario\n    current_annual_usd: float\n    current_seats: int\n    target_seats: int\n    opening_ask_usd: float       # first offer (lower than walk-away)\n    walk_away_usd: float         # maximum acceptable price\n    batna: BATNA\n    vendor_contacts: list[VendorContact] = field(default_factory=list)\n    data_package: list[str] = field(default_factory=list)  # evidence to present\n    concessions_available: list[str] = field(default_factory=list)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Scenario-Specific Playbooks"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Different renewal scenarios require different opening positions and concession structures. The two most common for AI tools are over-licensed (utilization < 50%) and competitive (a credible alternative exists at a materially lower price)."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def build_over_licensed_playbook(\n    tool_id: str,\n    product_name: str,\n    vendor: str,\n    renewal_date: date,\n    current_seats: int,\n    target_seats: int,\n    current_annual_usd: float,\n    batna: BATNA,\n    vendor_contacts: list[VendorContact],\n) -> RenewalPlaybook:\n    cost_per_seat = current_annual_usd / current_seats\n    target_cost = target_seats * cost_per_seat\n\n    return RenewalPlaybook(\n        tool_id=tool_id,\n        product_name=product_name,\n        vendor=vendor,\n        renewal_date=renewal_date,\n        scenario=NegotiationScenario.OVER_LICENSED,\n        current_annual_usd=current_annual_usd,\n        current_seats=current_seats,\n        target_seats=target_seats,\n        opening_ask_usd=target_cost * 0.85,    # open 15% below linear reduction\n        walk_away_usd=target_cost * 1.05,       # accept up to 5% above linear\n        batna=batna,\n        vendor_contacts=vendor_contacts,\n        data_package=[\n            f\"3-month utilization report: {target_seats} peak active users of {current_seats} seats\",\n            f\"Seat activity log: {current_seats - target_seats} seats with 0 logins in 90 days\",\n            f\"Budget constraint letter from Finance (if applicable)\",\n        ],\n        concessions_available=[\n            \"Accept 2-year term in exchange for 15% additional discount\",\n            \"Provide a reference customer case study\",\n            \"Participate in vendor beta programme\",\n        ],\n    )\n\n\ndef build_competitive_playbook(\n    tool_id: str,\n    product_name: str,\n    vendor: str,\n    renewal_date: date,\n    current_annual_usd: float,\n    current_seats: int,\n    batna: BATNA,\n    vendor_contacts: list[VendorContact],\n) -> RenewalPlaybook:\n    target_cost = min(current_annual_usd * 0.80, batna.est_annual_cost_usd * 1.10)\n\n    return RenewalPlaybook(\n        tool_id=tool_id,\n        product_name=product_name,\n        vendor=vendor,\n        renewal_date=renewal_date,\n        scenario=NegotiationScenario.COMPETITIVE,\n        current_annual_usd=current_annual_usd,\n        current_seats=current_seats,\n        target_seats=current_seats,   # same seats, better price\n        opening_ask_usd=target_cost * 0.90,\n        walk_away_usd=target_cost * 1.10,\n        batna=batna,\n        vendor_contacts=vendor_contacts,\n        data_package=[\n            f\"Competitor proposal: {batna.alternative} at ${batna.est_annual_cost_usd:,.0f}/yr\",\n            f\"Switching cost analysis: ${batna.switching_cost_usd:,.0f} one-time (migration + retraining)\",\n            f\"Internal evaluation summary confirming functional parity\",\n        ],\n        concessions_available=[\n            \"Remain on current vendor if price within 10% of competitor\",\n            \"Accept 18-month term (vs standard 12) for larger discount\",\n        ],\n    )"
          }
        ]
      },
