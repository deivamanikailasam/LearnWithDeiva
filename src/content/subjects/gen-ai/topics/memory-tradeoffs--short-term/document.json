        "content": [
          {
            "type": "text",
            "text": "The Context Window as Working Memory"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The context window is the "
          },
          {
            "type": "text",
            "text": "total capacity",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " of short-term memory. All input tokens (system prompt, conversation history, tool definitions, retrieved documents) plus all output tokens must fit within it. Modern models range from 32k to 200k tokens."
          }
        ]
      },
