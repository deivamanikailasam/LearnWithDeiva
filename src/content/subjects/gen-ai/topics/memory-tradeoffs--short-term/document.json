      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Short-term memory is fast and free \u2014 there is no retrieval cost or infrastructure to manage. The constraint is size: everything in short-term memory counts against the context limit."
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
