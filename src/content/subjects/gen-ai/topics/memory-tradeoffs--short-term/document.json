            "text": "Short-Term Memory in LLM Agents"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Short-term memory in an LLM agent is anything that lives "
          },
          {
            "type": "text",
            "text": "inside",
            "marks": [
              {
                "type": "italic"
              }
            ]
