        "content": [
          {
            "type": "text",
            "text": "def compress_history(messages: list[dict]) -> str:\n    \"\"\"\n    Convert a message list to a compact text representation\n    for use as context when the full list would overflow.\n    \"\"\"\n    lines = []\n    for m in messages:\n        role = \"U\" if m[\"role\"] == \"user\" else \"A\"\n        content = m[\"content\"]\n        if isinstance(content, list):\n            # Handle content blocks (e.g., tool results)\n            parts = []\n            for block in content:\n                if isinstance(block, dict) and block.get(\"type\") == \"text\":\n                    parts.append(block[\"text\"][:200])\n                elif isinstance(block, str):\n                    parts.append(block[:200])\n            content = \" | \".join(parts)\n        lines.append(f\"{role}: {str(content)[:200]}\")\n    return \"\\n\".join(lines)\n\n# Inject the compressed history as a single system message\n# when the full message list would overflow\ndef make_messages_with_compressed_history(\n    full_history: list[dict],\n    new_user_text: str,\n    max_verbatim: int = 6,\n) -> list[dict]:\n    recent = full_history[-max_verbatim:]\n    older = full_history[:-max_verbatim]\n\n    messages = []\n    if older:\n        compressed = compress_history(older)\n        messages.append({\"role\": \"user\", \"content\": f\"[Earlier conversation]\\n{compressed}\"})\n        messages.append({\"role\": \"assistant\", \"content\": \"I have that context.\"})\n    messages.extend(recent)\n    messages.append({\"role\": \"user\", \"content\": new_user_text})\n    return messages"
          }
        ]
      },
