            "type": "text",
            "text": "Authentication for GenAI APIs"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "GenAI APIs need authentication for two different caller types: "
          },
          {
            "type": "text",
            "text": "services",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " (backend systems with API keys) and "
          },
          {
            "type": "text",
            "text": "users",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " (humans with short-lived session tokens). Each requires a different auth pattern."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "LLM calls are expensive, so authentication here matters more than in typical CRUD APIs — an unauthenticated endpoint leaks both money and usage quota to anyone who discovers it."
          }
        ]
      },
