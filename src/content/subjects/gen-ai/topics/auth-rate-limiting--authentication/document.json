        "content": [
          {
            "type": "text",
            "text": "API Keys"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "API keys are the simplest pattern for server-to-server calls. Generate a cryptographically random key, store a hash of it (never the plaintext), and look it up on each request. Prefix keys with a recognisable string so secrets-scanning tools catch accidental exposure in logs or repos:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# scripts/generate_key.py\nimport secrets, hashlib\n\ndef generate_api_key() -> tuple[str, str]:\n    \"\"\"Returns (raw_key_to_give_user, hash_to_store_in_db).\"\"\"\n    raw = \"sk-\" + secrets.token_urlsafe(32)\n    hashed = hashlib.sha256(raw.encode()).hexdigest()\n    return raw, hashed\n\n# Store hashed in DB:\n# INSERT INTO api_keys (user_id, key_hash, name, created_at)\n# VALUES ($1, $2, $3, now());\nraw_key, key_hash = generate_api_key()\nprint(f\"Give to user: {raw_key}\")\nprint(f\"Store in DB:  {key_hash}\")"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# app/middleware/auth.py — API key verification\nimport hashlib\nfrom fastapi import Request, HTTPException, status\nfrom app.services.db import db\n\nasync def verify_api_key(request: Request) -> dict:\n    raw = request.headers.get(\"X-API-Key\", \"\")\n    if not raw.startswith(\"sk-\"):\n        raise HTTPException(status.HTTP_401_UNAUTHORIZED, \"Invalid API key format\")\n\n    key_hash = hashlib.sha256(raw.encode()).hexdigest()\n\n    # Query uses the hash — never the raw key\n    row = await db.fetchrow(\n        \"SELECT user_id, scopes, revoked_at FROM api_keys WHERE key_hash = $1\",\n        key_hash,\n    )\n    if not row or row[\"revoked_at\"] is not None:\n        raise HTTPException(status.HTTP_401_UNAUTHORIZED, \"API key not found or revoked\")\n\n    return {\"user_id\": row[\"user_id\"], \"scopes\": row[\"scopes\"]}"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Cache the hash-to-user_id lookup in Redis with a short TTL (30–60 seconds) to avoid hitting the database on every request. On key revocation, delete the cache entry immediately."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "JWT Authentication"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "JWTs are self-contained tokens signed by the auth server. The API verifies the signature without a database lookup — making them fast and stateless. Use HS256 (symmetric secret) for single-server setups and RS256 (asymmetric keypair) for multi-service architectures where multiple services need to verify tokens independently."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# app/auth/tokens.py\nimport jwt\nfrom datetime import datetime, timedelta, timezone\nfrom app.config import settings\n\ndef create_access_token(user_id: str, scopes: list[str]) -> str:\n    payload = {\n        \"sub\": user_id,\n        \"scopes\": scopes,\n        \"iat\": datetime.now(timezone.utc),\n        \"exp\": datetime.now(timezone.utc) + timedelta(minutes=15),\n    }\n    return jwt.encode(payload, settings.jwt_secret, algorithm=\"HS256\")\n\ndef create_refresh_token(user_id: str) -> str:\n    payload = {\n        \"sub\": user_id,\n        \"type\": \"refresh\",\n        \"exp\": datetime.now(timezone.utc) + timedelta(days=30),\n    }\n    return jwt.encode(payload, settings.jwt_refresh_secret, algorithm=\"HS256\")\n\ndef verify_access_token(token: str) -> dict:\n    try:\n        return jwt.decode(token, settings.jwt_secret, algorithms=[\"HS256\"])\n    except jwt.ExpiredSignatureError:\n        raise ValueError(\"Token expired\")\n    except jwt.InvalidTokenError as e:\n        raise ValueError(f\"Invalid token: {e}\")"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# app/api/auth.py — token endpoints\nfrom fastapi import APIRouter, HTTPException, status\nfrom pydantic import BaseModel\nfrom app.auth.tokens import create_access_token, create_refresh_token, verify_access_token\nfrom app.services.users import verify_password, get_user\n\nrouter = APIRouter(prefix=\"/auth\", tags=[\"auth\"])\n\nclass LoginRequest(BaseModel):\n    email: str\n    password: str\n\n@router.post(\"/token\")\nasync def login(body: LoginRequest):\n    user = await get_user(body.email)\n    if not user or not verify_password(body.password, user[\"password_hash\"]):\n        raise HTTPException(status.HTTP_401_UNAUTHORIZED, \"Invalid credentials\")\n\n    return {\n        \"access_token\": create_access_token(user[\"id\"], user[\"scopes\"]),\n        \"refresh_token\": create_refresh_token(user[\"id\"]),\n        \"token_type\": \"bearer\",\n    }\n\nclass RefreshRequest(BaseModel):\n    refresh_token: str\n\n@router.post(\"/refresh\")\nasync def refresh(body: RefreshRequest):\n    try:\n        payload = verify_access_token(body.refresh_token)\n        if payload.get(\"type\") != \"refresh\":\n            raise ValueError(\"Not a refresh token\")\n    except ValueError as e:\n        raise HTTPException(status.HTTP_401_UNAUTHORIZED, str(e))\n\n    user = await get_user_by_id(payload[\"sub\"])\n    return {\n        \"access_token\": create_access_token(user[\"id\"], user[\"scopes\"]),\n        \"token_type\": \"bearer\",\n    }"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "OIDC / OAuth2 with a Provider"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For social login (Google, GitHub) or enterprise SSO (Azure AD, Okta), implement the OAuth2 authorization code flow. The provider authenticates the user; your backend exchanges the authorization code for an ID token, verifies it, and issues its own short-lived JWT:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# app/api/oidc.py — Google OIDC example\nimport httpx, jwt as pyjwt\nfrom fastapi import APIRouter, Request\nfrom fastapi.responses import RedirectResponse\nfrom app.config import settings\nfrom app.auth.tokens import create_access_token\n\nrouter = APIRouter(prefix=\"/auth/oidc\", tags=[\"oidc\"])\n\nGOOGLE_TOKEN_URL = \"https://oauth2.googleapis.com/token\"\nGOOGLE_CERTS_URL = \"https://www.googleapis.com/oauth2/v3/certs\"\n\n@router.get(\"/login\")\nasync def oidc_login():\n    params = {\n        \"client_id\": settings.google_client_id,\n        \"redirect_uri\": settings.oidc_redirect_uri,\n        \"response_type\": \"code\",\n        \"scope\": \"openid email profile\",\n        \"state\": \"csrf-token\",   # in prod: use a signed random value\n    }\n    url = \"https://accounts.google.com/o/oauth2/v2/auth?\" + \"&\".join(\n        f\"{k}={v}\" for k, v in params.items()\n    )\n    return RedirectResponse(url)\n\n@router.get(\"/callback\")\nasync def oidc_callback(code: str, state: str):\n    # Exchange code for tokens\n    async with httpx.AsyncClient() as client:\n        resp = await client.post(GOOGLE_TOKEN_URL, data={\n            \"code\": code,\n            \"client_id\": settings.google_client_id,\n            \"client_secret\": settings.google_client_secret,\n            \"redirect_uri\": settings.oidc_redirect_uri,\n            \"grant_type\": \"authorization_code\",\n        })\n        tokens = resp.json()\n\n    # Verify the id_token using Google's public keys\n    # (google-auth library handles key rotation automatically)\n    from google.oauth2 import id_token as google_id_token\n    from google.auth.transport import requests as google_requests\n    id_info = google_id_token.verify_oauth2_token(\n        tokens[\"id_token\"],\n        google_requests.Request(),\n        settings.google_client_id,\n    )\n\n    user_id = await upsert_user(\n        email=id_info[\"email\"],\n        name=id_info.get(\"name\"),\n        provider=\"google\",\n        provider_sub=id_info[\"sub\"],\n    )\n\n    # Issue your own JWT — don't pass the Google token downstream\n    access_token = create_access_token(user_id, scopes=[\"chat\"])\n    return {\"access_token\": access_token, \"token_type\": \"bearer\"}"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Scope-Based Access Control"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Attach scopes to every token and check them in route dependencies. This prevents a key with "
          },
          {
            "type": "text",
            "text": "scope: read",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " from calling write endpoints, and limits API keys to specific capabilities:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# app/api/deps.py\nfrom fastapi import Depends, HTTPException, status\nfrom fastapi.security import HTTPBearer, HTTPAuthorizationCredentials\nfrom app.auth.tokens import verify_access_token\nfrom app.middleware.auth import verify_api_key\nfrom typing import Callable\n\nsecurity = HTTPBearer(auto_error=False)\n\nasync def get_auth_context(\n    credentials: HTTPAuthorizationCredentials | None = Depends(security),\n    request=None,\n) -> dict:\n    # Try API key first (X-API-Key header)\n    api_key = (request.headers.get(\"X-API-Key\") if request else None)\n    if api_key:\n        return await verify_api_key(request)\n\n    # Fall back to Bearer JWT\n    if not credentials:\n        raise HTTPException(status.HTTP_401_UNAUTHORIZED, \"Authentication required\")\n    try:\n        return verify_access_token(credentials.credentials)\n    except ValueError as e:\n        raise HTTPException(status.HTTP_401_UNAUTHORIZED, str(e))\n\ndef require_scope(scope: str) -> Callable:\n    async def check(auth: dict = Depends(get_auth_context)):\n        if scope not in auth.get(\"scopes\", []):\n            raise HTTPException(\n                status.HTTP_403_FORBIDDEN,\n                f\"Scope '{scope}' required\",\n            )\n        return auth\n    return check\n\n# Usage in routes:\n# @router.post(\"/chat/completions\")\n# async def chat(auth=Depends(require_scope(\"chat\"))):\n#     user_id = auth[\"user_id\"]"
          }
        ]
      },
