          {
            "type": "text",
            "text": "# tests/test_prompt_registry.py\nimport pytest\nfrom unittest.mock import patch, MagicMock\nimport json, hashlib\n\nFAKE_PROMPT = {\n    \"name\": \"rag-assistant\",\n    \"version\": \"v8\",\n    \"system\": \"You are a helpful assistant.\",\n    \"examples\": [],\n    \"parameters\": {\"temperature\": 0.2, \"max_tokens\": 512, \"top_p\": 0.9},\n}\nBLOB = json.dumps(FAKE_PROMPT, sort_keys=True, ensure_ascii=False)\nCONTENT_HASH = hashlib.sha256(BLOB.encode()).hexdigest()\n\n@pytest.fixture\ndef mock_registry(monkeypatch):\n    item = {**FAKE_PROMPT, \"blob\": BLOB, \"content_hash\": CONTENT_HASH, \"stage\": \"Production\"}\n    mock_table = MagicMock()\n    mock_table.query.return_value = {\"Items\": [item]}\n    monkeypatch.setattr(\"your_module._table\", mock_table)\n    # Clear LRU cache between tests\n    from your_module import load_prompt\n    load_prompt.cache_clear()\n    return mock_table\n\ndef test_load_prompt_returns_correct_version(mock_registry):\n    from your_module import load_prompt\n    result = load_prompt(\"rag-assistant\")\n    assert result[\"version\"] == \"v8\"\n    assert result[\"system\"] == \"You are a helpful assistant.\"\n\ndef test_load_prompt_integrity_check_fails_on_tampered_blob(monkeypatch):\n    tampered = {\n        **FAKE_PROMPT,\n        \"blob\": BLOB,\n        \"content_hash\": \"deadbeef\" * 8,  # wrong hash\n        \"stage\": \"Production\",\n    }\n    mock_table = MagicMock()\n    mock_table.query.return_value = {\"Items\": [tampered]}\n    monkeypatch.setattr(\"your_module._table\", mock_table)\n    from your_module import load_prompt\n    load_prompt.cache_clear()\n    with pytest.raises(RuntimeError, match=\"integrity check failed\"):\n        load_prompt(\"rag-assistant\")"
          }
        ]
