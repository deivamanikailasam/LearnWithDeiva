      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Entries are "
          },
          {
            "type": "text",
            "text": "immutable once created",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " — registering v8 seals it. To change a prompt, register v9. This makes the registry an append-only audit log."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Prompt YAML Format"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Store prompts as structured YAML rather than raw strings. Structure separates the system instruction from few-shot examples, making it easier to diff, review, and test individual parts:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "yaml"
        },
        "content": [
          {
            "type": "text",
            "text": "# config/prompts/rag-assistant/v8.yaml\nname: rag-assistant\nversion: v8\ndescription: \"Customer support RAG with citation enforcement\"\n\nsystem: |\n  You are a helpful assistant for Acme Inc. support.\n  Answer using only the context passages provided.\n  Cite sources with [Doc N] notation.\n  If the answer is not in context, respond: \"I don't have that information.\"\n\nexamples:\n  - role: user\n    content: \"What is the return policy?\"\n  - role: assistant\n    content: \"Returns are accepted within 30 days of purchase [Doc 1].\"\n\nparameters:\n  temperature: 0.2\n  max_tokens: 512\n  top_p: 0.9\n\nconstraints:\n  - \"Must cite at least one source for factual claims\"\n  - \"Must not answer questions outside the provided context\""
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "GitOps Approach: Git as the Source of Truth"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The prompt YAML file in git "
          },
          {
            "type": "text",
            "text": "is",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " the registry entry. CI reads it, validates it, and pushes it to the runtime registry store. This gives you free versioning (git history), code review for prompt changes, and a rollback path ("
          },
          {
            "type": "text",
            "text": "git revert",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ") before touching the runtime registry."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# scripts/register_prompt.py — run by CI after validation passes\nimport hashlib, json, yaml, boto3\nfrom datetime import datetime, timezone\n\ndef register_prompt(yaml_path: str, git_sha: str, run_id: str) -> dict:\n    with open(yaml_path) as f:\n        prompt = yaml.safe_load(f)\n\n    blob = json.dumps(prompt, sort_keys=True, ensure_ascii=False)\n    content_hash = hashlib.sha256(blob.encode()).hexdigest()\n\n    entry = {\n        \"name\": prompt[\"name\"],\n        \"version\": prompt[\"version\"],\n        \"stage\": \"Candidate\",\n        \"content_hash\": content_hash,\n        \"git_sha\": git_sha,\n        \"blob\": blob,\n        \"registered_at\": datetime.now(timezone.utc).isoformat(),\n        \"run_id\": run_id,\n    }\n\n    # Store in DynamoDB (or swap for MLflow / HF Hub artifact)\n    table = boto3.resource(\"dynamodb\").Table(\"prompt-registry\")\n    table.put_item(\n        Item=entry,\n        ConditionExpression=\"attribute_not_exists(#v)\",  # immutable: never overwrite\n        ExpressionAttributeNames={\"#v\": \"version\"},\n    )\n    return entry\n\nif __name__ == \"__main__\":\n    import os, subprocess\n    sha = subprocess.check_output([\"git\", \"rev-parse\", \"HEAD\"]).decode().strip()\n    entry = register_prompt(\n        yaml_path=\"config/prompts/rag-assistant/v8.yaml\",\n        git_sha=sha,\n        run_id=os.environ[\"GITHUB_RUN_ID\"],\n    )\n    print(f\"Registered {entry['name']} {entry['version']} ({entry['content_hash'][:8]})\")"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Promotion and Eval Gate"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Promote from Candidate to Staging, and from Staging to Production, only when eval scores clear defined thresholds. The same "
          },
          {
            "type": "text",
            "text": "promote.py",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " pattern from the model registry applies:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# scripts/promote_prompt.py\nimport boto3, json\nfrom datetime import datetime, timezone\n\nTHRESHOLDS = {\n    \"judge_score\": 0.85,\n    \"citation_rate\": 0.92,\n}\n\ndef promote(name: str, version: str, to_stage: str, eval_scores: dict) -> None:\n    for metric, threshold in THRESHOLDS.items():\n        score = eval_scores.get(metric, 0.0)\n        if score < threshold:\n            raise ValueError(\n                f\"Promotion blocked: {metric}={score:.3f} < {threshold}\"\n            )\n\n    table = boto3.resource(\"dynamodb\").Table(\"prompt-registry\")\n\n    # Archive the current occupant of to_stage\n    resp = table.query(\n        IndexName=\"stage-index\",\n        KeyConditionExpression=\"stage = :s AND #n = :name\",\n        ExpressionAttributeNames={\"#n\": \"name\"},\n        ExpressionAttributeValues={\":s\": to_stage, \":name\": name},\n    )\n    for item in resp[\"Items\"]:\n        table.update_item(\n            Key={\"name\": item[\"name\"], \"version\": item[\"version\"]},\n            UpdateExpression=\"SET stage = :archived\",\n            ExpressionAttributeValues={\":archived\": \"Archived\"},\n        )\n\n    # Promote target\n    table.update_item(\n        Key={\"name\": name, \"version\": version},\n        UpdateExpression=\"SET stage = :stage, eval_scores = :scores, promoted_at = :ts\",\n        ExpressionAttributeValues={\n            \":stage\": to_stage,\n            \":scores\": json.dumps(eval_scores),\n            \":ts\": datetime.now(timezone.utc).isoformat(),\n        },\n    )\n    print(f\"Promoted {name} {version} → {to_stage}\")"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Loading the Production Prompt at Serving Time"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The serving layer resolves the prompt at startup (or on a refresh interval) by name. It must validate the content hash on every load to detect silent corruption:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import hashlib, json, boto3\nfrom functools import lru_cache\nfrom typing import Any\n\n_table = boto3.resource(\"dynamodb\").Table(\"prompt-registry\")\n\n@lru_cache(maxsize=8)\ndef load_prompt(name: str, stage: str = \"Production\") -> dict[str, Any]:\n    resp = _table.query(\n        IndexName=\"stage-index\",\n        KeyConditionExpression=\"#n = :name AND stage = :stage\",\n        ExpressionAttributeNames={\"#n\": \"name\"},\n        ExpressionAttributeValues={\":name\": name, \":stage\": stage},\n    )\n    items = resp[\"Items\"]\n    if not items:\n        raise RuntimeError(f\"No {stage} prompt found for '{name}'\")\n\n    item = items[0]\n    prompt = json.loads(item[\"blob\"])\n\n    # Verify integrity\n    expected_hash = item[\"content_hash\"]\n    actual_hash = hashlib.sha256(item[\"blob\"].encode()).hexdigest()\n    if actual_hash != expected_hash:\n        raise RuntimeError(\n            f\"Prompt integrity check failed for {name} {item['version']}: \"\n            f\"expected {expected_hash[:8]}, got {actual_hash[:8]}\"\n        )\n\n    return {\"version\": item[\"version\"], **prompt}\n\n# Usage in request handler\ndef build_messages(user_query: str, context_passages: list[str]) -> list[dict]:\n    prompt = load_prompt(\"rag-assistant\")\n    system = prompt[\"system\"].strip()\n    context_block = \"\\n\\n\".join(\n        f\"[Doc {i+1}] {p}\" for i, p in enumerate(context_passages)\n    )\n    return [\n        {\"role\": \"system\", \"content\": system},\n        *prompt.get(\"examples\", []),\n        {\"role\": \"user\", \"content\": f\"Context:\\n{context_block}\\n\\nQuestion: {user_query}\"},\n    ]"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The "
          },
          {
            "type": "text",
            "text": "lru_cache",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " avoids a DynamoDB round-trip on every request. Invalidate the cache on receipt of a deployment notification (SNS, Kubernetes rollout hook) so the serving process picks up a newly promoted version without a restart."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Tagging Traces with Prompt Version"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Every LLM request trace should record the prompt name and version. This makes regressions searchable: filter your eval dashboard by prompt version to pinpoint when a quality drop first appeared."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\n\nclient = anthropic.Anthropic()\n\ndef run_rag_request(\n    query: str,\n    passages: list[str],\n    trace_logger,\n) -> str:\n    prompt_meta = load_prompt(\"rag-assistant\")\n    messages = build_messages(query, passages)\n\n    response = client.messages.create(\n        model=\"claude-sonnet-4-6\",\n        max_tokens=prompt_meta[\"parameters\"][\"max_tokens\"],\n        temperature=prompt_meta[\"parameters\"][\"temperature\"],\n        messages=messages,\n    )\n    answer = response.content[0].text\n\n    trace_logger.log({\n        \"prompt_name\": \"rag-assistant\",\n        \"prompt_version\": prompt_meta[\"version\"],\n        \"input_tokens\": response.usage.input_tokens,\n        \"output_tokens\": response.usage.output_tokens,\n        \"answer\": answer,\n    })\n    return answer"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing Prompt Registry Integration"
          }
        ]
      },
      {
        "type": "codeBlock",
