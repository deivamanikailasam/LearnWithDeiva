          {
            "type": "text",
            "text": "# Parameter profiles for different task types\nPROFILES: dict[str, dict] = {\n    \"factual_qa\": {\n        \"temperature\": 0.2,\n        \"frequency_penalty\": 0.0,\n        \"presence_penalty\": 0.0,\n        \"max_tokens\": 300,\n    },\n    \"creative_writing\": {\n        \"temperature\": 0.9,\n        \"frequency_penalty\": 0.5,  # prevents loops in long creative output\n        \"presence_penalty\": 0.3,\n        \"max_tokens\": 1024,\n    },\n    \"json_extraction\": {\n        \"temperature\": 0.0,\n        \"frequency_penalty\": 0.0,\n        \"presence_penalty\": 0.0,\n        \"max_tokens\": 512,\n        \"response_format\": {\"type\": \"json_object\"},\n    },\n    \"code_generation\": {\n        \"temperature\": 0.2,\n        \"frequency_penalty\": 0.2,\n        \"presence_penalty\": 0.0,\n        \"max_tokens\": 2048,\n    },\n}\n\nasync def generate_with_profile(messages: list[dict], profile: str) -> str | None:\n    params = PROFILES.get(profile, PROFILES[\"factual_qa\"])\n    resp = await client.chat.completions.create(\n        model=\"gpt-4o\",\n        messages=messages,\n        **params,\n    )\n    result = validate_output(resp)\n    return result.text if result.ok else None"
          }
