arning signal too large → unstable updates"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Slow Convergence"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Weights too small/symmetric"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Network learns extremely slowly"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why These Pitfalls Happen"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Symmetry Breaking Failure"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Concept"},{"type":"text","text":": Neurons need to start differently to learn different features."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem"},{"type":"text","text":": Zero/constant initialization → all neurons identical → identical updates → never diversify."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Solution"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"bold"}],"text":"Random initialization"},{"type":"text","text":" breaks symmetry."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Scale Mismatch"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Concept"},{"type":"text","text":": Weights need to be scaled to match the number of inputs."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem"},{"type":"text","text":": - Small weights: signal diminishes through layers\n- Large weights: signal explodes through layers"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Solution"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"bold"}],"text":"Scaled initialization"},{"type":"text","text":" (Xavier/He)."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Activation Function Ignorance"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Concept"},{"type":"text","text":": Different activations need different scales."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem"},{"type":"text","text":": Using Xavier (for sigmoid/tanh) with ReLU → vanishing variance."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Solution"},{"type":"text","text":": Match initialization to activation:\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Sigmoid/tanh"},{"type":"text","text":" → "},{"type":"text","marks":[{"type":"bold"}],"text":"Xavier"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"ReLU"},{"type":"text","text":" → "},{"type":"text","marks":[{"type":"bold"}],"text":"He"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How to Avoid These Pitfalls"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"✅ Best Practices"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Practice"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Why"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use Xavier initialization"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scaled random for sigmoid/tanh"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use He initialization"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scaled random for ReLU"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Never initialize to zero"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Symmetry never breaks"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Never initialize to constant"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Same as zero"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Avoid small random (×0.01)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Vanishing gradients"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Avoid large random (×10)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Exploding gradients"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Match init to activation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Xavier for sigmoid/tanh, He for ReLU"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"✅ Correct Code Examples"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# GOOD - He initialization for ReLU\nimport torch.nn.init as init\ninit.kaiming_normal_(layer.weight)  # PyTorch\n\n# GOOD - Xavier initialization for tanh\ninit.xavier_normal_(layer.weight)  # PyTorch\n\n# GOOD - TensorFlow/Keras\nfrom tensorflow.keras.initializers import HeNormal(), GlorotUniform()\nlayer = tf.keras.layers.Dense(128, kernel_initializer=HeNormal(), activation='relu')"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Zero initialization"},{"type":"text","text":" → network becomes linear model, "},{"type":"text","marks":[{"type":"bold"}],"text":"no learning"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Constant initialization"},{"type":"text","text":" → same problem as zero, "},{"type":"text","marks":[{"type":"bold"}],"text":"no diversity"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Small random"},{"type":"text","text":" → "},{"type":"text","marks":[{"type":"bold"}],"text":"vanishing gradients"},{"type":"text","text":", slow learning.md)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Large random"},{"type":"text","text":" → "},{"type":"text","marks":[{"type":"bold"}],"text":"exploding gradients"},{"type":"text","text":", unstable/divergent"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"All pitfalls"},{"type":"text","text":" stem from: symmetry failure, scale mismatch, activation mismatch"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Solution"},{"type":"text","text":": Use "},{"type":"text","marks":[{"type":"bold"}],"text":"scaled random initialization"},{"type":"text","text":" (Xavier/He) matched to activation function"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Proper initialization is critical"},{"type":"text","text":" for deep learning stability — poor initialization makes networks un-trainable from iteration 1"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"The deep learning community considers zero/constant initialization "},{"type":"text","marks":[{"type":"bold"}],"text":"poor practice"},{"type":"text","text":" — it's a fundamental mistake that breaks training entirely."}]}]}}
