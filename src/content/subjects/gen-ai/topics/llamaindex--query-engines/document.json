          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "All LlamaIndex query engines inherit from "
          },
          {
            "type": "text",
            "text": "CustomQueryEngine",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". Subclass it when you need logic that the built-in engines do not support \u2014 custom prompts, hybrid retrieval, external API calls, or unconventional synthesis."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from llama_index.core.query_engine import CustomQueryEngine\nfrom llama_index.core.retrievers import BaseRetriever\nfrom llama_index.core import Response\nfrom llama_index.llms.openai import OpenAI\n\nclass HybridQueryEngine(CustomQueryEngine):\n    \"\"\"Retrieve from two indexes, merge, then synthesise.\"\"\"\n    retriever_a: BaseRetriever\n    retriever_b: BaseRetriever\n    llm: OpenAI\n\n    def custom_query(self, query_str: str) -> Response:\n        nodes_a = self.retriever_a.retrieve(query_str)\n        nodes_b = self.retriever_b.retrieve(query_str)\n\n        # Merge by score, deduplicate\n        seen = set()\n        merged = []\n        for n in sorted(nodes_a + nodes_b, key=lambda x: x.score, reverse=True):\n            if n.node.node_id not in seen:\n                seen.add(n.node.node_id)\n                merged.append(n)\n\n        context = \"\\n\\n\".join(n.node.text for n in merged[:6])\n        answer = self.llm.complete(\n            f\"Context:\\n{context}\\n\\nQuestion: {query_str}\\nAnswer:\"\n        ).text\n\n        return Response(response=answer, source_nodes=merged[:6])\n\nengine = HybridQueryEngine(\n    retriever_a=index_a.as_retriever(similarity_top_k=5),\n    retriever_b=index_b.as_retriever(similarity_top_k=5),\n    llm=OpenAI(model=\"gpt-4o-mini\"),\n)\nresponse = engine.query(\"Compare approaches across both knowledge bases.\")"
          }
        ]
