      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from llama_index.core import VectorStoreIndex, Settings\n\n# tree_summarize: best for \"summarise this entire corpus\" questions\nengine = index.as_query_engine(response_mode=\"tree_summarize\")\nresponse = engine.query(\"What are all the risks mentioned in these reports?\")\n\n# refine: best when first few nodes are not enough and later nodes add context\nengine2 = index.as_query_engine(response_mode=\"refine\", verbose=True)\nresponse2 = engine2.query(\"Explain the CEO's strategy.\")"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "RetrieverQueryEngine \u2014 Full Control"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": ""
          },
          {
            "type": "text",
            "text": "index.as_query_engine()",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " is a convenience wrapper. For full control, construct a "
          },
          {
            "type": "text",
            "text": "RetrieverQueryEngine",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " directly, plugging in custom retrievers, response synthesisers, and post-processors."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from llama_index.core.query_engine import RetrieverQueryEngine\nfrom llama_index.core.response_synthesizers import get_response_synthesizer\nfrom llama_index.core.postprocessor import SimilarityPostprocessor\n\nretriever = index.as_retriever(similarity_top_k=8)\n\n# Post-processor: drop nodes with cosine similarity below 0.7\nfilter_pp = SimilarityPostprocessor(similarity_cutoff=0.7)\n\nsynthesizer = get_response_synthesizer(\n    response_mode=\"tree_summarize\",\n    use_async=True,\n)\n\nquery_engine = RetrieverQueryEngine(\n    retriever=retriever,\n    response_synthesizer=synthesizer,\n    node_postprocessors=[filter_pp],\n)\n\nresponse = await query_engine.aquery(\"What were the main findings?\")\nprint(response)\nprint(f\"Used {len(response.source_nodes)} source nodes\")"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Node Post-Processors"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Post-processors run after retrieval, before synthesis. They filter, re-rank, or augment the retrieved nodes. Multiple post-processors can be chained."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Similarity Cutoff"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from llama_index.core.postprocessor import SimilarityPostprocessor\n\n# Drop any node with similarity < 0.65\npp = SimilarityPostprocessor(similarity_cutoff=0.65)\nengine = index.as_query_engine(node_postprocessors=[pp])"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Keyword Filter"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from llama_index.core.postprocessor import KeywordNodePostprocessor\n\n# Keep nodes that contain at least one required keyword\npp = KeywordNodePostprocessor(\n    required_keywords=[\"revenue\", \"profit\"],\n    exclude_keywords=[\"draft\", \"confidential\"],\n)\nengine = index.as_query_engine(node_postprocessors=[pp])"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Cohere Re-Ranker"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# pip install llama-index-postprocessor-cohere-rerank cohere\nfrom llama_index.postprocessor.cohere_rerank import CohereRerank\n\nreranker = CohereRerank(api_key=\"your-key\", top_n=3)\n\n# Retrieve broad (top_k=10), rerank to 3\nengine = index.as_query_engine(\n    similarity_top_k=10,\n    node_postprocessors=[reranker],\n)\nresponse = engine.query(\"Which product line had the highest margin?\")"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Sentence Transformer Re-Ranker (Local)"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# pip install llama-index-postprocessor-sentence-transformer-rerank\nfrom llama_index.postprocessor.sentence_transformer_rerank import SentenceTransformerRerank\n\nreranker = SentenceTransformerRerank(\n    model=\"cross-encoder/ms-marco-MiniLM-L-2-v2\",\n    top_n=5,\n)\nengine = index.as_query_engine(\n    similarity_top_k=15,\n    node_postprocessors=[reranker],\n)"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "SubQuestionQueryEngine \u2014 Multi-Source Decomposition"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For questions that span multiple documents or indexes, "
          },
          {
            "type": "text",
            "text": "SubQuestionQueryEngine",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " uses an LLM to decompose the original question into sub-questions, routes each to the right engine, then synthesises all sub-answers into a final response."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# pip install llama-index-core\nfrom llama_index.core.query_engine import SubQuestionQueryEngine\nfrom llama_index.core.tools import QueryEngineTool\n\n# Create engines per data source\nq1_engine = q1_index.as_query_engine()\nq2_engine = q2_index.as_query_engine()\nq3_engine = q3_index.as_query_engine()\n\ntools = [\n    QueryEngineTool.from_defaults(\n        query_engine=q1_engine,\n        name=\"q1_earnings\",\n        description=\"Q1 2024 earnings report with revenue, margins, and guidance.\",\n    ),\n    QueryEngineTool.from_defaults(\n        query_engine=q2_engine,\n        name=\"q2_earnings\",\n        description=\"Q2 2024 earnings report with revenue, margins, and guidance.\",\n    ),\n    QueryEngineTool.from_defaults(\n        query_engine=q3_engine,\n        name=\"q3_earnings\",\n        description=\"Q3 2024 earnings report with revenue, margins, and guidance.\",\n    ),\n]\n\nsub_q_engine = SubQuestionQueryEngine.from_defaults(\n    query_engine_tools=tools,\n    verbose=True,   # shows each sub-question and sub-answer\n)\n\n# The LLM decomposes this into: \"Q1 revenue?\", \"Q2 revenue?\", \"Q3 revenue?\"\n# Routes each to the right engine, then compares in the final synthesis\nresponse = sub_q_engine.query(\n    \"Compare revenue across Q1, Q2, and Q3. Which quarter showed the most growth?\"\n)\nprint(response)"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Citation Query Engine"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": ""
          },
          {
            "type": "text",
            "text": "CitationQueryEngine",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " modifies the standard RAG prompt to instruct the LLM to include inline source citations in its answer (e.g. [1], [2]). Sources are mapped back to the original document metadata."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# pip install llama-index-core\nfrom llama_index.core.query_engine import CitationQueryEngine\n\nengine = CitationQueryEngine.from_args(\n    index,\n    similarity_top_k=5,\n    citation_chunk_size=512,    # size of citation text snippets\n)\n\nresponse = engine.query(\"What drove the margin expansion in Q3?\")\nprint(response.response)   # contains [1], [2] inline citations\n\n# Inspect sources\nfor i, source in enumerate(response.source_nodes, 1):\n    print(f\"[{i}] {source.node.metadata.get('source', 'unknown')}\")\n    print(f\"    {source.node.text[:120]}\")"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Streaming Responses"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For user-facing interfaces, stream the generated answer token by token rather than waiting for the full response. Both synchronous and async streaming are supported."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from llama_index.core import VectorStoreIndex\n\nengine = index.as_query_engine(streaming=True)\nstreaming_response = engine.query(\"Explain the product strategy.\")\n\n# Stream tokens as they arrive\nstreaming_response.print_response_stream()\n\n# Or collect into a string\nfull_text = \"\"\nfor token in streaming_response.response_gen:\n    full_text += token\n    print(token, end=\"\", flush=True)"
