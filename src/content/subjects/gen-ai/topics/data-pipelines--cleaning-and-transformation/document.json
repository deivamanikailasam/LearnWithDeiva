{"format":"tiptap/v1","updatedAt":"2026-06-22T04:39:33.036Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cleaning and transformation"},{"type":"text","text":" are the two core steps in a data pipeline that prepare raw data for ML models: "},{"type":"text","marks":[{"type":"bold"}],"text":"cleaning"},{"type":"text","text":" removes or corrects errors, inconsistencies, and missing values, while "},{"type":"text","marks":[{"type":"bold"}],"text":"transformation"},{"type":"text","text":" converts data into the right format, structure, and scale for modeling."}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key insight:"},{"type":"text","text":" “Data scientists spend a large amount of their time cleaning datasets... the 80/20 rule says that obtaining and cleaning data account for "},{"type":"text","marks":[{"type":"bold"}],"text":"80% of the time"},{"type":"text","text":" spent on any given project.”"}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What cleaning and transformation mean"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Data Cleaning"}]},{"type":"paragraph","content":[{"type":"text","text":"Removing or correcting:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Errors"},{"type":"text","text":": typos, wrong values, invalid entries"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Inconsistencies"},{"type":"text","text":": different formats for the same concept (e.g., "},{"type":"text","marks":[{"type":"code"}],"text":"USA"},{"type":"text","text":" vs "},{"type":"text","marks":[{"type":"code"}],"text":"U.S.A."},{"type":"text","text":")"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Missing values"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"NaN"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"NULL"},{"type":"text","text":", empty strings, custom markers like "},{"type":"text","marks":[{"type":"code"}],"text":"\"---\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Duplicates"},{"type":"text","text":": repeated rows that skew analysis"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Outliers"},{"type":"text","text":": extreme values that may bias models"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Data Transformation"}]},{"type":"paragraph","content":[{"type":"text","text":"Converting data from one format or structure to another:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Type conversion"},{"type":"text","text":": strings → numbers, dates → timestamps"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Feature scaling"},{"type":"text","text":": normalization, standardization"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Encoding"},{"type":"text","text":": categorical → numerical (e.g., "},{"type":"text","marks":[{"type":"code"}],"text":"\"red\""},{"type":"text","text":" → "},{"type":"text","marks":[{"type":"code"}],"text":"0"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"\"blue\""},{"type":"text","text":" → "},{"type":"text","marks":[{"type":"code"}],"text":"1"},{"type":"text","text":")"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Binning"},{"type":"text","text":": continuous → discrete ranges (e.g., age 20–30, 30–40)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Aggregation"},{"type":"text","text":": combining multiple rows into summaries (grouping, averaging)"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common cleaning operations with pandas"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Drop duplicates"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import pandas as pd\n\ndata = pd.read_csv(\"data.csv\")\n\n# Drop duplicate rows\ndata = data.drop_duplicates()\n\n# Drop duplicates based on specific column(s)\ndata = data.drop_duplicates(subset=[\"id\"])"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Handle missing values"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Option 1: Drop rows with missing values\ndata = data.dropna(subset=[\"value\"])  # Drop if \"value\" is NaN\n\n# Option 2: Fill missing values with a constant\ndata = data.fillna(value=0)\n\n# Option 3: Fill with statistical values\ndata[\"value\"] = data[\"value\"].fillna(data[\"value\"].mean())\ndata[\"value\"] = data[\"value\"].fillna(data[\"value\"].median())\n\n# Option 4: Use pandas na_values when loading\ndata = pd.read_csv(\"data.csv\", na_values=[\"---\", \"NULL\"])"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Convert data types"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Force column to float64\ndata[\"value\"] = data[\"value\"].astype(np.float64)\n\n# Convert categorical to numeric codes\ndata[\"category\"] = pd.Categorical(data[\"category\"]).codes\n\n# Convert string dates to datetime\ndata[\"date\"] = pd.to_datetime(data[\"date\"])"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Drop unnecessary columns"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Drop one column\ndata = data.drop(columns=[\"unnecessary_column\"])\n\n# Drop multiple columns\ndata = data.drop(columns=[\"col1\", \"col2\", \"col3\"])"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Renaming columns"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Rename specific columns\ndata = data.rename(columns={\n    \"old_name\": \"new_name\",\n    \"old_col\": \"new_col\"\n})"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common transformation operations with pandas & NumPy"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Feature scaling (normalization/standardization)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Standardization (z-score normalization)"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import numpy as np\n\n# Standardize a column\ndata[\"value_std\"] = (data[\"value\"] - data[\"value\"].mean()) / data[\"value\"].std()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Min-Max normalization"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"data[\"value_norm\"] = (data[\"value\"] - data[\"value\"].min()) / (data[\"value\"].max() - data[\"value\"].min())"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Categorical encoding"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# One-hot encoding\nencoded = pd.get_dummies(data, columns=[\"category\"])\n\n# Integer encoding (categories to codes)\ndata[\"category_code\"] = pd.Categorical(data[\"category\"]).codes"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Binning continuous data"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Create bins for age\ndata[\"age_bin\"] = pd.cut(data[\"age\"], bins=[0, 20, 40, 60, 100], labels=[\"child\", \"young\", \"middle\", \"senior\"])\n\n# Or use quantile-based binning\ndata[\"age_quantile\"] = pd.qcut(data[\"age\"], q=4, labels=[\"Q1\", \"Q2\", \"Q3\", \"Q4\"])"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"String manipulation"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Clean columns with .str methods\ndata[\"email_clean\"] = data[\"email\"].str.lower().str.strip()\n\n# Replace patterns\ndata[\"phone\"] = data[\"phone\"].str.replace(r\"\\D\", \"\", regex=True)  # Remove non-digits"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Aggregation (grouping)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Group by category and calculate mean\ngrouped = data.groupby(\"category\")[\"value\"].mean()\n\n# Group by and count unique values\ngrouped_count = data.groupby(\"category\").size()\n\n# Multiple aggregations\ngrouped_agg = data.groupby(\"category\")[\"value\"].agg([\"mean\", \"median\", \"std\"])"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Building a reusable data cleaning pipeline"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Approach 1: "},{"type":"text","marks":[{"type":"bold"}],"text":"Pandas "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":".pipe()"},{"type":"text","text":" (clean, modular)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import pandas as pd\n\ndata = {\n    \"id\": [1, 2, 2, 3, 4, 4, 7],\n    \"old_name\": [\"Karan\", \"Deepak\", \"Deepak\", \"Rahul\", \"Sachin\", \"Sachin\", \"Vikas\"],\n    \"Column\": [10, 20, 20, 30, 40, 40, 70]\n}\ndf = pd.DataFrame(data)\n\ndef clean_names(df):\n    return df.rename(columns={\"old_name\": \"new_name\"})\n\ndef drop_duplicates(df):\n    return df.drop_duplicates(subset=[\"id\"])\n\ndef convert_types(df):\n    return df.astype({\"Column\": \"int\"})\n\n# Chain transformations with .pipe()\nprocessed_df = (\n    df.pipe(clean_names)\n      .pipe(drop_duplicates)\n      .pipe(convert_types)\n)\n\nprint(processed_df)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits"},{"type":"text","text":":\n- Clean and modular\n- Production-ready\n- Easy to test each function independently"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Approach 2: "},{"type":"text","marks":[{"type":"bold"}],"text":"scikit-learn "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"Pipeline"},{"type":"text","text":" (reusable, standardized)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from sklearn.pipeline import Pipeline\nfrom sklearn.impute import SimpleImputer\nfrom sklearn.preprocessing import StandardScaler\nimport pandas as pd\n\n# Define pipeline\npipeline = Pipeline([\n    (\"imputer\", SimpleImputer(strategy=\"median\")),  # Fill missing with median\n    (\"scaler\", StandardScaler())                     # Standardize features\n])\n\n# Load data\ndata = pd.read_csv(\"your_dataset.csv\")\n\n# Apply pipeline\npreprocessed_data = pipeline.fit_transform(data)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits"},{"type":"text","text":":\n- Ensures "},{"type":"text","marks":[{"type":"bold"}],"text":"consistency"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"bold"}],"text":"reproducibility"},{"type":"text","text":"\n- Applies the same steps to train and test data\n- Prevents data leakage (fit on train, transform on test)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Performance best practices"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Use vectorized operations"},{"type":"text","text":" (NumPy)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"❌ Slow way (iteration)"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"def calculate_grade(row):\n    if row['score'] > 90:\n        return 'A'\n    elif row['score'] > 80:\n        return 'B'\n    elif row['score'] > 70:\n        return 'C'\n    else:\n        return 'F'\n\ndf['grade'] = df.apply(calculate_grade, axis=1)  # Slow"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"✅ Fast way (vectorization with "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"np.where"},{"type":"text","marks":[{"type":"bold"}],"text":")"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import numpy as np\n\ndf['grade'] = np.where(\n    df['score'] > 90, 'A',\n    np.where(df['score'] > 80, 'B',\n    np.where(df['score'] > 70, 'C', 'F'))\n)  # Fast"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why"},{"type":"text","text":": Vectorized operations apply to entire arrays at once, running in seconds even on millions of rows."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Avoid unnecessary operations"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Don't create intermediate DataFrames unless needed"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use "},{"type":"text","marks":[{"type":"code"}],"text":".loc"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"code"}],"text":".iloc"},{"type":"text","text":" for efficient indexing"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Handle large files in chunks"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Read large CSV in chunks\nchunks = pd.read_csv(\"large_file.csv\", chunksize=10000)\n\nfor chunk in chunks:\n    # Process chunk\n    cleaned = chunk.drop_duplicates().fillna(0)\n    # ..."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common cleaning and transformation pitfalls"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"❌ "},{"type":"text","marks":[{"type":"bold"}],"text":"Dropping all missing values blindly"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem"},{"type":"text","text":": May lose important data"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fix"},{"type":"text","text":": Impute missing values (mean, median, mode) or use model-based imputation"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"❌ "},{"type":"text","marks":[{"type":"bold"}],"text":"Not standardizing scaling"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem"},{"type":"text","text":": Features with different scales bias models (e.g., age 0–100 vs salary 0–1000000)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fix"},{"type":"text","text":": Use "},{"type":"text","marks":[{"type":"code"}],"text":"StandardScaler"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"code"}],"text":"MinMaxScaler"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"❌ "},{"type":"text","marks":[{"type":"bold"}],"text":"Using iteration instead of vectorization"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem"},{"type":"text","text":": Slow on large datasets"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fix"},{"type":"text","text":": Use "},{"type":"text","marks":[{"type":"code"}],"text":"np.where"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"np.piecewise"},{"type":"text","text":", or pandas vectorized methods"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"❌ "},{"type":"text","marks":[{"type":"bold"}],"text":"Not checking data types"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem"},{"type":"text","text":": Strings used as numbers, dates as strings"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fix"},{"type":"text","text":": Explicitly convert types with "},{"type":"text","marks":[{"type":"code"}],"text":".astype()"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"code"}],"text":"pd.to_datetime()"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Data cleaning"},{"type":"text","text":" removes errors, inconsistencies, missing values, duplicates, and outliers; "},{"type":"text","marks":[{"type":"bold"}],"text":"transformation"},{"type":"text","text":" converts data to the right format, scale, and structure for ML."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cleaning and transformation"},{"type":"text","text":" account for "},{"type":"text","marks":[{"type":"bold"}],"text":"80% of time"},{"type":"text","text":" in ML projects."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Common cleaning ops: "},{"type":"text","marks":[{"type":"code"}],"text":"drop_duplicates()"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"dropna()"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"fillna()"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"astype()"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"rename()"},{"type":"text","text":"."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Common transformation ops: scaling ("},{"type":"text","marks":[{"type":"code"}],"text":"StandardScaler"},{"type":"text","text":", min-max), encoding ("},{"type":"text","marks":[{"type":"code"}],"text":"get_dummies"},{"type":"text","text":", categorical codes), binning ("},{"type":"text","marks":[{"type":"code"}],"text":"pd.cut"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"pd.qcut"},{"type":"text","text":"), aggregation ("},{"type":"text","marks":[{"type":"code"}],"text":"groupby"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"agg"},{"type":"text","text":")."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use "},{"type":"text","marks":[{"type":"bold"}],"text":"pandas "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":".pipe()"},{"type":"text","text":" for clean, modular pipelines; use "},{"type":"text","marks":[{"type":"bold"}],"text":"scikit-learn "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"Pipeline"},{"type":"text","text":" for reusable, standardized preprocessing."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Always use "},{"type":"text","marks":[{"type":"bold"}],"text":"vectorized operations"},{"type":"text","text":" (NumPy "},{"type":"text","marks":[{"type":"code"}],"text":"np.where"},{"type":"text","text":") instead of iteration for speed on large datasets."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Follow best practices: avoid unnecessary operations, handle large files in chunks, check data types, and impute missing values appropriately."}]}]}]},{"type":"paragraph"}]}}
