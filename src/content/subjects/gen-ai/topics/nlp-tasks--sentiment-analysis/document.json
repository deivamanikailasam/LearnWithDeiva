        "content": [
          {
            "type": "text",
            "text": "Evaluation Metrics"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Binary classification"
                  },
                  {
                    "type": "text",
                    "text": ": accuracy and binary F1. Use F1 when the dataset is class-imbalanced."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Multiclass (3 or 5 classes)"
                  },
                  {
                    "type": "text",
                    "text": ": macro-F1 (treats all classes equally) or weighted-F1 (weights by support). Accuracy can be misleading when neutral examples dominate."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Ordinal (star ratings)"
                  },
                  {
                    "type": "text",
                    "text": ": mean absolute error (MAE) in addition to accuracy, because predicting 1-star when the truth is 5-star is worse than predicting 4-star."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "ABSA"
                  },
                  {
                    "type": "text",
                    "text": ": micro-F1 over (aspect, sentiment) pairs."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Neutral class imbalance"
                  },
                  {
                    "type": "text",
                    "text": ": in many real datasets, 50–70 % of sentences are neutral. A model that never predicts neutral can still reach 80 % accuracy — always check per-class F1."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
