                      }
                    ],
                    "text": "Label ambiguity"
                  },
                  {
                    "type": "text",
                    "text": ": \"The story is long\" is factual and sentiment-neutral, but humans annotate it differently depending on context. Inter-annotator agreement (Cohen's κ) should be reported for custom datasets."
                  }
                ]
              }
