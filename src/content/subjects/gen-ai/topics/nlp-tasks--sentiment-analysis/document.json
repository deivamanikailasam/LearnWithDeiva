                        "type": "bold"
                      }
                    ],
                    "text": "Domain mismatch"
                  },
                  {
                    "type": "text",
                    "text": ": \"unpredictable\" is negative in a product review, positive in a movie thriller review. A model trained on one domain often transfers poorly to another."
                  }
                ]
              }
            ]
          },
