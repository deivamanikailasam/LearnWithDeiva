            "type": "text",
            "text": "GitHub Actions Integration"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Wire the eval gate as a required CI check on every PR targeting main. The nightly run uses the larger "
          },
          {
            "type": "text",
            "text": "test",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " split and uploads results as artifacts:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "yaml"
        },
        "content": [
          {
            "type": "text",
            "text": "name: Eval Gate\non:\n  pull_request:\n    branches: [main]\n  schedule:\n    - cron: '0 2 * * *'   # nightly full suite\n\njobs:\n  eval:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n\n      - name: Install dependencies\n        run: pip install openai asyncio\n\n      - name: Download eval cases\n        run: |\n          python scripts/download_eval_cases.py \\\n            --version ${{ github.sha }} \\\n            --split dev \\\n            --output eval_cases.json\n\n      - name: Run eval suite\n        env:\n          OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}\n          MODEL_ID: ${{ vars.CANDIDATE_MODEL_ID }}\n        run: |\n          python scripts/run_eval.py \\\n            --cases eval_cases.json \\\n            --model $MODEL_ID \\\n            --output eval_results.json\n\n      - name: Check gate\n        run: python scripts/check_eval_gate.py\n\n      - name: Upload results\n        uses: actions/upload-artifact@v4\n        with:\n          name: eval-results\n          path: eval_results.json"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
