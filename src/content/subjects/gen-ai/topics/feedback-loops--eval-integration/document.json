      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Eval Runner"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The eval runner sends each input prompt to the candidate model, then passes the response through an LLM-as-judge scorer against the rubric or golden response. Run cases concurrently to keep the eval suite under 10 minutes for the dev split:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import openai, json, asyncio\nfrom dataclasses import dataclass\n\nJUDGE_PROMPT = (\n    \"You are an expert evaluator for an AI assistant.\\n\"\n    \"Evaluate the following response against the provided rubric.\\n\\n\"\n    \"Input prompt:\\n{input_prompt}\\n\\n\"\n    \"Model response:\\n{model_response}\\n\\n\"\n    \"Golden response (if available):\\n{golden_response}\\n\\n\"\n    \"Rubric criteria:\\n{criteria}\\n\\n\"\n    \"Score from 0.0 to 1.0 and explain. JSON: {{\\\"score\\\": 0.0, \\\"pass\\\": true, \\\"rationale\\\": \\\"...\\\"}}\"\n)\n\nasync def run_eval_case(case: dict, model_id: str, client: openai.AsyncOpenAI) -> dict:\n    # 1. Get model response\n    response = await client.chat.completions.create(\n        model=model_id,\n        messages=[{\"role\": \"user\", \"content\": case[\"input_prompt\"]}],\n        max_tokens=1024,\n    )\n    model_response = response.choices[0].message.content\n\n    # 2. Judge it\n    criteria_text = \"\\n\".join(f\"- {c}\" for c in case[\"rubric\"][\"criteria\"])\n    judge_resp = await client.chat.completions.create(\n        model=\"gpt-4o\",\n        messages=[{\"role\": \"user\", \"content\": JUDGE_PROMPT.format(\n            input_prompt=case[\"input_prompt\"],\n            model_response=model_response,\n            golden_response=case.get(\"golden_response\") or \"(none provided)\",\n            criteria=criteria_text,\n        )}],\n        response_format={\"type\": \"json_object\"},\n        max_tokens=256,\n    )\n    result = json.loads(judge_resp.choices[0].message.content)\n    result[\"response_text\"] = model_response\n    result[\"case_id\"] = case[\"id\"]\n    return result\n\nasync def run_eval_suite(cases: list[dict], model_id: str) -> list[dict]:\n    client = openai.AsyncOpenAI()\n    # Run up to 20 cases concurrently to stay within rate limits\n    sem = asyncio.Semaphore(20)\n    async def bounded(case):\n        async with sem:\n            return await run_eval_case(case, model_id, client)\n    return await asyncio.gather(*[bounded(c) for c in cases])"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Use a stronger judge model ("
          },
          {
            "type": "text",
            "text": "gpt-4o",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
