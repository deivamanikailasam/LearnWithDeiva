"type":"text","text":": Visualize feature correlations, importance"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Model evaluation"},{"type":"text","text":": Plot confusion matrices, ROC curves, residual plots"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Communicate insights"},{"type":"text","text":": Create publication-ready figures with minimal code"}]}]}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"“Data visualization helps to tell stories by curating data into a form easier to understand, highlighting the trends and outliers.”"}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Installation"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"pip install seaborn"}]},{"type":"paragraph","content":[{"type":"text","text":"Import alongside Matplotlib and pandas:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import matplotlib.pyplot as plt\nimport seaborn as sns\nimport pandas as pd"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common plot types with Seaborn"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Scatter Plot"},{"type":"text","text":" (bivariate relationships)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import seaborn as sns\nimport pandas as pd\n\ndf = pd.read_csv('data.csv')\n\n# Basic scatter plot\nsns.scatterplot(x='feature1', y='feature2', data=df)\n\n# With hue (color by category)\nsns.scatterplot(x='feature1', y='feature2', hue='category', data=df)\n\nplt.show()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use case"},{"type":"text","text":": See correlations between features, cluster visualization."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Line Plot"},{"type":"text","text":" (trends over time)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"sns.lineplot(x='time', y='value', data=df)\nplt.show()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use case"},{"type":"text","text":": Visualize training loss/accuracy over epochs."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Bar Plot"},{"type":"text","text":" (categorical vs numerical)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"sns.barplot(x='category', y='value', data=df)\n\n# Sort bars\nsns.barplot(x='category', y='value', data=df, order=['A', 'B', 'C'])\n\nplt.show()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use case"},{"type":"text","text":": Compare class counts, feature importance."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Histogram"},{"type":"text","text":" (distribution)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"sns.histplot(df['feature'])\nplt.show()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use case"},{"type":"text","text":": Visualize feature distributions, check normality."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Box Plot"},{"type":"text","text":" (summary statistics)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"sns.boxplot(x='category', y='value', data=df)\nplt.show()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use case"},{"type":"text","text":": See median, quartiles, outliers by category."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Violin Plot"},{"type":"text","text":" (distribution + statistics)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"sns.violinplot(x='category', y='value', data=df)\nplt.show()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use case"},{"type":"text","text":": More detailed than box plot (shows distribution shape)."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"7. "},{"type":"text","marks":[{"type":"bold"}],"text":"Heatmap"},{"type":"text","text":" (correlation matrix)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"corr = df.corr()\nsns.heatmap(corr, annot=True, cmap='coolwarm')\nplt.show()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use case"},{"type":"text","text":": See feature correlations, identify multicollinearity."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"8. "},{"type":"text","marks":[{"type":"bold"}],"text":"Count Plot"},{"type":"text","text":" (categorical frequencies)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"sns.countplot(x='category', data=df)\nplt.show()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use case"},{"type":"text","text":": Show class distribution, category counts."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"9. "},{"type":"text","marks":[{"type":"bold"}],"text":"Pair Plot"},{"type":"text","text":" (multivariate relationships)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"sns.pairplot(df)\nplt.show()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use case"},{"type":"text","text":": Quick overview of all pairwise relationships."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"10. "},{"type":"text","marks":[{"type":"bold"}],"text":"Cat Plot"},{"type":"text","text":" (categorical + numerical)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Point plot with error bars\nsns.catplot(x='category', y='value', data=df, kind='point')\n\n# Strip plot\nsns.catplot(x='category', y='value', data=df, kind='strip')\n\n# Swarm plot\nsns.catplot(x='category', y='value', data=df, kind='swarm')\n\nplt.show()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use case"},{"type":"text","text":": Display numerical values across categories with different visualizations."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Seaborn's high-level API vs. Matplotlib"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Seaborn (simplified)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Single line for complex plot\nsns.scatterplot(x='x', y='y', hue='category', size='size', data=df)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits"},{"type":"text","text":":\n- Handles pandas DataFrames directly\n- Automatic semantic mapping (hue, size, style)\n- Beautiful defaults (colors, styles)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Matplotlib (manual)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Multiple lines for same plot\nimport matplotlib.pyplot as plt\n\ncategories = df['category'].unique()\nfor cat in categories:\n    subset = df[df['category'] == cat]\n    plt.scatter(subset['x'], subset['y'], label=cat)\n\nplt.legend()\nplt.show()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Drawbacks"},{"type":"text","text":":\n- More code\n- Manual loops\n- No automatic color palettes"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Customization with Seaborn"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Set theme"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"sns.set_theme(style='darkgrid')  # or 'whitegrid', 'dark', 'light'\nsns.set_theme(style='darkgrid', palette='deep')"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Color palettes"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Use built-in palettes\nsns.scatterplot(x='x', y='y', hue='category', palette='Set2', data=df)\n\n# Custom colors\nsns.scatterplot(x='x', y='y', hue='category', palette=['red', 'blue', 'green'], data=df)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Figure-level vs. Axes-level functions"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Figure-level"},{"type":"text","text":": Create entire figure (e.g., "},{"type":"text","marks":[{"type":"code"}],"text":"pairplot"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"relplot"},{"type":"text","text":").\n"},{"type":"text","marks":[{"type":"bold"}],"text":"Axes-level"},{"type":"text","text":": Plot on current axes (e.g., "},{"type":"text","marks":[{"type":"code"}],"text":"scatterplot"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"lineplot"},{"type":"text","text":", "},{"type":"text","marks"