{"format":"tiptap/v1","updatedAt":"2026-06-22T10:59:45.894Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What Cell State Is"}]},{"type":"paragraph","content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"bold"}],"text":"cell state"},{"type":"text","text":" in LSTM (Long Short-Term Memory) networks is a "},{"type":"text","marks":[{"type":"bold"}],"text":"memory-like unit"},{"type":"text","text":" that stores information and allows it to be retained over long periods of time. It acts as the "},{"type":"text","marks":[{"type":"bold"}],"text":"long-term memory"},{"type":"text","text":" of the LSTM, distinct from the hidden state which serves as short-term memory."}]},{"type":"paragraph","content":[{"type":"text","text":"Think of it as a "},{"type":"text","marks":[{"type":"bold"}],"text":"conveyor belt"},{"type":"text","text":" that carries relevant information throughout the entire sequence, allowing information from earlier time steps to reach later time steps."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why Cell State Matters in Generative AI"}]},{"type":"paragraph","content":[{"type":"text","text":"The cell state is the key innovation that solves traditional RNNs' main limitation:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Problem"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Solution"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"RNNs forget early information"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Cell state retains information across many time steps"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Vanishing gradients"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Cell state provides stable gradient flow"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"No long-term memory"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Cell state captures long-term dependencies"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"This enables LSTMs to handle tasks like:\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Natural language processing"},{"type":"text","text":": Understand context across entire documents\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Speech recognition"},{"type":"text","text":": Remember phonetic patterns over time\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Time series forecasting"},{"type":"text","text":": Capture patterns from the past"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How Cell State Works (Core Mechanics)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The update formula:"}]},{"type":"paragraph","content":[{"type":"text","text":"At time step "},{"type":"inlineMath","attrs":{"latex":"t"}},{"type":"text","text":", the cell state "},{"type":"inlineMath","attrs":{"latex":"C_t"}},{"type":"text","text":" is updated based on:\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Previous cell state"},{"type":"text","text":": "},{"type":"inlineMath","attrs":{"latex":"C_{t-1}"}},{"type":"text","text":" (long-term memory)\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Current input"},{"type":"text","text":": "},{"type":"inlineMath","attrs":{"latex":"x_t"}},{"type":"text","text":" (new information)\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Previous hidden state"},{"type":"text","text":": "},{"type":"inlineMath","attrs":{"latex":"h_{t-1}"}},{"type":"text","text":" (short-term context)"}]},{"type":"paragraph","content":[{"type":"text","text":"The update happens in "},{"type":"text","marks":[{"type":"bold"}],"text":"3 stages"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Stage 1: FORGET\n  f_t = σ(W_f · [h_{t-1}, x_t] + b_f)\n  C_temp = f_t ⊙ C_{t-1}\n  (Remove irrelevant information from memory)\n\nStage 2: INPUT\n  i_t = σ(W_i · [h_{t-1}, x_t] + b_i)\n  C̃_t = tanh(W_C · [h_{t-1}, x_t] + b_C)\n  (Create candidate values for new information)\n  C_new_part = i_t ⊙ C̃_t\n  (Filter which candidates to store)\n\nStage 3: UPDATE\n  C_t = C_temp + C_new_part\n  (Final cell state = old memory + new information)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Characteristics"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Separate from Hidden State"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"State"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Role"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Lifetime"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cell State ("},{"type":"inlineMath","attrs":{"latex":"C_t"}},{"type":"text","text":")"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Long-term memory"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Persists across time steps"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hidden State ("},{"type":"inlineMath","attrs":{"latex":"h_t"}},{"type":"text","text":")"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Short-term memory"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Output to next step"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"LSTM has "},{"type":"text","marks":[{"type":"bold"}],"text":"two types of memory"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"LTM (Long-Term Memory)"},{"type":"text","text":" = Cell state "},{"type":"inlineMath","attrs":{"latex":"C_t"}},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"STM (Short-Term Memory)"},{"type":"text","text":" = Hidden state "},{"type":"inlineMath","attrs":{"latex":"h_t"}}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Additive Update (Not Multiplicative)"}]},{"type":"paragraph","content":[{"type":"text","text":"Unlike RNNs where information is multiplied (causing vanishing gradients), cell state updates are "},{"type":"text","marks":[{"type":"bold"}],"text":"additive"},{"type":"text","text":":"}]},{"type":"blockMath","attrs":{"latex":"C_t = C_{t-1} \\odot f_t + \\tilde{C}_t \\odot i_t"}},{"type":"paragraph","content":[{"type":"text","text":"This allows gradients to flow "},{"type":"text","marks":[{"type":"bold"}],"text":"without significant attenuation"},{"type":"text","text":", solving the vanishing gradient problem."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Uses tanh Activation"}]},{"type":"paragraph","content":[{"type":"text","text":"The candidate cell state uses "},{"type":"text","marks":[{"type":"bold"}],"text":"tanh"},{"type":"text","text":" (outputs −1 to +1):"}]},{"type":"blockMath","attrs":{"latex":"\\tilde{C}_t = \\tanh(W_C \\cdot [h_{t-1}, x_t] + b_C)"}},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why tanh?"},{"type":"text","text":"\n- Allows cell state to have values in range (−1, 1)\n- Helps improve stability and performance\n- Similar range to inputs"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Stable Memory Unit"}]},{"type":"paragraph","content":[{"type":"text","text":"The cell state acts as a "},{"type":"text","marks":[{"type":"bold"}],"text":"stable memory unit"},{"type":"text","text":" that allows gradients to flow through the network without being significantly attenuated or amplified. This makes LSTMs more robust and easier to train than traditional RNNs."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Cell State Visualization"}]},{"type":"codeBlock","attrs":{"language":"sql"},"content":[{"type":"text","text":"Conveyor Belt Analogy:\n════════════════════════════════════════\n  C₀ → C₁ → C₂ → C₃ → ... → Cₙ\n  │    │    │    │          │\n  ▼    ▼    ▼    ▼          ▼\n update update update      update\n════════════════════════════════════════\n\nThe cell state flows straight down the sequence,\nwith only minor linear interactions at each step.\nInformation from time step 1 can reach time step n."}]},{"type":"paragraph","content":[{"type":"text","text":"The cell state can be seen as a "},{"type":"text","marks":[{"type":"bold"}],"text":"summary of what the model has seen/learnt"},{"type":"text","text":" up to time "},{"type":"inlineMath","attrs":{"latex":"t"}},{"type":"text","text":"."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Benefits of Cell State"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Benefit"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Explanation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Long-term memory"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Captures and retains dependencies across many time steps"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Stable gradients"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Solves vanishing/exploding gradient problem"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Selective retention"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Gates control what to store, forget, or reveal"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Information flow"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Allows early information to reach later steps"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Complex pattern modeling"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Can model complex sequential patterns in text, speech, time series"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Trade-offs & Limitations"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Limitation"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Explanation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"More parameters"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"LSTM has ~4× more parameters than RNN (due to cell state + 3 gates)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Computationally expensive"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"More complex calculations than simple RNN"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Still sequential"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Cannot fully parallelize training (unlike Transformers)"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"LSTM vs. GRU Cell State"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Architecture"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Cell State"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"LSTM"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Has separate cell state "},{"type":"inlineMath","attrs":{"latex":"C_t"}},{"type":"text","text":" + hidden state "},{"type":"inlineMath","attrs":{"latex":"h_t"}}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"GRU"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No separate cell state; uses only hidden state"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"GRU is simpler because it doesn't have the separate long-term memory component that LSTM has."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of the cell state as a "},{"type":"text","marks":[{"type":"bold"}],"text":"notebook for a long story"},{"type":"text","text":":"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"You write notes as you read each sentence"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"The notebook (cell state) contains "},{"type":"text","marks":[{"type":"bold"}],"text":"all important information"},{"type":"text","text":" from the entire story"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"At each step, you:"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- "},{"type":"text","marks":[{"type":"bold"}],"text":"Forget"},{"type":"text","text":" irrelevant details (erase bad notes) → Forget gate - "},{"type":"text","marks":[{"type":"bold"}],"text":"Add"},{"type":"text","text":" new important information (write new notes) → Input gate - "},{"type":"text","marks":[{"type":"bold"}],"text":"Read"},{"type":"text","text":" notes to understand current context (consult notes) → Output gate\n- The notebook persists across the entire story, so you remember the beginning when you reach the end"}]},{"type":"paragraph","content":[{"type":"text","text":"Or think of it as a "},{"type":"text","marks":[{"type":"bold"}],"text":"library"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Cell state"},{"type":"text","text":" = All books in the library (permanent collection)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Hidden state"},{"type":"text","text":" = Books you're currently reading (temporary focus)\n- You can add/remove books from the library (forget/input gates)\n- You can consult the library to find relevant information (output gate)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cell state ("},{"type":"inlineMath","attrs":{"latex":"C_t"}},{"type":"text","text":")"},{"type":"text","marks":[{"type":"bold"}],"text":" is LSTM's dedicated "},{"type":"text","text":"long-term memory"},{"type":"text","marks":[{"type":"bold"}],"text":" unit that retains information across many time steps"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"It acts like a "},{"type":"text","marks":[{"type":"bold"}],"text":"conveyor belt"},{"type":"text","text":" carrying relevant information through the entire sequence"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Separate from hidden state"},{"type":"text","text":": Cell state = long-term memory; Hidden state = short-term memory"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Updated additively: "},{"type":"inlineMath","attrs":{"latex":"C_t = C_{t-1} \\odot f_t + \\tilde{C}_t \\odot i_t"}},{"type":"text","text":" (not multiplicative like RNNs)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Uses "},{"type":"text","marks":[{"type":"bold"}],"text":"tanh activation"},{"type":"text","text":" (−1 to +1) for candidate values, improving stability"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Solves vanishing gradients"},{"type":"text","text":": Provides stable gradient flow, enabling training on long sequences"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Essential for "},{"type":"text","marks":[{"type":"bold"}],"text":"NLP, speech recognition, and time series"},{"type":"text","text":" tasks requiring long-term context"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"GRU does not have"},{"type":"text","text":" a separate cell state; it uses only hidden state, making it simpler"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"The cell state is what makes LSTMs capable of remembering context over long sequences, enabling models like ChatGPT to understand entire conversations and documents."}]}]}}
