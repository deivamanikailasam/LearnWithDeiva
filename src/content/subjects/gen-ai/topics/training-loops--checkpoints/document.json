{"format": "tiptap/v1", "updatedAt": "2026-06-22T08:58:39.631Z", "doc": {"type": "doc", "content": [{"type": "image", "attrs": {"src": "data:image/svg+xml;base64,", "alt": "Checkpoints — concept overview"}}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "What Checkpoints Are"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Checkpoints"}, {"type": "text", "text": " are saved snapshots of a model's entire internal state at specific points during training. They include the model's "}, {"type": "text", "marks": [{"type": "bold"}], "text": "weights"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "bold"}], "text": "optimizer state"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "bold"}], "text": "learning rate"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "bold"}], "text": "number of epochs executed"}, {"type": "text", "text": ", and other variables necessary to resume training or deploy the model later."}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Think of checkpoints as "}, {"type": "text", "marks": [{"type": "bold"}], "text": "intermediate save points"}, {"type": "text", "text": " in a video game — they let you resume training from exactly where you stopped instead of starting from scratch."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Why Checkpoints Matter in Generative AI"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Training generative models (GANs, diffusion models, LLMs) takes "}, {"type": "text", "marks": [{"type": "bold"}], "text": "days to weeks"}, {"type": "text", "text": " and faces many risks:"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Risk"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Checkpoint Solution"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Hardware failure"}, {"type": "text", "text": " (GPU crashes, power loss)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Resume from last checkpoint instead of restarting"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Software crashes"}, {"type": "text", "text": " (bugs, memory errors)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Recover progress without losing weeks of training"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Overfitting"}, {"type": "text", "text": " (loss stops decreasing on validation)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use \"early stopping\" — pick best checkpoint before overfitting"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Long training time"}, {"type": "text", "text": " (terabytes of data per checkpoint)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Save periodically to balance recovery flexibility vs disk space "}, {"type": "text", "marks": [{"type": "link", "attrs": {"href": "https://www.ddn.com/resources/whitepapers/checkpointing-efficiency-is-a-critical-blocker-to-ai-productivity/", "target": "_blank", "rel": "noopener noreferrer nofollow", "class": "text-brand-600 underline dark:text-brand-400", "title": null}}], "text": "ddn"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Transfer learning"}, {"type": "text", "text": " (changing goals mid-training)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use checkpoint as starting point for new task/dataset"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Multi-system training"}, {"type": "text", "text": " (distributed across nodes)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Resume training on different clusters from checkpoint"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Checkpointing is a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "fault tolerance technique"}, {"type": "text", "text": " that prevents loss of progress due to interruptions like hardware failures, software crashes, or manual stops."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "What Checkpoints Contain"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "A checkpoint saves the "}, {"type": "text", "marks": [{"type": "bold"}], "text": "complete internal state"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# What's saved in a checkpoint\ncheckpoint = {\n    'epoch': 50,                    # Which epoch we're on\n    'model_state': model.state_dict(),  # All weights and biases\n    'optimizer_state': optimizer.state_dict(),  # Optimizer state (momentum, etc.)\n    'loss': loss.item(),            # Current loss value\n    'learning_rate': optimizer.lr,  # Current learning rate\n    'metrics': {\n        'train_loss': train_loss,\n        'val_loss': val_loss,\n        'accuracy': accuracy\n    }\n}"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Checkpoints in PyTorch"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Saving a Checkpoint"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import torch\nimport torch.nn as nn\nimport torch.optim as optim\n\n# Model, optimizer, loss\nmodel = nn.Linear(128, 784)\noptimizer = optim.Adam(model.parameters(), lr=0.001)\ncriterion = nn.MSELoss()\n\n# Training loop\nfor epoch in range(100):\n    for inputs, labels in dataset:\n        # Forward pass\n        outputs = model(inputs)\n        loss = criterion(outputs, labels)\n        \n        # Backward pass\n        optimizer.zero_grad()\n        loss.backward()\n        optimizer.step()\n    \n    # SAVE CHECKPOINT at end of each epoch\n    checkpoint = {\n        'epoch': epoch,\n        'model_state': model.state_dict(),  # All weights [web:119]\n        'optimizer_state': optimizer.state_dict(),  # Optimizer state [web:119]\n        'loss': loss.item()\n    }\n    \n    torch.save(checkpoint, f'checkpoint_epoch_{epoch}.pth')  # Save to disk [web:119]"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Loading a Checkpoint"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Load checkpoint\ncheckpoint = torch.load('checkpoint_epoch_50.pth')\n\n# Restore model state\nmodel.load_state_dict(checkpoint['model_state'])  # [web:119]\n\n# Restore optimizer state\noptimizer.load_state_dict(checkpoint['optimizer_state'])  # [web:119]\n\n# Resume training\nfor epoch in range(checkpoint['epoch'], 100):  # Start from epoch 50\n    for inputs, labels in dataset:\n        outputs = model(inputs)\n        loss = criterion(outputs, labels)\n        \n        optimizer.zero_grad()\n        loss.backward()\n        optimizer.step()"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Checkpoints in TensorFlow/Keras"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Using ModelCheckpoint Callback"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import tensorflow as tf\n\n# Model\nmodel = tf.keras.Sequential([\n    tf.keras.layers.Dense(256, activation='relu', input_shape=(128,)),\n    tf.keras.layers.Dense(784, activation='sigmoid')\n])\n\n# Loss and optimizer\nloss_fn = tf.keras.losses.MeanSquaredError()\noptimizer = tf.keras.optimizers.Adam(learning_rate=0.001)\n\n# ModelCheckpoint callback (saves automatically)\ncheckpoint_callback = tf.keras.callbacks.ModelCheckpoint(\n    filepath='checkpoints/model_epoch_{epoch}',  # Save path [web:121]\n    save_weights_only=True,  # Save weights only [web:115]\n    save_best_only=False,    # Save every epoch [web:115]\n    verbose=1\n)\n\n# Training with automatic checkpointing\nmodel.fit(\n    train_ds,\n    epochs=100,\n    callbacks=[checkpoint_callback]  # Automatic saving [web:121]\n)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Best-Checkpoint Callback (Early Stopping)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Save only the best checkpoint (lowest validation loss)\ncheckpoint_callback = tf.keras.callbacks.ModelCheckpoint(\n    filepath='checkpoints/best_model',\n    save_weights_only=True,\n    save_best_only=True,  # Only save if val_loss improves [web:121]\n    monitor='val_loss',   # Monitor validation loss [web:121]\n    verbose=1\n)\n\nmodel.fit(\n    train_ds,\n    epochs=100,\n    validation_data=val_ds,\n    callbacks=[checkpoint_callback]\n)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Manual Checkpointing"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Training loop with manual checkpointing\nfor epoch in range(100):\n    with tf.GradientTape() as tape:\n        predictions = model(train_ds, training=True)\n        loss = loss_fn(train_labels, predictions)\n    \n    gradients = tape.gradient(loss, model.trainable_variables)\n    optimizer.apply_gradients(zip(gradients, model.trainable_variables))\n    \n    # SAVE CHECKPOINT manually\n    if epoch % 10 == 0:  # Every 10 epochs\n        model.save_weights(f'checkpoints/epoch_{epoch}')  # Save weights [web:121]\n        print(f'Saved checkpoint at epoch {epoch}')\n    \n    # LOAD CHECKPOINT to resume\n    # model.load_weights('checkpoints/epoch_50')"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Checkpoint Frequency and Strategy"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Trade-offs"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Frequency"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Pros"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Cons"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Every epoch"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Maximum recovery flexibility"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "High disk usage (terabytes for large models) "}, {"type": "text", "marks": [{"type": "link", "attrs": {"href": "https://www.ddn.com/resources/whitepapers/checkpointing-efficiency-is-a-critical-blocker-to-ai-productivity/", "target": "_blank", "rel": "noopener noreferrer nofollow", "class": "text-brand-600 underline dark:text-brand-400", "title": null}}], "text": "ddn"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Every 10 epochs"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Balanced disk/recovery"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Less granular recovery options "}, {"type": "text", "marks": [{"type": "link", "attrs": {"href": "https://www.ddn.com/resources/whitepapers/checkpointing-efficiency-is-a-critical-blocker-to-ai-productivity/", "target": "_blank", "rel": "noopener noreferrer nofollow", "class": "text-brand-600 underline dark:text-brand-400", "title": null}}], "text": "ddn"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Every 100 epochs"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Minimal disk usage"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "May miss important training states "}, {"type": "text", "marks": [{"type": "link", "attrs": {"href": "https://www.ddn.com/resources/whitepapers/checkpointing-efficiency-is-a-critical-blocker-to-ai-productivity/", "target": "_blank", "rel": "noopener noreferrer nofollow", "class": "text-brand-600 underline dark:text-brand-400", "title": null}}], "text": "ddn"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Only best"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Saves only good model"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Can't resume interrupted training"}]}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Common Strategies"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Strategy 1: Regular checkpoints + best checkpoint\nif epoch % 10 == 0:\n    torch.save(checkpoint, f'checkpoint_epoch_{epoch}.pth')  # Regular [web:118]\n\nif loss < best_loss:\n    torch.save(checkpoint, 'checkpoint_best.pth')  # Best [web:121]\n\n# Strategy 2: Incremental checkpoints (overwrite same file)\ntorch.save(checkpoint, 'checkpoint_latest.pth')  # Always overwrite [web:118]\n\n# Strategy 3: Checkpoint + validation\ntorch.save(checkpoint, f'checkpoint_epoch_{epoch}.pth')\nevaluate_model(model)  # Check if validation loss improved"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Checkpoints in Generative AI"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "GAN Checkpointing"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Save both generator and discriminator\ncheckpoint = {\n    'epoch': epoch,\n    'generator_state': generator.state_dict(),\n    'discriminator_state': discriminator.state_dict(),\n    'g_optimizer_state': g_optimizer.state_dict(),\n    'd_optimizer_state': d_optimizer.state_dict(),\n    'g_loss': g_loss.item(),\n    'd_loss': d_loss.item()\n}\n\ntorch.save(checkpoint, f'gan_checkpoint_epoch_{epoch}.pth')"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Diffusion Model Checkpointing"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Diffusion models are large (hundreds of MB to GB)\ncheckpoint = {\n    'epoch': epoch,\n    'model_state': diffusion_model.state_dict(),\n    'optimizer_state': optimizer.state_dict(),\n    'timestep': epoch * batch_size,\n    'loss': loss.item()\n}\n\n# Save to cloud storage (等大型 models)\ntorch.save(checkpoint, f's3://checkpoints/diffusion_epoch_{epoch}.pth')"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "LLM Checkpointing"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# LLMs can be terabytes in size\ncheckpoint = {\n    'epoch': epoch,\n    'model_state': model.state_dict(),\n    'optimizer_state': optimizer.state_dict(),\n    'learning_rate': optimizer.lr,\n    'total_tokens': epoch * batch_size * sequence_length\n}\n\n# Use distributed saving (multiple files)\nfrom torch.distributed import checkpoint\ncheckpoint.save(checkpoint, 'llm_checkpoints/epoch_{epoch}')"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Checkpointing Best Practices"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "1. Save Optimizer State"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# WRONG: Only save model state\ntorch.save(model.state_dict(), 'checkpoint.pth')  # Can't resume training [web:120]\n\n# RIGHT: Save model + optimizer state\ncheckpoint = {\n    'model_state': model.state_dict(),\n    'optimizer_state': optimizer.state_dict()  # Required for Adam/momentum [web:120]\n}\ntorch.save(checkpoint, 'checkpoint.pth')"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "2. Save Key Training Metrics"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "checkpoint = {\n    'model_state': model.state_dict(),\n    'optimizer_state': optimizer.state_dict(),\n    'epoch': epoch,\n    'loss': loss.item(),\n    'val_loss': val_loss,  # For early stopping [web:121]\n    'best_loss': best_loss\n}"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "3. Use Incremental Checkpoints"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Overwrite same file to save disk space\ntorch.save(checkpoint, 'checkpoint_latest.pth')  # Always latest [web:118]"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "4. Checkpoint Before Long Operations"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Save checkpoint before expensive validation\ntorch.save(checkpoint, f'checkpoint_epoch_{epoch}.pth')\n\n# Run validation\nval_loss = evaluate_model(model)  # May take hours"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Mental Model"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Think of checkpoints as "}, {"type": "text", "marks": [{"type": "bold"}], "text": "bookmarking a book"}, {"type": "text", "text": ":"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Training"}, {"type": "text", "text": ": Reading through the book (learning)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Checkpoint"}, {"type": "text", "text": ": Bookmarking your current page (save state)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Failure"}, {"type": "text", "text": ": Book gets lost/damaged (crash)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Resume"}, {"type": "text", "text": ": Return to bookmarked page (load checkpoint)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Continue"}, {"type": "text", "text": ": Keep reading from where you left (resume training)"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Checkpoints are "}, {"type": "text", "marks": [{"type": "bold"}], "text": "persistent snapshots"}, {"type": "text", "text": " of the AI model that enable training to resume from a specific point in case of interruptions. "}, {"type": "text", "marks": [{"type": "link", "attrs": {"href": "https://www.ddn.com/blog/understanding-the-impact-of-checkpoints-on-ai-efficiency/", "target": "_blank", "rel": "noopener noreferrer nofollow", "class": "text-brand-600 underline dark:text-brand-400", "title": null}}], "text": "ddn"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Key Takeaways"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Checkpoint"}, {"type": "text", "text": " = Snapshot of model's entire internal state (weights, optimizer, epoch, loss)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Purpose"}, {"type": "text", "text": ": Fault tolerance — resume training from last checkpoint instead of restarting"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "What's saved"}, {"type": "text", "text": ": Architecture, weights, biases, optimizer state, learning rate, epoch count"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "PyTorch"}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "code"}], "text": "torch.save(checkpoint, 'file.pth')"}, {"type": "text", "text": " + "}, {"type": "text", "marks": [{"type": "code"}], "text": "load_state_dict()"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "TensorFlow"}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "code"}], "text": "tf.keras.callbacks.ModelCheckpoint"}, {"type": "text", "text": " or "}, {"type": "text", "marks": [{"type": "code"}], "text": "model.save_weights()"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Optimizer state"}, {"type": "text", "text": ": Crucial to save (required for Adam/momentum)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Frequency"}, {"type": "text", "text": ": Balance between recovery flexibility (every epoch) vs disk space (every 10 epochs) "}, {"type": "text", "marks": [{"type": "link", "attrs": {"href": "https://www.ddn.com/resources/whitepapers/checkpointing-efficiency-is-a-critical-blocker-to-ai-productivity/", "target": "_blank", "rel": "noopener noreferrer nofollow", "class": "text-brand-600 underline dark:text-brand-400", "title": null}}], "text": "ddn"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Best checkpoint"}, {"type": "text", "text": ": Save only when validation loss improves (early stopping)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Generation AI"}, {"type": "text", "text": ": Essential for days/weeks of training (GANs, diffusion, LLMs)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Transfer learning"}, {"type": "text", "text": ": Use checkpoint as starting point for new task/dataset"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Multi-system"}, {"type": "text", "text": ": Resume training on different clusters/nodes from checkpoint"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Large models"}, {"type": "text", "text": ": Terabytes per checkpoint for models >100GB "}, {"type": "text", "marks": [{"type": "link", "attrs": {"href": "https://www.ddn.com/resources/whitepapers/checkpointing-efficiency-is-a-critical-blocker-to-ai-productivity/", "target": "_blank", "rel": "noopener noreferrer nofollow", "class": "text-brand-600 underline dark:text-brand-400", "title": null}}], "text": "ddn"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Disk I/O"}, {"type": "text", "text": ": Checkpointing halts all GPU activity during save "}, {"type": "text", "marks": [{"type": "link", "attrs": {"href": "https://www.ddn.com/blog/understanding-the-impact-of-checkpoints-on-ai-efficiency/", "target": "_blank", "rel": "noopener noreferrer nofollow", "class": "text-brand-600 underline dark:text-brand-400", "title": null}}], "text": "ddn"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Incremental"}, {"type": "text", "text": ": Overwrite same file to save disk space "}, {"type": "text", "marks": [{"type": "link", "attrs": {"href": "https://www.ddn.com/resources/whitepapers/checkpointing-efficiency-is-a-critical-blocker-to-ai-productivity/", "target": "_blank", "rel": "noopener noreferrer nofollow", "class": "text-brand-600 underline dark:text-brand-400", "title": null}}], "text": "ddn"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Checkpointing is a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "fundamental technique"}, {"type": "text", "text": " in deep learning that significantly improves efficiency, robustness, and flexibility during training, enabling you to resume training, explore different hyperparameters, recover from failures, and smoothly deploy trained models."}]}]}}