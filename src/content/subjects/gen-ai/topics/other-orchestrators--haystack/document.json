      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Metadata Filtering"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "All Haystack document stores support metadata filters at retrieval time. Use "
          },
          {
            "type": "text",
            "text": "MetadataRouter",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " to route documents to different stores at index time, or pass "
          },
          {
            "type": "text",
            "text": "filters",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " to a retriever at query time to restrict results to matching documents."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from haystack.components.retrievers.in_memory import InMemoryBM25Retriever\n\nretriever = InMemoryBM25Retriever(document_store=document_store, top_k=5)\n\n# Only return documents from the finance department, fiscal_year >= 2024\nresult = retriever.run(\n    query=\"margin expansion\",\n    filters={\n        \"operator\": \"AND\",\n        \"conditions\": [\n            {\"field\": \"meta.department\", \"operator\": \"==\", \"value\": \"finance\"},\n            {\"field\": \"meta.fiscal_year\", \"operator\": \">=\", \"value\": 2024},\n        ],\n    },\n)\nfor doc in result[\"documents\"]:\n    print(doc.meta[\"source\"], doc.content[:80])"
          }
        ]
