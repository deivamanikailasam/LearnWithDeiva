      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "bash"
        },
        "content": [
          {
            "type": "text",
            "text": "# pip install haystack-ai\n# For specific document stores:\n# pip install haystack-ai elasticsearch-haystack\n# pip install haystack-ai qdrant-haystack"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Haystack 2.x (released 2024) is a full rewrite of Haystack 1.x. The component/pipeline API below is the 2.x API \u2014 the APIs are not compatible."
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "The Document Class"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Every piece of content in Haystack is a "
          },
          {
            "type": "text",
            "text": "Document",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". Documents are created during indexing and retrieved during search. The "
          },
          {
            "type": "text",
            "text": "meta",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " dict carries arbitrary metadata (source, date, department\u2026) that is stored alongside the document and can be used for filtering."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from haystack import Document\n\ndoc = Document(\n    content=\"Q3 2024 revenue reached $4.2B, up 18% year-over-year.\",\n    meta={\n        \"source\": \"earnings-q3-2024.pdf\",\n        \"department\": \"finance\",\n        \"fiscal_year\": 2024,\n    },\n)\nprint(doc.id)       # auto-generated UUID\nprint(doc.content)\nprint(doc.meta)"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "InMemoryDocumentStore \u2014 Prototype Quickly"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The "
          },
          {
            "type": "text",
            "text": "InMemoryDocumentStore",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " keeps documents in memory. It supports BM25 keyword search and \u2014 when you supply embeddings \u2014 cosine/dot-product ANN search. No external service needed, making it the right choice for development and testing."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from haystack.document_stores.in_memory import InMemoryDocumentStore\nfrom haystack import Document\n\nstore = InMemoryDocumentStore(embedding_similarity_function=\"cosine\")\n\ndocs = [\n    Document(content=\"Paris is the capital of France.\", meta={\"country\": \"France\"}),\n    Document(content=\"Berlin is the capital of Germany.\", meta={\"country\": \"Germany\"}),\n    Document(content=\"Tokyo is the capital of Japan.\", meta={\"country\": \"Japan\"}),\n]\nstore.write_documents(docs)\nprint(f\"Stored {store.count_documents()} documents\")"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Indexing Pipeline \u2014 From Files to Stored Embeddings"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "An indexing pipeline converts raw files into embedded "
          },
          {
            "type": "text",
            "text": "Document",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " objects and writes them to the document store. The canonical components in order are: "
          },
          {
            "type": "text",
            "text": "FileTypeRouter",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " \u2192 "
          },
          {
            "type": "text",
            "text": "Converter",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " \u2192 "
          },
          {
            "type": "text",
            "text": "DocumentSplitter",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " \u2192 "
          },
          {
            "type": "text",
            "text": "DocumentEmbedder",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " \u2192 "
          },
          {
            "type": "text",
            "text": "DocumentWriter",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": "."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import os\nfrom haystack import Pipeline\nfrom haystack.components.converters import PyPDFToDocument, TextFileToDocument\nfrom haystack.components.preprocessors import DocumentSplitter, DocumentCleaner\nfrom haystack.components.embedders import SentenceTransformersDocumentEmbedder\nfrom haystack.components.writers import DocumentWriter\nfrom haystack.document_stores.in_memory import InMemoryDocumentStore\n\n# os.environ[\"OPENAI_API_KEY\"] = \"sk-...\"\ndocument_store = InMemoryDocumentStore(embedding_similarity_function=\"cosine\")\n\nindexing = Pipeline()\nindexing.add_component(\"converter\", PyPDFToDocument())\nindexing.add_component(\n    \"cleaner\",\n    DocumentCleaner(remove_empty_lines=True, remove_extra_whitespaces=True),\n)\nindexing.add_component(\n    \"splitter\",\n    DocumentSplitter(split_by=\"word\", split_length=200, split_overlap=20),\n)\nindexing.add_component(\n    \"embedder\",\n    SentenceTransformersDocumentEmbedder(model=\"sentence-transformers/all-MiniLM-L6-v2\"),\n)\nindexing.add_component(\n    \"writer\",\n    DocumentWriter(document_store=document_store),\n)\n\n# Wire the components\nindexing.connect(\"converter\", \"cleaner\")\nindexing.connect(\"cleaner\", \"splitter\")\nindexing.connect(\"splitter\", \"embedder\")\nindexing.connect(\"embedder\", \"writer\")\n\n# Run\nindexing.run({\"converter\": {\"sources\": [\"report.pdf\"]}})\nprint(f\"Indexed {document_store.count_documents()} chunks\")"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "RAG Pipeline \u2014 Retrieve and Generate"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "After indexing, a RAG pipeline embeds the query, retrieves matching documents, fills a prompt template, and generates an answer. Haystack separates each step into a named component connected by socket."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from haystack import Pipeline\nfrom haystack.components.embedders import SentenceTransformersTextEmbedder\nfrom haystack.components.retrievers.in_memory import InMemoryEmbeddingRetriever\nfrom haystack.components.builders import PromptBuilder\nfrom haystack.components.generators import OpenAIGenerator\n\ntemplate = \"\"\"\nAnswer the question based on the context below.\nIf the answer is not in the context, say \"I don't know.\"\n\nContext:\n{% for doc in documents %}\n{{ doc.content }}\n{% endfor %}\n\nQuestion: {{ question }}\nAnswer:\n\"\"\"\n\nrag = Pipeline()\nrag.add_component(\n    \"query_embedder\",\n    SentenceTransformersTextEmbedder(model=\"sentence-transformers/all-MiniLM-L6-v2\"),\n)\nrag.add_component(\n    \"retriever\",\n    InMemoryEmbeddingRetriever(document_store=document_store, top_k=5),\n)\nrag.add_component(\"prompt_builder\", PromptBuilder(template=template))\nrag.add_component(\"generator\", OpenAIGenerator(model=\"gpt-4o-mini\"))\n\n# Connect sockets\nrag.connect(\"query_embedder.embedding\", \"retriever.query_embedding\")\nrag.connect(\"retriever.documents\", \"prompt_builder.documents\")\nrag.connect(\"prompt_builder.prompt\", \"generator.prompt\")\n\n# Run\nresult = rag.run({\n    \"query_embedder\": {\"text\": \"What was Q3 revenue?\"},\n    \"prompt_builder\": {\"question\": \"What was Q3 revenue?\"},\n})\nprint(result[\"generator\"][\"replies\"][0])"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "BM25 Retrieval \u2014 Keyword Search"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For keyword-based retrieval without embeddings, swap in "
          },
          {
            "type": "text",
            "text": "InMemoryBM25Retriever",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". BM25 requires no embedding model and returns results instantly. Use it as a standalone retriever or as one leg of a hybrid pipeline."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from haystack import Pipeline\nfrom haystack.components.retrievers.in_memory import InMemoryBM25Retriever\nfrom haystack.components.builders import PromptBuilder\nfrom haystack.components.generators import OpenAIGenerator\n\ntemplate = \"\"\"\nContext:\n{% for doc in documents %}\n{{ doc.content }}\n{% endfor %}\nQuestion: {{ question }}\nAnswer:\n\"\"\"\n\nbm25_rag = Pipeline()\nbm25_rag.add_component(\n    \"retriever\",\n    InMemoryBM25Retriever(document_store=document_store, top_k=5),\n)\nbm25_rag.add_component(\"prompt_builder\", PromptBuilder(template=template))\nbm25_rag.add_component(\"generator\", OpenAIGenerator(model=\"gpt-4o-mini\"))\n\nbm25_rag.connect(\"retriever.documents\", \"prompt_builder.documents\")\nbm25_rag.connect(\"prompt_builder.prompt\", \"generator.prompt\")\n\nresult = bm25_rag.run({\n    \"retriever\": {\"query\": \"EBITDA margin Q3 2024\"},\n    \"prompt_builder\": {\"question\": \"What is the EBITDA margin in Q3 2024?\"},\n})\nprint(result[\"generator\"][\"replies\"][0])"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Hybrid Retrieval \u2014 BM25 + Embedding Fusion"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Haystack's "
          },
          {
            "type": "text",
            "text": "DocumentJoiner",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " component merges result sets from multiple retrievers. Set "
          },
          {
            "type": "text",
            "text": "join_mode=\"reciprocal_rank_fusion\"",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " to apply RRF \u2014 the same fusion algorithm used by LlamaIndex's "
          },
          {
            "type": "text",
            "text": "QueryFusionRetriever",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". Run both retrievers in parallel, then join before the prompt builder."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from haystack import Pipeline\nfrom haystack.components.retrievers.in_memory import (\n    InMemoryBM25Retriever,\n    InMemoryEmbeddingRetriever,\n)\nfrom haystack.components.embedders import SentenceTransformersTextEmbedder\nfrom haystack.components.joiners import DocumentJoiner\nfrom haystack.components.builders import PromptBuilder\nfrom haystack.components.generators import OpenAIGenerator\n\ntemplate = \"\"\"\nContext:\n{% for doc in documents %}\n{{ doc.content }}\n{% endfor %}\nQuestion: {{ question }}\nAnswer:\n\"\"\"\n\nhybrid = Pipeline()\nhybrid.add_component(\"query_embedder\",\n    SentenceTransformersTextEmbedder(model=\"sentence-transformers/all-MiniLM-L6-v2\"))\nhybrid.add_component(\"bm25\",\n    InMemoryBM25Retriever(document_store=document_store, top_k=10))\nhybrid.add_component(\"dense\",\n    InMemoryEmbeddingRetriever(document_store=document_store, top_k=10))\nhybrid.add_component(\"joiner\",\n    DocumentJoiner(join_mode=\"reciprocal_rank_fusion\", top_k=5))\nhybrid.add_component(\"prompt_builder\", PromptBuilder(template=template))\nhybrid.add_component(\"generator\", OpenAIGenerator(model=\"gpt-4o-mini\"))\n\nhybrid.connect(\"query_embedder.embedding\", \"dense.query_embedding\")\nhybrid.connect(\"bm25.documents\", \"joiner.documents\")\nhybrid.connect(\"dense.documents\", \"joiner.documents\")\nhybrid.connect(\"joiner.documents\", \"prompt_builder.documents\")\nhybrid.connect(\"prompt_builder.prompt\", \"generator.prompt\")\n\nresult = hybrid.run({\n    \"query_embedder\": {\"text\": \"revenue growth drivers\"},\n    \"bm25\": {\"query\": \"revenue growth drivers\"},\n    \"prompt_builder\": {\"question\": \"What are the main revenue growth drivers?\"},\n})\nprint(result[\"generator\"][\"replies\"][0])"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Custom Components"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Any class decorated with "
          },
          {
            "type": "text",
            "text": "@component",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " and annotated with "
          },
          {
            "type": "text",
            "text": "@component.output_types",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " becomes a first-class Haystack component. Declare input types as method parameters with type hints; declare output types in the decorator. The "
          },
          {
            "type": "text",
            "text": "run()",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " method must return a dict matching the declared output keys."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from haystack import component, Document\nfrom typing import List\n\n@component\nclass ElasticsearchRetriever:\n    \"\"\"Retrieve documents from an external Elasticsearch index.\"\"\"\n\n    def __init__(self, es_client, index: str, top_k: int = 5):\n        self.es = es_client\n        self.index = index\n        self.top_k = top_k\n\n    @component.output_types(documents=List[Document])\n    def run(self, query: str) -> dict:\n        resp = self.es.search(\n            index=self.index,\n            body={\n                \"query\": {\"match\": {\"content\": query}},\n                \"size\": self.top_k,\n            },\n        )\n        docs = [\n            Document(\n                content=hit[\"_source\"][\"content\"],\n                meta={\"source\": hit[\"_source\"].get(\"filename\", \"\")},\n                id=hit[\"_id\"],\n            )\n            for hit in resp[\"hits\"][\"hits\"]\n        ]\n        return {\"documents\": docs}\n\n# Use it exactly like a built-in retriever\npipeline = Pipeline()\npipeline.add_component(\"retriever\", ElasticsearchRetriever(es_client, \"my_index\"))\npipeline.add_component(\"prompt_builder\", PromptBuilder(template=template))\npipeline.connect(\"retriever.documents\", \"prompt_builder.documents\")"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Pipeline Serialization \u2014 YAML"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Haystack pipelines serialize to and from YAML, enabling version-controlled pipeline definitions. Each component's class, init parameters, and connections are captured. Sensitive values (API keys) stay in environment variables and are resolved at runtime via "
          },
          {
            "type": "text",
            "text": "Secret",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": "."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Serialize to YAML\nyaml_str = rag.to_yaml()\nprint(yaml_str)\n\n# Save to file\nwith open(\"rag_pipeline.yaml\", \"w\") as f:\n    f.write(yaml_str)\n\n# Reload from YAML (e.g. in a different service or after restart)\nfrom haystack import Pipeline as HaystackPipeline\n\nwith open(\"rag_pipeline.yaml\") as f:\n    loaded_pipeline = HaystackPipeline.from_yaml(f.read())\n\n# The loaded pipeline is fully functional\nresult = loaded_pipeline.run({\n    \"query_embedder\": {\"text\": \"What is the refund policy?\"},\n    \"prompt_builder\": {\"question\": \"What is the refund policy?\"},\n})"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "yaml"
        },
        "content": [
          {
            "type": "text",
            "text": "# rag_pipeline.yaml (auto-generated \u2014 shape for illustration)\ncomponents:\n  query_embedder:\n    type: haystack.components.embedders.sentence_transformers_text_embedder.SentenceTransformersTextEmbedder\n    init_parameters:\n      model: sentence-transformers/all-MiniLM-L6-v2\n  retriever:\n    type: haystack.components.retrievers.in_memory.embedding_retriever.InMemoryEmbeddingRetriever\n    init_parameters:\n      top_k: 5\n  generator:\n    type: haystack.components.generators.openai.OpenAIGenerator\n    init_parameters:\n      model: gpt-4o-mini\nconnections:\n  - sender: query_embedder.embedding\n    receiver: retriever.query_embedding\n  - sender: retriever.documents\n    receiver: prompt_builder.documents\n  - sender: prompt_builder.prompt\n    receiver: generator.prompt"
          }
        ]
