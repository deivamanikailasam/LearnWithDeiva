{"format": "tiptap/v1", "updatedAt": "2026-06-22T03:45:37.858Z", "doc": {"type": "doc", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Ridge and Lasso"}, {"type": "text", "text": " are two popular "}, {"type": "text", "marks": [{"type": "bold"}], "text": "regularization techniques"}, {"type": "text", "text": " in classical machine learning used to prevent overfitting in linear (and logistic) regression models by adding a penalty term to the loss function, constraining the coefficients to improve predictive performance."}]}, {"type": "image", "attrs": {"src": "data:image/svg+xml;base64,", "alt": "Ridge & Lasso — concept overview"}}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "What They Are"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Both methods add a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "penalty"}, {"type": "text", "text": " proportional to the size of coefficients to constrain the model, but they differ in "}, {"type": "text", "marks": [{"type": "bold"}], "text": "how"}, {"type": "text", "text": " they apply this penalty:"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Method"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Regularization Type"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Penalty"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": " "}]