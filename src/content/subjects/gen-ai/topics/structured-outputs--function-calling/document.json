                    "content": [
                      {
                        "type": "text",
                        "marks": [
                          {
                            "type": "italic"
                          }
                        ],
                        "text": "\"Get weather.\""
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "marks": [
                          {
                            "type": "italic"
                          }
                        ],
                        "text": "\"Get the current temperature and conditions for a city. Use when the user asks about weather or plans involving outdoor activities.\""
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Overlapping tools"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Both search_web and search_news do web searching"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Add distinguishing criteria: \"Use search_news only for events in the last 7 days.\""
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Missing parameter details"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "marks": [
                          {
                            "type": "code"
                          }
                        ],
                        "text": "\"date\": {\"type\":\"string\"}"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "marks": [
                          {
                            "type": "code"
                          }
                        ],
                        "text": "\"date\": {\"type\":\"string\",\"description\":\"ISO 8601 date, e.g. 2025-01-15\"}"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Not appending the assistant's tool_calls turn"
                  },
                  {
                    "type": "text",
                    "text": ": The message with "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "role: \"assistant\""
                  },
                  {
                    "type": "text",
                    "text": " and "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "tool_calls"
                  },
                  {
                    "type": "text",
                    "text": " must be in the conversation before the tool results. Sending only the tool results without the preceding assistant turn causes an API error."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Infinite loop"
                  },
                  {
                    "type": "text",
                    "text": ": If a tool always returns an error, the model may keep re-calling it. Add a maximum iteration count (e.g. 10) and raise an exception if exceeded."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Returning too much data"
                  },
                  {
                    "type": "text",
                    "text": ": If a tool result is thousands of tokens, it consumes context and increases cost. Summarise or paginate tool outputs."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Side-effectful tools without confirmation"
                  },
                  {
                    "type": "text",
                    "text": ": Never let the model call destructive tools (delete, send email, charge payment) without a human-in-the-loop confirmation step, especially during development."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
