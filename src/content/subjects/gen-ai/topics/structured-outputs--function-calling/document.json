      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Using Function Calling for Data Extraction"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Forcing a tool call with "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "tool_choice=\"required\""
          },
          {
            "type": "text",
            "text": " is a reliable way to get structured JSON from unstructured text. Define the target schema as a tool named something like "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "extract_fields"
          },
          {
            "type": "text",
            "text": " and parse the arguments."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import json\nfrom openai import OpenAI\nfrom dataclasses import dataclass\n\nclient = OpenAI()\n\nextraction_tool = [\n    {\n        \"type\": \"function\",\n        \"function\": {\n            \"name\": \"extract_order\",\n            \"description\": \"Extract order details from customer email.\",\n            \"parameters\": {\n                \"type\": \"object\",\n                \"properties\": {\n                    \"order_id\": {\"type\": \"string\"},\n                    \"customer_name\": {\"type\": \"string\"},\n                    \"items\": {\n                        \"type\": \"array\",\n                        \"items\": {\n                            \"type\": \"object\",\n                            \"properties\": {\n                                \"product\": {\"type\": \"string\"},\n                                \"quantity\": {\"type\": \"integer\"},\n                            },\n                            \"required\": [\"product\", \"quantity\"],\n                        },\n                    },\n                    \"total_usd\": {\"type\": \"number\"},\n                    \"urgent\": {\"type\": \"boolean\"},\n                },\n                \"required\": [\"order_id\", \"customer_name\", \"items\"],\n            },\n        },\n    }\n]\n\n\ndef extract_order_from_email(email_text: str) -> dict:\n    response = client.chat.completions.create(\n        model=\"gpt-4o-mini\",\n        messages=[\n            {\"role\": \"system\", \"content\": \"Extract structured order data from the email.\"},\n            {\"role\": \"user\", \"content\": email_text},\n        ],\n        tools=extraction_tool,\n        tool_choice={\"type\": \"function\", \"function\": {\"name\": \"extract_order\"}},\n    )\n    tc = response.choices[0].message.tool_calls[0]\n    return json.loads(tc.function.arguments)\n\n\nemail = \"\"\"\nHi, I'm Jane Smith. My order #12345 has 3 x Blue Widget and 1 x Red Gadget.\nTotal was $47.50. Please ship ASAP — it's urgent!\n\"\"\"\n\norder = extract_order_from_email(email)\nprint(order)\n# {'order_id': '12345', 'customer_name': 'Jane Smith',\n#  'items': [{'product': 'Blue Widget', 'quantity': 3},\n#            {'product': 'Red Gadget', 'quantity': 1}],\n#  'total_usd': 47.5, 'urgent': True}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Function Calling with LangChain"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "LangChain's "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "@tool"
          },
          {
            "type": "text",
            "text": " decorator extracts the JSON schema from the function signature and docstring. "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "bind_tools()"
          },
          {
            "type": "text",
            "text": " attaches the tools to a chat model. "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "ToolNode"
          },
          {
            "type": "text",
            "text": " executes the tool calls in the response."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_core.tools import tool\nfrom langchain_openai import ChatOpenAI\nfrom langchain_core.messages import HumanMessage, AIMessage, ToolMessage\n\n\n@tool\ndef get_weather(location: str, units: str = \"celsius\") -> str:\n    \"\"\"Get the current weather for a city.\n\n    Args:\n        location: City name, optionally with country code.\n        units: Temperature unit, 'celsius' or 'fahrenheit'.\n    \"\"\"\n    return f\"{{\\\"location\\\": \\\"{location}\\\", \\\"temp\\\": 14, \\\"condition\\\": \\\"cloudy\\\"}}\"\n\n\n@tool\ndef search_web(query: str) -> str:\n    \"\"\"Search the web for current information.\"\"\"\n    return f\"Search results for '{query}': [result1, result2]\"\n\n\ntools = [get_weather, search_web]\nllm = ChatOpenAI(model=\"gpt-4o-mini\", temperature=0)\nllm_with_tools = llm.bind_tools(tools)\n\n# Build tool map for execution\ntool_map = {t.name: t for t in tools}\n\n\ndef run_agent(user_input: str) -> str:\n    messages = [HumanMessage(content=user_input)]\n\n    while True:\n        response: AIMessage = llm_with_tools.invoke(messages)\n        messages.append(response)\n\n        if not response.tool_calls:\n            return response.content\n\n        # Execute each tool call\n        for tc in response.tool_calls:\n            result = tool_map[tc[\"name\"]].invoke(tc[\"args\"])\n            messages.append(ToolMessage(content=str(result), tool_call_id=tc[\"id\"]))\n\n\nprint(run_agent(\"What's the weather in Rome?\"))"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Tool Calling with the Anthropic API"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The Anthropic API uses a slightly different format: tools are defined with "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "input_schema"
          },
          {
            "type": "text",
            "text": " instead of "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "parameters"
          },
          {
            "type": "text",
            "text": ", and tool results use a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "tool_result"
          },
          {
            "type": "text",
            "text": " content block rather than a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "tool"
          },
          {
            "type": "text",
            "text": " role message."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import json\nimport anthropic\n\nclient = anthropic.Anthropic()\n\ntools = [\n    {\n        \"name\": \"get_weather\",\n        \"description\": \"Get current weather for a location.\",\n        \"input_schema\": {\n            \"type\": \"object\",\n            \"properties\": {\n                \"location\": {\"type\": \"string\", \"description\": \"City name.\"},\n            },\n            \"required\": [\"location\"],\n        },\n    }\n]\n\n\ndef get_weather(location: str) -> dict:\n    return {\"location\": location, \"temp\": 14, \"condition\": \"cloudy\"}\n\n\ndef run_claude(user_message: str) -> str:\n    messages = [{\"role\": \"user\", \"content\": user_message}]\n\n    while True:\n        response = client.messages.create(\n            model=\"claude-sonnet-4-6\",\n            max_tokens=1024,\n            tools=tools,\n            messages=messages,\n        )\n\n        # Append the assistant's full content block list\n        messages.append({\"role\": \"assistant\", \"content\": response.content})\n\n        if response.stop_reason == \"tool_use\":\n            tool_results = []\n            for block in response.content:\n                if block.type == \"tool_use\":\n                    fn_result = get_weather(**block.input)  # dispatch by name in real code\n                    tool_results.append({\n                        \"type\": \"tool_result\",\n                        \"tool_use_id\": block.id,\n                        \"content\": json.dumps(fn_result),\n                    })\n            messages.append({\"role\": \"user\", \"content\": tool_results})\n        else:\n            # stop_reason == \"end_turn\" → extract text\n            for block in response.content:\n                if hasattr(block, \"text\"):\n                    return block.text\n\n\nprint(run_claude(\"What's the weather in Dublin?\"))"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Error Handling"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The model can produce malformed JSON arguments or call functions with invalid values. Validate before executing and return a clear error message as the tool result — the model will usually correct itself."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import json\nfrom typing import Any\n\n\ndef safe_execute_tool(tc, tool_map: dict) -> dict:\n    \"\"\"Execute a tool call, returning an error dict on failure.\"\"\"\n    tool_call_id = tc.id\n    name = tc.function.name\n\n    # Unknown function\n    if name not in tool_map:\n        return {\n            \"role\": \"tool\",\n            \"tool_call_id\": tool_call_id,\n            \"content\": json.dumps({\"error\": f\"Unknown function: {name}\"}),\n        }\n\n    # Parse arguments\n    try:\n        args = json.loads(tc.function.arguments)\n    except json.JSONDecodeError as e:\n        return {\n            \"role\": \"tool\",\n            \"tool_call_id\": tool_call_id,\n            \"content\": json.dumps({\"error\": f\"Invalid JSON arguments: {e}\"}),\n        }\n\n    # Execute with error capture\n    try:\n        result = tool_map[name](**args)\n        return {\n            \"role\": \"tool\",\n            \"tool_call_id\": tool_call_id,\n            \"content\": json.dumps(result) if not isinstance(result, str) else result,\n        }\n    except TypeError as e:\n        return {\n            \"role\": \"tool\",\n            \"tool_call_id\": tool_call_id,\n            \"content\": json.dumps({\"error\": f\"Invalid arguments: {e}\"}),\n        }\n    except Exception as e:\n        return {\n            \"role\": \"tool\",\n            \"tool_call_id\": tool_call_id,\n            \"content\": json.dumps({\"error\": f\"Execution failed: {type(e).__name__}: {e}\"}),\n        }"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
