{"format": "tiptap/v1", "updatedAt": "2026-06-22T03:42:57.796Z", "doc": {"type": "doc", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Linear Regression"}, {"type": "text", "text": " is a fundamental "}, {"type": "text", "marks": [{"type": "bold"}], "text": "supervised learning algorithm"}, {"type": "text", "text": " in classical machine learning that models the relationship between input variables and a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "continuous numerical output"}, {"type": "text", "text": " by fitting a straight line (or linear surface) to the data."}]}, {"type": "image", "attrs": {"src": "data:image/svg+xml;base64,", "alt": "Linear Regression — concept overview"}}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "What It Is"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Linear regression finds the "}, {"type": "text", "marks": [{"type": "bold"}], "text": "best-fit line"}, {"type": "text", "text": " that minimizes the difference between predicted and actual values, enabling predictions on continuous data like height, age, price, or temperature."}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Core equation"}, {"type": "text", "text": " (simple linear regression with one feature):"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "$$y = mx + b$$"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Where:\n- "}, {"type": "inlineMath", "attrs": {"latex": "y"}}, {"type": "text", "text": " = "}, {"type": "text", "marks": [{"type": "bold"}], "text": "dependent variable"}, {"type": "text", "text": " (target/predicted value)\n- "}, {"type": "inlineMath", "attrs": {"latex": "x"}}, {"type": "text", "text": " = "}, {"type": "text", "marks": [{"type": "bold"}], "text": "independent variable"}, {"type": "text", "text": " (input/feature)\n- "}, {"type": "inlineMath", "attrs": {"latex": "m"}}, {"type": "text", "text": " = "}, {"type": "text", "marks": [{"type": "bold"}], "text": "slope"}, {"type": "text", "text": " (regression coefficient; how much "}, {"type": "inlineMath", "attrs": {"latex": "y"}}, {"type": "text", "text": " changes per unit "}, {"type": "inlineMath", "attrs": {"latex": "x"}}, {"type": "text", "text": ")\n- "}, {"type": "inlineMath", "attrs": {"latex": "b"}}, {"type": "text", "text": " = "}, {"type": "text", "marks": [{"type": "bold"}], "text": "intercept"}, {"type": "text", "text": " (where line crosses the y-axis)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Multiple linear regression"}, {"type": "text", "text": " (with "}, {"type": "inlineMath", "attrs": {"latex": "k"}}, {"type": "text", "text": " features):"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "$$y = \\beta_0 + \\beta_1x_1 + \\beta_2x_2 +... + \\beta_kx_k + \\epsilon$$"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Where:\n- "}, {"type": "inlineMath", "attrs": {"latex": "\\beta_0"}}, {"type": "text", "text": " = intercept (constant)\n- "}, {"type": "inlineMath", "attrs": {"latex": "\\beta_k"}}, {"type": "text", "text": " = regression coefficients for each feature\n- "}, {"type": "inlineMath", "attrs": {"latex": "\\epsilon"}}, {"type": "text", "text": " = error term (residual)"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Why It Matters"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Purpose"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Explanation"}]}]}]}, {"type": "table