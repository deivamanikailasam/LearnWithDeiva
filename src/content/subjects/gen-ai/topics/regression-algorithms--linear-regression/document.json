type": "text", "text": " for new "}, {"type": "inlineMath", "attrs": {"latex": "x"}}, {"type": "text", "text": " values"}]}]}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "text": "Least Squares Method"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The regression line coefficients are calculated as:"}]}, {"type": "blockMath", "attrs": {"latex": "m = \\frac{n(\\sum xy) - \\sum x \\sum y}{n\\sum x^{2} - (\\sum x)^2}"}}, {"type": "blockMath", "attrs": {"latex": "b = \\frac{\\sum y - m\\sum x}{n}"}}, {"type": "paragraph", "content": [{"type": "text", "text": "This minimizes the "}, {"type": "text", "marks": [{"type": "bold"}], "text": "sum of squared residuals"}, {"type": "text", "text": " (errors) between predicted and actual values."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Visualization"}]}, {"type": "codeBlock", "attrs": {"language": "text"}, "content": [{"type": "text", "text": "Shoe Size (x) vs Height (y)\nHeight (cm)\n  ↑\n  │        ●\n  │      ●   ●\n  │    ●   ●\n  │  ●   ●\n  │●   ●\n  │________________→ Shoe Size (cm)\n  \nBest-fit line: y = mx + b\n(passes closest to all points)"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The line summarizes the data trend and enables predictions."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "When to Use Linear Regression"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "✅ Use When"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "❌ Don't Use When"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "att