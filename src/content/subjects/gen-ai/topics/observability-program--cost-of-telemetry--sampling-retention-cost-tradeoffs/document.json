        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# OTel span: keep only queryable attributes; move the rest to logs\nfrom opentelemetry import trace\n\ndef record_llm_span(span, response):\n    # KEEP on span: attributes you filter/aggregate in Tempo/Grafana\n    span.set_attribute(\"gen_ai.request.model\", response.model)\n    span.set_attribute(\"gen_ai.usage.total_tokens\", response.usage.total_tokens)\n    span.set_attribute(\"gen_ai.finish_reason\", response.finish_reason)\n    span.set_attribute(\"gen_ai.cost_usd\", response.cost_usd)\n    # ttft_ms: needed for P95 latency in trace queries\n    span.set_attribute(\"gen_ai.performance.ttft_ms\", response.ttft_ms)\n\n    # DO NOT SET on span (put in log instead):\n    # - response.choices[0].message.content  (large string, queried in Loki not Tempo)\n    # - response.usage.prompt_tokens_details  (nested dict, rarely queried)\n    # - Any field > 200 chars that isn't used in Tempo queries\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Recipe 3: Metric Cardinality Audit"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import requests\n\nPROMETHEUS_URL = \"http://prometheus:9090\"\n\ndef cardinality_report(job: str, top_n: int = 10) -> list[dict]:\n    \"\"\"Find the highest-cardinality labels for a given job.\"\"\"\n    # Get all label names for this job\n    labels_resp = requests.get(\n        f\"{PROMETHEUS_URL}/api/v1/labels\",\n        params={\"match[]\": f'{{job=\"{job}\"}}'},\n    ).json()\n\n    results = []\n    for label in labels_resp.get(\"data\", []):\n        if label.startswith(\"__\"): continue\n        values_resp = requests.get(\n            f\"{PROMETHEUS_URL}/api/v1/label/{label}/values\",\n            params={\"match[]\": f'{{job=\"{job}\"}}'},\n        ).json()\n        count = len(values_resp.get(\"data\", []))\n        results.append({\"label\": label, \"cardinality\": count})\n\n    results.sort(key=lambda x: -x[\"cardinality\"])\n    return results[:top_n]\n\n# Run before and after optimisation to measure impact\nfor r in cardinality_report(\"genai-search\"):\n    print(f\"  {r['label']:<30} {r['cardinality']:>8,} unique values\")\n# Example output showing a problem:\n#   request_id                       5,243,190 unique values  \u2190 DROP THIS LABEL\n#   user_id                          1,200,445 unique values  \u2190 HASH AND BUCKET\n#   model                                   12 unique values  \u2190 OK\n#   feature                                 18 unique values  \u2190 OK\n"
          }
        ]
      },
