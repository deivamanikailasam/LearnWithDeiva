type": "text", "text": "Transformers supports tasks across "}, {"type": "text", "marks": [{"type": "bold"}], "text": "multiple modalities"}, {"type": "text", "text": ":"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Text Tasks"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Text classification (spam/not spam)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Text generation (GPT-style)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Question answering"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Summarization"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Token classification (POS tagging, entities)"}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Audio Tasks"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Automatic speech recognition (audio to text)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Audio classification"}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Vision Tasks"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Object detection"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Image segmentation"}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Multimodal Tasks"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Reinforcement learning"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Vision-language models (VLMs)"}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "How to Use Transformers"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Basic Inference with Pipeline"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "from transformers import pipeline\n\n# Create pipeline for text generation\ngenerator = pipeline(\"text-generation\", model=\"gpt2\")\n\n# Generate text\nresult = generator(\"Hello, I'm a language model,\")\nprint(result)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Using Model + Tokenizer"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "from transformers import AutoModel, AutoTokenizer\nimport torch\n\n# Load model and tokenizer\nmodel_name = \"bert-base-uncased\"\ntokenizer = AutoTokenizer.from_pretrained(model_name)\nmodel = AutoModel.from_pretrained(model_name)\n\n# Prepare input\ntext = \"Hello, how are you?\"\ninputs = tokenizer(text, return_tensors=\"pt\")\n\n# Run model\noutputs = model(**inputs)\nprint(outputs.last_hidden_state)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Training with Trainer"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "from transformers import Trainer, TrainingArguments\nfrom transformers import AutoModelForSequenceClassification\n\n# Load model\nmodel = AutoModelForSequenceClassification.from_pretrained(\"bert-base-uncased\")\n\n# Training arguments\ntraining_args = TrainingArguments(\n    output_dir=\"./results\",\n    num_train_epochs=3,\n    per_device_train_batch_size=8,\n    fp16=True,  # Mixed precision [web:281]\n)\n\n# Trainer\ntrainer = Trainer(\n    model=model,\n    args=training_args,\n    train_dataset=train_dataset,\n)\n\n# Train\ntrainer.train()"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Using generate for LLMs"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "from transformers import AutoModelForCausalLM, AutoTokenizer\n\nmodel = AutoModelForCausalLM.from_pretrained(\"meta-llama/Llama-2-7b\")\ntokenizer = AutoTokenizer.from_pretrained(\"meta-llama/Llama-2-7b\")\n\n# Generate with streaming support\ninputs = tokenizer(\"Hello, I am\", return_tensors=\"pt\")\noutputs = model.generate(\n    **inputs,\n    max_new_tokens=100,\n    do_sample=True,\n    temperature=0.7,\n)\n\nprint(tokenizer.decode(outputs[0]))"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Supported Frameworks"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Transformers works with "}, {"type": "text", "marks": [{"type": "bold"}], "text": "three main deep learning frameworks"}, {"type": "text", "text": ":"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Framework"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Status"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "PyTorch"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Primary framework (default)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "TensorFlow"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Full support"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "JAX"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Full support"}]}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Model Architectures"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Transformers "}, {"type": "text", "marks": [{"type": "bold"}], "text": "supports 300+ model architectures"}, {"type": "text", "text": " with ~3 new architectures added every week:"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Popular Architectures"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Llama family"}, {"type": "text", "text": " (Llama, Llama-2, Llama-3)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Qwen"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "GLM"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "BERT"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "GPT"}]}]}, {"type": "l