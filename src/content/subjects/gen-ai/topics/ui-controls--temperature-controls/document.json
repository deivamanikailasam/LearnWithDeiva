      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Anthropic recommends altering either "
          },
          {
            "type": "text",
            "text": "temperature",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " or "
          },
          {
            "type": "text",
            "text": "top_p",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " but not both in the same request. Combining them has unpredictable interactions and is rarely beneficial."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "When to Expose Temperature to Users"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Most applications should "
          },
          {
            "type": "text",
            "text": "not",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " expose temperature to end users. Hard-code a task-appropriate value and move on. Expose it only when:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The product is a developer playground or API explorer (users are expected to be technical)."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The core value proposition is creative generation where users legitimately want to tune randomness."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "A/B testing or prompt engineering workflows where reproducibility matters."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "If you do expose it, use a slider with labeled presets rather than a raw numeric input. Users understand "
          },
          {
            "type": "text",
            "text": "\"Precise / Balanced / Creative\"",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " but not 0.17 vs 0.83."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "React Temperature Slider Component"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// components/TemperatureControl.tsx\nimport { useState, useCallback } from \"react\";\n\nconst PRESETS = [\n  { label: \"Precise\",  value: 0.0, description: \"Code, facts, structured output\" },\n  { label: \"Balanced\", value: 0.5, description: \"Chat, summarisation, editing\" },\n  { label: \"Creative\", value: 1.0, description: \"Brainstorming, fiction, poetry\" },\n] as const;\n\ninterface Props {\n  value: number;\n  onChange: (value: number) => void;\n  disabled?: boolean;\n}\n\nexport function TemperatureControl({ value, onChange, disabled = false }: Props) {\n  const activePreset = PRESETS.find(p => Math.abs(p.value - value) < 0.05);\n\n  const handleSlider = useCallback(\n    (e: React.ChangeEvent<HTMLInputElement>) => {\n      onChange(parseFloat(e.target.value));\n    },\n    [onChange]\n  );\n\n  return (\n    <div className=\"temperature-control\" aria-label=\"Temperature setting\">\n      <div className=\"temperature-header\">\n        <span className=\"label\">Temperature</span>\n        <span className=\"value\">{value.toFixed(1)}</span>\n      </div>\n\n      <input\n        type=\"range\"\n        min={0}\n        max={1}\n        step={0.1}\n        value={value}\n        onChange={handleSlider}\n        disabled={disabled}\n        aria-valuemin={0}\n        aria-valuemax={1}\n        aria-valuenow={value}\n        aria-valuetext={activePreset?.label ?? `${value}`}\n      />\n\n      {/* Preset chips */}\n      <div className=\"presets\">\n        {PRESETS.map(preset => (\n          <button\n            key={preset.label}\n            className={`preset ${preset.value === value ? \"active\" : \"\"}`}\n            onClick={() => onChange(preset.value)}\n            disabled={disabled}\n            title={preset.description}\n          >\n            {preset.label}\n          </button>\n        ))}\n      </div>\n\n      {activePreset && (\n        <p className=\"description\">{activePreset.description}</p>\n      )}\n    </div>\n  );\n}\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Debouncing the Change Handler"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "If the slider triggers an API call on every movement, a user dragging from 0 to 1 fires 10 network requests. Debounce the API call while keeping the local UI state responsive:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// hooks/useDebouncedTemperature.ts\nimport { useState, useCallback, useRef } from \"react\";\n\nexport function useDebouncedTemperature(\n  initialValue: number,\n  onCommit: (value: number) => void,\n  delayMs = 400,\n) {\n  const [display, setDisplay] = useState(initialValue);\n  const timerRef = useRef<ReturnType<typeof setTimeout> | null>(null);\n\n  const handleChange = useCallback((value: number) => {\n    setDisplay(value);   // update slider immediately\n    if (timerRef.current) clearTimeout(timerRef.current);\n    timerRef.current = setTimeout(() => onCommit(value), delayMs);\n  }, [onCommit, delayMs]);\n\n  return [display, handleChange] as const;\n}\n\n// Usage in parent:\nconst [temperature, setTemperature] = useDebouncedTemperature(\n  0.5,\n  (t) => updateSetting(\"temperature\", t),\n);\n\n<TemperatureControl value={temperature} onChange={setTemperature} />\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Wiring Temperature to the Backend"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The API parameter name is "
          },
          {
            "type": "text",
            "text": "temperature",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " and it is passed directly to "
          },
          {
            "type": "text",
            "text": "messages.create()",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". Validate on the server to prevent out-of-range values."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# backend/schemas.py\nfrom pydantic import BaseModel, Field\n\nclass ChatRequest(BaseModel):\n    model: str = \"claude-3-5-haiku-20241022\"\n    max_tokens: int = Field(default=2048, ge=1, le=8096)\n    temperature: float = Field(default=0.5, ge=0.0, le=1.0)\n    top_p: float | None = Field(default=None, ge=0.0, le=1.0)\n    messages: list[dict]\n    system: str | None = None\n"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# backend/routes/chat.py\nasync def _generate(req: ChatRequest, user_id: str):\n    params = {\n        \"model\": req.model,\n        \"max_tokens\": req.max_tokens,\n        \"messages\": req.messages,\n        \"temperature\": req.temperature,\n    }\n    # Never set both temperature and top_p simultaneously\n    if req.top_p is not None and req.temperature == 1.0:\n        params[\"top_p\"] = req.top_p\n\n    if req.system:\n        params[\"system\"] = req.system\n\n    async with client.messages.stream(**params) as stream:\n        async for chunk in stream.text_stream:\n            yield f\"data: {json.dumps({'delta': chunk})}\\n\\n\"\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Persisting User Preferences"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Store the user's last-used temperature in localStorage so it survives page reloads. Use a thin wrapper to keep serialisation logic in one place."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// utils/userPrefs.ts\nconst PREFS_KEY = \"chat:prefs\";\n\ninterface ChatPrefs {\n  temperature: number;\n  model: string;\n}\n\nconst DEFAULTS: ChatPrefs = { temperature: 0.5, model: \"claude-3-5-haiku-20241022\" };\n\nexport function loadPrefs(): ChatPrefs {\n  try {\n    const raw = localStorage.getItem(PREFS_KEY);\n    return raw ? { ...DEFAULTS, ...JSON.parse(raw) } : DEFAULTS;\n  } catch {\n    return DEFAULTS;\n  }\n}\n\nexport function savePrefs(update: Partial<ChatPrefs>): void {\n  try {\n    const current = loadPrefs();\n    localStorage.setItem(PREFS_KEY, JSON.stringify({ ...current, ...update }));\n  } catch {\n    // localStorage may be blocked (private browsing, storage quota)\n  }\n}\n"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// In the settings panel:\nconst [prefs, setPrefs] = useState(loadPrefs);\n\nconst handleTempChange = useCallback((t: number) => {\n  setPrefs(p => ({ ...p, temperature: t }));\n  savePrefs({ temperature: t });\n}, []);\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Unit Tests for the Temperature Component"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// TemperatureControl.test.tsx\nimport { render, screen, fireEvent } from \"@testing-library/react\";\nimport { TemperatureControl } from \"./TemperatureControl\";\n\ndescribe(\"TemperatureControl\", () => {\n  it(\"renders slider with current value\", () => {\n    render(<TemperatureControl value={0.5} onChange={jest.fn()} />);\n    const slider = screen.getByRole(\"slider\");\n    expect(slider).toHaveValue(\"0.5\");\n  });\n\n  it(\"calls onChange when slider moves\", () => {\n    const handler = jest.fn();\n    render(<TemperatureControl value={0.5} onChange={handler} />);\n    fireEvent.change(screen.getByRole(\"slider\"), { target: { value: \"0.8\" } });\n    expect(handler).toHaveBeenCalledWith(0.8);\n  });\n\n  it(\"sets value via preset chip\", () => {\n    const handler = jest.fn();\n    render(<TemperatureControl value={0.5} onChange={handler} />);\n    fireEvent.click(screen.getByText(\"Creative\"));\n    expect(handler).toHaveBeenCalledWith(1.0);\n  });\n\n  it(\"shows description for active preset\", () => {\n    render(<TemperatureControl value={0.0} onChange={jest.fn()} />);\n    expect(screen.getByText(/Code, facts/)).toBeInTheDocument();\n  });\n});\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Backend Validation Tests"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# tests/test_temperature.py\nimport pytest\nfrom fastapi.testclient import TestClient\nfrom backend.main import app\n\n@pytest.mark.parametrize(\"temperature,expected_status\", [\n    (0.0, 200),\n    (0.5, 200),\n    (1.0, 200),\n    (1.1, 422),   # Pydantic rejects > 1\n    (-0.1, 422),  # Pydantic rejects < 0\n])\ndef test_temperature_validation(temperature, expected_status, mock_anthropic_stream, auth_headers):\n    with TestClient(app) as client:\n        resp = client.post(\"/v1/chat/completions\", json={\n            \"messages\": [{\"role\": \"user\", \"content\": \"hi\"}],\n            \"temperature\": temperature,\n        }, headers=auth_headers)\n        assert resp.status_code == expected_status\n"
