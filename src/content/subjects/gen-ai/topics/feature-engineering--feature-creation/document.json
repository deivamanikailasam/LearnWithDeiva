{"format": "tiptap/v1", "updatedAt": "2026-06-22T04:50:56.161Z", "doc": {"type": "doc", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Feature creation"}, {"type": "text", "text": " is the process of "}, {"type": "text", "marks": [{"type": "bold"}], "text": "generating entirely new features from existing data"}, {"type": "text", "text": " to capture complex relationships, non-linear patterns, or domain-specific insights that might not be apparent from the original variables alone, thereby improving model performance."}]}, {"type": "blockquote", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Simple definition:"}, {"type": "text", "text": " \"Feature creation is the process of developing new features from existing ones in order to capture complicated relationships and patterns in data.\""}]}]}, {"type": "horizontalRule"}, {"type": "image", "attrs": {"src": "data:image/svg+xml;base64,", "alt": "Feature Creation — concept overview"}}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Why feature creation matters"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Creating informative features is a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "significant step in improving model performance"}, {"type": "text", "text": " because:"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Benefit"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Description"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Captures complex relationships"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "New features can reveal synergistic effects between variables"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Domain-specific insights"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Incorporates expert knowledge about the problem domain"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Non-linear patterns"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Helps models capture non-linear relationships"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Deeper understanding"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Gives you deeper understanding of your data and more valuable insights"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Better accuracy"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Improves model training, leading to better performance and greater accuracy"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Feature creation acts as an "}, {"type": "text", "marks": [{"type": "bold"}], "text": "intermediary between raw data and the model"}, {"type": "text", "text": ", providing important features that help the model learn and make accurate predictions."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Key techniques for feature creation"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "1. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Interaction Features"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Combine two or more features to capture their "}, {"type": "text", "marks": [{"type": "bold"}], "text": "synergistic effects"}, {"type": "text", "text": "."}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Formula"}, {"type": "text", "text": ": \\[\nf"}, {"type": "text", "marks": [{"type": "italic"}], "text": "{\\text{interaction}} = f_1 \\times f_2\n\\]"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Example"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import pandas as pd\n\ndf = pd.DataFrame({\n    'price': [100, 150, 200],\n    'quantity': [2, 3, 4]\n})\n\n# Create interaction feature: total cost\ndf['total_cost'] = df['price'] * df['quantity']"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use case"}, {"type": "text", "text": ": Captures combined influence of features (e.g., price × quantity = total revenue)."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "2. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Polynomial Features"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Generate "}, {"type": "text", "marks": [{"type": "bold"}], "text": "higher-order terms"}, {"type": "text", "text": " from numerical features to help models capture "}, {"type": "text", "marks": [{"type": "bold"}], "text": "non-linear patterns"}, {"type": "text", "text": "."}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Formula"}, {"type": "text", "text": ":\n\\[\nf"}, {"type": "text", "marks": [{"type": "italic"}], "text": "{\\text{squared}} = f_1^2\n\\]"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Example"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "from sklearn.preprocessing import PolynomialFeatures\nimport numpy as np\n\nX = np.array([[1, 2], [3, 4], [5, 6]])\n\npoly = PolynomialFeatures(degree=2)\nX_poly = poly.fit_transform(X)\n\n# Output includes: x1, x2, x1^2, x2^2, x1*x2"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use case"}, {"type": "text", "text": ": Beneficial for linear algorithms to capture non-linear correlations between features and target."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "3. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Date/Time Feature Extraction"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Break down timestamp data into "}, {"type": "text", "marks": [{"type": "bold"}], "text": "useful components"}, {"type": "text", "text": " such as year, month, day of the week, or hour."}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Example"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "df['order_date'] = pd.to_datetime(df['order_date'])\n\n# Extract components\ndf['year'] = df['order_date'].dt.year\ndf['month'] = df['order_date'].dt.month\ndf['day_of_week'] = df['order_date'].dt.dayofweek\ndf['hour'] = df['order_date'].dt.hour\ndf['is_weekend'] = df['day_of_week'] >= 5"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use case"}, {"type": "text", "text": ": Reveals temporal patterns (e.g., sales peak on weekends, holiday effects)."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "4. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Binning (Discretization)"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Convert "}, {"type": "text", "marks": [{"type": "bold"}], "text": "continuous numerical data into discrete categorical bins"}, {"type": "text", "text": "."}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Example"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "df['age'] = [25, 35, 45, 55, 65]\n\n# Create age bins\ndf['age_bin'] = pd.cut(df['age'], bins=[0, 30, 40, 50, 100], \n                        labels=['young', 'adult', 'middle', 'senior'])"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use case"}, {"type": "text", "text": ": Captures specific patterns in certain ranges, reduces noise, handles non-linear relationships."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "5. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Arithmetic Operations"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Create new features by performing "}, {"type": "text", "marks": [{"type": "bold"}], "text": "simple calculations"}, {"type": "text", "text": " using existing features."}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Common operations"}, {"type": "text", "text": ":\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Sum"}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "code"}], "text": "df['total'] = df['col1'] + df['col2']"}, {"type": "text", "text": "\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Difference"}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "code"}], "text": "df['gap'] = df['col1'] - df['col2']"}, {"type": "text", "text": "\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Ratio"}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "code"}], "text": "df['ratio'] = df['col1'] / df['col2']"}, {"type": "text", "text": "\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Average"}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "code"}], "text": "df['avg'] = (df['col1'] + df['col2']) / 2"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Example"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "df['income_per_person'] = df['total_income'] / df['family_size']"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "6. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Aggregate Features"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Use functions to "}, {"type": "text", "marks": [{"type": "bold"}], "text": "summarize or aggregate data from multiple entries"}, {"type": "text", "text": " per entity."}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Example"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Customer-level aggregates\ncustomer_agg = df.groupby('customer_id').agg({\n    'purchase_amount': ['mean', 'sum', 'count'],\n    'purchase_date': 'min'  # First purchase\n})\n\ncustomer_agg.columns = ['avg_purchase', 'total_purchase', 'purchase_count', 'first_purchase']"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use case"}, {"type": "text", "text": ": Creates summary statistics (mean, sum, count, min, max) across entities."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "7. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Feature Scaling and Normalizing"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Modify the "}, {"type": "text", "marks": [{"type": "bold"}], "text": "distribution of features"}, {"type": "text", "text": " for specific algorithms."}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Techniques"}, {"type": "text", "text": ":\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Z-score normalization"}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "code"}], "text": "X_scaled = (X - mean) / std"}, {"type": "text", "text": "\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Min-max scaling"}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "code"}], "text": "X_scaled = (X - min) / (max - min)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Example"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "from sklearn.preprocessing import StandardScaler\n\nscaler = StandardScaler()\ndf['age_scaled'] = scaler.fit_transform(df[['age']])"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Feature creation vs. other feature engineering steps"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Feature creation is one step in the broader "}, {"type": "text", "marks": [{"type": "bold"}], "text": "feature engineering"}, {"type": "text", "text": " process:"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Step"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "What it does"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Feature Creation"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Generate new features by combining existing ones"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Feature Transformation"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use mathematical approaches to change feature values"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type"