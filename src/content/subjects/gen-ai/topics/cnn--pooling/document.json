{"format":"tiptap/v1","updatedAt":"2026-06-22T10:44:27.074Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What Pooling Is"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pooling"},{"type":"text","text":" is a data reduction operation in CNNs that compresses feature maps into a smaller, more manageable form by downsampleing their spatial dimensions. After convolutions extract detailed features (edges, textures), pooling summarizes this information while retaining the most important patterns and discarding less critical details."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why Pooling Matters in Generative AI"}]},{"type":"paragraph","content":[{"type":"text","text":"Pooling serves two primary purposes in CNNs:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Purpose"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Impact"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Dimensionality reduction"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Reduces computational complexity and shortens training time"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Feature extraction"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Improves generalization by reducing redundant information"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Key benefits for generative models:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Translation invariance"},{"type":"text","text":": Models recognize objects even when they appear in different positions/scales"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prevents overfitting"},{"type":"text","text":": By removing less critical details, pooling reduces overfitting"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Enables deeper networks"},{"type":"text","text":": Progressive down-sampling allows construction of more complex architectures"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Computational efficiency"},{"type":"text","text":": Fewer operations in subsequent layers, suitable for real-time applications"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How Pooling Works (Core Mechanics)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The operation:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Partition"},{"type":"text","text":": Divide each feature map into fixed-size regions (typically 2×2 pixels)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Apply pooling function"},{"type":"text","text":": Calculate a summary value for each region"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output"},{"type":"text","text":": Create a smaller pooled feature map"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Standard configuration:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pool size"},{"type":"text","text":": Almost always 2×2 pixels"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Stride"},{"type":"text","text":": 2 pixels (pooling windows don't overlap)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Effect"},{"type":"text","text":": Reduces each dimension by 2, making the feature map "},{"type":"text","marks":[{"type":"bold"}],"text":"1/4 the size"},{"type":"text","text":" (e.g., 6×6 → 3×3)"}]}]}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Input: 6×6 (36 pixels)  →  Output: 3×3 (9 pixels)"}]},{"type":"paragraph","content":[{"type":"text","text":"The pooling layer operates on each feature map separately, creating the same number of pooled feature maps."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Types of Pooling"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Max Pooling (Most Common)"}]},{"type":"paragraph","content":[{"type":"text","text":"Selects the "},{"type":"text","marks":[{"type":"bold"}],"text":"maximum value"},{"type":"text","text":" within each region as the output."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it does"},{"type":"text","text":": Preserves the strongest features (most prominent edges/textures)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Max pooling logic\npooled[k,l] = imag