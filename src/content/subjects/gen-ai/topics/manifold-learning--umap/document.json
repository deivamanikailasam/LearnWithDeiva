{"format":"tiptap/v1","updatedAt":"2026-06-22T04:28:19.459Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"In classical machine learning, "},{"type":"text","marks":[{"type":"bold"}],"text":"UMAP (Uniform Manifold Approximation and Projection)"},{"type":"text","text":" is a "},{"type":"text","marks":[{"type":"bold"}],"text":"nonlinear dimensionality reduction"},{"type":"text","text":" technique used to visualize and analyze high-dimensional data by embedding it into a 2D, 3D, or generally low-dimensional space while preserving both local neighborhoods and some global structure."}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Simple definition:"},{"type":"text","text":" “UMAP is a dimension reduction technique that can be used for "},{"type":"text","marks":[{"type":"bold"}],"text":"visualization similarly to t-SNE"},{"type":"text","text":", but also for "},{"type":"text","marks":[{"type":"bold"}],"text":"general non-linear dimension reduction"},{"type":"text","text":".”"}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What UMAP is and why it matters"}]},{"type":"paragraph","content":[{"type":"text","text":"Like t-SNE, UMAP helps humans understand "},{"type":"text","marks":[{"type":"bold"}],"text":"high-dimensional data"},{"type":"text","text":" (e.g., gene expression, image features, embeddings) by mapping it to 2D/3D."}]},{"type":"paragraph","content":[{"type":"text","text":"But UMAP is designed to:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Preserve "},{"type":"text","marks":[{"type":"bold"}],"text":"local structure"},{"type":"text","text":" (which points are neighbors)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Preserve "},{"type":"text","marks":[{"type":"bold"}],"text":"more global structure"},{"type":"text","text":" than t-SNE (how clusters relate to each other)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Scale to "},{"type":"text","marks":[{"type":"bold"}],"text":"much larger datasets"},{"type":"text","text":" efficiently"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"It’s widely used in:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Single-cell genomics"},{"type":"text","text":" (RNA-seq data)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Natural language processing"},{"type":"text","text":" (embedding visualization)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Image analysis"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Clustering and pre-processing"},{"type":"text","text":" for other ML tasks"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How UMAP works (conceptually)"}]},{"type":"paragraph","content":[{"type":"text","text":"UMAP is based on "},{"type":"text","marks":[{"type":"bold"}],"text":"three key assumptions"},{"type":"text","text":" about the data:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"The data is "},{"type":"text","marks":[{"type":"bold"}],"text":"uniformly distributed on a Riemannian manifold"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"bold"}],"text":"Riemannian metric is locally constant"},{"type":"text","text":" (or approximately so)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"The manifold is "},{"type":"text","marks":[{"type":"bold"}],"text":"locally connected"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"From these assumptions, UMAP:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Builds a high-dimensional graph"},{"type":"text","text":" of the data:"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- Each point is a node - Edges connect each point to its "},{"type":"text","marks":[{"type":"bold"}],"text":"nearest neighbors"},{"type":"text","text":" (k-nearest neighbors) - Edge weights represent how strong the similarity is"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Models the data as a "},{"type":"text","marks":[{"type":"bold"}],"text":"fuzzy topological structure"},{"type":"text","text":" on this graph:"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- This is a probabilistic representation of connectivity and similarity"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Constructs a low-dimensional graph"},{"type":"text","text":":"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- It searches for a low-dimensional embedding that has the "},{"type":"text","marks":[{"type":"bold"}],"text":"closest possible equivalent fuzzy topological structure"},{"type":"text","text":" to the high-dimensional one"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Optimizes this low-dimensional graph using "},{"type":"text","marks":[{"type":"bold"}],"text":"cross-entropy loss"},{"type":"text","text":":"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- The objective is to make the low-dimensional graph structurally similar to the high-dimensional graph"}]},{"type":"paragraph","content":[{"type":"text","text":"In simple terms:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"UMAP expresses relationships as a "},{"type":"text","marks":[{"type":"bold"}],"text":"graph"},{"type":"text","text":", then finds a low-dimensional embedding that preserves that graph’s structure as closely as possible."}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key properties of UMAP"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Nonlinear dimensionality reduction"}]},{"type":"paragraph","content":[{"type":"text","text":"UMAP is "},{"type":"text","marks":[{"type":"bold"}],"text":"nonlinear"},{"type":"text","text":", like t-SNE, and can capture complex, curved manifolds that linear methods (like PCA) cannot."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Preserves both local and global structure"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Local structure"},{"type":"text","text":": points that are close neighbors in high dimensions remain close in the low-dimensional map"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Global structure"},{"type":"text","text":": UMAP preserves "},{"type":"text","marks":[{"type":"bold"}],"text":"more of the overall geometry"},{"type":"text","text":" (e.g., relative positions of clusters) than t-SNE"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"This makes UMAP plots more interpretable globally: distances between clusters are "},{"type":"text","marks":[{"type":"bold"}],"text":"more meaningful"},{"type":"text","text":" than in t-SNE."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Fast and scalable"}]},{"type":"paragraph","content":[{"type":"text","text":"UMAP is "},{"type":"text","marks":[{"type":"bold"}],"text":"much faster"},{"type":"text","text":" than t-SNE and can scale to:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Millions of points"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Very high-dimensional data"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"This speed is a key reason UMAP has become the industry standard in many domains (e.g., single-cell data)."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Out-of-sample transform"}]},{"type":"paragraph","content":[{"type":"text","text":"UMAP supports "},{"type":"text","marks":[{"type":"bold"}],"text":"transforming new data points"},{"type":"text","text":" into the existing embedding without recomputing everything:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"You can train UMAP on a large dataset"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Then embed new points by mapping them into the same low-dimensional space"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"t-SNE does "},{"type":"text","marks":[{"type":"bold"}],"text":"not"},{"type":"text","text":" support this; you must recompute the entire embedding for new data."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"UMAP in Classical Machine Learning (not Generative AI)"}]},{"type":"paragraph","content":[{"type":"text","text":"In "},{"type":"text","marks":[{"type":"bold"}],"text":"classical machine learning"},{"type":"text","text":", UMAP is used as a:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Visualization tool"},{"type":"text","text":": to explore clusters and structure in high-dimensional data"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Preprocessing step"},{"type":"text","text":": for tasks like clustering, classification, or anomaly detection"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Manifold learning method"},{"type":"text","text":": to capture nonlinear structure before applying other models"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Common use cases:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Visualizing "},{"type":"text","marks":[{"type":"bold"}],"text":"single-cell RNA-seq"},{"type":"text","text":" clusters"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Visualizing "},{"type":"text","marks":[{"type":"bold"}],"text":"word embeddings"},{"type":"text","text":" or document embeddings"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Preprocessing for "},{"type":"text","marks":[{"type":"bold"}],"text":"clustering"},{"type":"text","text":" (e.g., cluster after UMAP reduces dimensions)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Exploring "},{"type":"text","marks":[{"type":"bold"}],"text":"deep learning embeddings"},{"type":"text","text":" (e.g., from neural networks)"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"UMAP is "},{"type":"text","marks":[{"type":"bold"}],"text":"not a predictive model"},{"type":"text","text":"; it’s a "},{"type":"text","marks":[{"type":"bold"}],"text":"dimensionality reduction and analysis tool"},{"type":"text","text":"."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"UMAP vs. t-SNE (core differences)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"t-SNE"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"UMAP"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Philosophy"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Probability matching (Gaussian → t-distribution)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Graph-based (preserves a k-NN graph)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Loss function"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"KL divergence"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Cross-entropy"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Speed"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Slow; not scalable to large datasets"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Fast; scales to millions of points"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Global structure"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Poor; distances between clusters are meaningless"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Better; preserves some global geometry"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"New data"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No out-of-sample transform; must recompute"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Supports out-of-sample transform"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Interpretability"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Only local neighborhoods are trustworthy"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Local + some global structure more meaningful"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use in practice"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Good for fine-grain local clusters"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Preferred for large-scale workflows and general use"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Intuition:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"t-SNE"},{"type":"text","text":": “What is the probability that point A would choose point B as a neighbor?” → matches probabilities between high-D and low-D"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"UMAP"},{"type":"text","text":": “How strong is the edge between A and B in this graph?” → preserves graph structure via cross-entropy"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"For most modern workflows (e.g., single-cell genomics, large embedding visualization), "},{"type":"text","marks":[{"type":"bold"}],"text":"UMAP has largely replaced t-SNE"},{"type":"text","text":" due to its speed and better global structure preservation."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"UMAP"},{"type":"text","text":" is a "},{"type":"text","marks":[{"type":"bold"}],"text":"nonlinear dimensionality reduction"},{"type":"text","text":" method for visualizing and analyzing high-dimensional data while preserving local neighborhoods and some global structure."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"It builds a "},{"type":"text","marks":[{"type":"bold"}],"text":"high-dimensional graph"},{"type":"text","text":" of nearest neighbors and then finds a low-dimensional embedding that preserves this graph’s structure using "},{"type":"text","marks":[{"type":"bold"}],"text":"cross-entropy"},{"type":"text","text":"."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"UMAP is "},{"type":"text","marks":[{"type":"bold"}],"text":"fast"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"bold"}],"text":"scalable"},{"type":"text","text":", and supports "},{"type":"text","marks":[{"type":"bold"}],"text":"out-of-sample transform"},{"type":"text","text":", unlike t-SNE."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"In "},{"type":"text","marks":[{"type":"bold"}],"text":"classical ML"},{"type":"text","text":", UMAP is used for "},{"type":"text","marks":[{"type":"bold"}],"text":"visualization, clustering preprocessing, and manifold learning"},{"type":"text","text":", not as a predictive model."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Compared to t-SNE, UMAP preserves "},{"type":"text","marks":[{"type":"bold"}],"text":"more global structure"},{"type":"text","text":", is faster, and is more practical for large-scale workflows, making it the modern standard in many domains."}]}]}]},{"type":"paragraph"}]}}
