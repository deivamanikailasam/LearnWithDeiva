{"format":"tiptap/v1","updatedAt":"2026-06-21T14:02:41.102Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"A "},{"type":"text","marks":[{"type":"bold"}],"text":"graph"},{"type":"text","text":" is a non-linear data structure consisting of "},{"type":"text","marks":[{"type":"bold"}],"text":"vertices (nodes)"},{"type":"text","text":" connected by "},{"type":"text","marks":[{"type":"bold"}],"text":"edges (links)"},{"type":"text","text":", representing objects and their relationships. Unlike trees (hierarchical, parent-child), graphs can have "},{"type":"text","marks":[{"type":"bold"}],"text":"any connection pattern"},{"type":"text","text":" (cyclic, disconnected, multi-directional), making them ideal for modeling complex relationships in Gen AI like knowledge graphs, social networks, recommendation systems, and semantic reasoning—critical for reducing hallucinations and enabling context-aware AI responses."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Graph"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tree"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Array/Linked List"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Structure"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Non-linear, arbitrary connections"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Hierarchical (parent-child)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Linear (sequential)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Root"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No root (any node can start)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Single root (topmost)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"First/last element"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cycles"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Can have cycles (A→B→A)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No cycles (strict hierarchy)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No cycles"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Edges"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Directed or undirected"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Parent→child only (directed)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Next element only"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Connections"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Any node to any node"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Parent to children only"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Sequential only"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Real-world"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Social networks, maps, knowledge graphs "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://www.ey.com/en_us/insights/emerging-technologies/using-knowledge-graphs-to-unlock-genai-at-scale","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"ey"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"File systems, XML/JSON"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Lists, queues"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why It Matters for Gen AI"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ❌ WITHOUT graph: Flat data, no relationships (hallucinations)\nknowledge = {\n    \"apple\": \"fruit\",\n    \"banana\": \"fruit\",\n    \"car\": \"vehicle\"\n}\n# Query: \"What connects apple and car?\"\n# ❌ AI can't find relationship (hallucinates: \"Apple Cars exist?\") [web:131]\n\n# ✅ WITH graph: Structured relationships (reduces hallucinations)\n# Knowledge Graph:\n#   apple ──eaten_by── human\n#   car ──driven_by── human\n#   human ──owns── car\n# Query: \"What connects apple and car?\"\n# ✅ AI finds: \"Both connected to human\" (accurate, grounded) [web:128][web:131]\n\nclass Node:\n    def __init__(self, value):\n        self.value = value  # Entity (e.g., \"human\")\n        self.neighbors = []  # Connected nodes (edges) [web:130]\n\nclass Graph:\n    def __init__(self):\n        self.nodes = {}  # {value: Node} [web:130]\n    \n    def add_node(self, value):\n        if value not in self.nodes:\n            self.nodes[value] = Node(value)\n    \n    def add_edge(self, val1, val2, relationship):\n        self.add_node(val1)\n        self.add_node(val2)\n        # ✅ Edge with relationship (e.g., \"eaten_by\")\n        self.nodes[val1].neighbors.append((val2, relationship))\n        self.nodes[val2].neighbors.append((val1, relationship))  # ✅ Undirected\n\n# Build knowledge graph\ngraph = Graph()\ngraph.add_edge(\"apple\", \"human\", \"eaten_by\")  # ✅ apple → human\ngraph.add_edge(\"car\", \"human\", \"driven_by\")  # ✅ car → human [web:128][web:130]\n\n# Query: Find connection between apple and car\ndef find_connection(graph, start, end):\n    from collections import deque\n    queue = deque([(start, [start])])  # ✅ BFS: (node, path)\n    visited = set()\n    \n    while queue:\n        node, path = queue.popleft()\n        if node == end:\n            return path  # ✅ Found: [\"apple\", \"human\", \"car\"]\n        if node not in visited:\n            visited.add(node)\n            for neighbor, rel in graph.nodes[node].neighbors:\n                queue.append((neighbor, path + [neighbor]))  # ✅ BFS [web:130]\n    return None\n\nconnection = find_connection(graph, \"apple\", \"car\")\nprint(connection)  # ✅ [\"apple\", \"human\", \"car\"] (both connected to human) [web:130][web:131]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Reduce hallucinations"},{"type":"text","text":": Ground AI in structured relationships "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://www.ey.com/en_us/insights/emerging-technologies/using-knowledge-graphs-to-unlock-genai-at-scale","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"ey"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Context-aware"},{"type":"text","text":": Enable semantic reasoning across entities\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Relationship modeling"},{"type":"text","text":": Social networks, recommendations, fraud detection\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Advanced architectures"},{"type":"text","text":": Graph RAG (GraphRAG), Knowledge-augmented generation (KAG), Graph Neural Networks (GNNs)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How It Works (Core Components)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Graph Terminology"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Graph structure:\n#   A ──edge── B\n#   │         │\n#   edge    edge\n#   │         │\n#   C ──edge── D\n\n# ✅ Key terms:\n# - Vertex/Node: Object (A, B, C, D) [web:130]\n# - Edge: Relationship between nodes (A-B, B-D) [web:130]\n# - Directed edge: A→B (one-way, e.g., \"follows\") [web:130]\n# - Undirected edge: A-B (two-way, e.g., \"friend\") [web:130]\n# - Weighted edge: A─5─B (edge has value, e.g., distance) [web:130]\n# - Path: Sequence of edges (A→B→D) [web:130]\n# - Cycle: Path that returns to start (A→B→C→A) [web:130]\n# - Degree: Number of edges at node (A has degree 2) [web:130]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Graph Representation: Adjacency List"},{"type":"text","text":" ⭐ Most Common"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Adjacency list: {node: [neighbors]} (efficient for sparse graphs)\ngraph = {\n    \"A\": [\"B\", \"C\"],  # ✅ A connected to B, C\n    \"B\": [\"A\", \"D\"],  # ✅ B connected to A, D\n    \"C\": [\"A\", \"D\"],  # ✅ C connected to A, D\n    \"D\": [\"B\", \"C\"]   # ✅ D connected to B, C\n}  # [web:130]\n\n# ✅ Space: O(V + E) where V = vertices, E = edges [web:130]\n# ✅ Efficient for sparse graphs (few edges per node) [web:130]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Graph Representation: Adjacency Matrix"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Adjacency matrix: 2D array [V][V] (fast lookup, memory-heavy)\n#   A B C D\n# A 0 1 1 0  # ✅ A connected to B (1), C (1)\n# B 1 0 0 1  # ✅ B connected to A (1), D (1)\n# C 1 0 0 1  # ✅ C connected to A (1), D (1)\n# D 0 1 1 0  # ✅ D connected to B (1), C (1)\n\nmatrix = [\n    [0, 1, 1, 0],  # A\n    [1, 0, 0, 1],  # B\n    [1, 0, 0, 1],  # C\n    [0, 1, 1, 0]   # D\n]  # [web:130]\n\n# ✅ Space: O(V²) (memory-heavy for large graphs) [web:130]\n# ✅ Fast lookup: O(1) check if edge exists [matrix[i][j] == 1] [web:130]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Breadth-First Search (BFS)"},{"type":"text","text":" ⭐ O(V + E)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ BFS: Explore level-by-level (shortest path in unweighted graphs)\nfrom collections import deque\n\ndef bfs(graph, start):\n    queue = deque([start])  # ✅ Queue for BFS\n    visited = set([start])\n    \n    while queue:\n        node = queue.popleft()  # ✅ Dequeue (FIFO)\n        print(node)  # ✅ Visit node\n        for neighbor in graph[node]:  # ✅ Visit neighbors\n            if neighbor not in visited:\n                visited.add(neighbor)\n                queue.append(neighbor)  # ✅ Enqueue [web:130]\n\nbfs(graph, \"A\")  # ✅ A → B → C → D (level-by-level) [web:130]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Depth-First Search (DFS)"},{"type":"text","text":" ⭐ O(V + E)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ DFS: Explore deeply first (backtracking, cycle detection)\ndef dfs(graph, start, visited=None):\n    if visited is None:\n        visited = set()\n    \n    visited.add(start)  # ✅ Visit node\n    print(start)\n    \n    for neighbor in graph[start]:  # ✅ Visit neighbors\n        if neighbor not in visited:\n            dfs(graph, neighbor, visited)  # ✅ Recurse (stack)\n\ndfs(graph, \"A\")  # ✅ A → B → D → C (deep-first) [web:130]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Directed Graph (Digraph)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Directed: A→B (one-way, not B→A)\ndirected_graph = {\n    \"A\": [\"B\"],  # ✅ A → B\n    \"B\": [\"C\"],  # ✅ B → C\n    \"C\": []      # ✅ C has no outgoing edges\n}  # [web:130]\n\n# ✅ Use case: Follow relationships (Twitter: A follows B, but B doesn't follow A) [web:130]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"7. "},{"type":"text","marks":[{"type":"bold"}],"text":"Weighted Graph"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Weighted: Edges have values (distance, cost)\nweighted_graph = {\n    \"A\": [(\"B\", 5), (\"C\", 3)],  # ✅ A→B (cost 5), A→C (cost 3)\n    \"B\": [(\"A\", 5), (\"D\", 2)],  # ✅ B→A (cost 5), B→D (cost 2)\n    \"C\": [(\"A\", 3), (\"D\", 1)],  # ✅ C→A (cost 3), C→D (cost 1)\n    \"D\": [(\"B\", 2), (\"C\", 1)]   # ✅ D→B (cost 2), D→C (cost 1)\n}  # [web:130]\n\n# ✅ Use case: Map routing (shortest path with Dijkstra's algorithm) [web:130]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use (Decision Criteria)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Graph"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Tree"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Hash Table"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Complex relationships"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Social networks, knowledge graphs "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://www.ey.com/en_us/insights/emerging-technologies/using-knowledge-graphs-to-unlock-genai-at-scale","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"ey"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Hierarchical only"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Flat"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cyclic data"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ A→B→A cycles"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ No cycles"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ No structure"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Shortest path"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Maps, routing (BFS/Dijkstra)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Limited"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ No paths"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Recommendation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ \"Users who liked X also liked Y\""}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Hierarchical"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Flat"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hierarchical data"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Possible (but overkill)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ File systems, XML"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Flat"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fast lookup"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ O(V + E) search"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ O(log n) BST"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ O(1) hash"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Knowledge grounding"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ KGs reduce hallucinations "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://www.ey.com/en_us/insights/emerging-technologies/using-knowledge-graphs-to-unlock-genai-at-scale","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"ey"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Limited"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ No relationships"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rule of thumb:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Graph"},{"type":"text","text":": Complex relationships + cycles + shortest paths (social networks, knowledge graphs, recommendations) "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://www.ey.com/en_us/insights/emerging-technologies/using-knowledge-graphs-to-unlock-genai-at-scale","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"ey"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Tree"},{"type":"text","text":": Hierarchical data (file systems, XML/JSON)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Hash Table"},{"type":"text","text":": Fast O(1) lookup (no relationships needed)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Gen AI Applications"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Knowledge Graphs (KGs)"},{"type":"text","text":" ⭐ Critical for Reducing Hallucinations"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Knowledge Graph: Structure domain knowledge\n# Query: \"What is photosynthesis?\"\n# KG: plant ──performs── photosynthesis ──produces── oxygen\n# ✅ AI grounded in KG = accurate, no hallucinations [web:128][web:131]\n\n# Architecture: Graph RAG (GraphRAG)\n# Frontend → Graph Query → KG → Prompt Augmentation → LLM → Response\n# Benefits:\n# - Ground AI in real-world knowledge [web:128]\n# - Reduce hallucinations by verifying facts [web:131]\n# - Enable context-aware responses [web:135]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Graph Neural Networks (GNNs)"},{"type":"text","text":" ⭐ ML on Graphs"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ GNN: Learn patterns directly from graph structure\n# Use case: Social network recommendations, fraud detection [web:133]\n\n# GNN architecture:\n# Input: Graph (nodes + edges)\n# Layer 1: Aggregate neighbor features\n# Layer 2: Combine with node features\n# Output: Node classification / graph prediction [web:133]\n\n# Example: Predict user role in social network\n# Graph: user ──follows── user ──posts── content\n# GNN learns: Users who follow X also post Y → recommend Y [web:130][web:133]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Recommendation Systems"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Bipartite graph: Users ──likes── Items\n# User A ──likes── Movie X\n# User A ──likes── Movie Y\n# User B ──likes── Movie X\n# Query: \"What should User B watch?\"\n# ✅ Graph finds: User B → Movie X → User A → Movie Y → Recommend Movie Y [web:130]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Fraud Detection"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Multipartite graph: Detect fraud patterns\n# User ──has── Phone Number ──used_by── User ──has── Phone Number\n# Fraud pattern: Same phone used by multiple users → flag as fraud [web:130]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Time Complexity"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Operation"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Graph (Adjacency List)"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Graph (Adjacency Matrix)"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tree (BST)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"BFS/DFS"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(V + E)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(V²)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(V)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Shortest path (BFS)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(V + E)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(V²)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"N/A"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph