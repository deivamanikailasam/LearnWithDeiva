Timing & Performance"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# %time: Time single execution\n%time sum(range(1000))  # Output: Wall time: 0.000123 sec\n\n# %timeit: Time multiple executions (best practice)\n%timeit sum(range(1000))  # Output: 27.5 µs per loop (100000 loops)\n\n# With function\ndef my_func(x):\n    return x ** 2\n\n%timeit my_func(100)  # Time function execution"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"File System Commands"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# %ls: List files in directory\n%ls\n\n# %ls with wildcards\n%ls *.txt\n\n# %pwd: Show current working directory\n%pwd  # Output: /content\n\n# %cd: Change directory\n%cd /content/data\n\n# %mkdir: Create directory\n%mkdir new_folder\n\n# %cat: View file contents\n%cat file.txt"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Debugging Tools"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# %debug: Interactive debugger after error\n%debug  # Runs pdb after exception\n\n# %pdb: Enable automatic debugging\n%pdb on  # Automatically enter debugger on error\n\n# %who: List variables in namespace\n%who\n\n# %whos: Detailed variable info\n%whos  # Shows name, type, value"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Import & Extension Management"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# %matplotlib inline: Show plots in notebook\n%matplotlib inline\n\n# %autoreload: Reload modules automatically\n%load_ext autoreload\n%autoreload 2  # Reload before executing each line\n\n# %load_ext: Load extension\n%load_ext memory_profiler\n\n# %reload_ext: Reload extension\n%reload_ext autoreload"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Shell/System Commands"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# %ls: List files (same as !ls)\n%ls\n\n# %pwd: Print working directory\n%pwd\n\n# %cd: Change directory\n%cd /path/to/dir\n\n# %env: Set environment variable\n%env MY_VAR=value\n\n# %history: Show command history\n%history"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Essential Cell Magics ("},{"type":"text","marks":[{"type":"code"}],"text":"%%"},{"type":"text","text":")"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Timing & Profiling"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# %%time: Time entire cell\n%%time\nsum(range(1000))\nsum(range(2000))\n# Output: Executes all code, times total\n\n# %%timeit: Time entire cell multiple times\n%%timeit\nsum(range(1000))"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"File Operations"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# %%writefile: Write cell contents to file\n%%writefile hello.py\nprint(\"Hello, World!\")\n# Creates hello.py with the code\n\n# %%capture: Capture output to variable\n%%capture output\nprint(\"This won't show\")\nprint(\"This won't show either\")\n# output.text contains captured output\n\n# %%file: Same as %%writefile\n%%file notebook.md\n# This is markdown content"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Running Other Languages"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# %%bash: Run bash commands\n%%bash\necho \"Hello from bash\"\nls -la\n\n# %%script python3: Run Python 3 code\n%%script python3\nprint(\"Running in separate Python process\")\n\n# %%sh: Run shell commands\n%%sh\npwd\nls\n\n# %%html: Render HTML\n%%html\n<h1>Hello World</h1>\n<p>This is HTML</p>\n\n# %%javascript: Run JavaScript\n%%javascript\nconsole.log(\"Hello JavaScript\")"}]},{"type":"heading","attrs":{"level":3},"