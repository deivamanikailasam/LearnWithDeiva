anches"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"main"},{"type":"text","text":" only; features as "},{"type":"text","marks":[{"type":"code"}],"text":"feat/<ticket>"},{"type":"text","text":"."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PRs"},{"type":"text","text":":"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- All changes via PR. - 1–2 approvals + CI required.\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Local workflow"},{"type":"text","text":": - Rebase feature branch onto "},{"type":"text","marks":[{"type":"code"}],"text":"main"},{"type":"text","text":" before opening PR. - Use "},{"type":"text","marks":[{"type":"code"}],"text":"rebase -i"},{"type":"text","text":" to squash WIP commits.\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Merge"},{"type":"text","text":": - Use "},{"type":"text","marks":[{"type":"bold"}],"text":"merge commit"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"bold"}],"text":"squash merge"},{"type":"text","text":" in GitHub. - No rebase into "},{"type":"text","marks":[{"type":"code"}],"text":"main"},{"type":"text","text":" from shared branches."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"11. Common Mistakes"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Rebasing shared branches that others use."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Using "},{"type":"text","marks":[{"type":"code"}],"text":"git push --force"},{"type":"text","text":" without "},{"type":"text","marks":[{"type":"code"}],"text":"--force-with-lease"},{"type":"text","text":"."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Huge PRs with multiple unrelated features."}]}]},{"type":"listItem","content":[{"t