{"format":"tiptap/v1","updatedAt":"2026-06-22T09:18:41.634Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What FP16 & BF16 Are"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"FP16 (Float 16-bit)"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"bold"}],"text":"BF16 (Brain Float 16-bit)"},{"type":"text","text":" are two lower-precision numerical formats used in "},{"type":"text","marks":[{"type":"bold"}],"text":"mixed precision training"},{"type":"text","text":" to accelerate deep learning model training and reduce memory footprint."}]},{"type":"paragraph","content":[{"type":"text","text":"Instead of using traditional "},{"type":"text","marks":[{"type":"bold"}],"text":"FP32 (32-bit float)"},{"type":"text","text":" everywhere, mixed precision training strategically uses:\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"FP16/BF16"},{"type":"text","text":": For compute-intensive forward and backward passes\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"FP32"},{"type":"text","text":": For critical operations like loss scaling, optimizer states, and master weights"}]},{"type":"paragraph","content":[{"type":"text","text":"This hybrid approach delivers "},{"type":"text","marks":[{"type":"bold"}],"text":"1.5 to 3 times training speedup"},{"type":"text","text":" on modern accelerators while preserving convergence."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"FP16 vs BF16: Key Differences"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"FP16"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"col