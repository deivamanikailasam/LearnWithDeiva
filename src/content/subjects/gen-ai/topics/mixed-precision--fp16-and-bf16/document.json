recision training"},{"type":"text","text":" uses multiple numerical data types (precisions) in the same training process to achieve:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Benefit"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Impact"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Lower memory footprint"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"16-bit values occupy half the memory of 32-bit values"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Higher computational speed"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tensor Cores perform 16-bit ops much faster than 32-bit"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Larger batch sizes"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Memory savings enable 1.5 to 2 times larger batches"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Preserved accuracy"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"FP32 master weights prevent accuracy loss"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"1.5–3x speedup"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"End-to-end training acceleration"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How it works"},{"type":"text","text":":\n1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Store master weights in FP32"},{"type":"text","text":"\n2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Cast to FP16/BF16"},{"type":"text","text":" for forward and backward passes\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Accumulate gradients in FP32"},{"type":"text","text":"\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Update weights in FP32"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"FP16 Challenges and Solutions"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Challenge 1: Limited Exponent Range"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"FP16 has only 5 exponent bits"},{"type":"text","text":", meaning it can encode numbers between -65K and +65K."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem"},{"type":"text","text":": Small gradients can "},{"type":"text","marks":[{"type":"bold"}],"text":"underflow to zero"},{"type":"text","text":" (become 0), causing training to stall."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Solution: Dynamic Loss Scaling"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Loss scaling"},{"type":"text","text":" multiplies the loss by a factor (e.g., 1024) before backpropagation:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# FP16 mixed precision with loss scaling\nloss = model(input) * loss_scale  # Scale loss [web:253]\nloss.backward()  # Gradients shifted into FP16 range\noptimizer.step()  # Unscale before optimizer update [web:253]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Dynamic loss scaling approach"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Start"},{"type":"text","text":" with scale like 1024\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Increase"},{"type":"text","text":" by 2x every N steps if no overflow\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Halve"},{"type":"text","text":" immediately on NaN or Inf detection\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Adapts"},{"type":"text","text":" to gradient magnitude changes"}]},{"type":"paragraph","content":[{"type":"text","text":"This shifts gradients into FP16's representable range, then unscales before the optimizer step."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"BF16 Advantages"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Exponent Range Matches FP32"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"BF16 has 8 exponent bits"},{"type":"text","text":" (same as FP32), giving it the same dynamic range of 1e-38 to 3e38."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Eliminates most underflow issues"},{"type":"text","text":" without loss scaling\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Improves stability"},{"type":"text","text":" in transformer training where activation magnitudes vary widely\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Requires no hyperparameter changes"},{"type":"text","text":" from FP32 in most cases"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Hardware Support"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"BF16 is natively supported by"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"NVIDIA Ampere and newer GPUs"},{"type":"text","text":" (A100, H100)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Google TPUs"},{"type":"text","text":" (default for large model training)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Intel chips"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"FP16 vs BF16 Performance"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"NVIDIA A100 Tensor Cores"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Format"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Throughput vs FP32"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Case"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"FP16"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Up to 16x higher"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Smaller models, older GPUs"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"BF16"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Similar to FP16"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Large models, transformers"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"FP32"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Baseline"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Baseline computation"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Tensor Cores provide up to "},{"type":"text","marks":[{"type":"bold"}],"text":"16 times higher FP16 throughput"},{"type":"text","text":" versus FP32 on A100 GPUs."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mixed Precision Training in PyTorch"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Using Automatic Mixed Precision (AMP)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import torch\n\nmodel = MyModel().float()  # Load in FP32 (required for autocast) [web:254]\noptimizer = torch.optim.Adam(model.parameters(), lr=0.001)\n\n# AMP scaler for FP16\nscaler = torch.cuda.amp.GradScaler()\n\nfor input, target in dataset:\n    input = input.to('cuda')\n    target = target.to('cuda')\n    \n    # Use autocast for FP16/BF16\n    with torch.cuda.amp.autocast(device_type='cuda', dtype=torch.bfloat16):  # BF16 [web:254]\n        output = model(input)\n        loss = compute_loss(output, target)\n    \n    # Backward with scaler\n    scaler.scale(loss).backward()\n    \n    # Optimizer step with unscale\n    scaler.step(optimizer)\n    \n    # Update scaler\n    scaler.update()"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Load Model in FP32"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# WRONG: Loading in BF16/FP16 leaves no FP32 master copy\nmodel = MyModel().bfloat16()  # ERROR for mixed precision [web:254]\n\n# RIGHT: Load in FP32 for autocast to work\nmodel = MyModel().float()  # Correct for mixed precision [web:254]"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mixed Precision Training in TensorFlow"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Using Mixed Precision API"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import tensorflow as tf\n\n# Set mixed precision policy\npolicy = tf.keras.mixed_precision.Policy('mixed_bfloat16')  # or 'mixed_float16' [web:254]\ntf.keras.mixed_precision.set_global_policy(policy)\n\n# Load model in FP32\nmodel = MyModel()  # Automatically uses FP32 master weights [web:254]\nmodel.compile(optimizer='adam', loss='mse')\n\n# Training\nmodel.fit(train_data, train_labels, epochs=10)  # Auto uses BF16/FP16 [web:254]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Set BF16 or FP16"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Enable BF16 mixed precision\ntf.keras.mixed_precision.set_global_policy('mixed_bfloat16')  # BF16 [web:254]\n\n# Enable FP16 mixed precision\ntf.keras.mixed_precision.set_global_policy('mixed_float16')   # FP16 [web:254]"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"When to Use FP16 vs BF16"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Use BF16 When:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hardware supports it"},{"type":"text","text":" (A100, H100, MI300)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Training LLMs"},{"type":"text","text":" (LLAMA 3, large transformers)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Long sequences"},{"type":"text","text":" with large embeddings"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Transformer training"},{"type":"text","text":" (activation magnitudes vary widely)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Want stability"},{"type":"text","text":" without hyperparameter tuning"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"LLAMA 3 models trained with NVIDIA NeMo leverage BF16"},{"type":"text","text":" due to its higher exponent range matching FP32, making it safer for LLMs."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Use FP16 When:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Older GPUs"},{"type":"text","text":" (V100, T4)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hardware doesn't support BF16"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Smaller models"},{"type":"text","text":" where underflow is less likely"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Need slight throughput advantage"},{"type":"text","text":" on some hardware"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fallback to FP16"},{"type":"text","text":" on older hardware like V100 or T4 if BF16 not supported."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Use BF16 Over FP16 When Possible"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Recommendation: Use BF16 if your hardware supports it\nReason: Safer due to better exponent range (matches FP32)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Always Use AMP O2 Level for Training"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Balance of speed, stability, and accuracy"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Monitor Loss Scaling Regularly"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Avoid NaNs or zero gradients"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Keep Sensitive Operations in FP32"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Layer normalization, softmax, loss computation kept in FP32\n# Avoid numerical instability from reduced precision [web:253]\nwith torch.cuda.amp.autocast(dtype=torch.bfloat16):\n    output = model(input)\n    # Sensitive ops can be kept in FP32"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. Memory Savings Enable Larger Batches"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"FP16 halves activation memory → batch size increase from 32 to 64\nCan improve throughput by 1.3 to 1.5 times if compute bound"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Challenges by Precision"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Challenge"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"FP16"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"BF16"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Underflow"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Small gradients → zero"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Rare (large exponent range)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Overflow"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Possible (limited range)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Rare (FP32 range)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":