: "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "TPR"}, {"type": "text", "text": " = True Positive Rate = Recall = Sensitivity = TP/(TP+FN)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "FPR"}, {"type": "text", "text": " = False Positive Rate = FP/(FP+TN) = 1 - Specificity"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "AUC"}, {"type": "text", "text": " = Area under ROC curve, single number summarizing performance"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "AUC = 1.0"}, {"type": "text", "text": ": Perfect (100% probability positive > negative)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "AUC = 0.5"}, {"type": "text", "text": ": Random guessing (useless model)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "AUC < 0.5"}, {"type": "text", "text": ": Worse than random (predictions reversed)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Threshold-invariant"}, {"type": "text", "text": ": Doesn't depend on specific threshold"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Best for"}, {"type": "text", "text": ": Model comparison, imbalanced data, overall performance"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use probabilities"}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "code"}], "text": "roc_auc_score(y_true, y_pred_prob)"}, {"type": "text", "text": ", not binary predictions"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Smallest variance"}, {"type": "text", "text": ": Best for ranking models"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "ROC-AUC is the \"threshold-independent judge\" — by plotting model performance across all possible thresholds and measuring the area under that curve, it provides a single number representing the probability that the model will rank a random positive higher than a random negative, making it ideal for model comparison and imbalanced datasets where specific threshold metrics like Precision/Recall might be misleading."}]}]}}