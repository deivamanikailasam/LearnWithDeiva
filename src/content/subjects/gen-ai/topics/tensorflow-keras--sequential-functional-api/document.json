"type":"bold"}],"text":"factory assembly line"},{"type":"text","text":":"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Input → Station 1 → Station 2 → Station 3 → Output"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Everything flows in one straight line"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Simple, predictable, but can't branch"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Think of "},{"type":"text","marks":[{"type":"bold"}],"text":"Functional"},{"type":"text","text":" as a "},{"type":"text","marks":[{"type":"bold"}],"text":"neural network diagram"},{"type":"text","text":":"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"You draw arrows between any nodes"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Multiple inputs can feed into one layer"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"One layer can output to multiple branches"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Skip connections feed data back forward"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Full control over the graph structure"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sequential API"},{"type":"text","text":" = Linear stack of layers (one input → layers → one output)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Functional API"},{"type":"text","text":" = Arbitrary graph of layers (multiple inputs/outputs, skip connections, shared layers)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sequential creation"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"keras.Sequential([layer1, layer2,...])"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"code"}],"text":".add()"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Functional creation"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"keras.Model(inputs=input, outputs=output)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sequential limitation"},{"type":"text","text":": Single input/output only, no branching"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Functional strength"},{"type":"text","text":": \"Industry strength\" for complex architectures"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"For generative AI"},{"type":"text","text":": Use Functional for complex models (StyleGAN, diffusion U-Net, transformers)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Both compile/train same way"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":".compile()"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":".fit()"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":".evaluate()"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":".predict()"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Functional API is recommended"},{"type":"text","text":" for most production use cases"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sequential is beginner-friendly"},{"type":"text","text":" for simple problems"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Both APIs create Keras models that behave identically once built, but Functional API's flexibility is essential for modern generative AI architectures."}]}]}}
