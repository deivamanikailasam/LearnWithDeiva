s": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Vector (m numbers)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Matrix"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "m√ón"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Sensitivity of all outputs to all inputs"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Hessian"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Scalar (1 number)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Matrix"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "n√ón"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Curvature of the function"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Key insight"}, {"type": "text", "text": ": Jacobian generalizes gradient to vector-valued functions; Hessian generalizes derivative to second-order"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Why it matters ‚ÄĒ Importance in Generative AI"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Jacobian and Hessian matrices enable advanced ML techniques beyond basic gradient descent:"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "ML Application"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "How Jacobian/Hessian applies"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Sensitivity Analysis"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Jacobian shows how sensitive each output is to each input"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Parameter Tuning"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Jacobian guides tuning models with vector-valued outputs"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Newton's Method"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Hessian enables second-order optimization (faster convergence)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Curvature Analysis"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Hessian tells if landscape is steep/flat, convex/concave"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Local Minima Detection"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Positive definite Hessian = local minimum"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Model Interpretability"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Jacobian reveals which inputs affect which outputs"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Optimization"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Hessian eigenvalues indicate \"ravines\" causing slow convergence"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Regularization"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Hessian-based methods improve generalization"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Real example"}, {"type": "text", "text": ": In training a neural network with 10 output classes, the Jacobian tells you how changing weight w‚āĀ affects output class 1, class 2,..., class 10 separately."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Benefits ‚ÄĒ Key advantages"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "‚úÖ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Multi-output handling"}, {"type": "text", "text": ": Jacobian handles functions with many outputs"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "‚úÖ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Sensitivity mapping"}, {"type": "text", "text": ": Jacobian shows input-output relationships"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "‚úÖ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Curvature information"}, {"type": "text", "text": ": Hessian reveals landscape shape"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "‚úÖ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Faster convergence"}, {"type": "text", "text": ": Newton's method with Hessian converges faster than gradient descent"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "‚úÖ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Optimal point detection"}, {"type": "text", "text": ": Hessian eigenvalues classify minima/maxima"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "‚úÖ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Model interpretability"}, {"type": "text", "text": ": Jacobian reveals which features drive outputs"}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Trade-offs ‚ÄĒ Downsides and limitations"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Trade-off"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Impact"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Computational cost"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Jacobian: O(mn) computations; Hessian: O(n¬≤) second derivatives"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Memory usage"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Hessian for million-parameter model = 10¬Ļ¬≤ elements (petabytes)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Numerical instability"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Hessian inversion can be unstable (ill-conditioned)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Complexity"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Harder to implement and debug than gradients"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Rarely used"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Most ML uses only gradients; Hessians are expensive"}]}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "How it works ‚ÄĒ Step-by-step computation"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Computing Jacobian:"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Example"}, {"type": "text", "text": ": Function "}, {"type": "text", "marks": [{"type": "bold"}], "text": "g(x, y)"}, {"type": "text", "text": " outputs 2 numbers:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# g‚āĀ(x, y) = x¬≤ + y\n# g‚āā(x, y) = xy + y¬≥\n\n# Partial derivatives:\n‚ąāg‚āĀ/‚ąāx = 2x\n‚ąāg‚āĀ/‚ąāy = 1\n‚ąāg‚āā/‚ąāx = y\n‚ąāg‚āā/‚ąāy = x + 3y¬≤\n\n# Jacobian matrix (2√ó2):\nJ = [‚ąāg‚āĀ/‚ąāx  ‚ąāg‚āĀ/‚ąāy]   = [2x    1]\n    [‚ąāg‚āā/‚ąāx  ‚ąāg‚āā/‚ąāy]     [y  x + 3y¬≤]\n\n# Evaluate at point (1, 2):\nJ(1, 2) = [2√ó1    1]   = [2  1]\n          [2  1 + 3√ó4]   [2 13]"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Python (NumPy)"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import numpy as np\n\ndef g(x, y):\n    g1 = x**2 + y\n    g2 = x*y + y**3\n    return np.array([g1, g2])\n\n# Compute Jacobian at (1, 2)\nx, y = 1.0, 2.0\nh = 1e-5\n\n# Partial derivatives numerically\ndg1_dx = (g(x+h, y)[0] - g(x, y)[0]) / h\ndg1_dy = (g(x, y+h)[0] - g(x, y)[0]) / h\ndg2_dx = (g(x+h, y) [linkedin](https://www.linkedin.com/pulse/how-jacobian-hessian-matrices-used-machine-learning-ajit-jaokar-th7kf) - g(x, y) [linkedin](https://www.linkedin.com/pulse/how-jacobian-hessian-matrices-used-machine-learning-ajit-jaokar-th7kf)) / h\ndg2_dy = (g(x, y+h) [linkedin](https://www.linkedin.com/pulse/how-jacobian-hessian-matrices-used-machine-learning-ajit-jaokar-th7kf) - g(x, y) [linkedin](https://www.linkedin.com/pulse/how-jacobian-hessian-matrices-used-machine-learning-ajit-jaokar-th7kf)) / h\n\nJ = np.array([[dg1_dx, dg1_dy],\n              [dg2_dx, dg2_dy]])\n\nprint(f\"Jacobian: {J}\")  # [[2, 1], [2, 13]]"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Python (PyTorch)"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import torch\n\nx = torch.tensor([1.0, 2.0], requires_grad=True)\n\ndef g(xyz):\n    x, y = xyz[0], xyz [linkedin](https://www.linkedin.com/pulse/how-jacobian-hessian-matrices-used-machine-learning-ajit-jaokar-th7kf)\n    return torch.stack([x**2 + y, x*y + y**3])\n\ny = g(x)\n\n# Compute Jacobian\nJ = torch.zeros(2, 2)\nfor i in range(2):\n    y[i].backward(retain_graph=True)\n    J[i] = x.grad\n    x.grad.zero_()\n\nprint(f\"Jacobian: {J}\")  # [[2, 1], [2, 13]]"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Computing Hessian:"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Example"}, {"type": "text", "text": ": Function "}, {"type": "text", "marks": [{"type": "italic"}], "text": "f(x, y)"}, {"type": "text", "text": " outputs 1 number:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# f(x, y) = x¬≤ + xy + y¬≥\n\n# First derivatives (gradient):\n‚ąāf/‚ąāx = 2x + y\n‚ąāf/‚ąāy = x + 3y¬≤\n\n# Second derivatives (Hessian):\n‚ąā¬≤f/‚ąāx¬≤ = 2          (derivative of 2x + y w.r.t. x)\n‚ąā¬≤f/‚ąāx‚ąāy = 1         (derivative of 2x + y w.r.t. y)\n‚ąā¬≤f/‚ąāy‚ąāx = 1         (derivative of x + 3y¬≤ w.r.t. x)\n‚ąā¬≤f/‚ąāy¬≤ = 6y         (derivative of x + 3y¬≤ w.r.t. y)\n\n# Hessian matrix (2√ó2):\nH = [‚ąā¬≤f/‚ąāx¬≤   ‚ąā¬≤f/‚ąāx‚ąāy]  = [2   1]\n    [‚ąā¬≤f/‚ąāy‚ąāx  ‚ąā¬≤f/‚ąāy¬≤]    [1  6y]\n\n# Evaluate at point (1, 2):\nH(1, 2) = [2   1]\n          [1  12]"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Python (SymPy)"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import sympy as sp\n\nx, y = sp.symbols('x y')\nf = x**2 + x*y + y**3\n\n# Gradient\ngradient = [sp.diff(f, x), sp.diff(f, y)]\n# [2*x + y, x + 3*y**2]\n\n# Hessian\nH = sp.hessian(f, [x, y])\n# [[2, 1],\n#  [1, 6*y]]\n\n# Evaluate at (1, 2)\nH_at_point = H.subs({x: 1, y: 2})\n# [[2, 1],\n#  [1, 12]]"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Python (NumPy numerical)"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import numpy as np\n\ndef f(x, y):\n    return x**2 + x*y + y**3\n\n# Compute Hessian at (1, 2)\nx, y = 1.0, 2.0\nh = 1e-4\n\n# Second derivatives numerically\ndf_dx = (f(x+h, y) - f(x-h, y)) / (2*h)\ndf_dy = (f(x, y+h) - f(x, y-h)) / (2*h)\n\nd2f_dx2 = (f(x+h, y) - 2*f(x, y) + f(x-h, y)) / h**2\nd2f_dy2 = (f(x, y+h) - 2*f(x, y) + f(x, y-h)) / h**2\nd2f_dxdy = (f(x+h, y+h) - f(x+h, y-h) - f(x-h, y+h) + f(x-h, y-h)) / (4*h**2)\n\nH = np.array([[d2f_dx2, d2f_dxdy],\n              [d2f_dxdy, d2f_dy2]])\n\nprint(f\"Hessian: {H}\")  # [[2, 1], [1, 12]]"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Key properties ‚ÄĒ Mathematical rules"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Jacobian properties:"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Chain rule"}, {"type": "text", "text": ": For "}, {"type": "text", "marks": [{"type": "bold"}], "text": "f(g(x))"}, {"type": "text", "text": ", Jacobian is:"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "``"}, {"type": "text", "marks": [{"type": "code"}], "text": " J_{f‚ąėg} = J_f ¬∑ J_g (matrix multiplication) "}, {"type": "text", "text": "``"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Generalizes gradient"}, {"type": "text", "text": ": For scalar output (m=1), Jacobian = gradient transpose"}]}]}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Coordinate transforms"}, {"type": "text", "text": ": Used in changing variables (e.g., polar ‚Üí Cartesian)"}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Hessian properties:"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Symmetric"}, {"type": "text", "text": ": HŠĶĘ‚Īľ = H‚ĪľŠĶĘ (mixed partials equal)"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "``"}, {"type": "text", "marks": [{"type": "code"}], "text": " ‚ąā¬≤f/‚ąāx‚ąāy = ‚ąā¬≤f/‚ąāy‚ąāx "}, {"type": "text", "text": "``"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Eigenvalues indicate curvature"}, {"type": "text", "text": ":"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "All positive"}, {"type": "text", "text": " ‚Üí local minimum (convex) - "}, {"type": "text", "marks": [{"type": "bold"}], "text": "All negative"}, {"type": "text", "text": " ‚Üí local maximum (concave) - "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Mixed signs"}, {"type": "text", "text": " ‚Üí saddle point"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Positive definite"}, {"type": "text", "text": " ‚Üí local minimum"}]}]}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Newton's method"}, {"type": "text", "text": ": Uses Hessian for second-order update:"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "``"}, {"type": "text", "marks": [{"type": "code"}], "text": " w ‚Üź w - H‚ĀĽ¬Ļ‚ąáL(w) (faster than gradient descent) "}, {"type": "text", "text": "``"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "When to use it ‚ÄĒ Scenarios and decision criteria"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Use Jacobian when:"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "‚úÖ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Vector-valued function"}, {"type": "text", "text": ": Model has multiple outputs (e.g., 10-class classification)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "‚úÖ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Sensitivity analysis"}, {"type": "text", "text": ": Need to know how each output responds to each input"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "‚úÖ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Backpropagation"}, {"type": "text", "text": ": Computing gradients through neural network layers"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "‚úÖ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Coordinate transforms"}, {"type": "text", "text": ": Changing variable systems"}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Use Hessian when:"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "‚úÖ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Second-order optimization"}, {"type": "text", "text": ": Need faster convergence (Newton's method)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "‚úÖ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Curvature analysis"}, {"type": "text", "text": ": Understand landscape shape (steep/flat, convex/concave)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "‚úÖ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Local minima detection"}, {"type": "text", "text": ": Classify optimal points"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "‚úÖ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Ill-conditioned problems"}, {"type": "text", "text": ": Diagnose \"ravines\" causing zigzagging"}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Use gradient when:"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "‚ĚĆ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Standard optimization"}, {"type": "text", "text": ": Most ML uses first-order gradients only (simpler, faster)"}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "How to implement ‚ÄĒ Practical examples"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Example 1: Neural network Jacobian"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import torch\nimport torch.nn as nn\n\n# Neural network with 3 inputs, 5 outputs\nmodel = nn.Sequential(\n    nn.Linear(3, 10),\n    nn.ReLU(),\n    nn.Linear(10, 5)\n)\n\n# Input\nx = torch.randn(1, 3, requires_grad=True)\n\n# Compute Jacobian of output w.r.t. input\noutput = model(x)\n\nJ = torch.zeros(5, 3)\nfor i in range(5):\n    output[i].backward(retain_graph=True)\n    J[i] = x.grad\n    x.grad.zero_()\n\nprint(f\"Jacobian shape: {J.shape}\")  # (5, 3)\n# Each row i shows how output[i] changes with each input"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Example 2: Newton's method with Hessian"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import numpy as np\n\n# Function: f(x) = x¬≤\ndef f(x):\n    return x**2\n\n# Gradient: f'(x) = 2x\ndef gradient(x):\n    return 2*x\n\n# Hessian: f''(x) = 2\ndef hessian(x):\n    return 2\n\n# Newton's method (2nd-order optimization)\nx = 5.0\nfor i in range(5):\n    grad = gradient(x)\n    Hess = hessian(x)\n    \n    # Update: w ‚Üź w - H‚ĀĽ¬Ļ‚ąáL\n    x = x - grad / Hess\n    \n    print(f\"Iteration {i}: x = {x:.6f}, f(x) = {f(x):.6f}\")\n\nprint(f\"Final: x = {x:.6f}, f(x) = {f(x):.6f}\")  # x ‚Čą 0, f(x) ‚Čą 0"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Why faster than gradient descent?"}, {"type": "text", "text": "\n- Gradient descent: "}, {"type": "text", "marks": [{"type": "code"}], "text": "x = x - ő∑ √ó 2x"}, {"type": "text", "text": " (depends on learning rate ő∑)\n- Newton: "}, {"type": "text", "marks": [{"type": "code"}], "text": "x = x - 2x/2 = 0"}, {"type": "text", "text": " (one step to optimum!)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Example 3: Hessian for minima detection"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import numpy as np\n\n# Function: f(x, y) = x¬≤ + y¬≤ (bowl shape)\ndef f(x, y):\n    return x**2 + y**2\n\n# Hessian at (0, 0)\nH = np.array([[2, 0],\n              [0, 2]])\n\n# Eigenvalues\neigenvalues = np.linalg.eigvals(H)\nprint(f\"Eigenvalues: {eigenvalues}\")  # [2, 2]\n\n# Both positive ‚Üí local minimum ‚úď\nif np.all(eigenvalues > 0):\n    print(\"Point is a local MINIMUM\")"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Compare with saddle point"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Function: f(x, y) = x¬≤ - y¬≤ (saddle)\nH_saddle = np.array([[2, 0],\n                     [0, -2]])\n\neigenvalues_saddle = np.linalg.eigvals(H_saddle)\nprint(f\"Eigenvalues: {eigenvalues_saddle}\")  # [2, -2]\n\n# Mixed signs ‚Üí saddle point\nif np.any(eigenvalues_saddle > 0) and np.any(eigenvalues_saddle < 0):\n    print(\"Point is a SADDLE\")"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Common mistakes ‚ÄĒ Pitfalls to avoid"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Mistake"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Correction"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Confusing Jacobian with gradient"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Jacobian = matrix (m√ón); Gradient = vector (n√ó1)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Not checking Hessian symmetry"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Hessian should be symmetric: HŠĶĘ‚Īľ = H‚ĪľŠĶĘ"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Inverting ill-conditioned Hessian"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Hessian may be nearly singular; use regularization"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Computing full Hessian"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "For million parameters, Hessian is too large; use approximations"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Manual computation"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use autograd (PyTorch/TensorFlow) for Hessians"}]}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Key takeaways"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Gradient"}, {"type": "text", "text": ": Vector of 1st partials for scalar output: ‚ąáf = [‚ąāf/‚ąāx‚āĀ,..., ‚ąāf/‚ąāx‚āô]"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Jacobian"}, {"type": "text", "text": ": Matrix of ALL 1st partials for vector output: JŠĶĘ‚Īľ = ‚ąāgŠĶĘ/‚ąāx‚Īľ (m√ón)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Hessian"}, {"type": "text", "text": ": Matrix of ALL 2nd partials for scalar output: HŠĶĘ‚Īľ = ‚ąā¬≤f/‚ąāxŠĶĘ‚ąāx‚Īľ (n√ón)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Jacobian generalizes gradient"}, {"type": "text", "text": ": For m=1 output, Jacobian = gradient transpose"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Hessian = curvature"}, {"type": "text", "text": ": Tells if landscape is steep/flat, convex/concave"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Hessian symmetric"}, {"type": "text", "text": ": HŠĶĘ‚Īľ = H‚ĪľŠĶĘ (mixed partials equal)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Eigenvalues classify points"}, {"type": "text", "text": ": All positive ‚Üí minimum; mixed ‚Üí saddle"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Newton's method"}, {"type": "text", "text": ": Uses H‚ĀĽ¬Ļ‚ąáL for faster convergence"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Sensitivity analysis"}, {"type": "text", "text": ": Jacobian shows how outputs respond to inputs"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Rarely used"}, {"type": "text", "text": ": Most ML uses gradients only; Hessians are expensive"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "For Generative AI, Jacobians enable multi-output sensitivity analysis and backpropagation through vector-valued layers, while Hessians (though rarely computed fully) provide theoretical insights into optimization landscapes and curvature, explaining why some problems converge slowly due to \"ravines\" in the loss surface."}]}]}}