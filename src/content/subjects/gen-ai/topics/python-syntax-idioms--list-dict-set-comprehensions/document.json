{"format":"tiptap/v1","updatedAt":"2026-06-21T09:08:03.188Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What Are Comprehensions?"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Comprehensions"},{"type":"text","text":" are concise, Pythonic ways to create new sequences (lists, dictionaries, sets) from existing iterables in a single line of code."}]},{"type":"paragraph","content":[{"type":"text","text":"Think of them as "},{"type":"text","marks":[{"type":"bold"}],"text":"mathematical set-builder notation"},{"type":"text","text":" translated into Python syntax."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why Use Comprehensions?"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Benefit"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Description"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Concise syntax"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Shorter code than equivalent "},{"type":"text","marks":[{"type":"code"}],"text":"for"},{"type":"text","text":" loops"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Faster execution"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"More efficient than traditional loops"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Readable"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Easier to understand intent"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pythonic"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Standard idiomatic Python style"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"List Comprehension"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Basic Syntax"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"[expression for item in iterable if condition]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Components:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"code"}],"text":"expression"},{"type":"text","text":" — operation or value to include in the new list\n- "},{"type":"text","marks":[{"type":"code"}],"text":"item"},{"type":"text","text":" — current element from the iterable\n- "},{"type":"text","marks":[{"type":"code"}],"text":"iterable"},{"type":"text","text":" — sequence like list, tuple, or range\n- "},{"type":"text","marks":[{"type":"code"}],"text":"if condition"},{"type":"text","text":" — optional filter (only include items that satisfy it)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Simple Example: Square Numbers"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Using list comprehension\nsquares = [x**2 for x in range(5)]\nprint(squares)  # Output: [0, 1, 4, 9, 16]\n\n# Equivalent for loop (longer)\nsquares = []\nfor x in range(5):\n    squares.append(x**2)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example with Condition (Filter)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Only even numbers squared\neven_squares = [x**2 for x in range(10) if x % 2 == 0]\nprint(even_squares)  # Output: [0, 4, 16, 36, 64]\n\n# Equivalent for loop\neven_squares = []\nfor x in range(10):\n    if x % 2 == 0:\n        even_squares.append(x**2)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example: Transform String Elements"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Capitalize fruit names\nfruits = ['apple', 'mango', 'banana', 'cherry']\ncapitalized = [fruit.capitalize() for fruit in fruits]\nprint(capitalized)  # Output: ['Apple', 'Mango', 'Banana', 'Cherry']"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example: Extract First Letters"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Create dict with fruit names as keys and lengths as values\nfruits = ['apple', 'mango', 'banana', 'cherry']\nfruit_lengths = {f: len(f) for f in fruits}\nprint(fruit_lengths)  # Output: {'apple': 5, 'mango': 5, 'banana': 6, 'cherry': 6}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Nested List Comprehension"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Create 3x3 matrix\nmatrix = [[i*j for j in range(3)] for i in range(3)]\nprint(matrix)  # Output: [[0, 0, 0], [0, 1, 2], [0, 2, 4]]\n\n# Flatten a 2D list\nnested = [[1, 2], [3, 4], [5, 6]]\nflattened = [num for sublist in nested for num in sublist]\nprint(flattened)  # Output: [1, 2, 3, 4, 5, 6]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Real-World Example: Filter and Transform"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Get lengths of names longer than 3 characters\nnames = ['Alice', 'Bob', 'Charlie', 'David', 'Eve']\nlong_name_lengths = [len(name) for name in names if len(name) > 3]\nprint(long_name_lengths)  # Output: [5, 7, 5]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Dictionary Comprehension"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Basic Syntax"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"{key_expression: value_expression for item in iterable if condition}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example: Create Squares Dictionary"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Numbers 1-5 as keys, their squares as values\nnumbers = [1, 2, 3, 4, 5]\nsquares_dict = {num: num**2 for num in numbers}\nprint(squares_dict)  # Output: {1: 1, 2: 4, 3: 9, 4: 16, 5: 25}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example: Filter with Condition"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Only even numbers squared\nnumbers = range(10)\neven_squares = {num: num**2 for num in numbers if num % 2 == 0}\nprint(even_squares)  # Output: {0: 0, 2: 4, 4: 16, 6: 36, 8: 64}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example: Invert Dictionary"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Swap keys and values\noriginal = {'a': 1, 'b': 2, 'c': 3}\ninverted = {v: k for k, v in original.items()}\nprint(inverted)  # Output: {1: 'a', 2: 'b', 3: 'c'}\n\n# Equivalent code\ndef invert(d):\n    return {v: k for k, v in d.items()}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example: Double Dictionary Values"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Multiply all values by 2\noriginal = {'a': 1, 'b': 2, 'c': 3}\ndoubled = {key: value * 2 for key, value in original.items()}\nprint(doubled)  # Output: {'a': 2, 'b': 4, 'c': 6}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example: Create Customer Discount Dictionary"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import random\n\n# Assign random discounts to customers\ncustomers = ['Alex', 'Bob', 'Carol', 'Dave', 'Flow', 'Katie', 'Nate']\ndiscount_dict = {customer: random.randint(1, 100) for customer in customers}\nprint(discount_dict)\n# Output: {'Alex': 42, 'Bob': 17, 'Carol': 89, ...}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example: Create Dict from Two Lists"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Create dictionary from parallel lists\nkeys = ['name', 'age', 'city']\nvalues = ['Alice', 30, 'New York']\nperson_dict = {k: v for k, v in zip(keys, values)}\nprint(person_dict)  # Output: {'name': 'Alice', 'age': 30, 'city': 'New York'}"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Set Comprehension"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Basic Syntax"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"{expression for element in iterable if condition}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Note:"},{"type":"text","text":" Uses curly braces "},{"type":"text","marks":[{"type":"code"}],"text":"{}"},{"type":"text","text":" like dict comprehension, but produces a "},{"type":"text","marks":[{"type":"bold"}],"text":"set"},{"type":"text","text":" (unordered, unique elements)."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example: Unique Squares"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Create set of squares (eliminates duplicates)\nnumbers = [1, 2, 2, 3, 3, 4]\nunique_squares = {x**2 for x in numbers}\nprint(unique_squares)  # Output: {1, 4, 9, 16}\n\n# Note: Duplicate squares (2²=4, 2²=4) merged into single value"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example: Filter with Condition"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Only odd numbers squared\nnumbers = range(10)\nodd_squares = {x**2 for x in numbers if x % 2 == 1}\nprint(odd_squares)  # Output: {1, 9, 25, 49, 81}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example: Extract Unique Characters"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Get unique characters from string\ntext = \"hello world\"\nunique_chars = {char for char in text if char != ' '}\nprint(unique_chars)  # Output: {'h', 'e', 'l', 'o', 'w', 'r', 'd'}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example: Extract Unique Lengths"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Get unique word lengths\nwords = ['apple', 'banana', 'cherry', 'apple', 'banana']\nunique_lengths = {len(word) for word in words}\nprint(unique_lengths)  # Output: {5, 6}"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Comparison Table: All Three Comprehensions"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Syntax"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Output"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Example"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"List"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"[x for x in iterable]"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"List "},{"type":"text","marks":[{"type":"code"}],"text":"[...]"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"[x**2 for x in range(3)]"},{"type":"text","text":" → "},{"type":"text","marks":[{"type":"code"}],"text":"[0, 1, 4]"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Dict"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"{k: v for x in iterable}"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Dict "},{"type":"text","marks":[{"type":"code"}],"text":"{k: v}"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"{x: x**2 for x in range(3)}"},{"type":"text","text":" → "},{"type":"text","marks":[{"type":"code"}],"text":"{0:0, 1:1, 2:4}"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Set"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"{x for x in iterable}"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Set "},{"type":"text","marks":[{"type":"code"}],"text":"{...}"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"{x**2 for x in range(3)}"},{"type":"text","text":" → "},{"type":"text","marks":[{"type":"code"}],"text":"{0, 1, 4}"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Comprehensions vs. Traditional Loops"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"List Comprehension vs. For Loop"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# List comprehension (concise)\nevens = [x for x in range(10) if x % 2 == 0]\n\n# Equivalent for loop (longer)\nevens = []\nfor x in range(10):\n    if x % 2 == 0:\n        evens.append(x)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Dict Comprehension vs. For Loop"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Dict comprehension\nsquares = {x: x**2 for x in range(5)}\n\n# Equivalent for loop\nsquares = {}\nfor x in range(5):\n    squares[x] = x**2"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Set Comprehension vs. For Loop"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Set comprehension\nunique = {x**2 for x in [1, 2, 2, 3, 3]}\n\n# Equivalent for loop\nunique = set()\nfor x in [1, 2, 2, 3, 3]:\n    unique.add(x**2)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Performance Comparison"}]},{"type":"paragraph","content":[{"type":"text","text":"Comprehensions are "},{"type":"text","marks":[{"type":"bold"}],"text":"faster"},{"type":"text","text":" than equivalent for loops because they're optimized in C."}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import timeit\n\n# List comprehension\ntime_comprehension = timeit.timeit(lambda: [x**2 for x in range(1000)])\n\n# For loop\ntime_loop = timeit.timeit(lambda: \n    (result := [], [result.append(x**2) for x in range(1000)][0])\n)\n\nprint(f\"Comprehension: {time_comprehension}\")\nprint(f\"For loop: {time_loop}\")\n# Comprehension is typically 20-30% faster"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common Pitfalls"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Pitfall"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Wrong"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Correct"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Modifying during iteration"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"[x for x in lst if lst.remove(x)]"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Create new list first"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Unintended nesting"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"[[x for x in row] for row in matrix]"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use proper nesting"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Set vs Dict confusion"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"{x: x for x in range(3)}"},{"type":"text","text":" (dict)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"{x for x in range(3)}"},{"type":"text","text":" (set)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Condition placement"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"[x if x > 0 else 0 for x in nums]"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"[x for x in nums if x > 0]"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Advanced Examples"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Conditional Expression in List Comprehension"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Use if-else inside expression\nnumbers = [1, 2, 3, 4, 5]\nlabeled = ['even' if x % 2 == 0 else 'odd' for x in numbers]\nprint(labeled)  # Output: ['odd', 'even', 'odd', 'even', 'odd']"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Multiple Iterables"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Combine two lists\nlist1 = [1, 2, 3]\nlist2 = ['a', 'b', 'c']\ncombined = [(x, y) for x in list1 for y in list2]\nprint(combined)  # Output: [(1, 'a'), (1, 'b'), (1, 'c'), (2, 'a'), ...]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Nested Dict Comprehension"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Create nested dictionary\ndata = {'a': [1, 2], 'b': [3, 4]}\nnested = {key: {i: val for i, val in enumerate(values)} \n          for key, values in data.items()}\nprint(nested)  # Output: {'a': {0: 1, 1: 2}, 'b': {0: 3, 1: 4}}"}]},{"type":"paragraph","content":[{"type":"text","text":"Understanding comprehensions is essential for "},{"type":"text","marks":[{"type":"bold"}],"text":"Python Syntax & Idioms"},{"type":"text","text":" in Generative AI development, making code more concise, readable, and efficient."}]}]}}
