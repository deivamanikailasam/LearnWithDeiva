{"format":"tiptap/v1","updatedAt":"2026-06-22T03:44:54.542Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Logistic Regression"},{"type":"text","text":" is a fundamental "},{"type":"text","marks":[{"type":"bold"}],"text":"supervised learning algorithm"},{"type":"text","text":" in classical machine learning used for "},{"type":"text","marks":[{"type":"bold"}],"text":"classification tasks"},{"type":"text","text":" — it predicts the probability that an observation belongs to a particular category (e.g., spam/not-spam, sick/healthy) by fitting data to a "},{"type":"text","marks":[{"type":"bold"}],"text":"sigmoid (logistic) function"},{"type":"text","text":"."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","text":"Despite its name containing \"regression,\" logistic regression is actually a "},{"type":"text","marks":[{"type":"bold"}],"text":"classification algorithm"},{"type":"text","text":" that outputs probabilities between 0 and 1, which are then mapped to discrete categories."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Core equation"},{"type":"text","text":" (sigmoid function):"}]},{"type":"paragraph","content":[{"type":"text","text":"$$P(Y=1) = \\frac{1}{1 + e^{-(\\beta_0 + \\beta_1x_1 + \\beta_2x_2 +... + \\beta_nx_n)}}$$"}]},{"type":"paragraph","content":[{"type":"text","text":"Or simplified:"}]},{"type":"blockMath","attrs":{"latex":"p = \\frac{1}{1 + e^{-z}}"}},{"type":"paragraph","content":[{"type":"text","text":"Where:\n- "},{"type":"inlineMath","attrs":{"latex":"p"}},{"type":"text","text":" = "},{"type":"text","marks":[{"type":"bold"}],"text":"probability"},{"type":"text","text":" of the event occurring (class 1)\n- "},{"type":"inlineMath","attrs":{"latex":"z = \\beta_0 + \\beta_1x_1 +... + \\beta_nx_n"}},{"type":"text","text":" = "},{"type":"t