{"format": "tiptap/v1", "updatedAt": "2026-06-22T04:40:27.441Z", "doc": {"type": "doc", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Feature extraction"}, {"type": "text", "text": " is the process of transforming raw data into a set of "}, {"type": "text", "marks": [{"type": "bold"}], "text": "informative, compact features"}, {"type": "text", "text": " that ML models can use—by deriving new variables from existing data (e.g., extracting text statistics, creating interaction terms, applying PCA) rather than just selecting existing columns."}]}, {"type": "blockquote", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Key definition:"}, {"type": "text", "text": " “Feature extraction is our technological insight in machine learning. It addresses the problem of attaining the most "}, {"type": "text", "marks": [{"type": "bold"}], "text": "informative and compact set of features"}, {"type": "text", "text": ".”"}]}]}, {"type": "horizontalRule"}, {"type": "image", "attrs": {"src": "data:image/svg+xml;base64,", "alt": "Feature Extraction — concept overview"}}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "What feature extraction means"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Feature extraction "}, {"type": "text", "marks": [{"type": "bold"}], "text": "creates new features"}, {"type": "text", "text": " from raw data through mathematical transformations:"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Aspect"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Feature Extraction"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Feature Selection"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "What it does"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Creates "}, {"type": "text", "marks": [{"type": "bold"}], "text": "new features"}, {"type": "text", "text": " from raw data"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Selects "}, {"type": "text", "marks": [{"type": "bold"}], "text": "existing features"}, {"type": "text", "text": " from the dataset"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Goal"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Reduce dimensionality while preserving information"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Remove irrelevant/redundant features"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Methods"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "PCA, LDA, autoencoders, text statistics"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Filtering, ranking, pruning"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Output"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Transformed feature space (e.g., 100 → 10 PCs)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Subset of original features"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Example"}, {"type": "text", "text": ":\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Raw data"}, {"type": "text", "text": ": 10,000-word document\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Extraction"}, {"type": "text", "text": ": Convert to 100 features (word counts, TF-IDF scores, sentence length, avg word length)\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Result"}, {"type": "text", "text": ": Compact, informative representation for ML"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Common feature extraction techniques with NumPy & pandas"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "1. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Principal Component Analysis (PCA)"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "PCA reduces dimensionality by finding orthogonal directions (principal components) that capture maximum variance."}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import pandas as pd\nimport numpy as np\nfrom sklearn.decomposition import PCA\nfrom sklearn.preprocessing import StandardScaler\n\n# Load data\ndata = pd.read_csv(\"pokemon_data.csv\")\n\n# Select numeric features\nnumeric_features = data[['HP', 'Attack', 'Defense', 'Sp_Atk', 'Sp_Def', 'Speed']]\n\n# Standardize\nscaler = StandardScaler()\nX_scaled = scaler.fit_transform(numeric_features)\n\n# Extract features (reduce to 3 principal components)\npca = PCA(n_components=3)\nX_pca = pca.fit_transform(X_scaled)\n\n# Create new DataFrame with extracted features\nextraction_df = pd.DataFrame(X_pca, columns=['PC1', 'PC2', 'PC3'])"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Benefits"}, {"type": "text", "text": ":\n- Reduces dimensionality while preserving variance\n- Removes multicollinearity\n- Creates orthogonal features"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "2. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Text feature extraction"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Extract numeric features from text data:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import pandas as pd\nimport numpy as np\nfrom sklearn.feature_extraction import CountVectorizer, TfidfVectorizer\n\ndata = pd.read_csv(\"reviews.csv\")\n\n# Count vectorization (word frequencies)\ncount_vectorizer = CountVectorizer()\nX_counts = count_vectorizer.fit_transform(data[\"review_text\"])\n\n# TF-IDF (term frequency - inverse document frequency)\ntfidf_vectorizer = TfidfVectorizer(max_features=100)\nX_tfidf = tfidf_vectorizer.fit_transform(data[\"review_text\"])\n\n# Convert to DataFrame\nfeature_df = pd.DataFrame(X_tfidf.toarray(), columns=tfidf_vectorizer.get_feature_names_out())"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Common text features:\n- Word counts\n- TF-IDF scores\n- Character counts\n- Sentence length\n- Average word length\n- Punctuation frequency"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "3. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Time series feature extraction"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Extract statistical features from time series data:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import pandas as pd\nimport numpy as np\nfrom mne_features.feature_extraction import FeatureExtractor\n\n# Example: Extract features from MEG/EEG data\ndata = pd.read_csv(\"time_series.csv\")\n\n# Define feature extraction functions\nselected_funcs = ['mean', 'std', 'app_entropy', 'median']\n\nfeature_extractor = FeatureExtractor(\n    sfreq=1000,  # Sampling frequency\n    selected_funcs=selected_funcs\n)\n\n# Extract features\nX_features = feature_extractor.transform(data.values)"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Common time series features:\n- Mean, median, std\n- Skewness, kurtosis\n- Entropy (Shannon, approximate)\n- Autocorrelation\n- Peak amplitude\n- Energy"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "4. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Image feature extraction"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Extract features from images:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import pandas as pd\nimport numpy as np\nfrom skimage.feature import graycomatrix, graystatmatrix\nfrom sklearn.decomposition import PCA\n\n# Load image data\nimage = np.load(\"image_array.npy\")\n\n# Flatten image to 1D array\nX_flat = image.flatten()\n\n# Extract statistical features\nmean_val = np.mean(X_flat)\nstd_val = np.std(X_flat)\nmax_val = np.max(X_flat)\nmin_val = np.min(X_flat)\n\n# Create feature row\nfeatures = np.array([mean_val, std_val, max_val, min_val])"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Common image features:\n- Mean intensity\n- Standard deviation\n- Histogram features\n- Edge detection (Sobel, Canny)\n- Texture features (GLCM)"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "5. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Creating interaction features"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Combine existing features to create new ones:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import pandas as pd\n\ndata = pd.read_csv(\"titanic.csv\")\n\n# Create interaction features\ndata['age_fare'] = data['age'] * data['fare']  # Interaction\ndata['age_squared'] = data['age'] ** 2         # Polynomial\ndata['fare_per_person'] = data['fare'] / data['family_size']  # Ratio"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Common interaction features:\n- Product of two features ("}, {"type": "text", "marks": [{"type": "code"}], "text": "A B"}, {"type": "text", "text": ")\n- Ratio of two features ("}, {"type": "text", "marks": [{"type": "code"}], "text": "A / B"}, {"type": "text", "text": ")\n- Polynomial features ("}, {"type": "text", "marks": [{"type": "code"}], "text": "A^2"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "code"}], "text": "A^3"}, {"type": "text", "text": ")\n- Sum of features ("}, {"type": "text", "marks": [{"type": "code"}], "text": "A + B"}, {"type": "text", "text": ")"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "6. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Binning (creating categorical features from continuous)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import pandas as pd\n\ndata = pd.read_csv(\"data.csv\")\n\n# Create bins for age\ndata['age_bin'] = pd.cut(data['age'], bins=[0, 20, 40, 60, 100], labels=['child', 'young', 'middle', 'senior'])\n\n# Create bins for income\ndata['income_bin'] = pd.qcut(data['income'], q=4, labels=['low', 'medium', 'high', 'very_high'])"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Binning converts continuous features into discrete categories, useful for:\n- Reducing noise\n- Capturing non-linear relationships\n- Creating interpretable features"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "7. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "One-hot encoding (categorical → binary)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import pandas as pd\n\ndata = pd.read_csv(\"data.csv\")\n\n# One-hot encode categorical variable\nencoded = pd.get_dummies(data, columns=['category'])"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Transforms categorical features into binary columns:\n- "}, {"type": "text", "marks": [{"type": "code"}], "text": "category_A"}, {"type": "text", "text": " → "}, {"type": "text", "marks": [{"type": "code"}], "text": "[1, 0, 0]"}, {"type": "text", "text": "\n- "}, {"type": "text", "marks": [{"type": "code"}], "text": "category_B"}, {"type": "text", "text": " → "}, {"type": "text", "marks": [{"type": "code"}], "text": "[0, 1, 0]"}, {"type": "text", "text": "\n- "}, {"type": "text", "marks": [{"type": "code"}], "text": "category_C"}, {"type": "text", "text": " → "}, {"type": "text", "marks": [{"type": "code"}], "text": "[0, 0, 1]"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Feature extraction in scikit-learn pipelines"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Use "}, {"type": "text", "marks": [{"type": "code"}], "text": "ColumnTransformer"}, {"type": "text", "text": " to apply different extraction to different feature types:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import pandas as pd\nfrom sklearn.compose import ColumnTransformer\nfrom sklearn.preprocessing import StandardScaler, OneHotEncoder\nfrom sklearn.impute import SimpleImputer\nfrom sklearn.pipeline import Pipeline\n\nnumeric_features = ['age', 'fare']\nnumeric_transformer = Pipeline(steps=[\n    ('imputer', SimpleImputer(strategy='median')),\n    ('scaler', StandardScaler())\n])\n\ncategorical_features = ['embarked', 'sex']\ncategorical_transformer = Pipeline(steps=[\n    ('imputer', SimpleImputer(strategy='constant', fill_value='missing')),\n    ('onehot', OneHotEncoder(handle_unknown='ignore'))\n])\n\npreprocessor = ColumnTransformer(\n    transformers=[\n        ('num', numeric_transformer, numeric_features),\n        ('cat', categorical_transformer, categorical_features)\n    ]\n)\n\n# Apply to Dataset\nX_processed = preprocessor.fit_transform(data)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Benefits"}, {"type": "text", "text": ":\n- Handles mixed data types (numeric + categorical)\n- Ensures consistent preprocessing\n- Prevents data leakage"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Feature extraction with NumPy arrays"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "NumPy is optimized for ML computations:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import numpy as np\nimport pandas as pd\n\n# Load data\ndf = pd.read_csv(\"data.csv\")\nX = df.to_numpy()  # Convert to NumPy array\n\n# Extract mean and std for each row\nrow_means = np.mean(X, axis=1)\nrow_stds = np.std(X, axis=1)\n\n# Create feature matrix\nfeatures = np.column_stack([row_means, row_stds])"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Why NumPy"}, {"type": "text", "text": ":\n- Optimized for ML (faster than pandas for computation)\n- Supports vectorized operations\n- Compatible with all ML libraries"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Best practices for feature extraction"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Practice"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Why"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Standardize before extraction"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "PCA and similar methods assume standardized features"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Extract features separately for train/test"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Prevents data leakage (fit on train, transform on test)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use pipelines"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Ensures consistent preprocessing across experiment"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Monitor variance explained"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "For PCA, check "}, {"type": "text", "marks": [{"type": "code"}], "text": "pca.explained_variance_ratio_"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Keep it simple"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Start with hand-crafted features before complex extraction"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Validate with cross-validation"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Test if extracted features improve model performance "}, {"type": "text", "marks": [{"type": "link", "attrs": {"href": "https://mne.tools/mne-features/auto_examples/plot_mne_sample_gridsearch.html", "target": "_blank", "rel": "noopener noreferrer nofollow", "class": "text-brand-600 underline dark:text-brand-400", "title": null}}], "text": "mne"}]}]}]}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Common pitfalls"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "❌ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Not standardizing before PCA"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Problem"}, {"type": "text", "text": ": PCA is sensitive to scale; features with larger variance dominate"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Fix"}, {"type": "text", "text": ": Use "}, {"type": "text", "marks": [{"type": "code"}], "text": "StandardScaler"}, {"type": "text", "text": " before PCA"}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "❌ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Extracting from combined train/test"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Problem"}, {"type": "text", "text": ": Data leakage (test data influences extraction)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Fix"}, {"type": "text", "text": ": Fit extraction on train, transform test"}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "❌ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Extracting too many features"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Problem"}, {"type": "text", "text": ": Curse of dimensionality; model overfits"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Fix"}, {"type": "text", "text": ": Use PCA to reduce to meaningful number of components"}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "❌ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Ignoring feature importance"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Problem"}, {"type": "text", "text": ": Extracted features may not be relevant to target"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Fix"}, {"type": "text", "text": ": Validate with cross-validation and check model performance "}, {"type": "text", "marks": [{"type": "link", "attrs": {"href": "https://mne.tools/mne-features/auto_examples/plot_mne_sample_gridsearch.html", "target": "_blank", "rel": "noopener noreferrer nofollow", "class": "text-brand-600 underline dark:text-brand-400", "title": null}}], "text": "mne"}]}]}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Key takeaways"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Feature extraction"}, {"type": "text", "text": " creates "}, {"type": "text", "marks": [{"type": "bold"}], "text": "new, informative features"}, {"type": "text", "text": " from raw data through mathematical transformations (PCA, text stats, time series stats, image features)."}]