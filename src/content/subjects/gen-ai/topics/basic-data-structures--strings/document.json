 quotes\ntext1 = \"Hello\"\ntext2 = 'World'  # ✅ Both work [web:88][web:91]\n\n# ✅ Multi-line strings\nmultiline = \"\"\"Line 1\nLine 2\nLine 3\"\"\"  # ✅ Preserves newlines [web:88]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 2: Access Characters"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"text = \"Hello\"\nprint(text[0])  # 'H' (first)\nprint(text[-1])  # 'o' (last) [web:89][web:91]\n\n# ✅ Slice substring\nprint(text[1:4])  # \"ell\" (indices 1-3)\nprint(text[:3])  # \"Hel\" (0-2)\nprint(text[2:])  # \"llo\" (2-end) [web:88][web:90]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 3: Manipulate Text (Gen AI)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Tokenize prompt for LLM\nprompt = \"Explain quantum computing in simple terms\"\ntokens = prompt.split()  # ✅ ['Explain', 'quantum', 'computing', ...]\n\n# ✅ Normalize text\nnormalized = prompt.lower().strip()  # ✅ \"explain quantum computing in simple terms\"\n\n# ✅ Replace sensitive data\nsafe_prompt = prompt.replace(\"secret key\", \"[REDACTED]\")  # ✅ Sanitize [web:88][web:91]\n\n# ✅ Extract entities\nimport re\nemails = re.findall(r'\\b[\\w.-]+@[\\w.-]+\\.\\w+\\b', text)  # ✅ Regex pattern matching [web:88][web:90]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 4: Build Prompts"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Dynamic prompt template\nuser_query = \"What is photosynthesis?\"\ncontext = \"Photosynthesis is the process by which plants...\"\n\nprompt = f\"\"\"\nYou are a biology expert.\nContext: {context}\nUser Question: {user_query}\nAnswer:\n\"\"\"\nprint(prompt)  # ✅ Multi-line prompt for LLM [web:88]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Examples"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 1: Reversing a String"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Reverse using slice\ntext = \"Hello\"\nreversed_text = text[::-1]  # ✅ \"olleH\" [web:88]\n\n# ✅ Reverse using loop\nreversed_manual = \"\"\nfor char in text:\n    reversed_manual = char + reversed_manual  # ✅ \"olleH\""}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 2: Palindrome Check"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Check if string reads same backward\ndef is_palindrome(text: str) -> bool:\n    normalized = text.lower().strip()  # ✅ Normalize\n    return normalized == normalized[::-1]  # ✅ Compare with reversed\n\nprint(is_palindrome(\"racecar\"))  # True\nprint(is_palindrome(\"Hello\"))  # False [web:88][web:90]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 3: All Substrings"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Generate all possible substrings\ntext = \"abc\"\nsubstrings = []\n\nfor i in range(len(text)):\n    for j in range(i + 1, len(text) + 1):\n        substrings.append(text[i:j])  # ✅ [\"a\", \"ab\", \"abc\", \"b\", \"bc\", \"c\"]\n\nprint(substrings)  # ✅ All substrings [web:88][web:90]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 4: Python String for Gen AI"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Tokenize and count\nprompt = \"Explain quantum computing in 2 sentences\"\ntokens = prompt.split()\nprint(f\"Tokens: {tokens}\")  # ✅ ['Explain', 'quantum', ...]\nprint(f\"Token count: {len(tokens)}\")  # ✅ 6 [web:88][web:90]\n\n# ✅ Extract keywords\nkeywords = [word 