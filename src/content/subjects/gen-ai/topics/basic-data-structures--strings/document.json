ype":"text","text":"Small (26 lowercase, 256 ASCII, Unicode)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Any type"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why It Matters for Gen AI"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ❌ WITHOUT strings: Manual character handling\nprompt_chars = ['H', 'e', 'l', 'l', 'o']  # ❌ Tedious\nmessage = \"\"\nfor char in prompt_chars:\n    message += char  # ❌ O(n²) concatenation\n\n# ✅ WITH strings: Built-in operations\nprompt = \"Hello\"  # ✅ String literal\nmessage = prompt + \" World\"  # ✅ Concatenation\nprint(message.upper())  # ✅ \"HELLO WORLD\" [web:88][web:90]\n\n# ✅ Gen AI: Tokenization, prompts, outputs\nprompt = \"Explain quantum computing in 2 sentences\"\ntokens = prompt.split()  # ✅ ['Explain', 'quantum', 'computing', ...] [web:88][web:91]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Text representation"},{"type":"text","text":": Store prompts, responses, user input\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Immutable"},{"type":"text","text":": Safe for sharing (no accidental modification)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Small character set"},{"type":"text","text":": Enables fast algorithms (counting, sorting)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Built-in methods"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":".split()"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":".replace()"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":".find()"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":".lower()"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How It Works (Core Properties)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"String Properties"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Ordered: Characters have unique positions\ntext = \"Hello\"\nprint(text[0])  # 'H' (first character)\nprint(text [geeksforgeeks](https://www.geeksforgeeks.org/dsa/string-data-structure/))  # 'e' [web:89]\n\n# ✅ Indexable: Access via numerical index (0-based)\nprint(text [w3schools](https://www.w3schools.com/programming/prog_strings.php))  # 'o' (last character)\nprint(text[-1])  # 'o' (negative indexing) [web:89][web:91]\n\n# ✅ Comparable: Determine relative order\nprint(\"apple\" < \"banana\")  # True (alphabetical)\nprint(\"Hello\" == \"Hello\")  # True [web:89]\n\n# ✅ Immutable: Cannot modify after creation\ntext = \"Hello\"\ntext[0] = \"J\"  # ❌ TypeError: 'str' object doesn't support item assignment [web:88][web:89]\n\n# ✅ Create new string instead:\nnew_text = \"J\" + text[1:]  # ✅ \"Jello\" [web:89]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Basic String Operations"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Length: Number of characters\ntext = \"Hello World\"\nprint(len(text))  # 11 [web:88][web:90]\n\n# ✅ Concatenation: Combine strings\na = \"Hello\"\nb = \"World\"\nc = a + \" \" + b  # ✅ \"Hello World\" [web:88][web:91]\n\n# ✅ Slicing: Extract substrings\ntext = \"Hello World\"\nprint(text[0:5])  # \"Hello\" (indices 0-4)\nprint(text[6:])  # \"World\" (indices 6-end) [web:88][web:90]\n\n# ✅ Repetition: Repeat string\nprint(\"Hi\" * 3)  # \"HiHiHi\" [web:91]\n\n# ✅ Membership: Check if character exists\nprint(\"e\" in \"Hello\")  # True\nprint(\"z\" in \"Hello\")  # False [web:91]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Common String Methods"},{"type":"text","text":" ⭐ Essential for Gen AI"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"text = \"  Hello World  \"\n\n# ✅ Case conversion\nprint(text.upper())  # \"  HELLO WORLD  \"\nprint(text.lower())  # \"  hello world  \"\nprint(text.capitalize())  # \"  hello world  \" [web:88][web:91]\n\n# ✅ Strip whitespace\nprint(text.strip())  # \"Hello World\" [web:88][web:91]\n\n# ✅ Search: Find character/substring\nprint(text.find(\"World\"))  # 7 (index)\nprint(text.find(\"Python\"))  # -1 (not found) [web:88][web:90]\n\n# ✅ Replace: Substitute text\nprint(text.replace(\"World\", \"Python\"))  # \"  Hello Python  \" [web:88][web:91]\n\n# ✅ Split: Divide into list\nprint(text.split())  # [\"Hello\", \"World\"] (split by whitespace)\nprint(\"a,b,c\".split(\",\"))  # [\"a\", \"b\", \"c\"] [web:88][web:90]\n\n# ✅ Join: Combine list into string\nwords = [\"Hello\", \"World\"]\nprint(\" \".join(words))  # \"Hello World\" [web:88]\n\n# ✅ Check prefixes/suffixes\nprint(\"Hello\".startswith(\"He\"))  # True\nprint(\"Hello\".endswith(\"lo\"))  # True [web:91]\n\n# ✅ Count occurrences\nprint(\"Hello\".count(\"l\"))  # 2 [web:88][web:90]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"String Formatting"},{"type":"text","text":" ⭐ Critical for Prompt Engineering"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ f-strings (Python 3.6+)\nname = \"Alice\"\nage = 25\nprompt = f\"My name is {name} and I am {age} years old\"  # ✅ \"My name is Alice and I am 25 years old\" [web:88]\n\n# ✅ Template strings\nprompt = \"Hello, {}!\".format(name)  # ✅ \"Hello, Alice!\" [web:88]\n\n# ✅ Gen AI: Dynamic prompts\nuser_query = \"Explain quantum computing\"\nprompt_template = f\"\"\"\nYou are an AI assistant.\nUser: {user_query}\nAssistant:\n\"\"\"\nprint(prompt_template)  # ✅ Multi-line prompt [web:88]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"String vs Array Comparison"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ String: Immutable, character-based\ntext = \"Hello\"\nprint(text[0])  # 'H' (character)\nprint(len(text))  # 5 [web:88][web:89]\n\n# ✅ Array/List: Mutable, any-type\nchars = ['H', 'e', 'l', 'l', 'o']\nchars[0] = 'J'  # ✅ ['J', 'e', 'l', 'l', 'o']\nchars.append('!')  # ✅ ['J', 'e', 'l', 'l', 'o', '!'] [web:88]\n\n# ✅ Convert between:\ntext_to_list = list(\"Hello\")  # ✅ ['H', 'e', 'l', 'l', 'o']\nlist_to_text = \"\".join(chars)  # ✅ \"Hello\" [web:88]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use (Decision Criteria)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use String"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Array"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Text data"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Prompts, responses, user input"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align