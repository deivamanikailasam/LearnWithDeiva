ll","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Collision Resolution"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Open addressing"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Chaining (linked lists/trees)"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why Hash Maps/Dictionaries Are Essential in Generative AI"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Token Vocabularies (Most Critical Use Case)"},{"type":"text","text":"\n- LLMs map tokens → integer IDs using dictionaries: "},{"type":"text","marks":[{"type":"code"}],"text":"{\"hello\": 1543, \"world\": 2089}"},{"type":"text","text":"\n- Inverse mapping (IDs → tokens) also uses dictionaries for decoding\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"O(1) lookup"},{"type":"text","text":" enables real-time tokenization of millions of tokens"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Model Parameter Lookups"},{"type":"text","text":"\n- Named parameters: "},{"type":"text","marks":[{"type":"code"}],"text":"{\"embedding.weight\": tensor, \"attention.q_proj\": tensor}"},{"type":"text","text":"\n- Fast access to specific layers during training/debugging"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. Caching & Memoization"},{"type":"text","text":"\n- Cache prompt completions: "},{"type":"text","marks":[{"type":"code"}],"text":"{\"prompt_xyz\": \"completion_abc\"}"},{"type":"text","text":"\n- Avoid redundant API calls in generative AI applications"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"4. Configuration & Metadata"},{"type":"text","text":"\n- Store model configs: "},{"type":"text","marks":[{"type":"code"}],"text":"{\"hidden_size\": 768, \"num_layers\": 12}"},{"type":"text","text":"\n- JSON-like data structures naturally map to dictionaries"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How Hash Maps Work (Internal Mechanics)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Step-by-step hash map operation\ntoken_dict = {}\n\n# 1. Hash the key\nkey = \"hello\"\nhash_value = hash(key)  # e.g., 1234567890\n\n# 2. Map to bucket index\nbucket_index = hash_value % num_buckets  # e.g., 1234567890 % 16 = 10\n\n# 3. Store value at bucket\n# If collision (same bucket), use open addressing (Python) [web:18]\ntoken_dict[\"hello\"] = 1543"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Collision Handling in Python:"},{"type":"text","text":"\n- Uses "},{"type":"text","marks":[{"type":"bold"}],"text":"open addressing"},{"type":"text","text":": all entries in single array-like structure\n- Different from Java's "},{"type":"text","marks":[{"type":"bold"}],"text":"chaining"},{"type":"text","text":" (linked lists at each bucket)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Performance Optimization for AI"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Optimization"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Impact"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Code Example"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pre-allocate capacity"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"3× faster, zero resizes"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"dict = {key: None for key in keys}"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use immutable keys"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Required for hashability"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Strings, numbers, tuples"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Avoid bad hash functions"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Prevents O(n) degradation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Unique hashes per key"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benchmark Insight:"},{"type":"text","text":"\n- Pre-allocating capacity avoids O(n) resize operations\n- For 100K tok