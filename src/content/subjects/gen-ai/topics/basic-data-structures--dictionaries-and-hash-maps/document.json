{"format":"tiptap/v1","updatedAt":"2026-06-21T13:47:07.167Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"For "},{"type":"text","marks":[{"type":"bold"}],"text":"Generative AI"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"bold"}],"text":"dictionaries"},{"type":"text","text":" (Python's "},{"type":"text","marks":[{"type":"code"}],"text":"dict"},{"type":"text","text":") and "},{"type":"text","marks":[{"type":"bold"}],"text":"hash maps"},{"type":"text","text":" are essentially the same concept—Python dictionaries "},{"type":"text","marks":[{"type":"bold"}],"text":"are implemented as hash maps"},{"type":"text","text":". They're critical for token vocabularies, parameter lookups, and caching in AI systems."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Relationship: Dictionaries = Hash Maps"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Dictionary (Python)"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Hash Map (Concept)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Definition"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Language-specific implementation ("},{"type":"text","marks":[{"type":"code"}],"text":"dict"},{"type":"text","text":")"}]}]},{"type":"tableCell","attrs":{"colspan":1,"r