ext":"Basic Installation"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Install a single package\npip install requests\n\n# Install from PyPI (Python Package Index)\npip install numpy\npip install pandas\npip install torch"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Install Specific Version"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Install exact version\npip install requests==2.32.3\n\n# Install minimum version (and above)\npip install numpy>=1.24.0\n\n# Install version range\npip install pandas>=1.5.0,<2.0.0"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Install Multiple Packages"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Install multiple packages at once\npip install requests numpy pandas torch\n\n# Install from requirements file\npip install -r requirements.txt"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Install from Different Sources"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Install from local file\npip install ./package.tar.gz\n\n# Install from Git repository\npip install git+https://github.com/user/repo.git\n\n# Install from branch\npip install git+https://github.com/user/repo.git@branch-name\n\n# Install from PyPI pre-release\npip install --pre package-name"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Upgrading and Removing Packages"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Upgrade Packages"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Upgrade single package\npip install --upgrade requests\n\n# Upgrade all packages (not recommended)\npip list --outdated\npip install --upgrade <package-name>\n\n# Upgrade to specific version\npip install --upgrade requests==2.32.3"