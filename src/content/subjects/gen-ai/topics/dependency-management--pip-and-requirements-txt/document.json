andas==2.2.2\n\n# ML dependencies\ntorch==2.3.1\ntransformers==4.42.4\nscikit-learn==1.5.0\n\n# Utilities\npython-dotenv==1.0.1"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Install from "},{"type":"text","marks":[{"type":"code"}],"text":"requirements.txt"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Install all dependencies\npip install -r requirements.txt\n\n# Upgrade while installing\npip install -r requirements.txt --upgrade\n\n# Install without dependencies\npip install -r requirements.txt --no-deps"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices for "},{"type":"text","marks":[{"type":"code"}],"text":"requirements.txt"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Use Exact Versions"}]},{"type":"codeBlock","attrs":{"language":"txt"},"content":[{"type":"text","text":"# Good - exact versions\nrequests==2.32.3\nnumpy==1.26.4\n\n# Bad - no version specified\nrequests\nnumpy"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why:"},{"type":"text","text":" Ensures reproducible builds across environments."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Group Dependencies"}]},{"type":"codeBlock","attrs":{"language":"txt"},"content":[{"type":"text","text":"# Core\nrequests==2.32.3\nnumpy==1.26.4\n\n# Machine Learning\ntorch==2.3.1\ntransformers==4.42.4\n\n# Development\npytest==8.2.2\nblack==24.4.2"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Use Comments"}]},{"type":"codeBlock","attrs":{"language":"txt"},"content":[{"type":"text","text":"# Data processing\npandas==2.2.2\nnumpy==1.26.4\n\n# ML Training\ntorch==2.3.1\ntransformers==4.42.4  # BERT models\n\n# Utilities\npython-dotenv==1.0.1"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Separate Dev Dependencies"}]},{"type":