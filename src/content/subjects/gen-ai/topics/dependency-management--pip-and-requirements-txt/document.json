ull},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Handles non-Python deps"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"pyproject.toml support"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Learning curve"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Low"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Low"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Medium"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Medium"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Speed"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Moderate"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Moderate"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Moderate"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Slow"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"pip"},{"type":"text","text":" + "},{"type":"text","marks":[{"type":"code"}],"text":"requirements.txt"},{"type":"text","text":" is the "},{"type":"text","marks":[{"type":"bold"}],"text":"lowest common denominator"},{"type":"text","text":" — universally understood, universally supported, and sufficient for most projects. Poetry adds environment management and a better dependency declaration format. Conda adds the ability to install non-Python packages like CUDA libraries, MKL, and system tools — which matters in scientific computing. For new Generative AI projects, Poetry or Conda are increasingly recommended, but "},{"type":"text","marks":[{"type":"code"}],"text":"pip"},{"type":"text","text":" + "},{"type":"text","marks":[{"type":"code"}],"text":"requirements.txt"},{"type":"text","text":" remains the most broadly compatible baseline."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Security and Reliability"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Supply chain attacks:"},{"type":"text","text":" PyPI packages can be compromised or typosquatted (malicious packages with names similar to popular ones, e.g., "},{"type":"text","marks":[{"type":"code"}],"text":"requets"},{"type":"text","text":" instead of "},{"type":"text","marks":[{"type":"code"}],"text":"requests"},{"type":"text","text":"). Always verify package names before installing."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hash checking:"},{"type":"text","text":" pip supports verifying the integrity of downloaded packages using hashes. "},{"type":"text","marks":[{"type":"code"}],"text":"pip-compile --generate-hashes"},{"type":"text","text":" adds SHA-256 hashes to "},{"type":"text","marks":[{"type":"code"}],"text":"requirements.txt"},{"type":"text","text":", and pip verifies them on install:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"torch==2.3.0 \\\n    --hash=sha256:abc123... \\\n    --hash=sha256:def456..."}]},{"type":"paragraph","content":[{"type":"text","text":"This prevents a compromised PyPI mirror from serving tampered packages."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Yanked versions:"},{"type":"text","text":" PyPI allows package authors to \"yank\" broken versions. pip skips yanked versions unless you explicitly request them by exact version. This is a safety net but not a substitute for testing."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Known vulnerabilities:"},{"type":"text","text":" Regularly run "},{"type":"text","marks":[{"type":"code"}],"text":"pip audit"},{"type":"text","text":" or integrate it into CI to catch packages with published CVEs. Treat dependency updates as a security practice, not just a feature."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pinning and reproducibility as reliability:"},{"type":"text","text":" Beyond security, exact version pinning is itself a reliability mechanism. A deployment that worked yesterday should work identically today. Without pinning, a new release of any dependency can silently break your application on the next deployment."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"pip"},{"type":"text","text":" is Python's built-in package manager; "},{"type":"text","marks":[{"type":"code"}],"text":"requirements.txt"},{"type":"text","text":" is the standard file for recording what packages a project needs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Always use a virtual environment before running "},{"type":"text","marks":[{"type":"code"}],"text":"pip install"},{"type":"text","text":" — without one, packages pollute the global Python and conflict across projects"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"pip freeze > requirements.txt"},{"type":"text","text":" captures exact versions of everything installed; "},{"type":"text","marks":[{"type":"code"}],"text":"pip install -r requirements.txt"},{"type":"text","text":" reproduces that environment exactly"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Exact version pinning ("},{"type":"text","marks":[{"type":"code"}],"text":"=="},{"type":"text","text":") maximizes reproducibility; use "},{"type":"text","marks":[{"type":"code"}],"text":"pip-tools"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"code"}],"text":"uv"},{"type":"text","text":" to manage transitive dependency pinning automatically"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Split requirements files into "},{"type":"text","marks":[{"type":"code"}],"text":"base.txt"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"code"}],"text":"dev.txt"},{"type":"text","text":" to keep production environments lean"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"For Generative AI projects, pin CUDA-specific package builds explicitly and use a private or cached package registry in CI/CD to avoid slow downloads"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"uv"},{"type":"text","text":" is a modern, fast drop-in alternative to pip that is rapidly becoming the production standard while remaining fully compatible with "},{"type":"text","marks":[{"type":"code"}],"text":"requirements.txt"}]}]}]},{"type":"paragraph"}]}}
