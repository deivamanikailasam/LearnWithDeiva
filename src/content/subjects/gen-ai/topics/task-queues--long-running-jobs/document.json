        "content": [
          {
            "type": "text",
            "text": "Long-Running Jobs for GenAI"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A long-running GenAI job \u2014 batch document analysis, multi-file RAG ingestion, large-scale evaluation \u2014 can take minutes to hours. Three problems arise: "
          },
          {
            "type": "text",
            "text": "progress visibility",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " (clients need to know how far along the job is), "
          },
          {
            "type": "text",
            "text": "crash-resilience",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " (if the worker dies at 80%, the job should resume from 80% not from 0%), and "
          },
          {
            "type": "text",
            "text": "resource governance",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " (a job that fans out to 1,000 LLM calls must not overwhelm the API or the token quota)."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Long-running job phases with checkpointing and live progress via SSE",
          "title": null
        }
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Checkpointing"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A checkpoint is a small, durably-written record of how far a job has progressed. On worker restart the job loads its last checkpoint and skips everything already completed."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Redis-Based Checkpointing"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import json\nimport redis.asyncio as aioredis\n\nredis = aioredis.from_url(\"redis://localhost:6379/0\", decode_responses=True)\n\nasync def save_checkpoint(job_id: str, state: dict) -> None:\n    \"\"\"Overwrite the checkpoint atomically. Called after each batch completes.\"\"\"\n    key = f\"job:checkpoint:{job_id}\"\n    await redis.setex(key, 86400, json.dumps(state))  # expires after 24h\n\nasync def load_checkpoint(job_id: str) -> dict:\n    key = f\"job:checkpoint:{job_id}\"\n    raw = await redis.get(key)\n    return json.loads(raw) if raw else {}\n\nasync def clear_checkpoint(job_id: str) -> None:\n    await redis.delete(f\"job:checkpoint:{job_id}\")\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Multi-Phase Job with Resume Logic"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from anthropic import Anthropic\n\nclient = Anthropic()\n\nPHASES = [\"extract\", \"embed\", \"analyse\", \"store\"]\n\nasync def run_rag_ingestion(job_id: str, document_urls: list[str]) -> dict:\n    \"\"\"\n    Multi-phase RAG ingestion with per-phase checkpointing.\n    Safe to re-run after any crash \u2014 resumes from last checkpoint.\n    \"\"\"\n    ckpt = await load_checkpoint(job_id)\n    start_phase = ckpt.get(\"phase\", \"extract\")\n    phase_idx   = PHASES.index(start_phase)\n\n    chunks   = ckpt.get(\"chunks\",   [])\n    embeddings = ckpt.get(\"embeddings\", [])\n    analyses = ckpt.get(\"analyses\", [])\n\n    await update_job_progress(job_id, phase=start_phase, pct=0)\n\n    if phase_idx <= PHASES.index(\"extract\"):\n        chunks = await _extract_phase(job_id, document_urls)\n        await save_checkpoint(job_id, {\"phase\": \"embed\", \"chunks\": chunks})\n\n    if phase_idx <= PHASES.index(\"embed\"):\n        embeddings = await _embed_phase(job_id, chunks, ckpt.get(\"embed_batch_done\", 0))\n        await save_checkpoint(job_id, {\"phase\": \"analyse\", \"chunks\": chunks,\n                                       \"embeddings\": embeddings})\n\n    if phase_idx <= PHASES.index(\"analyse\"):\n        analyses = await _analyse_phase(job_id, chunks, ckpt.get(\"analyse_batch_done\", 0))\n        await save_checkpoint(job_id, {\"phase\": \"store\", \"analyses\": analyses})\n\n    if phase_idx <= PHASES.index(\"store\"):\n        await _store_phase(job_id, embeddings, analyses)\n\n    await clear_checkpoint(job_id)\n    return {\"chunks_processed\": len(chunks), \"analyses\": len(analyses)}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Progress Reporting"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Progress State in Redis"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Store progress as a Redis hash \u2014 cheap writes, readable from any process (the API server, the worker, monitoring):"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "async def update_job_progress(\n    job_id: str,\n    phase: str,\n    done: int = 0,\n    total: int = 0,\n    eta_s: int | None = None,\n) -> None:\n    key = f\"job:progress:{job_id}\"\n    pct = round(done / total * 100, 1) if total > 0 else 0\n    await redis.hset(key, mapping={\n        \"phase\": phase,\n        \"done\":  done,\n        \"total\": total,\n        \"pct\":   pct,\n        \"eta_s\": eta_s or 0,\n    })\n    await redis.expire(key, 86400)\n\nasync def get_job_progress(job_id: str) -> dict:\n    key = f\"job:progress:{job_id}\"\n    data = await redis.hgetall(key)\n    if not data:\n        return {\"phase\": \"unknown\", \"pct\": 0}\n    return {k: (float(v) if k in (\"pct\", \"eta_s\") else (int(v) if k in (\"done\", \"total\") else v))\n            for k, v in data.items()}\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "SSE Progress Stream Endpoint"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Let clients subscribe to a live progress stream instead of polling:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\nfrom fastapi import APIRouter\nfrom fastapi.responses import StreamingResponse\n\nrouter = APIRouter()\n\nasync def progress_generator(job_id: str):\n    \"\"\"Yields SSE events until the job reaches a terminal state.\"\"\"\n    terminal = {\"completed\", \"failed\", \"dead\"}\n    while True:\n        progress = await get_job_progress(job_id)\n        job      = await fetch_job(job_id)\n\n        data = {**progress, \"status\": job[\"status\"]}\n        yield f\"data: {json.dumps(data)}\\n\\n\"\n\n        if job[\"status\"] in terminal:\n            yield \"data: [DONE]\\n\\n\"\n            break\n        await asyncio.sleep(2)  # poll Redis every 2s\n\n@router.get(\"/v1/jobs/{job_id}/progress\")\nasync def job_progress_stream(job_id: str, auth=Depends(get_current_user)):\n    job = await fetch_job(job_id)\n    if not job or job[\"user_id\"] != auth[\"sub\"]:\n        raise HTTPException(404, \"Job not found\")\n    return StreamingResponse(\n        progress_generator(job_id),\n        media_type=\"text/event-stream\",\n        headers={\"Cache-Control\": \"no-cache\", \"X-Accel-Buffering\": \"no\"},\n    )\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Batch Phase Implementation"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The analyse phase fans out one LLM call per chunk. Process in batches to respect rate limits and enable fine-grained checkpointing:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\nimport time\nfrom anthropic import AsyncAnthropic\n\nasync_client = AsyncAnthropic()\n\nBATCH_SIZE = 10          # LLM calls per batch\nRATE_LIMIT_DELAY = 1.0   # seconds between batches\n\nasync def _analyse_phase(\n    job_id: str,\n    chunks: list[str],\n    start_batch: int = 0,\n) -> list[dict]:\n    results = []\n    batches = [chunks[i:i+BATCH_SIZE] for i in range(0, len(chunks), BATCH_SIZE)]\n    total = len(chunks)\n    start_time = time.monotonic()\n\n    for batch_idx, batch in enumerate(batches):\n        if batch_idx < start_batch:\n            continue  # resume: skip already-done batches\n\n        # Parallel LLM calls within the batch\n        tasks = [\n            async_client.messages.create(\n                model=\"claude-haiku-4-5-20251001\",\n                max_tokens=256,\n                messages=[{\"role\": \"user\", \"content\": f\"Extract key facts:\\n{chunk}\"}],\n            )\n            for chunk in batch\n        ]\n        responses = await asyncio.gather(*tasks, return_exceptions=True)\n\n        for chunk, resp in zip(batch, responses):\n            if isinstance(resp, Exception):\n                results.append({\"chunk\": chunk, \"error\": str(resp)})\n            else:\n                results.append({\"chunk\": chunk, \"facts\": resp.content[0].text})\n\n        done_count = min((batch_idx + 1) * BATCH_SIZE, total)\n        elapsed    = time.monotonic() - start_time\n        rate       = done_count / elapsed if elapsed > 0 else 1\n        eta        = int((total - done_count) / rate) if rate > 0 else 0\n\n        await update_job_progress(job_id, \"analyse\", done_count, total, eta)\n        await save_checkpoint(job_id, {\n            \"phase\": \"analyse\",\n            \"analyse_batch_done\": batch_idx + 1,\n        })\n        await asyncio.sleep(RATE_LIMIT_DELAY)\n\n    return results\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Timeout and Cancellation"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A job stuck forever is worse than one that fails cleanly. Enforce timeouts at both the task level and per-LLM-call level:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\n\nasync def _call_with_timeout(coro, timeout_s: float = 30.0):\n    \"\"\"Wrap a single LLM call with a timeout. Returns None on timeout.\"\"\"\n    try:\n        return await asyncio.wait_for(coro, timeout=timeout_s)\n    except asyncio.TimeoutError:\n        return None\n\n# In the batch loop, replace asyncio.gather with:\ntasks = [\n    _call_with_timeout(\n        async_client.messages.create(model=..., messages=..., max_tokens=256),\n        timeout_s=25.0,\n    )\n    for chunk in batch\n]\nresponses = await asyncio.gather(*tasks)\n\n# Cancellation check \u2014 useful in Celery with SoftTimeLimitExceeded\nimport signal\n\ndef _raise_timeout(signum, frame):\n    raise TimeoutError(\"Job cancelled by signal\")\n\nsignal.signal(signal.SIGTERM, _raise_timeout)\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Job Expiry and Cleanup"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Long-running jobs accumulate state \u2014 checkpoints in Redis, results in Postgres. A cleanup Celery Beat task prevents unbounded growth:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# workers/tasks/maintenance.py\nfrom workers.celery_app import celery_app\n\n@celery_app.task(queue=\"fast\")\ndef cleanup_expired_jobs():\n    \"\"\"Delete jobs and their Redis state older than their TTL.\"\"\"\n    import asyncio\n    asyncio.run(_cleanup_async())\n\nasync def _cleanup_async():\n    cutoff = datetime.utcnow() - timedelta(hours=24)\n    expired_ids = await db.fetch(\n        \"SELECT id FROM jobs WHERE completed_at < $1 OR (status = 'dead' AND created_at < $1)\",\n        cutoff,\n    )\n    for row in expired_ids:\n        job_id = row[\"id\"]\n        await redis.delete(f\"job:checkpoint:{job_id}\", f\"job:progress:{job_id}\")\n        await db.execute(\"DELETE FROM jobs WHERE id = $1\", job_id)\n"
          }
        ]
      },
