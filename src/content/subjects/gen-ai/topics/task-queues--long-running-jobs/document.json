      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Prometheus gauge for stuck jobs \u2014 emit from a monitoring task every 60s\nfrom prometheus_client import Gauge\n\nstuck_jobs_gauge = Gauge(\"genai_stuck_jobs_total\", \"Jobs running longer than their timeout\")\n\nasync def emit_stuck_jobs_metric():\n    cutoff = datetime.utcnow() - timedelta(seconds=300)  # running > 5 min\n    count = await db.fetchval(\n        \"SELECT COUNT(*) FROM jobs WHERE status = 'running' AND started_at < $1\",\n        cutoff,\n    )\n    stuck_jobs_gauge.set(count)\n"
          }
        ]
      },
