{"format":"tiptap/v1","updatedAt":"2026-06-22T03:46:28.252Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Decision Trees"},{"type":"text","text":" are a fundamental "},{"type":"text","marks":[{"type":"bold"}],"text":"supervised learning algorithm"},{"type":"text","text":" in classical machine learning that classifies or predicts by asking a sequence of "},{"type":"text","marks":[{"type":"bold"}],"text":"yes/no questions"},{"type":"text","text":" (like a flowchart), routing each example down to a leaf node that holds the final prediction."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","text":"A decision tree is a "},{"type":"text","marks":[{"type":"bold"}],"text":"hierarchical model"},{"type":"text","text":" composed of questions organized in a tree structure:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"          ┌── Root (first question)\n          │\n          ├── Internal nodes (follow-up questions)\n          │\n          └── Leaves (final predictions)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How it works"},{"type":"text","text":":\n- To predict, follow the path of answers from "},{"type":"text","marks":[{"type":"bold"}],"text":"root to leaf"},{"type":"text","text":"\n- Each "},{"type":"text","marks":[{"type":"bold"}],"text":"non-leaf node"},{"type":"text","text":" contains a condition/split/test\n- Each "},{"type":"text","marks":[{"type":"bold"}],"text":"leaf node"},{"type":"text","text":" contains the prediction\n- The set of visited nodes is called the "},{"type":"text","marks":[{"type":"bold"}],"text":"inference path"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": Predicting animal species from "},{"type":"text","marks":[{"type":"code"}],"text":"num_legs"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"code"}],"text":"num_eyes"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"        num_legs ≥ 3?\n       /            \\\n     Yes             No\n      |               |\n   num_eyes ≥ 3?     Cat\n   /        \\\n Yes        No\n  |          |\n Dog       Rabbit"}]},{"type":"paragraph","content":[{"type":"text","text":"Inference: "},{"type":"text","marks":[{"type":"code"}],"text":"num_legs=4, num_eyes=2"},{"type":"text","text":" → Yes → No → "},{"type":"text","marks":[{"type":"bold"}],"text":"Dog"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why It Matters"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Benefit"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Explanation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Interpretable"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"You can read the reasoning like a recipe—each decision path is explicit"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Non-linear"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Caves s