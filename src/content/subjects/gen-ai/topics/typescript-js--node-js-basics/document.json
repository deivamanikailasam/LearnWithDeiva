{"format":"tiptap/v1","updatedAt":"2026-06-21T13:42:07.915Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Node.js Basics"},{"type":"text","text":" for Generative AI means using Node.js as a "},{"type":"text","marks":[{"type":"bold"}],"text":"server-side runtime"},{"type":"text","text":" to securely call LLM APIs (Gemini, OpenAI, etc.), build AI-powered APIs, and create web backends—critical because you must "},{"type":"text","marks":[{"type":"bold"}],"text":"never expose API keys in client-side code"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Concept"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Definition"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Gen AI Use Case"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Node.js"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"JavaScript runtime on server (runs JS outside browser)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Backend API for LLM calls"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"npm"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Node Package Manager (installs libraries)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"npm install @google/generative-ai"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Express"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Minimal web framework for Node.js"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Build REST APIs with AI endpoints"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"dotenv"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Load environment variables from "},{"type":"text","marks":[{"type":"code"}],"text":".env"},{"type":"text","text":" file"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Secure API key storage"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"ES Modules"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Modern "},{"type":"text","marks":[{"type":"code"}],"text":"import/export"},{"type":"text","text":" syntax"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"import { GoogleGenerativeAI } from..."}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"CommonJS"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Legacy "},{"type":"text","marks":[{"type":"code"}],"text":"require()"},{"type":"text","text":" syntax"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"const express = require(\"express\")"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why It Matters for Gen AI"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ❌ CLIENT-SIDE (DANGEROUS): Exposes API key in browser\n// React component with API key:\nconst genAI = new GoogleGenerativeAI(\"YOUR_API_KEY_HERE\");  // ❌ Anyone can see!\n\n// ✅ SERVER-SIDE (SAFE): API key hidden in Node.js backend\n// Node.js server:\nimport dotenv from 'dotenv';\ndotenv.config();  // ✅ Loads from .env file (not in code)\n\nconst GEMINI_API_KEY = process.env.API_KEY;  // ✅ Hidden from frontend\nconst genAI = new GoogleGenerativeAI(GEMINI_API_KEY);"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Secure keys"},{"type":"text","text":": API keys stored in "},{"type":"text","marks":[{"type":"code"}],"text":".env"},{"type":"text","text":", never exposed to browser\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Backend APIs"},{"type":"text","text":": Build REST endpoints that frontend calls\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Async support"},{"type":"text","text":": Node.js handles millions of concurrent AI requests\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Package ecosystem"},{"type":"text","text":": 2M+ npm packages (LangChain, OpenAI SDK, etc.)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How It Works (Core Mechanics)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Project Setup"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Step 1: Create project directory\nmkdir gemini-node-app\ncd gemini-node-app\n\n# Step 2: Initialize Node.js project (creates package.json)\nnpm init -y\n\n# Step 3: Install dependencies\nnpm install express @google/generative-ai dotenv body-parser\n\n# For TypeScript (recommended for full-stack engineers):\nnpm install typescript @types/node ts-node\nnpm install --save-dev nodemon"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Configure Environment Variables"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Create .env file in project root (NEVER commit to Git!)\ncat > .env << EOF\nAPI_KEY=YOUR_GEMINI_API_KEY_HERE\nPORT=3000\nEOF\n\n# Add .env to .gitignore (prevent leaking keys)\necho \".env\" >> .gitignore"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// .env file contents:\nAPI_KEY=AIza...your-actual-api-key\nPORT=3000"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Basic Express Server with AI"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// server.js (CommonJS syntax)\nconst express = require(\"express\");\nconst bodyParser = require(\"body-parser\");\nconst { GoogleGenerativeAI } = require(\"@google/generative-ai\");\nconst dotenv = require(\"dotenv\");\n\ndotenv.config();  // ✅ Load .env variables\n\nconst app = express();\nconst port = process.env.PORT || 3000;\n\n// Middleware\napp.use(bodyParser.json());\n\n// Initialize Gemini AI (key from .env, NOT code)\nconst genAI = new GoogleGenerativeAI(process.env.API_KEY);\nconst model = genAI.getGenerativeModel({ model: \"gemini-1.5-flash\" });\n\n// ✅ GET endpoint: Test server\napp.get(\"/\", (req, res) => {\n  res.send(\"Server running! Use POST /generate for AI.\");\n});\n\n// ✅ POST endpoint: Call Gemini AI\nasync function generateResponse(req, res) {\n  const { prompt } = req.body;\n  \n  if (!prompt) {\n    return res.status(400).json({ error: \"Prompt required\" });\n  }\n\n  try {\n    const result = await model.generateContent(prompt);\n    const response = await result.response;\n    const text = response.text();\n    \n    res.json({ response: text });  // ✅ Send AI output to frontend\n  } catch (error) {\n    console.error(\"Gemini API error:\", error);\n    res.status(500).json({ error: \"AI failed\" });\n  }\n}\n\napp.post(\"/generate\", generateResponse);\n\n// Start server\napp.listen(port, () => {\n  console.log(`Server running on http://localhost:${port}`);\n});"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Run with ES Modules (Modern Syntax)"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// server.mjs (ES Module syntax with .mjs extension)\nimport express from \"express\";\nimport { GoogleGenerativeAI } from \"@google/generative-ai\";\nimport dotenv from \"dotenv\";\n\ndotenv.config();\n\nconst app = express();\nconst port = process.env.PORT || 3000;\n\napp.use(express.json());\n\nconst genAI = new GoogleGenerativeAI(process.env.API_KEY);\nconst model = genAI.getGenerativeModel({ model: \"gemini-1.5-flash\" });\n\napp.post(\"/generate\", async (req, res) => {\n  const { prompt } = req.body;\n  \n  try {\n    const result = await model.generateContent(prompt);\n    const response = await result.response;\n    res.json({ response: response.text() });\n  } catch (error) {\n    res.status(500).json({ error: \"AI failed\" });\n  }\n});\n\napp.listen(port, () => {\n  console.log(`Server running on port ${port}`);\n});"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Package.json Scripts"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"// package.json\n{\n  \"name\": \"gemini-node-app\",\n  \"version\": \"1.0.0\",\n  \"scripts\": {\n    \"start\": \"node server.js\",\n    \"dev\": \"nodemon server.js\",\n    \"type-check\": \"tsc --noEmit\"\n  },\n  \"dependencies\": {\n    \"express\": \"^4.18.2\",\n    \"@google/generative-ai\": \"^0.3.1\",\n    \"dotenv\": \"^16.3.1\",\n    \"body-parser\": \"^1.20.2\"\n  }\n}"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Run with scripts\nnpm run start    # node server.js\nnpm run dev      # nodemon server.js (auto-restarts on changes)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use (Decision Criteria)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Node.js"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Client-Side JS"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Secure API keys"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"code"}],"text":".env"},{"type":"text","text":" file"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Exposed in browser"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Production backend"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Scalable server"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Not suitable"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"AI-powered REST API"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Express endpoints"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Limited"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prototype only"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Good for testing"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ For prototyping"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Streaming responses"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Async streams"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ WebSockets"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"File processing"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Node.js file system"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Limited browser access"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rule of thumb:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Node.js"},{"type":"text","text":": Always for production AI backends\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Client-side"},{"type":"text","text":": Prototype only; never for production"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How to Implement (Step-by-Step)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 1: Get Gemini API Key"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# 1. Go to Google AI Studio\n# https://aistudio.google.com/\n\n# 2. Login with Google account\n\n# 3. Create API key\n# AI Studio → API Keys → Create New Key\n\n# 4. Copy key to .env file\necho \"API_KEY=your-api-key-here\" >> .env"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Note"},{"type":"text","text":": Free tier not available in Europe."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 2: Install Google Gen AI SDK"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"npm install @google/generative-ai"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 3: Initialize Model"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"import { GoogleGenerativeAI } from \"@google/generative-ai\";\nimport dotenv from \"dotenv\";\n\ndotenv.config();\n\nconst genAI = new GoogleGenerativeAI(process.env.API_KEY);\nconst model = genAI.getGenerativeModel({ model: \"gemini-1.5-flash\" });"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 4: Run a Prompt"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Simple text generation\nasync function generateText(prompt) {\n  const result = await model.generateContent(prompt);\n  const response = await result.response;\n  return response.text();\n}\n\nconst text = await generateText(\"Explain quantum computing\");\nconsole.log(text);"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 5: Multimodal (Image + Text)"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"import * as fs from 'fs';\n\nconst prompt = \"Does this look store-bought or homemade?\";\nconst image = {\n  inlineData: {\n    data: Buffer.from(fs.readFileSync(\"cookie.png\")).toString(\"base66\"),\n    mimeType: \"image/png\",\n  },\n};\n\nconst result = await model.generateContent([prompt, image]);\nconsole.log(result.response.text());  // ✅ AI analyzes image"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 6: Build REST API Endpoint"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// server.js\napp.post(\"/generate\", async (req, res) => {\n  const { prompt } = req.body;\n  \n  try {\n    const result = await model.generateContent(prompt);\n    const response = await result.response;\n    res.json({ response: response.text() });\n  } catch (error) {\n    res.status(500).json({ error: \"AI failed\" });\n  }\n});"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 7: Test with Postman"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# 1. Open Postman\n# 2. POST → http://localhost:3000/generate\n# 3. Body → raw → JSON\n{\n  \"prompt\": \"Explain quantum computing in 2 sentences\"\n}\n\n# 4. Click Send\n# Expected response:\n{\n  \"response\": \"Quantum computing uses quantum mechanics to process information...\"\n}"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Examples"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 1: Text Generation"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// text_generation.js\nimport { GoogleGenerativeAI } from \"@google/generative-ai\";\nimport dotenv from \"dotenv\";\n\ndotenv.config();\n\nconst genAI = new GoogleGenerativeAI(process.env.API_KEY);\nconst model = genAI.getGenerativeModel({ model: \"gemini-1.5-flash\" });\n\nconst prompt = \"Explain the theory of relativity\";\nconst result = await model.generateContent(prompt);\nconsole.log(result.response.text());"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 2: Chat with History"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// chat.js\nimport { GoogleGenerativeAI } from \"@google/generative-ai\";\nimport dotenv from \"dotenv\";\n\ndotenv.config();\n\nconst genAI = new GoogleGenerativeAI(process.env.API_KEY);\nconst model = genAI.getGenerativeModel({ model: \"gemini-1.5-flash\" });\n\nconst chat = model.startChat({\n  history: [\n    { role: \"user\", parts: [{ text: \"Hello\" }] },\n    { role: \"model\", parts: [{ text: \"Hi! How can I help?\" }] },\n  ],\n});\n\nconst result = await chat.sendMessage(\"What is quantum physics?\");\nconsole.log(result.response.text());"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 3: Express API with Streaming"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// server.js with streaming\napp.post(\"/generate/stream\", async (req, res) => {\n  const { prompt } = req.body;\n  \n  res.setHeader(\"Content-Type\", \"text/plain\");\n  res.setHeader(\"Content-Type\", \"text/event-stream\");\n  \n  const result = await model.generateContentStream(prompt);\n  \n  for await (const chunk of result.stream) {\n    const text = chunk.text();\n    res.write(text);  // ✅ Stream token by token\n  }\n  \n  res.end();\n});"}]},{"type":"horizo