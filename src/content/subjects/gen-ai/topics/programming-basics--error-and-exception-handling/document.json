e":"text","text":" — Let lower-level functions raise exceptions, catch at program edges (CLI, web handler)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"EAFP style"},{"type":"text","text":" — \"Easier to Ask Forgiveness than Permission\": try operation and handle exception if it fails"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Exceptions for errors, not control flow"},{"type":"text","text":" — Don't use exceptions for routine program branching"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use context managers"},{"type":"text","text":" — "},{"type":"text","marks":[{"type":"code"}],"text":"with"},{"type":"text","text":" statement for files, sockets, database connections"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Exception Chaining"}]},{"type":"paragraph","content":[{"type":"text","text":"When an unhandled exception occurs inside a "},{"type":"text","marks":[{"type":"code"}],"text":"try"},{"type":"text","text":" section, it gets "},{"type":"text","marks":[{"type":"bold"}],"text":"attached to the original exception"},{"type":"text","text":" [docs:8.5]:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"try:\n    open(\"database.sqlite\")\nexcept OSError:\n    raise RuntimeError(\"unable to handle error\")"}]},{"type":"paragraph","content":[{"type":"text","text":"Output shows both exceptions:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"FileNotFoundError: No such file or directory\nDuring handling of the above exception, another exception occurred:\nRuntimeError: unable to handle error"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Explicit Chaining with "},{"type":"text","marks":[{"type":"code"}],"text":"from"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"try:\n    func()\nexcept ConnectionError as exc:\n    raise RuntimeError('Failed to open database') from exc"}]},{"type":"paragraph","content":[{"type":"text","text":"Shows: \"The above exception was the direct cause of the following exception\" [docs:8.5]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Context Managers: "},{"type":"text","marks":[{"type":"code"}],"text":"with"},{"type":"text","text":" Statement"}]},{"type":"paragraph","content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"code"}],"text":"with"},{"type":"text","text":" statement ensures objects are "},{"type":"text","marks":[{"type":"bold"}],"text":"cleaned up promptly and correctly"},{"type":"text","text":" [docs:8.8]:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Without context manager (file stays open)\nfor line in open(\"myfile.txt\"):\n    print(line, end=\"\")\n\n# With context manager (file always closed)\nwith open(\"myfile.txt\") as f:\n    for line in f:\n        print(line, end=\"\")"}]},{"type":"paragraph","content":[{"type":"text","text":"The file is "},{"type":"text","marks":[{"type":"bold"}],"text":"always closed"},{"type":"text","text":" after "},{"type":"text","marks":[{"type":"code"}],"text":"with"},{"type":"text","text":", even if a problem occurs [docs:8.8]."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Generative AI & Error Handling"}]},{"type":"paragraph","content":[{"type":"text","text":"In Gen AI pipelines, "},{"type":"text","marks":[{"type":"bold"}],"text":"unhandled errors during data ingestion can crash multi-hour training jobs"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Strategies for AI-Generated Code"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Strategy"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Description"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Read error messages"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Carefully understand what the code produces"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Reproduce consistently"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Ensure you're debugging the correct issue"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Isolate the problem"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Comment out sections piece by piece"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Send errors back to LLM"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use error message as new prompt for correction"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Log with context"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Capture variable states during failure"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fail-fast principle"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Sometimes crashing is better than continuing corrupted"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Complete Production-Grade Example"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import logging\nfrom pathlib import Path\n\nclass DataProcessingError(Exception):\n    \"\"\"Custom exception for data processing failures\"\"\"\n    pass\n\ndef process_data_file(filepath):\n    try:\n        path = Path(filepath)\n        if not path.exists():\n            raise FileNotFoundError(f\"File not found: {filepath}\")\n        \n        with open(path, 'r') as f:\n            data = f.read()\n        \n        if not data.strip():\n            raise ValueError(\"File is empty\")\n        \n        return data\n    \n    except FileNotFoundError as e:\n        logging.error(f\"File error: {e}\")\n        raise DataProcessingError(f\"Cannot process file: {e}\") from e\n    \n    except ValueError as e:\n        logging.error(f\"Validation error: {e}\")\n        raise DataProcessingError(f\"Invalid data: {e}\") from e\n    \n    except Exception as e:\n        logging.error(f\"Unexpected error: {e}, type: {type(e)}\")\n        raise DataProcessingError(f\"Processing failed: {e}\") from e\n    \n    finally:\n        logging.info(\"Data processing completed (or failed)\")\n\n# Usage\ntry:\n    result = process_data_file(\"data.csv\")\nexcept DataProcessingError as e:\n    print(f\"Failed: {e}\")"}]},{"type":"paragraph","content":[{"type":"text","text":"This demonstrates: custom exceptions, logging, exception chaining, small "},{"type":"text","marks":[{"type":"code"}],"text":"try"},{"type":"text","text":" blocks, and "},{"type":"text","marks":[{"type":"code"}],"text":"finally"},{"type":"text","text":" cleanup."}]},{"type":"paragraph","content":[{"type":"text","text":"Understanding error and exception handling is essential for writing "},{"type":"text","marks":[{"type":"bold"}],"text":"robust, production-grade code"},{"type":"text","text":" in Generative AI applications."}]}]}}
