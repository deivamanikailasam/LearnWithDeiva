                      {
                        "type": "text",
                        "text": "Strategy"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableHeader",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "STS-B ρ (no FT)"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableHeader",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Extra params"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableHeader",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Best for"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "marks": [
                          {
                            "type": "code"
                          }
                        ],
                        "text": "[CLS]"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "≈ 0.30"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "None"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Fine-tuned NSP tasks; avoid for similarity without FT"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Mean"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "≈ 0.60 ★"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "None"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Semantic similarity, search, clustering — strong default"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Max"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "≈ 0.54"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "None"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Classification, presence-of-feature tasks"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Weighted"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Task-dependent"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "hidden_size weights"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "When token importance is asymmetric (e.g. topic sentences)"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "SBERT (mean + FT)"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "≈ 0.85"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "None"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "All semantic similarity tasks — best overall"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Fine-tuning matters far more than pooling strategy. SBERT with mean pooling and fine-tuning (ρ ≈ 0.85) beats every pooling strategy applied to a frozen BERT (best: ρ ≈ 0.60). Pooling selection is relevant when you cannot fine-tune — otherwise prioritize training data and loss function."
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Using sentence-transformers"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "sentence-transformers"
          },
          {
            "type": "text",
            "text": " library handles pooling for you via a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "Pooling"
          },
          {
            "type": "text",
            "text": " module that is composed with the transformer backbone:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from sentence_transformers import SentenceTransformer, models\n\n# Inspect the pooling module of a pre-built model\nmodel = SentenceTransformer(\"all-MiniLM-L6-v2\")\nfor name, module in model.named_modules():\n    if \"Pooling\" in type(module).__name__:\n        print(module.get_config_dict())\n# {'word_embedding_dimension': 384,\n#  'pooling_mode_cls_token': False,\n#  'pooling_mode_mean_tokens': True,    <-- mean pooling is active\n#  'pooling_mode_max_tokens': False, ...}\n\n# Build a custom model with max pooling instead\ntransformer = models.Transformer(\"bert-base-uncased\")\npooling = models.Pooling(\n    transformer.get_word_embedding_dimension(),\n    pooling_mode_mean_tokens=False,\n    pooling_mode_max_tokens=True,\n)\ncustom_model = SentenceTransformer(modules=[transformer, pooling])"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Layer-Level Pooling"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Pooling across layers (rather than across tokens) is a separate but related idea. Instead of using only the last hidden layer, you can combine multiple layers:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "inputs = tokenizer(\"The cat sat\", return_tensors=\"pt\")\nwith torch.no_grad():\n    outputs = model(**inputs, output_hidden_states=True)\n\n# outputs.hidden_states: tuple of (n_layers + 1) tensors of shape (1, T, 768)\n# Concatenate last 4 layers then mean-pool across tokens\nlast_4 = torch.stack(outputs.hidden_states[-4:], dim=0)  # (4, 1, T, 768)\nmean_layers = last_4.mean(dim=0)                          # (1, T, 768)\nsentence_vec = mean_layers.mean(dim=1)                    # (1, 768)\n\n# Alternative: sum last 4 layers (common in NER tasks)\nsum_layers = last_4.sum(dim=0).mean(dim=1)               # (1, 768)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Layer combination is most relevant when you extract embeddings from a frozen model (no fine-tuning). Earlier layers carry more syntactic information; later layers are more task-specific. For semantic similarity with fine-tuning, the last layer with mean pooling is typically sufficient."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Practical Recommendations"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Default choice:"
                  },
                  {
                    "type": "text",
                    "text": " Use mean pooling. It requires no extra parameters, is fast, and generalizes well across tasks."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Never use raw [CLS] for similarity"
                  },
                  {
                    "type": "text",
                    "text": " without fine-tuning — the NSP pre-training objective does not produce comparable sentence vectors."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Fine-tuning dominates:"
                  },
                  {
                    "type": "text",
                    "text": " Any pooling strategy on a fine-tuned SBERT model will outperform the best pooling on a frozen model."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Padding correctness:"
                  },
                  {
                    "type": "text",
                    "text": " Always apply the attention mask when pooling. Including padding token embeddings in the mean/max distorts the result, especially for short sentences in a batch."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
