:[{"type":"text","marks":[{"type":"bold"}],"text":"LSTM"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Adds gating mechanism (forget, input, output gates) to control memory"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"GRU"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Simplified gating; better long-range dependency handling"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"LSTM gates"},{"type":"text","text":" regulate memory manipulation:\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Forget gate"},{"type":"text","text":": Discards irrelevant information\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Input gate"},{"type":"text","text":": Adds valuable information\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Output gate"},{"type":"text","text":": Contributes useful information to output"}]},{"type":"paragraph","content":[{"type":"text","text":"This equips LSTMs to learn "},{"type":"text","marks":[{"type":"bold"}],"text":"when to forget, disregard, or retain"},{"type":"text","text":" information."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Example: Text Processing with RNN"}]},{"type":"paragraph","content":[{"type":"text","text":"When analyzing a sentence like \"The cat sits on the mat\":"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Step 1: Input \"The\"\n  Hidden state: [sentence starting]\n  \nStep 2: Input \"cat\"\n  Hidden state: [subject = cat]\n  \nStep 3: Input \"sits\"\n  Hidden state: [cat is doing something = sitting]\n  \nStep 4: Input \"on\"\n  Hidden state: [location information coming]\n  \nStep 5: Input \"the\"\n  Hidden state: [specific object following]\n  \nStep 6: Input \"mat\"\n  Hidden state: [complete sentence meaning]\n  \nOutput: Next word prediction (e.g., \".\", \"quietly\", \"softly\")"}]},{"type":"paragraph","content":[{"type":"text","text":"The hidden state updates to reflect the "},{"type":"text","marks":[{"type":"bold"}],"text":"meaning of the sentence up to that point"},{"type":"text","text":"."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Example: Time Series Forecasting"}]},{"type":"paragraph","content":[{"type":"text","text":"For hourly temperature readings:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Hour 1: Temperature = 20°C\n  Hidden state: [past = 20°]\n  Prediction: 21°C\n\nHour 2: Temperature = 21°C\n  Hidden state: [past = 20°, 21°]\n  Prediction: 22°C\n\nHour 3: Temperature = 22°C\n  Hidden state: [past = 20°, 21°, 22°]\n  Prediction: 23°C"}]},{"type":"paragraph","content":[{"type":"text","text":"At each hour, the RNN uses the "},{"type":"text","marks":[{"type":"bold"}],"text":"current temperature and hidden state (which summarizes past temperatures)"},{"type":"text","text":" to predict the next value."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sequence processing"},{"type":"text","text":" handles ordered data where order matters (text, audio, time series)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"RNNs use "},{"type":"text","marks":[{"type":"bold"}],"text":"loops and hidden states"},{"type":"text","text":" to pass information from one step to the next"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Parameter sharing"},{"type":"text","text":": Same weights reused at each time step (efficient for any length)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Three main architectures"},{"type":"text","text":": One-to-Many (image captioning), Many-to-One (sentiment), Many-to-Many (translation)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hidden state acts as memory"},{"type":"text","text":", capturing context from previous inputs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Basic RNNs struggle with long sequences"},{"type":"text","text":" due to vanishing gradients (forget early information)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"LSTM/GRU"},{"type":"text","text":" solve this with gating mechanisms for better long-term memory"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Essential for "},{"type":"text","marks":[{"type":"bold"}],"text":"text generation, machine translation, speech recognition"},{"type":"text","text":", and time series analysis"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Sequence processing is what makes RNNs the foundation for tasks like speech recognition, machine translation, and time series analysis in generative AI, despite their limitations with long sequences."}]}]}}
