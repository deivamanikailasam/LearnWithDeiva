{"format":"tiptap/v1","updatedAt":"2026-06-21T13:50:36.564Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"A "},{"type":"text","marks":[{"type":"bold"}],"text":"tuple"},{"type":"text","text":" is an ordered, fixed-size collection of values grouped together as a single unit, where each position has a specific type and meaning. Unlike arrays or lists that can grow/shrink, tuples represent immutable data with a predictable structure—ideal for coordinates, function return values, and lightweight data grouping without needing a full class or object."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tuple"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Array/List"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Size"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Fixed (cannot add/remove elements)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Variable (can grow/shrink)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mutability"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Immutable (values cannot change after creation)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Mutable (can modify elements)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Types"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Heterogeneous (different types at each position)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Homogeneous (all elements share same type)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Structure"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Each position has meaning (e.g., index 0 = x, index 1 = y)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Positions are interchangeable (all same type)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Memory"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Uses less memory (fixed size)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Uses more memory (dynamic)"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why It Matters"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ❌ WITHOUT tuple: No type safety, unclear structure\nfunction getUserData(): any {\n  return [\"Alice\", 25, true];  // ❌ What does each value mean?\n}\n\nconst data = getUserData();\nconsole.log(data [w3schools](https://www.w3schools.com/python/python_tuples.asp));  // ❌ Is this age? Count? ID?\n\n// ✅ WITH tuple: Type-safe, clear structure\nfunction getUserData(): [string, number, boolean] {\n  return [\"Alice\", 25, true];  // ✅ [name, age, active]\n}\n\nconst [name, age, isActive] = getUserData();\nconsole.log(age);  // ✅ TypeScript knows this is number [web:79][web:81]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Type safety"},{"type":"text","text":": Each position has defined type\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Clear intent"},{"type":"text","text":": Signals \"fixed structure\" to other developers\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Compact"},{"type":"text","text":": Group related values without creating a class\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Immutable"},{"type":"text","text":": Prevents accidental modifications"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How It Works (Core Patterns)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Tuple Declaration in TypeScript"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ✅ Fixed-length tuple with specific types\nconst coordinate: [number, number] = [10, 20];  // [x, y]\nconst rgb: [number, number, number] = [255, 0, 0];  // [red, green, blue]\n\n// ✅ Heterogeneous types (different types at each position)\nconst user: [string, number, boolean] = [\"Alice\", 25, true];\n// Index 0: string (name)\n// Index 1: number (age)\n// Index 2: boolean (active) [web:79][web:81]\n\n// ✅ Tuple with optional elements\nconst optionalTuple: [string, number?] = [\"Alice\", 25];  // ✅\nconst optionalTuple2: [string, number?] = [\"Bob\"];  // ✅ age is optional"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Tuple vs Array Comparison"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ❌ Array: Variable length, all same type\nconst numbers: number[] = [1, 2, 3];  // Can add more: numbers.push(4)\nconst mixed: (string | number)[] = [\"a\", 1, \"b\"];  // Any order, any count [web:79][web:83]\n\n// ✅ Tuple: Fixed length, specific types per position\nconst pair: [number, number] = [1, 2];  // ❌ Cannot add: pair.push(3)\nconst triple: [string, number, boolean] = [\"Alice\", 25, true];  // ✅ Exact structure [web:79][web:81]\n\n// TypeScript enforcement:\nconst invalidPair: [number, number] = [1, 2, 3];  // ❌ Error: 3 elements, expected 2 [web:83]\nconst invalidTriple: [string, number, boolean] = [1, \"Alice\", true];  // ❌ Error: type mismatch [web:83]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Function Return Values with Tuples"},{"type":"text","text":" ⭐ Common Use Case"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ✅ Return multiple values with clear types\nfunction divide(a: number, b: number): [number, number] {\n  const quotient = a / b;\n  const remainder = a % b;\n  return [quotient, remainder];  // ✅ [quotient, remainder]\n}\n\nconst [q, r] = divide(10, 3);\nconsole.log(q);  // 3.333 (number)\nconsole.log(r);  // 1 (number) [web:79][web:80]\n\n// ✅ Named tuple elements for clarity\ntype DivisionResult = [quotient: number, remainder: number];\n\nfunction divideNamed(a: number, b: number): DivisionResult {\n  return [a / b, a % b];\n}\n\nconst result = divideNamed(10, 3);\nconsole.log(result[0]);  // quotient [web:80]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Tuple Immutability (Python)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Python tuple: Immutable\ncoordinate = (10, 20)  # ✅ Create tuple\nprint(coordinate[0])   # 10 (access)\n\n# ❌ Cannot modify:\ncoordinate[0] = 15  # ❌ TypeError: 'tuple' object doesn't support item assignment [web:78][web:82]\n\n# ✅ Can create new tuple:\nnew_coordinate = (15, 20)  # ✅ New tuple\n\n# ✅ Tuples with different types:\nuser = (\"Alice\", 25, True)  # ✅ [string, int, bool] [web:78][web:84]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Tuple Access & Iteration"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ✅ Access by index\nconst user: [string, number, boolean] = [\"Alice\", 25, true];\nconsole.log(user[0]);  // \"Alice\" (string)\nconsole.log(user [w3schools](https://www.w3schools.com/python/python_tuples.asp));  // 25 (number)\nconsole.log(user [youtube](https://www.youtube.com/watch?v=Sm_SiatCru4));  // true (boolean) [web:78][web:84]\n\n// ✅ Tuple unpacking (destructuring)\nconst [name, age, isActive] = user;\nconsole.log(name);  // \"Alice\"\nconsole.log(age);   // 25 [web:79]\n\n// ✅ Iterate (tuples are iterable)\nfor (const value of user) {\n  console.log(value);  // \"Alice\", 25, true [web:86]\n}"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use (Decision Criteria)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Tuple"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Array"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Object"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fixed structure"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Coordinates "},{"type":"text","marks":[{"type":"code"}],"text":"[x, y]"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Variable length"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Overhead"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multiple return values"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"code"}],"text":"[quotient, remainder]"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Unclear types"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Named props"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key-value pairs"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"code"}],"text":"[key, value]"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Homogeneous only"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Named keys"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Homogeneous list"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Fixed size"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"code"}],"text":"number[]"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Wrong structure"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Named fields"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Index-based"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Index-based"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"code"}],"text":"{ name, age }"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Dynamic size"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Fixed"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Can grow/shrink"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Add/remove props"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rule of thumb:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Tuples"},{"type":"text","text":": Fixed-length mix-type structured data (coordinates, return values)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Arrays"},{"type":"text","text":": Dynamic homogeneous collections (lists of numbers, strings)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Objects"},{"type":"text","text":": Named fields with clarity ("},{"type":"text","marks":[{"type":"code"}],"text":"{ name: \"Alice\", age: 25 }"},{"type":"text","text":")"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How to Implement (Step-by-Step)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 1: Define Tuple Type"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// Type annotation with tuple syntax\nconst point: [number, number] = [10, 20];  // [x, y]\nconst color: [number, number, number] = [255, 0, 0];  // [r, g, b]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 2: Use in Functions"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// Return tuple from function\nfunction getMinMax(numbers: number[]): [number, number] {\n  const min = Math.min(...numbers);\n  const max = Math.max(...numbers);\n  return [min, max];  // ✅ [min, max]\n}\n\nconst [min, max] = getMinMax([3, 1, 4, 1, 5]);\nconsole.log(min);  // 1\nconsole.log(max);  // 5 [web:79]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 3: Tuple with Optional Elements"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// Optional second element\nconst pair: [string, number?] = [\"Alice\", 25];  // ✅\nconst single: [string, number?] = [\"Bob\"];  // ✅ number is optional\n\n// Access with check:\nif (pair [w3schools](https://www.w3schools.com/python/python_tuples.asp) !== undefined) {\n  console.log(pair [w3schools](https://www.w3schools.com/python/python_tuples.asp));  // 25 (number)\n}"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 4: Named Tuple Elements (TypeScript 4.0+)"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// Named elements for clarity\ntype Point = [x: number, y: number];\nconst point: Point = [10, 20];\n\nconsole.log(point[0]);  // x = 10\nconsole.log(point [w3schools](https://www.w3schools.com/python/python_tuples.asp));  // y = 20 [web:80]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Examples"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 1: 2D Coordinates"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ✅ Tuple for fixed coordinate structure\ntype Coordinate2D = [x: number, y: number];\n\nconst point1: Coordinate2D = [10, 20];\nconst point2: Coordinate2D = [30, 40];\n\nfunction distance(p1: Coordinate2D, p2: Coordinate2D): number {\n  const dx = p2[0] - p1[0];\n  const dy = p2 [w3schools](https://www.w3schools.com/python/python_tuples.asp) - p1 [w3schools](https://www.w3schools.com/python/python_tuples.asp);\n  return Math.sqrt(dx * dx + dy * dy);\n}\n\nconsole.log(distance(point1, point2));  // 28.28 [web:79][web:80]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 2: RGB Color"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ✅ Tuple for RGB color (fixed 3 values)\ntype RGB = [red: number, green: number, blue: number];\n\nconst color: RGB = [255, 128, 0];  // ✅ [red, green, blue]\n\nfunction toHex(rgb: RGB): string {\n  return `#${rgb[0].toString(16)}${rgb [w3schools](https://www.w3schools.com/python/python_tuples.asp).toString(16)}${rgb [youtube](https://www.youtube.com/watch?v=Sm_SiatCru4).toString(16)}`;\n}\n\nconsole.log(toHex(color));  // \"#ff800\" [web:80]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 3: Python Tuple"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Python: Immutable tuple\nuser = (\"Alice\", 25, True)  # ✅ [name, age, active]\n\nprint(user[0])  # \"Alice\"\nprint(user [w3schools](https://www.w3schools.com/python/python_tuples.asp))  # 25\n\n# ❌ Cannot modify:\nuser[0] = \"Bob\"  # ❌ TypeError [web:78][web:82]\n\n# ✅ Can unpack:\nname, age, active = user\nprint(name)  # \"Alice\" [web:84]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Real-World Example: API Response with Tuple"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Scale"},{"type":"text","text":": Production TypeScript API client\n"},{"type":"text","marks":[{"type":"bold"}],"text":"Architecture"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ✅ API returns tuple with success flag + data/error\ntype APIResponse<T> = [success: boolean, data: T | null, error: string | null];\n\nasync function fetchUser(id: number): APIResponse<User> {\n  try {\n    const response = await fetch(`/api/users/${id}`);\n    const user = await response.json();\n    return [true, user, null];  // ✅ [success, data, error]\n  } catch (error) {\n    return [false, null, error.message];  // ✅ [success, data, error]\n  }\n}\n\n// Usage with unpacking:\nconst [success, user, error] = await fetchUser(1);\n\nif (success) {\n  console.log(user.name);  // ✅ TypeScript knows user is User\n} else {\n  console.error(error);  // ✅ TypeScript knows error is string\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Outcome"},{"type":"text","text":": Clear success/error handling with type safety."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Common Mistakes to Avoid"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader",