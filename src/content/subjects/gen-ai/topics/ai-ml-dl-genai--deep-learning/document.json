text","text":"So:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"DL"},{"type":"text","text":" = deep neural networks that learn complex patterns"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Gen AI"},{"type":"text","text":" = deep learning models that learn the data distribution and "},{"type":"text","marks":[{"type":"bold"}],"text":"generate new content"},{"type":"text","text":" from it"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Deep Learning"},{"type":"text","text":" is a specialized subset of ML using multi-layer neural networks to learn hierarchical representations from data."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Classical ML"},{"type":"text","text":" uses simpler models, often needs manual features, and is strong on tabular data; "},{"type":"text","marks":[{"type":"bold"}],"text":"DL"},{"type":"text","text":" learns features automatically and is strong on images, speech, and text."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"DL requires "},{"type":"text","marks":[{"type":"bold"}],"text":"large data + GPUs"},{"type":"text","text":", while classical ML is cheaper, faster, and more interpretable."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Generative AI"},{"type":"text","text":" is built on deep learning: transformers, GANs, diffusion models — all DL architectures."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"DL is the "},{"type":"text","marks":[{"type":"bold"}],"text":"powerhouse"},{"type":"text","text":" behind Face ID, self-driving cars, speech recognition, and modern LLMs."}]}]}]},{"type":"paragraph"}]}}
