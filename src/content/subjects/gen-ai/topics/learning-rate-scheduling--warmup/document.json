{"format":"tiptap/v1","updatedAt":"2026-06-22T09:08:04.830Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What Warmup Is"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Warmup"},{"type":"text","text":" is a learning rate scheduling technique where the learning rate starts "},{"type":"text","marks":[{"type":"bold"}],"text":"very low"},{"type":"text","text":" and is "},{"type":"text","marks":[{"type":"bold"}],"text":"gradually increased"},{"type":"text","text":" to a target learning rate during the initial phase of training."}]},{"type":"paragraph","content":[{"type":"text","text":"The warm-up phase is an initial period where the learning rate ramps up from a "},{"type":"text","marks":[{"type":"bold"}],"text":"very low value (e.g., 1e-8) to a target learning rate"},{"type":"text","text":". This technique is designed to "},{"type":"text","marks":[{"type":"bold"}],"text":"stabilize training"},{"type":"text","text":", especially at the beginning when model weights are randomly initialized."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why Warmup Matters in Generative AI"}]},{"type":"paragraph","content":[{"type":"text","text":"Warmup solves critical problems in training deep neural networks, especially large models:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Problem"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Warmup Solution"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Irregular early training"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Prevents large initial updates that could destabilize the model"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Poor convergence"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Avoids suboptimal learning paths"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Overcommitting to early batches"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Small LR prevents overcommitting to any single batch's noisy gradients"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Large batch training"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Essential for stability with batch sizes >1000"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Transformers/LLMs"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Standard practice for state-of-the-art architectures"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Warm-up is "},{"type":"text","marks":[{"type":"bold"}],"text":"one of the most efficient network training regularization techniques"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How Warmup Works"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Core Idea"}]},{"type":"paragraph","content":[{"type":"text","text":"Instead of starting with a high learning rate that could cause instability, warmup:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Starts low"},{"type":"text","text":": Very small learning rate (e.g., 1e-8 or 1e-5)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Gradually increases"},{"type":"text","text":": Ramps up to target learning rate over N steps"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Holds constant"},{"type":"text","text":": Maintains target LR for main training phase"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Then decays"},{"type":"text","text":": Reduces LR for fine-tuning (often combined with decay)"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Linear Warmup (Most Common)"}]},{"type":"paragraph","content":[{"type":"text","text":"The learning rate increases "},{"type":"text","marks":[{"type":"bold"}],"text":"linearly"},{"type":"text","text":" with each step:"}]},{"type":"blockMath","attrs":{"latex":"\\text{lr}_{\\text{step}} = \\text{lr}_{\\text{init}} + \\frac{\\text{step}}{\\text{warmup\\_steps}} \\times (\\text{lr}_{\\text{target}} - \\text{lr}_{\\text{init}})"}},{"type":"paragraph","content":[{"type":"text","text":"Where:\n- "},{"type":"inlineMath","attrs":{"latex":"\\text{lr}_{\\text{init}}"}},{"type":"text","text":": Initial low learning rate (often 0 or 1e-8)\n- "},{"type":"inlineMath","attrs":{"latex":"\\text{lr}_{\\text{target}}"}},{"type":"text","text":": Target learning rate\n- "},{"type":"inlineMath","attrs":{"latex":"\\text{warmup\\_steps}"}},{"type":"text","text":": Number of warmup steps\n- "},{"type":"inlineMath","attrs":{"latex":"\\text{step}"}},{"type":"text","text":": Current training step"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Simplified (starting from 0)"},{"type":"text","text":":\n\\[\n\\text{lr}"},{"type":"text","marks":[{"type":"italic"}],"text":"{\\text{step}} = \\frac{\\text{step}}{\\text{warmup\\"},{"type":"text","text":"steps}} \\times \\text{lr}"},{"type":"text","marks":[{"type":"italic"}],"text":"{\\text{target}}\n\\]"}]},{"type":"paragraph","content":[{"type":"text","text":"[github](https://github.com/Sion1225/Warmup_Exponential_decay_LS)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Constant Warmup"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Constant warmup: use lr_init for warmup_steps, then switch to lr_target\nstep_now <= warmup_steps:\n    lr = lr_init\nstep_now > warmup_steps:\n    lr = lr_target"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem"},{"type":"text","text":": Abrupt change from lr_init to lr_target"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Gradual (Linear) Warmup"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Gradual warmup: smooth transition from lr_init to lr_target\nstep_now <= warmup_steps:\n    lr = lr_init + (step_now / warmup_steps) * (lr_target - lr_init)\nstep_now > warmup_steps:\n    lr = lr_target"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Advantage"},{"type":"text","text":": Smoothly connects lr_init and lr_target with intermediate steps"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why Warmup Works (The Mechanisms)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Allows Larger Target Learning Rates"}]},{"type":"paragraph","content":[{"type":"text","text":"The overwhelming benefit of warmup is "},{"type":"text","marks":[{"type":"bold"}],"text":"allowing the network to tolerate larger target learning rates"},{"type":"text","text":" by forcing it into "},{"type":"text","marks":[{"type":"bold"}],"text":"well-conditioned areas of the loss landscape"},{"type":"text","text":"."}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Without warmup"},{"type":"text","text":": Large LR causes instability → must use smaller LR"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"With warmup"},{"type":"text","text":": Small initial LR stabilizes → can use larger target LR"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Prevents Overcommitting to Noisy Gradients"}]},{"type":"paragraph","content":[{"type":"text","text":"During warmup, the model learns from every batch at a "},{"type":"text","marks":[{"type":"bold"}],"text":"small learning rate that prevents overcommitting"},{"type":"text","text":" to any single batch's noisy gradients."}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Early batches have "},{"type":"text","marks":[{"type":"bold"}],"text":"high variance"},{"type":"text","text":" (model weights are random)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Small LR prevents catastrophic updates"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Smooth Transition to High-Gradient Regions"}]},{"type":"paragraph","content":[{"type":"text","text":"Warmup allows the model to "},{"type":"text","marks":[{"type":"bold"}],"text":"transition smoothly from initial parameter space to regions of higher gradients"},{"type":"text","text":"."}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Starts in low-gradient region (random initialization)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Gradually moves to high-gradient region (learning)"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Improves Hyperparameter Robustness"}]},{"type":"paragraph","content":[{"type":"text","text":"The ability to handle larger target learning rates makes "},{"type":"text","marks":[{"type":"bold"}],"text":"hyperparameter tuning more robust"},{"type":"text","text":" while improving final performance."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Warmup + Decay Schedule (Transformer Style)"}]},{"type":"paragraph","content":[{"type":"text","text":"Most modern approaches combine warmup with decay:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Full schedule: Warmup + Linear/Exponential Decay\n# Warmup phase\nstep_now <= warmup_steps:\n    lr = (lr_target / warmup_steps) * step_now\n\n# Decay phase\nstep_now > warmup_steps:\n    lr = lr_target * decay_factor^(step_now - warmup_steps)"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Warmup"},{"type":"text","text":": Quickly adapt through large-scale learning"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Decay"},{"type":"text","text":": Converge to target rate through differentiable function"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Warmup Duration Guidelines"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Warmup Duration"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Large datasets"},{"type":"text","text":" (≥100M parameters)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"5–10% of total training steps"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Transformers"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"200–5000 steps (depends on model size)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"LLMs"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"2000–10000 steps"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Small models"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"50–500 steps"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Large batch training"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"10–20% of total steps"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rule of thumb"},{"type":"text","text":": For large models/datasets, warmup for "},{"type":"text","marks":[{"type":"bold"}],"text":"5–10% of total training steps"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Warmup in PyTorch"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Using CosineSchedule with Warmup"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import torch\nimport torch.optim as optim\nfrom torch.optim.lr_scheduler import CosineAnnealingLR\n\nmodel = torch.nn.Linear(10, 1)\noptimizer = optim.Adam(model.parameters(), lr=0.001)\n\ntotal_steps = 10000\nwarmup_steps = 1000  # 10% warmup\n\n# Custom warmup + cosine decay\ndef get_lr(step):\n    if step < warmup_steps:\n        # Linear warmup\n        return (step / warmup_steps) * 0.001\n    else:\n        # Cosine decay\n        decay_steps = total_steps - warmup_steps\n        return 0.001 * 0.5 * (1 + math.cos(math.pi * (step - warmup_steps) / decay_steps))\n\nscheduler = torch.optim.lr_scheduler.LambdaLR(optimizer, lr_lambda=get_lr)\n\n# Training loop\nfor step in range(total_steps):\n    train_step()\n    scheduler.step()\n    print(f\"Step {step}, LR: {scheduler.get_last_lr()[0]}\")"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Using LinearLR with Warmup"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from torch.optim.lr_scheduler import LinearLR, SequentialLR\n\n# Warmup scheduler\nwarmup_scheduler = LinearLR(\n    optimizer,\n    start_factor=0.001,  # Start at 0.001 * lr\n    end_factor=1.0,      # End at lr\n    total_steps=warmup_steps\n)\n\n# Main scheduler (constant LR)\nmain_scheduler = optim.lr_scheduler.ConstantLR(\n    optimizer,\n    factor=1.0,\n    total_steps=total_steps - warmup_steps\n)\n\n# Combine them\nscheduler = SequentialLR(\n    optimizer,\n    schedulers=[warmup_scheduler, main_scheduler],\n    milestones=[warmup_steps]\n)"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Warmup in TensorFlow/Keras"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Using PolynomialDecay with Warmup"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import tensorflow as tf\n\n# Warmup + decay schedule\ndef warmup_decay_schedule(step, warmup_steps, total_steps, lr_initial, lr_target):\n    if step < warmup_steps:\n        # Linear warmup\n        return lr_initial + (step / warmup_steps) * (lr_target - lr_initial)\n    else:\n        # Polynomial decay\n        decay_steps = total_steps - warmup_steps\n        return tf.keras.optimizers.schedules.PolynomialDecay(\n            lr_target, decay_steps, end_learning_rate=lr_initial * 0.01\n        )(step - warmup_steps)\n\n# Create optimizer with learning rate schedule\nlr_schedule = lambda step: warmup_decay_schedule(\n    step,\n    warmup_steps=1000,\n    total_steps=10000,\n    lr_initial=1e-8,\n    lr_target=1e-3\n)\n\noptimizer = tf.keras.optimizers.Adam(learning_rate=lr_schedule)\n\nmodel.fit(train_data, train_labels, epochs=100, optimizer=optimizer)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Using CosineDecay with Warmup"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from tensorflow.keras.optimizers.schedules import CosineDecay\n\ntotal_steps = 10000\nwarmup_steps = 1000\nlr_target = 0.001\n\ndef cosine_with_warmup(step):\n    if step < warmup_steps:\n        # Linear warmup\n        return (step / warmup_steps) * lr_target\n    else:\n        # Cosine decay\n        decay_steps = total_steps - warmup_steps\n        return CosineDecay(\n            lr_target, decay_steps, alpha=0.01\n        )(step - warmup_steps)\n\noptimizer = tf.keras.optimizers.Adam(learning_rate=cosine_with_warmup)"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Warmup vs. High Initial Learning Rate"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Approach"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Behavior"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Performance"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Warmup"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Start low, ramp up"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Better convergence, robust"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"High initial LR"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Start high, decay"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Risk of instability, poor convergence"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key insight"},{"type":"text","text":": Warmup is superior because it allows larger target LR while maintaining stability, whereas starting high risks catastrophic updates."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"When to Use Warmup"}]},{"type":"paragraph","content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"bold"}],"text":"Use Warmup When"},{"type":"text","text":":\n- Training "},{"type":"text","marks":[{"type":"bold"}],"text":"Transformers"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"bold"}],"text":"LLMs"},{"type":"text","text":" (standard practice)\n- Using "},{"type":"text","marks":[{"type":"bold"}],"text":"large batch sizes"},{"type":"text","text":" (>1000)\n- Model has "},{"type":"text","marks":[{"type":"bold"}],"text":"many parameters"},{"type":"text","text":" (≥100M)\n- Training on "},{"type":"text","marks":[{"type":"bold"}],"text":"large datasets"},{"type":"text","text":"\n- Want "},{"type":"text","marks":[{"type":"bold"}],"text":"more robust hyperparameter tuning"}]},{"type":"paragraph","content":[{"type":"text","text":"❌ "},{"type":"text","marks":[{"type":"bold"}],"text":"Don't Use Warmup When"},{"type":"text","text":":\n- Training "},{"type":"text","marks":[{"type":"bold"}],"text":"small models"},{"type":"text","text":" on "},{"type":"text","marks":[{"type":"bold"}],"text":"small datasets"},{"type":"text","text":" (unnecessary)\n- Using "},{"type":"text","marks":[{"type":"bold"}],"text":"very small batch sizes"},{"type":"text","text":" (less critical)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Quick experiments"},{"type":"text","text":" (skip for speed)"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of warmup as "},{"type":"text","marks":[{"type":"bold"}],"text":"starting a car engine gently"},{"type":"text","text":":"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cold engine"},{"type":"text","text":" (random weights): Don't rev immediately"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Gradually increase RPM"},{"type":"text","text":" (warmup): Start slow, ramp up"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Reach cruising speed"},{"type":"text","text":" (target LR): Full performance"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Avoid engine damage"},{"type":"text","text":" (stability): Prevents catastrophic updates"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Think of warmup as "},{"type":"text","marks":[{"type":"bold"}],"text":"a race swimmer entering the water"},{"type":"text","text":":"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Dip toes in"},{"type":"text","text":" (low LR): Feel the water"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Gradually enter"},{"type":"text","text":" (warmup): Smooth transition"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Full swim"},{"type":"text","text":" (target LR): Competition mode"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Avoid shock"},{"type":"text","text":" (stability): Don't jump in cold water"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Warmup"},{"type":"text","text":": Start with low LR, gradually increase to target LR"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Initial LR"},{"type":"text","text":": Very low value (1e-8 or 1e-5)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mechanism"},{"type":"text","text":": Forces network into well-conditioned loss landscape areas"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefit"},{"type":"text","text":": Allows larger target LR while maintaining stability"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Linear warmup"},{"type":"text","text":": "},{"type":"inlineMath","attrs":{"latex":"\\text{lr} = \\frac{\\text{step}}{\\text{warmup\\_steps}} \\times \\text{lr}_{\\text{target}}"}}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Constant warmup"},{"type":"text","text":": Fixed LR for warmup_steps, then abrupt switch"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Gradual warmup"},{"type":"text","text":": Smooth transition using linear interpolation"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Duration"},{"