{"format": "tiptap/v1", "updatedAt": "2026-06-22T08:50:56.221Z", "doc": {"type": "doc", "content": [{"type": "image", "attrs": {"src": "data:image/svg+xml;base64,", "alt": "tf.data — concept overview"}}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "What "}, {"type": "text", "marks": [{"type": "code"}], "text": "tf.data"}, {"type": "text", "text": " Is"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}, {"type": "code"}], "text": "tf.data"}, {"type": "text", "text": " is TensorFlow's high-level API for building efficient, scalable input pipelines to load and preprocess data for training deep learning models. It's the recommended way to handle data in TensorFlow/Keras, especially for large datasets that don't fit in memory."}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Think of "}, {"type": "text", "marks": [{"type": "code"}], "text": "tf.data"}, {"type": "text", "text": " as a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "data pipeline factory"}, {"type": "text", "text": " that chains together operations like loading, transforming, batching, and prefetching data—producing a dataset iterator that feeds your model during training."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Why "}, {"type": "text", "marks": [{"type": "code"}], "text": "tf.data"}, {"type": "text", "text": " Matters in Generative AI"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Generative models (GANs, diffusion, LLMs) require massive datasets and complex preprocessing:"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Challenge"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "tf.data"}, {"type": "text", "text": " Solution"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Large image datasets"}, {"type": "text", "text": " (millions of images for GANs)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Loads data from disk efficiently without loading all into memory"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Real-time augmentation"}, {"type": "text", "text": " (flips, crops, colors for diffusion)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Applies transformations via "}, {"type": "text", "marks": [{"type": "code"}], "text": "map()"}, {"type": "text", "text": " on-the-fly"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "GPU training bottlenecks"}, {"type": "text", "text": " (GPU waits for data)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "prefetch()"}, {"type": "text", "text": " preloads next batch while GPU trains"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Multi-worker training"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Parallel loading with "}, {"type": "text", "marks": [{"type": "code"}], "text": "num_parallel_calls=tf.data.AUTOTUNE"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Custom data formats"}, {"type": "text", "text": " (medical images, text)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Supports generators, CSVs, TFRecords, custom formats"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Shuffling large datasets"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Memory-efficient shuffle with buffer"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "tf.data"}, {"type": "text", "text": " enables efficient input pipelines crucial for training large-scale generative models."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Core Concepts"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "The "}, {"type": "text", "marks": [{"type": "code"}], "text": "tf.data.Dataset"}, {"type": "text", "text": " Object"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "A "}, {"type": "text", "marks": [{"type": "code"}], "text": "Dataset"}, {"type": "text", "text": " represents a potentially large set of elements, where each element can be:\n- A single tensor\n- A tuple of tensors (e.g., "}, {"type": "text", "marks": [{"type": "code"}], "text": "image, label"}, {"type": "text", "text": ")\n- A nested structure of tensors"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import tensorflow as tf\n\n# Create dataset from various sources\ndataset = tf.data.Dataset.from_tensor_slices([1, 2, 3, 4])\n\n# Each element is a scalar\nfor element in dataset:\n    print(element)  # 1, 2, 3, 4"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Pipeline Operations"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "You build pipelines by chaining transformations:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "dataset = dataset\n    .map(transform)      # Apply function to each element\n    .shuffle(buffer)     # Randomize order\n    .batch(size)         # Group into batches\n    .prefetch(n)         # Preload next batch"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Key Operations"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "1. Loading Data"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# From NumPy arrays (small datasets)\ndataset = tf.data.Dataset.from_tensor_slices((images, labels))\n\n# From Python generator (custom data)\ndef data_generator():\n    for i in range(1000):\n        yield load_image(i), load_label(i)\n\ndataset = tf.data.Dataset.from_generator(data_generator)\n\n# From TFRecords (large-scale production)\ndataset = tf.data.TFRecordDataset(\"data.tfrecord\")\n\n# From files (images, CSV)\ndataset = tf.data.Dataset.list_files(\"images/*.jpg\")\ndataset = dataset.map(load_and_parse_image)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "2. Mapping Transformations ("}, {"type": "text", "marks": [{"type": "code"}], "text": "map"}, {"type": "text", "text": ")"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Apply preprocessing to each element:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "def normalize_img(image, label):\n    \"\"\"Normalize: uint8 -> float32\"\"\"\n    return tf.cast(image, tf.float32) / 255., label\n\ndataset = dataset.map(\n    normalize_img,\n    num_parallel_calls=tf.data.AUTOTUNE  # Parallel processing [web:59]\n)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Common transformations"}, {"type": "text", "text": ":\n- Normalize images to "}, {"type": "text", "marks": [{"type": "code"}], "text": "[0, 1]"}, {"type": "text", "text": "\n- Resize images ("}, {"type": "text", "marks": [{"type": "code"}], "text": "tf.image.resize"}, {"type": "text", "text": ")\n- Apply augmentations (flip, crop, color jitter)\n- Parse text ("}, {"type": "text", "marks": [{"type": "code"}], "text": "tf.io.parse_text"}, {"type": "text", "text": ")"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "3. Shuffling ("}, {"type": "text", "marks": [{"type": "code"}], "text": "shuffle"}, {"type": "text", "text": ")"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Randomize data order for training:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "dataset = dataset.shuffle(\n    buffer_size=10000,  # Shuffle buffer size [web:59]\n    seed=42\n)"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "For "}, {"type": "text", "marks": [{"type": "bold"}], "text": "true randomness"}, {"type": "text", "text": ", set "}, {"type": "text", "marks": [{"type": "code"}], "text": "buffer_size"}, {"type": "text", "text": " to full dataset size"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "For "}, {"type": "text", "marks": [{"type": "bold"}], "text": "large datasets"}, {"type": "text", "text": ", use "}, {"type": "text", "marks": [{"type": "code"}], "text": "buffer_size=1000"}, {"type": "text", "text": " if system allows"}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "4. Batching ("}, {"type": "text", "marks": [{"type": "code"}], "text": "batch"}, {"type": "text", "text": ")"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Group elements into batches:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "dataset = dataset.batch(\n    batch_size=32,\n    drop_remainder=True  # Drop incomplete batch [web:59]\n)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "5. Caching ("}, {"type": "text", "marks": [{"type": "code"}], "text": "cache"}, {"type": "text", "text": ")"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Store data in memory after first epoch:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Cache before shuffle for better performance\ndataset = dataset.cache()\n\n# For large datasets, cache after batch\ndataset = dataset.batch(128).cache()"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "6. Prefetching ("}, {"type": "text", "marks": [{"type": "code"}], "text": "prefetch"}, {"type": "text", "text": ")"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Overlap preprocessing and training:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Preload next batch while GPU trains current batch\ndataset = dataset.prefetch(tf.data.AUTOTUNE)  # [web:59]"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Without prefetching: GPU waits for data → bottleneck\nWith prefetching: GPU trains batch N while batch N+1 loads → no bottleneck"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Complete Training Pipeline Example"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "MNIST with Keras (From TFDS)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import tensorflow as tf\nimport tensorflow_datasets as tfds\n\n# Step 1: Create input pipeline\n(ds_train, ds_test), ds_info = tfds.load(\n    'mnist',\n    split=['train', 'test'],\n    shuffle_files=True,      # Shuffle files [web:59]\n    as_supervised=True,      # Returns (img, label) tuple [web:59]\n    with_info=True\n)\n\n# Normalize images: uint8 -> float32\ndef normalize_img(image, label):\n    return tf.cast(image, tf.float32) / 255., label\n\n# Training pipeline\nds_train = ds_train.map(normalize_img, num_parallel_calls=tf.data.AUTOTUNE)\nds_train = ds_train.cache()                          # Cache before shuffle [web:59]\nds_train = ds_train.shuffle(ds_info.splits['train'].num_examples)  # Full buffer [web:59]\nds_train = ds_train.batch(128)\nds_train = ds_train.prefetch(tf.data.AUTOTUNE)       # Prefetch [web:59]\n\n# Evaluation pipeline (no shuffle)\nds_test = ds_test.map(normalize_img, num_parallel_calls=tf.data.AUTOTUNE)\nds_test = ds_test.batch(128)\nds_test = ds_test.cache()                            # Cache after batch [web:59]\nds_test = ds_test.prefetch(tf.data.AUTOTUNE)\n\n# Step 2: Create and train model\nmodel = tf.keras.models.Sequential([\n    tf.keras.layers.Flatten(input_shape=(28, 28)),\n    tf.keras.layers.Dense(128, activation='relu'),\n    tf.keras.layers.Dense(10)\n])\n\nmodel.compile(\n    optimizer=tf.keras.optimizers.Adam(0.001),\n    loss=tf.keras.losses.SparseCategoricalCrossentropy(from_logits=True),\n    metrics=[tf.keras.metrics.SparseCategoricalAccuracy()]\n)\n\nmodel.fit(\n    ds_train,\n    epochs=6,\n    validation_data=ds_test  # Pass dataset directly [web:59]\n)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "DCGAN with tf.data (Image Generation)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import tensorflow as tf\n\nIMG_SIZE = 64\nBATCH_SIZE = 32\n\ndef load_and_parse(image_path):\n    image = tf.io.read_file(image_path)\n    image = tf.image.decode_jpeg(image, channels=3)\n    image = tf.image.resize(image, [IMG_SIZE, IMG_SIZE])\n    image = tf.cast(image, tf.float32) / 255.0  # Normalize [0, 1]\n    return image\n\n# Create dataset from image files\nimage_paths = tf.io.gfile.glob(\"data/images/*.jpg\")\ndataset = tf.data.Dataset.from_tensor_slices(image_paths)\n\n# Build training pipeline\ndataset = dataset.map(load_and_parse, num_parallel_calls=tf.data.AUTOTUNE)\ndataset = dataset.shuffle(buffer_size=10000)\ndataset = dataset.batch(BATCH_SIZE)\ndataset = dataset.prefetch(tf.data.AUTOTUNE)\n\n# Train GAN\ndiscriminator = build_discriminator()\ngenerator = build_generator()\n\nfor epoch in range(100):\n    for real_images in dataset:  # tf.data feeds model [web:63]\n        # Generate fake\n        noise = tf.random.normal([BATCH_SIZE, 128])\n        fake_images = generator(noise, training=True)\n        \n        # Train discriminator\n        with tf.GradientTape() as tape:\n            real_pred = discriminator(real_images, training=True)\n            fake_pred = discriminator(fake_images, training=True)\n            loss = compute_d_loss(real_pred, fake_pred)\n        \n        grads = tape.gradient(loss, discriminator.trainable_variables)\n        discriminator.optimizer.apply_gradients(grads, discriminator.trainable_variables)\n        \n        # Train generator\n        # ... (similar pattern)"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Performance Tips"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Use "}, {"type": "text", "marks": [{"type": "code"}], "text": "tf.data.AUTOTUNE"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Automatic tuning for parallelism\ndataset.map(transform, num_parallel_calls=tf.data.AUTOTUNE)\ndataset.prefetch(tf.data.AUTOTUNE)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Avoid Python Generators for Large Data"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# ❌ Slow: Python generator bottleneck\ndef slow_generator():\n    for i in range(1000000):\n        yield load_image(i)\ndataset = tf.data.Dataset.from_generator(slow_generator)\n\n# ✅ Fast: Use tf.data operations\ndataset = tf.data.Dataset.list_files(\"images/*.jpg\")\ndataset = dataset.map(load_and_parse, num_parallel_calls=tf.data.AUTOTUNE)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Cache Strategically"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Small dataset: cache everything\ndataset = dataset.cache()\n\n# Large dataset: cache after batching\ndataset = dataset.batch(128).cache()"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Integration with Keras"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Plug Dataset into "}, {"type": "text", "marks": [{"type": "code"}], "text": "model.fit()"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# tf.data passes directly to Keras\nmodel.fit(\n    ds_train,\n    epochs=100,\n    validation_data=ds_test\n)\n\n# Keras handles iteration automatically"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Compare with Alternatives"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Method"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use Case"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Performance"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "NumPy arrays"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Small datasets (<1GB)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Fast loading, high memory"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Python generator"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Custom data, simple"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Slow (Python bottleneck)"}]}]}]}, {"type": "tableRow", "content": [{"type"