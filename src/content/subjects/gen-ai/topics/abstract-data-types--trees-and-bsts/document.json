{"format":"tiptap/v1","updatedAt":"2026-06-21T14:01:11.151Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Trees"},{"type":"text","text":" are hierarchical, non-linear data structures where nodes are connected in parent-child relationships, forming branches without cycles. A "},{"type":"text","marks":[{"type":"bold"}],"text":"Binary Search Tree (BST)"},{"type":"text","text":" is a specialized tree where each node has at most two children (left and right), with the "},{"type":"text","marks":[{"type":"bold"}],"text":"left child < parent < right child"},{"type":"text","text":" ordering, enabling efficient O(log n) search, insert, and delete operations—critical for Gen AI for decision trees, indexing token vocabularies, and hierarchical data organization."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tree"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Binary Search Tree (BST)"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Array/Linked List"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Structure"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Hierarchical (parent-child)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Hierarchical + sorted"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Linear (sequential)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Children"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Any number (0 to n)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"At most 2 (left + right)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"1 (next element)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Ordering"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No inherent order"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Left < Parent < Right"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Sequential only"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Root"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Topmost node (single)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Topmost node"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"First element"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Leaf"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Node with no children"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Node with no children"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Last element"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Search"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n) (traverse all)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(log n) average"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n) (linear)"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why It Matters for Gen AI"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ❌ WITHOUT tree: Linear search for AI vocabulary (slow)\nvocabulary = [\"apple\", \"banana\", \"cat\", \"dog\", \"elephant\"]  # Array\ndef find_word(word):\n    for i, w in vocabulary:  # ✅ O(n) linear search\n        if w == word:\n            return i\n    return -1\n\nfind_word(\"elephant\")  # ❌ Must check all 5 words [web:124][web:125]\n\n# ✅ WITH BST: Binary search for AI vocabulary (fast)\nclass Node:\n    def __init__(self, word):\n        self.word = word  # Data\n        self.left = None  # Left child (< word)\n        self.right = None  # Right child (> word) [web:124]\n\nclass BST:\n    def insert(self, root, word):\n        if root is None:\n            return Node(word)\n        if word < root.word:\n            root.left = self.insert(root.left, word)  # ✅ Left < parent\n        else:\n            root.right = self.insert(root.right, word)  # ✅ Right > parent [web:124][web:126]\n        return root\n    \n    def search(self, root, word):\n        if root is None:\n            return None\n        if word == root.word:\n            return root  # ✅ Found\n        if word < root.word:\n            return self.search(root.left, word)  # ✅ Search left\n        return self.search(root.right, word)  # ✅ Search right [web:124][web:126]\n\n# Usage: AI vocabulary with O(log n) search\nbst = BST()\nroot = None\nroot = bst.insert(root, \"apple\")\nroot = bst.insert(root, \"banana\")\nroot = bst.insert(root, \"cat\")\nroot = bst.insert(root, \"dog\")\nroot = bst.insert(root, \"elephant\")\n\nbst.search(root, \"elephant\")  # ✅ Found in O(log 5) ≈ 2 steps (vs 5 steps) [web:124][web:126]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Efficient search"},{"type":"text","text":": O(log n) vs O(n) for arrays\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Hierarchical data"},{"type":"text","text":": Decision trees, XML/JSON parsing, file systems\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Sorted order"},{"type":"text","text":": In-order traversal returns sorted data\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"AI foundation"},{"type":"text","text":": Decision trees, classification, regression, routing tables"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How It Works (Core Concepts)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Tree Terminology"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Tree structure:\n#       A (root)\n#      / \\\n#     B   C (children of A)\n#    /\n#   D (leaf: no children)\n\n# ✅ Key terms:\n# - Root: Topmost node (A) [web:124]\n# - Parent: Node with children (A is parent of B, C) [web:124]\n# - Child: Node with parent (B, C are children of A) [web:124]\n# - Leaf: Node with no children (D) [web:124]\n# - Height: Max distance from root to leaf (2 for this tree) [web:122]\n# - Depth: Distance from root to node (D has depth 2) [web:122]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Binary Search Tree (BST) Properties"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ BST ordering: Left < Parent < Right\nclass Node:\n    def __init__(self, value):\n        self.value = value\n        self.left = None  # Left child < value [web:124]\n        self.right = None  # Right child > value [web:124]\n\n# ✅ Create BST:\n#       5\n#      / \\\n#     3   7\n#    /   /\n#   2   6\n\n# Left subtree (3, 2) < 5, Right subtree (7, 6) > 5 [web:124][web:125]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"BST Insert Operation"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"class BST:\n    def insert(self, root, value):\n        if root is None:\n            return Node(value)  # ✅ Create new node\n        \n        if value < root.value:\n            root.left = self.insert(root.left, value)  # ✅ Insert left (< parent)\n        elif value > root.value:\n            root.right = self.insert(root.right, value)  # ✅ Insert right (> parent)\n        \n        return root  # ✅ Return root [web:124][web:126]\n\n# Visualization:\nroot = None\nroot = bst.insert(root, 5)  #  [scribd](https://www.scribd.com/presentation/975093900/19-AVL-Tree-I-1)\nroot = bst.insert(root, 3)  # [5, 3(left)]\nroot = bst.insert(root, 7)  # [5, 3(left), 7(right)]\nroot = bst.insert(root, 2)  # [5, 3(left, 2), 7(right)]\nroot = bst.insert(root, 6)  # [5, 3(left, 2), 7(right, 6)] [web:124]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"BST Search Operation"},{"type":"text","text":" ⭐ O(log n)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"class BST:\n    def search(self, root, value):\n        if root is None:\n            return None  # ✅ Not found\n        \n        if value == root.value:\n            return root  # ✅ Found [web:124][web:126]\n        \n        if value < root.value:\n            return self.search(root.left, value)  # ✅ Search left subtree\n        return self.search(root.right, value)  # ✅ Search right subtree\n\n# Usage: O(log n) search\nroot = bst.insert(None, 5)\nroot = bst.insert(root, 3)\nroot = bst.insert(root, 7)\n\nresult = bst.search(root, 3)  # ✅ Found in O(log 3) ≈ 1-2 steps\nprint(result.value)  # 3 [web:124][web:126]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"BST Traversal Methods"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"class BST:\n    # ✅ In-order traversal: Left → Parent → Right (returns sorted)\n    def inorder(self, root):\n        if root:\n            self.inorder(root.left)  # ✅ Visit left\n            print(root.value)  # ✅ Visit parent\n            self.inorder(root.right)  # ✅ Visit right [web:119][web:126]\n    \n    # ✅ Pre-order traversal: Parent → Left → Right\n    def preorder(self, root):\n        if root:\n            print(root.value)  # ✅ Visit parent\n            self.preorder(root.left)  # ✅ Visit left\n            self.preorder(root.right)  # ✅ Visit right [web:124]\n    \n    # ✅ Post-order traversal: Left → Right → Parent\n    def postorder(self, root):\n        if root:\n            self.postorder(root.left)  # ✅ Visit left\n            self.postorder(root.right)  # ✅ Visit right\n            print(root.value)  # ✅ Visit parent [web:124]\n\n# Example tree:\n#       5\n#      / \\\n#     3   7\n#    /   /\n#   2   6\n\nbst.inorder(root)  # ✅ 2 → 3 → 5 → 6 → 7 (sorted!) [web:119][web:126]\nbst.preorder(root)  # ✅ 5 → 3 → 2 → 7 → 6 [web:124]\nbst.postorder(root)  # ✅ 2 → 3 → 6 → 7 → 5 [web:124]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Self-Balancing BSTs (AVL, Red-Black)"},{"type":"text","text":" ⭐ Critical for Production"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ❌ Unbalanced BST: Can become O(n) like linked list\n#       1\n#        \\\n#         2\n#          \\\n#           3\n#            \\\n#             4  # Height = 4, search = O(4) ≈ O(n) [web:122]\n\n# ✅ Balanced BST (AVL): Height = O(log n)\n#       2\n#      / \\\n#     1   3\n#        /\n#       4  # Height = 2, search = O(2) ≈ O(log n) [web:122]\n\n# AVL Tree: Balance factor = height(left) - height(right) must be -1, 0, or 1 [web:122]\n# Auto-balances after insert/delete to maintain O(log n) height [web:118][web:122]\n\n# Red-Black Tree: Used in Java TreeMap, C++ map [web:119]\n# Maintains balance with color properties (red/black) [web:118]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use (Decision Criteria)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Tree/BST"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Array/Hash Table"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sorted data"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ In-order traversal returns sorted"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Unsorted (hash)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Range queries"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Find all values between 10-20"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ O(n) scan"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Decision logic"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Decision trees for classification"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Flat structure"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hierarchical data"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ XML/JSON, file systems"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Linear"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fast search"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ O(log n) average"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ O(1) hash (but unsorted)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Dynamic size"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Easy insert/delete"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ O(n) shift (array)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Indexing"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Database B-trees"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Limited"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prefix search"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Tries (tree variant)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ O(n) scan"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rule of thumb:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Tree/BST"},{"type":"text","text":": Sorted data + range queries + decision logic (AI classification, vocab indexing)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Array"},{"type":"text","text":": Static data + random access "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://www.uvm.edu/~cbcafier/cs2240/content/02_c++_essentials/09_linked_lists.html","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"uvm"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Hash Table"},{"type":"text","text":": O(1) search + no ordering needed"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How to Implement (Step-by-Step)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 1: Create Node Class"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"class Node:\n    def __init__(self, value):\n        self.value = value\n        self.left = None  # Left child < value [web:124]\n        self.right = None  # Right child > value [web:124]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 2: Create BST Class"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"class BST:\n    def __init__(self):\n        self.root = None  # Start with empty tree [web:124]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 3: Implement Insert"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"def insert(self, value):\n    self.root = self._insert(self.root, value)\n\ndef _insert(self, root, value):\n    if root is None:\n        return Node(value)\n    if value < root.value:\n        root.left = self._insert(root.left, value)\n    else:\n        root.right = self._insert(root.right, value)\n    return root"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 4: Implement Search"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"def search(self, value):\n    return self._search(self.root, value)\n\ndef _search(self, root, value):\n    if root is None:\n        return None\n    if value == root.value:\n        return root\n    if value < root.value:\n        return self._search(root.left, value)\n    return self._search(root.right, value)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 5: Use in Gen AI (Decision Tree)"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Decision tree for AI classification\nclass DecisionNode:\n    def __init__(self, feature, threshold, left=None, right=None, result=None):\n        self.feature = feature  # Feature to check (e.g., \"word length\")\n        self.threshold = threshold  # Threshold (e.g., > 5)\n        self.left = left  # Left child (feature <= threshold)\n        self.right = right  # Right child (feature > threshold)\n        self.result = result  # Leaf: classification result\n\ndef classify(node, features):\n    if node.result is not None:\n        return node.result  # ✅ Leaf: return result\n    \n    if features[node.feature] <= node.threshold:\n        return classify(node.left, features)  # ✅ Go left\n    return classify(node.right, features)  # ✅ Go right [web:121][web:124]\n\n# Example: Classify text as \"spam\" or \"not spam\"\ntree = DecisionNode(\n    feature=\"word_count\",\n    threshold=10,\n    left=DecisionNode(result=\"not spam\"),  # ✅ Word count ≤ 10 → not spam\n    right=DecisionNode(\n        feature=\"has_link\",\n        threshold=1,\n        left=DecisionNode(result=\"not spam\"),  # ✅ No link → not spam\n        right=DecisionNode(result=\"spam\")  # ✅ Has link → spam\n    )\n)\n\nclassify(tree, {\"word_count\": 15, \"has_link\": 1})  # ✅ \"spam\" [web:121][web:124]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Time Complexity"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Operation"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"BST (Average)"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"BST (Worst)"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Array"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Hash Table"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Search"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(log n)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(1)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":