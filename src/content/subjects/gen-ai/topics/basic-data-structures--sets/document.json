:null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(1)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use case"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Uniqueness, membership"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Ordered sequences"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Key-value mapping"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Fixed sequences"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Memory overhead"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Medium (hash table)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Low"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"High"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Very low"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Set vs. list for membership testing:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import time\n\ndata_list = list(range(1_000_000))\ndata_set  = set(range(1_000_000))\n\n# List: scans up to 1 million elements\n999_999 in data_list   # ~50ms\n\n# Set: direct hash lookup\n999_999 in data_set    # ~0.05ms — ~1000x faster"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Security & Reliability"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hash collision attacks"},{"type":"text","text":" — In older Python versions, predictable hash values for strings made sets vulnerable to denial-of-service via deliberate collision flooding. Python 3.3+ enables "},{"type":"text","marks":[{"type":"bold"}],"text":"hash randomization"},{"type":"text","text":" by default ("},{"type":"text","marks":[{"type":"code"}],"text":"PYTHONHASHSEED"},{"type":"text","text":"), making hash values unpredictable across runs and preventing this class of attack"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Non-deterministic order"},{"type":"text","text":" — Code that relies on set iteration order is fragile. With hash randomization, the same set may iterate in different orders across Python runs. Never serialize or compare sets by iteration order"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Thread safety"},{"type":"text","text":" — Python's GIL provides some protection, but concurrent modification of a set from multiple threads is not safe. Use "},{"type":"text","marks":[{"type":"code"}],"text":"threading.Lock"},{"type":"text","text":" or switch to thread-safe data structures for concurrent workloads"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"frozenset for safe sharing"},{"type":"text","text":" — When passing a set to external functions or storing it as a constant, use "},{"type":"text","marks":[{"type":"code"}],"text":"frozenset"},{"type":"text","text":" to guarantee it cannot be accidentally mutated"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of a set like a "},{"type":"text","marks":[{"type":"bold"}],"text":"bag of uniquely colored marbles"},{"type":"text","text":". You can throw in any number of marbles, but if you try to add a color that already exists, nothing changes — the bag simply keeps what it has. When you want to know if a specific color is in the bag, you do not have to search through each marble one by one; the bag tells you instantly. And when you combine two bags, the result automatically contains only one of each color, never doubles."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"A set stores "},{"type":"text","marks":[{"type":"bold"}],"text":"unique, unordered, hashable elements"},{"type":"text","text":" using a hash table for O(1) average-case membership testing"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Sets are ideal for "},{"type":"text","marks":[{"type":"bold"}],"text":"deduplication, fast lookup, and mathematical relational operations"},{"type":"text","text":" (union, intersection, difference)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Always use "},{"type":"text","marks":[{"type":"code"}],"text":"set()"},{"type":"text","text":" (not "},{"type":"text","marks":[{"type":"code"}],"text":"{}"},{"type":"text","text":") to create an empty set; "},{"type":"text","marks":[{"type":"code"}],"text":"{}"},{"type":"text","text":" creates an empty dictionary"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Elements must be "},{"type":"text","marks":[{"type":"bold"}],"text":"immutable (hashable)"},{"type":"text","text":" — strings, numbers, and tuples are allowed; lists and dicts are not"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use "},{"type":"text","marks":[{"type":"code"}],"text":"frozenset"},{"type":"text","text":" when you need an "},{"type":"text","marks":[{"type":"bold"}],"text":"immutable set"},{"type":"text","text":" (e.g., as a dictionary key or shared constant)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Sets are significantly "},{"type":"text","marks":[{"type":"bold"}],"text":"faster than lists for membership tests"},{"type":"text","text":", especially at large scale"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"When both uniqueness and frequency count, combine sets with "},{"type":"text","marks":[{"type":"code"}],"text":"collections.Counter"},{"type":"text","text":" or use a dictionary directly"}]}]}]},{"type":"paragraph"}]}}
