ragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Confusion Matrix"},{"type":"text","text":" = 2×2 (binary) or n×n (multi-class) table comparing actual vs. predicted values"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"TP"},{"type":"text","text":": Correct positive prediction (True=1, Predicted=1)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"TN"},{"type":"text","text":": Correct negative prediction (True=0, Predicted=0)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"FP"},{"type":"text","text":": Incorrect positive (Type I error) — True=0, Predicted=1"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"FN"},{"type":"text","text":": Incorrect negative (Type II error) — True=1, Predicted=0"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Essential tool"},{"type":"text","text":": Provides detailed insights into TP, TN, FP, FN"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Beyond accuracy"},{"type":"text","text":": Shows where model is confusing classes"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Imbalanced data"},{"type":"text","text":": Better than accuracy for imbalanced datasets"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"All metrics derived"},{"type":"text","text":": Accuracy, Precision, Recall, F1 calculated from matrix"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multi-class"},{"type":"text","text":": n×n matrix, diagonal=correct, o