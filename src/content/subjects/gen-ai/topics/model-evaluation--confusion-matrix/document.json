:"text","text":"Measures "},{"type":"text","marks":[{"type":"bold"}],"text":"proportion of actual positives correctly identified"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"High recall"},{"type":"text","text":" = Catching most real positives (few false negatives)."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"4. F1 Score"}]},{"type":"blockMath","attrs":{"latex":"\\text{F1} = 2 \\times \\frac{\\text{Precision} \\times \\text{Recall}}{\\text{Precision} + \\text{Recall}}"}},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Harmonic mean"},{"type":"text","text":" of precision and recall — balances both concerns."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"5. Misclassification Rate (Error Rate)"}]},{"type":"blockMath","attrs":{"latex":"\\text{Error Rate} = \\frac{FP + FN}{TP + TN + FP + FN}"}},{"type":"paragraph","content":[{"type":"text","text":"Proportion of "},{"type":"text","marks":[{"type":"bold"}],"text":"incorrect predictions"},{"type":"text","text":"."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"6. True Positive Rate (Sensitivity/Recall)"}]},{"type":"blockMath","attrs":{"latex":"\\text{TPR} = \\frac{TP}{TP + FN}"}},{"type":"paragraph","content":[{"type":"text","text":"Same as "},{"type":"text","marks":[{"type":"bold"}],"text":"Recall"},{"type":"text","text":"."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"7. False Positive Rate"}]},{"type":"blockMath","attrs":{"latex":"\\text{FPR} = \\frac{FP}{FP + TN}"}},{"type":"paragraph","content":[{"type":"text","text":"Proportion of negatives incorrectly classified as positive."}]},{"type":"horizontalRul