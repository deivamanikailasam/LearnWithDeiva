":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Object that returns next item (has "},{"type":"text","marks":[{"type":"code"}],"text":"__iter__()"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"code"}],"text":"__next__()"},{"type":"text","text":")"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"list_iterator"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"tuple_iterator"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Generator"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Special iterator created with function + "},{"type":"text","marks":[{"type":"code"}],"text":"yield"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Generator function"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key relationship:"},{"type":"text","text":" Every generator is an iterator, but not every iterator is a generator."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Iterators: The Iterator Protocol"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What is an Iterator?"}]},{"type":"paragraph","content":[{"type":"text","text":"An "},{"type":"text","marks":[{"type":"bold"}],"text":"iterator"},{"type":"text","text":" is an object that implements the "},{"type":"text","marks":[{"type":"bold"}],"text":"iterator protocol"},{"type":"text","text":" — it has two methods:\n- "},{"type":"text","marks":[{"type":"code"}],"text":"__iter__()"},{"type":"text","text":" — returns the iterator object itself\n- "},{"type":"text","marks":[{"type":"code"}],"text":"__next__()"},{"type":"text","text":" — returns the next item from the sequence"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Creating an Iterator"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Create iterator from a list\nmy_list = [1, 2, 3, 4, 5]\niterator = iter(my_list)  # Convert list to iterator\n\n# Use next() to get items one at a time\nprint(next(iterator))  # Output: 1\nprint(next(iterator))  # Output: 2\nprint(next(iterator))  # Output: 3"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Iterator Behavior"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Remembers state"},{"type":"text","text":" — keeps track of where it is during iteration"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Lazy evaluation"},{"type":"text","text":" — produces values only when requested"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Ends with StopIteration"},{"type":"text","text":" — raises exception when no more items"}]}]}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"iterator = iter([1, 2, 3])\nprint(next(iterator))  # 1\nprint(next(iterator))  # 2\nprint(next(iterator))  # 3\nprint(next(iterator))  # StopIteration exception!"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Manual Iterator with Class"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"class CountDown:\n    def __init__(self, start):\n        self.current = start\n    \n    def __iter__(self):\n        return self\n    \n    def __next__(self):\n        if self.current <= 0:\n            raise StopIteration\n        self.current -= 1\n        return self.current + 1\n\n# Use the iterator\nfor num in CountDown(3):\n    print(num)  # Output: 3, 2, 1"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Generators: The Easy Iterator"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What is a Generator?"}]},{"type":"paragraph","content":[{"type":"text","text":"A "},{"type":"text","marks":[{"type":"bold"}],"text":"generator"},{"type":"text","text":" is a special type of iterator defined using a function containing one or more "},{"type":"text","marks":[{"type":"code"}],"text":"yield"},{"type":"text","text":" expressions."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key difference:"},{"type":"text","text":" Generator functions "},{"type":"text","marks":[{"type":"bold"}],"text":"automatically handle"},{"type":"text","text":" "},{"type":"text","marks":[{"type":"code"}],"text":"__iter__()"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"code"}],"text":"__next__()"},{"type":"text","text":" methods for you."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Creating a Generator"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Generator function with yield\ndef count_up_to(n):\n    i = 1\n    while i <= n:\n        yield i  # Returns value, pauses function\n        i += 1\n\n# Use the generator\nfor num in count_up_to(3):\n    print(num)  # Output: 1, 2, 3"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How Generators Work"}]},{"type":"paragraph","content":[{"type":"text","text":"When you call a generator function:\n1. It "},{"type":"text","marks":[{"type":"bold"}],"text":"doesn't execute immediately"},{"type":"text","text":" — returns a generator object\n2. Function runs until first "},{"type":"text","marks":[{"type":"code"}],"text":"yield"},{"type":"text","text":" — returns that value\n3. Each "},{"type":"text","marks":[{"type":"code"}],"text":"next()"},{"type":"text","text":" call resumes execution after last "},{"type":"text","marks":[{"type":"code"}],"text":"yield"},{"type":"text","text":"\n4. State is "},{"type":"text","marks":[{"type":"bold"}],"text":"automatically saved"},{"type":"text","text":" between yields"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"def simple_generator():\n    print(\"First\")\n    yield 1\n    print(\"Second\")\n    yield 2\n    print(\"Third\")\n    yield 3\n\ngen = simple_generator()  # Doesn't run yet\nprint(next(gen))  # Output: First, then 1\nprint(next(gen))  # Output: Second, then 2\nprint(next(gen))  # Output: Third, then 3"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Generator vs Iterator: Key Differences"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Feature"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Iterator"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Generator"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Creation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Class with "},{"type":"text","marks":[{"type":"code"}