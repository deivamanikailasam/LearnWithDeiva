"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Matrix ops: O(n³) for deep learning"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"O(2ⁿ)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Exponential"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Naive Fibonacci"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Brute force: O(2ⁿ) unsolvable"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"O(n!)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Factorial"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Traveling salesman"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Permutation: O(n!) impossible"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How to Calculate Big-O (Step-by-Step)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Identify the Dominant Term"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Example 1: Single loop → O(n)\ndef loop_example(arr):\n    total = 0\n    for num in arr:  # ✅ 1 loop: n iterations\n        total += num\n    return total  # ✅ O(n) [web:158][web:159]\n\n# ✅ Example 2: Nested loops → O(n²)\ndef nested_example(arr):\n    n = len(arr)\n    for i in range(n):  # ✅ Outer: n iterations\n        for j in range(n):  # ✅ Inner: n iterations\n            print(arr[i], arr[j])  # ✅ Total: n × n = n² [web:158][web:159]\n    return  # ✅ O(n²)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Drop Constants and Lower-Order Terms"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Example: O(2n + 5) → O(n)\ndef example(arr):\n    total = 0\n    for num in arr:  # ✅ 2n: 2 loops\n        total += num\n    print(\"Done\")  # ✅ Constant: 1 operation (drop)\n    return total  # ✅ O(2n + 5) → O(n) (drop constants) [web:158][web:164]\n\n# ✅ Example: O(n² + n) → O(n²)\ndef example2(arr):\n    n = len(arr)\n    for i in range(n):  # ✅ n²: nested\n        for j in range(n):\n            print(arr[i], arr[j])\n    for num in arr:  # ✅ +n: single loop\n        print(num)\n    return  # ✅ O(n² + n) → O(n²) (drop lower-order n) [web:158][web:164]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Time Complexity Examples in Gen AI"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Tokenization (O(n))"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Tokenization: O(n) pass over text\ndef tokenize(text):\n    tokens = []\n    for word in text.split():  # ✅ O(n): n words\n        tokens.append(word.lower())\n    return tokens  # ✅ O(n) [web:158][web:159]\n\n# For 100 words: 100 operations\n# For 1000 words: 1000 operations [web:159]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Transformer Attention (O(n²) → O(n))"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ❌ O(n²) attention: Slow for large inputs\ndef attention_slow(tokens):\n    n = len(tokens)\n    matrix = [[0] * n for _ in range(n)]\n    for i in range(n):  # ❌ O(n): outer\n        for j in range(n):  # ❌ O(n): inner\n            matrix[i][j] = tokens[i] * tokens[j]  # ❌ Total: O(n²) [web:163]\n    return matrix\n\n# ✅ O(n) attention: Fast for large inputs\ndef attention_fast(tokens):\n    total = sum(tokens)  # ✅ O(n): 1 pass\n    return [token * total for token in tokens]  # ✅ O(n): 1 pass\n# Total: O(n) [web:163]\n\n# Impact:\n# 100 tokens: O(n²) = 10,000 ops, O(n) = 100 ops (100x faster)\n# 1000 tokens: O(n²) = 1,000,000 ops, O(n) = 1000 ops (1000x faster) [web:163]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Hash Table Lookup (O(1))"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Hash table: O(1) average lookup\nvocabulary = {\"apple\": 0, \"banana\": 1, \"cat\": 2}  # ✅ Python dict = hash table\n\ndef find_token(token):\n    return vocabulary.get(token, -1)  # ✅ O(1): constant time [web:148][web:151]\n\n# For 100 tokens: 100 operations (1 per token)\n# For 1000 tokens: 1000 operations (1 per token) [web:151]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Binary Search (O(log n))"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Binary search: O(log n) on sorted array\ndef binary_search(arr, target):\n    left, right = 0, len(arr) - 1\n    while left <= right:  # ✅ O(log n): halve each step\n        mid = (left + right) // 2\n        if arr[mid] == target:\n            return mid\n        elif arr[mid] < target:\n            left = mid + 1\n        else:\n            right = mid - 1\n    return -1  # ✅ O(log n) [web:158][web:159]\n\n# For 100 tokens: log₂(100) ≈ 7 operations\n# For 1000 tokens: log₂(1000) ≈ 10 operations (vs 1000 for linear) [web:159]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Space Complexity Examples in Gen AI"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"O(n²) Space (Quadratic Memory)"},{"type":"text","text":" ⭐ Critical for Transformers"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ❌ O(n²) space: Attention matrix (1GB for 10K tokens!)\ndef attention_matrix(tokens):\n    n = len(tokens)\n    matrix = [[0] * n for _ in range(n)]  # ❌ n × n = n² elements\n    for i in range(n):\n        for j in range(n):\n            matrix[i][j] = tokens[i] * tokens[j]\n    return matrix  # ❌ O(n²) space [web:161][web:163]\n\n# For 100 tokens: 100 × 100 = 10,000 elements (acceptable)\n# For 1000 tokens: 1000 × 1000 = 1,000,000 elements (1MB)\n# For 10,000 tokens: 10K × 10K = 100,000,000 elements (1GB!) [web:161][web:163]\n\n# ✅ O(n) space: Optimized attention\ndef attention_optimized(tokens):\n    total = sum(tokens)  # ✅ 1 variable: O(1)\n    return [token * total for token in tokens]  # ✅ n elements: O(n)\n# For 10K tokens: 10,000 elements (100KB) [web:163]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"AI Training Complexity ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Deep learning training complexity: O(E × L × N × D)\n# E = epochs, L = layers, N = neurons per layer, D = dataset size [web:163]\n\n# Training time for image classification:\n# O(E × L × N × D) = O(10 × 50 × 1000 × 100000) = O(50 billion operations) [web:163]\n\n# Space complexity (memory):\n# O(weights + biases) = O(L × N²) = O(50 × 1000²) = O(50 million weights) [web:163]\n\n# Impact:\n# - O(n²) memory = 1GB for large models (GPU memory limit)\n# - O(n³) training = days/weeks for training (cost: $10K+) [web:163]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Energy Complexity (New for Gen AI) ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Energy complexity: Evaluate energy consumption [web:161]\n# O(energy) = O(time × power) = O(flops × watts) [web:161]\n\n# Example:\n# O(n²) attention: 1M flops × 10W = 10M joules (high energy)\n# O(n) attention: 10K flops × 10W = 100K joules (100x less energy) [web:161]\n\n# Impact:\n# - Reduce energy from O(n²) → O(n) saves $1000s in GPU costs\n# - Eco-friendly AI: Lower energy = smaller carbon footprint [web:161]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Asymptotic upper bound"},{"type":"text","text":": Worst-case performance as n→∞"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Drop constants"},{"type":"text","text":": O(2n + 5) → O(n), O(n² + n) → O(n²)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Dominant term"},{"type":"text","text":": O(n) + O(2ⁿ) → O(2ⁿ)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Common classes"},{"type":"text","text":": O(1) → O(log n) → O(n) → O(n log n) → O(n²) → O(2ⁿ) → O(n!)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use for"},{"type":"text","text":": Scalability insight, algorithm selection, cost optimization, memory planning"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Gen AI"},{"type":"text","text":": Critical for attention (O(n²) → O(n)), tokenization (O(n)), training (O(E×L×N×D))"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Since you're a full-stack engineer working on Gen AI, Big-O is essential for optimizing transformer attention mechanisms (reducing O(n²) → O(n)), selecting efficient tokenization algorithms (O(n)), and planning GPU memory for large models (O(n²) space = 1GB for 10K tokens)."}]}]}}
