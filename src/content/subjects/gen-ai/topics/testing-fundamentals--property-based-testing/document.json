]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Company using property-based testing (security-focused)"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Use case"},{"type":"text","text":": Fuzzing targets beyond memory errors and crashes\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Setup"},{"type":"text","text":": PBT as \"fuzzy unit testing\" alongside regular unit tests\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Outcome"},{"type":"text","text":": - Discovered bugs during code writing (test data not considered by developer) - More effective than regular unit tests at finding edge cases - Less test code required, easier to reuse generators"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mid-sized software company (50 developers)"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Unit tests"},{"type":"text","text":": 15,000+ tests (example-based)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Property-based tests"},{"type":"text","text":": 50+ tests for: - Sorting algorithms (stability, monotonicity) - Mathematical operations (commutativity, inverses) - Data transformations (round-trip serialization) - String operations (reverse, concatenation)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"CI pipeline"},{"type":"text","text":": Runs PBT on every commit (adds 10–20 seconds)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Outcome"},{"type":"text","text":": Found 15+ edge case bugs before production, 95%+ bug-free releases"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common Mistakes"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Mistake"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"col