        "content": [
          {
            "type": "text",
            "text": "Semantic Functions \u2014 Prompt-Based Skills"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A semantic function wraps a prompt template in a "
          },
          {
            "type": "text",
            "text": "KernelFunction",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". Variables are injected using "
          },
          {
            "type": "text",
            "text": "{{$variable_name}}",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " syntax. The function renders the prompt, calls the LLM service, and returns a "
          },
          {
            "type": "text",
            "text": "FunctionResult",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": "."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\nfrom semantic_kernel import Kernel\nfrom semantic_kernel.connectors.ai.open_ai import OpenAIChatCompletion\nfrom semantic_kernel.prompt_template import PromptTemplateConfig\n\nkernel = Kernel()\nkernel.add_service(OpenAIChatCompletion(service_id=\"chat\", ai_model_id=\"gpt-4o-mini\"))\n\n# Define a semantic function inline\nsummarise_fn = kernel.add_function(\n    plugin_name=\"TextUtils\",\n    function_name=\"Summarise\",\n    prompt=\"Summarise the following in {{$max_sentences}} sentences:\\n{{$input}}\",\n    description=\"Summarises a passage of text.\",\n)\n\nasync def main():\n    from semantic_kernel.contents import ChatHistory\n    from semantic_kernel.kernel_pydantic import KernelBaseModel\n\n    result = await kernel.invoke(\n        summarise_fn,\n        input=\"Semantic Kernel is an open-source SDK that lets you integrate\"\n              \" AI models into your applications...\",\n        max_sentences=\"2\",\n    )\n    print(result)\n\nasyncio.run(main())"
          }
        ]
      },
