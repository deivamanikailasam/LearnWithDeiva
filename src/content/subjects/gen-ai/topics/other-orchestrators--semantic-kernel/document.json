            "type": "text",
            "text": "@kernel_function",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " methods in a class. Register the class once with "
          },
          {
            "type": "text",
            "text": "kernel.add_plugin()",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". All decorated methods become individually callable functions under that plugin name."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from semantic_kernel.functions import kernel_function\nimport json\n\nclass FinancePlugin:\n    \"\"\"Functions for working with financial data.\"\"\"\n\n    @kernel_function(\n        name=\"GetStockPrice\",\n        description=\"Return the latest price for a stock ticker symbol.\",\n    )\n    def get_stock_price(self, ticker: str) -> str:\n        # Stub \u2014 replace with a real market data API call\n        prices = {\"MSFT\": 420.50, \"AAPL\": 195.80, \"GOOG\": 175.30}\n        price = prices.get(ticker.upper(), \"unknown\")\n        return json.dumps({\"ticker\": ticker.upper(), \"price\": price, \"currency\": \"USD\"})\n\n    @kernel_function(\n        name=\"CalculateReturn\",\n        description=\"Calculate percentage return from buy_price to sell_price.\",\n    )\n    def calculate_return(self, buy_price: float, sell_price: float) -> str:\n        pct = (sell_price - buy_price) / buy_price * 100\n        return f\"{pct:.2f}% return\"\n\nkernel.add_plugin(FinancePlugin(), plugin_name=\"Finance\")\n\n# Call directly\nasync def demo():\n    result = await kernel.invoke(\n        kernel.plugins[\"Finance\"][\"GetStockPrice\"],\n        ticker=\"MSFT\",\n    )\n    print(result)\n\nasyncio.run(demo())"
          }
        ]
