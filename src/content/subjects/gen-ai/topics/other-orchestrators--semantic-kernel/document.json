          {
            "type": "text",
            "text": "recall",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " to retrieve the most semantically similar stored facts. Any vector store with a SK connector can back it."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\nfrom semantic_kernel import Kernel\nfrom semantic_kernel.connectors.ai.open_ai import (\n    OpenAIChatCompletion,\n    OpenAITextEmbedding,\n)\nfrom semantic_kernel.core_plugins import TextMemoryPlugin\nfrom semantic_kernel.memory import SemanticTextMemory\nfrom semantic_kernel.connectors.memory.chroma import ChromaMemoryStore\n\nkernel = Kernel()\nkernel.add_service(OpenAIChatCompletion(service_id=\"chat\", ai_model_id=\"gpt-4o-mini\"))\n\nembed_service = OpenAITextEmbedding(\n    service_id=\"embed\",\n    ai_model_id=\"text-embedding-3-small\",\n)\nkernel.add_service(embed_service)\n\nmemory_store = ChromaMemoryStore(persist_directory=\"./chroma_memory\")\nmemory = SemanticTextMemory(storage=memory_store, embeddings_generator=embed_service)\nkernel.add_plugin(TextMemoryPlugin(memory), plugin_name=\"Memory\")\n\nasync def main():\n    # Store facts\n    await memory.save_information(\n        collection=\"facts\",\n        id=\"fact1\",\n        text=\"The Paris Agreement was signed in 2015 to address climate change.\",\n    )\n    await memory.save_information(\n        collection=\"facts\",\n        id=\"fact2\",\n        text=\"Renewable energy now accounts for over 30% of global electricity generation.\",\n    )\n\n    # Recall\n    results = await memory.search(\"facts\", \"climate agreements\", limit=2)\n    for r in results:\n        print(f\"Relevance: {r.relevance:.3f} \u2014 {r.text[:80]}\")\n\nasyncio.run(main())"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Filters \u2014 Hooks Around Function Calls"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "SK's "
          },
          {
            "type": "text",
            "text": "FunctionInvocationFilter",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " interface provides before/after hooks around every function call. Use them for logging, caching, PII scrubbing, rate limiting, or injecting context."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from semantic_kernel.filters import FunctionInvocationContext\nfrom typing import Callable, Awaitable\n\nclass LoggingFilter:\n    async def on_function_invocation(\n        self,\n        context: FunctionInvocationContext,\n        next: Callable[[FunctionInvocationContext], Awaitable[None]],\n    ) -> None:\n        fn = context.function.fully_qualified_name\n        print(f\"[PRE ] Calling {fn} with args={context.arguments}\")\n        await next(context)   # run the actual function\n        print(f\"[POST] {fn} returned: {context.result}\")\n\nkernel.add_filter(LoggingFilter())\n\n# All subsequent kernel.invoke() calls will print before and after"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
