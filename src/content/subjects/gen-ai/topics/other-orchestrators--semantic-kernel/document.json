      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Streaming works by calling "
          },
          {
            "type": "text",
            "text": "get_streaming_chat_message_content",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " instead of "
          },
          {
            "type": "text",
            "text": "get_chat_message_content",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ". The method returns an async generator of partial content chunks."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\nfrom semantic_kernel.contents import ChatHistory\nfrom semantic_kernel.connectors.ai.open_ai.prompt_execution_settings.open_ai_prompt_execution_settings import (\n    OpenAIChatPromptExecutionSettings,\n)\n\nasync def stream_chat(kernel, service, user_msg: str):\n    history = ChatHistory()\n    history.add_system_message(\"You are a concise assistant.\")\n    history.add_user_message(user_msg)\n    settings = OpenAIChatPromptExecutionSettings(temperature=0)\n\n    full_response = \"\"\n    async for chunk in service.get_streaming_chat_message_content(\n        chat_history=history,\n        settings=settings,\n        kernel=kernel,\n    ):\n        if chunk.content:\n            print(chunk.content, end=\"\", flush=True)\n            full_response += chunk.content\n    print()\n    return full_response\n\nasyncio.run(stream_chat(kernel, service, \"Explain RAG in 3 sentences.\"))"
          }
        ]
      },
