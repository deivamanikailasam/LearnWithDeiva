      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A planner reads the available plugins and functions, then uses an LLM to generate a multi-step plan to achieve a goal. Semantic Kernel ships two planners:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "FunctionChoiceBehavior.Auto():",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " the recommended modern approach \u2014 lets the LLM call functions as tools, in any order, as many times as needed (equivalent to a ReAct-style tool-calling agent)"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Handlebars Planner:",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " the LLM generates a Handlebars template plan upfront, which is then executed deterministically \u2014 good when you need an auditable plan before execution"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Auto Function Calling (Recommended)"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\nfrom semantic_kernel import Kernel\nfrom semantic_kernel.connectors.ai.open_ai import OpenAIChatCompletion\nfrom semantic_kernel.connectors.ai.function_choice_behavior import FunctionChoiceBehavior\nfrom semantic_kernel.connectors.ai.open_ai.prompt_execution_settings.open_ai_prompt_execution_settings import (\n    OpenAIChatPromptExecutionSettings,\n)\nfrom semantic_kernel.contents import ChatHistory\n\nkernel = Kernel()\nservice = OpenAIChatCompletion(service_id=\"chat\", ai_model_id=\"gpt-4o\")\nkernel.add_service(service)\n\n# Register plugins\nkernel.add_plugin(FinancePlugin(), plugin_name=\"Finance\")\nkernel.add_plugin(WeatherPlugin(), plugin_name=\"Weather\")\n\nasync def agent_chat(user_msg: str):\n    history = ChatHistory()\n    history.add_user_message(user_msg)\n\n    settings = OpenAIChatPromptExecutionSettings(\n        # Allow the LLM to call any registered function\n        function_choice_behavior=FunctionChoiceBehavior.Auto(),\n    )\n\n    response = await service.get_chat_message_content(\n        chat_history=history,\n        settings=settings,\n        kernel=kernel,\n    )\n    return str(response)\n\n# The LLM will call Finance.GetStockPrice and WeatherPlugin.GetCurrentWeather\n# automatically when needed\nresult = asyncio.run(agent_chat(\n    \"What is Microsoft's stock price and what is the weather in Redmond?\"\n))\nprint(result)"
          }
        ]
      },
