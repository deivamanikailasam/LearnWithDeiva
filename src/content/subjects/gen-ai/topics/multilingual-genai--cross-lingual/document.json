                      {
                        "type": "bold"
                      }
                    ],
                    "text": "XNLI"
                  },
                  {
                    "type": "text",
                    "text": " — Cross-lingual natural language inference in 15 languages. Train on English MultiNLI; test on others. Standard ZS-XLT benchmark."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "MLQA / XQuAD"
                  },
                  {
                    "type": "text",
                    "text": " — Cross-lingual question answering. Passages and questions in different languages. Measures cross-lingual reading comprehension."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
