      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Cross-Lingual RAG Pipeline"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The core insight: use the same multilingual embedding model for both indexing documents and embedding queries. If documents were indexed with "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "multilingual-e5-large"
          },
          {
            "type": "text",
            "text": ", use the same model at query time regardless of the query language. The LLM then generates a response in the user's language, using the (possibly English) retrieved context — modern frontier models handle this translation and synthesis in one step."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from __future__ import annotations\n\nimport asyncio\nfrom dataclasses import dataclass\n\nimport httpx\nfrom sentence_transformers import SentenceTransformer\n\n# Use the same model for indexing AND querying\nEMBED_MODEL = SentenceTransformer(\"intfloat/multilingual-e5-large\")\n\n\ndef embed_query(text: str) -> list[float]:\n    # multilingual-e5 requires \"query: \" prefix for query-side encoding\n    return EMBED_MODEL.encode(f\"query: {text}\", normalize_embeddings=True).tolist()\n\n\ndef embed_passage(text: str) -> list[float]:\n    # \"passage: \" prefix for document-side encoding\n    return EMBED_MODEL.encode(f\"passage: {text}\", normalize_embeddings=True).tolist()\n\n\n@dataclass\nclass Chunk:\n    chunk_id: str\n    text: str\n    language: str    # ISO 639-1: \"en\", \"fr\", \"de\", etc.\n    url: str\n    title: str\n\n\nasync def cross_lingual_rag(\n    user_query: str,\n    vector_db,\n    llm_client,\n    model: str = \"claude-opus-4-8\",\n    top_k: int = 6,\n    target_lang: str | None = None,   # None = same as query language\n) -> str:\n    # 1. Detect language of query\n    detected_lang = detect_language(user_query)  # e.g. \"fr\"\n    respond_in = target_lang or detected_lang\n\n    # 2. Embed query with cross-lingual model\n    query_embedding = embed_query(user_query)\n\n    # 3. Retrieve — works across any language in the index\n    results = await vector_db.query(\n        vector=query_embedding,\n        top_k=top_k,\n        include_metadata=True,\n    )\n    chunks: list[Chunk] = [\n        Chunk(\n            chunk_id=r.id,\n            text=r.metadata[\"text\"],\n            language=r.metadata.get(\"language\", \"en\"),\n            url=r.metadata[\"url\"],\n            title=r.metadata[\"title\"],\n        )\n        for r in results.matches\n    ]\n\n    # 4. Build prompt — LLM handles translation of EN context into FR answer\n    context_blocks = \"\\n\\n\".join(\n        f\"[{i+1}] ({chunk.language.upper()}) {chunk.title}\\n{chunk.text}\"\n        for i, chunk in enumerate(chunks)\n    )\n    messages = [\n        {\n            \"role\": \"system\",\n            \"content\": (\n                f\"You are a helpful assistant. \"\n                f\"Always respond in {respond_in} (language code: {respond_in}), \"\n                f\"regardless of the language of the context passages. \"\n                \"Cite the passage numbers [1], [2], etc. that support each claim.\"\n            ),\n        },\n        {\n            \"role\": \"user\",\n            \"content\": f\"Context passages:\\n{context_blocks}\\n\\nQuestion: {user_query}\",\n        },\n    ]\n    response = llm_client.chat.completions.create(model=model, messages=messages)\n    return response.choices[0].message.content\n\n\ndef detect_language(text: str) -> str:\n    \"\"\"Detect ISO 639-1 language code. Use langdetect or a model call.\"\"\"\n    try:\n        from langdetect import detect\n        return detect(text)\n    except Exception:\n        return \"en\"  # fallback"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Indexing a Multilingual Knowledge Base"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When documents already exist in multiple languages (an international product knowledge base, for example), index all of them with the same multilingual embedding model. Store the "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "language"
          },
          {
            "type": "text",
            "text": " field in chunk metadata. This lets you optionally filter retrieval to documents in a specific language — useful when a user explicitly asks for content in their language, or when language-of-origin matters for compliance."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import hashlib\nfrom dataclasses import dataclass\n\n\n@dataclass\nclass IndexedDoc:\n    doc_id: str\n    title: str\n    text: str\n    language: str   # ISO 639-1\n    url: str\n\n\nasync def index_multilingual_doc(\n    doc: IndexedDoc,\n    vector_db,\n    chunker,\n    batch_size: int = 64,\n) -> int:\n    \"\"\"Chunk, embed, and index a doc in any language. Returns chunk count.\"\"\"\n    chunks = chunker(doc.text, max_tokens=400)\n    records = []\n    for i, chunk_text in enumerate(chunks):\n        chunk_id = f\"{doc.doc_id}::{i}\"\n        embedding = embed_passage(chunk_text)\n        records.append({\n            \"id\": chunk_id,\n            \"values\": embedding,\n            \"metadata\": {\n                \"doc_id\": doc.doc_id,\n                \"title\": doc.title,\n                \"text\": chunk_text,\n                \"language\": doc.language,\n                \"url\": doc.url,\n                \"content_hash\": hashlib.sha256(chunk_text.encode()).hexdigest(),\n            },\n        })\n\n    # Batch upsert\n    for start in range(0, len(records), batch_size):\n        await vector_db.upsert(records[start : start + batch_size])\n\n    return len(records)\n\n\n# Language-filtered retrieval (optional)\nasync def retrieve_same_language(\n    query: str,\n    language: str,\n    vector_db,\n    top_k: int = 5,\n) -> list[dict]:\n    \"\"\"Retrieve only chunks in the specified language.\"\"\"\n    embedding = embed_query(query)\n    results = await vector_db.query(\n        vector=embedding,\n        top_k=top_k,\n        filter={\"language\": {\"$eq\": language}},\n        include_metadata=True,\n    )\n    return [r.metadata for r in results.matches]"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Zero-Shot Cross-Lingual Transfer"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Zero-shot cross-lingual transfer (ZS-XLT) means training a model (classifier, NER tagger, intent detector) only on English data and deploying it on text in other languages. It works because multilingual pretrained encoders (mBERT, XLM-R, multilingual-e5) align representations across languages in shared embedding space. The model learns a task on English; the aligned representations let it apply that knowledge to Spanish, French, or German without seeing a single labeled example in those languages."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Zero-shot cross-lingual intent classification\n# Train on English intents; classify any language at inference\n\nfrom sentence_transformers import SentenceTransformer\nfrom sklearn.linear_model import LogisticRegression\nimport numpy as np\n\nENCODER = SentenceTransformer(\"intfloat/multilingual-e5-large\")\n\n# English training data only\nTRAIN_TEXTS = [\n    \"How do I cancel my subscription?\",\n    \"What are your pricing plans?\",\n    \"I need a refund for my order\",\n    \"How do I reset my password?\",\n    \"Where is my shipment?\",\n]\nTRAIN_LABELS = [\"cancel\", \"pricing\", \"refund\", \"password_reset\", \"order_tracking\"]\n\n\ndef train_intent_classifier(texts: list[str], labels: list[str]) -> LogisticRegression:\n    embeddings = ENCODER.encode(\n        [f\"query: {t}\" for t in texts], normalize_embeddings=True\n    )\n    clf = LogisticRegression(max_iter=1000)\n    clf.fit(embeddings, labels)\n    return clf\n\n\ndef predict_intent(text: str, clf: LogisticRegression) -> tuple[str, float]:\n    embedding = ENCODER.encode([f\"query: {text}\"], normalize_embeddings=True)\n    intent = clf.predict(embedding)[0]\n    confidence = clf.predict_proba(embedding).max()\n    return intent, float(confidence)\n\n\n# Works on languages never seen during training:\nclf = train_intent_classifier(TRAIN_TEXTS, TRAIN_LABELS)\n\ntest_cases = [\n    (\"Comment annuler mon abonnement?\", \"fr\"),   # French\n    (\"Wie kann ich mein Passwort zuruecksetzen?\", \"de\"),  # German\n    (\"Donde esta mi envio?\", \"es\"),               # Spanish\n    (\"サブスクリプションをキャンセルするには?\", \"ja\"),  # Japanese\n]\n\nfor text, lang in test_cases:\n    intent, conf = predict_intent(text, clf)\n    print(f\"[{lang}] '{text[:40]}...' → {intent} ({conf:.2f})\")\n# [fr] 'Comment annuler mon abonnement?...' → cancel (0.91)\n# [de] 'Wie kann ich mein Passwort zuruc...' → password_reset (0.88)\n# [es] 'Donde esta mi envio?...' → order_tracking (0.85)\n# [ja] 'サブスクリプションをキャンセルする...' → cancel (0.87)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Translate-First vs Native Cross-Lingual"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Two strategies exist for cross-lingual retrieval. \"Translate-first\" translates the query into the KB language before searching, enabling BM25/keyword search to work. \"Native cross-lingual\" embeds the query directly without translation. The right choice depends on your infrastructure:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Use translate-first"
                  },
                  {
                    "type": "text",
                    "text": " when your retrieval stack is built on Elasticsearch/BM25 and you need keyword matching. Also useful for hybrid search where you want the BM25 component to work across languages. Keep a lightweight, fast translation model (e.g., Helsinki-NLP OPUS) on-prem for low latency."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Use native cross-lingual embedding"
                  },
                  {
                    "type": "text",
                    "text": " when you control the embedding model and can use it for both indexing and querying. One fewer network call; no mistranslation risk. Preferred for new stacks."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "For hybrid search with cross-lingual embedding"
                  },
                  {
                    "type": "text",
                    "text": ": embed natively for the dense component; separately translate the query for the BM25 component. Merge results with Reciprocal Rank Fusion before passing to the LLM."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Language Detection"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Reliable language detection is prerequisite to cross-lingual routing. For short user inputs (under 20 words), many detectors perform poorly. Use "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "langdetect"
          },
          {
            "type": "text",
            "text": " (Python) or "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "fastText"
          },
          {
            "type": "text",
            "text": "'s language identifier (176 languages, fast, accurate down to ~5 words). For production, fall back to asking the LLM when the detector is uncertain."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langdetect import detect, detect_langs, LangDetectException\n\n\ndef detect_language_robust(\n    text: str,\n    min_confidence: float = 0.90,\n    fallback: str = \"en\",\n) -> tuple[str, float]:\n    \"\"\"Returns (lang_code, confidence). Falls back if uncertain.\"\"\"\n    if len(text.split()) < 4:\n        # Too short for reliable detection; use fallback\n        return fallback, 0.0\n    try:\n        candidates = detect_langs(text)  # e.g. [fr:0.97, en:0.02]\n        best = candidates[0]\n        if best.prob >= min_confidence:\n            return best.lang, best.prob\n        return fallback, best.prob\n    except LangDetectException:\n        return fallback, 0.0\n\n\ndef route_by_language(\n    text: str,\n    supported_languages: set[str],\n    llm_fallback_lang: str = \"en\",\n) -> dict:\n    lang, confidence = detect_language_robust(text)\n    if lang not in supported_languages:\n        # Unsupported language: log for coverage analysis, respond in closest\n        return {\"lang\": llm_fallback_lang, \"original_lang\": lang,\n                \"supported\": False, \"confidence\": confidence}\n    return {\"lang\": lang, \"original_lang\": lang,\n            \"supported\": True, \"confidence\": confidence}"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Evaluation Benchmarks"
          }
