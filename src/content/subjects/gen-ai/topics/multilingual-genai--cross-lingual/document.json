                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "MIRACL"
                  },
                  {
                    "type": "text",
                    "text": " — Multilingual information retrieval across 18 languages. Measures cross-lingual retrieval quality end-to-end."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "MTEB Multilingual"
                  },
                  {
                    "type": "text",
                    "text": " — Massive text embedding benchmark with multilingual retrieval, classification, and clustering tasks. Use it to compare embedding models before committing to one."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Mixing embedding models at index and query time."
                  },
                  {
                    "type": "text",
                    "text": " If you indexed with "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "text-embedding-ada-002"
                  },
                  {
                    "type": "text",
                    "text": " and now query with "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
