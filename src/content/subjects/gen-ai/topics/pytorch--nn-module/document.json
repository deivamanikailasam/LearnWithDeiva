{"format": "tiptap/v1", "updatedAt": "2026-06-22T08:41:35.409Z", "doc": {"type": "doc", "content": [{"type": "image", "attrs": {"src": "data:image/svg+xml;base64,", "alt": "nn.Module — concept overview"}}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "What "}, {"type": "text", "marks": [{"type": "code"}], "text": "nn.Module"}, {"type": "text", "text": " Is"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}, {"type": "code"}], "text": "nn.Module"}, {"type": "text", "text": " is the fundamental base class for all neural networks in PyTorch. It provides a flexible framework to define and manage neural network components, enabling creation of complex models efficiently."}]}, {"type": "paragraph", "content": [{"type": "text", "text": "In PyTorch, "}, {"type": "text", "marks": [{"type": "bold"}], "text": "any neural network layer"}, {"type": "text", "text": " (fully connected, convolutional, activation functions) inherits from "}, {"type": "text", "marks": [{"type": "code"}], "text": "nn.Module"}, {"type": "text", "text": ". By subclassing it, you define your own models and layers with customized behavior and structure."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Why "}, {"type": "text", "marks": [{"type": "code"}], "text": "nn.Module"}, {"type": "text", "text": " Matters in Generative AI"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "nn.Module"}, {"type": "text", "text": " is essential because it provides five critical capabilities:"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Feature"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "What It Does"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Why It Matters"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Layer organization"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Hierarchical nesting of layers (Linear, Conv2d, activations)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Build complex models like GANs, diffusion models, LLMs"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Parameter management"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Automatically tracks all learnable parameters (weights, biases)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Optimizers update all parameters via "}, {"type": "text", "marks": [{"type": "code"}], "text": ".parameters()"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Forward propagation"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "forward()"}, {"type": "text", "text": " method defines computation flow"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Custom architectures for generative tasks"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Device handling"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": ".to(device)"}, {"type": "text", "text": " moves model + all parameters to GPU"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "GPU acceleration for training large models"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Serialization"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Save/load models with "}, {"type": "text", "marks": [{"type": "code"}], "text": "torch.save()"}, {"type": "text", "text": "/"}, {"type": "text", "marks": [{"type": "code"}], "text": "torch.load()"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Persist trained generative models"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "It simplifies neural network design, layer definition, weight initialization, and forward propagation."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "How "}, {"type": "text", "marks": [{"type": "code"}], "text": "nn.Module"}, {"type": "text", "text": " Works"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Core Structure"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "All custom neural networks follow this pattern:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import torch\nimport torch.nn as nn\n\nclass NeuralNetwork(nn.Module):  # Subclass nn.Module [web:24]\n    def __init__(self):\n        super().__init__()  # Initialize base class [web:24]\n        # Define layers here (automatically registered as parameters)\n        self.layer1 = nn.Linear(128, 256)  # Parameters tracked [web:23]\n        self.layer2 = nn.Linear(256, 784)\n        self.relu = nn.ReLU()\n    \n    def forward(self, x):  # Define forward pass [web:22]\n        x = self.relu(self.layer1(x))  # Apply layers [web:24]\n        x = self.layer2(x)\n        return x  # Return output [web:24]\n\n# Usage\nmodel = NeuralNetwork()  # Create instance\ninput_tensor = torch.randn(32, 128)  # Batch of 32 samples\noutput = model(input_tensor)  # Calls forward() automatically [web:21]"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "The "}, {"type": "text", "marks": [{"type": "code"}], "text": "__call__"}, {"type": "text", "text": " → "}, {"type": "text", "marks": [{"type": "code"}], "text": "forward"}, {"type": "text", "text": " Mechanism"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "When you call "}, {"type": "text", "marks": [{"type": "code"}], "text": "model(input)"}, {"type": "text", "text": ":"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Python invokes "}, {"type": "text", "marks": [{"type": "code"}], "text": "__call__(input)"}, {"type": "text", "text": " on the Module"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "__call__"}, {"type": "text", "text": " internally calls "}, {"type": "text", "marks": [{"type": "code"}], "text": "self.forward(*input, **kwargs)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "forward()"}, {"type": "text", "text": " executes your custom computation"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Key: "}, {"type": "text", "marks": [{"type": "code"}], "text": "__call__"}, {"type": "text", "text": " runs registered hooks (for debugging), while "}, {"type": "text", "marks": [{"type": "code"}], "text": "forward()"}, {"type": "text", "text": " silently ignores them"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Important"}, {"type": "text", "text": ": Call the Module instance ("}, {"type": "text", "marks": [{"type": "code"}], "text": "model(x)"}, {"type": "text", "text": "), not "}, {"type": "text", "marks": [{"type": "code"}], "text": "forward(x)"}, {"type": "text", "text": " directly."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Integration with Tensors and Autograd"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Parameters Are Tensors"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "model = NeuralNetwork()\n\n# All parameters are tensors with gradient tracking\nfor param in model.parameters():\n    print(param.shape)      # Tensor shape\n    print(param.requires_grad)  # True (Autograd enabled) [web:25]"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Parameters are automatically registered and tracked. When you call "}, {"type": "text", "marks": [{"type": "code"}], "text": ".parameters()"}, {"type": "text", "text": ", it collects all parameters from the model and submodules."}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Autograd Works Automatically"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "model = NeuralNetwork()\ninput_tensor = torch.randn(32, 128)\n\n# Forward pass builds computational graph via Autograd\noutput = model(input_tensor)  \nloss = output.mean()\n\n# Backward pass computes gradients for ALL parameters automatically\nloss.backward()  # Gradients stored in param.grad [web:25]\n\n# Optimizer uses gradients to update weights\nfor param in model.parameters():\n    param -= 0.01 * param.grad  # Gradient descent [web:25]"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "nn.Module"}, {"type": "text", "text": " makes gradient computation and weight updates automatic."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Building Complex Generative Models"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Example: GAN Generator"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "class Generator(nn.Module):\n    def __init__(self):\n        super().__init__()\n        self.network = nn.Sequential(\n            nn.Linear(128, 256),\n            nn.ReLU(),\n            nn.Linear(256, 512),\n            nn.ReLU(),\n            nn.Linear(512, 784),\n            nn.Tanh()  # Output range [-1, 1]\n        )\n    \n    def forward(self, x):\n        return self.network(x)\n\n# Example: GAN Discriminator\nclass Discriminator(nn.Module):\n    def __init__(self):\n        super().__init__()\n        self.network = nn.Sequential(\n            nn.Linear(784, 512),\n            nn.LeakyReLU(0.2),\n            nn.Linear(512, 256),\n            nn.LeakyReLU(0.2),\n            nn.Linear(256, 1),\n            nn.Sigmoid()\n        )\n    \n    def forward(self, x):\n        return self.network(x)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Example: Diffusion Model (Simplified)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "class DiffusionModel(nn.Module):\n    def __init__(self):\n        super().__init__()\n        self.embedding = nn.Linear(784, 512)\n        self.layers = nn.Sequential(\n            nn.ReLU(),\n            nn.Linear(512, 512),\n            nn.ReLU(),\n            nn.Linear(512, 784)\n        )\n        self.time_embed = nn.Linear(1, 512)\n    \n    def forward(self, x, t):\n        x_emb = self.embedding(x)\n        t_emb = self.time_embed(t)\n        return self.layers(x_emb + t_emb)"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Key Methods & Features"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Method"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Purpose"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Example"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "__init__()"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Define layers"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "self.fc = nn.Linear(128, 256)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "forward(x)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Define computation"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "return self.fc(x)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": ".parameters()"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Get all learnable params"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "for p in model.parameters()"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": ".buffers()"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Get non-param tensors"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Batch norm running stats"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": ".to(device)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Move to GPU/CPU"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "model.to('cuda')"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": ".zero_grad()"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Clear gradients"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "model.zero_grad()"}, {"type": "text", "text": " before backward"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": ".children()"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Get submodules"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "For recursive operations"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": ".apply(fn)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Apply function recursively"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Weight initialization"}]}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Weight Initialization"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "def init_weights(m):\n    if type(m) == nn.Linear:\n        torch.nn.init.xavier_uniform_(m.weight)  # Xavier init [web:20]\n\nmodel.apply(init_weights)  # Apply to all layers [web:20]"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Mental Model"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Think of "}, {"type": "text", "marks": [{"type": "code"}], "text": "nn.Module"}, {"type": "text", "text": " as a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Lego block system"}, {"type": "text", "text": ":"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Each layer is a block"}, {"type": "text", "text": ": Linear, Conv, ReLU are pre-built blocks"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "You stack blocks"}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "code"}], "text": "Sequential"}, {"type": "text", "text": " chains them together"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Blocks connect automatically"}, {"type": "text", "text": ": Output of one feeds input of next"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Everything tracked"}, {"type": "text", "text": ": PyTorch knows all blocks and their parameters"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Forward = Assembly line"}, {"type": "text", "text": ": Data flows through blocks in order"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Backward = Reverse assembly"}, {"type": "text", "text": ": Gradients flow backward through same path"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "You're building a factory where data flows through stations (layers), and "}, {"type": "text", "marks": [{"type": "code"}], "text": "nn.Module"}, {"type": "text", "text": " manages the entire factory."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Key Takeaways"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}, {"type": "code"}], "text": "nn.Module"}, {"type": "text", "marks": [{"type": "bold"}], "text": " is the base class"}, {"type": "text", "text": " for all neural networks in PyTorch"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Subclass it"}, {"type": "text", "text": " to define custom models: "}, {"type": "text", "marks": [{"type": "code"}], "text": "class MyModel(nn.Module)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Define layers in "}, {"type": "text", "marks": [{"type": "bold"}, {"type": "code"}], "text": "__init__()"}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "code"}], "text": "self.layer = nn.Linear(128, 256)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Implement "}, {"type": "text", "marks": [{"type": "bold"}, {"type": "code"}], "text": "forward(x)"}, {"type": "text", "text": " to define computation flow"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Call "}, {"type": "text", "marks": [{"type": "bold"}, {"type": "code"}], "text": "model(x)"}, {"type": "text", "text": " (not "}, {"type": "text", "marks": [{"type": "code"}], "text": "forward(x)"}, {"type": "text", "text": ") to execute the network"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Parameters auto-tracked"}, {"type": "text", "text": ": All "}, {"type": "text", "marks": [{"type": "code"}], "text": ".parameters()"}, {"type": "text", "text": " registered automatically"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Autograd integrates seamlessly"}, {"type": "text", "text": ": Gradients computed for all parameters"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "GPU support"}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "code"}], "text": ".to('cuda')"}, {"type": "text", "text": " moves model + parameters"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Hierarchical nesting"}, {"type": "text", "text": ": Build complex models from submodules"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Essential for generative AI"}, {"type": "text", "text": ": Used in GANs, diffusion models, LLMs, transformers"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "nn.Module"}, {"type": "text", "text": " provides the structured foundation for building, managing, and deploying deep learning models, making PyTorch both powerful and maintainable for production generative AI systems."}]}]}}