pe":"text","text":"Think of "},{"type":"text","marks":[{"type":"code"}],"text":"nn.Module"},{"type":"text","text":" as a "},{"type":"text","marks":[{"type":"bold"}],"text":"Lego block system"},{"type":"text","text":":"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Each layer is a block"},{"type":"text","text":": Linear, Conv, ReLU are pre-built blocks"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"You stack blocks"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"Sequential"},{"type":"text","text":" chains them together"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Blocks connect automatically"},{"type":"text","text":": Output of one feeds input of next"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Everything tracked"},{"type":"text","text":": PyTorch knows all blocks and their parameters"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Forward = Assembly line"},{"type":"text","text":": Data flows through blocks in order"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Backward = Reverse assembly"},{"type":"text","text":": Gradients flow backward through same path"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"You're building a factory where data flows through stations (layers), and "},{"type":"text","marks":[{"type":"code"}],"text":"nn.Module"},{"type":"text","text":" manages the entire factory."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type"