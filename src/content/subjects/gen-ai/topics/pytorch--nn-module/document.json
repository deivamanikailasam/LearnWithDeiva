{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Device handling"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":".to(device)"},{"type":"text","text":" moves model + all parameters to GPU"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"GPU acceleration for training large models"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Serialization"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Save/load models with "},{"type":"text","marks":[{"type":"code"}],"text":"torch.save()"},{"type":"text","text":"/"},{"type":"text","marks":[{"type":"code"}],"text":"torch.load()"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Persist trained generative models"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"It simplifies neural network design, layer definition, weight initialization, and forward propagation."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How "},{"type":"text","marks":[{"type":"code"}],"text":"nn.Module"},{"type":"text","text":" Works"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Core Structure"}]},{"type":"paragraph","content":[{"type":"text","text":"All custom neural networks follow this pattern:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import torch\nimport torch.nn as nn\n\nclass NeuralNetwork(nn.Module):  # Subclass nn.Module [web:24]\n    def __init__(self):\n        super().__init__()  # Initialize base class [web:24]\n        # Define layers here (automatically registered as parameters)\n        self.layer1 = nn.Linear(128, 256)  # Parameters tracked [web:23]\n        self.layer2 = nn.Linear(256, 784)\n        self.relu = nn.ReLU()\n    \n    def forward(self, x):  # Define forward pass [web:22]\n        x = self.relu(self.layer1(x))  # Apply layers [web:24]\n        x = self.layer2(x)\n        return x  # Return output [web:24]\n\n# Usage\nmodel = NeuralNetwork()  # Create instance\ninput_tensor = torch.randn(32, 128)  # Batch of 32 samples\noutput = model(input_tensor)  # Calls forward() automatically [web:21]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"code"}],"text":"__call__"},{"type":"text","text":" → "},{"type":"text","marks":[{"type":"code"}],"text":"forward"},{"type":"text","text":" Mechanism"}]},{"type":"paragraph","content":[{"type":"text","text":"When you call "},{"type":"text","marks":[{"type":"code"}],"text":"model(input)"},{"type":"text","text":":"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Python invokes "},{"type":"text","marks":[{"type":"code"}],"text":"__call__(input)"},{"type":"text","text":" on the Module"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"__call__"},{"type":"text","text":" internally calls "},{"type":"text","marks":[{"type":"code"}],"text":"self.forward(*input, **kwargs)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"forward()"},{"type":"text","text":" executes your custom computation"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Key: "},{"type":"text","marks":[{"type":"code"}],"text":"__call__"},{"type":"text","text":" runs registered hooks (for debugging), while "},{"type":"text","marks":[{"type":"code"}],"text":"forward()"},{"type":"text","text":" silently ignores them"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Important"},{"type":"text","text":": Call the Module instance ("},{"type":"text","marks":[{"type":"code"}],"text":"model(x)"},{"type":"text","text":"), not "},{"type":"text","marks":[{"type":"code"}],"text":"forward(x)"},{"type":"text","text":" directly."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Integration with Tensors and Autograd"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Parameters Are Tensors"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"model = NeuralNetwork()\n\n# All parameters are tensors with gradient tracking\nfor param in model.parameters():\n    print(param.shape)      # Tensor shape\n    print(param.requires_grad)  # True (Autograd enabled) [web:25]"}]},{"type":"paragraph","content":[{"type":"text","text":"Parameters are automatically registered and tracked. When you call "},{"type":"text","marks":[{"type":"code"}],"text":".parameters()"},{"type":"text","text":", it collects all parameters from the model and submodules."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Autograd Works Automatically"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"model = NeuralNetwork()\ninput_tensor = torch.randn(32, 128)\n\n# Forward pass builds computational graph via Autograd\noutput = model(input_tensor)  \nloss = output.mean()\n\n# Backward pass computes gradients for ALL parameters automatically\nloss.backward()  # Gradients stored in param.grad [web:25]\n\n# Optimizer uses gradients to update weights\nfor param in model.parameters():\n    param -= 0.01 * param.grad  # Gradient descent [web:25]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"nn.Module"},{"type":"text","text":" makes gradient computation and weight updates automatic."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Building Complex Generative Models"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example: GAN Generator"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"class Generator(nn.Module):\n    def __init__(self):\n        super().__init__()\n        self.network = nn.Sequential(\n            nn.Linear(128, 256),\n            nn.ReLU(),\n            nn.Linear(256, 512),\n            nn.ReLU(),\n            nn.Linear(512, 784),\n            nn.Tanh()  # Output range [-1, 1]\n        )\n    \n    def forward(self, x):\n        return self.network(x)\n\n# Example: GAN Discriminator\nclass Discriminator(nn.Module):\n    def __init__(self):\n        super().__init__()\n        self.network = nn.Sequential(\n            nn.Linear(784, 512),\n            nn.LeakyReLU(0.2),\n            nn.Linear(512, 256),\n            nn.LeakyReLU(0.2),\n            nn.Linear(256, 1),\n            nn.Sigmoid()\n        )\n    \n    def forward(self, x):\n        return self.network(x)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example: Diffusion Model (Simplified)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"class DiffusionModel(nn.Module):\n    def __init__(self):\n        super().__init__()\n        self.embedding = nn.Linear(784, 512)\n        self.layers = nn.Sequential(\n            nn.ReLU(),\n            nn.Linear(512, 512),\n            nn.ReLU(),\n            nn.Linear(512, 784)\n        )\n        self.time_embed = nn.Linear(1, 512)\n    \n    def forward(self, x, t):\n        x_emb = self.embedding(x)\n        t_emb = self.time_embed(t)\n        return self.layers(x_emb + t_emb)"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Methods & Features"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Method"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Purpose"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Example"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"__init__()"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Define layers"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"self.fc = nn.Linear(128, 256)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"forward(x)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Define computation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"return self.fc(x)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspa