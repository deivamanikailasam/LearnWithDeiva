                  {
                    "type": "text",
                    "text": " (one CLIP forward pass) — catches semantic rephrasing of blocked content."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Rate limiting and anomaly detection",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " — catches systematic probing by tracking per-user prompt distributions."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Model-level concept erasure",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " (weight-level, requires fine-tuning) — removes the capability entirely for the highest-risk concepts."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Output image classifier",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " (post-generation, catches model leakage and adversarial inputs that bypassed earlier layers)."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Layered safety wrapper around any diffusers pipeline\n\nimport torch\nfrom dataclasses import dataclass\nfrom PIL import Image\n\n@dataclass\nclass SafetyResult:\n    safe: bool\n    blocked_at: str   # \"prompt_blocklist\", \"prompt_embedding\", \"output_classifier\", or \"passed\"\n    image: Image.Image | None\n\nclass LayeredSafety:\n    def __init__(self, pipe, prompt_filter, output_classifier):\n        self.pipe       = pipe\n        self.pf         = prompt_filter\n        self.oc         = output_classifier\n\n    def generate(self, prompt: str, **kwargs) -> SafetyResult:\n        # Layer 1: prompt filter\n        if not self.pf.check_blocklist(prompt):\n            return SafetyResult(safe=False, blocked_at=\"prompt_blocklist\", image=None)\n        if not self.pf.check_embedding(prompt):\n            return SafetyResult(safe=False, blocked_at=\"prompt_embedding\", image=None)\n\n        # Layer 2: generation (safety_checker already runs inside pipe if configured)\n        result = self.pipe(prompt=prompt, **kwargs)\n        if any(result.nsfw_content_detected or []):\n            return SafetyResult(safe=False, blocked_at=\"output_classifier\", image=None)\n\n        # Layer 3: custom output classifier (e.g. a fine-tuned ViT for harder cases)\n        image = result.images[0]\n        if not self.oc.is_safe(image):\n            return SafetyResult(safe=False, blocked_at=\"output_classifier\", image=None)\n\n        return SafetyResult(safe=True, blocked_at=\"passed\", image=image)"
          }
        ]
      },
