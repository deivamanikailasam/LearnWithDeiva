            "type": "text",
            "text": "// buildRequest.test.ts\nimport { buildChatRequest } from \"./buildRequest\";\n\nconst base = {\n  model: \"claude-3-5-haiku-20241022\", maxTokens: 2048,\n  temperature: 0.5, topP: null, systemPrompt: \"\",\n  stopSequences: [], stream: true,\n};\nconst msgs = [{ role: \"user\", content: \"hi\" }];\n\ntest(\"omits system prompt when empty\", () => {\n  const req = buildChatRequest(msgs, base);\n  expect(req.system).toBeUndefined();\n});\n\ntest(\"includes system prompt when set\", () => {\n  const req = buildChatRequest(msgs, { ...base, systemPrompt: \"Be brief.\" });\n  expect(req.system).toBe(\"Be brief.\");\n});\n\ntest(\"includes stop_sequences when non-empty\", () => {\n  const req = buildChatRequest(msgs, { ...base, stopSequences: [\"###\"] });\n  expect(req.stop_sequences).toEqual([\"###\"]);\n});\n\ntest(\"uses top_p only when temperature is 1.0\", () => {\n  const withTop = buildChatRequest(msgs, { ...base, temperature: 1.0, topP: 0.9 });\n  expect(withTop.top_p).toBe(0.9);\n  expect(withTop.temperature).toBeUndefined();\n\n  const withTemp = buildChatRequest(msgs, { ...base, temperature: 0.7, topP: 0.9 });\n  expect(withTemp.temperature).toBe(0.7);\n  expect(withTemp.top_p).toBeUndefined();\n});\n"
