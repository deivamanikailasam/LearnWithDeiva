          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Model Selector"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Expose 2–4 curated model choices with labels that communicate cost and capability, not internal version strings. Include a cost/latency hint so users can make an informed trade-off."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// constants/models.ts\nexport const MODELS = [\n  {\n    id: \"claude-3-5-haiku-20241022\",\n    label: \"Haiku (Fast)\",\n    description: \"Best for quick tasks, lower cost\",\n    inputCostPer1M:  0.80,\n    outputCostPer1M: 4.00,\n    contextK: 200,\n  },\n  {\n    id: \"claude-opus-4-8\",\n    label: \"Opus (Capable)\",\n    description: \"Best for complex reasoning\",\n    inputCostPer1M: 15.00,\n    outputCostPer1M: 75.00,\n    contextK: 200,\n  },\n] as const;\n\nexport type ModelId = (typeof MODELS)[number][\"id\"];\n"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// components/ModelSelector.tsx\nimport { MODELS } from \"../constants/models\";\n\ninterface Props {\n  value: string;\n  onChange: (id: string) => void;\n}\n\nexport function ModelSelector({ value, onChange }: Props) {\n  const selected = MODELS.find(m => m.id === value);\n\n  return (\n    <div className=\"model-selector\">\n      <label htmlFor=\"model-select\">Model</label>\n      <select\n        id=\"model-select\"\n        value={value}\n        onChange={e => onChange(e.target.value)}\n      >\n        {MODELS.map(m => (\n          <option key={m.id} value={m.id}>{m.label}</option>\n        ))}\n      </select>\n      {selected && (\n        <p className=\"model-hint\">\n          {selected.description} · ~${selected.inputCostPer1M}/M input tokens\n        </p>\n      )}\n    </div>\n  );\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "System Prompt Editor"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The system prompt shapes how the model behaves in every turn. The editor needs character counting, an approximate token estimate, and preset templates so users start from something sensible rather than a blank box."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// components/SystemPromptEditor.tsx\nimport { useCallback, useEffect, useRef } from \"react\";\n\nconst PRESETS: Record<string, string> = {\n  Default:   \"\",\n  \"Code review\": \"You are an expert software engineer. Review the provided code and point out bugs, style issues, and optimisation opportunities. Be concise.\",\n  \"Writing coach\": \"You are a writing coach. Help the user improve clarity, structure, and tone. Ask clarifying questions when the goal is unclear.\",\n  \"Data analyst\": \"You are a data analyst. Respond with precise, quantified answers. Show your reasoning. Prefer tabular output.\",\n};\n\ninterface Props {\n  value: string;\n  onChange: (v: string) => void;\n  maxLength?: number;\n}\n\n// Rough token estimate: 4 chars ≈ 1 token\nfunction estimateTokens(text: string): number {\n  return Math.ceil(text.length / 4);\n}\n\nexport function SystemPromptEditor({ value, onChange, maxLength = 10000 }: Props) {\n  const textareaRef = useRef<HTMLTextAreaElement>(null);\n\n  // Auto-resize on content change\n  useEffect(() => {\n    const el = textareaRef.current;\n    if (!el) return;\n    el.style.height = \"auto\";\n    el.style.height = Math.min(el.scrollHeight, 300) + \"px\";\n  }, [value]);\n\n  const applyPreset = useCallback(\n    (name: string) => onChange(PRESETS[name] ?? \"\"),\n    [onChange]\n  );\n\n  return (\n    <div className=\"system-prompt-editor\">\n      <label htmlFor=\"system-prompt\">System prompt</label>\n\n      {/* Preset chips */}\n      <div className=\"preset-chips\">\n        {Object.keys(PRESETS).map(name => (\n          <button key={name} onClick={() => applyPreset(name)} className=\"chip\">\n            {name}\n          </button>\n        ))}\n      </div>\n\n      <textarea\n        id=\"system-prompt\"\n        ref={textareaRef}\n        value={value}\n        onChange={e => onChange(e.target.value)}\n        maxLength={maxLength}\n        placeholder=\"You are a helpful assistant...\"\n        style={{ resize: \"vertical\", overflow: \"auto\" }}\n        aria-describedby=\"system-prompt-meta\"\n      />\n\n      <p id=\"system-prompt-meta\" className=\"prompt-meta\">\n        {value.length.toLocaleString()} / {maxLength.toLocaleString()} chars\n        · ~{estimateTokens(value).toLocaleString()} tokens\n      </p>\n    </div>\n  );\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Stop Sequences"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Stop sequences instruct the model to halt generation when it produces a specific string. Useful for structured output (stop at "
          },
          {
            "type": "text",
            "text": "###",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": "), multi-agent pipelines (stop at a speaker marker), or preventing runaway responses. The API accepts up to 4."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// components/StopSequences.tsx\nimport { useState, useCallback, KeyboardEvent } from \"react\";\n\ninterface Props {\n  value: string[];\n  onChange: (sequences: string[]) => void;\n}\n\nexport function StopSequences({ value, onChange }: Props) {\n  const [input, setInput] = useState(\"\");\n\n  const add = useCallback(() => {\n    const trimmed = input.trim();\n    if (!trimmed || value.includes(trimmed) || value.length >= 4) return;\n    onChange([...value, trimmed]);\n    setInput(\"\");\n  }, [input, value, onChange]);\n\n  const remove = useCallback(\n    (seq: string) => onChange(value.filter(s => s !== seq)),\n    [value, onChange]\n  );\n\n  const onKeyDown = useCallback((e: KeyboardEvent<HTMLInputElement>) => {\n    if (e.key === \"Enter\") { e.preventDefault(); add(); }\n  }, [add]);\n\n  return (\n    <div className=\"stop-sequences\" aria-label=\"Stop sequences\">\n      <label>Stop sequences ({value.length}/4)</label>\n\n      <div className=\"chips\">\n        {value.map(seq => (\n          <span key={seq} className=\"chip\">\n            {seq}\n            <button onClick={() => remove(seq)} aria-label={`Remove ${seq}`}>×</button>\n          </span>\n        ))}\n      </div>\n\n      {value.length < 4 && (\n        <div className=\"add-row\">\n          <input\n            type=\"text\"\n            value={input}\n            onChange={e => setInput(e.target.value)}\n            onKeyDown={onKeyDown}\n            placeholder=\"Type and press Enter\"\n            aria-label=\"Add stop sequence\"\n          />\n          <button onClick={add} disabled={!input.trim()}>Add</button>\n        </div>\n      )}\n    </div>\n  );\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Context Window Usage Indicator"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Conversations grow until they hit the model's context limit. Without visibility, users get a cryptic error or unexpected truncation. Show a token progress bar that updates after each message."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// components/ContextMeter.tsx\ninterface Props {\n  usedTokens: number;\n  modelContextK: number;\n}\n\nexport function ContextMeter({ usedTokens, modelContextK }: Props) {\n  const maxTokens = modelContextK * 1000;\n  const pct = Math.min((usedTokens / maxTokens) * 100, 100);\n  const color = pct > 85 ? \"#ef4444\" : pct > 65 ? \"#f59e0b\" : \"#22c55e\";\n\n  return (\n    <div className=\"context-meter\" aria-label=\"Context window usage\">\n      <div className=\"meter-track\">\n        <div\n          className=\"meter-fill\"\n          style={{ width: `${pct}%`, background: color }}\n          role=\"progressbar\"\n          aria-valuenow={usedTokens}\n          aria-valuemax={maxTokens}\n        />\n      </div>\n      <span className=\"meter-label\">\n        {(usedTokens / 1000).toFixed(1)}K / {modelContextK}K tokens\n      </span>\n      {pct > 85 && (\n        <p className=\"meter-warning\">\n          Context nearly full — oldest messages will be trimmed automatically.\n        </p>\n      )}\n    </div>\n  );\n}\n"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// utils/tokenCount.ts — rough client-side estimate before the server responds\nexport function estimateMessageTokens(messages: { role: string; content: string }[]): number {\n  // Each message has ~4 overhead tokens (role, separators)\n  return messages.reduce((sum, msg) => sum + Math.ceil(msg.content.length / 4) + 4, 0);\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Wiring All Parameters to the Request"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Centralise all advanced options into the request body. The backend passes them through to the Anthropic API after server-side validation."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// utils/buildRequest.ts\nimport type { Settings } from \"../hooks/useChatSettings\";\n\nexport function buildChatRequest(\n  messages: Message[],\n  settings: Settings,\n) {\n  const body: Record<string, unknown> = {\n    model:      settings.model,\n    max_tokens: settings.maxTokens,\n    messages,\n    stream:     settings.stream ?? true,\n  };\n\n  if (settings.systemPrompt.trim()) {\n    body.system = settings.systemPrompt.trim();\n  }\n  if (settings.stopSequences.length > 0) {\n    body.stop_sequences = settings.stopSequences.slice(0, 4);\n  }\n  // top_p only meaningful when temperature == 1.0\n  if (settings.topP !== null && settings.temperature === 1.0) {\n    body.top_p = settings.topP;\n  } else {\n    body.temperature = settings.temperature;\n  }\n\n  return body;\n}\n"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
