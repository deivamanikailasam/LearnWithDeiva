            "text": "// StopSequences.test.tsx\nimport { render, screen, fireEvent } from \"@testing-library/react\";\nimport { StopSequences } from \"./StopSequences\";\n\ntest(\"adds sequence on Enter\", () => {\n  const handler = jest.fn();\n  render(<StopSequences value={[]} onChange={handler} />);\n\n  const input = screen.getByRole(\"textbox\");\n  fireEvent.change(input, { target: { value: \"###\" } });\n  fireEvent.keyDown(input, { key: \"Enter\" });\n  expect(handler).toHaveBeenCalledWith([\"###\"]);\n});\n\ntest(\"blocks adding more than 4 sequences\", () => {\n  render(<StopSequences value={[\"a\", \"b\", \"c\", \"d\"]} onChange={jest.fn()} />);\n  expect(screen.queryByRole(\"textbox\")).toBeNull();   // input hidden at limit\n});\n\ntest(\"removes sequence on × click\", () => {\n  const handler = jest.fn();\n  render(<StopSequences value={[\"###\", \"END\"]} onChange={handler} />);\n  fireEvent.click(screen.getByRole(\"button\", { name: /Remove ###/ }));\n  expect(handler).toHaveBeenCalledWith([\"END\"]);\n});\n"
