{"format":"tiptap/v1","updatedAt":"2026-06-21T13:35:26.625Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"For Generative AI applications in TypeScript/JavaScript, "},{"type":"text","marks":[{"type":"bold"}],"text":"Types and Interfaces"},{"type":"text","text":" define the structure of AI request/response data, ensure type safety during API calls, and prevent runtime errors from mismatched data—critical when working with unpredictable LLM outputs."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Concept"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Definition"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Best For Gen AI"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Type"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Flexible alias for any value (unions, intersections, primitives)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Model names, response variants, primitive aliases"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Interface"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Object shape definition; extensible with "},{"type":"text","marks":[{"type":"code"}],"text":"extends"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"AI request/response structures, API contracts"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Union Type"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Value can be one of multiple types"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Multiple AI model outputs (`\"gpt\""}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"bert\""}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"claude\"`)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Generic"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Reusable type parameter"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Functions handling multiple model outputs"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"unknown"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Requires type check before use (safer than "},{"type":"text","marks":[{"type":"code"}],"text":"any"},{"type":"text","text":")"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Variable AI responses needing runtime validation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why It Matters for Gen AI"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ❌ WITHOUT types: Runtime crash\nconst response = await fetch(\"/api/ai\");\nconst data = response.json();\ndata.confidence.toUpperCase(); // Error: confidence is number, not string\n\n// ✅ WITH types: Compile-time error caught\ninterface AIResponse {\n  text: string;\n  confidence: number;\n}\n\nasync function getAIResponse(): Promise<AIResponse> {\n  const res = await fetch(\"/api/ai\");\n  return res.json();\n}\n\nconst data = await getAIResponse();\ndata.confidence.toUpperCase(); // ❌ TypeScript error IMMEDIATELY [web:29]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Catch bugs at compile time"},{"type":"text","text":" instead of runtime (prevents hackathon disasters)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Clear contracts"},{"type":"text","text":" between frontend/backend for AI data flow\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Autocomplete + IntelliSense"},{"type":"text","text":" reduces communication overhead\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Structured AI output"},{"type":"text","text":" prevents mismatched data handling"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How It Works (Core Patterns)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Define AI Request/Response Interfaces"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ✅ Best for AI responses: interface (extendable object shape)\ninterface AIResponse {\n  text: string;\n  confidence: number;\n  tokens_used?: number;  // Optional field\n}\n\ninterface ChatMessage {\n  role: \"system\" | \"user\" | \"assistant\";  // Union type for role\n  content: string;\n  timestamp?: Date;\n}\n\n// Extension for specific models\ninterface GPTResponse extends AIResponse {\n  model: \"gpt-3.5\" | \"gpt-4\";\n  temperature: number;\n}"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Union Types for Multiple Model Outputs"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ✅ Type alias for model names (primitive union)\ntype Model = \"gpt\" | \"bert\" | \"claude\" | \"gemini\";\n\n// ✅ Union for different response formats\ntype AIOutput = \n  | { type: \"text\"; content: string }\n  | { type: \"image\"; url: string }\n  | { type: \"code\"; language: string; code: string };\n\nfunction processOutput(output: AIOutput): string {\n  if (output.type === \"text\") return output.content;\n  if (output.type === \"image\") return `Image: ${output.url}`;\n  return `Code (${output.language}): ${output.code}`;\n}"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Async/Await with Types for API Calls"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ✅ Ensure API returns correct data type\nasync function callGenAI(prompt: string): Promise<AIResponse> {\n  const res = await fetch(\"/api/ai\", {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ prompt }),\n  });\n  \n  if (!res.ok) throw new Error(`API error: ${res.status}`);\n  return res.json() as Promise<AIResponse>;  // Type assertion\n}\n\n// ✅ Usage with type safety\nconst response = await callGenAI(\"Explain quantum computing\");\nconsole.log(response.text);        // ✅ string\nconsole.log(response.confidence);  // ✅ number"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Generics for Reusable AI Functions"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ✅ Generic function for multiple model outputs\nfunction handleModelOutput<T extends AIOutput>(output: T): string {\n  return processOutput(output);  // Reusable without rewriting\n}\n\n// ✅ Generic for chat history\ninterface ChatHistory<T extends ChatMessage = ChatMessage> {\n  messages: T[];\n  addMessage(msg: T): void;\n  getMessages(): T[];\n}"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Typed Error Handling with AI APIs"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ✅ Try/catch with typed errors\nasync function safeCallGenAI(prompt: string): Promise<AIResponse | null> {\n  try {\n    const data = await getAIResponse();\n    return data;\n  } catch (error: unknown) {  // ✅ unknown requires type check\n    if (error instanceof Error) {\n      console.error(`AI API error: ${error.message}`);\n      return null;\n    }\n    throw new Error(\"Unknown error occurred\");\n  }\n}"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use (Decision Criteria)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Interface"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"AI response structure"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"code"}],"text":"interface AIResponse"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Model name aliases"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ `type Model = \"gpt\""}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"bert\"`"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multiple output formats"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Union types"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Extending contracts"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"code"}],"text":"extends"},{"type":"text","text":" keyword"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Function parameters"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Object shapes"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Unions/intersections"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph"}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Primitive aliases"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ `type Status = \"success\""}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"\"error\"`"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rule of thumb:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Interfaces"},{"type":"text","text":": Best for AI request/response shapes (extendable)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Types"},{"type":"text","text":": More flexible for unions, intersections, primitives"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How to Implement (Step-by-Step)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 1: Create "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"types/ai.ts"},{"type":"text","marks":[{"type":"bold"}],"text":" File"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// types/ai.ts\nexport interface AIResponse {\n  text: string;\n  confidence: number;\n  tokens_used?: number;\n}\n\nexport type Model = \"gpt-4\" | \"claude-3\" | \"gemini-1.5\";\n\nexport interface ChatMessage {\n  role: \"system\" | \"user\" | \"assistant\";\n  content: string;\n}"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 2: Import Types in API Client"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// api/genAI.ts\nimport { AIResponse, Model, ChatMessage } from \"../types/ai\";\n\nexport async function callAI(\n  prompt: string,\n  model: Model = \"gpt-4\"\n): Promise<AIResponse> {\n  const res = await fetch(\"/api/ai\", {\n    method: \"POST\",\n    body: JSON.stringify({ prompt, model }),\n  });\n  return res.json() as Promise<AIResponse>;\n}"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 3:Use in React Component"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// components/AIChat.tsx\nimport { AIResponse, ChatMessage } from \"../types/ai\";\n\nexport function AIChat() {\n  const [messages, setMessages] = useState<ChatMessage[]>([]);\n  const [response, setResponse] = useState<AIResponse | null>(null);\n\n  const handleSubmit = async (prompt: string) => {\n    const data = await callAI(prompt);  // ✅ Typed as AIResponse\n    setResponse(data);\n    setMessages([...messages, { role: \"user\", content: prompt }]);\n  };\n\n  return <div>{response?.text}</div>;  // ✅ TypeScript knows .text is string\n}"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 4: Integrate Third-Party Libraries"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# ✅ For libraries without native TS support\nnpm install axios @types/axios"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import axios, { AxiosResponse } from \"axios\";\nimport { AIResponse } from \"../types/ai\";\n\nconst res = await axios.get(\"/api/ai\") as AxiosResponse<AIResponse>;"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Examples"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 1: OpenAI API with TypeScript"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import { OpenAI } from \"openai\";\n\ninterface OpenAIResponse {\n  content: string;\n  model: string;\n  usage: {\n    total_tokens: number;\n    prompt_tokens: number;\n  };\n}\n\nasync function generateText(prompt: string): Promise<OpenAIResponse> {\n  const openai = new OpenAI({ apiKey: process.env.OPENAI_API_KEY });\n  \n  const response = await openai.chat.completions.create({\n    model: \"gpt-4\",\n    messages: [{ role: \"user\", content: prompt }],\n  });\n\n  return {\n    content: response.choices[0].message.content!,\n    model: response.model,\n    usage: response.usage,\n  };  // ✅ Type-checked\n}"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 2: Google Gemini SDK Types"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import { GoogleGenerativeAI } from \"@google/generative-ai\";\n\ninterface GeminiResponse {\n  text: string;\n  safetyRatings: Array<{ category: string; probability: string }>;\n}\n\nconst genAI = new GoogleGenerativeAI(process.env.API_KEY);\nconst model = genAI.getGenerativeModel({ model: \"gemini-1.5-flash\" });\n\nconst result = await model.generateContent(\"Explain quantum computing\");\nconst response: GeminiResponse = {\n  text: result.response.text(),\n  safetyRatings: result.response.safetyRatings,\n};  // ✅ Type-safe"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Real-World Example: Full-Stack GenAI Chat App"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Scale"},{"type":"text","text":": Production chatbot with 10K+ users\n"},{"type":"text","marks":[{"type":"bold"}],"text":"Architecture"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Frontend (Next.js + React):\n├── types/ai.ts (AIResponse, ChatMessage, Model)\n├── api/genAI.ts (callAI function with types)\n├── components/AIChat.tsx (typed useState)\n└── hooks/useAIChat.ts (generic async hook)\n\nBackend (Next.js API Routes):\n├── types/ai.ts (shared types)\n├── routes/api/ai.ts (typed request/response)\n└── lib/openai.ts (typed OpenAI client)\n\nBenefits:\n- Compile-time errors prevent runtime crashes\n- Autocomplete speeds up develop