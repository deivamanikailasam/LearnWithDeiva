      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Measuring TTFB in production"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import time, httpx\n\ndef measure_ttfb(messages: list[dict]) -> float:\n    \"\"\"Return time in ms until the first SSE data chunk is received.\"\"\"\n    t0 = time.monotonic()\n    ttfb_ms = None\n    with httpx.Client(timeout=120.0) as http:\n        with http.stream(\n            \"POST\",\n            \"https://api.example.com/v1/chat/stream\",\n            json={\"messages\": messages},\n            headers={\"Authorization\": \"Bearer my-token\"},\n        ) as response:\n            for line in response.iter_lines():\n                if line.startswith(\"data: \") and ttfb_ms is None:\n                    ttfb_ms = (time.monotonic() - t0) * 1000\n                    print(f\"TTFB: {ttfb_ms:.0f} ms\")\n                    break   # got what we needed\n    return ttfb_ms or 0.0"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Buffering and Proxy Configuration"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Streaming responses break at every layer that buffers HTTP bodies. The most common failure mode is deploying a streaming endpoint and discovering it doesn't stream because a proxy or CDN in the path accumulates the response:"
          }
        ]
      },
      {
        "type": "table",
        "content": [
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableHeader",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Layer"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableHeader",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Default behavior"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableHeader",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Fix"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "nginx (reverse proxy)"
                      }
