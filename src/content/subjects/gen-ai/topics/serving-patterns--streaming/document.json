      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "SSE over HTTP is the dominant choice for LLM APIs \u2014 it reuses standard HTTP infrastructure, is proxy-friendly, and has a built-in reconnect mechanism. WebSockets are preferred when the connection is bidirectional (e.g. voice agents, real-time tool calls)."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Server-Side: FastAPI SSE Endpoint"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Basic streaming endpoint"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from fastapi import FastAPI\nfrom fastapi.responses import StreamingResponse\nfrom openai import AsyncOpenAI\nfrom pydantic import BaseModel\nimport json\n\napp = FastAPI()\nclient = AsyncOpenAI()\n\nclass ChatRequest(BaseModel):\n    messages: list[dict]\n    model: str = \"gpt-4o-mini\"\n\nasync def token_generator(req: ChatRequest):\n    \"\"\"Yield SSE-formatted chunks as the model generates tokens.\"\"\"\n    async with client.chat.completions.stream(\n        model=req.model,\n        messages=req.messages,\n    ) as stream:\n        async for chunk in stream:\n            delta = chunk.choices[0].delta\n            if delta.content:\n                # SSE format: \"data: <json>\\n\\n\"\n                payload = json.dumps({\"delta\": delta.content})\n                yield f\"data: {payload}\\n\\n\"\n\n        # Signal end of stream\n        yield \"data: [DONE]\\n\\n\"\n\n@app.post(\"/v1/chat/stream\")\nasync def chat_stream(req: ChatRequest) -> StreamingResponse:\n    return StreamingResponse(\n        token_generator(req),\n        media_type=\"text/event-stream\",\n        headers={\n            \"Cache-Control\": \"no-cache\",\n            \"X-Accel-Buffering\": \"no\",   # disable nginx buffering\n        },\n    )"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "The "
              },
              {
                "type": "text",
                "marks": [
                  {
                    "type": "code"
                  }
                ],
                "text": "X-Accel-Buffering: no"
              },
              {
                "type": "text",
                "text": " header tells nginx (and similar proxies) not to buffer the response body. Without it, the proxy accumulates the entire response before forwarding, defeating the purpose of streaming."
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Including usage metadata at end of stream"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "async def token_generator_with_usage(req: ChatRequest):\n    usage = None\n    async with client.chat.completions.stream(\n        model=req.model,\n        messages=req.messages,\n        stream_options={\"include_usage\": True},   # OpenAI-specific option\n    ) as stream:\n        async for chunk in stream:\n            delta = chunk.choices[0].delta\n            if delta.content:\n                yield f\"data: {json.dumps({'delta': delta.content})}\\n\\n\"\n            if chunk.usage:\n                usage = chunk.usage\n\n    if usage:\n        meta = {\n            \"done\": True,\n            \"input_tokens\": usage.prompt_tokens,\n            \"output_tokens\": usage.completion_tokens,\n        }\n        yield f\"data: {json.dumps(meta)}\\n\\n\"\n    yield \"data: [DONE]\\n\\n\""
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Client-Side Consumption"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Python client using httpx"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import httpx, json\n\ndef stream_chat(messages: list[dict]) -> None:\n    \"\"\"Print tokens as they arrive, then print final stats.\"\"\"\n    total_tokens = {}\n    with httpx.Client(timeout=120.0) as http:\n        with http.stream(\n            \"POST\",\n            \"https://api.example.com/v1/chat/stream\",\n            json={\"messages\": messages},\n            headers={\"Authorization\": \"Bearer my-token\"},\n        ) as response:\n            response.raise_for_status()\n            for line in response.iter_lines():\n                if not line.startswith(\"data: \"):\n                    continue\n                payload = line[6:]   # strip \"data: \"\n                if payload == \"[DONE]\":\n                    break\n                data = json.loads(payload)\n                if \"delta\" in data:\n                    print(data[\"delta\"], end=\"\", flush=True)\n                if \"output_tokens\" in data:\n                    total_tokens = data\n    print()  # newline after streamed output\n    if total_tokens:\n        print(f\"[tokens: in={total_tokens['input_tokens']} out={total_tokens['output_tokens']}]\")\n\nstream_chat([{\"role\": \"user\", \"content\": \"Explain gradient descent in three paragraphs.\"}])"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "JavaScript client (browser / Node.js)"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "javascript"
        },
        "content": [
          {
            "type": "text",
            "text": "async function streamChat(messages) {\n  const response = await fetch(\"https://api.example.com/v1/chat/stream\", {\n    method: \"POST\",\n    headers: {\n      \"Content-Type\": \"application/json\",\n      \"Authorization\": \"Bearer my-token\",\n    },\n    body: JSON.stringify({ messages }),\n  });\n\n  if (!response.ok) throw new Error(`HTTP ${response.status}`);\n\n  const reader = response.body.getReader();\n  const decoder = new TextDecoder();\n  let buffer = \"\";\n\n  while (true) {\n    const { done, value } = await reader.read();\n    if (done) break;\n\n    buffer += decoder.decode(value, { stream: true });\n    const lines = buffer.split(\"\\n\");\n    buffer = lines.pop();  // keep incomplete line for next chunk\n\n    for (const line of lines) {\n      if (!line.startsWith(\"data: \")) continue;\n      const payload = line.slice(6);\n      if (payload === \"[DONE]\") return;\n      const data = JSON.parse(payload);\n      if (data.delta) {\n        process.stdout.write(data.delta);  // or update DOM in browser\n      }\n    }\n  }\n}"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Time-to-First-Byte (TTFB)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "TTFB is the latency from when the client sends the request to when the client receives the first byte of the response body (the first token). For streaming APIs this is the primary UX metric \u2014 users perceive the app as 'fast' or 'slow' based on TTFB, not total response time."
          }
        ]
      },
