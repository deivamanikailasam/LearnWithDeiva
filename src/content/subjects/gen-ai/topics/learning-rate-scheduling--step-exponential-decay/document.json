{"format": "tiptap/v1", "updatedAt": "2026-06-22T09:06:48.063Z", "doc": {"type": "doc", "content": [{"type": "image", "attrs": {"src": "data:image/svg+xml;base64,", "alt": "Step/Exponential Decay — concept overview"}}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "What Step/Exponential Decay Are"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Step Decay"}, {"type": "text", "text": " and "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Exponential Decay"}, {"type": "text", "text": " are two popular learning rate scheduling strategies that reduce the learning rate over time as training progresses."}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The core idea: "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Start with a high learning rate"}, {"type": "text", "text": " for fast initial learning, then "}, {"type": "text", "marks": [{"type": "bold"}], "text": "gradually reduce it"}, {"type": "text", "text": " as the model gets closer to the optimal solution, enabling finer adjustments."}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Strategy"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "How It Works"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Step Decay"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Reduces learning rate by a fixed factor after a fixed number of epochs/steps"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Exponential Decay"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Reduces learning rate exponentially over time (continuously decreasing)"}]}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Why They Matter in Generative AI"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Different scheduling strategies suit different training scenarios:"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use Case"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Preferred Strategy"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Reason"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Large-scale training"}, {"type": "text", "text": " (LLMs, diffusion)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Step Decay"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Near-optimal, geometric decay"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Transformers"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Exponential Decay"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Smooth convergence, differentiable"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Simple models"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Step Decay"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Easy to tune, predictable"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Fine-tuning"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Exponential Decay"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Gradual, smooth reduction"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Computer vision"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Step Decay"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Cut by constant factor every constant epochs"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Learning rate decay is "}, {"type": "text", "marks": [{"type": "bold"}], "text": "crucial"}, {"type": "text", "text": " for optimization algorithms and significantly impacts model performance."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Step Decay Learning Rate Schedule"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "How It Works"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The learning rate is reduced by a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "fixed factor"}, {"type": "text", "text": " after a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "fixed number of epochs or iterations"}, {"type": "text", "text": ":"}]}, {"type": "blockMath", "attrs": {"latex": "\\alpha_{\\text{new}} = \\alpha \\times \\delta"}}, {"type": "paragraph", "content": [{"type": "text", "text": "Where:\n- "}, {"type": "inlineMath", "attrs": {"latex": "\\alpha"}}, {"type": "text", "text": ": Current learning rate\n- "}, {"type": "inlineMath", "attrs": {"latex": "\\delta"}}, {"type": "text", "text": ": Decay factor (0 to 1, typically 0.5 or 0.1)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Full formula"}, {"type": "text", "text": ":\n\\[\n\\alpha"}, {"type": "text", "marks": [{"type": "italic"}], "text": "{\\text{epoch}} = \\alpha"}, {"type": "text", "text": "{\\text{initial}} \\times \\delta^{\\lfloor \\frac{1 + \\text{epoch}}{\\text{epochs\\"}, {"type": "text", "marks": [{"type": "italic"}], "text": "drop}} \\rfloor}\n\\]"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Where:\n- "}, {"type": "inlineMath", "attrs": {"latex": "\\lfloor \\cdot \\rfloor"}}, {"type": "text", "text": ": Floor function (integer division)\n- "}, {"type": "inlineMath", "attrs": {"latex": "\\text{epochs\\_drop}"}}, {"type": "text", "text": ": Number of epochs between each decay"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Example"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Step: 0.5 every 10 epochs\ninitial_lr = 0.1\ndrop = 0.5\nepochs_drop = 10\n\n# Epoch 0-9:  lr = 0.1\n# Epoch 10-19: lr = 0.1 * 0.5 = 0.05\n# Epoch 20-29: lr = 0.1 * 0.5^2 = 0.025\n# Epoch 30-39: lr = 0.1 * 0.5^3 = 0.0125"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "In PyTorch"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import torch\nimport torch.optim as optim\nfrom torch.optim.lr_scheduler import StepLR\n\nmodel = torch.nn.Linear(10, 1)\noptimizer = optim.SGD(model.parameters(), lr=0.1)\n\n# Step decay scheduler\nscheduler = StepLR(\n    optimizer,\n    step_size=10,      # Decay every 10 epochs [web:180]\n    gamma=0.5          # Decay factor δ [web:180]\n)\n\n# Training loop\nfor epoch in range(50):\n    train_epoch()\n    valid_epoch()\n    scheduler.step()  # Decay learning rate [web:180]\n    print(f\"Epoch {epoch}, LR: {scheduler.get_last_lr()[0]}\")"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "In TensorFlow/Keras"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import tensorflow as tf\nfrom tensorflow.keras.callbacks import LearningRateScheduler\nimport math\n\ndef step_decay(epoch):\n    initial_lr = 0.1\n    drop = 0.5\n    epochs_drop = 10\n    lr = initial_lr * math.pow(drop, math.floor((1 + epoch) / epochs_drop))\n    return lr\n\nlr_scheduler = LearningRateScheduler(step_decay)\n\nmodel.compile(optimizer='sgd', loss='mse', callbacks=[lr_scheduler])"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Exponential Decay Learning Rate Schedule"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "How It Works"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The learning rate is reduced "}, {"type": "text", "marks": [{"type": "bold"}], "text": "exponentially over time"}, {"type": "text", "text": ":"}]}, {"type": "blockMath", "attrs": {"latex": "\\alpha_{\\text{step}} = \\alpha_{\\text{initial}} \\times \\gamma^{\\frac{\\text{step}}{\\text{decay\\_steps}}}"}}, {"type": "paragraph", "content": [{"type": "text", "text": "Where:\n- "}, {"type": "inlineMath", "attrs": {"latex": "\\gamma"}}, {"type": "text", "text": ": Decay rate (0 to 1, typically 0.9-0.99)\n- "}, {"type": "inlineMath", "attrs": {"latex": "\\text{step}"}}, {"type": "text", "text": ": Current optimizer step\n- "}, {"type": "inlineMath", "attrs": {"latex": "\\text{decay\\_steps}"}}, {"type": "text", "text": ": Steps between decays"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "With staircase=True"}, {"type": "text", "text": " (integer division):\n\\[\n\\alpha"}, {"type": "text", "marks": [{"type": "italic"}], "text": "{\\text{step}} = \\alpha"}, {"type": "text", "text": "{\\text{initial}} \\times \\gamma^{\\lfloor \\frac{\\text{step}}{\\text{decay\\"}, {"type": "text", "marks": [{"type": "italic"}], "text": "steps}} \\rfloor}\n\\]"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "This follows a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "staircase function"}, {"type": "text", "text": "."}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "In TensorFlow/Keras"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import tensorflow as tf\n\n# Exponential decay schedule\nlr_schedule = tf.keras.optimizers.schedules.ExponentialDecay(\n    initial_learning_rate=0.1,\n    decay_steps=1000,       # Decay every 1000 steps [web:177]\n    decay_rate=0.96,         # Decay rate γ [web:177]\n    staircase=True           # Use integer division [web:177]\n)\n\noptimizer = tf.keras.optimizers.Adam(learning_rate=lr_schedule)\n\nmodel.fit(\n    train_data,\n    train_labels,\n    epochs=100,\n    optimizer=optimizer\n)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "In PyTorch"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import torch\nimport torch.optim as optim\nfrom torch.optim.lr_scheduler import ExponentialLR\n\nmodel = torch.nn.Linear(10, 1)\noptimizer = optim.Adam(model.parameters(), lr=0.01)\n\n# Exponential decay scheduler\nscheduler = ExponentialLR(\n    optimizer,\n    gamma=0.96  # Decay rate γ [web:179][web:181]\n)\n\n# Training loop - step schedulers every epoch\nfor epoch in range(30):\n    train_epoch()\n    valid_epoch()\n    scheduler.step()  # Decay learning rate exponentially [web:179][web:181]\n    print(f\"Epoch {epoch}, LR: {scheduler.get_last_lr()[0]}\")"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Calculating gamma for target decay"}, {"type": "text", "text": ":"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "If you want to decay from 0.01 to 0.0001 in 30 epochs:"}]}, {"type": "blockMath", "attrs": {"latex": "0.01 \\times \\gamma^{30} = 0.0001"}}, {"type": "blockMath", "attrs": {"latex": "\\gamma = 0.01^{1/30} \\approx 0.86"}}, {"type": "paragraph", "content": [{"type": "text", "text": "[discuss.pytorch](https://discuss.pytorch.org/t/exponential-decay-learning-rate/76384)"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Step Decay vs. Exponential Decay"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Aspect"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Step Decay"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Exponential Decay"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Reduction pattern"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Staircase (step-wise)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Continuous exponential"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "When it decays"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Fixed intervals (e.g., every 10 epochs)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Every step/epoch"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Smoothness"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Discrete jumps"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Smooth, continuous"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Tuning complexity"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Easy (step_size, gamma)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Moderate (decay_rate)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Predictability"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Highly predictable"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Less predictable"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use case"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Large-scale, vision tasks"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Transformers, fine-tuning"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Research backing"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Near-optimal for least squares"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Standard in Transformer paper"}]}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Key Differences Explained"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Step Decay: \"Staircase\" Pattern"}]}, {"type": "codeBlock", "attrs": {"language": "text"}, "content": [{"type": "text", "text": "LR\n0.1 |-----------\n    |           |-----------\n    |           |           |-----------\n0.05|           |           |\n    |           |           |\n0.025|           |           |\n    |