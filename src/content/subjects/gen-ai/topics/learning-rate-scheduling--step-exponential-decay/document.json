"text":"# Warmup step: quickly adapt through large-scale learning\nstep_now <= step_warmup\nlr = (max_lr / max_step_warmup) * step_now\n\n# Exponential decay after warmup\nstep_warmup < step_now\nlr = -e^(α * (step_now - max_step_warmup)) + min_lr"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Warmup"},{"type":"text","text":": Starts with large learning rate for fast adaptation"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Exponential decay"},{"type":"text","text":": Converges to target rate through differentiable function"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Alpha"},{"type":"text","text":": Controls rate of convergence (larger α = faster convergence)"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Typical Values"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Hyperparameter"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Typical Value"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step decay gamma"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"0.5 (reduce by half)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"b