      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Handling Many Tools \u2014 Tool Routing"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "LLMs handle up to ~20 tools reliably. Beyond that, selection accuracy drops and latency increases because all tool descriptions are in the context window. For large tool sets, use "
          },
          {
            "type": "text",
            "text": "tool routing",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": ": a first LLM call with a small number of category-selector tools picks the right category, and the second call is given only the tools in that category."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from openai import OpenAI\nimport json\n\nclient = OpenAI()\n\n# Route selector: a small set of category tools\nCATEGORY_TOOLS = [\n    {\n        \"type\": \"function\",\n        \"function\": {\n            \"name\": \"select_category\",\n            \"description\": \"Select the tool category for this request.\",\n            \"parameters\": {\n                \"type\": \"object\",\n                \"properties\": {\n                    \"category\": {\n                        \"type\": \"string\",\n                        \"enum\": [\"finance\", \"weather\", \"calendar\", \"documents\"],\n                        \"description\": \"The category of tool needed.\",\n                    }\n                },\n                \"required\": [\"category\"],\n                \"additionalProperties\": False,\n            }\n        }\n    }\n]\n\n# Per-category tool sets (defined elsewhere)\nTOOLS_BY_CATEGORY = {\n    \"finance\": [get_stock_tool, get_earnings_tool, get_portfolio_tool],\n    \"weather\": [get_weather_tool, get_forecast_tool],\n    \"calendar\": [create_event_tool, list_events_tool, delete_event_tool],\n    \"documents\": [search_docs_tool, get_doc_tool, summarize_doc_tool],\n}\n\ndef route_and_execute(user_message: str) -> str:\n    # Step 1: categorise\n    route_response = client.chat.completions.create(\n        model=\"gpt-4o-mini\",\n        messages=[{\"role\": \"user\", \"content\": user_message}],\n        tools=CATEGORY_TOOLS,\n        tool_choice=\"required\",\n    )\n    category_call = route_response.choices[0].message.tool_calls[0]\n    category = json.loads(category_call.function.arguments)[\"category\"]\n\n    # Step 2: call with only the relevant tools\n    messages = [\n        {\"role\": \"user\", \"content\": user_message},\n    ]\n    final = client.chat.completions.create(\n        model=\"gpt-4o-mini\",\n        messages=messages,\n        tools=TOOLS_BY_CATEGORY[category],\n        tool_choice=\"auto\",\n    )\n    # ... dispatch tool call and return answer\n    return final.choices[0].message.content\n\nprint(route_and_execute(\"Search for the Q3 earnings report on Apple.\"))"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Structured Extraction with tool_choice: required"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Forcing a tool call with "
          },
          {
            "type": "text",
            "text": "tool_choice=\"required\"",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " (or a specific tool) is the most reliable way to extract structured data from text. The schema guarantees the output shape; the LLM cannot fall back to prose."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from openai import OpenAI\nfrom pydantic import BaseModel, Field\nfrom typing import Optional\nimport json\n\nclient = OpenAI()\n\nclass InvoiceData(BaseModel):\n    vendor: str = Field(description=\"Vendor name from the invoice.\")\n    invoice_number: str = Field(description=\"Invoice number or ID.\")\n    total_amount: float = Field(description=\"Total amount due.\")\n    currency: str = Field(description=\"Three-letter currency code, e.g. USD.\")\n    due_date: Optional[str] = Field(default=None, description=\"Due date in YYYY-MM-DD format, if present.\")\n\nINVOICE_TOOL = {\n    \"type\": \"function\",\n    \"function\": {\n        \"name\": \"extract_invoice\",\n        \"description\": \"Extract structured data from an invoice document.\",\n        \"parameters\": InvoiceData.model_json_schema(),\n    }\n}\n\ndef extract_invoice(text: str) -> InvoiceData:\n    response = client.chat.completions.create(\n        model=\"gpt-4o-mini\",\n        messages=[\n            {\"role\": \"system\", \"content\": \"Extract invoice data from the provided text.\"},\n            {\"role\": \"user\", \"content\": text},\n        ],\n        tools=[INVOICE_TOOL],\n        tool_choice={\"type\": \"function\", \"function\": {\"name\": \"extract_invoice\"}},\n    )\n    args = response.choices[0].message.tool_calls[0].function.arguments\n    return InvoiceData.model_validate_json(args)\n\ninvoice_text = \"\"\"\nINVOICE #INV-2024-0892\nVendor: Acme Supplies Ltd\nDue: 2024-07-15\nTotal: $3,450.00 USD\n\"\"\"\ndata = extract_invoice(invoice_text)\nprint(data.vendor, data.total_amount, data.currency)"
          }
        ]
