      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Good descriptions:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "State the action clearly:",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " start with a verb (Return, Search, Create, Delete\u2026)"
                  }
