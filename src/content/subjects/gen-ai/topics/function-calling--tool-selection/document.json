                    "content": [
                      {
                        "type": "text",
                        "text": "Return the current temperature, humidity, and conditions for a given city. Use this when the user asks about weather, temperature, climate, or whether to bring an umbrella. Do NOT use for historical weather data (use get_weather_history instead)."
