      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "NER Example: Token Classification"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from transformers import pipeline\n\n# Pre-fine-tuned NER model from the Hub\nner = pipeline(\"ner\", model=\"dbmdz/bert-large-cased-finetuned-conll03-english\",\n               aggregation_strategy=\"simple\")\n\nresult = ner(\"Hugging Face was founded in New York City.\")\nfor entity in result:\n    print(f\"{entity['entity_group']:5s}  {entity['word']:20s}  score={entity['score']:.3f}\")\n# ORG   Hugging Face          score=0.998\n# LOC   New York City         score=0.999"
          }
        ]
      },
