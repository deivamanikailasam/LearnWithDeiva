        "content": [
          {
            "type": "text",
            "text": "Tokenization"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "BERT uses WordPiece tokenization with a 30 522-token vocabulary. Rare or unknown words are split into subword pieces. The tokenizer always prepends "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "[CLS]"
          },
          {
            "type": "text",
            "text": " and appends "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "[SEP]"
          },
          {
            "type": "text",
            "text": " automatically:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from transformers import AutoTokenizer\n\ntokenizer = AutoTokenizer.from_pretrained(\"bert-base-uncased\")\n\nencoding = tokenizer(\"Banking rules changed.\", return_tensors=\"pt\")\nprint(tokenizer.convert_ids_to_tokens(encoding[\"input_ids\"][0].tolist()))\n# ['[CLS]', 'banking', 'rules', 'changed', '.', '[SEP]']\n\n# Subword splitting for an OOV word\nprint(tokenizer.tokenize(\"unrecognizable\"))\n# ['un', '##rec', '##og', '##ni', '##za', '##ble']"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "BERT has a 512-token limit. For longer documents, common strategies are: truncate to the first 512 tokens, use a sliding window over the document, or switch to a model with extended context (LongFormer, BigBird)."
              }
            ]
          }
        ]
      }
