{"format": "tiptap/v1", "updatedAt": "2026-06-22T09:24:15.001Z", "doc": {"type": "doc", "content": [{"type": "image", "attrs": {"src": "data:image/svg+xml;base64,", "alt": "Automatic Mixed Precision — concept overview"}}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "What Automatic Mixed Precision Is"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Automatic Mixed Precision (AMP)"}, {"type": "text", "text": " is a feature in modern deep learning frameworks that "}, {"type": "text", "marks": [{"type": "bold"}], "text": "automatically determines which operations should use FP16/BF16 and which should stay in FP32"}, {"type": "text", "text": ", requiring minimal or no code changes from the user."}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Instead of manually configuring precision for each layer, AMP uses "}, {"type": "text", "marks": [{"type": "bold"}], "text": "graph rewrite"}, {"type": "text", "text": " technology to categorize operators by their numerical-safety level and automatically applies the optimal precision mix."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Why AMP Matters in Generative AI"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "AMP provides significant benefits for training large AI models:"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Benefit"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Impact"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Speedup"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "2–3× faster training on Tensor Cores"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Memory reduction"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Reduces memory requirements for training"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Easy setup"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Minimal code changes or environment variables"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Preserved accuracy"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Maintains FP32 accuracy while using FP16/BF16"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Up to 3× speedup"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Maximum performance gain on NVIDIA GPUs"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "State-of-the-art frameworks (TensorFlow, PyTorch, MXNet) now support AMP, automatically leveraging FP16 power with minor code changes."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "How AMP Works"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "The Core Mechanism: Graph Rewrite"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "AMP uses "}, {"type": "text", "marks": [{"type": "bold"}], "text": "graph rewrite"}, {"type": "text", "text": " to categorize operators by numerical-safety level:"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Category"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Operations"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Precision"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "White (Always FP16)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Clear operations"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "FP16 only"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Black (Always FP32)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Numerically-dangerous"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "FP32 only"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Grey (Context-Dependent)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Conditional operations"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Based on context"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "[cs.toronto](https://www.cs.toronto.edu/ecosystem/documents/AMP-Tutorial.pdf)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Operator Categorization"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "AMP categorizes operators into four safety levels:"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Safety Level"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Examples"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Precision Strategy"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Numerically-Safe + Performance Critical"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Convolution, MatMul"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "FP16 (Tensor Cores)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Numerically-Neutral"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Max, Min"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "FP16 safe"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Numerically-Safe (Conditional)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Activations (ReLU, etc.)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "FP16 or FP32"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Numerically-Dangerous"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Exp, Log, Pow, Softmax, Reduction Sum, Mean"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Always FP32"}]}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Graph Rewrite Goals"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "AMP rewrites the computation graph with these objectives:"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Performance-critical ops in FP16"}, {"type": "text", "text": " (Conv, MatMul)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Numerical safety preserved"}, {"type": "text", "text": " for dangerous ops (Exp, Log, Softmax)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Minimize Cast operations"}, {"type": "text", "text": " (reduce overhead)"}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Numerically-Dangerous Ops"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Why These Need FP32"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Numerically-dangerous operations"}, {"type": "text", "text": " include:\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Exponential, Logarithmic"}, {"type": "text", "text": "\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Reduction Sum"}, {"type": "text", "text": "\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Softmax, Mean"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Problem"}, {"type": "text", "text": ": In FP32, "}, {"type": "text", "marks": [{"type": "code"}], "text": "1 + 10⁻¹⁰ = 1.0001"}, {"type": "text", "text": ", but in FP16, "}, {"type": "text", "marks": [{"type": "code"}], "text": "1 + 10⁻¹⁰ = 1"}, {"type": "text", "text": " — FP16's "}, {"type": "text", "marks": [{"type": "code"}], "text": "+"}, {"type": "text", "text": " is ineffective if operands differ by more than "}, {"type": "inlineMath", "attrs": {"latex": "2^{k}"}}, {"type": "text", "text": "."}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Example"}, {"type": "text", "text": ": FP16 addition loses precision when operands are very different."}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "MatMul Exception"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Question"}, {"type": "text", "text": ": Why can MatMul (matrix multiplication) use FP16 if it involves reduction sum?"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Answer"}, {"type": "text", "text": ": In Tensor Core FP16 MAC (Multiply-Accumulate) unit, "}, {"type": "text", "marks": [{"type": "bold"}], "text": "accumulation is always done in full precision"}, {"type": "text", "text": ", avoiding underflow."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Loss Scaling in AMP"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Automatic Loss Scaling"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "AMP uses "}, {"type": "text", "marks": [{"type": "bold"}], "text": "automatic loss scaling"}, {"type": "text", "text": " to determine the optimal scaling factor:"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Aspect"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Value/Strategy"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Initial scale"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "2¹⁵ ≈ 3×10⁵ (very large)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Goal"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "As large as possible without overflow"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "On overflow"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Halve scale immediately (s = s/2)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Steady iterations"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "After 2k steady steps, double scale"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Strategy"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Too high decreases faster than too low increases"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The loss scale factor "}, {"type": "inlineMath", "attrs": {"latex": "s"}}, {"type": "text", "text": " is determined "}, {"type": "text", "marks": [{"type": "bold"}], "text": "automatically"}, {"type": "text", "text": ", not manually."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "AMP in PyTorch"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Using torch.cuda.amp.autocast (Manual AMP)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import torch\n\nmodel = MyModel().float()  # Must be FP32 [web:254]\noptimizer = torch.optim.Adam(model.parameters())\nscaler = torch.cuda.amp.GradScaler()  # Auto loss scaling [web:263]\n\nfor input, target in dataset:\n    input = input.to('cuda')\n    target = target.to('cuda')\n    \n    # Automatic mixed precision\n    with torch.cuda.amp.autocast(device_type='cuda', dtype=torch.bfloat16):\n        output = model(input)  # Auto uses FP16/BF16 [web:254]\n        loss = compute_loss(output, target)\n    \n    # Scale loss\n    scaler.scale(loss).backward()\n    \n    # Unscaled optimizer step\n    scaler.step(optimizer)\n    \n    # Update scaler (auto adjust scale)\n    scaler.update()"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Using NVIDIA Apex (Original AMP)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "from apex import amp\n\n# Initialize AMP\nmodel, optimizer = amp.initialize(model, optimizer, opt_level='O2')\n\n# Use scale_loss instead of loss.backward()\nwith amp.scale_loss(loss, optimizer) as scaled_loss:\n    scaled_loss.backward()"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "AMP in TensorFlow"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Setting Environment Variable"}]}, {"type": "codeBlock", "attrs": {"language": "bash"}, "content": [{"type": "text", "text": "# Enable AMP via environment variable\nexport TF_ENABLE_AUTO_MIXED_PRECISION=1"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Using Config Parameter"}]}, {"type": "codeBlock", "attrs": {"language": "json"}, "content": [{"type": "text", "text": "{\n  \"epochs\": 1240,\n  \"num_training_epoch_per_valid\": 20,\n  \"learning_rate\": 1e-4,\n  \"use_amp\": true  // Enable AMP in config.json [web:274]\n}"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Using Mixed Precision Policy"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import tensorflow as tf\n\n# Enable mixed precision\npolicy = tf.keras.mixed_precision.Policy('mixed_float16')  # FP16 [web:254]\ntf.keras.mixed_precision.set_global_policy(policy)\n\n# Load model in FP32\nmodel = MyModel()  # Automatically uses FP32 master weights [web:254]\nmodel.compile(optimizer='adam', loss='mse')\n\n# Training (auto uses FP16)\nmodel.fit(train_data, train_labels, epochs=10)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Using LossScaleOptimizer"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Switch optimizer to automatic loss scaling\noptimizer = LossScaleOptimizer(optimizer)  # Auto loss scaling [web:273]"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "AMP Support by Framework"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Framework"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AMP Support"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Method"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "PyTorch"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Yes"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks":