[{"type": "bold"}], "text": "Formula"}, {"type": "text", "text": ":\n$$d(p, q) = \\sum"}, {"type": "text", "marks": [{"type": "italic"}], "text": "{i=1}^{n} |p_i - q_i|$$"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Where:\n- "}, {"type": "inlineMath", "attrs": {"latex": "p"}}, {"type": "text", "text": " and "}, {"type": "inlineMath", "attrs": {"latex": "q"}}, {"type": "text", "text": " = data points\n- "}, {"type": "inlineMath", "attrs": {"latex": "|p_i - q_i|"}}, {"type": "text", "text": " = absolute difference in dimension "}, {"type": "inlineMath", "attrs": {"latex": "i"}}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Properties"}, {"type": "text", "text": ":\n- ✅ Robust to outliers compared to Euclidean distance\n- ✅ Preferred for high-dimensional data\n- ✅ Works well in sparse feature environments (e.g., text data)"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "When to Use"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Not Ideal When"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Example Use Case"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "High-dimensional or grid-based data"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Features are highly corre