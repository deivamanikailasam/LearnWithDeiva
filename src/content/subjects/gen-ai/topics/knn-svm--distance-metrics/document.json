, {"type": "inlineMath", "attrs": {"latex": "p"}}, {"type": "text", "text": " carefully (can be tricky)"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "When to Use"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Not Ideal When"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Example Use Case"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Need "}, {"type": "text", "marks": [{"type": "bold"}], "text": "flexible distance tuning"}, {"type": "text", "text": " of parameter "}, {"type": "inlineMath", "attrs": {"latex": "p"}}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Unsure how to choose "}, {"type": "inlineMath", "attrs": {"latex": "p"}}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Generalized k-NN experiments"}]}]}]}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "4. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Chebyshev Distance"}, {"type": "text", "text": " (Maximum Norm)"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Measures the "}, {"type": "text", "marks": [{"type": "bold"}], "text": "maximum absolute difference"}, {"type": "text", "text": " across all features — focuses on the largest deviation."}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Formula"}, {"type": "text", "text": ":\n"}, {"type": "inlineMath", "attrs": {"latex": "$d(p, q) = \\max_i (|p_i - q_i|)"}}, {"type": "text", "text": "$"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Where:\n- "}, {"type": "inlineMath", "attrs": {"latex": "\\max_i"}}, {"type": "text", "text": " = maximum value across all dimensions\n- "}, {"type": "inlineMath", "attrs": {"latex": "|p_i - q_i|"}}, {"type": "text", "text": " = absolute difference in dimension "}, {"type": "inlineMath", "attrs": {"latex": "i"}}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Properties"}, {"type": "text", "text": ":\n- ✅ Uses the maximum feature difference\n- ✅ Ignores smaller variations\n- ✅ Square-shaped distance boundary"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "When to Use"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Not Ideal When"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Example Use Case"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Max difference matters"}, {"type": "text", "text": " across dimensions"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Small variations are important"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Chessboard moves, quality control"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Visual"}, {"type": "text", "text": ": Like a chess king moving (any direction, 1 step)."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "5. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Cosine Similarity"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Measures the "}, {"type": "text", "marks": [{"type": "bold"}], "text": "angle"}, {"type": "text", "text": " between two vectors instead of magnitude — captures directional similarity."}]}, {"type": "blockMath", "attrs": {"latex": "Formula:\n$$\\cos \\theta = \\frac{\\vec{a} \\cdot \\vec{b}}{||\\vec{a}|| \\cdot ||\\vec{b}||}$$"}}, {"type": "paragraph", "content": [{"type": "text", "text": "Where:\n- "}, {"type": "inlineMath", "attrs": {"latex": "\\vec{a} \\cdot \\vec{b}"}}, {"type": "text", "text": " = dot product of vectors\n- "}, {"type": "inlineMath", "attrs": {"latex": "||\\vec{a}||, ||\\vec{b}||"}}, {"type": "text", "text": " = magnitudes (lengths) of vectors"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Range"}, {"type": "text", "text": ": -1 to 1\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "1"}, {"type": "text", "text": ": vectors point in same direction (high similarity)\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "0"}, {"type": "text", "text": ": vectors are orthogonal (no relation)\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "-1"}, {"type": "text", "text": ": vectors opposite direction (high dissimilarity)"}]}, {"type": "paragraph", "content"