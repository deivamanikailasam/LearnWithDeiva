      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing with grpcurl and pytest"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "bash"
        },
        "content": [
          {
            "type": "text",
            "text": "# Test the streaming RPC from the CLI\ngrpcurl -plaintext \\\n    -d '{\"messages\": [{\"role\": \"user\", \"content\": \"Hello\"}], \"model\": \"claude-sonnet-4-6\", \"max_tokens\": 50}' \\\n    -H \"authorization: Bearer <token>\" \\\n    localhost:50051 \\\n    chat.ChatService/Chat"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# tests/test_chat_servicer.py\nimport pytest, grpc\nfrom unittest.mock import patch, MagicMock\nfrom src.server import ChatServicer\nfrom src.generated import chat_pb2\n\n@pytest.fixture\ndef servicer():\n    return ChatServicer()\n\ndef make_request(*contents):\n    return chat_pb2.ChatRequest(\n        messages=[chat_pb2.Message(role=\"user\", content=c) for c in contents],\n        model=\"claude-sonnet-4-6\",\n        max_tokens=128,\n    )\n\ndef test_chat_yields_chunks_then_done(servicer):\n    ctx = MagicMock()\n    ctx.is_active.return_value = True\n\n    # Mock the Anthropic stream to yield two text pieces\n    mock_stream = MagicMock()\n    mock_stream.__enter__ = lambda s: s\n    mock_stream.__exit__ = MagicMock(return_value=False)\n    mock_stream.text_stream = iter([\"Hello\", \", world!\"])\n\n    with patch(\"src.server._anthropic.messages.stream\", return_value=mock_stream):\n        chunks = list(servicer.Chat(make_request(\"Hi\"), ctx))\n\n    assert len(chunks) == 3   # \"Hello\", \", world!\", done-sentinel\n    assert chunks[0].delta == \"Hello\"\n    assert chunks[1].delta == \", world!\"\n    assert chunks[2].done is True\n    assert chunks[2].delta == \"\"\n\ndef test_chat_sends_error_chunk_on_api_failure(servicer):\n    ctx = MagicMock()\n    ctx.is_active.return_value = True\n\n    with patch(\n        \"src.server._anthropic.messages.stream\",\n        side_effect=Exception(\"overloaded\"),\n    ):\n        chunks = list(servicer.Chat(make_request(\"Hi\"), ctx))\n\n    assert any(c.error for c in chunks)"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Using ThreadPoolExecutor without enough workers for streaming:",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " each active streaming RPC holds a thread for its duration. Size the pool to "
                  },
                  {
                    "type": "text",
                    "text": "max_concurrent_streams",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": ", not just background tasks."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Not checking context.is_active() in the yield loop:",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " if the client disconnects mid-stream, the generator should stop. "
                  },
                  {
                    "type": "text",
                    "text": "context.is_active()",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " returns False when the call is cancelled."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Forgetting to regenerate stubs after proto changes:",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " the generated "
                  },
                  {
                    "type": "text",
                    "text": "*_pb2.py",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " files must be rebuilt whenever "
                  },
                  {
                    "type": "text",
                    "text": "chat.proto",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " changes. Add this to CI."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Deploying without TLS:",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " insecure gRPC channels are fine for local dev but must never reach the internet. Always add TLS (or mTLS) before exposing a gRPC endpoint externally."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Not setting a deadline on the client:",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " LLM calls can take many seconds. Set a per-RPC deadline ("
                  },
                  {
                    "type": "text",
                    "text": "stub.Chat(request, timeout=120)",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": ") so hung calls do not block threads indefinitely."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "gRPC's server-side streaming makes it a natural fit for LLM token delivery in service-to-service architectures. Define the contract in "
              },
              {
                "type": "text",
                "text": "chat.proto",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": ", implement the servicer with a "
              },
              {
                "type": "text",
                "text": "yield",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " loop over the Anthropic SDK's "
              },
              {
                "type": "text",
                "text": "text_stream",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": ", and attach auth and rate-limiting as interceptors. Add TLS before any external exposure and use grpcurl for quick CLI testing."
              }
            ]
          }
        ]
      }
    ]
  }
