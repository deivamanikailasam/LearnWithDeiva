bold"}],"text":"context vector"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Context vector"},{"type":"text","text":" is a fixed-length numerical summary representing the entire input"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Decoder"},{"type":"text","text":" takes context vector and generates output sequence one token at a time"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Handles "},{"type":"text","marks":[{"type":"bold"}],"text":"variable input-output lengths"},{"type":"text","text":" (3 words → 5 words, long article → short summary)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Attention mechanism"},{"type":"text","text":" revolutionized the architecture by allowing decoder to look back at specific input words"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Powers "},{"type":"text","marks":[{"type":"bold"}],"text":"translation apps, text summarizers, chatbots, question answering"},{"type":"text","text":", and code generation"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Modern versions use "},{"type":"text","marks":[{"type":"bold"}],"text":"Transformers"},{"type":"text","text":" instead of RNNs for parallel processing and better performance"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"The encoder-decoder architecture is the engine behind translation, summarization, and many other generative tasks, especially when enhanced with attention mechanisms."}]}]}}
