{"format":"tiptap/v1","updatedAt":"2026-06-22T12:00:54.417Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What Queries, Keys, and Values Are"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Queries, Keys, and Values (Q, K, V)"},{"type":"text","text":" are the three learned vector representations that make attention work in Transformer models. They let the model decide "},{"type":"text","marks":[{"type":"bold"}],"text":"what to look for"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"bold"}],"text":"what each token offers"},{"type":"text","text":", and "},{"type":"text","marks":[{"type":"bold"}],"text":"what information to pass along"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","text":"A simple way to remember them is: "},{"type":"text","marks":[{"type":"bold"}],"text":"Query = ask"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"bold"}],"text":"Key = match"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"bold"}],"text":"Value = carry the content"},{"type":"text","text":"."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why They Matter"}]},{"type":"paragraph","content":[{"type":"text","text":"Q, K, and V are what allow attention to be "},{"type":"text","marks":[{"type":"bold"}],"text":"selective"},{"type":"text","text":" instead of treating every token equally. This is why Transformers can focus on the most relevant words in a sentence, even when they are far apart."}]},{"type":"paragraph","content":[{"type":"text","text":"They are central to:\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Self-attention"},{"type":"text","text":", where tokens attend to other tokens in the same sequence. "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://d2l.ai/chapter_attention-mechanisms-and-transformers/queries-keys-values.html","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"d2l"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Cross-attention"},{"type":"text","text":", where a decoder attends to encoder outputs.\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Multi-head attention"},{"type":"text","text":", where several attention patterns are learned in parallel."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What Each One Does"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Component"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Meaning"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Role"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Query (Q)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"“What am I looking for?”"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Represents the current token’s search request."}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Key (K)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"“What do I contain?”"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Represents what each token can match against."}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Value (V)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"“What information do I provide?”"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Holds the content that gets combined if the match is strong."}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"The model compares a "},{"type":"text","marks":[{"type":"bold"}],"text":"query"},{"type":"text","text":" to all "},{"type":"text","marks":[{"type":"bold"}],"text":"keys"},{"type":"text","text":" to compute relevance scores, then uses those scores to blend the "},{"type":"text","marks":[{"type":"bold"}],"text":"values"},{"type":"text","text":" into a new contextual representation."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How They Are Created"}]},{"type":"paragraph","content":[{"type":"text","text":"Each input token starts as an embedding, then the model applies three learned linear transformations to produce Q, K, and V. In other words, the same token can play three different roles depending on which projection is used."}]},{"type":"paragraph","content":[{"type":"text","text":"A compact view is:"}]},{"type":"blockMath","attrs":{"latex":"Q = XW_Q,\\quad K = XW_K,\\quad V = XW_V"}},{"type":"paragraph","content":[{"type":"text","text":"where "},{"type":"inlineMath","attrs":{"latex":"X"}},{"type":"text","text":" is the input embedding matrix and "},{"type":"inlineMath","attrs":{"latex":"W_Q, W_K, W_V"}},{"type":"text","text":" are learned weights."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How They Work Together"}]},{"type":"paragraph","content":[{"type":"text","text":"The workflow is:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Turn input tokens into embeddings."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Project embeddings into Q, K, and V spaces."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Compare Q with K using dot products to get attention scores."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Scale and normalize those scores."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use the scores to take a weighted sum of V. "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://d2l.ai/chapter_attention-mechanisms-and-transformers/queries-keys-values.html","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"d2l"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"So the "},{"type":"text","marks":[{"type":"bold"}],"text":"key"},{"type":"text","text":" decides whether a token is relevant to a query, while the "},{"type":"text","marks":[{"type":"bold"}],"text":"value"},{"type":"text","text":" is the actual information that gets passed through if it is relevant."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Self-Attention Example"}]},{"type":"paragraph","content":[{"type":"text","text":"In self-attention, every token can look at every other token in the same sentence. For example, in “The animal didn’t cross because it was tired,” the token "},{"type":"text","marks":[{"type":"bold"}],"text":"“it”"},{"type":"text","text":" can attend to "},{"type":"text","marks":[{"type":"bold"}],"text":"“animal”"},{"type":"text","text":" because the query for “it” matches the key for “animal” more strongly than other keys."}]},{"type":"paragraph","content":[{"type":"text","text":"That lets the model build context-sensitive meanings rather than relying on fixed word embeddings."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Cross-Attention Example"}]},{"type":"paragraph","content":[{"type":"text","text":"In encoder-decoder models, the decoder uses its own queries to search over encoder-produced keys and values. This is useful in translation, where the decoder must decide which source-language words matter most for the next target-language token."}]},{"type":"paragraph","content":[{"type":"text","text":"So:\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Decoder Query"},{"type":"text","text":" = what the decoder needs right now.\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Encoder Keys"},{"type":"text","text":" = what each source token offers.\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Encoder Values"},{"type":"text","text":" = the source information passed to the decoder."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Multi-Head Attention Connection"}]},{"type":"paragraph","content":[{"type":"text","text":"Multi-head attention runs this Q/K/V process several times in parallel with different learned projections. Each head can focus on a different relationship, such as syntax, coreference, or long-range context."}]},{"type":"paragraph","content":[{"type":"text","text":"This is one reason Transformers are so effective: they do not rely on a single notion of relevance, but multiple ones at once."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of Q, K, and V like a "},{"type":"text","marks":[{"type":"bold"}],"text":"library search"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Query"},{"type":"text","text":" = the search terms you type in.\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Key"},{"type":"text","text":" = the catalog labels on each book.\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Value"},{"type":"text","text":" = the actual book content you retrieve."}]},{"type":"paragraph","content":[{"type":"text","text":"The system first checks which books match the search terms, then pulls the useful content from the best matches."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Query"},{"type":"text","text":" asks what the model is looking for."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key"},{"type":"text","text":" describes what each token matches against."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Value"},{"type":"text","text":" contains the information that gets combined into the output."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Q, K, and V are created by learned linear projections of token embeddings."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Attention uses "},{"type":"text","marks":[{"type":"bold"}],"text":"Q against K"},{"type":"text","text":" to compute relevance, then applies those weights to "},{"type":"text","marks":[{"type":"bold"}],"text":"V"},{"type":"text","text":". "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://d2l.ai/chapter_attention-mechanisms-and-transformers/queries-keys-values.html","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"d2l"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"This mechanism powers "},{"type":"text","marks":[{"type":"bold"}],"text":"self-attention, cross-attention, and multi-head attention"},{"type":"text","text":"."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Q/K/V let Transformers model long-range context efficiently and flexibly."}]}]}]},{"type":"paragraph"}]}}
