"paragraph", "content": [{"type": "text", "text": "Names meaningful."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Logic sound, optimized."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "No debug logs, TODOs, unused code."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Tests added/updated and passing."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Build and linting pass."}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Submit as "}, {"type": "text", "marks": [{"type": "bold"}], "text": "draft"}, {"type": "text", "text": " while polishing; mark "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Ready for Review"}, {"type": "text", "text": " only when satisfied."}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Automated Checks"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Ensure:"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "All unit/integration tests pass."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Code coverage doesn’t drop significantly."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Linting and static analysis succeed."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "CI builds pass before requesting review."}]}]}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "8. Examples"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Small Feature PR"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Title: "}, {"type": "text", "marks": [{"type": "code"}], "text": "Add user profile page with avatar"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Description:"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "- Purpose: Allow users to view/edit their profile. - Changes: - New "}, {"type": "text", "marks": [{"type": "code"}], "text": "UserProfile"}, {"type": "text", "text": " component (TypeScript). - New "}, {"type": "text", "marks": [{"type": "code"}], "text": "/api/user/profile"}, {"type": "text", "text": " endpoint (Go). - Updated tests for endpoint and component. - How to test: - Run "}, {"type": "text", "marks": [{"type": "code"}], "text": "go test./api/..."}, {"type": "text", "text": " - Run "}, {"type": "text", "marks": [{"type": "code"}], "text": "npm test src/components/UserProfile"}, {"type": "text", "text": " - Navigate to "}, {"type": "text", "marks": [{"type": "code"}], "text": "/profile"}, {"type": "text", "text": " in browser. - Ticket: "}, {"type": "text", "marks": [{"type": "code"}], "text": "JIRA-1234"}, {"type": "text", "text": " - Screenshots: attached profile page."}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Bug Fix PR"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Title: "}, {"type": "text", "marks": [{"type": "code"}], "text": "Fix timeout on retry for payment API"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Description:"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "- Purpose: Payments fail after 2s timeout on retry. - Changes: - Increased retry timeout from 2s → 5s. - Added retry logic test. - How to test: - Run integration test "}, {"type": "text", "marks": [{"type": "code"}], "text": "PaymentRetryTest"}, {"type": "text", "text": ". - Simulate slow payment provider. - Ticket: "}, {"type": "text", "marks": [{"type": "code"}], "text": "JIRA-1235"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "9. Real-World Example (Cloud-Native Team)"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "A distributed systems team:"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Policy"}, {"type": "text", "text": ":"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "- All changes to "}, {"type": "text", "marks": [{"type": "code"}], "text": "main"}, {"type": "text", "text": " via PR. - 1–2 approvals + CI required.\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "PRs"}, {"type": "text", "text": ": - Small, focused (< 400 lines). - Draft while working; ready when tests pass.\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Reviews"}, {"type": "text", "text": ": - Focus on correctness under concurrency, latency, memory. - Check auth, secrets, input validation. - Review tests as seriously as code.\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Tooling"}, {"type": "text", "text": ": - GitHub PRs + reviews. - GitHub Actions CI on PRs. - Protected "}, {"type": "text", "marks": [{"type": "code"}], "text": "main"}, {"type": "text", "text": " with PR requirements."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "10. Common Mistakes"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Large PRs"}, {"type": "text", "text": ": hard to review, easy to miss bugs."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "No description"}, {"type": "text", "text": ": reviewers don’t understand context."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "No tests"}, {"type": "text", "text": ": reviewer becomes QA, not collaborator."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Ignoring CI"}, {"type": "text", "text": ": submitting PRs with failing builds/tests."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Mixing unrelated changes"}, {"type": "text", "text": ": feature + refactor + formatting."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Leaving PRs open"}, {"type": "text", "text": ": no follow-up, stale reviews."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Rubber-stamp reviews"}, {"type": "text", "text": ": approving without reading."}]}]}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "11. Best Practices"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "For Authors"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Keep PRs "}, {"type": "text", "marks": [{"type": "bold"}], "text": "small and focused"}, {"type": "text", "text": "."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Write "}, {"type": "text", "marks": [{"type": "bold"}], "text": "clear titles and descriptions"}, {"type": "text", "text": "."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Perform "}, {"type": "text", "marks": [{"type": "bold"}], "text": "self-review"}, {"type": "text", "text": " before requesting review."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Submit as "}, {"type": "text", "marks": [{"type": "bold"}], "text": "draft"}, {"type": "text", "text": " while polishing."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Ensure "}, {"type": "text", "marks": [{"type": "bold"}], "text": "tests and build pass"}, {"type": "text", "text": "."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Include "}, {"type": "text", "marks": [{"type": "bold"}], "text": "tests"}, {"type": "text", "text": " for all new logic."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Clean up:"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "- Remove unused code. - Squash WIP commits if needed. - Remove debug logs, TODOs."}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "For Reviewers"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Be "}, {"type": "text", "marks": [{"type": "bold"}], "text": "constructive and non-confrontational"}, {"type": "text", "text": "."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Focus on:"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "- Robustness, correctness, security. - Design, performance, tests.\n- Avoid: - Nitpicking style on every line. - Pursuing “perfect” implementation everywhere.\n- Suggest edits when helpful.\n- Approve when concerns are addressed."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "12. Performance & Scalability"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Small PRs scale better:"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "- Faster reviews. - Less conflict risk. - Higher throughput.\n- Large PRs become bottlenecks: - Hard to review deeply. - Reviewers skim; bugs slip through."}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Set team expectations:\n- Max lines per PR.\n- Max open PRs per person.\n- Review SLA (e.g., respond within 24h)."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "13. Tooling & Ecosystem"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Platforms"}, {"type": "text", "text": ": GitHub, GitLab, Bitbucket."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "PR templates"}, {"type": "text", "text": ": enforce structure (Description, Tests, Links, etc.)."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "CI"}, {"type": "text", "text": ": GitHub Actions, GitLab CI, Jenkins."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Code owners"}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "code"}], "text": "CODEOWNERS"}, {"type": "text", "text": " to auto-assign reviewers."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Draft PRs"}, {"type": "text", "text": ": for WIP; mark ready when polished."}]}]}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "14. Comparison with Alternatives"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Approach"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Pros"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Cons"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Direct "}, {"type": "text", "marks": [{"type": "code"}], "text": "main"}, {"type": "text", "text": " commits"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Fast, simple"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "No review, high risk, noisy history"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "PR + Code Review"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Safe, reviewable, traceable"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Slightly slower, needs discipline"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "For full-stack, cloud-native, distributed systems work, "}, {"type": "text", "marks": [{"type": "bold"}], "text": "PR + code review"}, {"type": "text", "text": " is the standard."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "15. Security & Reliability"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "PRs prevent unreviewed changes to "}, {"type": "text", "marks": [{"type": "code"}], "text": "main"}, {"type": "text", "text": "."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Require:"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "- Approvals. - Passing CI. - Protected "}, {"type": "text", "marks": [{"type": "code"}], "text": "main"}, {"type": "text", "text": " (no direct writes).\n- Review for: - Auth / authz bugs. - Secret handling. - Input validation. - Concurrency and resource leaks."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "PR Template (Copy-Paste)"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "You can adapt this for your team:"}]}, {"type": "codeBlock", "attrs": {"language": "markdown"}, "content": [{"type": "text", "text": "## Description\n<!-- What does this PR do? Why is it needed? -->\n\n## Changes\n<!-- List of key changes -->\n- Added: ...\n- Modified: ...\n- Removed: ...\n\n## Related Issue\n<!-- Link to ticket -->\nFixes #<issue-number>\nJIRA-<ticket-id>\n\n## How to Test\n<!-- Steps to verify changes -->\n1. ...\n2. ...\n3. ...\n\n## Tests\n<!-- What tests did you run? -->\n- [ ] Unit test\n- [ ] Integration test\n- [ ] End-to-end test\n- [ ] System test\n\n## Screenshots / Logs\n<!-- For UI or output changes -->\n- [ ] Attached screenshots\n- [ ] Attached logs\n\n## Review Guidance\n<!-- How should reviewers approach this PR? -->\n- Start with: ...\n- Review order: ...\n\n## Checklist\n- [ ] Code conforms to coding conventions\n- [ ] Build passes without errors/warnings\n- [ ] All tests pass\n- [ ] Documentation updated\n- [ ] No debug logs or unused code"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Commit Message Guidelines"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Structure"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Short subject"}, {"type": "text", "text": " (≤ 50 chars):"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "- Format: "}, {"type": "text", "marks": [{"type": "code"}], "text": "<type>: <what>"}, {"type": "text", "text": " - Example: "}, {"type": "text", "marks": [{"type": "code"}], "text": "feat: add JWT login endpoint"}, {"type": "text", "text": " - Example: "}, {"type": "text", "marks": [{"type": "code"}], "text": "fix: increase retry timeout for payment API"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Body"}, {"type": "text", "text": " (optional, but useful):"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "- Why this change is needed. - What changed. - Trade-offs, assumptions, concerns. - How to test."}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Types"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "feat"}, {"type": "text", "text": ": new feature"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "fix"}, {"type": "text", "text": ": bug fix"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "docs"}, {"type": "text", "text": ": documentation only"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "refactor"}, {"type": "text", "text": ": code restructuring without behavior change"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "test"}, {"type": "text", "text": ": tests only"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "chore"}, {"type": "text", "text": ": maintenance, tooling, deps"}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Examples"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Good:"}]}, {"type": "codeBlock", "attrs": {"language": "yaml"}, "content": [{"type": "text", "text": "feat: add user profile endpoint with JWT auth\n\n- Add /api/user/profile endpoint (Go)\n- Validate JWT token and refresh\n- Add unit + integration tests\n\nHow to test:\n- go test ./api/user\n- Call endpoint with valid JWT"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Bad:"}]}, {"type": "codeBlock", "attrs": {"language": "text"}, "content": [{"type": "text", "text": "fix"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "or"}]}, {"type": "codeBlock", "attrs": {"language": "text"}, "content": [{"type": "text", "text": "stuff\nWIP"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Key Takeaways"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "PRs are "}, {"type": "text", "marks": [{"type": "bold"}], "text": "structured proposals"}, {"type": "text", "text": " to merge changes, with context and discussion."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Code review is a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "collaborative quality gate"}, {"type": "text", "text": ", not QA."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Keep PRs "}, {"type": "text", "marks": [{"type": "bold"}], "text": "small, focused, and testable"}, {"type": "text", "text": "."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Write "}, {"type": "text", "marks": [{"type": "bold"}], "text": "clear titles and descriptions"}, {"type": "text", "text": "; include tests and links."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Do a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "self-review"}, {"type": "text", "text": " before requesting review."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Reviewers should be "}, {"type": "text", "marks": [{"type": "bold"}], "text": "constructive"}, {"type": "text", "text": ", specific, and focused on robustness."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use "}, {"type": "text", "marks": [{"type": "bold"}], "text": "PR templates"}, {"type": "text", "text": " and "}, {"type": "text", "marks": [{"type": "bold"}], "text": "commit message conventions"}, {"type": "text", "text": " to standardize."}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "If you’d like, I can tailor this PR template and commit guidelines specifically to your Go + TypeScript cloud-native stack (e.g., with Go test commands, TypeScript test commands, and example sections)."}]}]}}