 "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Team policy; often still PR for visibility"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Prototypes / local experiments"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "❌ No"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Speed over review; no production impact"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "In professional teams, "}, {"type": "text", "marks": [{"type": "bold"}], "text": "all changes to "}, {"type": "text", "marks": [{"type": "bold"}, {"type": "code"}], "text": "main"}, {"type": "text", "marks": [{"type": "bold"}], "text": " should go through a PR"}, {"type": "text", "text": "."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "7. How to Implement (Practical Rules)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "PR Size & Focus"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Keep PRs "}, {"type": "text", "marks": [{"type": "bold"}], "text": "small and focused"}, {"type": "text", "text": ":"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "- Ideally "}, {"type": "text", "marks": [{"type": "bold"}], "text": "< 400 lines"}, {"type": "text", "text": " of code changed (excluding auto-generated files). - Preferably "}, {"type": "text", "marks": [{"type": "bold"}], "text": "< 10 files"}, {"type": "text", "text": ".\n- Follow "}, {"type": "text", "marks": [{"