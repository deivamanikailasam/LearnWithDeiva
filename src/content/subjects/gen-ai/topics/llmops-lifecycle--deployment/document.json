        "content": [
          {
            "type": "text",
            "text": "# Example: read config from environment / AWS AppConfig / LaunchDarkly\nimport os, json\n\nclass ConfigStore:\n    \"\"\"\n    Minimal config store backed by environment variables.\n    In production: replace with AWS AppConfig, GCP Runtime Config, or LaunchDarkly.\n    \"\"\"\n    def __init__(self):\n        raw = os.environ.get(\"LLMOPS_CONFIG\", \"{}\")\n        self._config = json.loads(raw)\n\n    def get(self, key: str, default=None):\n        return self._config.get(key, default)\n\n    def model_pin(self, env: str = \"production\") -> str:\n        return self.get(f\"model_pin.{env}\", \"claude-haiku-4-5-20251001\")\n\n    def canary_pct(self) -> float:\n        return float(self.get(\"canary_pct\", \"0.0\"))\n\n    def prompt_version(self, name: str) -> str:\n        return self.get(f\"prompt_version.{name}\", \"v1\")\n\n# Application startup\nconfig = ConfigStore()\nprint(config.model_pin(\"production\"))  # claude-haiku-4-5-20251001\nprint(config.canary_pct())             # 0.05\nprint(config.prompt_version(\"support-assistant\"))  # v3\n"
          }
        ]
