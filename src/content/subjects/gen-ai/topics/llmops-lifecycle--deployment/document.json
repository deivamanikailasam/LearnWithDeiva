          {
            "type": "text",
            "text": "The Gateway / Router Layer"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Every production LLM deployment should have a gateway in front of the model calls. The gateway handles cross-cutting concerns so application code stays clean:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Authentication and authorisation",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": ": verify API keys, JWTs, or session tokens; enforce per-user or per-team quotas."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Rate limiting",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": ": protect the upstream LLM API from traffic spikes; enforce per-client token budgets."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Model routing",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": ": select the cheapest model that meets the quality bar for the request class; fall back to a more capable model on retries."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Canary splitting",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": ": route a configurable percentage of traffic to the candidate model version; read the split from the config store so it can be changed without redeployment."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Request/response logging",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": ": capture trace metadata at a single point rather than scattering log calls across the codebase."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import random, time, anthropic\nfrom dataclasses import dataclass\nfrom enum import Enum\n\nclass ModelTier(Enum):\n    FAST   = \"fast\"    # lowest cost; good for simple tasks\n    SMART  = \"smart\"   # higher cost; complex reasoning\n    EXPERT = \"expert\"  # highest cost; most capable\n\nMODEL_MAP = {\n    ModelTier.FAST:   \"claude-haiku-4-5-20251001\",\n    ModelTier.SMART:  \"claude-sonnet-4-6\",\n    ModelTier.EXPERT: \"claude-opus-4-8\",\n}\n\n@dataclass\nclass RoutingConfig:\n    default_tier: ModelTier\n    canary_model: str | None\n    canary_pct: float          # 0.0\u20131.0\n    max_tokens_per_minute: int\n\nclass LLMGateway:\n    def __init__(self, config: RoutingConfig):\n        self.config = config\n        self._client = anthropic.Anthropic()\n        self._token_counter = 0\n        self._window_start  = time.time()\n\n    def _check_rate_limit(self, estimated_tokens: int):\n        now = time.time()\n        if now - self._window_start > 60:\n            self._token_counter = 0\n            self._window_start  = now\n        if self._token_counter + estimated_tokens > self.config.max_tokens_per_minute:\n            raise RuntimeError(\"Rate limit exceeded\")\n        self._token_counter += estimated_tokens\n\n    def _select_model(self, tier: ModelTier) -> str:\n        if (self.config.canary_model and\n                random.random() < self.config.canary_pct):\n            return self.config.canary_model\n        return MODEL_MAP[tier]\n\n    def complete(self, system: str, user: str,\n                 tier: ModelTier = ModelTier.FAST,\n                 max_tokens: int = 512) -> dict:\n        self._check_rate_limit(estimated_tokens=max_tokens)\n        model = self._select_model(tier)\n        t0    = time.perf_counter()\n        resp  = self._client.messages.create(\n            model=model, max_tokens=max_tokens,\n            system=system,\n            messages=[{\"role\": \"user\", \"content\": user}],\n        )\n        latency_ms = (time.perf_counter() - t0) * 1000\n        return {\n            \"text\":        resp.content[0].text,\n            \"model\":       resp.model,\n            \"input_tok\":   resp.usage.input_tokens,\n            \"output_tok\":  resp.usage.output_tokens,\n            \"latency_ms\":  round(latency_ms, 1),\n        }\n\nconfig = RoutingConfig(\n    default_tier=ModelTier.FAST,\n    canary_model=\"claude-sonnet-4-6\",\n    canary_pct=0.05,\n    max_tokens_per_minute=200_000,\n)\ngateway = LLMGateway(config)\n"
          }
        ]
      },
