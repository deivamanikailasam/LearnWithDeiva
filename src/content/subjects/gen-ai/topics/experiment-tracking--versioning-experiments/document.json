":"text","text":" for each evaluation experiment"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Associating each experiment run with the "},{"type":"text","marks":[{"type":"bold"}],"text":"exact codebase state"},{"type":"text","text":" that produced it"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Procedure: version an experiment"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"procedure version_experiment(experiment_name, commit_message, repo_path, create_branch, stage_all):\n  1. Locate Git repo\n  2. Stage changes (if any)\n  3. Create commit with experiment name\n  4. Create branch: ragas/{experiment_name}\n  5. Return commit hash as version identifier"}]},{"type":"paragraph","content":[{"type":"text","text":"This creates a "},{"type":"text","marks":[{"type":"bold"}],"text":"reproducibility key"},{"type":"text","text":" (commit hash) linked to the experiment name."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Model versioning vs. experiment versioning"}]},{"type":"paragraph","content":[{"type":"text","text":"These are related but distinct:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Model Versioning"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Experiment Versioning"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"