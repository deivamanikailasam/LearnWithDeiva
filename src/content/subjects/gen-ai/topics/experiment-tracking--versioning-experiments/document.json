ode"}],"text":"w"},{"type":"text","text":" (hyperparameters, tweaks)"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Version: "},{"type":"text","marks":[{"type":"code"}],"text":"x.y.z.w"},{"type":"text","text":" (e.g., "},{"type":"text","marks":[{"type":"code"}],"text":"1.2.3.1"},{"type":"text","text":")"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Treat experiments as code"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Store metrics, parameters, and artifacts in "},{"type":"text","marks":[{"type":"bold"}],"text":"text files"},{"type":"text","text":" that can be versioned"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use Git for code, DVC for data and pipeline "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://dvc.org/blog/ml-experiment-versioning/","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"dvc"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Automate logging"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Use automated logging to capture metadata in real time"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Reduce manual effort and risk of oversight"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Use atomic runs"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Each experiment run should capture:"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- Source code - Configuration - Upstream requirements (datasets) - Generated output\n- All in a "},{"type":"text","marks":[{"type":"bold"}],"text":"single place"},{"type":"text","text":", not scattered across systems"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Experiment versioning"},{"type":"text","text":" treats experiments as code by snapshotting code, data, pipeline, parameters, and metrics so you can reproduce and restore any experiment with a single command."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Unlike "},{"type":"text","marks":[{"type":"bold"}],"text":"tracking-only"},{"type":"text","text":" (dashboards), versioning ensures experiment logs are "},{"type":"text","marks":[{"type":"bold"}],"text":"always connected"},{"type":"text","text":" to the exact data, code, and pipeline that produced them."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"DVC"},{"type":"text","text":" is the main tool for experiment versioning, enabling:"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- "},{"type":"text","marks":[{"type":"code"}],"text":"dvc exp init"},{"type":"text","text":" to structure projects - "},{"type":"text","marks":[{"type":"code"}],"text":"dvc exp run"},{"type":"text","text":" to run experiments - "},{"type":"text","marks":[{"type":"code"}],"text":"dvc exp restore"},{"type":"text","text":" to reproduce past experiments\n- For LLM evaluation, experiment versioning creates "},{"type":"text","marks":[{"type":"bold"}],"text":"Git snapshots"},{"type":"text","text":" linked to commit hashes as reproducibility keys.\n- Best practices: use meaningful version naming, automate logging, and treat each experiment as an atomic unit capturing code, data, config, and output."}]}]}}
