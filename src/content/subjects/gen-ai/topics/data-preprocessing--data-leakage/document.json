{"format": "tiptap/v1", "updatedAt": "2026-06-22T04:14:38.068Z", "doc": {"type": "doc", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Data Leakage"}, {"type": "text", "text": " (also called "}, {"type": "text", "marks": [{"type": "bold"}], "text": "target leakage"}, {"type": "text", "text": " or "}, {"type": "text", "marks": [{"type": "bold"}], "text": "information leakage"}, {"type": "text", "text": ") is when a machine learning model uses information during training that "}, {"type": "text", "marks": [{"type": "bold"}], "text": "would not be available at prediction time"}, {"type": "text", "text": " — this results in overly optimistic performance estimates where the model appears to perform better during evaluation than it actually would in a real production environment.)"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "What It Is"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Core definition"}, {"type": "text", "text": ":\n- Model learns information that "}, {"type": "text", "marks": [{"type": "bold"}], "text": "won't exist when making future predictions"}, {"type": "text", "text": "\n- Creates "}, {"type": "text", "marks": [{"type": "bold"}], "text": "false confidence"}, {"type": "text", "text": " in model performance\n- Leakage is often "}, {"type": "text", "marks": [{"type": "bold"}], "text": "subtle and indirect"}, {"type": "text", "text": ", making it difficult to detect and eliminate)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Main problem"}, {"type": "text", "text": ":\n- Part of \"unseen\" test data has already been \"seen\" by the model during training\n- Researchers can't tell if predictions are "}, {"type": "text", "marks": [{"type": "bold"}], "text": "real predictions"}, {"type": "text", "text": " or just "}, {"type": "text", "marks": [{"type": "bold"}], "text": "recognition of information already analyzed"}, {"type": "text", "text": "\n- Results in "}, {"type": "text", "marks": [{"type": "bold"}], "text": "artificially inflated performance"}, {"type": "text", "text": " that doesn't generalize to truly unseen data"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Visual example"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "yaml"}, "content": [{"type": "text", "text": "Training: Model sees zipcode + future income → predicts income perfectly\nTesting: Model only sees zipcode → can't predict income\nReal world: Model fails because it learned from information not available at prediction"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Types of Data Leakage"}]}, {"type": "image", "attrs": {"src": "data:image/svg+xml;base64,", "alt": "Data Leakage — concept overview"}}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "1. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Target Leakage"}, {"type": "text", "text": " (Column-wise Leakage)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "What it is"}, {"type": "text", "text": ": Features include "}, {"type": "text", "marks": [{"type": "bold"}], "text": "the target variable itself"}, {"type": "text", "text": ", a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "proxy for the label"}, {"type": "text", "text": ", or "}, {"type": "text", "marks": [{"type": "bold"}], "text": "future information"}, {"type": "text", "text": " that wouldn't exist at prediction time."}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Also called"}, {"type": "text", "text": ": Anachronisms (features that won't be available when model is used))"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Examples"}, {"type": "text", "text": ":"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Scenario"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Problem"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Predicting loan default"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Feature includes \"loan was defaulted\" (this is the target!))"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Predicting disease"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Feature includes \"patient was diagnosed with disease\" (future information)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Predicting churn"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Feature includes \"customer already churned\" (target variable)"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Why it's bad"}, {"type": "text", "text": ": The model cheats by seeing the answer during training.)"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "2. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Preprocessing Leakage"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "What it is"}, {"type": "text", "text": ": Occurs during data preprocessing steps like "}, {"type": "text", "marks": [{"type": "bold"}], "text": "scaling, imputation, outlier treatment, and handling multicollinearity"}, {"type": "text", "text": " when information from test set leaks into training set."}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Common causes"}, {"type": "text", "text": ":"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Preprocessing Step"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Leakage Risk"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Scaling/Normalization"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Fitting scaler on entire dataset (train + test) instead of just training data"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Missing Value Imputation"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Computing mean/median from entire dataset including test"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Outlier Treatment"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Detecting outliers using test data statistics"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Feature Selection"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Selecting features based on entire dataset instead of training only"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Example"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# WRONG - Preprocessing leakage!\nfrom sklearn.preprocessing import StandardScaler\n\n# Fitting scaler on entire dataset (train + test)\nscaler = StandardScaler()\nX_scaled = scaler.fit_transform(X_all)  # X_all includes test data!"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Correct approach"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# CORRECT - No leakage\nfrom sklearn.preprocessing import StandardScaler\n\n# Split first\nX_train, X_test, y_train, y_test = train_test_split(X, y)\n\n# Fit scaler ONLY on training data\nscaler = StandardScaler()\nX_train_scaled = scaler.fit_transform(X_train)\n\n# Apply same scaler to test data (no fitting!)\nX_test_scaled = scaler.transform(X_test)"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "3. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Temporal Leakage"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "What it is"}, {"type": "text", "text": ": Using "}, {"type": "text", "marks": [{"type": "bold"}], "text": "future information"}, {"type": "text", "text": " to predict present or past events — time-based leakage where data from after the prediction time is used."}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Examples"}, {"type": "text", "text": ":"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Scenario"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Problem"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Predicting stock price on Jan 1"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Using stock price data from Jan 2 (future)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Predicting disease outbreak (2020)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Using data from 2021 (future)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Predicting customer behavior (2023)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Using data from 2024 (future)"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Why it's bad"}, {"type": "text", "text": ": Impossible in real world — you can't use future to predict past."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "4. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Repeated Subject Leakage"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "What it is"}, {"type": "text", "text": ": Data from an "}, {"type": "text", "marks": [{"type": "bold"}], "text": "individual appears in both training and testing sets"}, {"type": "text", "text": "."}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Example"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "text"}, "content": [{"type": "text", "text": "Training set: Patient A (rows 1, 2, 3)\nTest set: Patient A (row 4) ← Same person!"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Problem"}, {"type": "text", "text": ": Model recognizes Patient A's data patterns rather than learning generalizable features."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "5. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Feature Selection Leakage"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "What it is"}, {"type": "text", "text": ": Selecting brain areas/features from "}, {"type": "text", "marks": [{"type": "bold"}], "text": "entire pool of data"}, {"type": "text", "text": " rather than from "}, {"type": "text", "marks": [{"type": "bold"}], "text": "training data only"}, {"type": "text", "text": "."}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Example"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "yaml"}, "content": [{"type": "text", "text": "WRONG: Select top 10 features based on entire dataset (train + test)\nCORRECT: Select top 10 features based on training data only"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Problem"}, {"type": "text", "text": ": Test data influences which features are selected, inflating performance."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Effects of Data Leakage"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Effect"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Description"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": 