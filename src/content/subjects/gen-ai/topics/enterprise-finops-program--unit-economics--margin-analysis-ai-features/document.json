                        "type": "bold"
                      }
                    ],
                    "text": "Model downgrade for low-complexity turns"
                  },
                  {
                    "type": "text",
                    "text": ": Route FAQ-style queries to a cheaper model. Even 50% of traffic on a 10\u00d7 cheaper model improves LLM ratio by ~45%."
                  }
                ]
              }
