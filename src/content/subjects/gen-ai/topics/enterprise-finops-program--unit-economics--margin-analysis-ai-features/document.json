                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Response caching"
                  },
                  {
                    "type": "text",
                    "text": ": Identical or near-identical prompts (e.g. onboarding flows) can be cached. Cache hit rate of 20% reduces LLM cost by 20%."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Context window pruning"
                  },
                  {
                    "type": "text",
                    "text": ": Cap conversation history at the last N turns. Each removed turn eliminates its tokens from every subsequent API call."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Prompt compression"
                  },
                  {
                    "type": "text",
