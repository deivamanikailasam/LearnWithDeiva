                  },
                  {
                    "type": "text",
                    "text": ": deduplicate, scrub PII, remove credentials from training corpora before training or fine-tuning."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Differential privacy",
                    "marks": [
