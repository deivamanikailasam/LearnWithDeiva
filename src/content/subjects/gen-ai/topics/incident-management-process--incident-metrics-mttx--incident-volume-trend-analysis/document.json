        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Automating the Monthly Report"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Generate the monthly incident volume report automatically\n# Runs as a scheduled job and posts to Slack #engineering-reliability\n\nimport datetime\n\ndef generate_monthly_report(incident_db, request_metrics_db):\n    now = datetime.datetime.utcnow()\n    this_month = now.replace(day=1)\n    last_month = (this_month - datetime.timedelta(days=1)).replace(day=1)\n\n    current = incident_db.query(\n        start=this_month,\n        end=now,\n    )\n    prior = incident_db.query(\n        start=last_month,\n        end=this_month,\n    )\n\n    def by_sev(incidents):\n        counts = {\"SEV-1\": 0, \"SEV-2\": 0, \"SEV-3\": 0}\n        for i in incidents:\n            counts[i[\"severity\"]] = counts.get(i[\"severity\"], 0) + 1\n        return counts\n\n    curr_by_sev = by_sev(current)\n    prev_by_sev = by_sev(prior)\n\n    def delta(curr, prev):\n        if prev == 0:\n            return \"N/A\"\n        pct = (curr - prev) / prev * 100\n        return f\"{pct:+.0f}%\"\n\n    lines = [\n        f\"*Incident Volume Report -- {now.strftime('%B %Y')}*\",\n        \"\",\n        \"*Volume (vs prior month):*\",\n    ]\n    for sev in [\"SEV-1\", \"SEV-2\", \"SEV-3\"]:\n        c, p = curr_by_sev[sev], prev_by_sev[sev]\n        lines.append(f\"  {sev}: {c} ({delta(c, p)})\")\n\n    total_c = sum(curr_by_sev.values())\n    total_p = sum(prev_by_sev.values())\n    lines.append(f\"  Total: {total_c} ({delta(total_c, total_p)})\")\n\n    return \"\\n\".join(lines)"
          }
        ]
