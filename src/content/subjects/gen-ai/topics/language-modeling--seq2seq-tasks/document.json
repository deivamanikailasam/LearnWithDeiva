            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "marks": [
                          {
                            "type": "bold"
                          }
                        ],
                        "text": "Encoder-decoder"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Full encoder + causal decoder with cross-attention"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Translation, summarisation, QA"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "T5, BART, mBART, Whisper"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Modern large language models are increasingly decoder-only even for seq2seq tasks — the source is prepended to the prompt and the model generates the target as a continuation. This works well in practice but loses the bidirectional encoding of the source that a true encoder-decoder model provides."
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Evaluating Seq2Seq Output"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "BLEU"
                  },
                  {
                    "type": "text",
                    "text": " — measures n-gram overlap between generated and reference translations. Standard for machine translation but known to correlate poorly with human judgement at the sentence level."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "ROUGE"
                  },
                  {
                    "type": "text",
                    "text": " (Recall-Oriented Understudy for Gisting Evaluation) — measures recall of n-grams from the reference in the generated output. Standard for summarisation (ROUGE-1, ROUGE-2, ROUGE-L)."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "BERTScore"
                  },
                  {
                    "type": "text",
                    "text": " — compares contextual embeddings of generated and reference tokens using cosine similarity. More robust to paraphrases than n-gram metrics."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from evaluate import load\n\nbleu = load(\"bleu\")\nrouge = load(\"rouge\")\n\npredictions = [\"The cat sleeps on the rug.\"]\nreferences  = [[\"The cat is sleeping on the mat.\"]]\n\nprint(bleu.compute(predictions=predictions, references=references))\n# {'bleu': 0.356, ...}\n\nprint(rouge.compute(predictions=predictions, references=[\"The cat is sleeping on the mat.\"]))\n# {'rouge1': 0.727, 'rouge2': 0.5, 'rougeL': 0.727, ...}"
          }
        ]
      }
    ]
  }
}
