:{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Filter, Wrapper, Embedded"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"PCA, LDA, Autoencoders"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Interpretability"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Enhances interpretability"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"May introduce redundancy"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Three main types of feature selection methods"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Filter Methods"}]},{"type":"paragraph","content":[{"type":"text","text":"Use "},{"type":"text","marks":[{"type":"bold"}],"text":"statistical techniques to score each feature independently"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How it works"},{"type":"text","text":":\n- Score each feature based on statistical relationship with target\n- Select top-N features or features above threshold\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Does not depend on model"},{"type":"text","text":" (independent)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Common techniques"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Correlation Coefficient"},{"type":"text","text":": Measures linear relationship with target\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Chi-Square Test"},{"type":"text","text":": Tests independence between feature and target\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"ANOVA"},{"type":"text","text":": Tests variance differences across groups"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pros"},{"type":"text","text":":\n- Fast and simple\n- Independent of model choice"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cons"},{"type":"text","text":":\n- Ignores feature interactions\n- May miss complex relationships"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use"},{"type":"text","text":": Quick initial filtering, large datasets, exploratory analysis."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Wrapper Methods"}]},{"type":"paragraph","content":[{"type":"text","text":"Evaluate "},{"type":"text","marks":[{"type":"bold"}],"text":"feature subsets based on model performance"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How it works"},{"type":"text","text":":\n- Try different combinations of features\n- Train model on each combination\n- Select combination with best performance"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Common techniques"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Recursive Feature Elimination (RFE)"},{"type":"text","text":": Remove least important features iteratively\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Forward Selection"},{"type":"text","text":": Start with no features, add best one at each step\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Backward Elimination"},{"type":"text","text":": Start with all features, remove worst one at each step"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pros"},{"type":"text","text":":\n- Accounts for feature interactions\n- Model-aware (finds best features for specific model)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cons"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Slow and computationally expensive"},{"type":"text","text":" (many model training runs)\n- Can overfit to training data"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use"},{"type":"text","text":": Smaller datasets, when you need optimal subset for specific model."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Embedded Methods"},{"type":"text","text":" (Integrated)"}]},{"type":"paragraph","content":[{"type":"text","text":"Perform feature selection "},{"type":"text","marks":[{"type":"bold"}],"text":"during model training process"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How it works"},{"type":"text","text":":\n- Model learns which features are important\n- Uses built-in mechanisms to select features"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Common techniques"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Lasso (L1 Regularization)"},{"type":"text","text":": Shrinks coefficients, zeros out unimportant features\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Tree-based feature importance"},{"type":"text","text":": Decision trees assign importance scores\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Random Forest importance"},{"type":"text","text":": Aggregates feature importance across trees"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pros"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Balanced"},{"type":"text","text":": Faster than wrapper, more accurate than filter\n- Model-aware (finds features for specific model)\n- Efficient (single training run)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cons"},{"type":"text","text":":\n- Only works with models that support it"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use"},{"type":"text","text":": Most common choice for production, good balance of speed and accuracy."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Step-by-step feature selection workflow"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 1: Filter Methods (Quick Filter)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from sklearn.feature_selection import correlation_matrix\n\n# Remove features with low correlation to target\ncorrelations = df.corr()['target'].abs()\nselected_features = correlations[correlations > 0.1].index"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Purpose"},{"type":"text","text":": Quick elimination of irrelevant features."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 2: Embedded Methods (Model-Based)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from sklearn.ensemble import RandomForestClassifier\n\nmodel = RandomForestClassifier()\nmodel.fit(X, y)\n\n# Get feature importance\nimportances = model.feature_importances_"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Purpose"},{"type":"text","text":": Identify important features using model's built-in mechanism."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 3: Wrapper Methods (Fine-Tuning)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from sklearn.feature_selection import RFE\n\nmodel = RandomForestClassifier()\nrfe = RFE(estimator=model, n_features_to_select=10)\nrfe.fit(X, y)\n\nselected_features = X.columns[rfe.get_support()]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Purpose"},{"type":"text","text":": Optimize feature subset for best performance."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"When to use feature selection"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"bold"}],"text":"Use feature selection when"},{"type":"text","text":":"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Why"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Many irrelevant features"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Remove noise, improve accuracy"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"High-dimensional data"}]}]},{"type":"t