text","text":"Why"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Very high-dimensional"},{"type":"text","text":" (images, text)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Need to capture underlying structure"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Correlated or noisy features"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"PCA handles correlation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Deep learning"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Requires dense, informative representations"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best practices for feature selection"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"bold"}],"text":"Start with filter methods"}]},{"type":"paragraph","content":[{"type":"text","text":"Quick initial filter to remove obviously irrelevant features."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"bold"}],"text":"Use embedded methods for production"}]},{"type":"paragraph","content":[{"type":"text","text":"Best balance of speed and accuracy; Random Forest, Lasso work well."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"bold"}],"text":"Validate with cross-validation"}]},{"type":"paragraph","content":[{"type":"text","text":"Ensure selected features generalize well."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"bold"}],"text":"Iterate"}]},{"type":"paragraph","content":[{"type":"text","text":"Feature selection is iterative: select → train → evaluate → refine."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"bold"}],"text":"Remove highly correlated features"}]},{"type":"paragraph","content":[{"type":"text","text":"Features with correlation > 0.9 are likely redundant; remove one."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Feature selection"},{"type":"text","text":" selects the "},{"type":"text","marks":[{"type":"bold"}],"text":"most relevant features"},{"type":"text","text":" from dataset by removing irrelevant/redundant ones, improving accuracy and reducing overfitting."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Three main methods"},{"type":"text","text":":"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- "},{"type":"text","marks":[{"type":"bold"}],"text":"Filter"},{"type":"text","text":": Statistical scoring (correlation, chi-square, ANOVA); fast but ignores interactions - "},{"type":"text","marks":[{"type":"bold"}],"text":"Wrapper"},{"type":"text","text":": Model performance-based (RFE, forward/backward selection); accurate but slow - "},{"type":"text","marks":[{"type":"bold"}],"text":"Embedded"},{"type":"text","text":": During training (Lasso L1, tree importance); balanced speed+accuracy\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Benefits"},{"type":"text","text":": Reduces overfitting, improves training speed, enhances interpretability, minimizes noise, reduces dimensionality.\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Feature selection"},{"type":"text","text":" = removes columns; "},{"type":"text","marks":[{"type":"bold"}],"text":"feature engineering"},{"type":"text","text":" = creates new columns; "},{"type":"text","marks":[{"type":"bold"}],"text":"feature extraction"},{"type":"text","text":" = transforms to new space (PCA, autoencoders).\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Best practice"},{"type":"text","text":": Start with "},{"type":"text","marks":[{"type":"bold"}],"text":"filter methods"},{"type":"text","text":" → use "},{"type":"text","marks":[{"type":"bold"}],"text":"embedded methods"},{"type":"text","text":" (Random Forest, Lasso) → validate with cross-validation.\n- Use feature selection when many irrelevant features, high-dimensional data, need interpretability, or overfitting; use feature extraction for very high-dimensional (images/text) or correlated features."}]}]}}
