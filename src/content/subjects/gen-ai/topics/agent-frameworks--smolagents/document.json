            "type": "text",
            "text": "import asyncio\nfrom pydantic import BaseModel, Field\nfrom pydantic_ai import Agent\n\nclass ResearchSummary(BaseModel):\n    topic: str\n    key_facts: list[str] = Field(min_length=3, max_length=5)\n    confidence: float = Field(ge=0.0, le=1.0, description=\"0=uncertain, 1=confident\")\n    sources_needed: bool\n\nresearch_agent = Agent(\n    \"openai:gpt-4o\",\n    system_prompt=(\n        \"You are a research assistant. \"\n        \"Summarize topics accurately. \"\n        \"Set confidence based on how well you know the subject.\"\n    ),\n    result_type=ResearchSummary,\n)\n\nasync def main():\n    result = await research_agent.run(\n        \"Summarize what you know about transformer neural network architecture.\"\n    )\n\n    summary = result.data  # ResearchSummary, Pydantic-validated\n    print(f\"Topic: {summary.topic}\")\n    print(f\"Facts: {summary.key_facts}\")\n    print(f\"Confidence: {summary.confidence:.0%}\")\n    print(f\"Needs more sources: {summary.sources_needed}\")\n    print(f\"Tokens used: {result.usage().total_tokens}\")\n\n    # Streaming: yield tokens as they arrive (result_type validated at end)\n    async with research_agent.run_stream(\"What is quantum entanglement?\") as stream:\n        async for text_chunk in stream.stream_text(delta=True):\n            print(text_chunk, end=\"\", flush=True)\n    print()\n    # stream.get_data() returns the validated ResearchSummary after the stream ends\n\nasyncio.run(main())"
          }
