te modified versions of training samples that preserve the "}, {"type": "text", "marks": [{"type": "bold"}], "text": "underlying semantics"}, {"type": "text", "text": " (label meaning)."}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "2. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Preserve labels"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Transformations must not change the "}, {"type": "text", "marks": [{"type": "bold"}], "text": "correct answer"}, {"type": "text", "text": " (e.g., flipped image of a cat is still a cat)."}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "3. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Simulate real-world variations"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Transformations mimic natural variations:\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Images"}, {"type": "text", "text": ": flipping, rotating, zooming, changing brightness/contrast\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Text"}, {"type": "text", "text": ": synonym replacement, word deletion, sentence shuffling\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Audio"}, {"type": "text", "text": ": adding noise, changing pitch/speed, time stretching"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "4. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Train on augmented data"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Model learns from original + augmented samples, becoming less sensitive to training set idiosyncrasies."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Data augmentation by data type"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "1. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Image Augmentation"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Most common in CNNs for classification, detection, segmentation."}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Technique"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Description"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Example"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Random Flip"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Horizontal/vertical flip"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Flip image left-right"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Random Rotation"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Rotate by angle (e.g., ±18°)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type"