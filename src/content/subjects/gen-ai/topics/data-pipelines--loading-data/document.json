: "SQL"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Database tables"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Enterprise data"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "URL"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Data from web"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Public datasets"}]}]}]}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Four main ways to load data in Python"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "1. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Manual loading with "}, {"type": "text", "marks": [{"type": "bold"}, {"type": "code"}], "text": "csv"}, {"type": "text", "marks": [{"type": "bold"}], "text": " module"}, {"type": "text", "text": " (low-level)"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Basic but manual approach:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import csv\nimport numpy as np\n\nFILE_NAME = \"spambase.data\"\nwith open(FILE_NAME, 'r') as f:\n    data = list(csv.reader(f, delimiter=\",\"))\n    data = np.array(data, dtype=np.float32)\n\nprint(data.shape)  # (n_samples, n_features)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Pros"}, {"type": "text", "text": ": No dependencies beyond Python's built-in "}, {"type": "text", "marks": [{"type": "code"}], "text": "csv"}, {"type": "text", "text": "\n"}, {"type": "text", "marks": [{"type": "bold"}], "text": "Cons"}, {"type": "text", "text": ": Manual, error-prone, no type inference, no missing value handling"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "2. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "NumPy: "}, {"type": "text", "marks": [{"type": "bold"}, {"type": "code"}], "text": "np.loadtxt()"}, {"type": "text", "text": " (simple text loading)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import numpy as np\n\nFILE_NAME = \"spambase.data\"\ndata = np.loadtxt(FILE_NAME, delimiter=\",\", dtype=np.float32)\n\nprint(data.shape, data.dtype)  # (5709, 58) float32"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Pros"}, {"type": "text", "text": ":\n- Fast for simple numeric CSVs\n- No Pandas dependency"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Cons"}, {"type": "text", "text": ":\n- No header support (must use "}, {"type": "text", "marks": [{"type": "code"}], "text": "skiprows"}, {"type": "text", "text": ")\n- No missing value handling by default\n- Assumes all data is numeric with same dtype"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "3. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "NumPy: "}, {"type": "text", "marks": [{"type": "bold"}, {"type": "code"}], "text": "np.genfromtxt()"}, {"type": "text", "text": " (smarter text loading)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import numpy as np\n\nFILE_NAME = \"spambase.data\"\ndata = np.genfromtxt(\n    FILE_NAME,\n    delimiter=\",\",\n    dtype=np.float32,\n    skip_header=0,  # or skiprows\n    missing_values=\"---\",  # custom missing marker\n    filling_values=0.0    # what to fill missing with\n)\n\nprint(data.shape)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Pros"}, {"type": "text", "text": ":\n- Handles missing values (e.g., "}, {"type": "text", "marks": [{"type": "code"}], "text": "\"---\""}, {"type": "text", "text": ")\n- Can use "}, {"type": "text", "marks": [{"type": "code"}], "text": "dtype=None"}, {"type": "text", "text": " to infer types per column\n- Can specify column names with "}, {"type": "text", "marks": [{"type": "code"}], "text": "names=True"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Cons"}, {"type": "text", "text": ":\n- Still limited compared to pandas for complex data\n- Slower than "}, {"type": "text", "marks": [{"type": "code"}], "text": "np.loadtxt()"}, {"type": "text", "text": " for large files"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "4. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Pandas: "}, {"type": "text", "marks": [{"type": "bold"}, {"type": "code"}], "text": "pd.read_csv()"}, {"type": "text", "text": " (recommended for ML)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import pandas as pd\nimport numpy as np\n\nFILE_NAME = \"spambase.data\"\n\n# Load with pandas\ndf = pd.read_csv(\n    FILE_NAME,\n    header=None,          # No column names\n    skiprows=0,           # Don't skip any rows\n    dtype=np.float32,     # Force dtype\n    na_values=['---']     # Custom missing marker\n)\n\n# Handle missing values\ndf = df.fillna(0.0)\n\n# Convert to NumPy array for ML\ndata = df.to_numpy()\n\nprint(data.shape)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Pros"}, {"type": "text", "text": ":\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Most accessible and complete"}, {"type": "text", "text": " function for loading tabular data\n- Infers data types automatically per column\n- Handles missing values, dates, and erroneous data\n- Supports custom delimiters, headers, and encoding\n- Creates a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "pandas DataFrame"}, {"type": "text", "text": " with row indices and column names\n- Can start summarizing and plotting immediately\n- Can load from URLs directly: "}, {"type": "text", "marks": [{"type": "code"}], "text": "pd.read_csv(\"https://...\")"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Cons"}, {"type": "text", "text": ":\n- Slightly slower than pure NumPy for very large numeric-only files\n- Requires pandas installation"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Loading data from URLs"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Both NumPy and pandas can load from URLs:"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "NumPy:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "from numpy import loadtxt\nfrom urllib.request import urlopen\n\nurl = 'https://python.org/data.csv'\nraw_data = urlopen(url)\ndataset = loadtxt(raw_data, delimiter=\",\")\nprint(dataset)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Pandas (recommended):"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import pandas as pd\n\nurl = 'https://example.com/data.csv'\ndf = pd.read_csv(url)\nprint(df.head())"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Pandas is more flexible and handles parsing automatically."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Loading NumPy binary files ("}, {"type": "text", "marks": [{"type": "code"}], "text": ".npy"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "code"}], "text": ".npz"}, {"type": "text", "text": ")"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Single array ("}, {"type": "text", "marks": [{"type": "code"}], "text": ".npy"}, {"type": "text", "text": "):"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import numpy as np\n\n_arr = np.load(\"array.npy\", allow_pickle=False)  # Safe for untrusted sources\nprint(_arr.shape, _arr.dtype)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Multiple arrays ("}, {"type": "text", "marks": [{"type": "code"}], "text": ".npz"}, {"type": "text", "text": "):"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "_arr = np.load(\"arrays.npz\")\nprint(_arr.files)  # List of array names\nx = _arr[\"x\"]\ny = _arr[\"y\"]"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Loading Pickle files (serialized DataFrames/models)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import pickle\n\nfilename = \"data.pkl\"\nwith open(filename, \"rb\") as f:  # Binary mode\n    df = pickle.load(f)\n\nprint(df.head())"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Pickle is ideal for:\n- Serialized DataFrames\n- Pre-trained models\n- Complex Python objects"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Extracting features and labels from loaded data"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "After loading CSV data:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "n_samples, n_features = data.shape\nn_features -= 1  # Last column is label\n\nX = data[:, 0:n_features]  # Features\ny = data[:, n_features]     # Labels\n\nprint(X.shape, y.shape)  # (5709, 57), (5709,)"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Or if label is first column:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "X = data[:, 1:n_features+1]\ny = data[:, 0]"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Extracting columns from pandas DataFrames"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import pandas as pd\nimport numpy as np\n\ndf = pd.read_csv(\"shell_sort1_timings.csv\", sep=',')\n\n# Extract columns\nsizes = df['size']\ntimes = df['time']\n\n# Filter rows (like SQL WHERE)\nmerge_rows = df[df['algorithm'] == 'merge_sort']\n\n# Use for ML (NumPy arrays)\nx = df['size'].values\ny = df['time'].values"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "NumPy vs. Pandas for loading data"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Concern"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "NumPy"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Pandas"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text"