      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Decisions made by the architecture council are binding on all member teams. A team that disagrees with a council decision may appeal to the VP Engineering within 5 business days, but must comply with the decision while the appeal is pending."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
