xt":"Misleading for imbalanced data"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Precision"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"False positive focus"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Ignores false negatives"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Recall"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"False negative focus"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Ignores false positives"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"F1 Score"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Both errors matter"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Single metric, may hide trade-offs"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why accuracy is misleading"},{"type":"text","text":":\n- Imagine 95% negative, 5% positive classes\n- Model predicts all as negative → 95% accuracy\n- But model found "},{"type":"text","marks":[{"type":"bold"}],"text":"0% of positives"},{"type":"text","text":" (recall = 0)\n- Accuracy hides the problem!"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Python Implementation"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from sklearn.metrics import precision_score, recall_score, f1_score\n\n# Classification metrics\nprecision = precision_score(y_test, y_pred)\nrecall = recall_score(y_test, y_pred)\nf1 = f1_score(y_test, y_pred)\n\nprint(f\"Precision: {precision:.3f}\")\nprint(f\"Recall: {recall:.3f}\")\nprint(f\"F1 Score: {f1:.3f}\")"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Precision"},{"type":"text","text":" = TP/(TP+FP) — \"Of all positives I predicted, how many were correct?\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Recall"},{"type":"text","text":" = TP/(TP+FN) — \"Of all actual positives, how many did I find?\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"F1 Score"},{"type":"text","text":" = 2×(Precision×Recall)/(Precision+Recall) — harmonic mean balancing both"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Precision focus"},{"type":"text","text":": False positives costly (spam detection, fraud detection)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Recall focus"},{"type":"text","text":": False negatives costly (cancer detection, disease outbreak)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"F1 focus"},{"type":"text","text":": Both errors matter, imbalanced classes"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Trade-off"},{"type":"text","text":": Can't maximize both precision and recall simultaneously"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Accuracy misleading"},{"type":"text","text":": For imbalanced data, use Precision/Recall/F1 instead"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"F1 is conservative"},{"type":"text","text":": Penalizes extreme imbalance more than arithmetic mean"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Always report together"},{"type":"text","text":": Precision and recall should be reported together"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Precision/Recall/F1 are the \"quality, completeness, and balance\" metrics for classification — precision measures how many of your positive predictions were correct (quality), recall measures how many actual positives you found (completeness), and F1 balances both into a single score, making them essential for imbalanced datasets where accuracy alone is misleading."}]}]}}
