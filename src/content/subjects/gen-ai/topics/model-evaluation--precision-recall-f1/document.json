{"format":"tiptap/v1","updatedAt":"2026-06-22T04:04:56.323Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Precision"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"bold"}],"text":"Recall"},{"type":"text","text":", and "},{"type":"text","marks":[{"type":"bold"}],"text":"F1 Score"},{"type":"text","text":" are three critical metrics for evaluating "},{"type":"text","marks":[{"type":"bold"}],"text":"classification models"},{"type":"text","text":", especially when dealing with "},{"type":"text","marks":[{"type":"bold"}],"text":"imbalanced datasets"},{"type":"text","text":" where accuracy alone is misleading — they measure different aspects of prediction quality and help you understand trade-offs between false positives and false negatives."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What They Are: The Confusion Matrix Basics"}]},{"type":"paragraph","content":[{"type":"text","text":"All three metrics are calculated using the "},{"type":"text","marks":[{"type":"bold"}],"text":"confusion matrix"},{"type":"text","text":":"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Term"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Definition"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"True Positives (TP)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Correctly predicted positive instances"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"False Positives (FP)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Incorrectly predicted positive (Type I error)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"True Negatives (TN)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Correctly predicted negative instances"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"False Negatives (FN)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Incorrectly predicted negative (Type II error)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Visual"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"              Actual Positive   Actual Negative\nPredicted Positive        TP             FP\nPredicted Negative        FN             TN"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Precision"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Definition"},{"type":"text","text":": Measures the proportion of "},{"type":"text","marks":[{"type":"bold"}],"text":"correctly predicted positives"},{"type":"text","text":" out of "},{"type":"text","marks":[{"type":"bold"}],"text":"all instances predicted as positive"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Question it answers"},{"type":"text","text":": \"Of all the cases I predicted as positive, how many were actually positive?\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Formula"},{"type":"text","text":":\n$$\\text{Precision} = \\frac{TP}{TP + FP}$$"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Interpretation"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"High precision"},{"type":"text","text":": Few false positives (rarely mislabels negative as positive)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Low precision"},{"type":"text","text":": Many false positives (over-predicts positive)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use"},{"type":"text","text":":\n- ⭐ "},{"type":"text","marks":[{"type":"bold"}],"text":"False positives are costly"},{"type":"text","text":" or undesirable\n- Spam email classification (don't want to mark legitimate emails as spam)\n- Fraud detection (don't want to flag legitimate transactions)\n- Recommendation systems (don't want to recommend irrelevant items)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": Email spam detector\n- Predicted spam: 100 emails\n- Actually spam: 90 emails\n- Precision = 90/100 = "},{"type":"text","marks":[{"type":"bold"}],"text":"0.90"},{"type":"text","text":" (90% of spam predictions were correct)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Recall"},{"type":"text","text":" (Sensitivity / True Positive Rate)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Definition"},{"type":"text","text":": Measures the proportion of "},{"type":"text","marks":[{"type":"bold"}],"text":"correctly predicted positives"},{"type":"text","text":" out of "},{"type":"text","marks":[{"type":"bold"}],"text":"all actual positive instances"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Question it answers"},{"type":"text","text":": \"Of all the actual positive cases, how many did I find?\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Formula"},{"type":"text","text":":\n$$\\text{Recall} = \\frac{TP}{TP + FN}$$"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Interpretation"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"High recall"},{"type":"text","text":": Few false negatives (catches most positive cases)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Low recall"},{"type":"text","text":": Many false negatives (misses positive cases)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use"},{"type":"text","text":":\n- ⭐ "},{"type":"text","marks":[{"type":"bold"}],"text":"Missing positive cases is critical"},{"type":"text","text":" or dangerous\n- Medical diagnosis (detecting cancer — don't miss cases)\n- Disease outbreak detection (don't miss infected patients)\n- Safety-critical systems (don't miss faults)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": Cancer detection\n- Actual cancer patients: 100\n- Detected cancer patients: 80\n- Recall = 80/100 = "},{"type":"text","marks":[{"type":"bold"}],"text":"0.80"},{"type":"text","text":" (found 80% of actual cancer cases)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"F1 Score"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Definition"},{"type":"text","text":": The "},{"type":"text","marks":[{"type":"bold"}],"text":"harmonic mean"},{"type":"text","text":" of precision and recall — provides a balanced measure when you need to consider both false positives and false negatives."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Question it answers"},{"type":"text","text":": \"What's the single score that balances both precision and recall?\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Formula"},{"type":"text","text":":\n$$\\text{F1} = 2 \\times \\frac{\\text{Precision} \\times \\text{Recall}}{\\text{Precision} + \\text{Recall}}$$"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Alternative formula"},{"type":"text","text":":\n$$\\text{F1} = \\frac{2 \\times TP}{2 \\times TP + FP + FN}$$"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Interpretation"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"High F1"},{"type":"text","text":": Both precision and recall are high\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Low F1"},{"type":"text","text":": Either precision or recall (or both) is low\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Maximum"},{"type":"text","text":": 1.0 (perfect precision and recall)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Minimum"},{"type":"text","text":": 0.0"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key insight"},{"type":"text","text":": F1 is a \"conservative average\" — it penalizes extreme imbalance:\n- F1(0.5, 0.5) = 0.5\n- F1(1.0, 0.5) = 0.66\n- F1(1.0, 0.01) = 0.02 (very low, even though one is perfect!)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use"},{"type":"text","text":":\n- ⭐ "},{"type":"text","marks":[{"type":"bold"}],"text":"Both precision and recall matter"},{"type":"text","text":"\n- Imbalanced class distribution\n- Need single metric for model comparison\n- Real-world scenarios where both errors are costly"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": Investment recommendation system\n- Precision = 0.80 (80% of recommended investments succeeded)\n- Recall = 0.70 (found 70% of all successful investments)\n- F1 = 2 × (0.80 × 0.70) / (0.80 + 0.70) = "},{"type":"text","marks":[{"type":"bold"}],"text":"0.74"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Precision vs. Recall: The Trade-Off"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Precision"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Recall"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Focus"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Quality of positive predictions"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Completeness of positive detection"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Penalizes"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"False positives"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"False negatives"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"High when"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Few false positives"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Few false negatives"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Low when"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Many false positives"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Many false negatives"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use when"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"co