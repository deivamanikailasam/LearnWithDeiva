{"format":"tiptap/v1","updatedAt":"2026-06-22T08:59:46.434Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What SGD Is"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"SGD (Stochastic Gradient Descent)"},{"type":"text","text":" is the foundational optimization algorithm in deep learning that updates model parameters by following the negative gradient of the loss function. It's a variation of standard gradient descent designed to speed up learning by updating weights more frequently—using only a single or a few randomly selected training examples per update instead of the entire dataset."}]},{"type":"paragraph","content":[{"type":"text","text":"The name \"stochastic\" comes from this "},{"type":"text","marks":[{"type":"bold"}],"text":"random nature"},{"type":"text","text":"—SGD introduces noise into the optimization path, which can help escape suboptimal solutions."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why SGD Matters in Generative AI"}]},{"type":"paragraph","content":[{"type":"text","text":"SGD powers the training of many AI models:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Application"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Why SGD Works"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Large datasets"},{"type":"text","text":" (millions of images)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Updates after seeing few examples, not full dataset"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Neural networks"},{"type":"text","text":" (high cost of backprop)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Overcomes computational cost of full gradient descent"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"YOLO object detection"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Powers efficient AI training for autonomous vehicles"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Medical diagnostics"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Trains complex CNNs without overwhelming memory"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Computer vision"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Still frequently used for finding generalizable solutions"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"SGD can overcome the high cost of running backpropagation over the full training set and still lead to fast convergence."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How SGD Works"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Update Formula"}]},{"type":"paragraph","content":[{"type":"text","text":"The standard gradient descent algorithm updates parameters "},{"type":"inlineMath","attrs":{"latex":"\\theta"}},{"type":"text","text":" as:"}]},{"type":"blockMath","attrs":{"latex":"\\theta = \\theta - \\alpha \\nabla_\\theta E[J(\\theta)]"}},{"type":"paragraph","content":[{"type":"text","text":"Where:\n- "},{"type":"inlineMath","attrs":{"latex":"\\theta"}},{"type":"text","text":": Model parameters (weights/biases)\n- "},{"type":"inlineMath","attrs":{"latex":"\\alpha"}},{"type":"text","text":": Learning rate (step size)\n- "},{"type":"inlineMath","attrs":{"latex":"\\nabla_\\theta E[J(\\theta)]"}},{"type":"text","text":": Expected gradient over full training set"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"SGD removes the expectation"},{"type":"text","text":" and computes gradients using only a single or mini-batch of training examples:"}]},{"type":"blockMath","attrs":{"latex":"\\theta = \\theta - \\alpha \\nabla_\\theta J(\\theta; x^{(i)}, y^{(i)})"}},{"type":"paragraph","content":[{"type":"text","text":"With a pair "},{"type":"inlineMath","attrs":{"latex":"(x^{(i)}, y^{(i)})"}},{"type":"text","text":" from the training set."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step-by-Step Process"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Select random data point"},{"type":"text","text":": Choose a random sample from training data"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Forward pass"},{"type":"text","text":": Generate prediction"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Calculate error"},{"type":"text","text":": Compute loss (difference between prediction and target)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Backpropagation"},{"type":"text","text":": Compute gradient (slope of error landscape)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Update weights"},{"type":"text","text":": Move in opposite direction of gradient to reduce error"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Repeat"},{"type":"text","text":": Continue for many iterations until performance stabilizes"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Mini-Batch SGD (What's Actually Used)"}]},{"type":"paragraph","content":[{"type":"text","text":"In practice, most frameworks implement "},{"type":"text","marks":[{"type":"bold"}],"text":"mini-batch SGD"},{"type":"text","text":"—a hybrid approach:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Updates parameters using a "},{"type":"text","marks":[{"type":"bold"}],"text":"small group of samples"},{"type":"text","text":" (batch) instead of just one"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Typical mini-batch size: "},{"type":"text","marks":[{"type":"bold"}],"text":"256"},{"type":"text","text":" (varies by application)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Benefits: Reduces variance (more stable) + enables optimized matrix operations"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"SGD in PyTorch"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Basic SGD"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import torch\nimport torch.nn as nn\nimport torch.optim as optim\n\n# Model\nmodel = nn.Linear(10, 1)\n\n# SGD optimizer (no momentum)\noptimizer = optim.SGD(\n    model.parameters(),  # Parameters to optimize\n    lr=0.01              # Learning rate\n)\n\n# Training step\ndata = torch.randn(1, 10)\ntarget = torch.randn(1, 1)\n\noutput = model(data)\nloss = nn.MSELoss()(output, target)\n\noptimizer.zero_grad()      # Clear gradients\nloss.backward()            # Compute gradients\noptimizer.step()           # Update parameters [web:126]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"SGD with Momentum"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Common practice: SGD with momentum\noptimizer = optim.SGD(\n    model.parameters(),\n    lr=0.01,\n    momentum=0.9,          # Accelerate in correct direction [web:126]\n    nesterov=True          # Nesterov momentum (optional)\n)"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"SGD vs. Other Optimizers"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"SGD vs. Batch Gradient Descent"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Batch Gradient Descent"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"SGD"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Data per update"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Entire dataset"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Single example or mini-batch"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Speed"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Slow (one update per epoch)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Fast (many updates per epoch)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Memory"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"High (need full dataset)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Low (process incrementally)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Path"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Smooth trajectory"}]}]},{"type":"tableCell","attrs