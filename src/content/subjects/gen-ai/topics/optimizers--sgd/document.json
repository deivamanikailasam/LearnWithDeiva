pe":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Transformers, LLMs, NLP"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Challenges and Solutions"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Challenge 1: Learning Rate Selection"}]},{"type":"paragraph","content":[{"type":"text","text":"The learning rate "},{"type":"inlineMath","attrs":{"latex":"\\alpha"}},{"type":"text","text":" is critical:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Too high"},{"type":"text","text":": Model overshoots minimum (exploding gradient)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Too low"},{"type":"text","text":": Training is painfully slow"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"SGD requirement"},{"type":"text","text":": Typically much smaller than batch gradient descent due to variance"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Common schedules"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Schedule 1: Constant + halve\nlr = 0.01  # Small enough for stable convergence\n# After epoch 2: lr = 0.005\n\n# Schedule 2: Anneal after each epoch\nif change_in_objective < threshold:\n    lr = lr * 0.9  # Reduce learning rate\n\n# Schedule 3: Inverse time decay\nlr = a / (b + t)  # a = initial lr, b = when annealing begins [web:125]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Challenge 2: Noisy Updates"}]},{"type":"paragraph","content":[{"type":"text","text":"The noise in gradient steps can cause loss to fluctuate wildly."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Solution: Momentum"}]},{"type":"paragraph","content":[{"type":"text","text":"Momentum helps accelerate SGD in the relevant direction and dampens oscillations, like a heavy ball rolling down a hill:"}]},{"type":"blockMath","attrs":{"latex":"v = \\gamma v + \\alpha \\nabla_\\theta J(\\theta; x^{(i)}, y^{(i)})"}},{"type":"blockMath","attrs":{"latex":"\\theta = \\theta - v"}},{"type":"paragraph","content":[{"type":"text","text":"Where:\n- "},{"type":"inlineMath","attrs":{"latex":"v"}},{"type":"text","text":": Velocity (accumulates past gradients)\n- "},{"type":"inlineMath","attrs":{"latex":"\\gamma \\in (0,1]"}},{"type":"text","text":": Momentum coefficient (typically 0.9)\n- "},{"type":"inlineMath","attrs":{"latex":"\\alpha"}},{"type":"text","text":": Learning rate"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Typical values"},{"type":"text","text":":\n- "},{"type":"inlineMath","attrs":{"latex":"\\gamma = 0.5"}},{"type":"text","text":" initially\n- "},{"type":"inlineMath","attrs":{"latex":"\\gamma = 0.9"}},{"type":"text","text":" or higher after learning stabilizes"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Challenge 3: Data Order Bias"}]},{"type":"paragraph","content":[{"type":"text","text":"If data is given in meaningful order, it can bias the gradient and lead to poor convergence."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Solution: Random shuffling"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Shuffle data before each epoch\ndataset.shuffle()  # Randomize order [web:125]"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"SGD Optimizer in PyTorch (Complete Example)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import torch\nimport torch.nn as nn\nimport torch.optim as optim\n\n# Define model\nmodel = nn.Sequential(\n    nn.Linear(784, 256),\n    nn.ReLU(),\n    nn.Linear(256, 128),\n    nn.ReLU(),\n    nn.Linear(128, 10)\n)\n\n# SGD with momentum (common practice)\noptimizer = optim.SGD(\n    model.parameters(),\n    lr=0.01,\n    momentum=0.9,\n    nesterov=True\n)\n\n# Training loop\nfor epoch in range(100):\n    for data, target in dataset:\n        # Forward pass\n        output = model(data)\n        loss = nn.CrossEntropyLoss()(output, target)\n        \n        # Backward pass\n        optimizer.zero_grad()\n        loss.backward()\n        optimizer.step()  # SGD update [web:126]\n    \n    # Learning rate schedule\n    if epoch % 10 == 0:\n        optimizer.param_groups[0]['lr'] *= 0.9  # Anneal [web:125]"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of SGD as "},{"type":"text","marks":[{"type":"bold"}],"text":"rolling down a hill blindfolded"},{"type":"text","text":":"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Feel the slope"},{"type":"text","text":": Compute gradient (where does loss increase?)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step downhill"},{"type":"text","text":": Update weights opposite to gradient"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Random steps"},{"type":"text","text":": Only feel one spot at a time (stochastic)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Small steps"},{"type":"text","text":": Learning rate controls step size"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Momentum"},{"type":"text","text":": Carry forward velocity to avoid getting stuck in local minima"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"The noise from random steps helps you "},{"type":"text","marks":[{"type":"bold"}],"text":"escape local minima"},{"type":"text","text":" and potentially find a better global solution."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"SGD"},{"type":"text","text":" = Updates parameters using single/mini-batch instead of full dataset"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Stochastic"},{"type":"text","text":" = Random selection introduces noise, helps escape suboptimal solutions"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Update formula"},{"type":"text","text":": "},{"type":"inlineMath","attrs":{"latex":"\\theta = \\theta - \\alpha \\nabla_\\theta J(\\theta; x^{(i)}, y^{(i)})"}}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mini-batch SGD"},{"type":"text","text":": Uses small group (typ. 256) for stability + efficiency"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Learning rate"},{"type":"text","text":": Critical—smaller than batch gradient descent due to variance"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Momentum"},{"type":"text","text":": Accumulates past gradients (γ=0.9) to accelerate and reduce oscillations"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PyTorch"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"optim.SGD(params, lr=0.01, momentum=0.9)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Advantages"},{"type":"text","text":": Fast, low memory, escapes local minima"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Challenges"},{"type":"text","text":": Noisy updates, difficult learning rate tuning"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Computer vision"},{"type":"text","text":": Still frequently used for better generalization"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Transformers/LLMs"},{"type":"text","text":": Adam/AdamW preferred (adaptive learning rate)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Shuffle data"},{"type":"text","text":": Randomize before each epoch to avoid order bias"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Learning rate schedule"},{"type":"text","text":": Anneal when convergence slows (e.g., lr "},{"type":"text","marks":[{"type":"italic"}],"text":"= 0.9 every 10 epochs)"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"SGD is the "},{"type":"text","marks":[{"type":"bold"}],"text":"oldest but still efficient optimizer"},{"type":"text","text":" that powers many transformative AI technologies, working by iteratively refining model accuracy through small, noisy updates that can lead to better global solutions."}]}]}}
