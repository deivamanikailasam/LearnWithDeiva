{"format":"tiptap/v1","updatedAt":"2026-06-21T13:39:13.442Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Async/Await & Promises"},{"type":"text","text":" in TypeScript/JavaScript are the foundation for handling Generative AI's asynchronous operations—API calls to LLMs, streaming responses, and file uploads never complete instantly, so you need non-blocking code that doesn't freeze your web app."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Concept"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Definition"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Gen AI Use Case"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Promise"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Object representing eventual completion/failure of async operation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"API call result ("},{"type":"text","marks":[{"type":"code"}],"text":"fetch(\"/api/ai\")"},{"type":"text","text":")"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":".then()"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Callback-based Promise chaining (pre-ES2017)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Legacy code; rarely used now"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"async"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Declares function returns Promise; enables "},{"type":"text","marks":[{"type":"code"}],"text":"await"},{"type":"text","text":" inside"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"async function callAI() {... }"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"await"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Pauses async function until Promise settles; returns value"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"const response = await callAI(prompt)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"try/catch"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Error handling for async operations"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"try { await callAI() } catch (err) {... }"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"AsyncGenerator"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Async + Generator combo for streaming values"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Real-time AI streaming responses"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why It Matters for Gen AI"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ❌ WITHOUT async/await: Callback hell / blocking\nfetch(\"/api/ai\")\n  .then(res => res.json())\n  .then(data => {\n    console.log(data.text);\n    // Can't do anything here until resolved\n  })\n  .catch(err => console.error(err));\n\n// ✅ WITH async/await: Synchronous-looking, non-blocking\nasync function getAIResponse() {\n  try {\n    const res = await fetch(\"/api/ai\");  // ✅ Waits without blocking\n    const data = await res.json();\n    console.log(data.text);              // ✅ Runs AFTER fetch completes\n    return data;\n  } catch (err) {\n    console.error(err);                  // ✅ Handles errors cleanly\n    return null;\n  }\n}\n\nconst response = await getAIResponse();  // ✅ Clean, readable"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Non-blocking"},{"type":"text","text":": UI stays responsive while waiting for LLM\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Readable"},{"type":"text","text":": Looks like synchronous code; easier to debug\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Error handling"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"try/catch"},{"type":"text","text":" instead of chained "},{"type":"text","marks":[{"type":"code"}],"text":".catch()"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Streaming support"},{"type":"text","text":": AsyncGenerators for real-time AI output"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How It Works (Core Mechanics)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Promise States"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"const aiPromise = new Promise<string>((resolve, reject) => {\n  // Simulate API call\n  setTimeout(() => {\n    if (Math.random() > 0.5) {\n      resolve(\"AI response text\");  // ✅ Fulfilled\n    } else {\n      reject(\"API error\");           // ❌ Rejected\n    }\n  }, 1000);\n});\n\n// Three states:\n// 1. Pending: Operation ongoing (initial state)\n// 2. Fulfilled: Completed successfully (resolve called)\n// 3. Rejected: Failed (reject called) [web:38]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Async Function Declaration"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ✅ async keyword = function returns Promise\nasync function callGenAI(prompt: string): Promise<string> {\n  const res = await fetch(\"/api/ai\", {\n    method: \"POST\",\n    body: JSON.stringify({ prompt }),\n  });\n  \n  if (!res.ok) throw new Error(`API error: ${res.status}`);\n  return res.json();  // ✅ Returns Promise<string>\n}\n\n// ✅ Usage\nconst response = await callGenAI(\"Explain quantum computing\");\nconsole.log(response);  // ✅ \"AI response text\""}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Await Only in Async Functions"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ❌ ERROR: await outside async function\nconst res = fetch(\"/api/ai\");  // ❌ Returns Promise, not value\nconst data = await res.json(); // ❌ SyntaxError: await in non-async\n\n// ✅ CORRECT: Wrap in async\nasync function getData() {\n  const res = await fetch(\"/api/ai\");\n  const data = await res.json();\n  return data;\n}\n\n// ✅ Call from event handler (async)\nbutton.addEventListener(\"click\", async () => {\n  const data = await getData();\n  console.log(data);\n});"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Error Handling with try/catch"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"async function safeCallGenAI(prompt: string): Promise<string | null> {\n  try {\n    const res = await fetch(\"/api/ai\");\n    const data = await res.json();\n    return data.text;\n  } catch (error: unknown) {  // ✅ unknown requires type check\n    if (error instanceof Error) {\n      console.error(`AI API error: ${error.message}`);\n      return null;\n    }\n    throw new Error(\"Unknown error\");\n  }\n}\n\n// Usage\nconst response = await safeCallGenAI(\"Hello\");\nif (response) console.log(response);\nelse console.log(\"Failed to get response\");"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Parallel Execution with Promise.all"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ✅ Call multiple AI models simultaneously\nasync function callMultipleModels(prompts: string[]) {\n  const results = await Promise.all(\n    prompts.map(prompt => callGenAI(prompt))  // ✅ All run in parallel\n  );\n  return results;  // ✅ Array of responses\n}\n\n// ❌ DON'T: Sequential (slow)\nasync function callSequential(prompts: string[]) {\n  const results = [];\n  for (const prompt of prompts) {\n    const response = await callGenAI(prompt);  // ❌ Waits for each\n    results.push(response);\n  }\n  return results;\n}"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"6. "},{"type":"text","marks":[{"type":"bold"}],"text":"AsyncGenerators for Streaming AI Responses"},{"type":"text","text":" ⭐ Crucial for Gen AI"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ✅ AsyncGenerator: Stream AI tokens one-by-one\nasync function* streamAIResponse(prompt: string): AsyncGenerator<string> {\n  const res = await fetch(\"/api/ai/stream\", {\n    method: \"POST\",\n    body: JSON.stringify({ prompt, stream: true }),\n  });\n  \n  const reader = res.body!.getReader();\n  const decoder = new TextDecoder();\n  \n  while (true) {\n    const { done, value } = await reader.read();\n    if (done) break;\n    const chunk = decoder.decode(value);\n    yield chunk;  // ✅ Yield each token as it arrives\n  }\n}\n\n// ✅ Usage: Real-time streaming\nasync function displayStreamingResponse() {\n  const stream = streamAIResponse(\"Explain quantum computing\");\n  \n  for await (const token of stream) {  // ✅ for-await loop\n    console.log(token);  // ✅ Prints token immediately\n    updateUI(token);     // ✅ Update UI in real-time\n  }\n}"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Gemini CLI example"},{"type":"text","text":" uses AsyncGenerator for streaming:"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"async generateContentStream(\n  req: GenerateContentParameters\n): Promise<AsyncGenerator<GenerateContentResponse>> {\n  const resps = await this.requestStreamingPost(\n    'streamGenerateContent',\n    req\n  );\n  return (async function* (): AsyncGenerator<GenerateContentResponse> {\n    for await (const resp of resps) {\n      yield fromGenerateContentResponse(resp);  // ✅ Stream each token\n    }\n  });\n}  // [web:36]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use (Decision Criteria)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use async/await"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use.then()"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use AsyncGenerator"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Single API call"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"code"}],"text":"await fetch()"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Legacy"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multiple parallel calls"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"code"}],"text":"Promise.all()"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Nested "},{"type":"text","marks":[{"type":"code"}],"text":".then()"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Streaming responses"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"code"}],"text":"for await (chunk of stream)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Error handling"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"code"}],"text":"try/catch"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ "},{"type":"text","marks":[{"type":"code"}],"text":".catch()"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"code"}],"text":"try/catch"},{"type":"text","text":" inside generator"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Readable code"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Synchronous-looking"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Callback chains"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Specialized"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Legacy code"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Refactor"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Existing"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rule of thumb:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"async/await"},{"type":"text","text":": Default for all async operations\n- "},{"type":"text","marks":[{"type":"bold"}],"text":".then()"},{"type":"text","text":": Only for legacy code or when you need granular control\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"AsyncGenerator"},{"type":"text","text":": Real-time streaming (LLM tokens, chat messages)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How to Implement (Step-by-Step)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 1: Create Async API Client"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// api/genAI.ts\ninterface AIResponse {\n  text: string;\n  confidence: number;\n}\n\nexport async function callGenAI(prompt: string): Promise<AIResponse> {\n  const res = await fetch(\"/api/ai\", {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ prompt }),\n  });\n  \n  if (!res.ok) throw new Error(`API error: ${res.status}`);\n  return res.json() as Promise<AIResponse>;\n}"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 2: Use in React Component"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// components/AIChat.tsx\nimport { callGenAI } from \"../api/genAI\";\n\nexport function AIChat() {\n  const [response, setResponse] = useState<AIResponse | null>(null);\n  const [loading, setLoading] = useState(false);\n\n  // ✅ Async event handler\n  const handleSubmit = async (prompt: string) => {\n    setLoading(true);\n    try {\n      const data = await callGenAI(prompt);  // ✅ Waits for response\n      setResponse(data);\n    } catch (error) {\n      if (error instanceof Error) {\n        console.error(error.message);\n      }\n      setResponse(null);\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  return (\n    <div>\n      {loading ? <p>Loading...</p> : response && <p>{response.text}</p>}\n    </div>\n  );\n}"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 3: Add Streaming Support"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// api/streamGenAI.ts\nexport async function* streamGenAI(prompt: string): AsyncGenerator<string> {\n  const res = await fetch(\"/api/ai/stream\", {\n    method: \"POST\",\n    body: JSON.stringify({ prompt, stream: true }),\n  });\n  \n  const reader = res.body!.getReader();\n  const decoder = new TextDecoder();\n  \n  while (true) {\n    const { done, value } = await reader.read();\n    if (done) break;\n    yield decoder.decode(value);\n  }\n}\n\n// components/StreamingAIChat.tsx\nexport function StreamingAIChat() {\n  const [fullText, setFullText] = useState(\"\");\n\n  const handleStream = async (prompt: string) => {\n    const stream = streamGenAI(prompt);\n    \n    for await (const token of stream) {  // ✅ Real-time streaming\n      setFullText(fullText + token);\n    }\n  };\n\n  return <div>{fullText}</div>;\n}"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Examples"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 1: OpenAI API with TypeScript"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import { OpenAI } from \"openai\";\n\nasync function generateText(prompt: string): Promise<string> {\n  const openai = new OpenAI({ apiKey: process.env.OPENAI_API_KEY });\n  \n  const response = await openai.chat.completions.create({\n    model: \"gpt-4\",\n    messages: [{ role: \"user\", content: prompt }],\n  });\n  \n  return response.choices[0].message.content!;  // ✅ Await returns value\n}\n\nconst text = await generateText(\"Explain quantum computing\");\nconsole.log(text);"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 2: OpenAI Streaming with AsyncGenerator"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import { OpenAI } from \"openai\";\n\nasync function* streamText(prompt: string): AsyncGenerator<string> {\n  const openai = new OpenAI({ apiKey: process.env.OPENAI_API_KEY });\n  \n  const stream = await openai.chat.completions.create({\n    model: \"gpt-4\",\n    messages: [{ role: \"user\", content: prompt }],\n    stream: true,\n  });\n  \n  for await (const chunk of stream) {\n    const content = chunk.choices[0].delta.content;\n    if (content) yield content;  // ✅ Stream each token\n  }\n}\n\n// Usage\nasync function displayStreaming() {\n  for await (const token of streamText(\"Explain quantum computing\")) {\n    console.log(token);  // ✅ Real-time output\n  }\n}"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example 3: Google Gemini SDK Streaming"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import { GoogleGenerativeAI } from \"@google/generative-ai\";\n\nasync function* streamGemini(prompt: string): AsyncGenerator<string> {\n  const genAI = new GoogleGenerativeAI(process.env.API_KEY);\n  const model = genAI.getGenerativeModel({ model: \"gemini-1.5-flash\" });\n  \n  const result = await model.generateContentStream(prompt);\n  for await (const chunk of result.stream) {\n    const text = chunk.text();\n    yield text;  // ✅ Stream tokens\n  }\n}"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Real-World Example: Production Chat App with Streaming"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Scale"},{"type":"text","text":": 10K+ users, real-time LLM streaming\n"},{"type":"text","marks":[{"type":"bold"}],"text":"Constraints"},{"type":"text","text":": LLM takes 2-5 seconds per response\n"},{"type":"text","marks":[{"type":"bold"}],"text":"Architecture"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Frontend (Next.js + React):\n├── api/genAI.ts (async callGenAI function)\n├── api/streamGenAI.ts (AsyncGenerator for streaming)\n├── components/AIChat.tsx (async event handler)\n├── components/StreamingAIChat.tsx (for-await loop)\n└── hooks/useAIStream.ts (custom hook with AbortController)\n\nBackend (Next.js API Routes):\n├── routes/api/ai.ts (async POST handler)\n├── routes/api/ai/stream.ts (streaming endpoint)\n└── lib/openai.ts (streaming client)\n\nBenefits:\n- UI stays responsive during 2-5s LLM wait\n- Real-time token streaming (not wait-all)\n- AbortController cancels long requests\n- Error handling with try/catch"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Outcome"},{"type":"text","text":": Users see tokens appear instantly instead of waiting 5s for full response."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Common Mistakes to Avoid"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Mistake"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Consequenc