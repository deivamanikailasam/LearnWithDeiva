{"format":"tiptap/v1","updatedAt":"2026-06-22T09:27:27.158Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What Tokenizers Library Is"}]},{"type":"paragraph","content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"bold"}],"text":"Tokenizers library"},{"type":"text","text":" is a fast, state-of-the-art tokenization library from Hugging Face that provides "},{"type":"text","marks":[{"type":"bold"}],"text":"extremely fast tokenizers optimized for research and production"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","text":"Built in "},{"type":"text","marks":[{"type":"bold"}],"text":"Rust"},{"type":"text","text":" for performance, it takes less than 20 seconds to tokenize a GB of text on a server's CPU, providing implementations of today's most used tokenizers with focus on performance and versatility."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why Tokenizers Library Matters in Generative AI"}]},{"type":"paragraph","content":[{"type":"text","text":"Tokenizers is essential text preprocessing infrastructure:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Feature"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Impact"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rust implementation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Extremely fast (both training and tokenization)"}]}]}]},{"type":"tableRow",