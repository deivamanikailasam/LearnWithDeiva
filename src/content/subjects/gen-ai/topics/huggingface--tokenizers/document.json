ent":[{"type":"text","text":"Truncate, pad, add special tokens automatically"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Tokenizers provides "},{"type":"text","marks":[{"type":"bold"}],"text":"fast state-of-the-art tokenizers"},{"type":"text","text":" that are essential for preparing text inputs for transformer models."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How Tokenizers Work"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Tokenizer Pipeline"}]},{"type":"paragraph","content":[{"type":"text","text":"A Tokenizer works as a "},{"type":"text","marks":[{"type":"bold"}],"text":"pipeline"},{"type":"text","text":" that processes raw text and outputs an "},{"type":"text","marks":[{"type":"code"}],"text":"Encoding"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Raw Text → Encoding"}]},{"type":"paragraph","content":[{"type":"text","text":"The pipeline consists of four steps:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Normalizer"},{"type":"text","text":": Normalize text (e.g., Unicode normalization NFD, NFKC)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PreTokenizer"},{"type":"text","text":": Create initial word splits (e.g., whitespace splitting)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Model"},{"type":"text","text":": Perform actual tokenization (e.g., BPE, WordPiece)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PostProcessor"},{"type":"text","text":": Post-process encoding (add special tokens for language models)"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Preprocessing Pipeline"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Raw Input\n    ↓\n [github](https://github.com/huggingface/tokenizers) Normalizer → Unicode normalization\n    ↓\n [github](https://github.com/huggingface/tokenizers/blob/main/tokenizers/README.md) PreTokenizer → Split into words (whitespace)\n    ↓\n [huggingface](https://huggingface.co/docs/transformers/en/index) Model → Tokenize (BPE/WordPiece/Unigram)\n    ↓\n [huggingface](https://huggingface.co/docs/transformers/en/main_classes/tokenizer) PostProcessor → Add special tokens\n    ↓\nFinal Encoding (tokens + metadata)"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Features"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Train New Vocabularies"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Train custom tokenizer\nfrom tokenizers import Tokenizer\nfrom tokenizers.models import BPE\n\ntokenizer = Tokenizer(BPE())"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Train new vocabularies and tokenize"},{"type":"text","text":" using today's most used tokenizers."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Customizable Pre-tokenization"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Customize pre-tokenization (splitting into words)\nfrom tokenizers.pre_tokenizers import Whitespace\n\ntokenizer.pre_tokenizer = Whitespace()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Customize how pre-tokenization"},{"type":"text","text":" (e.g., splitting into words) is done."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Alignment Tracking"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Get original text span for each token\n# Offset tracking feature"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Normalization comes with alignments tracking"},{"type":"text","text":" — always possible to get the part of the original sentence that corresponds to a given token."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key functionality"},{"type":"text","text":": Fast tokenizers keep track of the "},{"type":"text","marks":[{"type":"bold"}],"text":"original span of texts"},{"type":"text","text":" the final tokens come from — called "},{"type":"text","marks":[{"type":"bold"}],"text":"offset tracking"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Complete Pre-processing"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Does all pre-processing automatically\n# - Truncate\n# - Pad\n# - Add special tokens"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Does all the pre-processing"},{"type":"text","text":": Truncate, pad, add special tokens your model needs."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Supported Tokenizer Models"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Main Tokenizers"}]},{"type":"paragraph","content":[{"type":"text","text":"Provides implementation of today's most used tokenizers:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Model"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Description"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","m