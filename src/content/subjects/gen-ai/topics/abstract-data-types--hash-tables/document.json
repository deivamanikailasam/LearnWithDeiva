null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(log n)"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Gen AI Applications"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Token Vocabulary Index"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Hash table for O(1) token → ID lookup (LLM tokenizer)\ntoken_vocab = {\n    \"the\": 1,\n    \"cat\": 2,\n    \"sat\": 3,\n    \"on\": 4,\n    \"mat\": 5\n}\n\n# Tokenize: O(n) for n tokens\ntext = \"the cat sat on the mat\"\ntokens = text.split()\ntoken_ids = [token_vocab.get(token, 0) for token in tokens]  # ✅ O(1) per token\nprint(token_ids)  # ✅ [1, 2, 3, 4, 1, 5] [web:148][web:151]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Feature Engineering (NLP)"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Hash table for categorical feature grouping (NLP)\nuser_categories = {\n    \"user1\": [\"sports\", \"tech\"],\n    \"user2\": [\"tech\", \"books\"],\n    \"user3\": [\"sports\", \"books\"]\n}\n\n# Count category frequencies: O(n)\ncategory_freq = {}\nfor user, categories in user_categories.items():\n    for category in categories:\n        category_freq[category] = category_freq.get(category, 0) + 1  # ✅ O(1) [web:148][web:151]\n\nprint(category_freq)  # ✅ {\"sports\": 2, \"tech\": 2, \"books\": 2} [web:151]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Duplicate Elimination (Hash Set)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Hash set (no values) for O(1) duplicate check\ntext = \"the cat sat on the mat\"\nwords = text.split()\n\n# Find unique words: O(n)\nunique_words = set()\nfor word in words:\n    unique_words.add(word)  # ✅ O(1) check + insert [web:151][web:153]\n\nprint(unique_words)  # ✅ {\"the\", \"cat\", \"sat\", \"on\", \"mat\"} [web:151][web:153]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"O(1) average time"},{"type":"text","text":": Lookup/insert/delete = constant time"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hash function"},{"type":"text","text":": Maps key → index (e.g., "},{"type":"text","marks":[{"type":"code"}],"text":"sum(ord(char)) % size"},{"type":"text","text":")"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Collision handling"},{"type":"text","text":": Separate chaining (lists) or open addressing (probing)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Any key type"},{"type":"text","text":": Strings, objects, integers as keys"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use for"},{"type":"text","text":": Fast lookups, dictionaries, caches, frequency counting, duplicate elimination"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Python dict"},{"type":"text","text":": Built-in hash table ("},{"type":"text","marks":[{"type":"code"}],"text":"{key: value}"},{"type":"text","text":")"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Since you're a full-stack engineer working on Gen AI, hash tables are essential for building fast token vocabularies (O(1) token → ID lookup), implementing LLM response caches (avoid re-computation), and performing feature engineering in NLP (frequency counting, categorical grouping)."}]}]}}
