ll","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Ordering"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No inherent order"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Sequential"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Sorted"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key type"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Any (string, object, int)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Index (int only)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Comparable (int, string)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Space"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n) + overhead"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n)"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why It Matters for Gen AI"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ❌ WITHOUT hash table: O(n) token lookup (slow)\nvocabulary = [\"apple\", \"banana\", \"cat\", \"dog\", \"elephant\"]  # Array\ndef find_token(token):\n    for i, word in vocabulary:  # ✅ O(n) linear search\n        if word == token:\n            return i\n    return -1\n\nfind_token(\"elephant\")  # ❌ Must check all 5 words (5 steps)\n\n# ✅ WITH hash table: O(1) token lookup (instant)\nvocabulary = {\n    \"apple\": 0,\n    \"banana\": 1,\n    \"cat\": 2,\n    \"dog\": 3,\n    \"elephant\": 4\n}  # ✅ Hash table (dict in Python) [web:148][web:151]\n\ndef find_token(token):\n    return vocabulary.get(token, -1)  # ✅ O(1) lookup\n\nfind_token(\"elephant\")  # ✅ Returns 4 in O(1) (1 step) [web:148][web:151]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Fast lookup"},{"type":"text","text":": O(1) average vs O(n) for arrays\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Any key type"},{"type":"text","text":": Strings, objects, integers as keys\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Feature engineering"},{"type":"text","text":": Fast grouping, counting, frequency analysis in NLP\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Caching"},{"type":"text","text":": Store LLM responses for quick retrieval (avoid re-computation)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How It Works (Core Mechanics)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Hash Function"},{"type":"text","text":" ⭐ Maps Key to Index"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Hash function: key → index (0 to size-1)\ndef simple_hash(key, size):\n    # Convert string to integer (sum of character codes)\n    total = sum(ord(char) for char in key)\n    return total % size  # ✅ Modulo to fit in array [web:148][web:149]\n\n# Example:\nsimple_hash(\"apple\", 10)  # ✅ ord('a')=97, ord('p')=112, ... → sum=510 → 510%10=0\nsimple_hash(\"banana\", 10)  # ✅ sum=505 → 505%10=5 [web:148]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Hash Table Structure"},{"type":"text","text":" (Array + Hash Function)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Hash table: Array of size N\nhash_table = [None] * 10  # ✅ Array of size 10\n\n# Insert: hash(key) → index → store value\nkey = \"apple\"\nvalue = 0\nindex = simple_hash(key, 10)  # ✅ 0\nhash_table[index] = value  # ✅ hash_table[0] = 0 [web:148][web:149]\n\n# Lookup: hash(key) → index → retrieve value\nkey = \"apple\"\nindex = simple_hash(key, 10)  # ✅ 0\nvalue = hash_table[index]  # ✅ value = 0 [web:148]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Collision Handling"},{"type":"text","text":": When Two Keys Hash to Same Index"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ❌ Collision: Two keys → same index\nindex1 = simple_hash(\"apple\", 10)  # ✅ 0\nindex2 = simple_hash(\"apricot\", 10)  # ✅ Also 0 (collision!) [web:149]\n\n# ✅ Solution 1: Separate Chaining (linked list at each index)\nhash_table = [[] for _ in range(10)]  # ✅ Array of lists\n\n# Insert with chaining\nkey1 = \"apple\"\nvalue1 = 0\nindex1 = simple_hash(key1, 10)\nhash_table[index1].append((key1, value1))  # ✅ [(\"apple\", 0)]\n\nkey2 = \"apricot\"\nvalue2 = 5\nindex2 = simple_hash(key2, 10)\nhash_table[index2].append((key2, value2))  # ✅ [(\"apple\", 0), (\"apricot\", 5)] [web:149]\n\n# ✅ Solution 2: Open Addressing (find next empty slot)\nhash_table = [None] * 10\n\n# Insert with linear probing\ndef insert_open_addressing(key, value, size):\n    index = simple_hash(key, size)\n    while hash_table[index] is not None:\n        index = (index + 1) % size  # ✅ Next slot (linear probing)\n    hash_table[index] = (key, value)  # ✅ Store [web:149]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Python's "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"dict"},{"type":"text","marks":[{"type":"bold"}],"text":" (Built-in Hash Table)"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Python dict = hash table (O(1) average)\nvocabulary = {\n    \"apple\": 0,\n    \"banana\": 1,\n    \"cat\": 2\n}\n\n# ✅ Insert: O(1)\nvocabulary[\"dog\"] = 3  # ✅ O(1) [web:148][web:151]\n\n# ✅ Lookup: O(1)\nprint(vocabulary[\"apple\"])  # ✅ 0 (O(1)) [web:148][web:151]\n\n# ✅ Delete: O(1)\ndel vocabulary[\"cat\"]  # ✅ O(1) [web:148][web:151]\n\n# ✅ Check existence: O(1)\nprint(\"apple\" in vocabulary)  # ✅ True (O(1)) [web:148][web:153]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Word Frequency Analysis (Hash Table for NLP)"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Hash table for counting word frequencies (NLP feature engineering)\ntext = \"The cat sat on the mat. The cat was happy.\"\n\n# Build frequency hash table: O(n)\nfrequency = {}\nfor word in text.split():\n    word = word.lower().strip(\".\")  # Normalize\n    frequency[word] = frequency.get(word, 0) + 1  # ✅ O(1) increment [web:148][web:151]\n\nprint(frequency)  # ✅ {\"the\": 2, \"cat\": 2, \"sat\": 1, \"on\": 1, \"mat\": 1, \"was\": 1, \"happy\": 1} [web:151][web:153]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"6. "},{"type":"text","marks":[{"type":"bold"}],"text":"LLM Response Caching (Hash Table for Speed)"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Hash table cache: Store LLM responses to avoid re-computation\nllm_cache = {}\n\ndef generate_response(prompt):\n    # Check cache: O(1)\n    if prompt in llm_cache:\n        return llm_cache[prompt]  # ✅ Return cached response [web:149][web:152]\n    \n    # Generate new response (slow: 2-5 seconds)\n    response = \"This is the LLM response for: \" + prompt\n    \n    # Cache: O(1)\n    llm_cache[prompt] = response  # ✅ Store [web:149][web:152]\n    return response\n\n# First call: Slow (2-5 seconds)\nprint(generate_response(\"Explain quantum computing\"))  # ⏱️ 2-5 seconds\n\n# Second call: Instant (O(1) cache lookup)\nprint(generate_response(\"Explain quantum computing\"))  # ✅ Instant (cached) [web:149][web:152]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use (Decision Criteria)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Hash Table"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Array"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use BST"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fast lookup"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ O(1) average"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ O(1) (index)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ O(log n)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Any key type"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Strings, objects, ints"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Int index only"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Comparable only"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Frequency counting"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ O(1) increment"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content