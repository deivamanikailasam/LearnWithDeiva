          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Nginx/proxy buffering"
                  },
                  {
                    "type": "text",
                    "text": ": Reverse proxies buffer responses by default, defeating streaming. Set "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "X-Accel-Buffering: no"
                  },
                  {
                    "type": "text",
                    "text": " (nginx) or "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "proxy_buffering off;"
                  },
                  {
                    "type": "text",
                    "text": " in config."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Empty delta content"
                  },
                  {
                    "type": "text",
                    "text": ": The first and last chunks may have "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "delta.content == None"
                  },
                  {
                    "type": "text",
                    "text": " (role-only or finish-reason chunks). Always use "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "delta.content or \"\""
                  },
                  {
                    "type": "text",
                    "text": " to avoid "
