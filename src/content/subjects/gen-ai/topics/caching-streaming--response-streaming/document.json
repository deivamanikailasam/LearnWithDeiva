    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "LLM generation is sequential: tokens arrive one at a time, each depending on the previous. Streaming sends each token to the client as it is generated rather than buffering the entire response. For a 200-word answer that takes 8 seconds to generate, streaming shows the first word in under 500 ms — transforming user perception from \"waiting\" to \"reading as it types\". Token-by-token delivery is the default expectation for any interactive LLM interface."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Streaming vs non-streaming comparison; token flow visualization; SDK patterns for OpenAI, FastAPI SSE, LangChain LCEL, and Anthropic; SSE wire format"
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "How Streaming Works"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "stream=True"
          },
          {
            "type": "text",
            "text": " is set, the API uses HTTP chunked transfer encoding (not WebSockets). Each chunk is a Server-Sent Event (SSE) — a small JSON object delivered as "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "data: <json>\\n\\n"
          },
          {
            "type": "text",
            "text": " on the wire. The final chunk is "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "data: [DONE]\\n\\n"
          },
          {
            "type": "text",
            "text": ". Each chunk's "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "choices[0].delta.content"
          },
          {
            "type": "text",
            "text": " contains the incremental text — typically one token, sometimes two or three."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "OpenAI SDK Streaming"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from openai import OpenAI\n\nclient = OpenAI()\n\n# Synchronous streaming\nwith client.chat.completions.stream(\n    model=\"gpt-4o-mini\",\n    messages=[{\"role\": \"user\", \"content\": \"Tell me a short story.\"}],\n    max_tokens=300,\n) as stream:\n    for text in stream.text_stream:\n        print(text, end=\"\", flush=True)\n\n# Access the final accumulated message after the loop\nfinal = stream.get_final_message()\nprint(f\"\\nTotal tokens: {final.usage.completion_tokens}\")"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Async Streaming"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\nfrom openai import AsyncOpenAI\n\nclient = AsyncOpenAI()\n\n\nasync def stream_to_string(prompt: str) -> str:\n    \"\"\"Accumulate a streamed response into a single string.\"\"\"\n    chunks = []\n    async with client.chat.completions.stream(\n        model=\"gpt-4o-mini\",\n        messages=[{\"role\": \"user\", \"content\": prompt}],\n    ) as stream:\n        async for text in stream.text_stream:\n            chunks.append(text)\n    return \"\".join(chunks)\n\n\nasync def main():\n    result = await stream_to_string(\"What is 2 + 2?\")\n    print(result)\n\nasyncio.run(main())"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Anthropic SDK Streaming"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import anthropic\n\nclient = anthropic.Anthropic()\n\n# Synchronous streaming with context manager\nwith client.messages.stream(\n    model=\"claude-sonnet-4-6\",\n    max_tokens=512,\n    messages=[{\"role\": \"user\", \"content\": \"Explain streaming in LLMs.\"}],\n) as stream:\n    for text in stream.text_stream:\n        print(text, end=\"\", flush=True)\n\n# Get usage stats after stream closes\nfinal_message = stream.get_final_message()\nprint(f\"\\nInput tokens: {final_message.usage.input_tokens}\")\nprint(f\"Output tokens: {final_message.usage.output_tokens}\")\n\n\n# Async version\nimport asyncio\nfrom anthropic import AsyncAnthropic\n\nasync_client = AsyncAnthropic()\n\nasync def async_stream(prompt: str):\n    async with async_client.messages.stream(\n        model=\"claude-sonnet-4-6\",\n        max_tokens=256,\n        messages=[{\"role\": \"user\", \"content\": prompt}],\n    ) as stream:\n        async for text in stream.text_stream:\n            yield text\n\nasync def main():\n    async for token in async_stream(\"Count to 5.\"):\n        print(token, end=\"\", flush=True)\n\nasyncio.run(main())"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "FastAPI Server-Sent Events Endpoint"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Expose a streaming endpoint from a FastAPI app using "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "StreamingResponse"
          },
          {
            "type": "text",
            "text": " with SSE format. The client can consume this with the "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "EventSource"
          },
          {
            "type": "text",
            "text": " browser API or "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "httpx"
          },
          {
            "type": "text",
            "text": " in Python."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import json\nfrom fastapi import FastAPI\nfrom fastapi.responses import StreamingResponse\nfrom openai import AsyncOpenAI\nfrom pydantic import BaseModel\n\napp = FastAPI()\nclient = AsyncOpenAI()\n\n\nclass ChatRequest(BaseModel):\n    message: str\n    model: str = \"gpt-4o-mini\"\n    max_tokens: int = 512\n\n\n@app.post(\"/chat/stream\")\nasync def chat_stream(req: ChatRequest):\n    async def event_generator():\n        try:\n            async with client.chat.completions.stream(\n                model=req.model,\n                messages=[{\"role\": \"user\", \"content\": req.message}],\n                max_tokens=req.max_tokens,\n            ) as stream:\n                async for text in stream.text_stream:\n                    # SSE format: 'data: <payload>\\n\\n'\n                    payload = json.dumps({\"token\": text})\n                    yield f\"data: {payload}\\n\\n\"\n                # Signal stream end\n                yield \"data: [DONE]\\n\\n\"\n        except Exception as e:\n            yield f\"data: {json.dumps({'error': str(e)})}\\n\\n\"\n\n    return StreamingResponse(\n        event_generator(),\n        media_type=\"text/event-stream\",\n        headers={\n            \"Cache-Control\": \"no-cache\",\n            \"X-Accel-Buffering\": \"no\",   # disable nginx buffering\n        },\n    )"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Client-Side: Consuming SSE"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Python client using httpx\nimport httpx\nimport json\n\nasync def stream_chat(message: str) -> str:\n    collected = []\n    async with httpx.AsyncClient() as http:\n        async with http.stream(\n            \"POST\",\n            \"http://localhost:8000/chat/stream\",\n            json={\"message\": message},\n            timeout=60.0,\n        ) as response:\n            async for line in response.aiter_lines():\n                if line.startswith(\"data: \"):\n                    payload = line[6:]  # strip 'data: '\n                    if payload == \"[DONE]\":\n                        break\n                    data = json.loads(payload)\n                    if \"error\" in data:\n                        raise RuntimeError(data[\"error\"])\n                    token = data[\"token\"]\n                    collected.append(token)\n                    print(token, end=\"\", flush=True)\n    print()\n    return \"\".join(collected)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "LangChain LCEL Streaming"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from langchain_openai import ChatOpenAI\nfrom langchain_core.prompts import ChatPromptTemplate\nfrom langchain_core.output_parsers import StrOutputParser\nimport asyncio\n\nllm = ChatOpenAI(model=\"gpt-4o-mini\", temperature=0.7, streaming=True)\nprompt = ChatPromptTemplate.from_messages([\n    (\"system\", \"You are a helpful assistant.\"),\n    (\"human\", \"{question}\"),\n])\nchain = prompt | llm | StrOutputParser()\n\n\n# Sync streaming with chain.stream()\nfor chunk in chain.stream({\"question\": \"Explain streaming in two sentences.\"}):\n    print(chunk, end=\"\", flush=True)\nprint()\n\n\n# Async streaming with chain.astream()\nasync def stream_async():\n    async for chunk in chain.astream({\"question\": \"Name three capitals.\"}):\n        print(chunk, end=\"\", flush=True)\n    print()\n\nasyncio.run(stream_async())\n\n\n# astream_events() for detailed event types\nasync def stream_with_events():\n    async for event in chain.astream_events(\n        {\"question\": \"What is Python?\"},\n        version=\"v2\",\n    ):\n        kind = event[\"event\"]\n        if kind == \"on_chat_model_stream\":\n            token = event[\"data\"][\"chunk\"].content\n            print(token, end=\"\", flush=True)\n        elif kind == \"on_chain_end\":\n            print(f\"\\n[Done: run_id={event['run_id']}]\")\n\nasyncio.run(stream_with_events())"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Streaming with LangChain in FastAPI"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import json\nfrom fastapi import FastAPI\nfrom fastapi.responses import StreamingResponse\nfrom langchain_openai import ChatOpenAI\nfrom langchain_core.prompts import ChatPromptTemplate\nfrom langchain_core.output_parsers import StrOutputParser\n\napp = FastAPI()\nllm = ChatOpenAI(model=\"gpt-4o-mini\", streaming=True)\nprompt = ChatPromptTemplate.from_messages([(\"human\", \"{question}\")])\nchain = prompt | llm | StrOutputParser()\n\n\n@app.get(\"/ask\")\nasync def ask(question: str):\n    async def generate():\n        async for chunk in chain.astream({\"question\": question}):\n            yield f\"data: {json.dumps({'chunk': chunk})}\\n\\n\"\n        yield \"data: [DONE]\\n\\n\"\n\n    return StreamingResponse(\n        generate(),\n        media_type=\"text/event-stream\",\n        headers={\"Cache-Control\": \"no-cache\"},\n    )"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Buffering for Downstream Processors"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Some downstream operations (structured output parsing, sentiment scoring) need the full text. Accumulate tokens without blocking the UI by writing to a queue: one consumer displays tokens, another collects them."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\nfrom openai import AsyncOpenAI\n\nclient = AsyncOpenAI()\n\n\nasync def stream_and_accumulate(prompt: str) -> tuple[asyncio.Queue, asyncio.Task]:\n    \"\"\"Return a queue of tokens and a background task accumulating the full text.\"\"\"\n    queue: asyncio.Queue[str | None] = asyncio.Queue()\n    full_text = []\n\n    async def producer():\n        async with client.chat.completions.stream(\n            model=\"gpt-4o-mini\",\n            messages=[{\"role\": \"user\", \"content\": prompt}],\n        ) as stream:\n            async for text in stream.text_stream:\n                full_text.append(text)\n                await queue.put(text)\n        await queue.put(None)   # sentinel: stream ended\n\n    task = asyncio.create_task(producer())\n    return queue, task, full_text\n\n\nasync def main():\n    queue, task, full_text = await stream_and_accumulate(\"Say hello.\")\n\n    while True:\n        token = await queue.get()\n        if token is None:\n            break\n        print(token, end=\"\", flush=True)\n\n    await task\n    print(f\"\\nFull response ({len(full_text)} chunks): {''.join(full_text)!r}\")\n\nasyncio.run(main())"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Error Handling in Streams"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\nfrom openai import AsyncOpenAI, APIError, APITimeoutError\n\nclient = AsyncOpenAI()\n\n\nasync def resilient_stream(prompt: str, retries: int = 3) -> str:\n    for attempt in range(retries):\n        chunks = []\n        try:\n            async with client.chat.completions.stream(\n                model=\"gpt-4o-mini\",\n                messages=[{\"role\": \"user\", \"content\": prompt}],\n                timeout=30.0,\n            ) as stream:\n                async for text in stream.text_stream:\n                    chunks.append(text)\n            return \"\".join(chunks)\n\n        except APITimeoutError:\n            if attempt < retries - 1:\n                wait = 2 ** attempt\n                print(f\"Timeout, retrying in {wait}s...\")\n                await asyncio.sleep(wait)\n            else:\n                raise\n\n        except APIError as e:\n            if e.status_code in (429, 500, 502, 503) and attempt < retries - 1:\n                wait = 2 ** attempt\n                print(f\"API error {e.status_code}, retrying in {wait}s...\")\n                await asyncio.sleep(wait)\n            else:\n                raise\n\n    raise RuntimeError(\"All retries exhausted\")"
          }
        ]
      },
