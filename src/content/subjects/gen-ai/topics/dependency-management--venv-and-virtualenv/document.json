{"format":"tiptap/v1","updatedAt":"2026-06-21T13:07:39.182Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Overview: Why Use Virtual Environments?"}]},{"type":"paragraph","content":[{"type":"text","text":"A "},{"type":"text","marks":[{"type":"bold"}],"text":"virtual environment"},{"type":"text","text":" is an isolated Python environment that allows you to manage project-specific dependencies without conflicts."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key benefits:"},{"type":"text","text":"\n- Keep dependencies "},{"type":"text","marks":[{"type":"bold"}],"text":"separate per project"},{"type":"text","text":"\n- Avoid "},{"type":"text","marks":[{"type":"bold"}],"text":"global package conflicts"},{"type":"text","text":"\n- Work on "},{"type":"text","marks":[{"type":"bold"}],"text":"different projects"},{"type":"text","text":" with different versions simultaneously\n- Ensure "},{"type":"text","marks":[{"type":"bold"}],"text":"reproducible environments"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","marks":[{"type":"code"}],"text":"venv"},{"type":"text","text":": Built-in Virtual Environments"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What is "},{"type":"text","marks":[{"type":"code"}],"text":"venv"},{"type":"text","text":"?"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"venv"},{"type":"text","text":" is a "},{"type":"text","marks":[{"type":"bold"}],"text":"built-in module"},{"type":"text","text":" that creates isolated Python environments, integrated into Python's standard library since version 3.3."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key features:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"No installation needed"},{"type":"text","text":" — comes with Pytho