{"format": "tiptap/v1", "updatedAt": "2026-06-22T03:43:52.432Z", "doc": {"type": "doc", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Polynomial Regression"}, {"type": "text", "text": " is a special type of "}, {"type": "text", "marks": [{"type": "bold"}], "text": "linear regression"}, {"type": "text", "text": " that models "}, {"type": "text", "marks": [{"type": "bold"}], "text": "non-linear (curved) relationships"}, {"type": "text", "text": " between input variables and a continuous output by fitting a polynomial equation (with powers like "}, {"type": "inlineMath", "attrs": {"latex": "x^{2}"}}, {"type": "text", "text": ", "}, {"type": "inlineMath", "attrs": {"latex": "x^{3}"}}, {"type": "text", "text": ", etc.) instead of a straight line."}]}, {"type": "image", "attrs": {"src": "data:image/svg+xml;base64,", "alt": "Polynomial Regression — concept overview"}}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "What It Is"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Despite modeling curved relationships, polynomial regression is still considered a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "linear model"}, {"type": "text", "text": " because it's "}, {"type": "text", "marks": [{"type": "bold"}], "text": "linear in the parameters"}, {"type": "text", "text": " (coefficients) — it estimates linear coefficients ("}, {"type": "inlineMath", "attrs": {"latex": "\\beta"}}, {"type": "text", "text": ") for each term ("}, {"type": "inlineMath", "attrs": {"latex": "x"}}, {"type": "text", "text": ", "}, {"type": "inlineMath", "attrs": {"latex": "x^{2}"}}, {"type": "text", "text": ", "}, {"type": "inlineMath", "attrs": {"latex": "x^{3}"}}, {"type": "text", "text": ") even though predictors are raised to powers."}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "General equation"}, {"type": "text", "text": " (degree "}, {"type": "inlineMath", "attrs": {"latex": "n"}}, {"type": "text", "text": " polynomial):"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "$$y = \\beta_0 + \\beta_1x + \\beta_2x^2 + \\beta_3x^3 +... + \\beta_nx^n + \\epsilon$$"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Where:\n- "}, {"type": "inlineMath", "attrs": {"latex": "y"}}, {"type": "text", "text": " = dependent variable (target)\n- "}, {"type": "inlineMath", "attrs": {"latex": "x"}}, {"type": "text", "text": " = independent variable (feature)\n- "}, {"type": "inlineMath", "attrs": {"latex": "\\beta_0"}}, {"type": "text", "text": " = intercept (constant)\n- "}, {"type": "inlineMath", "attrs": {"latex": "\\beta_1, \\beta_2,..., \\beta_n"}}, {"type": "text", "text": " = coefficients for each polynomial term\n- "}, {"type": "inlineMath", "attrs": {"latex": "n"}}, {"type": "text", "text": " = "}, {"type": "text", "marks": [{"type": "bold"}], "text": "degree"}, {"type": "text", "text": " of the polynomial (highest exponent)\n- "}, {"type": "inlineMath", "attrs": {"latex": "\\epsilon"}}, {"type": "text", "text": " = error term (residual)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Key names by degree"}, {"type": "text", "text": ":\n- "}, {"type": "inlineMath", "attrs": {"latex": "h = 2"}}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Quadratic"}, {"type": "text", "text": " (one bend)\n- "}, {"type": "inlineMath", "attrs": {"latex": "h = 3"}}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Cubic"}, {"type": "text", "text": " (two bends)\n- "}, {"type": "inlineMath", "attrs": {"latex": "h = 4"}}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Quartic"}, {"type": "text", "text": " (three bends)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Number of bends"}, {"type": "text", "text": " = degree − 1"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Why It Matters"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Problem with Linear Regression"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Solution with Polynomial Regression"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Assumes "}, {"type": "text", "marks": [{"type": "bold"}], "text": "straight-line"}, {"type": "text", "text": " relationship"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Captures "}, {"type": "text", "marks": [{"type": "bold"}], "text": "curved"}, {"type": "text", "text": " relationships"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Effect of "}, {"type": "inlineMath", "attrs": {"latex": "x"}}, {"type": "text", "text": " is "}, {"type": "text", "marks": [{"type": "bold"}], "text": "constant"}, {"type": "text", "text": " across range"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Effect of "}, {"type": "inlineMath", "attrs": {"latex": "x"}}, {"type": "text", "text": " "}, {"type": "text", "marks": [{"type": "bold"}], "text": "changes"}, {"type": "text", "text": " depending on its value"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Underfits"}, {"type": "text", "text": " non-linear data"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Better fit to real-world curvature"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Misses phenomena like diminishing returns"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Models diminishing returns, acceleration, inflection points"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Polynomial regression allows fitting "}, {"type": "text", "marks": [{"type": "bold"}], "text": "curved relationships"}, {"type": "text", "text": " rather than assuming a straight line."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "How It Works"}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "text": "Step-by-Step Process"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Start with linear features"}, {"type": "text", "text": ": Original input "}, {"type": "inlineMath", "attrs": {"latex": "x"}}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Create polynomial features"}, {"type": "text", "text": ": Generate "}, {"type": "inlineMath", "attrs": {"latex": "x^{2}"}}, {"type": "text", "text": ", "}, {"type": "inlineMath", "attrs": {"latex": "x^{3}"}}, {"type": "text", "text": ",..., "}, {"type": "inlineMath", "attrs": {"latex": "x^{n}"}}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Fit linear regression"}, {"type": "text", "text": " on transformed features ("}, {"type": "inlineMath", "attrs": {"latex": "x, x^{2}, x^{3},..."}}, {"type": "text", "text": ")"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Estimate coefficients"}, {"type": "text", "text": " using least squares method"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Result"}, {"type": "text", "text": ": A curved line that fits non-linear data better"}]}]}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "text": "Transformation Example"}]}, {"type": "codeBlock", "attrs": {"language": "yaml"}, "content": [{"type": "text", "text": "Original data: x = [1, 2, 3, 4, 5]\n\nQuadratic features (degree=2):\nx     x²\n1  →  1\n2  →  4\n3  →  9\n4  →  16\n5  →  25\n\nLinear regression fits: y = β₀ + β₁x + β₂x²\nResult: Curved parabola"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The model treats "}, {"type": "inlineMath", "attrs": {"latex": "x^{2}"}}, {"type": "text", "text": " as a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "new feature"}, {"type": "text", "text": ", so it's still linear regression on transformed data."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Visualization"}]}, {"type": "codeBlock", "attrs": {"language": "text"}, "content": [{"type": "text", "text": "Linear Regression:      Polynomial Regression:\n                       \n  y ↑                     y ↑\n    │   ●                 │      ●\n    │ ●   ●               │    ●   ●\n    │   ●                 │  ●       ●\n    │ ●                   │●           ●\n    │_________________ x  │_______________ x\n     Straight line        Curved line (fits better)"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Polynomial regression captures the curvature that linear regression misses."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Real-World Example: Crop Yield vs. Fertilizer"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Scenario"}, {"type": "text", "text": ": Modeling crop yield as a function of fertilizer use."}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Model Type"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Prediction"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Linear"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Yield increases constantly with fertilizer (straight line)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Polynomial (quadratic)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Yield initially increases, then "}, {"type": "text", "marks": [{"type": "bold"}], "text": "levels off and declines"}, {"type": "text", "text": " at high fertilizer levels"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Why polynomial fits better"}, {"type": "text", "text": ":\n- Excessive fertilizer "}, {"type": "text", "marks": [{"type": "bold"}], "text": "reduces"}, {"type": "text", "text": " crop efficiency (diminishing returns)\n- This creates a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "curved relationship"}, {"type": "text", "text": " (inverted U-shape)\n- Linear model can't capture this; polynomial captures the real-world curvature"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "$$\\text{Yield} = \\beta_0 + \\beta_1(\\text{Fertilizer}) + \\beta_2(\\text{Fertilizer}^2)$$"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "When to Use Polynomial Regression"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "✅ Use When"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "❌ Don't Use When"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Relationship is "}, {"type": "text", "marks": [{"type": "bold"}], "text": "non-linear"}, {"type": "text", "text": " (curved)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Relationship is truly "}, {"type": "text", "marks": [{"type": "bold"}], "text": "linear"}, {"type": "text", "text": " (use simple linear regression)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "You see "}, {"type": "text", "marks": [{"type": "bold"}], "text": "bends/inflection points"}, {"type": "text", "text": " in scatter plot"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Data has "}, {"type": "text", "marks": [{"type": "bold"}], "text": "no clear pattern"}, {"type": "text", "text": " (random noise)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "You need "}, {"type": "text", "marks": [{"type": "bold"}], "text": "interpretable"}, {"type": "text", "text": " coefficients (unlike neural nets)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Need to model "}, {"type": "text", "marks": [{"type": "bold"}], "text": "extremely complex"}, {"type": "text", "text": " patterns (use deep learning)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Sample size is "}, {"type": "text", "marks": [{"type": "bold"}], "text": "large"}, {"type": "text", "text": " (more data = more reliable fitted model)"}]}]}, {"type": "tabl