        "content": [
          {
            "type": "text",
            "text": "Schema Design for User Data in GenAI Applications"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A GenAI application's user data schema must handle more than a typical web application: it must track per-user model preferences, accumulate token usage for billing, store hashed API keys, and support GDPR erasure without corrupting foreign-key references. This sub-subtopic presents a production-ready five-table design and explains the reasoning behind each decision."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "User data schema: users, user_preferences, api_keys, usage_ledger, gdpr_requests \u2014 entity relationships and design notes"
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Full DDL"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "users"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "CREATE TABLE users (\n    id               UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    email            TEXT UNIQUE NOT NULL,\n    display_name     TEXT,\n    tier             TEXT NOT NULL DEFAULT 'free'\n                         CHECK (tier IN ('free', 'pro', 'enterprise')),\n    hashed_password  TEXT,                     -- NULL for OAuth-only accounts\n    email_verified   BOOLEAN NOT NULL DEFAULT FALSE,\n    created_at       TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    last_login_at    TIMESTAMPTZ,\n    deleted_at       TIMESTAMPTZ,              -- soft delete\n    gdpr_erased_at   TIMESTAMPTZ               -- set after GDPR erasure; PII has been nullified\n);\n\nCREATE INDEX users_email         ON users (email) WHERE deleted_at IS NULL;\nCREATE INDEX users_tier_created  ON users (tier, created_at DESC);"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "PII encryption:",
                "marks": [
                  {
                    "type": "bold"
                  }
                ]
              },
              {
                "type": "text",
                "text": " store "
              },
              {
                "type": "text",
                "text": "email",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " and "
              },
              {
                "type": "text",
                "text": "display_name",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " Fernet-encrypted in the database. The application layer decrypts them on read. This limits exposure if the database backup is compromised. Keep the Fernet key in a secrets manager (AWS Secrets Manager, GCP Secret Manager), not in environment variables on disk."
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "user_preferences"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "CREATE TABLE user_preferences (\n    user_id         UUID PRIMARY KEY REFERENCES users(id) ON DELETE CASCADE,\n    default_model   TEXT NOT NULL DEFAULT 'claude-haiku-4-5-20251001',\n    default_temp    REAL NOT NULL DEFAULT 0.7\n                        CHECK (default_temp BETWEEN 0 AND 1),\n    ui_theme        TEXT NOT NULL DEFAULT 'system'\n                        CHECK (ui_theme IN ('light', 'dark', 'system')),\n    locale          TEXT NOT NULL DEFAULT 'en',\n    system_prompt   TEXT,                      -- user's custom persona / instructions\n    extra           JSONB NOT NULL DEFAULT '{}',  -- absorbs future prefs without migrations\n    updated_at      TIMESTAMPTZ NOT NULL DEFAULT NOW()\n);"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The 1:1 relationship ("
          },
          {
            "type": "text",
            "text": "user_id",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " as primary key) guarantees exactly one preferences row per user. Creating it in the same transaction as the "
          },
          {
            "type": "text",
            "text": "users",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " row avoids the need for a nullable-preference join later:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "async def create_user(pool: asyncpg.Pool, email: str, hashed_password: str) -> str:\n    async with pool.acquire() as conn:\n        async with conn.transaction():\n            user_id = await conn.fetchval(\n                \"INSERT INTO users (email, hashed_password) VALUES ($1, $2) RETURNING id\",\n                email, hashed_password,\n            )\n            await conn.execute(\n                \"INSERT INTO user_preferences (user_id) VALUES ($1)\",\n                user_id,\n            )\n    return str(user_id)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "api_keys"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "CREATE TABLE api_keys (\n    id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    user_id     UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,\n    key_hash    TEXT NOT NULL,        -- SHA-256 of the raw key; never store the raw key\n    label       TEXT,                 -- user-visible name: \"CI pipeline\", \"VS Code\"\n    last_used   TIMESTAMPTZ,\n    revoked_at  TIMESTAMPTZ,\n    created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW()\n);\n\nCREATE INDEX api_keys_user    ON api_keys (user_id) WHERE revoked_at IS NULL;\nCREATE INDEX api_keys_hash    ON api_keys (key_hash) WHERE revoked_at IS NULL;"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import secrets, hashlib\n\ndef generate_api_key() -> tuple[str, str]:\n    \"\"\"Return (raw_key, hash). Store hash; show raw_key once to the user.\"\"\"\n    raw = \"sk-\" + secrets.token_urlsafe(32)\n    key_hash = hashlib.sha256(raw.encode()).hexdigest()\n    return raw, key_hash\n\nasync def authenticate_api_key(pool: asyncpg.Pool, raw_key: str) -> str | None:\n    \"\"\"Return user_id if key is valid and not revoked, else None.\"\"\"\n    key_hash = hashlib.sha256(raw_key.encode()).hexdigest()\n    async with pool.acquire() as conn:\n        row = await conn.fetchrow(\n            \"\"\"SELECT user_id FROM api_keys\n               WHERE key_hash = $1 AND revoked_at IS NULL\"\"\",\n            key_hash,\n        )\n        if row:\n            await conn.execute(\n                \"UPDATE api_keys SET last_used=NOW() WHERE key_hash=$1\", key_hash\n            )\n    return str(row[\"user_id\"]) if row else None"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "usage_ledger"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "CREATE TABLE usage_ledger (\n    id            UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    user_id       UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,\n    period        DATE NOT NULL,   -- first day of the billing month: DATE_TRUNC('month', NOW())\n    model         TEXT NOT NULL,\n    input_tokens  BIGINT NOT NULL DEFAULT 0,\n    output_tokens BIGINT NOT NULL DEFAULT 0,\n    cost_usd      NUMERIC(10, 6) NOT NULL DEFAULT 0,\n    updated_at    TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    CONSTRAINT usage_ledger_unique UNIQUE (user_id, period, model)\n);\n\nCREATE INDEX usage_user_period ON usage_ledger (user_id, period DESC);"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Use "
          },
          {
            "type": "text",
            "text": "ON CONFLICT DO UPDATE",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " for atomic, race-free token accumulation:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "INPUT_COST  = {\"claude-haiku-4-5-20251001\": 0.80,  \"claude-opus-4-8\": 15.0}  # per 1M tokens\nOUTPUT_COST = {\"claude-haiku-4-5-20251001\": 4.00,  \"claude-opus-4-8\": 75.0}\n\nasync def record_usage(\n    pool: asyncpg.Pool, user_id: str, model: str,\n    input_tokens: int, output_tokens: int,\n) -> None:\n    cost = (\n        input_tokens  / 1_000_000 * INPUT_COST.get(model, 0)\n        + output_tokens / 1_000_000 * OUTPUT_COST.get(model, 0)\n    )\n    async with pool.acquire() as conn:\n        await conn.execute(\n            \"\"\"INSERT INTO usage_ledger\n                   (user_id, period, model, input_tokens, output_tokens, cost_usd, updated_at)\n               VALUES ($1, DATE_TRUNC('month', NOW())::date, $2, $3, $4, $5, NOW())\n               ON CONFLICT (user_id, period, model) DO UPDATE SET\n                   input_tokens  = usage_ledger.input_tokens  + EXCLUDED.input_tokens,\n                   output_tokens = usage_ledger.output_tokens + EXCLUDED.output_tokens,\n                   cost_usd      = usage_ledger.cost_usd      + EXCLUDED.cost_usd,\n                   updated_at    = NOW()\"\"\",\n            user_id, model, input_tokens, output_tokens, cost,\n        )"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "gdpr_requests"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "CREATE TABLE gdpr_requests (\n    id           UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    user_id      UUID NOT NULL REFERENCES users(id),  -- keep after erasure for audit trail\n    kind         TEXT NOT NULL CHECK (kind IN ('erasure', 'export')),\n    requested_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    completed_at TIMESTAMPTZ,\n    status       TEXT NOT NULL DEFAULT 'pending'\n                     CHECK (status IN ('pending', 'processing', 'done', 'failed')),\n    operator_id  UUID,   -- which admin or automated job executed this\n    notes        TEXT\n);"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "GDPR Erasure Workflow"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When a user submits a right-to-erasure request, the application must:"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Nullify all direct PII in "
                  },
                  {
                    "type": "text",
                    "text": "users",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " (email, display_name, hashed_password)."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Delete the user's RAG source content (chunks, documents, sources) and conversation history."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Revoke all API keys."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Set "
                  },
                  {
                    "type": "text",
                    "text": "users.gdpr_erased_at",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " to record when the erasure was completed."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Mark the "
                  },
                  {
                    "type": "text",
                    "text": "gdpr_requests",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " row as done. Retain it for compliance audit \u2014 it contains no PII."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "async def execute_erasure(pool: asyncpg.Pool, request_id: str, operator_id: str) -> None:\n    async with pool.acquire() as conn:\n        async with conn.transaction():\n            req = await conn.fetchrow(\n                \"SELECT user_id FROM gdpr_requests WHERE id=$1 AND status='pending'\",\n                request_id,\n            )\n            if not req:\n                raise ValueError(f\"No pending erasure request {request_id}\")\n\n            user_id = req[\"user_id\"]\n\n            # 1. Nullify PII\n            await conn.execute(\n                \"\"\"UPDATE users SET\n                       email=NULL, display_name=NULL, hashed_password=NULL,\n                       gdpr_erased_at=NOW(), deleted_at=COALESCE(deleted_at, NOW())\n                   WHERE id=$1\"\"\",\n                user_id,\n            )\n            # 2. Revoke all API keys (keep rows for audit, remove usable secret)\n            await conn.execute(\n                \"UPDATE api_keys SET key_hash='erased', revoked_at=NOW() WHERE user_id=$1\",\n                user_id,\n            )\n            # 3. Hard-delete conversation + RAG data (CASCADE handles child rows)\n            await conn.execute(\n                \"DELETE FROM conversations WHERE user_id=$1\", user_id\n            )\n            await conn.execute(\n                \"DELETE FROM sources WHERE tenant_id=$1\", user_id\n            )\n            # 4. Mark request done\n            await conn.execute(\n                \"\"\"UPDATE gdpr_requests SET status='done', completed_at=NOW(), operator_id=$2\n                   WHERE id=$1\"\"\",\n                request_id, operator_id,\n            )"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Audit retention:",
                "marks": [
                  {
                    "type": "bold"
                  }
                ]
              },
              {
                "type": "text",
                "text": " the "
              },
              {
                "type": "text",
                "text": "gdpr_requests",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " row deliberately keeps "
              },
              {
                "type": "text",
                "text": "user_id",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " even after erasure so supervisory authorities can verify requests were honoured. The user_id UUID itself contains no PII \u2014 only the PII columns that were nullified do."
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Tier Enforcement and Quota Gates"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "TIER_LIMITS = {\n    \"free\":       {\"monthly_output_tokens\": 100_000,  \"max_conversations\": 20},\n    \"pro\":        {\"monthly_output_tokens\": 5_000_000, \"max_conversations\": 500},\n    \"enterprise\": {\"monthly_output_tokens\": None,      \"max_conversations\": None},  # unlimited\n}\n\nasync def check_quota(pool: asyncpg.Pool, user_id: str) -> None:\n    \"\"\"Raise QuotaExceededError if the user has exceeded their monthly token limit.\"\"\"\n    async with pool.acquire() as conn:\n        row = await conn.fetchrow(\n            \"\"\"SELECT u.tier, COALESCE(SUM(l.output_tokens), 0) AS used\n               FROM users u\n               LEFT JOIN usage_ledger l\n                   ON l.user_id = u.id AND l.period = DATE_TRUNC('month', NOW())::date\n               WHERE u.id = $1\n               GROUP BY u.tier\"\"\",\n            user_id,\n        )\n    limit = TIER_LIMITS[row[\"tier\"]][\"monthly_output_tokens\"]\n    if limit is not None and row[\"used\"] >= limit:\n        raise QuotaExceededError(f\"Monthly limit of {limit:,} output tokens reached\")"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# tests/test_user_schema.py\nimport pytest\n\n@pytest.mark.asyncio\nasync def test_create_user_creates_preferences(pg_pool):\n    user_id = await create_user(pg_pool, \"alice@example.com\", \"hashed\")\n    row = await pg_pool.fetchrow(\"SELECT * FROM user_preferences WHERE user_id=$1\", user_id)\n    assert row is not None\n    assert row[\"default_temp\"] == pytest.approx(0.7)\n\n@pytest.mark.asyncio\nasync def test_usage_ledger_idempotent(pg_pool):\n    user_id = await create_user(pg_pool, \"bob@example.com\", \"hashed\")\n    await record_usage(pg_pool, user_id, \"claude-haiku-4-5-20251001\", 1000, 500)\n    await record_usage(pg_pool, user_id, \"claude-haiku-4-5-20251001\", 500, 250)\n    row = await pg_pool.fetchrow(\n        \"SELECT input_tokens, output_tokens FROM usage_ledger WHERE user_id=$1\", user_id\n    )\n    assert row[\"input_tokens\"] == 1500\n    assert row[\"output_tokens\"] == 750\n\n@pytest.mark.asyncio\nasync def test_gdpr_erasure_nullifies_pii(pg_pool):\n    user_id = await create_user(pg_pool, \"carol@example.com\", \"hashed\")\n    req_id = await pg_pool.fetchval(\n        \"INSERT INTO gdpr_requests (user_id, kind) VALUES ($1, 'erasure') RETURNING id\", user_id\n    )\n    await execute_erasure(pg_pool, str(req_id), operator_id=\"system\")\n    u = await pg_pool.fetchrow(\"SELECT email, gdpr_erased_at FROM users WHERE id=$1\", user_id)\n    assert u[\"email\"] is None\n    assert u[\"gdpr_erased_at\"] is not None"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Five tables cover all user data concerns: identity ("
                  },
                  {
                    "type": "text",
                    "text": "users",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": "), settings ("
                  },
                  {
                    "type": "text",
                    "text": "user_preferences",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": "), authentication ("
                  },
                  {
                    "type": "text",
                    "text": "api_keys",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": "), billing ("
                  },
                  {
                    "type": "text",
                    "text": "usage_ledger",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": "), and compliance ("
                  },
                  {
                    "type": "text",
                    "text": "gdpr_requests",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": ")."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Encrypt PII columns at the application layer; store only SHA-256 hashes of API keys."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Use "
                  },
                  {
                    "type": "text",
                    "text": "ON CONFLICT DO UPDATE",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " in "
                  },
                  {
                    "type": "text",
                    "text": "usage_ledger",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " for atomic, concurrent-safe token accumulation."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "GDPR erasure nullifies PII in "
                  },
                  {
                    "type": "text",
                    "text": "users",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": ", hard-deletes conversation and RAG data, and revokes all API keys \u2014 all inside a single transaction."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The "
                  },
                  {
                    "type": "text",
                    "text": "extra JSONB",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
