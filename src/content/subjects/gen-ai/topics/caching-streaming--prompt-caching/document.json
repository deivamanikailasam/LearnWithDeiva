      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Measuring Cache Effectiveness"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Track cache hits in production to verify the feature is working. A cache hit rate below ~80% on stable prompts suggests a content-stability issue — something is changing in the prefix unexpectedly."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass, field\nfrom collections import deque\n\n@dataclass\nclass CacheStats:\n    reads: int = 0\n    writes: int = 0\n    input_tokens: int = 0\n    recent_hit_rates: deque = field(default_factory=lambda: deque(maxlen=100))\n\n    def record(self, usage) -> None:\n        # Works for both Anthropic and OpenAI usage objects\n        cached = getattr(usage, \"cache_read_input_tokens\",\n                 getattr(getattr(usage, \"prompt_tokens_details\", None),\n                         \"cached_tokens\", 0) or 0)\n        total_input = getattr(usage, \"input_tokens\",\n                     getattr(usage, \"prompt_tokens\", 0))\n\n        self.reads += cached\n        self.input_tokens += total_input\n        self.recent_hit_rates.append(1 if cached > 0 else 0)\n\n    @property\n    def hit_rate(self) -> float:\n        if not self.recent_hit_rates:\n            return 0.0\n        return sum(self.recent_hit_rates) / len(self.recent_hit_rates)\n\n    @property\n    def tokens_saved(self) -> int:\n        # Anthropic: cached tokens cost 10% → 90% savings on those tokens\n        # OpenAI: cached tokens cost 50% → 50% savings on those tokens\n        return self.reads  # compare to self.input_tokens for full picture\n\nstats = CacheStats()\n\n# After each API call:\nstats.record(response.usage)\nprint(f\"Cache hit rate: {stats.hit_rate:.1%}\")\nprint(f\"Tokens read from cache: {stats.reads:,}\")"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Dynamic content in the prefix"
                  },
                  {
                    "type": "text",
                    "text": ". Including a timestamp, request ID, or per-user data inside the system prompt before the cache breakpoint causes every request to be a cache miss. Move dynamic data to the user message."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Cache expiry on Anthropic"
                  },
                  {
                    "type": "text",
                    "text": ". Cache entries expire 5 minutes after last access. If your request rate is low (e.g. one request per 10 minutes), the cache expires between calls and you always pay the write fee. The OpenAI cache expires after 1 hour by default."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Forgetting the minimum size"
                  },
                  {
                    "type": "text",
                    "text": ". Both providers require at least 1024 tokens in the cached prefix. Short system prompts won't be cached regardless of the markup."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Cache write cost"
                  },
                  {
                    "type": "text",
                    "text": ". Anthropic charges a cache write fee (≈25% extra on the first write per entry). At very low request volumes the write cost can exceed the savings. Caching is most beneficial when the same prefix is used at least 2–3 times within the cache TTL."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Shared cache is per-organization, not per-user"
                  },
                  {
                    "type": "text",
                    "text": ". Multiple users hitting the same system prompt share the same cache, which is ideal for cost savings. There is no per-session isolation of cached KV state — only the prefix is cached, not inference state."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
