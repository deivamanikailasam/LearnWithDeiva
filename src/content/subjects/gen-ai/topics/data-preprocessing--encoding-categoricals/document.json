{"format":"tiptap/v1","updatedAt":"2026-06-22T04:10:19.738Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Encoding Categoricals"},{"type":"text","text":" is the process of converting categorical (non-numeric) variables into numerical format that machine learning models can process — since models can only train on floating-point values and cannot understand strings like \"dog\" or \"maple,\" we must transform categories into numerical vectors."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why Encoding is Necessary"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Core problem"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Computers only process numbers"},{"type":"text","text":" → models cannot train on strings\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Categorical data represents finite discrete values"},{"type":"text","text":" → categories, labels, or types\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Machine learning requires numerical input"},{"type":"text","text":" → must convert categories to numbers"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What is categorical data"},{"type":"text","text":":\n- Qualitative data divided into distinct groups or categories\n- Examples: gender, color, product type, country, language"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Types of Categorical Variables"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Definition"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Examples"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Nominal"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Categories without intrinsic order"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Gender (Male, Female), Color (Red, Blue, Green), Race, Languages"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Ordinal"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Categories with meaningful order/hierarchy"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Education (High School, Bachelor's, Master's), Rating (Poor, Fair, Good, Excellent)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key difference"},{"type":"text","text":": Nominal variables have no order → need special encoding; Ordinal variables have order → can use ordinal encoding."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"One-Hot Encoding"},{"type":"text","text":" (Dummy Encoding)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best for"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"bold"}],"text":"Nominal variables"},{"type":"text","text":" (no order)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it does"},{"type":"text","text":": Converts each category to a "},{"type":"text","marks":[{"type":"bold"}],"text":"binary column"},{"type":"text","text":" that takes value 0 or 1."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How One-Hot Encoding Works"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": Color variable with categories Red, Blue, Green"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Before:\n  Color\n  Red\n  Blue\n  Green\n\nAfter (One-Hot):\n  Color_Red  Color_Blue  Color_Green\n  1          0           0\n  0          1           0\n  0          0           1"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Process"},{"type":"text","text":":\n- Each unique category → separate boolean column\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"1 or True"},{"type":"text","text":" = category present\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"0 or False"},{"type":"text","text":" = category absent"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use One-Hot Encoding"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Case"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Reason"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":nu