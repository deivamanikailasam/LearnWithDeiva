      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Full DDL"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Sources"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "CREATE EXTENSION IF NOT EXISTS vector;\n\nCREATE TABLE sources (\n    id           UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    tenant_id    UUID NOT NULL,\n    url          TEXT,\n    title        TEXT,\n    media_type   TEXT NOT NULL DEFAULT 'text/plain',  -- 'application/pdf', 'text/html', etc.\n    checksum     TEXT,                                -- SHA-256 of raw bytes; NULL for streams\n    ingested_at  TIMESTAMPTZ,\n    status       TEXT NOT NULL DEFAULT 'pending'\n                     CHECK (status IN ('pending', 'processing', 'done', 'error')),\n    error_msg    TEXT,\n    metadata     JSONB,\n    created_at   TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    CONSTRAINT sources_tenant_url_unique UNIQUE (tenant_id, url)\n);\n\nCREATE INDEX src_tenant   ON sources (tenant_id);\nCREATE INDEX src_status   ON sources (status, ingested_at) WHERE status IN ('pending','processing');"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Documents"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "CREATE TABLE documents (\n    id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    source_id   UUID REFERENCES sources(id) ON DELETE CASCADE,\n    tenant_id   UUID NOT NULL,\n    lang        TEXT NOT NULL DEFAULT 'en',\n    token_count INT,\n    metadata    JSONB,           -- e.g. {\"author\":\"...\", \"section\":\"intro\", \"page_start\":1}\n    created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    updated_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    deleted_at  TIMESTAMPTZ      -- soft delete; exclude with WHERE deleted_at IS NULL\n);\n\nCREATE INDEX doc_tenant_active ON documents (tenant_id, deleted_at);\nCREATE INDEX doc_source        ON documents (source_id);\nCREATE INDEX doc_metadata      ON documents USING GIN (metadata jsonb_path_ops);"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Chunks"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "CREATE TABLE chunks (\n    id           UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    document_id  UUID NOT NULL REFERENCES documents(id) ON DELETE CASCADE,\n    tenant_id    UUID NOT NULL,                -- denormalised from documents for filter efficiency\n    chunk_index  INT NOT NULL,\n    content      TEXT NOT NULL,\n    embedding    VECTOR(1536),                 -- NULL until embedding job runs\n    token_count  INT,\n    strategy     TEXT NOT NULL DEFAULT 'fixed' CHECK (strategy IN ('fixed','semantic','sentence')),\n    overlap_n    INT NOT NULL DEFAULT 0,       -- token overlap with adjacent chunk\n    created_at   TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    CONSTRAINT chunks_doc_idx_unique UNIQUE (document_id, chunk_index)\n);\n\n-- Relational indexes\nCREATE INDEX chunk_doc    ON chunks (document_id);\nCREATE INDEX chunk_tenant ON chunks (tenant_id);\n\n-- Vector index (build after bulk ingest to avoid per-insert overhead)\nCREATE INDEX chunk_emb_hnsw ON chunks\n    USING hnsw (embedding vector_cosine_ops)\n    WITH (m = 16, ef_construction = 64);\n\n-- Full-text search index for hybrid retrieval\nCREATE INDEX chunk_fts ON chunks\n    USING GIN (to_tsvector('english', content));"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Retrieval Log"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "CREATE TABLE retrieval_log (\n    id           UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    chunk_id     UUID NOT NULL REFERENCES chunks(id) ON DELETE CASCADE,\n    message_id   UUID NOT NULL,              -- FK to messages table in conversation schema\n    rank         INT NOT NULL,               -- 1 = top result\n    score        REAL NOT NULL,              -- cosine similarity (0\u20131)\n    strategy     TEXT NOT NULL DEFAULT 'semantic',\n    retrieved_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    used_in_ctx  BOOLEAN NOT NULL DEFAULT FALSE,  -- true if included in prompt\n    feedback     SMALLINT CHECK (feedback IN (-1, 0, 1))  -- thumbs down/neutral/up\n);\n\nCREATE INDEX rl_chunk   ON retrieval_log (chunk_id);\nCREATE INDEX rl_message ON retrieval_log (message_id);\nCREATE INDEX rl_time    ON retrieval_log (retrieved_at DESC);"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Row-Level Security for Multi-Tenancy"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Enable PostgreSQL RLS to enforce tenant isolation at the database level, so a misconfigured query cannot leak another tenant's data:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "ALTER TABLE chunks ENABLE ROW LEVEL SECURITY;\n\nCREATE POLICY chunks_tenant_isolation ON chunks\n    USING (tenant_id = current_setting('app.current_tenant', true)::uuid);\n\n-- Repeat for sources, documents, retrieval_log"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# In asyncpg: set the session variable before executing any query\nasync def execute_as_tenant(pool: asyncpg.Pool, tenant_id: str, query: str, *args):\n    async with pool.acquire() as conn:\n        await conn.execute(f\"SET app.current_tenant = '{tenant_id}'\")\n        return await conn.fetch(query, *args)"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Security note:",
                "marks": [
                  {
                    "type": "bold"
                  }
                ]
              },
              {
                "type": "text",
                "text": " never interpolate "
              },
              {
                "type": "text",
                "text": "tenant_id",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " directly into SQL strings. Always use the RLS policy or parameterised queries. The "
              },
              {
                "type": "text",
                "text": "SET",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " approach is session-scoped \u2014 reset it before returning the connection to the pool, or use a transaction-scoped setting."
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Ingestion Pipeline"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncpg, hashlib\n\nasync def ingest_source(pool: asyncpg.Pool, tenant_id: str, url: str, raw_bytes: bytes, title: str = \"\") -> str:\n    checksum = hashlib.sha256(raw_bytes).hexdigest()\n    async with pool.acquire() as conn:\n        # Idempotent: skip if already ingested with same content\n        existing = await conn.fetchval(\n            \"SELECT id FROM sources WHERE tenant_id=$1 AND url=$2 AND checksum=$3\",\n            tenant_id, url, checksum,\n        )\n        if existing:\n            return str(existing)\n\n        source_id = await conn.fetchval(\n            \"\"\"INSERT INTO sources (tenant_id, url, title, checksum, status)\n               VALUES ($1, $2, $3, $4, 'pending')\n               ON CONFLICT (tenant_id, url) DO UPDATE\n                   SET checksum=EXCLUDED.checksum, status='pending', error_msg=NULL\n               RETURNING id\"\"\",\n            tenant_id, url, title, checksum,\n        )\n    return str(source_id)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Chunking and embedding"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "async def ingest_chunks(\n    pool: asyncpg.Pool,\n    source_id: str,\n    tenant_id: str,\n    content: str,\n    chunk_size: int = 512,\n    overlap: int = 64,\n) -> None:\n    # Simple fixed-size token chunking\n    words = content.split()\n    chunks = []\n    i = 0\n    while i < len(words):\n        window = words[max(0, i - overlap) : i + chunk_size]\n        chunks.append(\" \".join(window))\n        i += chunk_size\n\n    async with pool.acquire() as conn:\n        # Create parent document\n        doc_id = await conn.fetchval(\n            \"\"\"INSERT INTO documents (source_id, tenant_id, token_count)\n               VALUES ($1, $2, $3) RETURNING id\"\"\",\n            source_id, tenant_id, len(words),\n        )\n\n        for idx, chunk_text in enumerate(chunks):\n            embedding = await embed(chunk_text)  # your embedding function\n            await conn.execute(\n                \"\"\"INSERT INTO chunks\n                       (document_id, tenant_id, chunk_index, content, embedding, token_count, overlap_n)\n                   VALUES ($1, $2, $3, $4, $5::vector, $6, $7)\n                   ON CONFLICT (document_id, chunk_index) DO UPDATE\n                       SET content=EXCLUDED.content, embedding=EXCLUDED.embedding\"\"\",\n                doc_id, tenant_id, idx, chunk_text, embedding, len(chunk_text.split()), overlap,\n            )\n\n        await conn.execute(\n            \"UPDATE sources SET status='done', ingested_at=NOW() WHERE id=$1\",\n            source_id,\n        )"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Retrieval with Audit Logging"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "async def retrieve_and_log(\n    pool: asyncpg.Pool,\n    query_embedding: list[float],\n    tenant_id: str,\n    message_id: str,\n    top_k: int = 10,\n    score_threshold: float = 0.75,\n) -> list[dict]:\n    async with pool.acquire() as conn:\n        rows = await conn.fetch(\n            \"\"\"SELECT c.id, c.content, 1 - (c.embedding <=> $1::vector) AS score\n               FROM chunks c\n               JOIN documents d ON d.id = c.document_id\n               WHERE c.tenant_id = $2\n                 AND d.deleted_at IS NULL\n                 AND 1 - (c.embedding <=> $1::vector) >= $3\n               ORDER BY c.embedding <=> $1::vector\n               LIMIT $4\"\"\",\n            query_embedding, tenant_id, score_threshold, top_k,\n        )\n\n        # Log retrievals\n        for rank, row in enumerate(rows, start=1):\n            await conn.execute(\n                \"\"\"INSERT INTO retrieval_log\n                       (chunk_id, message_id, rank, score, used_in_ctx)\n                   VALUES ($1, $2, $3, $4, $5)\"\"\",\n                row[\"id\"], message_id, rank, float(row[\"score\"]),\n                rank <= 5,  # only top-5 actually fit in the prompt window\n            )\n\n    return [{\"content\": r[\"content\"], \"score\": float(r[\"score\"])} for r in rows]"
          }
        ]
      },
