        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Use "
          },
          {
            "type": "text",
            "text": "CREATE INDEX ON documents USING GIN (metadata jsonb_path_ops)",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " to make these filters fast. The GIN index supports "
          },
          {
            "type": "text",
            "text": "@>",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " containment and "
          },
          {
            "type": "text",
            "text": "->>",
            "marks": [
              {
                "type": "code"
              }
            ]
