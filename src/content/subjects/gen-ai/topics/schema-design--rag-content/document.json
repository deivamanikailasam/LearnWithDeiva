        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Soft Delete and Re-ingestion"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When a source document is deleted or updated, soft-delete the "
          },
          {
            "type": "text",
            "text": "documents",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " row by setting "
          },
          {
            "type": "text",
            "text": "deleted_at",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " and re-ingest the new version as a fresh document with a new "
          },
          {
            "type": "text",
            "text": "source_id",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " row pointing to the updated URL. This preserves "
          },
          {
            "type": "text",
            "text": "retrieval_log",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " history against old chunks while excluding them from search:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "async def soft_delete_document(pool: asyncpg.Pool, document_id: str) -> None:\n    async with pool.acquire() as conn:\n        await conn.execute(\n            \"UPDATE documents SET deleted_at=NOW() WHERE id=$1\", document_id\n        )\n        # Chunks remain for audit; excluded by the JOIN d.deleted_at IS NULL filter"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Summary"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The four-table design (sources \u2192 documents \u2192 chunks, plus retrieval_log) separates origin tracking, chunking metadata, vector storage, and retrieval audit into distinct, focused tables."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Denormalise "
                  },
                  {
                    "type": "text",
                    "text": "tenant_id",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " onto "
                  },
                  {
                    "type": "text",
                    "text": "chunks",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " so ANN searches can filter by tenant without joining "
                  },
                  {
                    "type": "text",
                    "text": "documents",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " on the hot path."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Use PostgreSQL RLS policies to enforce tenant isolation at the database level, eliminating an entire class of data-leak bugs."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Store arbitrary per-document attributes in "
                  },
                  {
                    "type": "text",
                    "text": "JSONB metadata",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " with a GIN index; avoid premature column proliferation."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Log every retrieval in "
                  },
                  {
                    "type": "text",
                    "text": "retrieval_log",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " to enable retrieval quality analytics, feedback loops, and GDPR-compliant audit trails."
                  }
