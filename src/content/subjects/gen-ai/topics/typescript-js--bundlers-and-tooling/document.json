ttrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Publishing AI packages to npm"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"SWC"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Rust-based compiler (faster than Babel)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"TypeScript transpilation + bundling"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Parcel"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Zero-config bundler"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Quick prototypes without setup"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why It Matters for Gen AI"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ❌ WITHOUT bundler: Browser can't run TypeScript/JSX\n// src/main.tsx (browser fails to load):\nimport React from 'react';\nconst AIChat = () => <div>AI Response</div>;  // ❌ JSX syntax error\n\n// ✅ WITH bundler: Transpiled to browser-safe JS\n// dist/main.js (bundle output):\n\"react\";\nvar AIChat = function() { return React.createElement(\"div\", null, \"AI Response\"); };\n// ✅ Browser loads successfully [web:60][web:66]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"TypeScript compilation"},{"type":"text","text":": Converts "},{"type":"text","marks":[{"type":"code"}],"text":".ts"},{"type":"text","text":"/.tsx"},{"type":"text","marks":[{"type":"code"}],"text":" to "},{"type":"text","text":".js` - "},{"type":"text","marks":[{"type":"bold"}],"text":"Code optimization"},{"type":"text","text":": Minifies, bundles, dead code elimination\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Fast dev"},{"type":"text","text":": HMR (instant updates) with Vite\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Multi-environment"},{"type":"text","text":": Works in browser + Node.js + edge\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"AI SDK support"},{"type":"text","text":": Bundles LangChain.js, OpenAI SDK, etc."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How It Works (Core Concepts)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Bundling Process"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Source Code (TypeScript/JSX):\n├── src/main.tsx (React + TypeScript)\n├── src/api/openai.ts (AI fetch calls)\n├── src/components/AIChat.tsx (UI)\n└── src/types/ai.ts (interfaces)\n\nBundler (Vite/Webpack):\n├── TypeScript compilation → JavaScript\n├── JSX transpilation → React.createElement()\n├── Module resolution → Collect all dependencies\n├── Optimization → Minify, remove dead code\n└── Output → dist/main.js (single bundle)\n\nBrowser:\n└── Loads dist/main.js (no TypeScript/JSX needed) [web:60][web:66]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Vite Setup for Gen AI + React"},{"type":"text","text":" ⭐ Recommended 2026"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Step 1: Create Vite project with React + TypeScript\nnpm create vite@latest ai-chat-app -- --template react-ts\ncd ai-chat-app\n\n# Step 2: Install dependencies\nnpm install\nnpm install @google/generative-ai openai\n\n# Step 3: Start dev server (HMR enabled)\nnpm run dev\n# Server starts at http://localhost:5173 [web:60][web:72][web:76]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Project structure:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"ai-chat-app/\n├── src/\n│   ├── main.tsx (React entry)\n│   ├── App.tsx (root component)\n│   ├── api/openai.ts (AI fetch calls)\n│   ├── components/AIChat.tsx (UI)\n│   └── types/ai.ts (interfaces)\n├── public/\n├── vite.config.ts\n├── tsconfig.json\n├── package.json\n└── index.html"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Vite Configuration for AI"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// vite.config.ts\nimport { defineConfig } from 'vite';\nimport react from '@vitejs/plugin-react';\n\nexport default defineConfig({\n  plugins: [react()],\n  server: {\n    port: 5173,\n    proxy: {\n      // Proxy API calls to backend (avoid CORS)\n      '/api': {\n        target: 'http://localhost:3000',\n        changeOrigin: true,\n      },\n    },\n  },\n  build: {\n    outDir: 'dist',\n    minify: 'terser',  // Optimize for production\n    sourcemap: true,   // Debug in production\n  },\n});"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Webpack Configuration (Legacy)"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// webpack.config.js\nconst path = require('path');\n\nmodule.exports = {\n  entry: './src/main.tsx',\n  output: {\n    path: path.resolve(__dirname, 'dist'),\n    filename: 'bundle.js',\n  },\n  module: {\n    rules: [\n      {\n        test: /\\.tsx?$/,\n        use: 'ts-loader',\n        exclude: '/node_modules/',\n      },\n      {\n        test: /\\.jsx$/,\n        use: 'babel-loader',\n      },\n    ],\n  },\n  resolve: {\n    extensions: ['.tsx', '.ts', '.jsx', '.js'],\n  },\n};"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Build for Production"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Vite: Build optimized bundle\nnpm run build\n# Output: dist/ folder (ready to deploy)\n\n# Deploy to Vercel/Netlify\nvercel deploy --prod\n\n# Check bundle size\nnpm run build -- --report"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use (Decision Criteria)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Vite"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Webpack"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use esbuild"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"React + TypeScript app"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Default 2026"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Legacy"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Not for apps"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fast HMR dev"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Instant updates"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Slower"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ No HMR"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Complex plugins"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Good ecosystem"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Massive"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Limited"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Library bundling"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Good"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Good"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ esbuild + Rollup"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Zero config"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Minimal setup"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Heavy config"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Zero config"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Legacy browser"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Need polyfills"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Best support"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Modern only"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rule of thumb:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Vite"},{"type":"text","text":": Default for React + TypeScript AI apps\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Webpack"},{"type":"text","text":": Legacy projects or need complex plugins\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"esbuild"},{"type":"text","text":": Lightning-fast library builds"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How to Implement (Step-by-Step)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 1: Create Vite + React + TypeScript Project"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"npm create vite@latest ai-chat-app -- --template react-ts\ncd ai-chat-app\nnpm install"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 2: Install AI SDKs"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Google Gemini\nnpm install @google/generative-ai\n\n# OpenAI\nnpm install openai\n\n# LangChain.js\nnpm install langchain"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 3: Configure TypeScript"}]},{"type":"codeBlock","attrs":{"language":"json"},"content":[{"type":"text","text":"// tsconfig.json\n{\n  \"compilerOptions\": {\n    \"target\": \"ES2020\",\n    \"useDefineForClassFields\": true,\n    \"lib\": [\"ES2020\", \"DOM\", \"DOM.Iterable\"],\n    \"module\": \"ESNext\",\n    \"skipLibCheck\": true,\n    \"moduleResolution\": \"bundler\",\n    \"allowImportingTsExtensions\": true,\n    \"resolveJsonModule\": true,\n    \"isolatedModules\": true,\n    \"noEmit\": true,\n    \"jsx\": \"react-jsx\",\n    \"strict\": true,\n    \"noUnusedLocals\": true,\n    \"noUnusedParameters\": true,\n    \"noFallthroughCasesInSwitch\": true\n  },\n  \"include\": [\"src\"],\n  \"references\": [{ \"path\": \"./tsconfig.node.json\" }]\n}"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 4: Create AI API Client"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// src/api/openai.ts\nimport { AIRequest, AIResponse } from '../types/ai';\n\nexport async function callOpenAI(request: AIRequest): Promise<AIResponse> {\n  const response = await fetch('/api/openai', {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify(request),\n  });\n  \n  if (!response.ok) throw new Error(`API error: ${response.status}`);\n  return await response.json() as Promise<AIResponse>;\n}"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 5: Build AI Chat Component"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// src/components/AIChat.tsx\nimport { useState } from 'react';\nimport { callOpenAI } from '../api/openai';\nimport { AIRequest } from '../types/ai';\n\nexport function AIChat() {\n  const [response, setResponse] = useState<string | null>(null);\n  const [loading, setLoading] = useState(false);\n\n  const handleSubmit = async (prompt: string) => {\n    setLoading(true);\n    try {\n      const request: AIRequest = {\n        model: 'gpt-4o-mini',\n        messages: [{ role: 'user', content: prompt }],\n      };\n      \n      const result = await callOpenAI(request);\n      setResponse(result.choices[0].message.content);\n    } catch (error) {\n      if (error instanceof Error) {\n        console.error(error.message);\n      }\n      setResponse(null);\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  return (\n    <div>\n      {loading ? <p>Loading...</p> : response && <p>{response}</p>}\n    </div>\n  );\n}"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 6: Build & Deploy"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Build optimized bundle\nnpm run build\n\n# Output: dist/ folder\n# Deploy to Vercel\nvercel deploy --prod\n\n# Or deploy to Netlify\nnetlify deploy --prod"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Real-World Example: Production AI App with Vite"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Scale"},{"type":"text","text":": 10K+ users, React + TypeScript + Vite\n"},{"type":"text","marks":[{"type":"bold"}],"text":"Architecture"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Project Structure:\n├── src/\n│   ├── main.tsx (React entry)\n│   ├── App.tsx (root)\n│   ├── api/\n│   │   ├── openai.ts (fetch wrapper)\n│   │   └── gemini.ts (fetch wrapper)\n│   ├── components/\n│   │   ├── AIChat.tsx (UI)\n│   │   └── StreamingChat.tsx (streaming)\n│   ├── types/\n│   │   └── ai.ts (interfaces)\n│   └── hooks/\n│       └── useAIChat.ts (custom hook)\n├── public/\n├── vite.config.ts\n├── tsconfig.json\n├── package.json\n└── index.html\n\nBuild Output:\n└── dist/\n    ├── index.html\n    ├── assets/\n    │   ├── main.js (bundle)\n    │   └── main.css (styles)\n\nDeployment:\n└── Vercel/Netlify (CDN-hosted)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Outcome"},{"type":"text","text":": Fast dev with HMR, optimized production bundle, zero TypeScript in browser."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Common Mistakes to Avoid"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwi