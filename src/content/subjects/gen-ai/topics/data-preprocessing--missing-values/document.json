{"format":"tiptap/v1","updatedAt":"2026-06-22T04:13:37.112Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Missing Values"},{"type":"text","text":" are data points that are absent, blank, or not recorded in a dataset — they occur due to data entry errors, incomplete data collection, survey fields left blank, or respondents declining to answer, and must be handled carefully because ignoring them can lead to wrong results and misleading model performance."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What Are Missing Values"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Definition"},{"type":"text","text":": Entries that are left blank, marked as NaN, None, or special strings like \"Unknown\"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Common causes"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Error-prone data entry process"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Wrong data collection methods"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Fields left blank in surveys"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Respondent decline to answer"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Certain values not applicable"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"How they appear"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"code"}],"text":"NaN"},{"type":"text","text":" (Not a Number)\n- "},{"type":"text","marks":[{"type":"code"}],"text":"NA"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"code"}],"text":"?"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"code"}],"text":"0"},{"type":"text","text":" (zero)\n- "},{"type":"text","marks":[{"type":"code"}],"text":"xx"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"code"}],"text":"-1"},{"type":"text","text":" (minus one)\n- Blank space "},{"type":"text","marks":[{"type":"code"}],"text":"\"\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pandas"},{"type":"text","text":": Always recognizes missing values as "},{"type":"text","marks":[{"type":"code"}],"text":"NaN"},{"type":"text","text":" — must convert all non-NaN entries to "},{"type":"text","marks":[{"type":"code"}],"text":"NaN"},{"type":"text","text":" first."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Types of Missing Data"}]},{"type":"paragraph","content":[{"type":"text","text":"There are "},{"type":"text","marks":[{"type":"bold"}],"text":"three categories of missing data"},{"type":"text","text":":"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. MCAR"},{"type":"text","text":" (Missing Completely At Random)"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Pattern of missingness is "},{"type":"text","marks":[{"type":"bold"}],"text":"statistically independent"},{"type":"text","text":" of the data record"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": Coffee spilled on paper, destroying part of data randomly"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. MAR"},{"type":"text","text":" (Missing At Random)"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Probability of missingness is "},{"type":"text","marks":[{"type":"bold"}],"text":"dependent on observable data"},{"type":"text","text":" in the record"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"MCAR is a special case of MAR"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": Child doesn't attend educational assessment because genuinely ill (predictable from health data, but not from what would have been measured)"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"3. MNAR"},{"type":"text","text":" (Missing Not At Random)"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Missingness is "},{"type":"text","marks":[{"type":"bold"}],"text":"specifically related to what is missing"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"NOT MAR"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": Person doesn't attend drug test because they took drugs the night before"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key insight"},{"type":"text","text":": Missingness is almost always informative — we should tell the algorithm if a value is missing."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Handling Missing Values: Main Strategies"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Deleting Rows/Columns"},{"type":"text","text":" (Removal)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it does"},{"type":"text","text":": Remove samples (rows) or features (columns) with missing values"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Listwise Deletion"},{"type":"text","text":" (Remove Rows)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use"},{"type":"text","text":":\n- Missingness is "},{"type":"text","marks":[{"type":"bold"}],"text":"random"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Dataset is large"},{"type":"text","text":"\n- Simple and straightforward"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Method"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Pandas: Remove rows with missing values\ndf_clean = df.dropna()  # Removes any row with NaN\n\n# Remove rows with missing values in specific column\ndf_clean = df.dropna(subset=['age'])\n\n# Set threshold (keep rows with at least 80% complete data)\ndf_clean = df.dropna(thresh=0.8 * len(df.columns))"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problem"},{"type":"text","text":": Might not always be ideal — discards valuable data"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Remove Columns"},{"type":"text","text":" (Variables)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use"},{"type":"text","text":":\n- Feature/column contains "},{"type":"text","marks":[{"type":"bold"}],"text":"> 60% missing values"},{"type":"text","text":"\n- Feature is "},{"type":"text","marks":[{"type":"bold"}],"text":"insignificant"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Verify"},{"type":"text","text":": Variable is not important in decision-making process"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Method"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Remove columns with too many missing values\ndf_clean = df.dropna(axis=1, thresh=int(0.6 * len(df)))"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Advantage over deletion"},{"type":"text","text":": Imputation is always preferred over dropping variables"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Imputation"},{"type":"text","text":" (Filling Missing Values)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it does"},{"type":"text","text":": Fill the missing values with some other value from available data"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why preferred"},{"type":"text","text":": Imputation is always preferred over dropping variables because it preserves data"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"A. Statistical Imputation"},{"type":"text","text":" (Mean, Median, Mode)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mean Imputation"},{"type":"text","text":" (Numerical)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Formula"},{"type":"text","text":": Replace missing with column mean"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Method"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Pandas\ndf['age'].fillna(df['age'].mean(), inplace=True)\n\n# Scikit-learn\nfrom sklearn.impute import SimpleImputer\n\nimputer = SimpleImputer(strategy='mean')\ndf_imputed = imputer.fit_transform(df)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best for"},{"type":"text","text":": Numerical data, uncorrelated variables, linear data"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Median Imputation"},{"type":"text","text":" (Numerical)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Formula"},{"type":"text","text":": Replace missing with column median"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Method"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Pandas\ndf['income'].fillna(df['income'].median(), inplace=True)\n\n# Scikit-learn\nimputer = SimpleImputer(strategy='median')"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best for"},{"type":"text","text":": Numerical data with "},{"type":"text","marks":[{"type":"bold"}],"text":"outliers"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"bold"}],"text":"skewed distribution"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mode Imputation"},{"type":"text","text":" (Categorical)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Formula"},{"type":"text","text":": Replace missing with most frequent value (mode)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Method"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Pandas\ndf['gender'].fillna(df['gender'].mode()[0], inplace=True)\n\n# Scikit-learn\nimputer = SimpleImputer(strategy='most_frequent')"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best for"},{"type":"text","text":": Categorical data — assumes most common category is reasonable substitute"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Constant Value Imputation"},{"type":"text","text":" (Zero)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Formula"},{"type":"text","text":": Replace missing with a constant (e.g., 0)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Method"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Pandas\ndf['purchases'].fillna(0, inplace=True)\n\n# Scikit-learn\nimputer = SimpleImputer(strategy='constant', fill_value=0)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"bold"}],"text":"Only when zero is meaningful"},{"type":"text","text":" — e.g., zero purchases or zero visits logically represents absence of activity"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"B. Advanced Imputation Methods"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"KNN Imputation"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it does"},{"type":"text","text":": Assign missing value based on "},{"type":"text","marks":[{"type":"bold"}],"text":"nearest neighbors"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Method"},{"type":"text","text":":\n- Calculate distance between entities\n- Use "},{"type":"text","marks":[{"type":"bold"}],"text":"Euclidean, Cosine, Manhattan"},{"type":"text","text":" (numeric) or "},{"type":"text","marks":[{"type":"bold"}],"text":"Hamming"},{"type":"text","text":" (categorical)\n- Assign value from nearest neighbor"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best for"},{"type":"text","text":": Both numerical and categorical variables"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Iterative Imputation"},{"type":"text","text":" (ML-based)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it does"},{"type":"text","text":": Model each feature with missing values as a "},{"type":"text","marks":[{"type":"bold"}],"text":"function of other features"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Method"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from sklearn.impute import IterativeImputer\n\nimputer = IterativeImputer()\ndf_imputed = imputer.fit_transform(df)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best for"},{"type":"text","text":": Correlated features, uses ML algorithms to predict missing values"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Machine Learning Prediction"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it does"},{"type":"text","text":": Build prediction model to handle missing values"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Method"},{"type":"text","text":":\n1. Split data into training set (no missing) and test set (has missing)\n2. Treat variable with missing values as "},{"type":"text","marks":[{"type":"bold"}],"text":"target variable"},{"type":"text","text":"\n3. Create model to predict target\n4. Use model to populate missing values in test set"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Algorithms"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Linear Regression"},{"type":"text","text":" (commonly used for age, weight, height)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"KNN"},{"type":"text","text":" (missing value = nearest neighbor)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Random Forests"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"XGBoost"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"C. Time-Series Imputation"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Forward Fill (ffill)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it does"},{"type":"text","text":": Propagate "},{"type":"text","marks":[{"type":"bold"}],"text":"previous value forward"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Method"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Pandas\ndf['stock_price'] = df['stock_price'].fillna(method='ffill')"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best for"},{"type":"text","text":": Time-series data, continuous data"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Backward Fill (bfill)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it does"},{"type":"text","text":": Propagate "},{"type":"text","marks":[{"type":"bold"}],"text":"next value backward"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Method"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Pandas\ndf['stock_price'] = df['stock_price'].fillna(method='bfill')"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Interpolation"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it does"},{"type":"text","text":": Estimate missing values based on "},{"type":"text","marks":[{"type":"bold"}],"text":"data pattern"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Method"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Pandas (linear interpolation)\ndf['value'] = df['value'].interpolate(method='linear')"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best for"},{"type":"text","text":": Continuous data, estimates based on surrounding values"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Comparison: Deletion vs. Imputation"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Deletion"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Imputation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Data preservation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Discards data"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Preserves all data"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Bias"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Can introduce bias if missing not random"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Less bias if appropriate method used"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sample size"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Reduces sample size"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Maintains sample size"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Large dataset, random missingness"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Most cases, small datasets"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Preference"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Last resort"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Always preferred"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rule"},{"type":"text","text":": Imputation is always preferred over dropping variables."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Missing values"},{"type":"text","text":": Data points absent, blank, NaN, NA,?, or \"Unknown\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Causes"},{"type":"text","text":": Data entry errors, incomplete collection, surveys left blank, respondents declining"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"MCAR"},{"type":"text","text":": Missing completely at random (independent of data)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"MAR"},{"type":"text","text":": Missing at random (dependent on observable data)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"MNAR"},{"type":"text","text":": Missing not at random (related to what's missing)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Missingness is informative"},{"type":"text","text":": Tell algorithm if value is missing"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Deletion"},{"type":"text","text":": Remove rows/columns with missing values (simple but loses data)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Imputation"},{"type":"text","text":": Fill missing values (preferred over deletion)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mean imputation"},{"type":"text","text":": Best for numerical, uncorrelated, linear data"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Median imputation"},{"type":"text","text":": Best for numerical with outliers/skewed data"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mode imputation"},{"type":"text","text":": Best for categorical (most frequent value)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Zero imputation"},{"type":"text","text":": Only when zero is meaningful (absence of activity)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"KNN imputation"},{"type":"text","text":": Nearest neighbor-based, works for both types"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Iterative imputation"},{"type":"text","text":": ML-based, models features as function of others"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Forward/Backward fill"},{"type":"text","text":": For time-series, propagate values"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Interpolation"},{"type":"text","text":": Estimate based on data pattern for continuous data"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"60% threshold"},{"type":"text","text":": If >60% missing, consider dropping column"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Missing values are the \"data gaps\" that must be addressed before modeling — they occur due to errors, incomplete collection, or survey responses, and come in three types (MCAR, MAR, MNAR) based on why they're missing, and while deletion (removing rows/columns) is simple, imputation (filling with mean, median, mode, KNN, or ML prediction) is always preferred because it preserves data and reduces bias, making it essential for accurate model training."}]}]}}
