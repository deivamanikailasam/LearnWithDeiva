{"format":"tiptap/v1","updatedAt":"2026-06-21T13:54:11.868Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Stacks and Queues"},{"type":"text","text":" are linear data structures that organize elements in specific orders for processing—"},{"type":"text","marks":[{"type":"bold"}],"text":"Stacks"},{"type":"text","text":" use "},{"type":"text","marks":[{"type":"bold"}],"text":"LIFO (Last-In-First-Out)"},{"type":"text","text":" ordering where the most recent element is processed first, while "},{"type":"text","marks":[{"type":"bold"}],"text":"Queues"},{"type":"text","text":" use "},{"type":"text","marks":[{"type":"bold"}],"text":"FIFO (First-In-First-Out)"},{"type":"text","text":" ordering where the earliest element is processed first. These ordering principles dictate when to use each structure in Gen AI for token buffering, request scheduling, and backtracking algorithms."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Stack"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Queue"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Ordering"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"LIFO (Last-In-First-Out)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"FIFO (First-In-First-Out)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Insertion"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"push()"},{"type":"text","text":" at top"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"enqueue()"},{"type":"text","text":" at rear"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Deletion"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"pop()"},{"type":"text","text":" from top"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"dequeue()"},{"type":"text","text":" from front"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Access Point"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"One end (top)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Two ends (front + rear)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Real-world analogy"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Stack of plates (last added = first removed)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Line at store (first arrived = first served)"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why It Matters for Gen AI"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ❌ WITHOUT stack: No undo/redo for AI prompts\nprompt = \"Explain quantum computing\"\nedit1 = prompt + \" in simple terms\"  # ✅ Edit 1\nedit2 = edit1 + \" with examples\"  # ✅ Edit 2\n# Can't go back to previous version easily\n\n# ✅ WITH stack: Undo/redo for AI interactions\nprompt_stack = []\nprompt_stack.append(\"Explain quantum computing\")  # ✅ push\nprompt_stack.append(\"Explain quantum computing in simple terms\")  # ✅ push\nprompt_stack.append(\"Explain quantum computing in simple terms with examples\")  # ✅ push\n\n# Undo: Get previous prompt\nprevious = prompt_stack.pop()  # ✅ \"Explain quantum computing in simple terms\" (LIFO)\nprint(previous) [web:98][web:99]\n\n# ✅ WITH queue: Request scheduling for AI API\nrequest_queue = []\nrequest_queue.append(\"User 1: Explain photosynthesis\")  # ✅ enqueue\nrequest_queue.append(\"User 2: Explain quantum computing\")  # ✅ enqueue\nrequest_queue.append(\"User 3: Explain neural networks\")  # ✅ enqueue\n\n# Process in order: First request first\nfirst_request = request_queue.pop(0)  # ✅ \"User 1: Explain photosynthesis\" (FIFO)\nprint(first_request) [web:99][web:103]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Ordering control"},{"type":"text","text":": LIFO for backtracking, FIFO for fair scheduling\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Efficient operations"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"push/pop/enqueue/dequeue"},{"type":"text","text":" are O(1)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Memory management"},{"type":"text","text":": Stacks track function calls, queues buffer async requests\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Algorithm foundation"},{"type":"text","text":": DFS (stack), BFS (queue) for graph/tree traversal"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How It Works (Core Operations)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Stack Operations (LIFO)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Create stack\nstack = []\n\n# ✅ Push: Add element to top\nstack.push(\"element1\")  # OR stack.append(\"element1\") in Python\nstack.push(\"element2\")\nstack.push(\"element3\")\nprint(stack)  # [\"element1\", \"element2\", \"element3\"] [web:98][web:102]\n\n# ✅ Pop: Remove and return top element\ntop = stack.pop()  # ✅ \"element3\" (last added = first removed)\nprint(top)  # \"element3\"\nprint(stack)  # [\"element1\", \"element2\"] [web:98][web:102]\n\n# ✅ Peek: View top without removing\ntop = stack.peek()  # OR stack[-1] in Python\nprint(top)  # \"element2\" [web:102]\n\n# ✅ Size: Check number of elements\nsize = len(stack)  # ✅ 2 [web:102]\n\n# ✅ LIFO visualization:\nstack = []\nstack.append(1)  #  [youtube](https://www.youtube.com/watch?v=aBR8SxPMbng)\nstack.append(2)  # [1, 2]\nstack.append(3)  # [1, 2, 3]\nstack.pop()  # [1, 2] ← 3 removed (last in, first out) [web:98]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Queue Operations (FIFO)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Create queue (use collections.deque for O(1) operations)\nfrom collections import deque\nqueue = deque()\n\n# ✅ Enqueue: Add element to rear\nqueue.append(\"request1\")  # OR queue.enqueue(\"request1\")\nqueue.append(\"request2\")\nqueue.append(\"request3\")\nprint(queue)  # deque(['request1', 'request2', 'request3']) [web:102][web:106]\n\n# ✅ Dequeue: Remove and return front element\nfront = queue.pop(0)  # OR queue.popleft() in deque\n# ✅ \"request1\" (first added = first removed)\nprint(front)  # \"request1\"\nprint(queue)  # deque(['request2', 'request3']) [web:102][web:106]\n\n# ✅ Peek front: View first without removing\nfront = queue[0]  # ✅ \"request2\" [web:102]\n\n# ✅ FIFO visualization:\nqueue = deque()\nqueue.append(1)  #  [youtube](https://www.youtube.com/watch?v=aBR8SxPMbng)\nqueue.append(2)  # [1, 2]\nqueue.append(3)  # [1, 2, 3]\nqueue.popleft()  # [2, 3] ← 1 removed (first in, first out) [web:98]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Stack Use Cases in Gen AI"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ 1. Function Call Management (recursion tracking)\ndef recursive_ai(prompt: str, depth: int = 0):\n    if depth > 3:\n        return prompt\n    \n    # Push to stack (call stack)\n    recursive_ai(prompt + f\" (depth {depth})\", depth + 1)  # ✅ Stack tracks calls [web:99]\n\n# ✅ 2. Undo/Redo for AI Prompts\nclass AIEditor:\n    def __init__(self):\n        self.history = []  # ✅ Stack for undo\n    \n    def edit(self, prompt: str):\n        self.history.append(prompt)  # ✅ push\n        return prompt\n    \n    def undo(self):\n        if self.history:\n            return self.history.pop()  # ✅ pop (LIFO) [web:99][web:101]\n\neditor = AIEditor()\neditor.edit(\"Explain quantum computing\")\neditor.edit(\"Explain quantum computing in simple terms\")\neditor.undo()  # ✅ \"Explain quantum computing\" [web:99]\n\n# ✅ 3. Backtracking Algorithms (maze solving, token generation)\ndef backtrack_token_generation(prompt: str, tokens: list = []):\n    if len(tokens) == 10:\n        return tokens\n    \n    tokens.append(\"token\")  # ✅ push\n    result = backtrack_token_generation(prompt, tokens)\n    tokens.pop()  # ✅ pop (backtrack) [web:99][web:101]\n\n# ✅ 4. Depth-First Search (DFS) for Graphs/Trees\ndef dfs(graph: dict, start: str, visited: set = None):\n    if visited is None:\n        visited = set()\n    \n    stack = [start]  # ✅ Stack for DFS\n    while stack:\n        node = stack.pop()  # ✅ pop (LIFO)\n        if node not in visited:\n            visited.add(node)\n            stack.extend(graph[node])  # ✅ push neighbors [web:99][web:101]\n\ndfs({\"A\": [\"B\", \"C\"], \"B\": [\"D\"], \"C\": [], \"D\": []}, \"A\")  # ✅ [web:99]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Queue Use Cases in Gen AI"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ 1. Task Scheduling (CPU/process management)\nfrom collections import deque\n\nclass AITaskScheduler:\n    def __init__(self):\n        self.queue = deque()  # ✅ Queue for FIFO\n    \n    def add_task(self, task: str):\n        self.queue.append(task)  # ✅ enqueue [web:99][web:101]\n    \n    def process_task(self):\n        if self.queue:\n            return self.queue.popleft()  # ✅ dequeue (FIFO) [web:99][web:101]\n\nscheduler = AITaskScheduler()\nscheduler.add_task(\"User 1: Explain photosynthesis\")\nscheduler.add_task(\"User 2: Explain quantum computing\")\nscheduler.process_task()  # ✅ \"User 1: Explain photosynthesis\" [web:99]\n\n# ✅ 2. Breadth-First Search (BFS) for Graphs/Trees\ndef bfs(graph: dict, start: str):\n    from collections import deque\n    queue = deque([start])  # ✅ Queue for BFS\n    visited = set([start])\n    \n    while queue:\n        node = queue.popleft()  # ✅ dequeue (FIFO)\n        for neighbor in graph[node]:\n            if neighbor not in visited:\n                visited.add(neighbor)\n                queue.append(neighbor)  # ✅ enqueue [web:99][web:101]\n\nbfs({\"A\": [\"B\", \"C\"], \"B\": [\"D\"], \"C\": [], \"D\": []}, \"A\")  # ✅ [web:99]\n\n# ✅ 3. Message Queues (distributed AI systems)\nclass AIMessageQueue:\n    def __init__(self):\n        self.queue = deque()  # ✅ Queue for async messages\n    \n    def send_message(self, message: str):\n        self.queue.append(message)  # ✅ enqueue [web:103]\n    \n    def receive_message(self):\n        if self.queue:\n            return self.queue.popleft()  # ✅ dequeue [web:103]\n\n# ✅ 4. Token Buffering (streaming LLM responses)\nclass TokenBuffer:\n    def __init__(self):\n        self.queue = deque()  # ✅ Queue for tokens\n    \n    def add_token(self, token: str):\n        self.queue.append(token)  # ✅ enqueue [web:103]\n    \n    def get_next_token(self):\n        if self.queue:\n            return self.queue.popleft()  # ✅ dequeue (FIFO) [web:103]\n\nbuffer = TokenBuffer()\nbuffer.add_token(\"Quantum\")\nbuffer.add_token(\"computing\")\nbuffer.add_token(\"uses\")\nbuffer.get_next_token()  # ✅ \"Quantum\" [web:103]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use (Decision Criteria)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Stack"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Queue"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Order reversal"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Undo/redo, backtracking"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Preserves order"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fair scheduling"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ LIFO = unfair"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Task scheduling, CPU"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Nested structures"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Function calls, parentheses"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Not nested"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Level-by-level"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Depth-first only"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ BFS, tree levels"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Last action first"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Undo, recursion"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ First action first"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"First action first"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Last action first"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Request queue, print jobs"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Memory tracking"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Call stack"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Not for memory"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Async buffering"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ LIFO = wrong order"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Message queues"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rule of thumb:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Stack"},{"type":"text","text":": When you need to "},{"type":"text","marks":[{"type":"bold"}],"text":"reverse order"},{"type":"text","text":" or track "},{"type":"text","marks":[{"type":"bold"}],"text":"nested operations"},{"type":"text","text":" (undo, recursion, DFS)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Queue"},{"type":"text","text":": When you need to "},{"type":"text","marks":[{"type":"bold"}],"text":"preserve order"},{"type":"text","text":" or process "},{"type":"text","marks":[{"type":"bold"}],"text":"level-by-level"},{"type":"text","text":" (task scheduling, BFS, message queues)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How to Implement (Step-by-Step)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 1: Stack Implementation (Python)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Using list (O(1) push/pop)\nclass Stack:\n    def __init__(self):\n        self.items = []\n    \n    def push(self, item):\n        self.items.append(item)  # ✅ O(1) [web:102]\n    \n    def pop(self):\n        if not self.is_empty():\n            return self.items.pop()  # ✅ O(1) [web:102]\n        return None\n    \n    def peek(self):\n        if not self.is_empty():\n            return self.items[-1]  # ✅ O(1) [web:102]\n        return None\n    \n    def is_empty(self):\n        return len(self.items) == 0\n    \n    def size(self):\n        return len(self.items)\n\nstack = Stack()\nstack.push(1)\nstack.push(2)\nstack.push(3)\nprint(stack.pop())  # ✅ 3 (LIFO) [web:102]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 2: Queue Implementation (Python)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Using collections.deque (O(1) enqueue/dequeue)\nfrom collections import deque\n\nclass Queue:\n    def __init__(self):\n        self.items = deque()\n    \n    def enqueue(self, item):\n        self.items.append(item)  # ✅ O(1) [web:102]\n    \n    def dequeue(self):\n        if not self.is_empty():\n            return self.items.popleft()  # ✅ O(1) [web:102]\n        return None\n    \n    def peek(self):\n        if not self.is_empty():\n            return self.items[0]  # ✅ O(1) [web:102]\n        return None\n    \n    def is_empty(self):\n        return len(self.items) == 0\n    \n    def size(self):\n        return len(self.items)\n\nqueue = Queue()\nqueue.enqueue(1)\nqueue.enqueue(2)\nqueue.enqueue(3)\nprint(queue.dequeue())  # ✅ 1 (FIFO) [web:102]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 3: Stack in TypeScript"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ✅ Using array\nclass Stack<T> {\n  private items: T[] = [];\n  \n  push(item: T): void {\n    this.items.push(item);  // ✅ O(1)\n  }\n  \n  pop(): T | undefined {\n    return this.items.pop();  // ✅ O(1)\n  }\n  \n  peek(): T | undefined {\n    return this.items[this.items.length - 1];  // ✅ O(1)\n  }\n  \n  isEmpty(): boolean {\n    return this.items.length === 0;\n  }\n  \n  size(): number {\n    return this.items.length;\n  }\n}\n\nconst stack = new Stack<string>();\nstack.push(\"Hello\");\nstack.push(\"World\");\nconsole.log(stack.pop());  // ✅ \"World\" (LIFO)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 4: Queue in TypeScript"}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"// ✅ Using array (simple) or linked list (O(1) dequeue)\nclass Queue<T> {\n  private items: T[] = [];\n  \n  enqueue(item: T): void {\n    this.items.push(item);  // ✅ O(1)\n  }\n  \n  dequeue(): T | undefined {\n    return this.items.shift();  // ⚠️ O(n) - use linked list for O(1)\n  }\n  \n  peek(): T | undefined {\n    return this.items[0];  // ✅ O(1)\n  }\n  \n  isEmpty(): boolean {\n    return this.items.length === 0;\n  }\n  \n  size(): number {\n    return this.items.length;\n  }\n}\n\nconst queue = new Queue<string>();\nqueue.enqueue(\"Hello\");\nqueue.enqueue(\"World\");\nconsole.log(queue.dequeue());  // ✅ \"Hello\" (FIFO)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Time Complexity"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Operation"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Stack"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":nul