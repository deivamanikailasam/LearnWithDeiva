"type":"text","text":": 10K+ concurrent AI requests, queue-based scheduling\n"},{"type":"text","marks":[{"type":"bold"}],"text":"Architecture"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Frontend → API Gateway → Task Queue → Worker Pool → LLM API → Response Queue → Frontend\n\nQueue Usage:\n- Request queue: FIFO scheduling (user 1 → user 2 → user 3) [web:99][web:101]\n- Response queue: FIFO delivery (first response → first user) [web:103]\n\nStack Usage:\n- Call stack: Track nested function calls in AI processing [web:99]\n- Undo stack: Allow users to revert AI edits [web:99][web:101]\n\nBenefits:\n- Fair scheduling: First request = first processed [web:99]\n- Memory efficiency: Stack tracks recursion depth [web:99]\n- Scalability: Queue buffers async requests [web:103]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Outcome"},{"type":"text","text":": 10K+ requests handled with fair ordering and efficient memory."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Common Mistakes to Avoid"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Mistake"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Consequence"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Fix"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Using array for queue dequeue"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowsp