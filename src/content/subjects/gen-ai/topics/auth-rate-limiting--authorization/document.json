      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Embed scopes in the JWT payload at token issuance so the API never needs to query a roles table on every request:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Token issuance: look up user's plan and build scopes\nPLAN_SCOPES = {\n    \"free\":       [\"chat:basic\"],\n    \"pro\":        [\"chat:basic\", \"chat:advanced\", \"rag:query\"],\n    \"enterprise\": [\"chat:basic\", \"chat:advanced\", \"rag:query\", \"rag:ingest\", \"admin:read\"],\n}\n\nasync def create_token_for_user(user: dict) -> str:\n    scopes = PLAN_SCOPES.get(user[\"plan\"], [\"chat:basic\"])\n    if user.get(\"is_admin\"):\n        scopes.append(\"admin:write\")\n    return create_access_token(user[\"id\"], scopes)"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Enforcing Scopes in Route Dependencies"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# app/api/deps.py\nfrom fastapi import Depends, HTTPException, status\nfrom app.auth.tokens import verify_access_token\nfrom fastapi.security import HTTPBearer\n\nsecurity = HTTPBearer()\n\nasync def get_auth(credentials=Depends(security)) -> dict:\n    try:\n        return verify_access_token(credentials.credentials)\n    except ValueError as e:\n        raise HTTPException(status.HTTP_401_UNAUTHORIZED, str(e))\n\ndef require_scope(*required: str):\n    \"\"\"All listed scopes must be present.\"\"\"\n    async def check(auth: dict = Depends(get_auth)):\n        scopes = set(auth.get(\"scopes\", []))\n        missing = set(required) - scopes\n        if missing:\n            raise HTTPException(\n                status.HTTP_403_FORBIDDEN,\n                f\"Required scopes missing: {', '.join(sorted(missing))}\",\n            )\n        return auth\n    return check\n\ndef require_any_scope(*options: str):\n    \"\"\"At least one of the listed scopes must be present.\"\"\"\n    async def check(auth: dict = Depends(get_auth)):\n        scopes = set(auth.get(\"scopes\", []))\n        if not scopes.intersection(options):\n            raise HTTPException(\n                status.HTTP_403_FORBIDDEN,\n                f\"One of the following scopes required: {', '.join(options)}\",\n            )\n        return auth\n    return check"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# app/api/chat.py — scopes enforced per endpoint\nfrom app.api.deps import require_scope, require_any_scope\n\n@router.post(\"/completions\")\nasync def chat_completions(\n    request: ChatRequest,\n    auth: dict = Depends(require_scope(\"chat:basic\")),\n):\n    # Check model access within the handler (ABAC rule)\n    if request.model not in ALLOWED_MODELS_BY_SCOPE:\n        allowed = ALLOWED_MODELS_BY_SCOPE.get(\"chat:advanced\", [])\n        if request.model in allowed and \"chat:advanced\" not in auth[\"scopes\"]:\n            raise HTTPException(\n                status.HTTP_403_FORBIDDEN,\n                f\"Model '{request.model}' requires scope 'chat:advanced'\",\n            )\n    # ... proceed ...\n\n@router.post(\"/ingest\")\nasync def ingest_documents(\n    request: IngestRequest,\n    auth: dict = Depends(require_scope(\"rag:ingest\")),\n):\n    ..."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Model-Level Authorization"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Different models have different costs. Restrict which models each scope can access with a lookup table rather than hardcoded conditionals:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# app/services/model_access.py\nSCOPE_MODEL_ALLOWLIST: dict[str, list[str]] = {\n    \"chat:basic\": [\n        \"claude-haiku-4-5-20251001\",\n    ],\n    \"chat:advanced\": [\n        \"claude-haiku-4-5-20251001\",\n        \"claude-sonnet-4-6\",\n        \"claude-opus-4-8\",\n    ],\n}\n\ndef allowed_models_for_scopes(scopes: list[str]) -> set[str]:\n    result: set[str] = set()\n    for scope in scopes:\n        result.update(SCOPE_MODEL_ALLOWLIST.get(scope, []))\n    return result\n\ndef check_model_access(model: str, scopes: list[str]) -> None:\n    allowed = allowed_models_for_scopes(scopes)\n    if model not in allowed:\n        raise PermissionError(\n            f\"Model '{model}' not allowed for your plan. \"\n            f\"Allowed: {', '.join(sorted(allowed))}\"\n        )"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Resource-Level Authorization (Data Isolation)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "In multi-tenant deployments, users must only access their own data — conversations, RAG document collections, fine-tuned models. Enforce ownership at the query level, never by filtering in Python after fetching:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# app/services/conversations.py\nfrom app.services.db import db\n\nasync def get_conversation(\n    conversation_id: str,\n    user_id: str,   # ALWAYS pass the authenticated user_id\n) -> dict | None:\n    # The WHERE clause includes user_id — row is invisible if it belongs to another user\n    return await db.fetchrow(\n        \"SELECT * FROM conversations WHERE id = $1 AND user_id = $2\",\n        conversation_id, user_id,\n    )\n\nasync def list_conversations(user_id: str) -> list[dict]:\n    return await db.fetch(\n        \"SELECT id, title, created_at FROM conversations \"\n        \"WHERE user_id = $1 ORDER BY created_at DESC LIMIT 50\",\n        user_id,\n    )\n\nasync def delete_conversation(conversation_id: str, user_id: str) -> bool:\n    result = await db.execute(\n        \"DELETE FROM conversations WHERE id = $1 AND user_id = $2\",\n        conversation_id, user_id,\n    )\n    return result == \"DELETE 1\""
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For "
          },
          {
            "type": "text",
            "text": "organization-level tenancy",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " (one account, many users), add an "
          },
          {
            "type": "text",
            "text": "org_id",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " column and check both "
          },
          {
            "type": "text",
            "text": "org_id = $org",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " and a role column that controls whether the user can read or write within that org."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Organization-Level Authorization"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# app/services/org_access.py\nfrom enum import StrEnum\n\nclass OrgRole(StrEnum):\n    MEMBER = \"member\"\n    ADMIN  = \"admin\"\n    OWNER  = \"owner\"\n\nROLE_PERMISSIONS: dict[OrgRole, set[str]] = {\n    OrgRole.MEMBER: {\"conversation:read\", \"conversation:write\", \"rag:query\"},\n    OrgRole.ADMIN:  {\"conversation:read\", \"conversation:write\",\n                     \"rag:query\", \"rag:ingest\", \"member:read\"},\n    OrgRole.OWNER:  {\"conversation:read\", \"conversation:write\",\n                     \"rag:query\", \"rag:ingest\", \"member:read\",\n                     \"member:write\", \"billing:read\"},\n}\n\nasync def check_org_permission(user_id: str, org_id: str, permission: str) -> None:\n    row = await db.fetchrow(\n        \"SELECT role FROM org_members WHERE user_id = $1 AND org_id = $2\",\n        user_id, org_id,\n    )\n    if not row:\n        raise PermissionError(\"Not a member of this organization\")\n\n    role = OrgRole(row[\"role\"])\n    if permission not in ROLE_PERMISSIONS[role]:\n        raise PermissionError(\n            f\"Role '{role}' lacks permission '{permission}' in org '{org_id}'\"\n        )"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing Authorization Rules"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Authorization bugs (missing checks, wrong scope name) are security vulnerabilities. Test every protected endpoint with the wrong scope, the right scope, and no token at all:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# tests/test_authorization.py\nimport pytest, jwt\nfrom httpx import AsyncClient, ASGITransport\nfrom app.main import app\nfrom app.config import settings\n\ndef make_token(scopes: list[str], user_id: str = \"user-1\") -> str:\n    return jwt.encode(\n        {\"sub\": user_id, \"scopes\": scopes},\n        settings.jwt_secret,\n        algorithm=\"HS256\",\n    )\n\n@pytest.mark.asyncio\n@pytest.mark.parametrize(\"scopes,expected_status\", [\n    ([\"chat:basic\"],    200),       # correct scope\n    ([\"rag:query\"],     403),       # wrong scope\n    ([],                403),       # no scopes\n])\nasync def test_chat_scope_enforcement(scopes, expected_status):\n    async with AsyncClient(transport=ASGITransport(app=app), base_url=\"http://test\") as c:\n        res = await c.post(\n            \"/chat/completions\",\n            json={\"messages\": [{\"role\": \"user\", \"content\": \"Hi\"}]},\n            headers={\"Authorization\": f\"Bearer {make_token(scopes)}\"},\n        )\n        assert res.status_code == expected_status\n\n@pytest.mark.asyncio\nasync def test_no_token_returns_401():\n    async with AsyncClient(transport=ASGITransport(app=app), base_url=\"http://test\") as c:\n        res = await c.post(\n            \"/chat/completions\",\n            json={\"messages\": [{\"role\": \"user\", \"content\": \"Hi\"}]},\n        )\n        assert res.status_code == 401\n\n@pytest.mark.asyncio\nasync def test_advanced_model_requires_advanced_scope():\n    basic_token = make_token([\"chat:basic\"])\n    async with AsyncClient(transport=ASGITransport(app=app), base_url=\"http://test\") as c:\n        res = await c.post(\n            \"/chat/completions\",\n            json={\n                \"messages\": [{\"role\": \"user\", \"content\": \"Hi\"}],\n                \"model\": \"claude-opus-4-8\",\n            },\n            headers={\"Authorization\": f\"Bearer {basic_token}\"},\n        )\n        assert res.status_code == 403"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Audit Logging Authorization Decisions"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Log every authorization failure with enough context to investigate: who, what endpoint, what scopes they had, and why it was denied. Authorization failures are security signals — a spike may indicate a scraping attempt or a client bug:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import logging, time\nfrom fastapi import Request, Response\nfrom fastapi.routing import APIRoute\n\nlogger = logging.getLogger(\"auth_audit\")\n\nclass AuditRoute(APIRoute):\n    def get_route_handler(self):\n        original = super().get_route_handler()\n\n        async def handler(request: Request) -> Response:\n            start = time.monotonic()\n            try:\n                response = await original(request)\n            except Exception as exc:\n                # Log 401/403 responses\n                status_code = getattr(exc, \"status_code\", 500)\n                if status_code in (401, 403):\n                    logger.warning(\n                        \"auth_denied\",\n                        extra={\n                            \"status\": status_code,\n                            \"path\": request.url.path,\n                            \"method\": request.method,\n                            \"user_agent\": request.headers.get(\"user-agent\"),\n                            \"ip\": request.client.host if request.client else None,\n                            \"duration_ms\": (time.monotonic() - start) * 1000,\n                        },\n                    )\n                raise\n            return response\n        return handler"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Checking only authentication, not authorization:",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " a valid token does not mean the user can call every endpoint. Always check scopes AND resource ownership."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Fetching all resources and filtering in Python:",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " always include "
                  },
                  {
                    "type": "text",
                    "text": "user_id = $1",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " in the SQL WHERE clause. Fetching all rows and filtering is both a security risk and a performance problem."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Leaking resource existence in 403 responses:",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " return 404 instead of 403 when a user tries to access another user's resource — a 403 confirms the resource exists."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Using roles instead of scopes in JWTs:",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " if you embed "
                  },
                  {
                    "type": "text",
                    "text": "\"role\": \"admin\"",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " in the JWT, the API must look up what 'admin' means. Embed the actual scopes so the check is a set lookup."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Not testing cross-tenant access:",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " write a test that creates a resource as user A, then attempts to read/delete it as user B. It must return 404."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Authorization in GenAI APIs combines scope enforcement (what endpoints can this token call?), model-level access (what models can this plan use?), and resource ownership (can this user access this conversation/document?). Embed scopes in JWTs, check them in dependencies, enforce ownership with SQL WHERE clauses, and test every protected endpoint with wrong-scope and cross-user scenarios."
              }
            ]
          }
        ]
      }
    ]
  }
}