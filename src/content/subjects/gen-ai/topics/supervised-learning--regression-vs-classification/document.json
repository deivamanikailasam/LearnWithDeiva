{"format":"tiptap/v1","updatedAt":"2026-06-22T03:28:53.570Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"In "},{"type":"text","marks":[{"type":"bold"}],"text":"supervised learning"},{"type":"text","text":", both regression and classification are tasks where the model learns from labeled data (input-output pairs), but they differ fundamentally in "},{"type":"text","marks":[{"type":"bold"}],"text":"what they predict"},{"type":"text","text":":"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Regression"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Classification"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Continuous numerical value"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Discrete category/class label"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Goal"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Predict a quantity"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Assign to a category"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Examples"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"House prices, temperature, stock values"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Spam/not-spam, disease present/absent, image categories"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output Form"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Real number (e.g., 342,500.75)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Class (e.g., \"spam\", \"cat\", 0/1)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key distinction"},{"type":"text","text":": Regression predicts "},{"type":"text","marks":[{"type":"italic"}],"text":"how much"},{"type":"text","text":" (continuous), while classification predicts "},{"type":"text","marks":[{"type":"italic"}],"text":"which one"},{"type":"text","text":" (discrete)."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What is a Loss Function?"}]},{"type":"paragraph","content":[{"type":"text","text":"A "},{"type":"text","marks":[{"type":"bold"}],"text":"loss function"},{"type":"text","text":" (also called cost function) is a mathematical measure of how \"wrong\" a model's predictions are. It quantifies the distance between predicted values and actual ground truth labels. The model's goal during training is to "},{"type":"text","marks":[{"type":"bold"}],"text":"minimize"},{"type":"text","text":" this loss."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Regression Loss Functions"}]},{"type":"paragraph","content":[{"type":"text","text":"Regression loss functions measure the error between predicted and actual continuous values:"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Mean Squared Error (MSE / L2 Loss)"}]},{"type":"blockMath","attrs":{"latex":"\\text{MSE} = \\frac{1}{n}\\sum_{i=1}^{n}(y_i - \\hat{y}_i)^2"}},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Measures squared difference between predicted and actual"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Larger errors contribute more"},{"type":"text","text":" (squared penalty)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Most common for regression; sensitive to outliers"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Mean Absolute Error (MAE / L1 Loss)"}]},{"type":"blockMath","attrs":{"latex":"\\text{MAE} = \\frac{1}{n}\\sum_{i=1}^{n}|y_i - \\hat{y}_i|"}},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Measures average absolute difference"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Small and large errors weighted equally"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Less sensitive to outliers than MSE; non-differentiable at 0"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Huber Loss"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Combination of MSE and MAE"},{"type":"text","text":": uses MSE for small errors, MAE for large errors"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Less sensitive to outliers while remaining differentiable"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Parameterized by δ (hyperparameter)"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Root Mean Squared Error (RMSE)"}]},{"type":"blockMath","attrs":{"latex":"\\text{RMSE} = \\sqrt{\\frac{1}{n}\\sum_{i=1}^{n}(y_i - \\hat{y}_i)^2}"}},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"MSE with square root; loss has same units as target variable"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Classification Loss Functions"}]},{"type":"paragraph","content":[{"type":"text","text":"Classification loss functions measure the dissimilarity between predicted probabilities and true class labels:"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Binary Cross-Entropy (BCE / Log Loss)"}]},{"type":"blockMath","attrs":{"latex":"\\text{BCE} = -\\frac{1}{n}\\sum_{i=1}^{n}\\left[y_i\\log(\\hat{y}_i) + (1-y_i)\\log(1-\\hat{y}_i)\\right]"}},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"For "},{"type":"text","marks":[{"type":"bold"}],"text":"binary classification"},{"type":"text","text":" (2 classes)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Measures dissimilarity between predicted probability and true binary label"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Used in logistic regression"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Cross-Entropy Loss (Multi-class)"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Extension of BCE to "},{"type":"text","marks":[{"type":"bold"}],"text":"multi-class classification"},{"type":"text","text":" (k > 2 classes)"}]}]}]},{"type":"blockMath","attrs":{"latex":"\\text{CE} = -\\frac{1}{n}\\sum_{i=1}^{n}\\sum_{j=1}^{k}y_{ij}\\log(\\hat{y}_{ij})"}},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Standard for neural network classification"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Hinge Loss"}]},{"type":"blockMath","attrs":{"latex":"\\text{Hinge} = \\frac{1}{n}\\sum_{i=1}^{n}\\max(0, 1 - y_i\\hat{y}_i)"}},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Based on "},{"type":"text","marks":[{"type":"bold"}],"text":"margin"},{"type":"text","text":" concept (distance to decision boundary)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Primarily used for "},{"type":"text","marks":[{"type":"bold"}],"text":"Support Vector Machines (SVMs)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Penalizes wrong predictions AND confident-but-wrong predictions"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"KL Divergence"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Measures information lost when approximating one distribution with another"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"For classification, equivalent to minimizing cross-entropy"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why the Distinction Matters for Generative AI"}]},{"type":"paragraph","content":[{"type":"text","text":"Understanding regression vs classification is foundational for "},{"type":"text","marks":[{"type":"bold"}],"text":"classical machine learning"},{"type":"text","text":" before diving into generative AI:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Context"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Application"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Classical ML"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Regression: price prediction; Classification: spam detection"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Generative AI"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Text generation is technically classification (predict next token from vocabulary); image generation can be regression (predict continuous pixel values) or classification (discrete buckets)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Loss choice"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Directly affects model convergence, stability, and final performance"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mental model"},{"type":"text","text":": Think of regression as "},{"type":"text","marks":[{"type":"italic"}],"text":"\"drawing a line through points\""},{"type":"text","text":" (fitting continuous relationships) and classification as "},{"type":"text","marks":[{"type":"italic"}],"text":"\"drawing a boundary between groups\""},{"type":"text","text":" (separating categories)."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Regression = continuous output"},{"type":"text","text":" (how much); "},{"type":"text","marks":[{"type":"bold"}],"text":"Classification = discrete output"},{"type":"text","text":" (which category)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Loss functions"},{"type":"text","text":" measure prediction error; models minimize loss during training"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"MSE/MAE"},{"type":"text","text":" dominate regression; "},{"type":"text","marks":[{"type":"bold"}],"text":"Cross-Entropy"},{"type":"text","text":" dominates classification"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Choice of loss function affects "},{"type":"text","marks":[{"type":"bold"}],"text":"outlier sensitivity"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"bold"}],"text":"convergence speed"},{"type":"text","text":", and "},{"type":"text","marks":[{"type":"bold"}],"text":"model robustness"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"This distinction is critical when designing generative AI systems, as token prediction is fundamentally a classification task"}]}]}]},{"type":"paragraph"}]}}
