{"format": "tiptap/v1", "updatedAt": "2026-06-22T08:49:00.712Z", "doc": {"type": "doc", "content": [{"type": "image", "attrs": {"src": "data:image/svg+xml;base64,", "alt": "Layers & Models — concept overview"}}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "What Layers & Models Are"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "In TensorFlow/Keras, "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Layers"}, {"type": "text", "text": " and "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Models"}, {"type": "text", "text": " are the two core data structures that define neural networks:"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Layer"}, {"type": "text", "text": ": A simple input/output transformation consisting of computation (in "}, {"type": "text", "marks": [{"type": "code"}], "text": "call()"}, {"type": "text", "text": " method) + state (weights)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Model"}, {"type": "text", "text": ": A directed acyclic graph (DAG) of layers grouped together with training/evaluation capabilities"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Think of layers as "}, {"type": "text", "marks": [{"type": "bold"}], "text": "individual building blocks"}, {"type": "text", "text": " (like bricks) and models as the "}, {"type": "text", "marks": [{"type": "bold"}], "text": "complete structure"}, {"type": "text", "text": " built from those blocks."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Why Layers & Models Matter in Generative AI"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Component"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Role in Generative AI"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Layers"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Implement specific operations: convolution (GANs), attention (transformers), dense layers (autoencoders)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Models"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Define complete architectures: StyleGAN generator, diffusion U-Net, transformer encoder-decoder"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Layers"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Handle preprocessing: normalization, text vectorization (portable with model)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Models"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Provide training loops: "}, {"type": "text", "marks": [{"type": "code"}], "text": ".fit()"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "code"}], "text": ".evaluate()"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "code"}], "text": ".predict()"}, {"type": "text", "text": " for end-to-end training"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Layers encapsulate state (weights) and computation, while models group layers together and can be trained on data."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Layers: The Building Blocks"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "What Is a Layer?"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "A "}, {"type": "text", "marks": [{"type": "bold"}], "text": "layer"}, {"type": "text", "text": " is the fundamental abstraction in Keras. It consists of:"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Computation"}, {"type": "text", "text": ": Defined in "}, {"type": "text", "marks": [{"type": "code"}], "text": "tf.keras.layers.Layer.call()"}, {"type": "text", "text": " method"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "State"}, {"type": "text", "text": ": Weights (TensorFlow variables) stored in "}, {"type": "text", "marks": [{"type": "code"}], "text": "layer.weights"}]}]}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import tensorflow as tf\nfrom tensorflow.keras import layers\n\n# Layer as function call\ndense_layer = layers.Dense(64, activation='relu')  # Layer instance [web:57]\n\n# Call layer like a function\noutput = dense_layer(input_tensor)  # tensor-in, tensor-out [web:57]\n\n# Unlike a plain function, layer maintains state\nprint(dense_layer.weights)  # Contains trainable weights (kernel, bias) [web:57]"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Key Characteristics"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Feature"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Description"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Callable"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Like a function: "}, {"type": "text", "marks": [{"type": "code"}], "text": "layer(input_tensor)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Stateful"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Maintains weights updated during training"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Composable"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Layers can be nested inside other layers"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Weight types"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Trainable (weights) + non-trainable (e.g., batch norm stats)"}]}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Common Layer Types"}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "text": "1. Dense (Fully Connected) Layers"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# For autoencoders, simple GANs\ndense = layers.Dense(\n    units=128,           # Number of output features\n    activation='relu',   # Activation function\n    use_bias=True,       # Include bias vector\n    kernel_initializer='glorot_uniform'  # Weight initialization\n)"}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "text": "2. Convolutional Layers (CNNs)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# For image generation (GANs, diffusion)\nconv = layers.Conv2D(\n    filters=32,          # Number of output channels\n    kernel_size=3,       # Filter size (3×3)\n    strides=1,           # Step size\n    padding='same',      # 'same' or 'valid'\n    activation='relu'\n)\n\n# Transposed convolution for upscaling (generator)\nconv_transpose = layers.Conv2DTranspose(\n    filters=64,\n    kernel_size=4,\n    strides=2,           # Upscale by 2x\n    padding='same'\n)"}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "text": "3. Recurrent Layers (Sequence Modeling)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# For text generation, time-series\nlstm = layers.LSTM(\n    units=256,\n    return_sequences=True  # Return all outputs\n)\n\n# Bidirectional for better context\nbidirectional = layers.Bidirectional(\n    layers.LSTM(128)\n)"}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "text": "4. Attention Layers (Transformers)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# For language models, text-to-image\nattention = layers.MultiHeadAttention(\n    num_heads=8,\n    key_dim=128\n)\n\n# Self-attention\nx = attention(query=x, value=x)"}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "text": "5. Normalization Layers"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Batch normalization (GANs)\nbatch_norm = layers.BatchNormalization()\n\n# Layer normalization (transformers)\nlayer_norm = layers.LayerNormalization()"}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "text": "6. Regularization Layers"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Dropout to prevent overfitting\ndropout = layers.Dropout(0.5)  # 50% dropout\n\n# Activity regularization\nlayers.Dense(64, activity_regularizer=tf.keras.regularizers.l2(0.01))"}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "text": "7. Preprocessing Layers"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Image preprocessing (portable with model)\nnormalization = layers.Normalization()\n\n# Text vectorization\nvectorization = layers.TextVectorization(\n    standardize='lower_and_strip_punctuation',\n    max_tokens=10000,\n    output_mode='int'\n)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Creating Custom Layers"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "class MLPBlock(layers.Layer):  # Subclass Layer [web:52]\n    def __init__(self):\n        super().__init__()\n        # Define sub-layers\n        self.dense_1 = layers.Dense(32)\n        self.dense_2 = layers.Dense(32)\n        self.dense_3 = layers.Dense(1)\n    \n    def call(self, inputs):  # Forward pass [web:42]\n        x = self.dense_1(inputs)\n        x = tf.keras.activations.relu(x)\n        x = self.dense_2(x)\n        x = tf.keras.activations.relu(x)\n        return self.dense_3(x)\n\n# Use custom layer\nmodel_input = layers.Input(shape=(100,))\noutput = MLPBlock()(model_input)"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Layers are recursively composable: if you assign a layer as an attribute of another layer, the outer layer tracks the inner layer's weights."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Models: Complete Architectures"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "What Is a Model?"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "A "}, {"type": "text", "marks": [{"type": "bold"}], "text": "model"}, {"type": "text", "text": " groups layers together into an object that can be trained on data. The "}, {"type": "text", "marks": [{"type": "code"}], "text": "tf.keras.Model"}, {"type": "text", "text": " class provides built-in training/evaluation methods:"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Method"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Purpose"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "model.fit()"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Trains for fixed number of epochs"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "model.predict()"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Generates predictions for input samples"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "model.evaluate()"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Returns loss and metrics values"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "model.compile()"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Configures optimizer, loss, metrics"}]}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Three Ways to Create Models"}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "text": "1. Sequential Model (Simplest)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "from tensorflow import keras\nfrom tensorflow.keras import layers\n\n# Linear stack of layers (one input → layers → one output)\nmodel = keras.Sequential([\n    layers.Input(shape=(784,)),\n    layers.Dense(256, activation='relu'),\n    layers.Dense(128, activation='relu'),\n    layers.Dense(784, activation='sigmoid')\n])\n\n# Compile and train\nmodel.compile(optimizer='adam', loss='binary_crossentropy')\nmodel.fit(train_data, train_labels, epochs=100)"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Best for: Simple image classification, sentiment analysis, basic regression"}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "text": "2. Functional API (Flexible)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Build arbitrary graphs of layers\ninput_layer = keras.Input(shape=(256, 256, 3))\n\nx = layers.Conv2D(32, 3, activation='relu')(input_layer)\nx = layers.Conv2D(64, 3, activation='relu')(x)\n\n# Skip connection\nresidual = layers.MaxPooling2D(3)(x)\nx = layers.Conv2D(64, 3, padding='same')(x)\nx = layers.Add()([x, residual])  # Skip connection\nx = layers.ReLU()(x)\n\noutput = layers.Conv2D(32, 3, padding='same')(x)\n\n# Create Model from input/output tensors\nmodel = keras.Model(inputs=input_layer, outputs=output, name='mini_resnet')"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Best for: Multi-input/output, skip connections (ResNet, U-Net), shared layers"}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "text": "3. Model Subclassing (Custom)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "class CustomModel(keras.Model):  # Subclass Model [web:51]\n    def __init__(self):\n        super().__init__()\n        self.dense1 = layers.Dense(256, activation='relu')\n        self.dense2 = layers.Dense(784, activation='sigmoid')\n    \n    def call(self, inputs):\n        x = self.dense1(inputs)\n        return self.dense2(x)\n\n# Use like any model\nmodel = CustomModel()\nmodel.compile(optimizer='adam', loss='binary_crossentropy')\nmodel.fit(train_data, train_labels)"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Best for: Custom training loops, complex research architectures"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Difference Between "}, {"type": "text", "marks": [{"type": "code"}], "text": "Layer"}, {"type": "text", "text": " and "}, {"type": "text", "marks": [{"type": "code"}], "text": "Model"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Aspect"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "layers.Layer"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "keras.Model"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Training loops"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "❌ No "}, {"type": "text", "marks": [{"type": "code"}], "text": ".fit()"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "code"}], "text": ".evaluate()"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "code"}], "text": ".predict()"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "✅ Has built-in loops"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Inner layers"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "❌ No "}, {"type": "text", "marks": [{"type": "code"}], "text": ".layers"}, {"type": "text", "text": " property"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "✅ Exposes "}, {"type": "text", "marks": [{"type": "code"}], "text": "model.layers"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Saving"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "❌ Limited serialization"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "✅ Full saving APIs"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use case"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "\"Layer\" or \"block\" (conv layer, ResNet block)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "\"Model\" or \"network\" (complete architecture)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Weight"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Leaner (no extra functionality)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Bigger (training/evaluation features)"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Rule"}, {"type": "text", "text": ": If you want to call "}, {"type": "text", "marks": [{"type": "code"}], "text": ".fit()"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "code"}], "text": ".evaluate()"}, {"type": "text", "text": ", or "}, {"type": "text", "marks": [{"type": "code"}], "text": ".predict()"}, {"type": "text", "text": " on a block, or save/load it separately, use "}, {"type": "text", "marks": [{"type": "code"}], "text": "Model"}, {"type": "text", "text": ". Otherwise, use "}, {"type": "text", "marks": [{"type": "code"}], "text": "Layer"}, {"type": "text", "text": "."}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Complete GAN Example with Layers & Models"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "from tensorflow import keras\nfrom tensorflow.keras import layers\n\n# Generator (Functional API for upscaling)\ndef build_generator():\n    input = keras.Input(shape=(128,))\n    \n    x = layers.Dense(256, activation='relu')(input)\n    x = layers.Dense(512, activation='relu')(x)\n    x = layers.Dense(1024, activation='relu')(x)\n    \n    # Upscale to image\n    x = layers.Dense(784, activation='sigmoid')(x)\n    output = layers.Reshape((28, 28, 1))(x)\n    \n    return keras.Model(inputs=input, outputs=output, name='generator')\n\n# Discriminator (Simple Sequential)\ndef build_discriminator():\n    model = keras.Sequential([\n        layers.Input(shape=(28, 28, 1)),\n        layers.Conv2D(64, 3, strides=2, padding='same'),\n        layers.LeakyReLU(0.2),\n        layers.Conv2D(128, 3, strides=2, padding='same'),\n        layers.LeakyReLU(0.2),\n        layers.GlobalAveragePooling2D(),\n        layers.Dense(1, activation='sigmoid')\n    ])\n    return model\n\n# Build models\ngenerator = build_generator()\ndiscriminator = build_discriminator()\n\n# Compile discriminator\ndiscriminator.compile(\n    optimizer=keras.optimizers.Adam(0.0002),\n    loss='binary_crossentropy',\n    metrics=['accuracy']\n)\n\n# Train\nfor epoch in range(100):\n    # Real images\n    real_images = load_batch()\n    \n    # Generate fake\n    noise = keras.random.normal((64, 128))\n    fake_images = generator(noise)\n    \n    # Train discriminator\n    discriminator.train_on_batch(real_images, ones)\n    discriminator.train_on_batch(fake_images, zeros)"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Mental Model"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Think of "}, {"type": "text", "marks": [{"type": "bold"}], "text": "layers"}, {"type": "text", "text": " as "}, {"type": "text", "marks": [{"type": "bold"}], "text": "individual tools"}, {"type": "text", "text": ":\n- Conv2D: Cuts shapes from images\n- Dense: Connects everything together\n- Dropout: Randomly removes connections\n- ReLU: Activates neurons"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Think of "}, {"type": "text", "marks": [{"type": "bold"}], "text": "models"}, {"type": "text", "text": " as the "}, {"type": "text", "marks": [{"type": "bold"}], "text": "complete factory"}, {"type": "text", "text": ":\n- Arranges tools in sequence (Sequential)\n- Routes data through multiple paths (Functional)\n- Has a control system (train/evaluate/predict)"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Key Takeaways"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Layer"}, {"type": "text", "text": " = Fundamental abstraction with computation ("}, {"type": "text", "marks": [{"type": "code"}], "text": "call()"}, {"type": "text", "text": ") + state (weights)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Model"}, {"type": "text", "text": " = Groups layers into object with training/evaluation methods ["}, {"type": "text", "marks": [{"type": "code"}], "text": ".fit()"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "code"}], "text": ".evaluate()"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "code"}], "text": ".predict()"}, {"type": "text", "text": "]"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Layers are composable"}, {"type": "text", "text": ": Nest layers inside other layers; outer layer tracks inner weights"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Three model types"}, {"type": "text", "text": ": Sequential (linear), Functional (arbitrary graphs), Subclassing (custom)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}, {"type": "code"}], "text": "Layer"}, {"type": "text", "marks": [{"type": "bold"}], "text": " vs "}, {"type": "text", "marks": [{"type": "bold"}, {"type": "code"}], "text": "Model"}, {"type": "text", "text": ": Model has "}, {"type": "text", "marks": [{"type": "code"}], "text": ".fit()"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "code"}], "text": ".layers"}, {"type": "text", "text": ", saving APIs; Layer is leaner"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Common layers"}, {"type": "text", "text": ": Dense, Conv2D, LSTM, MultiHeadAttention, BatchNormalization, Dropout"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Preprocessing layers"}, {"type": "text", "text": ": Can be included directly in models (portable after training)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "For generative AI"}, {"type": "text", "text": ": Use Conv2D/Conv2DTranspose (GANs), MultiHeadAttention (transformers), LSTM (text)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Functional API recommended"}, {"type": "text", "text": " for complex architectures (ResNet, U-Net, StyleGAN)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Custom layers"}, {"type": "text", "text": ": Subclass "}, {"type": "text", "marks": [{"type": "code"}], "text": "layers.Layer"}, {"type": "text", "text": " and implement "}, {"type": "text", "marks": [{"type": "code"}], "text": "call()"}, {"type": "text", "text": " for custom operations"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Layers are the "}, {"type": "text", "marks": [{"type": "bold"}], "text": "atomic building blocks"}, {"type": "text", "text": ", while models are the "}, {"type": "text", "marks": [{"type": "bold"}], "text": "complete architectures"}, {"type": "text", "text": " that combine layers into trainable systems for generative AI applications."}]}]}}