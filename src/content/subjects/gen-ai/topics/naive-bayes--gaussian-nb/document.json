{"format":"tiptap/v1","updatedAt":"2026-06-22T04:19:24.104Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Gaussian Naive Bayes"},{"type":"text","text":" is a variant of the Naive Bayes classifier specifically designed for "},{"type":"text","marks":[{"type":"bold"}],"text":"continuous numerical features"},{"type":"text","text":" by assuming that each feature follows a "},{"type":"text","marks":[{"type":"bold"}],"text":"Gaussian (Normal) distribution"},{"type":"text","text":" within each class — instead of counting frequencies like in standard Naive Bayes, it uses the bell curve probability density function to calculate likelihoods."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Definition"},{"type":"text","text":": A supervised learning algorithm that assumes continuous feature values are distributed according to a "},{"type":"text","marks":[{"type":"bold"}],"text":"Gaussian (Normal) distribution"},{"type":"text","text":" for each class."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key difference from standard Naive Bayes"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Standard Naive Bayes"},{"type":"text","text":": Works with discrete/categorical features (counts frequencies)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Gaussian Naive Bayes"},{"type":"text","text":": Works with continuous features (uses Gaussian distribution)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Core assumption"},{"type":"text","text":":\n- Each feature follows a "},{"type":"text","marks":[{"type":"bold"}],"text":"normal, bell-shaped distribution"},{"type":"text","text":" (like height of people in a population)\n- Features are "},{"type":"text","marks":[{"type":"bold"}],"text":"conditionally independent given the class"},{"type":"text","text":" (the \"naive\" assumption)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Gaussian Assumption"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Gaussian (Normal) Distribution"},{"type":"text","text":":\nThe probability density function is:"}]},{"type":"blockMath","attrs":{"latex":"P(x|C) = \\frac{1}{\\sqrt{2\\pi\\sigma^{2}}} \\exp\\left(-\\frac{(x - \\mu)^2}{2\\sigma^{2}}\\right)"}},{"type":"paragraph","content":[{"type":"text","text":"Where for each feature "},{"type":"inlineMath","attrs":{"latex":"x_i"}},{"type":"text","text":" and class "},{"type":"inlineMath","attrs":{"latex":"C"}},{"type":"text","text":":\n- "},{"type":"inlineMath","attrs":{"latex":"\\mu_C"}},{"type":"text","text":" = "},{"type":"text","marks":[{"type":"bold"}],"text":"mean"},{"type":"text","text":" of feature values for class "},{"type":"inlineMath","attrs":{"latex":"C"}},{"type":"text","text":"\n- "},{"type":"inlineMath","attrs":{"latex":"\\sigma^{2}_C"}},{"type":"text","text":" = "},{"type":"text","marks":[{"type":"bold"}],"text":"variance"},{"type":"text","text":" of feature values for class "},{"type":"inlineMath","attrs":{"latex":"C"}}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Visual"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"      Bell Curve (Gaussian Distribution)\n         ___\n        /   \\\n       /     \\\n      /       \\\n     /         \\\n    _____________\n      mean (μ)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it means"},{"type":"text","text":": For each class, every feature has its own mean and variance that define its Gaussian distribution."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How It Works: Step-by-Step"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 1: Training (Estimate Parameters)"}]},{"type":"paragraph","content":[{"type":"text","text":"For each class "},{"type":"inlineMath","attrs":{"latex":"C"}},{"type":"text","text":" and each feature "},{"type":"inlineMath","attrs":{"latex":"x_i"}},{"type":"text","text":":"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Calculate mean"},{"type":"text","text":" ("},{"type":"inlineMath","attrs":{"latex":"\\mu_{i,C}"}},{"type":"text","text":"):"}]}]}]},{"type":"blockMath","attrs":{"latex":"\\mu_{i,C} = \\frac{\\sum_{j \\in C} x_{i,j}}{N_C}"}},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Calculate variance"},{"type":"text","text":" ("},{"type":"inlineMath","attrs":{"latex":"\\sigma^{2}_{i,C}"}},{"type":"text","text":"):"}]}]}]},{"type":"blockMath","attrs":{"latex":"\\sigma^{2}_{i,C} = \\frac{\\sum_{j \\in C} (x_{i,j} - \\mu_{i,C})^2}{N_C}"}},{"type":"paragraph","content":[{"type":"text","text":"Where "},{"type":"inlineMath","attrs":{"latex":"N_C"}},{"type":"text","text":" = number of samples in class "},{"type":"inlineMath","attrs":{"latex":"C"}}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Result"},{"type":"text","text":": Store mean and variance for each feature-class pair."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 2: Prediction (Calculate Posterior)"}]},{"type":"paragraph","content":[{"type":"text","text":"For a new data point with features "},{"type":"inlineMath","attrs":{"latex":"x_1, x_2,..., x_d"}},{"type":"text","text":":"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Calculate likelihood"},{"type":"text","text":" for each class "},{"type":"inlineMath","attrs":{"latex":"C"}},{"type":"text","text":":"}]}]}]},{"type":"blockMath","attrs":{"latex":"P(x|C) = \\prod_{i=1}^{d} P(x_i|C)"}},{"type":"paragraph","content":[{"type":"text","text":"Where "},{"type":"inlineMath","attrs":{"latex":"P(x_i|C)"}},{"type":"text","text":" is the Gaussian probability density"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Calculate posterior probability"},{"type":"text","text":":"}]}]}]},{"type":"blockMath","attrs":{"latex":"P(C|x) = \\frac{P(x|C) \\times P(C)}{P(x)}"}},{"type":"paragraph","content":[{"type":"text","text":"Where "},{"type":"inlineMath","attrs":{"latex":"P(C)"}},{"type":"text","text":" = prior probability of class "},{"type":"inlineMath","attrs":{"latex":"C"}}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Choose class with highest posterior"},{"type":"text","text":":"}]}]}]},{"type":"blockMath","attrs":{"latex":"\\hat{C} = \\text{argmax}_C P(C|x)"}},{"type":"paragraph","content":[{"type":"text","text":"[medium](https://medium.com/@yodharin.monplub/decoding-gaussian-naive-bayes-a-gentle-introduction-930e83c041bd)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Mathematical Foundation"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"1. Bayes' Theorem"}]},{"type":"blockMath","attrs":{"latex":"P(C|x) = \\frac{P(x|C) \\times P(C)}{P(x)}"}},{"type":"paragraph","content":[{"type":"text","text":"Where:\n- "},{"type":"inlineMath","attrs":{"latex":"P(C|x)"}},{"type":"text","text":" = posterior probability of class "},{"type":"inlineMath","attrs":{"latex":"C"}},{"type":"text","text":" given features "},{"type":"inlineMath","attrs":{"latex":"x"}},{"type":"text","text":"\n- "},{"type":"inlineMath","attrs":{"latex":"P(x|C)"}},{"type":"text","text":" = likelihood of features given class "},{"type":"inlineMath","attrs":{"latex":"C"}},{"type":"text","text":" (Gaussian)\n- "},{"type":"inlineMath","attrs":{"latex":"P(C)"}},{"type":"text","text":" = prior probability of class "},{"type":"inlineMath","attrs":{"latex":"C"}},{"type":"text","text":"\n- "},{"type":"inlineMath","attrs":{"latex":"P(x)"}},{"type":"text","text":" = prior probability of features (constant for all classes)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"2. Naive Bayes Independence Assumption"}]},{"type":"blockMath","attrs":{"latex":"P(x|C) = P(x_1, x_2, ..., x_d | C) = \\prod_{i=1}^{d} P(x_i|C)"}},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key distinction"},{"type":"text","text":":\n- Unlike Quadratic Discriminant Analysis (QDA) which uses full covariance matrices\n- Gaussian Naive Bayes uses "},{"type":"text","marks":[{"type":"bold"}],"text":"diagonal covariance matrices"},{"type":"text","text":" (all non-diagonal entries = 0)\n- This enforces the independence assumption"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Covariance matrix"},{"type":"text","text":":\n$$\\Sigma = \\text{diag}(\\sigma_1^2, \\sigma_2^2,..., \\sigma_n^2)$$"}]},{"type":"paragraph","content":[{"type":"text","text":"Where \"diag\" means all values not on diagonal are zero."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Visual Example: Gaussian Distributions"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Two Classes: A (red) and B (blue)\nFeature: Height\n\nClass A: μ = 170cm, σ² = 10\nClass B: μ = 180cm, σ² = 15\n\n      Class A (red)      Class B (blue)\n         ___                ___\n        /   \\              /   \\\n       /     \\            /     \\\n      /       \\          /       \\\n     /         \\        /         \\\n    _____________      _____________\n      170 cm              180 cm\n      \nFor height = 175cm:\nP(A|175) based on red curve\nP(B|175) based on blue curve\n→ Choose class with higher probability"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Python Implementation"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from sklearn.naive_bayes import GaussianNB\nfrom sklearn.datasets import load_iris\nfrom sklearn.model_selection import train_test_split\n\n# Load data (continuous features)\niris = load_iris()\nX = iris.data  # Features: sepal length, width, petal length, width\ny = iris.target  # Classes: 0, 1, 2\n\n# Split data\nX_train, X_test, y_train, y_test = train_test_split(X, y)\n\n# Create and train model\nmodel = GaussianNB()\nmodel.fit(X_train, y_train)\n\n# Predict\npredictions = model.predict(X_test)\n\n# Calculate accuracy\naccuracy = model.score(X_test, y_test)\nprint(f\"Accuracy: {accuracy:.2f}\")"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Advantages"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Advantage"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Explanation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Simple and fast"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Straightforward to implement, computationally efficient"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Works with small data"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Only needs mean and variance per feature-class (few parameters)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Effective in high dimensions"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Independence assumption manages complexity well"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Interpretable"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Clear probabilistic explanation for each decision"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"No training iterations"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Parameters estimated directly from data (no optimization)"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Limitations"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Limitation"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Explanation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Strong independence assumption"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Features often correlated in real data"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sensitive to distribution"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Assumes Gaussian distribution (may not hold for all datasets)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Precursors needed"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"May need normalization/transformations if features aren't Gaussian"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Outliers affect estimates"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Mean and variance sensitive to extreme values"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use Gaussian Naive Bayes"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Case"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Why"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Continuous features"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Designed for numerical data (height, weight, temperature)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Small training dataset"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Needs little data to estimate parameters"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"High-dimensional data"}]}]},{"type":"tableCell","attrs":{