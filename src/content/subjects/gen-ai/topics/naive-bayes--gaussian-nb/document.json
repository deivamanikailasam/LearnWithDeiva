ableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Spam Filtering"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Classify emails using continuous features (word frequencies, character counts)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sentiment Analysis"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Classify reviews as positive/negative based on numerical scores"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fraud Detection"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Identify fraudulent transactions using transaction amounts, time intervals"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Image Recognition"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Classify images using pixel intensity values"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Gaussian Naive Bayes"},{"type":"text","text":": Naive Bayes variant for "},{"type":"text","marks":[{"type":"bold"}],"text":"continuous features"},{"type":"text","text":" assuming Gaussian distribution"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Gaussian assumption"},{"type":"text","text":": Each feature follows normal/bell-shaped distribution per class"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Parameters estimated"},{"type":"text","text":": Mean ("},{"type":"inlineMath","attrs":{"latex":"\\mu"}},{"type":"text","text":") and variance ("},{"type":"inlineMath","attrs":{"latex":"\\sigma^{2}"}},{"type":"text","text":") for each feature-class pair"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Likelihood formula"},{"type":"text","text":": "},{"type":"inlineMath","attrs":{"latex":"P(x|C) = \\prod P(x_i|C)"}},{"type":"text","text":" using Gaussian density function"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Diagonal covariance"},{"type":"text","text":": Enforces independence (non-diagonal entries = 0)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Simple and fast"},{"type":"text","text":": Computationally efficient, no training iterations"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Works with small data"},{"type":"text","text":": Only needs mean/variance per feature (few parameters)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"High dimensions"},{"type":"text","text":": Independence assumption handles many features well"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Interpretable"},{"type":"text","text":": Clear probabilistic explanation for predictions"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Limitation"},{"type":"text","text":": Assumes features are independent (often violated in reality)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Limitation"},{"type":"text","text":": Assumes Gaussian distribution (may not hold for all data)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best for"},{"type":"text","text":": Continuous features, small datasets, high-dimensional data"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Gaussian Naive Bayes is the \"continuous data specialist\" of the Naive Bayes family — by assuming each feature follows a bell curve (Gaussian) distribution within each class, it calculates likelihoods using mean and variance instead of counts, making it ideal for numerical features like height, weight, or temperature, while maintaining the simplicity and speed that make Naive Bayes popular despite the strong independence assumption."}]}]}}
