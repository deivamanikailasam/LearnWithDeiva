{"format":"tiptap/v1","updatedAt":"2026-06-22T03:52:42.772Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Support Vector Machines (SVM)"},{"type":"text","text":" are one of the "},{"type":"text","marks":[{"type":"bold"}],"text":"simplest and most elegant classification methods"},{"type":"text","text":" in machine learning that separate data into classes by finding the "},{"type":"text","marks":[{"type":"bold"}],"text":"optimal hyperplane"},{"type":"text","text":" that maximizes the distance (margin) to the closest points from each class."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"paragraph","content":[{"type":"text","text":"SVM is a "},{"type":"text","marks":[{"type":"bold"}],"text":"supervised learning algorithm"},{"type":"text","text":" that:\n- Represents each data point as coordinates in "},{"type":"text","marks":[{"type":"bold"}],"text":"n-dimensional space"},{"type":"text","text":" (features = coordinates)\n- Finds a "},{"type":"text","marks":[{"type":"bold"}],"text":"hyperplane"},{"type":"text","text":" (line in 2D, plane in 3D) to separate classes\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Maximizes the margin"},{"type":"text","text":" — the distance between the hyperplane and closest points from each class"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Core terms"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Support Vectors"},{"type":"text","text":" = points closest to the hyperplane (critical elements)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Hyperplane"},{"type":"text","text":" = subspace with dimension 1 lower than ambient space\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Margin"},{"type":"text","text":" = distance from hyperplane to support vectors"}]},{"type":"paragraph","content":[{"type":"text","