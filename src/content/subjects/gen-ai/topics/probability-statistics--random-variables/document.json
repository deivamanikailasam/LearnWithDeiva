l","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hypothesis Testing"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Test if model performance difference is significant"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Confidence Intervals"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Report uncertainty in predictions/estimates"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Real example"},{"type":"text","text":": In a GPT model, the predicted probability for next token is a random variable; we can compute confidence intervals for prediction quality."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key properties of random variables"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Expectation (Mean)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Expected value"},{"type":"text","text":": Average value weighted by probability."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Discrete"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"E[X] = Σ x · P(X = x)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Continuous"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"E[X] = ∫ x · f(x) dx"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": Fair die"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"X ∈ {1, 2, 3, 4, 5, 6}, P(X=x) = 1/6\nE[X] = 1×(1/6) + 2×(1/6) + 3×(1/6) + 4×(1/6) + 5×(1/6) + 6×(1/6)\n     = (1 + 2 + 3 + 4 + 5 + 6) / 6\n     = 21 / 6\n     = 3.5"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Variance"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Measure of spread"},{"type":"text","text":": How much values deviate from mean."}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Var(X) = E[(X - E[X])²]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Alternative formula"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Var(X) = E[X²] - (E[X])²"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": Fair die (E = 3.5)"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Var(X) = E[(X - 3.5)²]\n       = (1-3.5)²×(1/6) + (2-3.5)²×(1/6) + ... + (6-3.5)²×(1/6)\n       = 6.25/6 + 2.25/6 + 0.25/6 + 0.25/6 + 2.25/6 + 6.25/6\n       = 29.5 / 6\n       ≈ 2.92"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Standard Deviation"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"σ = √Var(X)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": Fair die"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"σ = √2.92 ≈ 1.71"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Independence"}]},{"type":"paragraph","content":[{"type":"text","text":"Two random variables X and Y are "},{"type":"text","marks":[{"type":"bold"}],"text":"independent"},{"type":"text","text":" if:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"P(X = x AND Y = y) = P(X = x) × P(Y = y)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Meaning"},{"type":"text","text":": Outcome of X doesn't affect outcome of Y."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Distributions — Probability patterns of random variables"}]},{"type":"paragraph","content":[{"type":"text","text":"A "},{"type":"text","marks":[{"type":"bold"}],"text":"distribution"},{"type":"text","text":" describes how probabilities are assigned to values of a random variable."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Common discrete distributions:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Distribution"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use case"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Formula"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Uniform"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Equal probability"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"P(X=x) = 1/n"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Bernoulli"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Binary outcome"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"P(X=1) = p, P(X=0) = 1-p"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Binomial"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Successes in n trials"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"P(X=k) = C(n,k) · p^k · (1-p)^(n-k)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Poisson"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Count in time interval"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"P(X=k) = (λ^k · e^(-λ)) / k!"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Common continuous distributions:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Distribution"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use case"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"PDF"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Normal (Gaussian)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Natural phenomena"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"f(x) = (1/√(2πσ²)) · e^(-(x-μ)²/(2σ²))"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Uniform"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Equal probability"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"f(x) = 1/(b-a) for x ∈ [a,b]"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Exponential"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Time until event"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"f(x) = λ · e^(-λx)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"t-distribution"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Small sample inference"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Complex formula"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"[britannica](https://www.britannica.com/topic/random-variable)"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Hypothesis Testing — Using random variables to make decisions"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Concept:"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hypothesis testing"},{"type":"text","text":" uses random variables to determine if observed data supports a claim about a population."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Steps:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Step 1: Formulate hypotheses\n  Null hypothesis (H₀): No effect (e.g., \"model A = model B\")\n  Alternative hypothesis (H₁): Effect exists (e.g., \"model A > model B\")\n\nStep 2: Choose test statistic\n  T = random variable computed from data (e.g., t-statistic, χ²)\n\nStep 3: Compute p-value\n  p = P(observing data as extreme as we did, assuming H₀ is true)\n\nStep 4: Make decision\n  If p < α (e.g., α = 0.05): Reject H₀ (statistically significant)\n  If p ≥ α: Fail to reject H₀ (not significant) [web:202][web:208]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example: Comparing two ML models"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"H₀: Model A accuracy = Model B accuracy\nH₁: Model A accuracy > Model B accuracy\n\nTest: t-test on 100 accuracy measurements\nResult: p = 0.02\n\nDecision: p < 0.05 → Reject H₀ → Model A is significantly better"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"p-value interpretation:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"p-value = probability that observed effect occurred by chance if no true effect exists\n\nConventionally:\n  p < 0.05: statistically significant\n  p < 0.01: highly significant [web:208]"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Confidence Intervals — Estimating uncertainty"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Concept:"}]},{"type":"paragraph","content":[{"type":"text","text":"A "},{"type":"text","marks":[{"type":"bold"}],"text":"confidence interval"},{"type":"text","text":" provides a range of plausible values for a population parameter, with a specified confidence level (e.g., 95%)."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Definition:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"100(1 - α)% confidence interval C(X) satisfies:\nP(θ ∈ C(X)) ≥ 1 - α"}]},{"type":"paragraph","content":[{"type":"text","text":"Where:\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"θ"},{"type":"text","text":" = true population parameter (e.g., mean μ)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"C(X)"},{"type":"text","text":" = interval computed from sample X\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"α"},{"type":"text","text":" = significance level (e.g., α = 0.05 for 95% CI)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Interpretation:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"95% CI means: If we repeat the study 100 times, the interval will contain the true value in 95 of them [web:208].\n\nOnce calculated, the parameter either IS or IS NOT in the interval—we'll never know for sure [web:204]."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Formula (for mean μ, known σ):"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Lower Boundary = Ȳ - z_(1-α/2) × (σ / √n)\nUpper Boundary = Ȳ + z_(1-α/2) × (σ / √n)"}]},{"type":"paragraph","content":[{"type":"text","text":"Where:\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Ȳ"},{"type":"text","text":" = sample mean\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"σ"},{"type":"text","text":" = population standard deviation\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"n"},{"type":"text","text":" = sample size\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"z"},{"type":"text","marks":[{"type":"bold"},{"type":"italic"}],"text":"(1-α/2)"},{"type":"text","marks":[{"type":"italic"}],"text":" = critical value from normal distribution (e.g., z = 1.96 for 95% CI)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example: Model accuracy"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Measured accuracy over 100 samples: Ȳ = 0.85\nPopulation σ = 0.05 (known)\nn = 100\n95% CI: z = 1.96\n\nLower = 0.85 - 1.96 × (0.05/√100) = 0.85 - 0.0098 = 0.8402\nUpper = 0.85 + 1.96 × (0.05/√100) = 0.85 + 0.0098 = 0.8598\n\n95% CI = [0.840, 0.860]\n\nInterpretation: True accuracy is between 84.0% and 86.0% with 95% confidence"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Confidence interval vs. p-value:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"A 95% CI includes the null hypothesis value if p ≥ 0.05\nA 95% CI excludes the null hypothesis value if p < 0.05 [web:202][web:206]"}]},{"type":"paragraph","content":[{"type":"text","text":"CI provides more information about "},{"type":"text","marks":[{"type":"bold"}],"text":"precision"},{"type":"text","text":" of estimate than p-value alone."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Python implementation"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Simulating random variables:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import numpy as np\n\n# Discrete: Bernoulli (coin flip)\ncoin_flips = np.random.binomial(n=1, p=0.5, size=1000)\n# 1 = heads, 0 = tails\nprint(f\"Heads proportion: {np.mean(coin_flips):.3f}\")  # ≈ 0.5\n\n# Continuous: Normal distribution\ntemperatures = np.random.normal(loc=20, scale=5, size=1000)\n# μ = 20°C, σ = 5°C\nprint(f\"Mean temperature: {np.mean(temperatures):.2f}\")  # ≈ 20"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Computing confidence intervals:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import numpy as np\nfrom scipy import stats\n\n# Sample data: model accuracies\naccuracies = np.random.normal(loc=0.85, scale=0.05, size=100)\n\n# 95% CI\nmean = np.mean(accuracies)\nstd = np.std(accuracies, ddof=1)  # sample std\nn = len(accuracies)\n\nci = stats.t.interval(alpha=0.95, df=n-1, loc=mean, scale=std/np.sqrt(n))\n\nprint(f\"Mean accuracy: {mean:.3f}\")\nprint(f\"95% CI: [{ci[0]:.3f}, {ci [youtube](https://www.youtube.com/watch?v=3v9w79NhsfI):.3f}]\")\n# e.g., Mean: 0.847, 95% CI: [0.837, 0.857]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Hypothesis testing:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import numpy as np\nfrom scipy import stats\n\n# Two models' accuracies\nmodel_A = np.random.normal(loc=0.85, scale=0.05, size=100)\nmodel_B = np.random.normal(loc=0.82, scale=0.05, size=100)\n\n# t-test: Is difference significant?\nt_stat, p_value = stats.ttest_ind(model_A, model_B)\n\nprint(f\"t-statistic: {t_stat:.3f}\")\nprint(f\"p-value: {p_value:.3f}\")\n\nif p_value < 0.05:\n    print(\"Model A is significantly better than Model B\")\nelse:\n    print(\"No significant difference\")"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key takeaways"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Random variable = function mapping random outcomes to numbers"},{"type":"text","text":": X maps {heads, tails} to {1, 0}"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Discrete"},{"type":"text","text":": Finite/countable values (dice, coin flips); use PMF"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Continuous"},{"type":"text","text":": Infinite values (temperature, height); use PDF"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Expectation (mean)"},{"type":"text","text":": E = average weighted by probability"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Variance"},{"type":"text","text":": Var(X) = E[(X - E)²] measures spread"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Standard deviation"},{"type":"text","text":": σ = √Var(X)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Distribution"},{"type":"text","text":": Describes probability assignment to values"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hypothesis testing"},{"type":"text","text":": Use p-values to test claims (p < 0.05 = significant)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Confidence interval"},{"type":"text","text":": Range containing true parameter with specified confidence (95% CI)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"CI vs p-value"},{"type":"text","text":": CI shows precision; p < 0.05 ↔ CI excludes null"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"For Generative AI, random variables model uncertainty in predictions, enable Bayesian inference for parameter estimation, support hypothesis testing for model comparison, and provide confidence intervals for quantifying prediction reliability."}]}]}}
