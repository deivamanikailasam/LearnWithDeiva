        "content": [
          {
            "type": "text",
            "text": "def auto_approve_eligible(\n    request:       BudgetExceptionRequest,\n    exception_log: list[dict],\n) -> bool:\n    \"\"\"Return True if the request qualifies for bot auto-approval.\"\"\"\n    if request.extra_budget_usd > 500:\n        return False\n    if request.urgency == Urgency.P0:\n        return False   # P0 always needs a human in the loop\n    # Check: no denied exceptions this quarter\n    import datetime\n    quarter_start = datetime.date.today().replace(\n        month=((datetime.date.today().month - 1) // 3) * 3 + 1, day=1\n    ).isoformat()\n    prior_denials = [\n        r for r in exception_log\n        if r[\"team\"] == request.team\n        and r[\"decision\"] == \"denied\"\n        and r[\"decided_at\"] >= quarter_start\n    ]\n    if prior_denials:\n        return False\n    # Check: optimisation plan is non-trivial\n    if len(request.optimisation_plan.split()) < 10:\n        return False\n    return True"
          }
        ]
