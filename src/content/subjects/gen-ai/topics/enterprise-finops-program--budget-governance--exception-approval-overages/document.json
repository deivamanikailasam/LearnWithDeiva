      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import datetime\n\ndef check_sla_breaches(\n    open_requests: list[BudgetExceptionRequest],\n    routes:        dict[str, ApprovalRoute],   # request_id -> route\n) -> list[BudgetExceptionRequest]:\n    \"\"\"Return requests whose SLA deadline is within 30 minutes or passed.\"\"\"\n    at_risk = []\n    now     = datetime.datetime.utcnow()\n    for req in open_requests:\n        if req.status != ExceptionStatus.PENDING:\n            continue\n        route    = routes.get(req.request_id)\n        if route is None:\n            continue\n        submitted = datetime.datetime.fromisoformat(req.submitted_at)\n        deadline  = submitted + datetime.timedelta(hours=route.sla_hours)\n        if deadline - now <= datetime.timedelta(minutes=30):\n            at_risk.append(req)\n    return at_risk"
          }
        ]
