: [{"type": "text", "text": "Slower than direct commits"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Direct to Main"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Fastest"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "High risk, no review"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Forking Workflow"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Perfect for open source"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Complex, extra steps"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Centralized Workflow"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Simple"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "No isolation, conflicts"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Feature Branch + PR is industry standard"}, {"type": "text", "text": " for most teams."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Security & Reliability"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Risks"}, {"type": "text", "text": ":\n- Unreviewed code → security vulnerabilities\n- Merging broken code → production failures\n- Accidental main branch changes"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Mitigation"}, {"type": "text", "text": ":\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Require reviews"}, {"type": "text", "text": " before merge (2+ for critical files)\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Enable CI tests"}, {"type": "text", "text": " on all PRs\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Protect main branch"}, {"type": "text", "text": ": No direct commits, must use PR\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Use draft PRs"}, {"type": "text", "text": " for WIP to avoid premature review requests"}]}, {"type": "horizontalRule"}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Key Takeaways"}, {"type": "text", "text": ":\n1. Git workflow = branch → change → push → PR → review → merge\n2. Feature branches "}, {"type": "text", "marks": [{"type": "bold"}], "text": "isolate changes"}, {"type": "text", "text": " and prevent breaking main code\n3. Pull requests are GitHub's "}, {"type": "text", "marks": [{"type": "bold"}], "text": "collaboration feature"}, {"type": "text", "text": " for discussing code before merge\n4. Code review "}, {"type": "text", "marks": [{"type": "bold"}], "text": "catches bugs early"}, {"type": "text", "text": " and maintains quality\n5. Keep PRs "}, {"type": "text", "marks": [{"type": "bold"}], "text": "small"}, {"type": "text", "text": ", write "}, {"type": "text", "marks": [{"type": "bold"}], "text": "clear descriptions"}, {"type": "text", "text": ", and "}, {"type": "text", "marks": [{"type": "bold"}], "text": "pull from main daily"}, {"type": "text", "text": "\n6. Always "}, {"type": "text", "marks": [{"type": "bold"}], "text": "wait for CI tests"}, {"type": "text", "text": " before merging"}]}]}}