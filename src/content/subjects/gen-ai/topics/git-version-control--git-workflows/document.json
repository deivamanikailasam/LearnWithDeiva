{"format": "tiptap/v1", "updatedAt": "2026-06-21T15:52:56.628Z", "doc": {"type": "doc", "content": [{"type": "image", "attrs": {"src": "data:image/svg+xml;base64,", "alt": "Git Workflows — concept overview"}}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "What It Is"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Git Workflows"}, {"type": "text", "text": " are standardized processes that teams follow to manage code changes collaboratively using Git. They define how developers create "}, {"type": "text", "marks": [{"type": "bold"}], "text": "branches"}, {"type": "text", "text": ", submit "}, {"type": "text", "marks": [{"type": "bold"}], "text": "pull requests (PRs)"}, {"type": "text", "text": ", and conduct "}, {"type": "text", "marks": [{"type": "bold"}], "text": "code reviews"}, {"type": "text", "text": " before merging changes into the main codebase. The core workflow is: "}, {"type": "text", "marks": [{"type": "italic"}], "text": "create a branch → make changes → push to remote → create PR → get review → merge"}, {"type": "text", "text": "."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Why It Matters"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Without a structured Git workflow:\n- Code changes collide, causing merge conflicts\n- Bugs slip into production without review\n- Team coordination breaks down\n- Repository history becomes chaotic and hard to debug"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "A proper workflow ensures "}, {"type": "text", "marks": [{"type": "bold"}], "text": "code quality"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "bold"}], "text": "team collaboration"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "bold"}], "text": "traceability"}, {"type": "text", "text": ", and "}, {"type": "text", "marks": [{"type": "bold"}], "text": "continuous integration"}, {"type": "text", "text": "."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Benefits"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Benefit"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Impact"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Isolated changes"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Feature branches prevent breaking main code"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Quality control"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Code review catches bugs before merge"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Collaboration"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "PRs enable discussion and feedback"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Clean history"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Organized commits and branches make debugging easier"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Early conflict detection"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Regular pulls from main reduce merge issues"}]}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Trade-offs"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Limitation"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Consequence"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Slower development"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Review process adds time before merging"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Coordination overhead"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Requires team communication and scheduling"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "PR fatigue"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Developers may get overwhelmed by many reviews"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Conflict resolution time"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Merge conflicts still require manual fixing"}]}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "How It Works"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "The Standard Pull Request Workflow"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Follow this 9-step development workflow:"}]}, {"type": "codeBlock", "attrs": {"language": "text"}, "content": [{"type": "text", "text": "1. [Developer] Clone/pull source of work target\n2. [Developer] Create branch for work\n3. [Developer] Add/modify functions (development work)\n4. [Developer] Push completed task to remote\n5. [Developer] Create PR (specify merge branch → target branch)\n6. [Reviewer] Check changes and review\n7. [Reviewer] Send feedback if necessary\n8. [Reviewer] Merge if no problems\n9. [Reviewer] Close if PR becomes unnecessary"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Repeat steps 3–7 as needed to improve code quality."}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Step-by-Step Breakdown"}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "text": "1. Create a Branch"}]}, {"type": "codeBlock", "attrs": {"language": "bash"}, "content": [{"type": "text", "text": "# Start from develop/main branch\ngit checkout develop\n\n# Create and switch to new feature branch\ngit checkout -b feature/something"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Why branches?"}, {"type": "text", "text": " Feature branches isolate changes, preventing work from breaking the main codebase."}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "text": "2. Make Changes & Commit"}]}, {"type": "codeBlock", "attrs": {"language": "bash"}, "content": [{"type": "text", "text": "# Stage changes\ngit add .\n\n# Commit with meaningful message\ngit commit -m \"Implement something feature\""}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Best practices:\n- Write "}, {"type": "text", "marks": [{"type": "bold"}], "text": "descriptive, concise"}, {"type": "text", "text": " commit messages\n- Clearly communicate the "}, {"type": "text", "marks": [{"type": "bold"}], "text": "purpose"}, {"type": "text", "text": " of each commit"}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "text": "3. Push Branch to Remote"}]}, {"type": "codeBlock", "attrs": {"language": "bash"}, "content": [{"type": "text", "text": "git push -u origin feature/something"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "This shares your changes with the team and prepares for PR creation."}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "text": "4. Create Pull Request"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "On GitHub/GitLab/Bitbucket:\n1. Navigate to repository\n2. Switch to your branch\n3. Click \"Pull requests\" → \"New pull request\"\n4. Select "}, {"type": "text", "marks": [{"type": "bold"}], "text": "base branch"}, {"type": "text", "text": " (usually "}, {"type": "text", "marks": [{"type": "code"}], "text": "main"}, {"type": "text", "text": "/"}, {"type": "text", "marks": [{"type": "code"}], "text": "develop"}, {"type": "text", "text": ") and "}, {"type": "text", "marks": [{"type": "bold"}], "text": "compare branch"}, {"type": "text", "text": " (your feature)\n5. Review changes that will be merged\n6. Add "}, {"type": "text", "marks": [{"type": "bold"}], "text": "title"}, {"type": "text", "text": " and "}, {"type": "text", "marks": [{"type": "bold"}], "text": "detailed description"}, {"type": "text", "text": " explaining what changes do and why\n7. Assign "}, {"type": "text", "marks": [{"type": "bold"}], "text": "reviewers"}, {"type": "text", "text": "\n8. Click \"Create pull request\""}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "What is a PR?"}, {"type": "text", "text": " On GitHub, a PR is a \"reviewable set of changes\" — you're requesting maintainers to \"pull\" your suggested changes into the project."}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "text": "5. Code Review Process"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "As a reviewer"}, {"type": "text", "text": ":\n1. Go to the PR on GitHub\n2. Click \"Files changed\" tab to see modifications\n3. Leave "}, {"type": "text", "marks": [{"type": "bold"}], "text": "inline comments"}, {"type": "text", "text": " by clicking the "}, {"type": "text", "marks": [{"type": "code"}], "text": "+"}, {"type": "text", "text": " next to problematic lines\n4. Discuss issues/suggestions directly within PR\n5. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Approve"}, {"type": "text", "text": " or "}, {"type": "text", "marks": [{"type": "bold"}], "text": "request changes"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Best practices for reviewers"}, {"type": "text", "text": ":\n- Don't just use GitHub's generated diff — "}, {"type": "text", "marks": [{"type": "bold"}], "text": "pull the branch and test yourself"}, {"type": "text", "text": "\n- Set specific times to check PRs\n- Add additional edits/commits if it saves back-and-forth"}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "text": "6. Respond to Feedback"}]}, {"type": "codeBlock", "attrs": {"language": "bash"}, "content": [{"type": "text", "text": "# Make changes locally on your feature branch\ngit checkout feature/something\n\n# Implement fixes, commit, push\ngit add .\ngit commit -m \"Fix: Address reviewer feedback\"\ngit push origin feature/something"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The PR "}, {"type": "text", "marks": [{"type": "bold"}], "text": "updates automatically"}, {"type": "text", "text": " with new commits."}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "text": "7. Merge Pull Request"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Once approved and all issues resolved:\n1. Click \"Merge pull request\" button on PR page\n2. Confirm merge\n3. Optionally "}, {"type": "text", "marks": [{"type": "bold"}], "text": "delete branch"}, {"type": "text", "text": " to keep repository clean"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Before merging"}, {"type": "text", "text": ": Wait for automated tests (CI) to ensure changes don't break the codebase."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "When to Use It"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Scenario"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Recommended Approach"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "New feature"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Create "}, {"type": "text", "marks": [{"type": "code"}], "text": "feature/"}, {"type": "text", "text": " branch from "}, {"type": "text", "marks": [{"type": "code"}], "text": "develop"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Bug fix"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Create "}, {"type": "text", "marks": [{"type": "code"}], "text": "bugfix/"}, {"type": "text", "text": " branch, target "}, {"type": "text", "marks": [{"type": "code"}], "text": "main"}, {"type": "text", "text": " or "}, {"type": "text", "marks": [{"type": "code"}], "text": "develop"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Small team"}, {"type": "text", "text": " (<5)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Direct feature branch → main workflow"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Large team"}, {"type": "text", "text": " (>20)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use GitFlow with "}, {"type": "text", "marks": [{"type": "code"}], "text": "develop"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "code"}], "text": "release"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "code"}], "text": "master"}, {"type": "text", "text": " branches"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Critical changes"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Require 2+ reviewer approvals + CI tests"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "When NOT to use"}, {"type": "text", "text": ": Don't bypass review—even for small changes, maintain code quality."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "How to Implement"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Branching Strategy Options"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Strategy"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Description"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Best For"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Feature Branch"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Each feature in isolated branch → merge to main"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Small teams, straightforward projects"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "GitFlow"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "code"}], "text": "main"}, {"type": "text", "text": " (production), "}, {"type": "text", "marks": [{"type": "code"}], "text": "develop"}, {"type": "text", "text": " (integration), "}, {"type": "text", "marks": [{"type": "code"}], "text": "release"}, {"type": "text", "text": " (pre-release), "}, {"type": "text", "marks": [{"type": "code"}], "text": "feature"}, {"type": "text", "text": " branches"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Medium/large teams, structured releases"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "GitHub Flow"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Any branch → PR → merge to "}, {"type": "text", "marks": [{"type": "code"}], "text": "master"}, {"type": "text", "text": " (always deployable)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Continuous deployment, small teams"}]}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Handling Merge Conflicts"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "When conflicts arise during PR:"}]}, {"type": "codeBlock", "attrs": {"language": "bash"}, "content": [{"type": "text", "text": "# Fetch latest branches\ngit fetch\n\n# Pull latest main changes\ngit checkout master\ngit pull origin master\n\n# Return to branch and merge master\ngit checkout my_new_branch\ngit merge master\n\n# Resolve conflicts in editor (IDEs assist)\ngit commit -am \"Merging master into my_new_branch\"\ngit push origin my_new_branch"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Then retry the PR on GitHub UI."}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Best Practices"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Pull regularly"}, {"type": "text", "text": " from "}, {"type": "text", "marks": [{"type": "code"}], "text": "main"}, {"type": "text", "text": " to avoid conflicts"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Keep PRs small and focused"}, {"type": "text", "text": " — reduces conflict probability"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Create meaningful PRs"}, {"type": "text", "text": " with clear descriptions"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Provide constructive feedback"}, {"type": "text", "text": " during code reviews"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Communicate purpose"}, {"type": "text", "text": " clearly in PR description"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use "}, {"type": "text", "marks": [{"type": "bold"}], "text": "draft PRs"}, {"type": "text", "text": " when not ready for review (won't auto-request reviewers)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Mark PR as "}, {"type": "text", "marks": [{"type": "bold"}], "text": "\"Ready for Review\""}, {"type": "text", "text": " when feedback wanted"}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Examples"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Simple Feature Development"}]}, {"type": "codeBlock", "attrs": {"language": "bash"}, "content": [{"type": "text", "text": "# 1. Start from develop\ngit checkout develop\n\n# 2. Create feature branch\ngit checkout -b feature/user-auth\n\n# 3. Make changes\ngit add .\ngit commit -m \"Add JWT authentication\"\n\n# 4. Push\ngit push -u origin feature/user-auth\n\n# 5. Create PR on GitHub → merge to develop\n# 6. Reviewer approves → merge\n# 7. Delete branch"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Iterative PR with Feedback"}]}, {"type": "codeBlock", "attrs": {"language": "text"}, "content": [{"type": "text", "text": "Developer creates PR\n  ↓\nReviewer comments: \"Use more exclamation points!!!\" [web:11]\n  ↓\nDeveloper makes fix commit\n  ↓\nPushes → PR updates automatically [web:11]\n  ↓\nReviewer approves → merge"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Real-World Production Usage"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Team of 10 developers at mid-sized company"}, {"type": "text", "text": ":\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Daily"}, {"type": "text", "text": ": 15–20 PRs created\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Review time"}, {"type": "text", "text": ": 2–4 hours average per PR\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Merge rate"}, {"type": "text", "text": ": 90% merge within 24 hours\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Branch strategy"}, {"type": "text", "text": ": GitFlow ("}, {"type": "text", "marks": [{"type": "code"}], "text": "main"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "code"}], "text": "develop"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "code"}], "text": "release/*"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "code"}], "text": "feature/*"}, {"type": "text", "text": ")\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "CI integration"}, {"type": "text", "text": ": Automated tests run on every PR\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Outcomes"}, {"type": "text", "text": ": 95%+ production stability, minimal bugs post-merge"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Common Mistakes"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Mistake"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Why It's Bad"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Fix"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Working directly on main"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Breaks production code"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Always use feature branches"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Large PRs (>400 lines)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Hard to review, high conflict risk"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Split into smaller PRs"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Poor PR descriptions"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Reviewers don't understand context"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Write detailed explanations"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Skipping tests before merge"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Bugs enter production"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Wait for CI tests"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Not pulling from main"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Accumulates conflicts"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowsp