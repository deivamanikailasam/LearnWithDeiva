}, {"type": "text", "text": ": Keep repo clean"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use draft PRs early"}, {"type": "text", "text": ": Share work-in-progress without requesting review"}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Tooling & Ecosystem"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Category"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Tools"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Platforms"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "GitHub, GitLab, Bitbucket"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "IDEs"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "VS Code (Git integration), IntelliJ (GitFlow support)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "CI/CD"}]}]}, {"type": "tableCell", "