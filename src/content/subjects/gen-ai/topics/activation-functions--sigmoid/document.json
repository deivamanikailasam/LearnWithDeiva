"},{"type":"text","text":": "},{"type":"inlineMath","attrs":{"latex":"\\sigma(x) = \\frac{1}{1 + e^{-x}}"}}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output range"},{"type":"text","text":": Always — interpretable as probability"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"S-shaped curve"},{"type":"text","text":": Smooth, continuously differentiable everywhere"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"At x = 0"},{"type":"text","text":": Output = 0.5 (uncertain)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Gradient"},{"type":"text","text":": "},{"type":"inlineMath","attrs":{"latex":"\\sigma(x) \\cdot (1 - \\sigma(x))"}},{"type":"text","text":", max = 0.25"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Vanishing gradient problem"},{"type":"text","text":": Severe — gradients disappear in deep layers"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Not zero-centered"},{"type":"text","text":": Output causes inefficient updates (Tanh is better)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Computationally expensive"},{"type":"text","text":": Requires exponential calculation vs. ReLU's simple max"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best use"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"bold"}],"text":"Binary classification output layer"},{"type":"text","text":" (probability interpretation)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}