{"format":"tiptap/v1","updatedAt":"2026-06-22T09:14:24.003Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What Device Placement Is"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Device placement"},{"type":"text","text":" is the process of explicitly specifying where tensors, models, and computations should reside in your system — typically on the "},{"type":"text","marks":[{"type":"bold"}],"text":"CPU (host)"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"bold"}],"text":"GPU (device)"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","text":"In deep learning frameworks like PyTorch and TensorFlow, you control device placement to ensure computations run on the GPU when available, leveraging CUDA for parallel processing."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why Device Placement Matters in Generative AI"}]},{"type":"paragraph","content":[{"type":"text","text":"Device placement is critical for training and inference because:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"CPU"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"GPU"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Speed"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"24 cores, slower for parallel math"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"16,000+ cores, 100x faster for matrices"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Memory"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Shared RAM"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Separate GPU memory"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use case"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Small models, preprocessing"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Large models, training, inference"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Teraflops"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"~1 teraflop"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"100+ teraflops (RTX 4090)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Without proper device placement, models train on CPU and take "},{"type":"text","marks":[{"type":"bold"}],"text":"days or weeks"},{"type":"text","text":" instead of "},{"type":"text","marks":[{"type":"bold"}],"text":"hours"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Device Placement in PyTorch"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Basic Device Placement"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import torch\n\n# Create tensor on CPU (default)\ntensor_cpu = torch.randn(1000, 1000)\n\n# Move tensor to GPU\ntensor_gpu = tensor_cpu.to('cuda')  # or tensor_cpu.cuda()\n\n# Operations automatically run on GPU\nresult = tensor_gpu @ tensor_gpu.T  # Matrix multiplication on GPU"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Checking CUDA Availability"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Check if CUDA is available\nif torch.cuda.is_available():\n    device = torch.device('cuda')\n    print(f\"Using GPU: {torch.cuda.get_device_name(0)}\")\n    print(f\"Number of GPUs: {torch.cuda.device_count()}\")\nelse:\n    device = torch.device('cpu')\n    print(\"CUDA not available, using CPU\")\n\n# Place tensor on device\ntensor = torch.randn(100, 50).to(device)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Placing Models on GPU"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Create model\nmodel = torch.nn.Sequential(\n    torch.nn.Linear(784, 256),\n    torch.nn.ReLU(),\n    torch.nn.Linear(256, 10)\n)\n\n# Move entire model to GPU\nmodel = model.to(device)  # or model.to('cuda')\n\n# All operations now run on GPU\ninput = torch.randn(64, 784).to(device)\noutput = model(input)  # Forward pass on GPU"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Multi-GPU Device Placement"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Multiple GPUs available\ndevice_0 = torch.device('cuda:0')  # First GPU\ndevice_1 = torch.device('cuda:1')  # Second GPU\n\n# Place different parts on different GPUs\nmodel_layer1 = torch.nn.Linear(784, 256).to(device_0)\nmodel_layer2 = torch.nn.Linear(256, 10).to(device_1)\n\n# Manual placement\ninput_gpu0 = torch.randn(64, 784).to(device_0)\noutput1 = model_layer1(input_gpu0)  # Runs on GPU 0\noutput1_gpu1 = output1.to(device_1)  # Move to GPU 1\noutput2 = model_layer2(output1_gpu1)  # Runs on GPU 1"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Device Placement in TensorFlow/Keras"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Basic Device Placement"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import tensorflow as tf\n\n# Check available devices\nprint(tf.config.list_physical_devices('GPU'))  # List GPUs [web:223]\n\n# Create tensor on CPU (default)\ntensor_cpu = tf.random.normal([1000, 1000])\n\n# Place tensor on GPU\nwith tf.device('GPU'):  # Or tf.device('cuda')\n    tensor_gpu = tf.random.normal([1000, 1000])\n    result = tf.matmul(tensor_gpu, tensor_gpu, transpose_b=True)\n\n# Alternative: explicit placement\ntensor_gpu = tensor_cpu.numpy()\ntensor_gpu = tf.convert_to_tensor(tensor_gpu, device='GPU:0')"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Automatic Device Placement"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Enable soft device placement (automatic)\ntf.config.set_soft_device_placement(True)  # Auto-assign tasks [web:223]\n\n# Model will automatically use GPU if available\nmodel = tf.keras.Sequential([\n    tf.keras.layers.Dense(256, activation='relu', input_shape=(784,)),\n    tf.keras.layers.Dense(10)\n])\n\nmodel.compile(optimizer='adam', loss='mse')\nmodel.fit(train_data, train_labels, epochs=10)  # Auto on GPU"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Explicit Device Placement"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Set visible devices (limit to specific GPU)\ntf.config.experimental.set_visible_devices('GPU:0', 'GPU')  # Only GPU 0 visible [web:223]\n\n# Get all physical devices\ngpus = tf.config.experimental.list_physical_devices('GPU')  # List GPUs [web:223]\nprint(gpus)\n\n# Use specific GPU in computation\nwith tf.device('/GPU:0'):\n    x = tf.random.normal([100, 100])\n    y = tf.matmul(x, x)"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Device Placement Strategies"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Best Practices"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# PyTorch recommended pattern\ndevice = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n\n# Create model and move to device\nmodel = MyModel().to(device)\n\n# Create data and move to device\ninput = torch.randn(64, 784).to(device)\ntarget = torch.randn(64, 10).to(device)\n\n# Training loop\noutput = model(input)  # Runs on device\nloss = compute_loss(output, target)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Explicit vs Implicit"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# IMPLICIT: Framework auto-assigns (TensorFlow with soft device placement)\nmodel = tf.keras.Model()\nmodel.fit(data, labels)  # Auto GPU if available\n\n# EXPLICIT: You control placement (PyTorch)\ndevice = torch.device('cuda')\nmodel = MyModel().to(device)\ninput = data.to(device)\noutput = model(input)  # Explicit GPU"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Memory Growth Strategy"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# PyTorch: Memory grows automatically\n# (No explicit setup needed)\n\n# TensorFlow: Set memory growth\ngpus = tf.config.experimental.list_physical_devices('GPU')\nfor gpu in gpus:\n    tf.config.experimental.set_memory_growth(gpu, True)  # Memory grows [web:223]"}]},{"type":"paragraph","content":[{"type":"text","text":"Sets memory to grow as needed instead of pre-allocating all."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common Device Methods"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Framework"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Method"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Description"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PyTorch"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":".to('cuda')"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Move tensor/model to GPU"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PyTorch"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":".cuda()"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Move tensor/model to GPU"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PyTorch"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":".cpu()"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Move tensor/model to CPU"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PyTorch"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":".device"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Get device of tensor"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"TensorFlow"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"tf.device('GPU')"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Set device context"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"TensorFlow"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"list_physical_devices('GPU')"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"List GPUs"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"TensorFlow"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"set_visible_devices()"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Limit visible GPUs"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Device Placement Issues"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Issue 1: CPU-GPU Mismatch"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# WRONG: Model on GPU, data on CPU\nmodel = MyModel().to('cuda')\ninput = torch.randn(64, 784)  # On CPU\noutput = model(input)  # ERROR! CPU vs GPU mismatch\n\n# RIGHT: Both on same device\nmodel = MyModel().to(device)\ninput = torch.randn(64, 784).to(device)  # On GPU\noutput = model(input)  # OK! Both on GPU"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Issue 2: Not Checking CUDA Availability"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# WRONG: Always assume GPU exists\nmodel = MyModel().to('cuda')  # CRASH if no GPU\n\n# RIGHT: Check first\nif torch.cuda.is_available():\n    model = MyModel().to('cuda')\nelse:\n    model = MyModel().to('cpu')"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Issue 3: Memory Not Released"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# WRONG: Don't clear GPU memory\nfor batch in dataset:\n    input = batch.to('cuda')\n    output = model(input)\n    # Don't delete input — memory stays allocated\n\n# RIGHT: Clear unnecessary tensors\nfor batch in dataset:\n    input = batch.to('cuda')\n    output = model(input)\n    del input  # Free GPU memory\n    torch.cuda.empty_cache()  # Clear cache"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Multi-GPU Considerations"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Device IDs"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# CUDA assigns device IDs automatically\n# Default: CUDA kernels execute on device ID 0 [web:227]\n# Multiple GPUs: GPU:0, GPU:1, GPU:2, ...\n\n# Explicit device selection\ndevice = torch.device('cuda:0')  # First GPU\n# or\ndevice = torch.device('cuda:1')  # Second GPU"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Virtual Device Mechanism"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# TensorFlow: Virtual devices (split GPU into logical parts)\ntf.config.experimental.set_virtual_device_configuration(\n    tf.config.experimental.list_physical_devices('GPU')[0],\n    [tf.config.experimental.VirtualDeviceConfiguration(memory_limit=4096)]\n)  # Split GPU into logical GPUs [web:223]"}]},{"type":"paragraph","content":[{"type":"text","text":"Allows manual cutting of one GPU into multiple virtual logical GPUs."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of device placement as "},{"type":"text","marks":[{"type":"bold"}],"text":"assigning work to the right factory"},{"type":"text","text":":"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"CPU (Small workshop)"},{"type":"text","text":": Good for simple tasks, serial work"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"GPU (Massive factory)"},{"type":"text","text":": 16,000 workers, perfect for parallel matrix math"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Device placement"},{"type":"text","text":": Decision of which factory does the work"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Data transfer"},{"type":"text","text":": Moving materials between workshops (expensive)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Same device"},{"type":"text","text":": Keep everything in one factory to avoid transfer"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Device placement"},{"type":"text","text":": Explicitly specifying CPU or GPU for tensors/models"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Host"},{"type":"text","text":": CPU device"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Device"},{"type":"text","text":": GPU device"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PyTorch"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":".to('cuda')"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"code"}],"text":".cuda()"},{"type":"text","text":" moves to GPU"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PyTorch"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":".to('cpu')"},{"type":"text","text":" moves to CPU"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"TensorFlow"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"tf.device('GPU')"},{"type":"text","text":" sets device context"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Check availability"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"torch.cuda.is_available()"},{"type":"text","text":" before using GPU"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Model on GPU"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"model.to(device)"},{"type":"text","text":" places entire model"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Data on GPU"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"input.to(device)"},{"type":"text","text":" places input data"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mismatch error"},{"type":"text","text":": Model and data must be on same device"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multi-GPU"},{"type":"text","text":": Use "},{"type":"text","marks":[{"type":"code"}],"text":"'cuda:0'"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"'cuda:1'"},{"type":"text","text":" for different GPUs"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Device ID 0"},{"type":"text","text":": Default GPU for CUDA kernels"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Memory growth"},{"type":"text","text":": TensorFlow can grow memory instead of pre-allocating"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Soft device placement"},{"type":"text","text":": TensorFlow auto-assigns tasks to GPU"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Visible devices"},{"type":"text","text":": Limit which GPUs are accessible"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"16,000+ cores"},{"type":"text","text":": RTX 4090 has over 16,000 CUDA cores"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Teraflops"},{"type":"text","text":": GPUs measure in trillions of FLOPs per second"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Transfer cost"},{"type":"text","text":": Moving data between CPU/GPU is expensive"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Compute-bound"},{"type":"text","text":": GPU jobs need lots of math, few transfers"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Proper device placement ensures your deep learning models run on the GPU when available, leveraging CUDA's parallel processing power to achieve "},{"type":"text","marks":[{"type":"bold"}],"text":"100x speedup"},{"type":"text","text":" for matrix operations compared to CPU, making training large generative AI models practical."}]}]}}
