:[{"type":"text","text":"Alternative: Install with pip"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"pip install poetry\npoetry --version"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Creating Projects with Poetry"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Initialize New Project"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Create new project with standard structure\npoetry new my-project\n\n# Creates:\n# my-project/\n# ├── pyproject.toml\n# ├── README.md\n# ├── my_project/\n# │   └── __init__.py\n# └── tests/\n#     └── __init__.py"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Add Poetry to Existing Project"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Navigate to existing project directory\ncd my_existing_project\n\n# Initialize Poetry (interactive, asks questions)\npoetry init\n\n# Or create basic pyproject.toml\npoetry init --no-interaction"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Managing Dependencies with Poetry"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Add Dependencies"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Add main dependency\npoetry add requests\n\n# Add specific version\npoetry add requests==2.32.3\n\n# Add version constraint\npoetry add requests>=2.28.0\n\n# Add development dependency\npoetry add --dev pytest"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Add to Dependency Groups"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Create custom group and add dependency\npoetry add pytest --group test\n\n# Add to docs group\npoetry add sphinx --group docs\n\n# Add multiple to same group\npoetry add black mypy --group dev"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Remove Dependencies"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Remove main dependency\npoetry remove requests\n\n# Remove from specific group\npoetry remove pytest --group test"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Update Dependencies"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Update specific package\npoetry update requests\n\n# Update all packages\npoetry update\n\n# Show outdated packages\npoetry show --outdated"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"code"}],"text":"pyproject.toml"},{"type":"text","text":" File"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What is "},{"type":"text","marks":[{"type":"code"}],"text":"pyproject.toml"},{"type":"text","text":"?"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"pyproject.toml"},{"type":"text","text":" is the "},{"type":"text","marks":[{"type":"bold"}],"text":"configuration file"},{"type":"text","text":" for Poetry that declares project metadata and dependencies."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example "},{"type":"text","marks":[{"type":"code"}],"text":"pyproject.toml"}]},{"type":"codeBlock","attrs":{"language":"toml"},"content":[{"type":"text","text":"[tool.poetry]\nname = \"my-project\"\nversion = \"0.1.0\"\ndescription = \"My AI project\"\nauthors = [\"Your Name <your@email.com>\"]\nlicense = \"MIT\"\nreadme = \"README.md\"\n\n# Main dependencies\n[tool.poetry.dependencies]\npython = \"^3.10\"\nrequests = \"2.32.3\"\nnumpy = \"1.26.4\"\npandas = \"2.2.2\"\ntorch = \"2.3.1\"\n\n# Development dependencies\n[tool.poetry.group.dev.dependencies]\npytest = \"8.2.2\"\nblack = \"24.4.2\"\nmypy = \"1.10.0\"\n\n# Test dependencies\n[tool.poetry.group.test.dependencies]\npytest = \"8.2.2\"\npytest-cov = \"5.0.0\"\n\n# Build settings\n[build-system]\nrequires = [\"poetry-core\"]\nbuild-backend = \"poetry.core.masonry.api\""}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"PEP 621 Standard Format (Modern)"}]},{"type":"codeBlock","attrs":{"language":"toml"},"content":[{"type":"text","text":"[project]\nname = \"my-project\"\nversion = \"0.1.0\"\ndescription = \"My AI project\"\nrequires-python = \">=3.10\"\ndependencies = [\n    \"requests==2.32.3\",\n    \"numpy==1.26.4\",\n    \"pandas==2.2.2\",\n]\n\n[project.optional-dependencies]\ndev = [\n    \"pytest==8.2.2\",\n    \"black==24.4.2\",\n]\n\n[tool.poetry]\n# Poetry-specific configuration"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Installing Dependencies"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Install All Dependencies"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Install all dependencies (creates virtual env if needed)\npoetry install\n\n# Install only main dependencies (no dev/test)\npoetry install --without dev,test\n\n# Install with dev dependencies\npoetry install --with dev\n\n# Install specific group\npoetry install --with test"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"code"}],"text":"poetry.lock"},{"type":"text","text":" File"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"poetry.lock"},{"type":"text","text":" is a "},{"type":"text","marks":[{"type":"bold"}],"text":"lockfile"},{"type":"text","text":" that pins exact versions of all dependencies, ensuring reproducible installs across machines."}]},{"type":"codeBlock","attrs":{"language":"toml"},"content":[{"type":"text","text":"[[package]]\nname = \"requests\"\nversion = \"2.32.3\"\ndescription = \"HTTP library\"\ncategory = \"main\"\noptional = false\npython-versions = \">=3.7\"\n\n[[package]]\nname = \"numpy\"\nversion = \"1.26.4\"\ndescription = \"Numerical Python\"\ncategory = \"main\"\noptional = false\npython-versions = \">=3.9\""}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key point:"},{"type":"text","text":" Always commit "},{"type":"text","marks":[{"type":"code"}],"text":"poetry.lock"},{"type":"text","text":" to ensure reproducible builds."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Running Commands in Poetry Environment"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Activate Environment"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Enter Poetry's virtual environment shell\npoetry shell\n\n# Now you're inside the environment\npython script.py"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Run Without Activating"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Run command within Poetry environment\npoetry run python script.py\npoetry run pytest\npoetry run black ."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Run Scripts"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Add script entry point to pyproject.toml\n[tool.poetry.scripts]\nmy-script = \"my_package.main:main\"\n\n# Run script\npoetry run my-script"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Exporting to "},{"type":"text","marks":[{"type":"code"}],"text":"requirements.txt"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Create "},{"type":"text","marks":[{"type":"code"}],"text":"requirements.txt"},{"type":"text","text":" from Poetry"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Export main dependencies\npoetry export -f requirements.txt --output requirements.txt\n\n# Include dev dependencies\npoetry export -f requirements.txt --with dev --output requirements.txt\n\n# Without hashes (faster)\npoetry export -f requirements.txt --without-hashes --output requirements.txt"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use case:"},{"type":"text","text":" Some systems still require "},{"type":"text","marks":[{"type":"code"}],"text":"requirements.txt"},{"type":"text","text":" (e.g., Docker, CI/CD)."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Building and Publishing Packages"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Build Package"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Build distribution packages\npoetry build\n\n# Creates:\n# dist/\n# ├── my-project-0.1.0.tar.gz\n# └── my_project-0.1.0-py3-none-any.whl"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Publish to PyPI"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Configure PyPI credentials\npoetry config pypi-token.my-pypi YOUR_TOKEN\n\n# Publish to PyPI\npoetry publish"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Poetry vs pip/venv Comparison"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Feature"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"pip"},{"type":"text","text":" + "},{"type":"text","marks":[{"type":"code"}],"text":"venv"}]}]},{"type":"tableHeader","attrs":{"col