{
  "format": "tiptap/v1",
  "doc": {
    "type": "doc",
    "content": [
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Token Streaming"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "LLMs do not generate text character by character — they sample "
          },
          {
            "type": "text",
            "text": "tokens",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": ", which are subword units typically 3–6 characters each. The Anthropic SDK surfaces these as variable-size text chunks that arrive asynchronously. Rendering them well requires handling partial markdown, batching React updates, and committing the final message only on completion."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Token streaming pipeline: model token generation → SDK stream → FastAPI SSE → client parser → React UI",
          "title": null
        }
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "How the SDK Exposes Streaming"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The Anthropic Python SDK provides three ways to consume a streamed response from a single call to "
          },
          {
            "type": "text",
            "text": "messages.stream()",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": ":"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\nfrom anthropic import AsyncAnthropic\n\nclient = AsyncAnthropic()\n\nasync def demo():\n    async with client.messages.stream(\n        model=\"claude-3-5-haiku-20241022\",\n        max_tokens=512,\n        messages=[{\"role\": \"user\", \"content\": \"Count to five.\"}],\n    ) as stream:\n\n        # Option 1: text_stream — async generator of decoded text chunks\n        async for text_chunk in stream.text_stream:\n            print(text_chunk, end=\"\", flush=True)\n\n        # Option 2: input_stream — raw typed event objects\n        # async for event in stream.input_stream:\n        #     if event.type == \"content_block_delta\":\n        #         print(event.delta.text, end=\"\", flush=True)\n\n        # After the context manager exits, usage is available:\n        msg = await stream.get_final_message()\n        print(f\"\\nInput tokens: {msg.usage.input_tokens}\")\n        print(f\"Output tokens: {msg.usage.output_tokens}\")\n        print(f\"Stop reason: {msg.stop_reason}\")\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "text_stream",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " is the convenience surface — it yields the decoded text string for each content_block_delta event, skipping all other event types. "
          },
          {
            "type": "text",
            "text": "input_stream",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " gives access to all event types including message_start, content_block_start, and message_stop — useful when you need to track tool use or log event metadata."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Stop Reason Matters"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Always check "
          },
          {
            "type": "text",
            "text": "stop_reason",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " after streaming completes. A truncated response requires different handling than a natural end:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "msg = await stream.get_final_message()\nmatch msg.stop_reason:\n    case \"end_turn\":\n        pass   # model finished normally\n    case \"max_tokens\":\n        # Response was cut off — warn the user or request continuation\n        await ws.send_json({\"type\": \"warning\", \"message\": \"Response truncated (max tokens)\"})\n    case \"stop_sequence\":\n        pass   # hit a custom stop sequence\n    case \"tool_use\":\n        # Model wants to call a tool; extract tool_use blocks from msg.content\n        ...\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Forwarding Tokens to the Client"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The FastAPI SSE generator should yield every text chunk immediately without batching — the client is responsible for display-side batching. Buffering on the server adds latency with no benefit."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# backend/routes/chat.py\nimport json\nfrom fastapi.responses import StreamingResponse\nfrom anthropic import AsyncAnthropic, APIStatusError\n\nclient = AsyncAnthropic()\n\nasync def _generate(messages: list, model: str, user_id: str):\n    try:\n        async with client.messages.stream(\n            model=model,\n            max_tokens=2048,\n            messages=messages,\n        ) as stream:\n            async for chunk in stream.text_stream:\n                yield f\"data: {json.dumps({'delta': chunk})}\\n\\n\"\n\n            msg = await stream.get_final_message()\n            yield f\"data: {json.dumps({\n                'done': True,\n                'stop_reason': msg.stop_reason,\n                'usage': {\n                    'input_tokens': msg.usage.input_tokens,\n                    'output_tokens': msg.usage.output_tokens,\n                },\n            })}\\n\\n\"\n\n    except APIStatusError as exc:\n        code = \"rate_limit\" if exc.status_code == 429 else \"api_error\"\n        yield f\"event: error\\ndata: {json.dumps({'code': code})}\\n\\n\"\n\n@router.post(\"/v1/chat/completions\")\nasync def stream_chat(req: ChatRequest, user=Depends(get_current_user)):\n    return StreamingResponse(\n        _generate(req.messages, req.model, user.id),\n        media_type=\"text/event-stream\",\n        headers={\"Cache-Control\": \"no-cache\", \"X-Accel-Buffering\": \"no\"},\n    )\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Client-Side Accumulation and RAF Batching"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "High-speed models can emit 50-100 tokens per second. Calling "
          },
          {
            "type": "text",
            "text": "setState",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " on every token triggers a React re-render for each chunk — at 100 tokens/s that is 100 synchronous renders per second, overwhelming the browser. Batch using "
          },
          {
            "type": "text",
            "text": "requestAnimationFrame",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " or a flush interval instead."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// utils/tokenBuffer.ts\nexport class TokenBuffer {\n  private buffer = \"\";\n  private rafId: number | null = null;\n  private readonly flush: (text: string) => void;\n\n  constructor(onFlush: (text: string) => void) {\n    this.flush = onFlush;\n  }\n\n  /** Call on every arriving delta */\n  push(delta: string): void {\n    this.buffer += delta;\n    if (this.rafId === null) {\n      this.rafId = requestAnimationFrame(() => {\n        this.rafId = null;\n        if (this.buffer) {\n          this.flush(this.buffer);\n          this.buffer = \"\";\n        }\n      });\n    }\n  }\n\n  /** Call when [DONE] arrives — flush immediately */\n  complete(): void {\n    if (this.rafId !== null) {\n      cancelAnimationFrame(this.rafId);\n      this.rafId = null;\n    }\n    if (this.buffer) {\n      this.flush(this.buffer);\n      this.buffer = \"\";\n    }\n  }\n}\n"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The buffer coalesces all deltas that arrive within a single animation frame (~16 ms at 60 fps) into one state update, capping renders at 60/s regardless of token throughput."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// In the streaming hook:\nimport { useRef, useCallback, useState } from \"react\";\nimport { TokenBuffer } from \"../utils/tokenBuffer\";\n\nexport function useChatStream(apiUrl: string, token: string) {\n  const [messages, setMessages] = useState<Message[]>([]);\n  const accRef = useRef(\"\");\n  const bufferRef = useRef<TokenBuffer | null>(null);\n\n  const send = useCallback(async (userText: string) => {\n    accRef.current = \"\";\n\n    bufferRef.current = new TokenBuffer((flushedText) => {\n      accRef.current += flushedText;\n      setMessages(prev => {\n        const next = [...prev];\n        const last = next[next.length - 1];\n        if (last?.role === \"assistant\") {\n          next[next.length - 1] = { ...last, content: accRef.current };\n        } else {\n          next.push({ role: \"assistant\", content: accRef.current });\n        }\n        return next;\n      });\n    });\n\n    // ... fetch + SSE parser loop ...\n    // In the delta handler:\n    //   bufferRef.current?.push(evt.delta)\n    // In the done handler:\n    //   bufferRef.current?.complete()\n  }, []);\n  ...\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Handling Partial Markdown During Streaming"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When a code fence is still open (the model has emitted "
          },
          {
            "type": "text",
            "text": "```python",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " but not the closing "
          },
          {
            "type": "text",
            "text": "```",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": "), most markdown parsers treat the rest of the document as code — which corrupts the render. Two strategies:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Detect open fences and delay parsing",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " — count backtick fences; if odd, append a synthetic closing fence before parsing. Remove it from the display after the real one arrives."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Defer full parse until done",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " — render raw text during streaming, switch to markdown-rendered output only when the response is complete. Simpler, but loses formatting for long responses."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "/** Returns true if the markdown string has an unclosed code fence */\nexport function hasOpenCodeFence(text: string): boolean {\n  const lines = text.split(\"\\n\");\n  let open = false;\n  let lang = \"\";\n  for (const line of lines) {\n    if (line.startsWith(\"```\")) {\n      if (!open) {\n        open = true;\n        lang = line.slice(3).trim();\n      } else {\n        open = false;\n        lang = \"\";\n      }\n    }\n  }\n  return open;\n}\n\n/** Append a synthetic closing fence so the parser doesn't corrupt the rest */\nexport function closeFences(text: string, lang: string): string {\n  return hasOpenCodeFence(text) ? text + \"\\n```\" : text;\n}\n\n// In MarkdownRenderer when streaming:\nconst safeContent = isStreaming ? closeFences(content, \"\") : content;\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "React Rendering Optimisation"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "React.memo and useDeferredValue"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The streaming bubble re-renders on every buffer flush. Wrapping child components in "
          },
          {
            "type": "text",
            "text": "React.memo",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " prevents unnecessary sub-tree re-renders when only the streaming text changes."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { memo, useDeferredValue } from \"react\";\n\n// Stable child components — only re-render if props change\nconst MessageBubble = memo(function MessageBubble({\n  role,\n  content,\n  isStreaming,\n}: {\n  role: string;\n  content: string;\n  isStreaming: boolean;\n}) {\n  // Defer expensive markdown parse — keeps input field responsive\n  // The deferred value may lag by one frame, but that's acceptable\n  const deferredContent = useDeferredValue(content);\n\n  return (\n    <div className={role === \"user\" ? \"user-bubble\" : \"assistant-bubble\"}>\n      {isStreaming ? (\n        // During streaming: render raw text (fast) + cursor\n        <>\n          <pre style={{ whiteSpace: \"pre-wrap\" }}>{content}</pre>\n          <span className=\"cursor\">▌</span>\n        </>\n      ) : (\n        // After done: render parsed markdown\n        <MarkdownRenderer content={deferredContent} />\n      )}\n    </div>\n  );\n});\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Streaming Cursor CSS"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "css"
        },
        "content": [
          {
            "type": "text",
            "text": "/* Blinking cursor while streaming */\n.cursor {\n  display: inline-block;\n  animation: blink 0.8s step-end infinite;\n  color: #6366f1;\n  font-weight: bold;\n}\n\n@keyframes blink {\n  0%, 100% { opacity: 1; }\n  50%       { opacity: 0; }\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Tracking Token Usage on the Client"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The server emits a "
          },
          {
            "type": "text",
            "text": "done",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " event with token counts. Displaying this gives users visibility into model costs and helps diagnose truncation."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// In the SSE parser — handle the done event:\nif (evt.done) {\n  const { input_tokens, output_tokens, stop_reason } = evt.usage ?? {};\n  setUsage({ inputTokens: input_tokens ?? 0, outputTokens: output_tokens ?? 0 });\n  if (stop_reason === \"max_tokens\") {\n    setWarning(\"Response truncated. Ask the model to continue.\");\n  }\n  bufferRef.current?.complete();\n  setStreaming(false);\n}\n"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// Optional: display usage beneath the message\nfunction TokenStats({ inputTokens, outputTokens }: { inputTokens: number; outputTokens: number }) {\n  return (\n    <div className=\"token-stats\">\n      {inputTokens.toLocaleString()} in · {outputTokens.toLocaleString()} out\n    </div>\n  );\n}\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Unit Tests for the Token Buffer"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "// tokenBuffer.test.ts\nimport { TokenBuffer } from \"./tokenBuffer\";\n\ndescribe(\"TokenBuffer\", () => {\n  it(\"coalesces multiple pushes into one flush callback\", async () => {\n    const flushed: string[] = [];\n    const buf = new TokenBuffer((t) => flushed.push(t));\n\n    buf.push(\"Hello\");\n    buf.push(\", \");\n    buf.push(\"world\");\n\n    // Before the animation frame fires, nothing has flushed\n    expect(flushed).toHaveLength(0);\n\n    // Advance fakes timers (or use jest's fake requestAnimationFrame shim)\n    await new Promise((r) => requestAnimationFrame(r));\n    expect(flushed).toHaveLength(1);\n    expect(flushed[0]).toBe(\"Hello, world\");\n  });\n\n  it(\"complete() flushes immediately without waiting for RAF\", () => {\n    const flushed: string[] = [];\n    const buf = new TokenBuffer((t) => flushed.push(t));\n    buf.push(\"partial\");\n    buf.complete();\n    expect(flushed).toEqual([\"partial\"]);\n  });\n});\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Testing the Open Fence Detector"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "typescript"
        },
        "content": [
          {
            "type": "text",
            "text": "import { hasOpenCodeFence, closeFences } from \"./markdownUtils\";\n\ntest(\"detects unclosed triple-backtick fence\", () => {\n  expect(hasOpenCodeFence(\"```python\\nprint('hi')\")).toBe(true);\n  expect(hasOpenCodeFence(\"```python\\nprint('hi')\\n```\")).toBe(false);\n  expect(hasOpenCodeFence(\"no fences here\")).toBe(false);\n});\n\ntest(\"closeFences appends closing fence for open block\", () => {\n  const partial = \"Here is code:\\n```python\\ndef foo():\";\n  const closed = closeFences(partial, \"\");\n  expect(closed.endsWith(\"\\n```\")).toBe(true);\n});\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Use "
              },
              {
                "type": "text",
                "text": "stream.text_stream",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " for the simplest path to text deltas and check "
              },
              {
                "type": "text",
                "text": "stop_reason",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " after the stream ends. Batch React state updates with "
              },
              {
                "type": "text",
                "text": "requestAnimationFrame",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " to cap renders at 60/s, detect open code fences and append a synthetic closing fence so the markdown parser does not corrupt in-progress output, and switch from raw-text display to fully-parsed markdown only when the "
              },
              {
                "type": "text",
                "text": "done",
                "marks": [
                  {
                    "type": "code"
                  }
                ]
              },
              {
                "type": "text",
                "text": " event arrives."
              }
            ]
          }
        ]
      }
    ]
  }
}