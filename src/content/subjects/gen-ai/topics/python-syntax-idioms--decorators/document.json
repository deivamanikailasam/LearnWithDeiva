{"format":"tiptap/v1","updatedAt":"2026-06-21T09:15:04.613Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What Are Decorators?"}]},{"type":"paragraph","content":[{"type":"text","text":"A "},{"type":"text","marks":[{"type":"bold"}],"text":"decorator"},{"type":"text","text":" is a function that extends the behavior of another function "},{"type":"text","marks":[{"type":"bold"}],"text":"without modifying the base function"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","text":"Think of it like a "},{"type":"text","marks":[{"type":"bold"}],"text":"gift wrapper"},{"type":"text","text":":\n- You have an object (your original function)\n- A decorator takes that function, wraps it in new functionality, and returns an "},{"type":"text","marks":[{"type":"bold"}],"text":"enhanced version"},{"type":"text","text":"\n- It modifies how a function behaves "},{"type":"text","marks":[{"type":"bold"}],"text":"without changing the code inside the function itself"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why Use Decorators?"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Benefit"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Description"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Code reusability"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Add functionality once, use everywhere"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Readability"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Clean, declarative syntax with "},{"type":"text","marks":[{"type":"code"}],"text":"@"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Separation of concerns"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Keep core logic separate from extensions"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"No source modification"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Enhance behavior without altering original code"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"code"}],"text":"@"},{"type":"text","text":" Syntax (Syntactic Sugar)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Basic Decorator Syntax"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"@decorator_name\ndef function():\n    pass"}]},{"type":"paragraph","content":[{"type":"text","text":"Place the decorator's name preceded by "},{"type":"text","marks":[{"type":"code"}],"text":"@"},{"type":"text","text":" directly "},{"type":"text","marks":[{"type":"bold"}],"text":"above the function definition"},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What Actually Happens Under the Hood?"}]},{"type":"paragraph","content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"code"}],"text":"@"},{"type":"text","text":" syntax is "},{"type":"text","marks":[{"type":"bold"}],"text":"syntactic sugar"},{"type":"text","text":" — a shortcut:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# With @ syntax (clean)\n@uppercase\ndef greet():\n    return \"Hello\"\n\n# What Python actually does (under the hood)\ndef greet():\n    return \"Hello\"\ngreet = uppercase(greet)  # Pass function to decorator, reassign"}]},{"type":"paragraph","content":[{"type":"text","text":"When you write "},{"type":"text","marks":[{"type":"code"}],"text":"@uppercase"},{"type":"text","text":" above "},{"type":"text","marks":[{"type":"code"}],"text":"greet"},{"type":"text","text":", Python:\n1. Takes the "},{"type":"text","marks":[{"type":"code"}],"text":"greet"},{"type":"text","text":" function\n2. Passes it into the "},{"type":"text","marks":[{"type":"code"}],"text":"uppercase"},{"type":"text","text":" function\n3. Assigns the result back to the name "},{"type":"text","marks":[{"type":"code"}],"text":"greet"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Anatomy of a Decorator"}]},{"type":"paragraph","content":[{"type":"text","text":"A standard decorator has "},{"type":"text","marks":[{"type":"bold"}],"text":"three parts"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"def decorator(func):\n    # 1. Wrapper function (creates a sandwich)\n    def wrapper(*args, **kwargs):\n        # 2. Code BEFORE original function\n        # 3. Call original function\n        result = func(*args, **kwargs)\n        # 4. Code AFTER original function\n        return result  # ← Must return!\n    return wrapper  # ← Return wrapper"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Components"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Part"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Purpose"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Outer function"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Takes the function as input"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Wrapper function"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Creates a \"sandwich\" around the original call"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Return wrapper"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Returns wrapper to replace original"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"The wrapper can:\n- Run code "},{"type":"text","marks":[{"type":"bold"}],"text":"before"},{"type":"text","text":" the original function\n- Call the original function\n- Run code "},{"type":"text","marks":[{"type":"bold"}],"text":"after"},{"type":"text","text":" the original function"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Simple Example: \"Be Polite\" Decorator"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"def be_polite(func):\n    def wrapper():\n        print(\"Please, would you kindly...\")\n        func()\n        print(\"Thank you! 🙏\")\n    return wrapper\n\n@be_polite\ndef say_hello():\n    print(\"Hello!\")\n\nsay_hello()\n# Output:\n# Please, would you kindly...\n# Hello!\n# Thank you! 🙏"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Handling Arguments with "},{"type":"text","marks":[{"type":"code"}],"text":"*args"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"code"}],"text":"**kwargs"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Problem: Functions with Parameters"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# This breaks if function takes arguments!\ndef decorator(func):\n    def wrapper():\n        func()  # Won't work with arguments!\n    return wrapper"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Solution: Use "},{"type":"text","marks":[{"type":"code"}],"text":"*args"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"code"}],"text":"**kwargs"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"def decorator(func):\n    def wrapper(*args, **kwargs):  # Accept ANY arguments\n        print(\"Before function call\")\n        result = func(*args, **kwargs)  # Pass arguments blindly\n        print(\"After function call\")\n        return result  # ← Don't forget to return!\n    return wrapper\n\n@decorator\ndef greet(name, age):\n    return f\"Hello {name}, age {age}\"\n\nprint(greet(\"Alice\", 25))\n# Output:\n# Before function call\n# Hello Alice, age 25\n# After function call"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why this works:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"code"}],"text":"*args"},{"type":"text","text":" — accepts any number of "},{"type":"text","marks":[{"type":"bold"}],"text":"positional"},{"type":"text","text":" arguments\n- "},{"type":"text","marks":[{"type":"code"}],"text":"**kwargs"},{"type":"text","text":" — accepts any number of "},{"type":"text","marks":[{"type":"bold"}],"text":"keyword"},{"type":"text","text":" arguments\n- Passes them \"blindly\" to the original function, ensuring nothing gets lost"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common Mistake: Missing Return Value"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Bug"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"def bad_decorator(func):\n    def wrapper(*args, **kwargs):\n        func(*args, **kwargs)  # ← Missing return!\n    return wrapper\n\n@bad_decorator\ndef add(a, b):\n    return a + b\n\nprint(add(2, 3))  # Output: None (not 5!)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The Fix"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"def good_decorator(func):\n    def wrapper(*args, **kwargs):\n        result = func(*args, **kwargs)  # Capture result\n        return result  # ← Return it!\n    return wrapper\n\n@good_decorator\ndef add(a, b):\n    return a + b\n\nprint(add(2, 3))  # Output: 5 ✅"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key rule:"},{"type":"text","text":" If your original function returns a value, your wrapper "},{"type":"text","marks":[{"type":"bold"}],"text":"must capture and return it"},{"type":"text","text":". Without returning, the decorated function returns "},{"type":"text","marks":[{"type":"code"}],"text":"None"},{"type":"text","text":", effectively deleting the result."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Practical Use Case: Performance Timer"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import time\n\ndef timer(func):\n    def wrapper(*args, **kwargs):\n        start = time.time()\n        result = func(*args, **kwargs)\n        end = time.time()\n        print(f\"{func.__name__} took {end - start:.4f} seconds\")\n        return result\n    return wrapper\n\n@timer\ndef slow_function():\n    time.sleep(1)\n    return \"Done\"\n\nslow_function()\n# Output: slow_function took 1.0002 seconds"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Stacking Multiple Decorators"}]},{"type":"paragraph","content":[{"type":"text","text":"You can apply "},{"type":"text","marks":[{"type":"bold"}],"text":"multiple decorators"},{"type":"text","text":" to a single function:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"def decorator1(func):\n    def wrapper(*args, **kwargs):\n        print(\"Decorator 1 BEFORE\")\n        result = func(*args, **kwargs)\n        print(\"Decorator 1 AFTER\")\n        return result\n    return wrapper\n\ndef decorator2(func):\n    def wrapper(*args, **kwargs):\n        print(\"Decorator 2 BEFORE\")\n        result = func(*args, **kwargs)\n        print(\"Decorator 2 AFTER\")\n        return result\n    return wrapper\n\n@decorator1\n@decorator2\ndef greet(name):\n    print(f\"Hello, {name}\")\n\ngreet(\"Alice\")\n# Output:\n# Decorator 1 BEFORE\n# Decorator 2 BEFORE\n# Hello, Alice\n# Decorator 2 AFTER\n# Decorator 1 AFTER"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Order:"},{"type":"text","text":" Decorators stack from "},{"type":"text","marks":[{"type":"bold"}],"text":"bottom to top"},{"type":"text","text":" (closest to function executed first)."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Using "},{"type":"text","marks":[{"type":"code"}],"text":"functools.wraps"},{"type":"text","text":" (Best Practice)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from functools import wraps\n\ndef timer(func):\n    @wraps(func)  # Preserves function metadata\n    def wrapper(*args, **kwargs):\n        start = time.time()\n        result = func(*args, **kwargs)\n        end = time.time()\n        print(f\"{func.__name__} took {end - start:.4f} seconds\")\n        return result\n    return wrapper\n\n@timer\ndef slow_function():\n    time.sleep(1)\n    return \"Done\"\n\nprint(slow_function.__name__)  # Output: slow_function (not wrapper!)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"@wraps"},{"type":"text","marks":[{"type":"bold"}],"text":"?"},{"type":"text","text":"\n- Preserves original function's "},{"type":"text","marks":[{"type":"code"}],"text":"__name__"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"__doc__"},{"type":"text","text":", and metadata\n- Makes debugging easier\n- Standard practice for decorators"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Class-Based Decorators"}]},{"type":"paragraph","content":[{"type":"text","text":"Decorators can also be "},{"type":"text","marks":[{"type":"bold"}],"text":"classes"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"class CountCalls:\n    def __init__(self, func):\n        self.func = func\n        self.count = 0\n    \n    def __call__(self, *args, **kwargs):\n        self.count += 1\n        print(f\"Call {self.count} of {self.func.__name__}\")\n        return self.func(*args, **kwargs)\n\n@CountCalls\ndef greet(name):\n    print(f\"Hello, {name}\")\n\ngreet(\"Alice\")  # Call 1 of greet\ngreet(\"Bob\")     # Call 2 of greet"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key:"},{"type":"text","text":" "},{"type":"text","marks":[{"type":"code"}],"text":"__call__"},{"type":"text","text":" lets the class instance be called like a function."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Decorators with Arguments"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"def repeat(times):\n    def decorator(func):\n        def wrapper(*args, **kwargs):\n            for _ in range(times):\n                func(*args, **kwargs)\n        return wrapper\n    return decorator\n\n@repeat(3)\ndef greet(name):\n    print(f\"Hello, {name}\")\n\ngreet(\"Alice\")\n# Output:\n# Hello, Alice\n# Hello, Alice\n# Hello, Alice"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Structure:"},{"type":"text","text":" Outer function takes arguments, returns decorator."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common Built-in Decorators"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Decorator"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Purpose"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"@staticmethod"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Static method in class"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"@classmethod"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Class method in class"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"@property"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Create getter for attribute"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"@lru_cache"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Memoization/caching"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"When to Use Decorators"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Case"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Example"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Logging"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Track function calls"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Timing"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Measure execution time"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Caching"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Memoize results ("},{"type":"text","marks":[{"type":"code"}],"text":"@lru_cache"},{"type":"text","text":")"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Authentication"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"@login_required"},{"type":"text","text":" in web apps"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Validation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Check input parameters"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rate limiting"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Prevent too many calls"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Decorators are essential for "},{"type":"text","marks":[{"type":"bold"}],"text":"Python Syntax & Idioms"},{"type":"text","text":" in Generative AI development, enabling clean, reusable patterns for logging, caching, and authentication."}]}]}}
