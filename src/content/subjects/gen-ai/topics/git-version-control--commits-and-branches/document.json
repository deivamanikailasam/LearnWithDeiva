{"format":"tiptap/v1","updatedAt":"2026-06-21T15:15:13.277Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"You’re asking about the core Git workflow that modern software engineering teams use: "},{"type":"text","marks":[{"type":"bold"}],"text":"commits & branches"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"bold"}],"text":"branching strategies"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"bold"}],"text":"pull requests (PRs)"},{"type":"text","text":", and "},{"type":"text","marks":[{"type":"bold"}],"text":"code review"},{"type":"text","text":". Below is a practical, engineer-focused overview."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"1. What It Is"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Commit"},{"type":"text","text":": A snapshot of your code with a message, author, timestamp, and parent commit hash."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Branch"},{"type":"text","text":": An independent line of development (e.g., "},{"type":"text","marks":[{"type":"code"}],"text":"main"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"feature/login"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"bugfix/timeouts"},{"type":"text","text":")."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pull Request (PR)"},{"type":"text","text":": A proposal to merge one branch into another, with discussion and review before merging."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Code Review"},{"type":"text","text":": The human process of examining changes (via PR) for correctness, design, tests, and style before integration."}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"2. Why It Matters"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Isolation"},{"type":"text","text":": Branches let you work on features/bugs without breaking "},{"type":"text","marks":[{"type":"code"}],"text":"main"},{"type":"text","text":"."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Collaboration"},{"type":"text","text":": PRs create a shared, auditable thread for discussion and iteration."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Quality"},{"type":"text","text":": Code review catches bugs, design issues, and test gaps early."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"History & Traceability"},{"type":"text","text":": Commits + PRs give a clear, reversible record of who changed what and why."}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"3. Benefits"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Benefit"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Branching"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Safe parallel development; no lock-step coordination needed"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Pull Requests"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Structured review, automated checks, and discussion before merge"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Code Review"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Better code quality, knowledge sharing, and team alignment"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Commits"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Fine-grained history; easy debugging, rollbacks, and blame tracking"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"4. Trade-offs"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Overhead"},{"type":"text","text":": PRs and reviews add time compared to direct merges."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Merge Conflicts"},{"type":"text","text":": More branches can increase conflict frequency."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Complexity"},{"type":"text","text":": Teams need clear conventions (branch names, PR size, review etiquette)."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PR Hoarding"},{"type":"text","text":": Too many open PRs can slow throughput and dilute review quality."}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"5. How It Works (Workflow)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Basic Git Flow (Feature Branch + PR)"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Start from "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"main"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"``"},{"type":"text","marks":[{"type":"code"}],"text":"bash git switch main git pull origin main "},{"type":"text","text":"``"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Create a feature branch"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"``"},{"type":"text","marks":[{"type":"code"}],"text":"bash git switch -c feature/login-auth "},{"type":"text","text":"``"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Make changes and commit"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"``"},{"type":"text","marks":[{"type":"code"}],"text":"bash git add. git commit -m \"Add login auth with JWT tokens\" "},{"type":"text","text":"`` - Write small, focused commits (one logical change per commit). - Use clear commit messages: “what” + “why”."}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":