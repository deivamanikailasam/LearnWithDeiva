n":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Yes"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Careful review worth the overhead"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Quick prototype (iter0)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ No"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Speed over review; merge directly if team agrees"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Bug fix in production-critical code"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Yes"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Always review critical changes"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Small refactor / docs tweak"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚖️ Optional"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Team policy; often still PR for visibility"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"You generally "},{"type":"text","marks":[{"type":"bold"}],"text":"do not"},{"type":"text","text":" commit directly to "},{"type":"text","marks":[{"type":"code"}],"text":"main"},{"type":"text","text":" in professional teams; everything goes through a branch + PR."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"7. How to Implement (Practical Rules)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Commits"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"One logical change per commit"},{"type":"text","text":"."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Avoid “WIP” commits on shared branches; clean up with "},{"type":"text","marks":[{"type":"code"}],"text":"git commit --amend"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"code"}],"text":"git rebase -i"},{"type":"text","text":" before PR."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Message pattern:"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- Short: "},{"type":"text","marks":[{"type":"code"}],"text":"Add JWT login endpoint"},{"type":"text","text":" - Body: explain why, trade-offs, test strategy."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Branching"}]},{"type":"paragraph","content":[{"type":"text","text":"Common patterns:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"GitHub Flow"},{"type":"text","text":" (simple, modern):"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- Long-lived "},{"type":"text","marks":[{"type":"code"}],"text":"main"},{"type":"text","text":" (always deployable). - Short-lived feature branches per task/PR.\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"GitFlow"},{"type":"text","text":" (more structured): - "},{"type":"text","marks":[{"type":"code"}],"text":"main"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"develop"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"feature/*"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"release/*"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"hotfix/*"},{"type":"text","text":".\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Trunk-Based Development"},{"type":"text","text":": - Very short-lived branches; frequent small merges to trunk ("},{"type":"text","marks":[{"type":"code"}],"text":"main"},{"type":"text","text":"). - Emphasizes CI and small PRs."}]},{"type":"paragraph","content":[{"type":"text","text":"Branch naming examples:\n- "},{"type":"text","marks":[{"type":"code"}],"text":"feature/payments-refactor"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"code"}],"text":"bugfix/timeout-on-retry"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"code"}],"text":"hotfix/login-503-jun22"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Pull Requests"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Keep PRs "},{"type":"text","marks":[{"type":"bold"}],"text":"small and focused"},{"type":"text","text":" (ideally < 200–400 lines)."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Title: clear and specific."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Description:"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- What changed? - Why? - How to test? - Related issues.\n- Use "},{"type":"text","marks":[{"type":"bold"}],"text":"draft PRs"},{"type":"text","text":" for work-in-progress; mark ready when you want reviews."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Code Review Etiquette"}]},{"type":"paragraph","content":[{"type":"text","text":"For reviewers:\n- Respond promptly.\n- Be specific: “This loop is O(n²); consider a map” vs “bad”.\n- Suggest edits when helpful.\n- Don’t nitpick style in first pass; focus on correctness and design."}]},{"type":"paragraph","content":[{"type":"text","text":"For authors:\n- Don’t argue; ask clarifying questions.\n- Address feedback with new commits, not by rewriting history on shared branches.\n- If a reviewer suggests small fixes, sometimes "},{"type":"text","marks":[{"type":"bold"}],"text":"apply them directly"},{"type":"text","text":" to save back-and-forth."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"8. Examples"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Minimal Local-to-PR Workflow"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# 1. Start from main\ngit switch main\ngit pull origin main\n\n# 2. Create branch\ngit switch -c feature/user-profile\n\n# 3. Work + commit\ngit add .\ngit commit -m \"Add user profile page with avatar\"\n\n# 4. Push\ngit push -u origin feature/user-profile\n\n# 5. Create PR in GitHub UI\n# 6. Review → add more commits → push\ngit add .\ngit commit -m \"Fix avatar sizing on mobile\"\ngit push\n\n# 7. Merge and delete branch in GitHub\n# 8. Update local main\ngit switch main\ngit pull origin main"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"9. Real-World Example (Production Team)"}]},{"type":"paragraph","content":[{"type":"text","text":"A distributed systems team at a cloud provider:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Trunk-based + short branches"},{"type":"text","text":":"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- "},{"type":"text","marks":[{"type":"code"}],"text":"main"},{"type":"text","text":" is always deployable. - Branches live 1–2 days max.\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"PR policy"},{"type":"text","text":": - All changes to "},{"type":"text","marks":[{"type":"code"}],"text":"main"},{"type":"text","text":" require: - 1–2 approvals. - Passing CI (tests, benchmarks, security scans).\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Code review focus"},{"type":"text","text":": - Correctness under concurrency. - Performance (latency, CPU, memory). - Failure handling and retries. - Test coverage (unit + integration).\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Tooling"},{"type":"text","text":": - GitHub for PRs + reviews. - CI on push to branches. - Automated merge only when all checks pass. - Occasional squash merges for tiny cleanup PRs."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"10. Common Mistakes"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Committing directly to "},{"type":"text","marks":[{"type":"code"}],"text":"main"},{"type":"text","text":"."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Huge PRs with multiple unrelated features."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Poor commit messages (“fix”, “wip”)."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Rewriting history on shared branches ("},{"type":"text","marks":[{"type":"code"}],"text":"git push --force"},{"type":"text","text":" with rebased branches)."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Ignoring CI failures before review."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Reviewing only code, not tests or design."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Leaving PRs open for weeks without follow-up."}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"11. Best Practices"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Small, frequent PRs"},{"type":"text","text":" → faster reviews, less risk."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Write tests first"},{"type":"text","text":" or at least alongside code."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use draft PRs"},{"type":"text","text":" for early feedback."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Review quickly"},{"type":"text","text":"; treat PR latency as a team metric."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Clean commit history"},{"type":"text","text":" before PR (rebase, squash, amend)."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Automate"},{"type":"text","text":": lint, tests, type checks, security scans in CI."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Document conventions"},{"type":"text","text":" in a "},{"type":"text","marks":[{"type":"code"}],"text":"CONTRIBUTING.md"},{"type":"text","text":"."}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"12. Performance & Scalability"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Small PRs scale better: more parallel reviews, fewer conflicts."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Large monolithic PRs become bottlenecks and are hard to review."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"For large teams:"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- Use code owners ("},{"type":"text","marks":[{"type":"code"}],"text":"CODEOWNERS"},{"type":"text","text":") to auto-assign reviewers. - Enforce PR size limits via policy or tooling. - Limit open PRs per person to avoid review hoarding."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"13. Tooling & Ecosystem"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Git"},{"type":"text","text":": base tool."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Platforms"},{"type":"text","text":": GitHub, GitLab, Bitbucket."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"CLI helpers"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"gh"},{"type":"text","text":" (GitHub CLI), "},{"type":"text","marks":[{"type":"code"}],"text":"hub"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"gitsh"},{"type":"text","text":"."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Editors"},{"type":"text","text":": VS Code Git integration, Vim Fugitive."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"CI"},{"type":"text","text":": GitHub Actions, GitLab CI, Jenkins, CircleCI."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Review tools"},{"type":"text","text":": GitHub PR reviews, line comments, suggested changes."}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"14. Comparison with Alternatives"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Approach"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Pros"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Cons"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Direct "},{"type":"text","marks":[{"type":"code"}],"text":"main"},{"type":"text","text":" commits"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Fast, simple"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No review, high risk, noisy history"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Feature branches + PR"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Safe, reviewable, traceable"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Slightly slower, needs discipline"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Centralized workflow"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Simple for small teams"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Harder to isolate work, more conflicts"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"For full-stack, cloud-native, distributed systems work, "},{"type":"text","marks":[{"type":"bold"}],"text":"feature branches + PRs + code review"},{"type":"text","text":" is the standard."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"15. Security & Reliability"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"PRs prevent unreviewed changes to "},{"type":"text","marks":[{"type":"code"}],"text":"main"},{"type":"text","text":"."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Require:"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- At least one approval. - Passing CI. - Protected "},{"type":"text","marks":[{"type":"code"}],"text":"main"},{"type":"text","text":" branch (no direct writes).\n- Use code owners for sensitive paths.\n- Review for: - Auth / authz bugs. - Secret handling. - Input validation. - Resource leaks and concurrency issues."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Models"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Branch = “safe sandbox”"},{"type":"text","text":" for a change."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PR = “proposal + discussion thread”"},{"type":"text","text":" for that sandbox."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Commit = “step in the story”"},{"type":"text","text":" of how you got there."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Code review = “quality gate before production”"},{"type":"text","text":"."}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Never commit directly to "},{"type":"text","marks":[{"type":"code"}],"text":"main"},{"type":"text","text":" in a professional team; use branches + PRs."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Keep commits small and focused; keep PRs small and reviewable."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Code review is a human quality gate, separate from CI but usually required before merging."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"PRs create an auditable, collaborative history of changes."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Clear conventions (branch names, PR size, review etiquette) are essential for team efficiency."}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"If you want, I can show a concrete end-to-end example tailored to your stack (e.g., cloud-native Go/Python + TypeScript frontend) with exact commands and PR template structure."}]}]}}
