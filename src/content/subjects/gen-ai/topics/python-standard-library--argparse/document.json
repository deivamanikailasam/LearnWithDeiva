th various options',\n    epilog='For more information, visit docs.example.com'\n)\nparser.add_argument('filename', help='Input file to process')\nparser.add_argument('--output', help='Output file (optional)')\nparser.add_argument('--verbose', '-v', action='store_true', help='Enable verbose mode')\n\nargs = parser.parse_args()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Running with "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"-h"},{"type":"text","marks":[{"type":"bold"}],"text":":"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"$ python script.py -h\nUsage: script.py [-h] [--output OUTPUT] [--verbose] filename\n\nProcess files with various options\n\nPositional Arguments:\n  filename              Input file to process\n\nOptional Arguments:\n  -h, --help            show this help message and exit\n  --output OUTPUT       Output file (optional)\n  --verbose, -v         Enable verbose mode\n\nFor more information, visit docs.example.com"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Special Actions"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Boolean Flag ("},{"type":"text","marks":[{"type":"code"}],"text":"store_true"},{"type":"text","text":" / "},{"type":"text","marks":[{"type":"code"}],"text":"store_false"},{"type":"text","text":")"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import argparse\n\nparser = argparse.ArgumentParser()\nparser.add_argument('--verbose', '-v', action='store_true', help='Enable verbose mode')\nparser.add_argument('--quiet', '-q', action='store_false', help='Disable output')\n\nargs = parser.parse_args()\n\nif args.verbose:\n    print(\"Verbose mode enabled\")"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Usage:"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{