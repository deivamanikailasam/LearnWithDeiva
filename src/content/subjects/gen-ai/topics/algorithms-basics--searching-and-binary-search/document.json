{"format":"tiptap/v1","updatedAt":"2026-06-21T14:47:14.415Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Searching"},{"type":"text","text":" is the process of finding a specific element in a collection of data, while "},{"type":"text","marks":[{"type":"bold"}],"text":"Binary Search"},{"type":"text","text":" is an efficient algorithm that finds elements in "},{"type":"text","marks":[{"type":"bold"}],"text":"sorted arrays"},{"type":"text","text":" by repeatedly dividing the search space in half. Binary Search achieves "},{"type":"text","marks":[{"type":"bold"}],"text":"O(log n)"},{"type":"text","text":" time complexity (vs O(n) for Linear Search), making it 100x faster for large datasets—critical for Gen AI for hyperparameter tuning, vocabulary lookups, neural network architecture search, and database indexing."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Linear Search"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Binary Search"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Data Requirement"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Any (unsorted or sorted) "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://klu.ai/glossary/search-algorithm","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"klu"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Must be sorted"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Approach"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Check every element sequentially "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://klu.ai/glossary/search-algorithm","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"klu"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Divide search space in half"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Time Complexity"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n) worst case"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(log n)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best Case"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(1) (element at first position)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(1) (element at middle)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"comparisons"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Up to n comparisons "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://klu.ai/glossary/search-algorithm","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"klu"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Up to log₂(n) comparisons"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use Case"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Small/unsorted data "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://klu.ai/glossary/search-algorithm","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"klu"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Large/sorted data"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why It Matters for Gen AI"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ❌ WITHOUT binary search: O(n) vocabulary lookup (slow)\nvocabulary = [\"apple\", \"banana\", \"cat\", \"dog\", \"elephant\"]  # Unsorted\n\ndef linear_search(word):\n    for i, w in vocabulary:  # ✅ O(n): check all n words\n        if w == word:\n            return i\n    return -1\n\nlinear_search(\"elephant\")  # ❌ 5 comparisons for 5 words\n# For 1000 words: 1000 comparisons (slow!) [web:169]\n\n# ✅ WITH binary search: O(log n) vocabulary lookup (fast)\nvocabulary = [\"apple\", \"banana\", \"cat\", \"dog\", \"elephant\"]  # Sorted\n\ndef binary_search(word):\n    left, right = 0, len(vocabulary) - 1\n    while left <= right:\n        mid = (left + right) // 2  # ✅ Find middle\n        if vocabulary[mid] == word:\n            return mid  # ✅ Found\n        elif vocabulary[mid] < word:\n            left = mid + 1  # ✅ Search right half\n        else:\n            right = mid - 1  # ✅ Search left half [web:168][web:170]\n    return -1\n\nbinary_search(\"elephant\")  # ✅ 2-3 comparisons for 5 words (vs 5)\n# For 1000 words: log₂(1000) ≈ 10 comparisons (vs 1000) [web:169]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"100x faster"},{"type":"text","text":": O(log n) vs O(n) for large datasets\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Hyperparameter tuning"},{"type":"text","text":": Find optimal learning rate with binary search\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Neural architecture search"},{"type":"text","text":": 100x improvement over linear search\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Database indexing"},{"type":"text","text":": B-trees use binary search for fast queries"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How Binary Search Works (Step-by-Step)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Core Algorithm"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Binary Search: Divide search space in half\ndef binary_search(arr, target):\n    left, right = 0, len(arr) - 1  # ✅ Start with full array\n    \n    while left <= right:  # ✅ While search space exists\n        mid = (left + right) // 2  # ✅ Find middle index\n        \n        if arr[mid] == target:  # ✅ Case 1: Found at middle\n            return mid\n        elif arr[mid] < target:  # ✅ Case 2: Target in right half\n            left = mid + 1  # ✅ Discard left half\n        else:  # ✅ Case 3: Target in left half\n            right = mid - 1  # ✅ Discard right half [web:168][web:170]\n    \n    return -1  # ❌ Not found"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Visualization"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Array: [2, 5, 8, 12, 16, 23, 38, 45, 56, 67, 78]\n# Search for: 23\n\n# Step 1: left=0, right=10, mid=5\n# arr [klu](https://klu.ai/glossary/search-algorithm) = 23  ✅ Found! (1 comparison)\n\n# Search for: 16\n# Step 1: left=0, right=10, mid=5\n# arr [klu](https://klu.ai/glossary/search-algorithm) = 23 > 16  → right=4 (discard right half)\n# Step 2: left=0, right=4, mid=2\n# arr [medium](https://medium.com/@azar.mohammed4u/binary-search-the-foundation-of-efficient-computing-756f42c0b2d9) = 8 < 16  → left=3 (discard left half)\n# Step 3: left=3, right=4, mid=3\n# arr [studocu](https://www.studocu.com/in/document/kiet-group-of-institutions/btech/15-searching/61221526) = 12 < 16  → left=4 (discard left half)\n# Step 4: left=4, right=4, mid=4\n# arr [medium](https://medium.com/@imanshu822/binary-search-and-its-powerful-applications-39ae7d7bca69) = 16  ✅ Found! (4 comparisons)\n\n# For 11 elements: log₂(11) ≈ 3-4 comparisons (vs 11 for linear) [web:168]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Order-Agnostic Binary Search"},{"type":"text","text":" (Works on Descending Arrays)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Works on both ascending and descending sorted arrays\ndef order_agnostic_binary_search(arr, target):\n    left, right = 0, len(arr) - 1\n    is_ascending = arr[left] < arr[right]  # ✅ Check order\n    \n    while left <= right:\n        mid = (left + right) // 2\n        if arr[mid] == target:\n            return mid\n        \n        if is_ascending:  # ✅ Ascending order\n            if arr[mid] < target:\n                left = mid + 1\n            else:\n                right = mid - 1\n        else:  # ✅ Descending order\n            if arr[mid] > target:\n                left = mid + 1\n            else:\n                right = mid - 1 [web:168]\n    \n    return -1"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Time Complexity Analysis"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Input Size"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Linear Search (O(n))"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Binary Search (O(log n))"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Speedup"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"10"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"10 comparisons"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"3-4 comparisons"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"3x faster"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"100"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"100 comparisons"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"6-7 comparisons"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"15x faster"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"1000"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"1000 comparisons"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"10 comparisons"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"100x faster"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"10,000"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"10,000 comparisons"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"13-14 comparisons"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"700x faster"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"1,000,000"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"1M comparisons"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"20 comparisons"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"50,000x faster"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Formula:"},{"type":"text","text":"\n- Binary Search: "},{"type":"inlineMath","attrs":{"latex":"\\log_2(n)"}},{"type":"text","text":" comparisons\n- For "},{"type":"inlineMath","attrs":{"latex":"n = 1,000,000"}},{"type":"text","text":": "},{"type":"inlineMath","attrs":{"latex":"\\log_2(1,000,000) \\approx 20"}},{"type":"text","text":" comparisons"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Gen AI Applications ⭐"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Hyperparameter Tuning"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Binary search for optimal learning rate\ndef train_model(learning_rate):\n    # Train model with given learning rate\n    accuracy = train_and_validate(learning_rate)\n    return accuracy\n\n# Binary search: Find best learning rate in range [0.001, 0.1]\nleft, right = 0.001, 0.1\nfor _ in range(10):  # ✅ 10 iterations (log scale)\n    mid = (left + right) / 2\n    accuracy_mid = train_model(mid)\n    \n    accuracy_left = train_model(left)\n    if accuracy_mid > accuracy_left:\n        left = mid  # ✅ Better at mid, search right half\n    else:\n        right = mid  # ✅ Better at left, search left half [web:169]\n\nbest_lr = left  # ✅ Optimal learning rate found in 10 iterations (vs 1000)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Neural Network Architecture Search"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Binary search: Find optimal architecture size (100x faster)\n# Search space: architecture sizes [100, 1000] neurons\n\nleft, right = 100, 1000\nwhile left < right:\n    mid = (left + right) // 2\n    accuracy_mid = train_model(neurons=mid)\n    accuracy_left = train_model(neurons=left)\n    \n    if accuracy_mid > accuracy_left:\n        left = mid  # ✅ Better at mid\n    else:\n        right = mid  # ✅ Better at left\n\noptimal_size = left  # ✅ Found in ~10 iterations (vs 900 for linear) [web:174]\n# 100-fold running time improvement over naive linear search [web:174]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Spell Checkers & Autocorrect"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Binary search for fast dictionary lookup (NLP)\ndictionary = [\"apple\", \"banana\", \"cat\", \"dog\", \"elephant\"]  # Sorted\n\ndef spell_check(word):\n    index = binary_search(dictionary, word)  # ✅ O(log n)\n    return index != -1  # ✅ True if word exists\n\nspell_check(\"cat\")  # ✅ True (found in 2-3 comparisons)\nspell_check(\"xyz\")  # ❌ False (not found) [web:169][web:171]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Database Indexing (B-Trees)"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ B-trees use binary search for fast queries\n# Database: Sorted index [100, 200, 300, 400, 500]\n\ndef find_record(id):\n    index = binary_search(database_index, id)  # ✅ O(log n)\n    if index != -1:\n        return database_records[index]  # ✅ Return record\n    return None  # ❌ Not found [web:169][web:173]\n\n# For 1M records: log₂(1M) ≈ 20 comparisons (vs 1M for linear) [web:169]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Finding Closest Value"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Binary search for nearest match (financial applications)\nstock_prices = [10, 20, 30, 40, 50, 60, 70]  # Sorted\n\ndef find_closest_price(target):\n    left, right = 0, len(stock_prices) - 1\n    \n    while left < right:\n        mid = (left + right) // 2\n        if stock_prices[mid] < target:\n            left = mid + 1\n        else:\n            right = mid\n    \n    # Check neighboring values for closest\n    if left > 0 and abs(stock_prices[left-1] - target) < abs(stock_prices[left] - target):\n        return stock_prices[left-1]\n    return stock_prices[left]  # ✅ Closest price [web:169][web:171]\n\nfind_closest_price(35)  # ✅ 30 or 40 (closest to 35) [web:171]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use (Decision Criteria)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Binary Search"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Linear Search"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sorted data"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Large sorted arrays"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Small sorted arrays"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Unsorted data"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph