: "Pull Request"}, {"type": "text", "text": " is a request to merge code from one branch into another (usually "}, {"type": "text", "marks": [{"type": "code"}], "text": "main"}, {"type": "text", "text": "):\n- Says: \"Hey team, I've finished work. Can you review and approve before adding to main?\"\n- Managed on platforms: GitHub, GitLab, Bitbucket"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "3. Code Review Process"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Reviewers examine:\n- Code correctness and logic\n- Test coverage\n- Style consistency\n- Potential conflicts with existing code"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "4. Conflict Resolution Steps"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "When Git flags a conflict, you see markers in the file:"}]}, {"type": "codeBlock", "attrs": {"language": "text"}, "content": [{"type": "text", "text": "<<<<<<< HEAD\n// Your branch's changes\n=======\n// main branch's changes\n>>>>>>> branch-name"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Resolution process"}, {"type": "text", "text": ":"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Open the conflicted file"}, {"type": "text", "text": " in your editor (VS Code, IntelliJ, etc.)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": " Decide"}, {"type": "text", "text": " which changes to keep:"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "- Keep only your branch's changes - Keep only "}, {"type": "text", "marks": [{"type": "code"}], "text": "main"}, {"type": "text", "text": "'s changes - Combine both into a new change\n3. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Delete conflict markers"}, {"type": "text", "text": " ("}, {"type": "text", "marks": [{"type": "code"}], "text": "<<<<<<<"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "code"}], "text": "======="}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "code"}], "text": ">>>>>>>"}, {"type": "text", "text": ")\n4. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Mark as resolved"}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "code"}], "text": "git add <file>"}, {"type": "text", "text": "\n5. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Commit"}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "code"}], "text": "git commit -m \"Resolve merge conflict\""}, {"type": "text", "text": "\n6. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Push"}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "code"}], "text": "git push"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "When Conflicts Happen After PR Creation"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "If your PR shows conflicts with "}, {"type": "text", "marks": [{"type": "code"}], "text": "main"}, {"type": "text", "text": " "}, {"type": "text", "marks": [{"type": "bold"}], "text": "after creation"}, {"type": "text", "text": ", use this strategy:"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Option A: Fix Inside Your PR Branch"}]}, {"type": "codeBlock", "attrs": {"language": "bash"}, "content": [{"type": "text", "text": "git checkout feat/user-auth\ngit pull origin main\n# Resolve conflicts in editor\ngit add .\ngit commit -m \"Resolve conflicts with main\"\ngit push"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Option B: Temporary Helper Branch"}, {"type": "text", "text": " (cleaner, more review-friendly)"}]}, {"type": "codeBlock", "attrs": {"language": "bash"}, "content": [{"type": "text", "text": "git checkout feat/user-auth\ngit checkout -b feat/user-auth-merge-fix\ngit merge main\n# Resolve conflicts\ngit add .\ngit commit -m \"Resolved conflicts with main\"\ngit push origin feat/user-auth-merge-fix"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Then create a new PR from the helper branch."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "When to Use It"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Scenario"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use This Approach"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Small PRs"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Fix conflicts directly in your branch"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Complex conflicts"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use helper branch for reviewability"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Multiple reviewers"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Resolve, then request re-review"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Adjacent line conflicts"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AI tools can help detect if truly critical"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "When NOT to use"}, {"type": "text", "text": ": Don't merge without review—even AI-assisted resolution needs human code review."}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "How to Implement: Best Practices"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Pull often"}, {"type": "text", "text": " from "}, {"type": "text", "marks": [{"type": "code"}], "text": "main"}, {"type": "text", "text": " to stay up-to-date:"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "``"}, {"type": "text", "marks": [{"type": "code"}], "text": "bash git pull origin main --rebase "}, {"type": "text", "text": "``"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Keep PRs small and focused"}, {"type": "text", "text": " – reduces conflict probability"}