{"format":"tiptap/v1","updatedAt":"2026-06-21T13:56:25.434Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"A "},{"type":"text","marks":[{"type":"bold"}],"text":"linked list"},{"type":"text","text":" is a linear data structure where elements are stored in "},{"type":"text","marks":[{"type":"bold"}],"text":"nodes"},{"type":"text","text":" that are connected via "},{"type":"text","marks":[{"type":"bold"}],"text":"pointers"},{"type":"text","text":" (references), rather than being stored in contiguous memory like arrays. Each node contains "},{"type":"text","marks":[{"type":"bold"}],"text":"data"},{"type":"text","text":" and a "},{"type":"text","marks":[{"type":"bold"}],"text":"pointer to the next node"},{"type":"text","text":", allowing dynamic size, efficient insertion/deletion without shifting, and non-contiguous memory allocation—overcoming arrays' fixed-size limitations."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Linked List"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Array"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Memory"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Non-contiguous (nodes scattered)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Contiguous (sequential)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Size"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Dynamic (can grow/shrink)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Fixed (must declare upfront)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Insertion/Deletion"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(1) at known position (no shifting)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n) (shift elements)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Access"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n) (must traverse) "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://www.uvm.edu/~cbcafier/cs2240/content/02_c++_essentials/09_linked_lists.html","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"uvm"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(1) (direct index) "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://www.uvm.edu/~cbcafier/cs2240/content/02_c++_essentials/09_linked_lists.html","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"uvm"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pointers"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Required (next/prev references)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"None (index-based) "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://www.uvm.edu/~cbcafier/cs2240/content/02_c++_essentials/09_linked_lists.html","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"uvm"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Memory overhead"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Higher (pointer per node)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Lower (data only)"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why It Matters for Gen AI"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ❌ WITHOUT linked list: Array limitations for dynamic AI data\n# Fixed-size array: Can't add more tokens after max limit\ntokens = [\"Hello\", \"World\"]  # ✅ Array\n# tokens.append(\"AI\")  # ❌ Error if array is full (fixed size)\n\n# ✅ WITH linked list: Dynamic size for AI token streams\n# Node structure: data + pointer to next\nclass Node:\n    def __init__(self, data):\n        self.data = data  # Token text\n        self.next = None  # Pointer to next token\n\n# Create linked list for AI tokens\ntoken1 = Node(\"Hello\")\ntoken2 = Node(\"World\")\ntoken3 = Node(\"AI\")\n\ntoken1.next = token2  # ✅ Link: Hello → World\ntoken2.next = token3  # ✅ Link: World → AI\n# ✅ Dynamic: Can add infinite tokens without size limit [web:110][web:114]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Dynamic size"},{"type":"text","text":": No pre-declaration needed; grows as AI generates tokens\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Efficient insert/delete"},{"type":"text","text":": O(1) insertion at any point (no shifting)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Non-contiguous memory"},{"type":"text","text":": Nodes allocated anywhere; no memory fragmentation "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://www.uvm.edu/~cbcafier/cs2240/content/02_c++_essentials/09_linked_lists.html","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"uvm"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Implementation foundation"},{"type":"text","text":": Used for stacks, queues, hash tables, graphs"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How It Works (Core Types)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Singly Linked List"},{"type":"text","text":" (Most Common)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Each node: data + pointer to next node only\nclass Node:\n    def __init__(self, data):\n        self.data = data  # Data (e.g., AI token)\n        self.next = None  # Pointer to next node [web:110][web:114]\n\nclass SinglyLinkedList:\n    def __init__(self):\n        self.head = None  # First node (None if empty) [web:110]\n    \n    # ✅ Insert at beginning: O(1)\n    def insert_beginning(self, data):\n        new_node = Node(data)\n        new_node.next = self.head  # ✅ Point to old head\n        self.head = new_node  # ✅ New node is head [web:110][web:114]\n    \n    # ✅ Insert at end: O(n) (must traverse)\n    def insert_end(self, data):\n        new_node = Node(data)\n        if self.head is None:\n            self.head = new_node\n            return\n        last = self.head\n        while last.next:  # ✅ Traverse to end\n            last = last.next\n        last.next = new_node  # ✅ Link new node [web:110][web:114]\n    \n    # ✅ Delete node: O(n) (must find node)\n    def delete(self, data):\n        if self.head is None:\n            return\n        if self.head.data == data:\n            self.head = self.head.next  # ✅ Remove head\n            return\n        current = self.head\n        while current.next:  # ✅ Traverse to find node\n            if current.next.data == data:\n                current.next = current.next.next  # ✅ Skip node\n                return\n            current = current.next\n    \n    # ✅ Traverse: O(n)\n    def traverse(self):\n        current = self.head\n        while current:  # ✅ Visit each node\n            print(current.data)\n            current = current.next\n\n# Usage\nll = SinglyLinkedList()\nll.insert_end(\"Hello\")\nll.insert_end(\"World\")\nll.insert_end(\"AI\")\nll.traverse()  # ✅ Hello → World → AI [web:110][web:114]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Doubly Linked List"},{"type":"text","text":" (Forward + Backward) ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Each node: data + pointer to next + pointer to prev\nclass Node:\n    def __init__(self, data):\n        self.data = data  # Data\n        self.next = None  # Pointer to next [web:109][web:112]\n        self.prev = None  # Pointer to prev [web:109][web:112]\n\nclass DoublyLinkedList:\n    def __init__(self):\n        self.head = None\n        self.tail = None  # Last node (for O(1) end insertion) [web:109]\n    \n    # ✅ Insert at beginning: O(1)\n    def insert_beginning(self, data):\n        new_node = Node(data)\n        if self.head is None:\n            self.head = new_node\n            self.tail = new_node\n        else:\n            new_node.next = self.head\n            self.head.prev = new_node\n            self.head = new_node\n    \n    # ✅ Insert at end: O(1) (using tail)\n    def insert_end(self, data):\n        new_node = Node(data)\n        if self.tail is None:\n            self.head = new_node\n            self.tail = new_node\n        else:\n            new_node.prev = self.tail\n            self.tail.next = new_node\n            self.tail = new_node  # ✅ Update tail [web:109]\n    \n    # ✅ Traverse forward: O(n)\n    def traverse_forward(self):\n        current = self.head\n        while current:\n            print(current.data)\n            current = current.next\n    \n    # ✅ Traverse backward: O(n) (from tail)\n    def traverse_backward(self):\n        current = self.tail\n        while current:\n            print(current.data)\n            current = current.prev\n\n# Usage: Undo/Redo for AI prompts (doubly linked list)\nll = DoublyLinkedList()\nll.insert_end(\"Prompt 1: Explain quantum\")\nll.insert_end(\"Prompt 2: Explain quantum in simple terms\")\nll.insert_end(\"Prompt 3: Explain quantum with examples\")\n\nll.traverse_forward()  # ✅ Prompt 1 → Prompt 2 → Prompt 3\nll.traverse_backward()  # ✅ Prompt 3 → Prompt 2 → Prompt 1 [web:109]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Circular Linked List"},{"type":"text","text":" (Loop)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Last node points back to first (circular)\nclass Node:\n    def __init__(self, data):\n        self.data = data\n        self.next = None\n\nclass CircularLinkedList:\n    def __init__(self):\n        self.head = None\n    \n    def insert_end(self, data):\n        new_node = Node(data)\n        if self.head is None:\n            self.head = new_node\n            new_node.next = self.head  # ✅ Circular: points to head\n            return\n        last = self.head\n        while last.next != self.head:  # ✅ Find last (not head)\n            last = last.next\n        last.next = new_node\n        new_node.next = self.head  # ✅ Circular: points to head\n\n# Usage: Round-robin scheduling for AI tasks\nll = CircularLinkedList()\nll.insert_end(\"Task 1: User A\")\nll.insert_end(\"Task 2: User B\")\nll.insert_end(\"Task 3: User C\")\n\n# ✅ Cycle infinitely through tasks\ncurrent = ll.head\nfor _ in range(6):  # 6 iterations\n    print(current.data)\n    current = current.next  # ✅ Loops back to head [web:109][web:112]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use (Decision Criteria)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Linked List"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Array"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Dynamic size"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ AI token streams, chat history"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Fixed size"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Frequent insert/delete"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ O(1) at known position"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ O(n) shifting"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Random access needed"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ O(n) traversal"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ O(1) index"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Memory efficiency"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Pointer overhead"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Compact storage"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Stack/Queue impl"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Natural implementation"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Requires shifting"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hash table chaining"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Collision resolution"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Fixed buckets"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Graph adjacency"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Store neighbors"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ Fixed size"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Undo/Redo"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Doubly linked list"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ O(n) shifts"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rule of thumb:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Linked List"},{"type":"text","text":": Dynamic size + frequent insert/delete (AI tokens, chat history, undo/redo)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Array"},{"type":"text","text":": Random access + memory efficiency (token arrays, fixed-size buffers)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How to Implement (Step-by-Step)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 1: Create Node Class"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"class Node:\n    def __init__(self, data):\n        self.data = data\n        self.next = None  # Pointer to next [web:110][web:114]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 2: Create Linked List Class"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"class LinkedList:\n    def __init__(self):\n        self.head = None  # Start with empty list [web:110]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 3: Implement Core Operations"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"def insert_end(self, data):\n    new_node = Node(data)\n    if self.head is None:\n        self.head = new_node\n        return\n    last = self.head\n    while last.next:  # ✅ Traverse to end\n        last = last.next\n    last.next = new_node  # ✅ Link [web:110][web:114]\n\ndef traverse(self):\n    current = self.head\n    while current:  # ✅ Visit all nodes\n        print(current.data)\n        current = current.next"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 4: Use in Gen AI (Token Stream)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"class TokenStream:\n    def __init__(self):\n        self.ll = LinkedList()  # ✅ Linked list for tokens\n    \n    def add_token(self, token: str):\n        self.ll.insert_end(token)  # ✅ Dynamic growth [web:110]\n    \n    def get_all_tokens(self):\n        tokens = []\n        current = self.ll.head\n        while current:\n            tokens.append(current.data)\n            current = current.next\n        return \"\".join(tokens)  # ✅ Reconstruct text\n\n# Usage: AI generates tokens one-by-one\nstream = TokenStream()\nstream.add_token(\"Quantum\")\nstream.add_token(\" computing\")\nstream.add_token(\" uses\")\nstream.add_token(\" superposition\")\nprint(stream.get_all_tokens())  # ✅ \"Quantum computing uses superposition\" [web:110]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Time Complexity"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Operation"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Linked List"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Array"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Insert at beginning"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(1)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n) (shift)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Insert at end"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n) (traverse)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(1) (if space)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Delete node"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n) (find)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan