ss in chunks"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Real-World Example: Production Gen AI Workflow"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Scale"},{"type":"text","text":": Training 7B-parameter LLM on free Colab\n"},{"type":"text","marks":[{"type":"bold"}],"text":"Constraints"},{"type":"text","text":": 12GB RAM, limited GPU quota\n"},{"type":"text","marks":[{"type":"bold"}],"text":"Architecture"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"Notebook Structure:\n├── Section 0: Setup (imports, pip installs)\n├── Section 1: Data prep (CPU, chunked loading)\n├── Section 2: Model (GPU, mixed precision)\n├── Section 3: Training (gradient checkpointing, checkpoints to Drive)\n├── Section 4: Evaluation (CPU)\n└── Section 5: Results (markdown + plots)\n\nResilience:\n- try/except around training loop\n- Checkpoint every epoch → Google Drive\n- Pin revision before major changes"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Outcome"},{"type":"text","text":": Model trained despite 90-min idle timeout by resuming from checkpoints."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Common Mistakes to Avoid"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Mistake"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Consequence"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Fix"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"r