                  {
                    "type": "text",
                    "text": "Selecting a larger-context model without benchmarking recall quality.",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " Longer context ≠ better recall across the full window. Run a needle-in-a-haystack test (insert a specific fact at varying positions, ask the model to find it) to measure actual recall quality at the context depth your application requires."
                  }
                ]
              }
            ]
