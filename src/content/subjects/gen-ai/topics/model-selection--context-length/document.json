                    "type": "text",
                    "text": "Burying the question in the middle of a long context.",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " Placing the user's question between large blocks of retrieved text means it may be ignored. Put the question at the end (after the context), or repeat it at both the beginning and end of the context."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
