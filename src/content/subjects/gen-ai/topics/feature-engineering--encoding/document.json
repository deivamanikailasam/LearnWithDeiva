attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Tree-based models"},{"type":"text","text":" (Random Forest, XGBoost)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Label Encoding"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Ordinal categories"},{"type":"text","text":" (low < medium < high)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Ordinal Encoding"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"High-cardinality features"},{"type":"text","text":" (many unique values)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Target/Mean/Frequency Encoding"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Deep learning, recommender systems"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Embeddings"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Text features"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Embeddings (word2vec, BERT)"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best practices for encoding"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"bold"}],"text":"Use One-Hot for non-ordered labels"}]},{"type":"paragraph","content":[{"type":"text","text":"For most ML tasks, prefer one-hot encoding because it doesn't imply artificial ordering."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"bold"}],"text":"Use Label Encoding for tree models"}]},{"type":"paragraph","content":[{"type":"text","text":"Tree-based models don't care about ordering, so label encoding is fine."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"bold"}],"text":"Use Target/Mean encoding for high cardinality"}]},{"type":"paragraph","content":[{"type":"text","text":"Avoid creating hundreds/thousands of columns; use target encoding instead."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"bold"}],"text":"Avoid data leakage with target encoding"}]},{"type":"paragraph","content":[{"type":"text","text":"Must be done carefully with cross-validation to prevent target information leaking into features."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"✅ "},{"type":"text","marks":[{"type":"bold"}],"text":"Use embeddings for text or high-cardinality"}]},{"type":"paragraph","content":[{"type":"text","text":"Word embeddings (word2vec, BERT) or learned embeddings for user/product IDs."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Encoding"},{"type":"text","text":" transforms categorical/text features into "},{"type":"text","marks":[{"type":"bold"}],"text":"numeric representation"},{"type":"text","text":" so ML models (which only understand numbers) can process them."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"One-Hot Encoding"},{"type":"text","text":": Each category → binary column (0/1); best for small categorical features with no order; creates high dimensionality for many categories."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Label Encoding"},{"type":"text","text":": Each category → integer (0, 1, 2...); compact but implies ordering; fine for tree models, bad for linear models."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Ordinal Encoding"},{"type":"text","text":": For ordered categories (low < medium < high → 1, 2, 3); preserves natural order."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Target/Mean Encoding"},{"type":"text","text":": Replace category with mean of target; best for high cardinality; risk of data leakage."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Frequency Encoding"},{"type":"text","text":": Encode by frequency of occurrence; helps model understand weight."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Embeddings"},{"type":"text","text":": Dense vector representation (50–300D); best for deep learning, recommender systems, NLP, high-cardinality categories."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Quick decision"},{"type":"text","text":": One-hot for small non-ordered; Label for tree models; Ordinal for ordered; Target/Mean for high cardinality; Embeddings for text/deep learning."}]}]}]},{"type":"paragraph"}]}}
