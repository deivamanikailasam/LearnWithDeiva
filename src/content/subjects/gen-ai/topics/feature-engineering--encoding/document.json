{"format":"tiptap/v1","updatedAt":"2026-06-22T04:52:50.182Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Encoding"},{"type":"text","text":" is the process of "},{"type":"text","marks":[{"type":"bold"}],"text":"transforming categorical or text features into a numeric representation"},{"type":"text","text":" so they can be used by machine learning models, since most ML algorithms work with numbers and cannot understand categorical/text values directly."}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Simple definition:"},{"type":"text","text":" \"Encoding transforms categorical or text features into numeric values that machine learning models can process. Since models are like smart mathematicians that understand numbers (3, 10) but not words (London, Paris), we must translate text into numbers.\""}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why encoding matters"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"The problem"},{"type":"text","text":": Models only understand numbers, not text labels."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example dataset"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Employee | Department | City | Salary\nRobert   | HR         | Paris| 50000\nJane     | Finance    | Berlin| 60000"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Model can't process"},{"type":"text","text":": \"HR\", \"Finance\", \"Paris\", \"Berlin\" are text strings."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Solution"},{"type":"text","text":": Encode categorical columns into numbers so the model can learn from them."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common encoding methods"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"One-Hot Encoding (OHE)"}]},{"type":"paragraph","content":[{"type":"text","text":"Each category becomes a "},{"type":"text","marks":[{"type":"bold"}],"text":"separate binary column"},{"type":"text","text":" (0/1)."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": Color = {red, green, blue}"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"red"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"green"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"blue"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"1"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"0"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"0"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"0"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"1"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"0"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"0"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"0"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"1"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"[insightful-data-lab](https://insightful-data-lab.com/2025/08/20/encode-in-feature-engineering/)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use"},{"type":"text","text":":\n- Small categorical features (color, gender, country)\n- No ordering assumption between categories\n- Non-ordered labels (preferred for most ML tasks)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pros"},{"type":"text","text":":\n- Simple and intuitive\n- No artificial ordering implied"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cons"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"High dimensionality"},{"type":"text","text":" if many categories (creates many columns)\n- For high-cardinality features, slows down learning significantly"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Label Encoding"}]},{"type":"paragraph","content":[{"type":"text","text":"Assigns a "},{"type":"text","marks":[{"type":"bold"}],"text":"unique integer"},{"type":"text","text":" to each category (1 through N, where N = number of categories)."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":":\n- Red = 0\n- Green = 1\n- Blue = 2"}]},{"type":"paragraph","content":[{"type":"text","text":"[insightful-data-lab](https://insightful-data-lab.com/2025/08/20/encode-in-feature-engineering/)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Tree-based models"},{"type":"text","text":" (Random Forest, XGBoost) — fine for them\n- Simple categories with few values"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pros"},{"type":"text","text":":\n- Compact (single column)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cons"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Implies ordering"},{"type":"text","text":" that may not exist (e.g., Car < Bus < Truck → 0 < 1 < 2)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Bad for linear models"},{"type":"text","text":" (they interpret the integer as magnitude)\n- Categories lose information after encoding"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Ordinal Encoding"}]},{"type":"paragraph","content":[{"type":"text","text":"For categorical features with a "},{"type":"text","marks":[{"type":"bold"}],"text":"natural order"},{"type":"text","text":" (ordinal data)."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": \"low < medium < high\" → 1, 2, 3"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"education_level"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"ordinal"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"bachelor"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"1"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"master"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"2"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"doctorate"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"3"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"[youtube](https://www.youtube.com/watch?v=dDd4AM0u-Ec)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use"},{"type":"text","text":":\n- Ordinal categories with clear ranking (education level, satisfaction: low/medium/high)\n- Preserves ordering information"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pros"},{"type":"text","text":":\n- Preserves natural order"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Target / Mean Encoding"}]},{"type":"paragraph","content":[{"type":"text","text":"Replace category with "},{"type":"text","marks":[{"type":"bold"}],"text":"mean of target variable"},{"type":"text","text":" for that category."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": If loan default rate for \"industry=A\" is 20%, encode \"industry=A\" as 0.2."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"High-cardinality categorical features"},{"type":"text","text":" (many unique values)\n- Works well when frequency is related to target variable"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pros"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Does not affect data volume"},{"type":"text","text":" (single column, no expansion)\n- Helps faster learning"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cons"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Risk of data leakage"},{"type":"text","text":" (must be done carefully with cross-validation)\n- Labels are correlated directly with target"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Frequency Encoding"}]},{"type":"paragraph","content":[{"type":"text","text":"Encode category by "},{"type":"text","marks":[{"type":"bold"}],"text":"frequency of occurrence"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": Rare categories get low values, common ones get high values."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use"},{"type":"text","text":":\n- When frequency is somewhat related to target variable\n- Helps model understand weight in direct/inverse proportion"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Embeddings"},{"type":"text","text":" (for high-cardinality categories or text)"}]},{"type":"paragraph","content":[{"type":"text","text":"Learn a "},{"type":"text","marks":[{"type":"bold"}],"text":"dense vector representation"},{"type":"text","text":" (like NLP word embeddings)."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":":\n- User IDs → mapped to 50–300D vectors\n- Product IDs → mapped to vectors\n- Words → word embeddings"}]},{"type":"paragraph","content":[{"type":"text","text":"[insightful-data-lab](https://insightful-data-lab.com/2025/08/20/encode-in-feature-engineering/)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When to use"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Deep learning"},{"type":"text","text":" models\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Recommender systems"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"NLP"},{"type":"text","text":" tasks\n- High-cardinality categorical features"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Encoding nominal vs. ordinal data"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Nominal Encoding"},{"type":"text","text":" (order doesn't matter)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Method"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use case"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"p