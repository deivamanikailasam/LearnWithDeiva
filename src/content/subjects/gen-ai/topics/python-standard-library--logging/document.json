,{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import logging\n\n# Configure basic logging\nlogging.basicConfig(\n    level=logging.INFO,\n    format='%(asctime)s - %(levelname)s - %(message)s'\n)\n\n# Log messages\nlogging.debug('This is a debug message')\nlogging.info('This is an info message')\nlogging.warning('This is a warning message')\nlogging.error('This is an error message')\nlogging.critical('This is a critical message')"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"2026-06-21 19:42:00 - INFO - This is an info message\n2026-06-21 19:42:00 - WARNING - This is a warning message\n2026-06-21 19:42:00 - ERROR - This is an error message\n2026-06-21 19:42:00 - CRITICAL - This is a critical message"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Core Components: Logger, Handler, Formatter"}]},{"type":"paragraph","content":[{"type":"text","text":"The logging system has "},{"type":"text","marks":[{"type":"bold"}],"text":"three main components"},{"type":"text","text":":"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Component"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Purpose"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Example"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Logger"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Main object that emits log messages"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"logging.getLogger('name')"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Handler"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Processes messages from logger (output destination)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"StreamHandler"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"FileHandler"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Formatter"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Specifies format of log messages"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"Formatter('%(message)s')"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Detailed Example with All Components"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import logging\n\n# 1. Create a logger\nlogger = logging.getLogger('my_logger')\nlogger.setLevel(logging.DEBUG)  # Set logger level\n\n# 2. Create a handler (StreamHandler = console output)\nhandler = logging.StreamHandler()\nhandler.setLevel(logging.DEBUG)  # Set handler level\n\n# 3. Create a formatter\nformatter = logging.Formatter(\n    '%(asctime)s - %(name)s - %(levelname)s - %(message)s'\n)\nhandler.setFormatter(formatter)  # Apply formatter to handler\n\n# 4. Add handler to logger\nlogger.addHandler(handler)\n\n# 5. Emit log messages\nlogger.debug('This is a debug message')\nlogger.info('This is an info message')\nlogger.warning('This is a warning message')\nlogger.error('This is an error message')\nlogger.critical('This is a critical message')"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"2026-06-21 19:42:00 - my_logger - DEBUG - This is a debug message\n2026-06-21 19:42:00 - my_logger - INFO - This is an info message"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Logging to Files"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Write to Single File"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import logging\n\nlogger = logging.getLogger('file_logger')\nlogger.setLevel(logging.DEBUG)\n\n# Create FileHandler (writes to file)\nfile_handler = logging.FileHandler('app.log')\nfile_handler.setLevel(logging.DEBUG)\n\n# Create formatter\nformatter = logging.Formatter('%(asctime)s - %(levelname)s - %(message)s')\nfile_handler.setFormatter(formatter)\n\n# Add handler\nlogger.addHandler(file_handler)\n\n# Log messages (written to file)\nlogger.info('Application started')\nlogger.error('Something went wrong')"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Rotating File Handler (Prevent Huge Logs)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import logging\n\nlogger = logging.getLogger('rotating_logger')\n\n# RotatingFileHandler: Creates new file when size limit reached\nhandler = logging.RotatingFileHandler(\n    'app.log',\n    maxBytes=5*1024*1024,  # 5 MB\n    backupCount=3           # Keep 3 backup files\n)\n\nformatter = logging.Formatter('%(asctime)s - %(message)s')\nhandler.setFormatter(formatter)\nlogger.addHandler(handler)\nlogger.setLevel(logging.DEBUG)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common Formatters"}]},{"type":"paragraph","content":[{"type":"text","text":"The logging module provides built-in formatters:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import logging\n\nformatter = logging.Formatter(\n    '%(asctime)s - %(name)s - %(levelname)s - %(message)s'\n)\n\n# Common attributes:\n# %(asctime)  - Timestamp\n# %(name)     - Logger name\n# %(levelname) - Log level (DEBUG, INFO, etc.)\n# %(message)   - Log message\n# %(filename)  - Filename where log was created\n# %(lineno)    - Line number\n# %(funcName)  - Function name"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Use Logger per Module (Not Global)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# In each module (e.g., database.py)\nimport logging\n\n# Create module-specific logger\nlogger = logging.getLogger(__name__)  # '__name__' = module name\n\ndef query_database():\n    logger.debug('Querying database')\n    # ... code ...\n    logger.info('Query completed')"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Configure Logging in Main Module"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# main.py\nimport logging\nfrom database import query_database\n\n# Configure logging in main module\nlogging.basicConfig(\n    level=logging.DEBUG,\n    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',\n    handlers=[\n        logging.FileHandler('app.log'),\n        logging.StreamHandler()  # Also output to console\n    ]\n)\n\nquery_database()"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Never Use "},{"type":"text","marks":[{"type":"code"}],"text":"print()"},{"type":"text","text":" in Production"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Bad\nprint('User logged in')\n\n# Good\nlogger.info('User logged in')"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Use Appropriate Log Levels"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# DEBUG: Internal state, debugging\nlogger.debug(f'Variable value: {var}')\n\n# INFO: General progress\nlogger.info('Processing started')\n\n# WARNING: Issue but still working\nlogger.warning('Disk space low: 10% remaining')\n\n# ERROR: Function failed\nlogger.error('Failed to connect to database')\n\n# CRITICAL: Severe error\nlogger.critical('System out of memory')"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Logging Exceptions"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import logging\n\nlogger = logging.getLogger('exception_logger')\nlogger.setLevel(logging.ERROR)\n\ndef divide(a, b):\n    try:\n        return a / b\n    except Exception as e:\n        # Log exception with full traceback\n        logger.exception('Division failed')  # Equivalent to logger.error(..., exc_info=True)\n\ndivide(10, 0)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output includes full traceback:"}]},{"type":"codeBlock","attrs":{"language":"yaml"},"content":[{"type":"text","text":"ERROR exception_logger - Division failed\nTraceback (most recent call last):\n  ...\nZeroDivisionError: division by zero"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Logging with Context (Extra Data)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import logging\n\nlogger = logging.getLogger('context_logger')\nlogger.setLevel(logging.INFO)\n\nhandler = logging.StreamHandler()\nformatter = logging.Formatter('%(asctime)s - %(message)s - user=%(user)s')\nhandler.setFormatter(formatter)\nlogger.addHandler(handler)\n\n# Log with extra context\nlogger.info('Request processed', extra={'user': 'alice'})"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"2026-06-21 19:42:00 - Request processed - user=alice"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Complete Production Example"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import logging\nfrom logging.handlers import RotatingFileHandler\n\n# Create logger\nlogger = logging.getLogger('production_app')\nlogger.setLevel(logging.DEBUG)\n\n# Create handlers\nconsole_handler = logging.StreamHandler()\nfile_handler = RotatingFileHandler('app.log', maxBytes=10*1024*1024, backupCount=5)\n\n# Create formatters\nconsole_formatter = logging.Formatter('%(levelname)s - %(message)s')\nfile_formatter = logging.Formatter(\n    '%(asctime)s - %(name)s - %(levelname)s - %(message)s'\n)\n\nconsole_handler.setFormatter(console_formatter)\nfile_handler.setFormatter(file_formatter)\n\n# Set levels\nconsole_handler.setLevel(logging.INFO)\nfile_handler.setLevel(logging.DEBUG)\n\n# Add handlers\nlogger.addHandler(console_handler)\nlogger.addHandler(file_handler)\n\n# Use logger\nlogger.info('Application started')\nlogger.debug('Debugging internal state')\nlogger.warning('Warning: Low memory')\nlogger.error('Error: Failed to process request')"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Recommendation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"logging"},{"type":"text","marks":[{"type":"bold"}],"text":" not "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"print()"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Production-ready with levels"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Set appropriate level"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"DEBUG for dev, INFO for production"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"logger.exception()"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Captures full traceback for errors"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Multiple handlers"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Console + file simultaneously"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"RotatingFileHandler"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Prevent huge log files"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Module-specific loggers"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"getLogger(__name__)"},{"type":"text","text":" per module"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Understanding "},{"type":"text","marks":[{"type":"code"}],"text":"logging"},{"type":"text","text":" is essential for "},{"type":"text","marks":[{"type":"bold"}],"text":"Python Standard Library"},{"type":"text","text":" in Generative AI development, enabling production-grade debugging, error tracking, and monitoring."}]}]}}
