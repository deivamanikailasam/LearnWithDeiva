                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Unigrams only — same as plain BoW"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "marks": [
                          {
                            "type": "code"
                          }
                        ],
                        "text": "ngram_range=(1,2)"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "unigrams + bigrams"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Captures local pairs; most common practical setting"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "marks": [
                          {
                            "type": "code"
                          }
                        ],
                        "text": "ngram_range=(2,2)"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "bigrams only"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Removes unigrams entirely; forces pairwise context"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "marks": [
                          {
                            "type": "code"
                          }
                        ],
                        "text": "ngram_range=(1,3)"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "up to trigrams"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Better phrase coverage; vector dimension explodes — use max_features"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "marks": [
                          {
                            "type": "code"
                          }
                        ],
                        "text": "min_df"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "int or float"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Drop n-grams below a document frequency threshold — critical for bigrams/trigrams"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "tableRow",
            "content": [
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "marks": [
                          {
                            "type": "code"
                          }
                        ],
                        "text": "analyzer"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "'word' or 'char'"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Character n-grams handle typos and morphology better than word n-grams"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Character N-grams"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Setting "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "analyzer='char_wb'"
          },
          {
            "type": "text",
            "text": " slices over characters instead of words. \"colour\" and \"color\" share most of their character 4-grams ("
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "colo"
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "olor"
          },
          {
            "type": "text",
            "text": ") so the vectorizer naturally handles British/American spelling variants and minor typos."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from sklearn.feature_extraction.text import TfidfVectorizer\n\nvec_char = TfidfVectorizer(\n    analyzer='char_wb',   # pads word boundaries with spaces\n    ngram_range=(3, 5),   # character 3- to 5-grams\n    max_features=50000,\n    min_df=3,\n)\n# Useful for: noisy user-generated text, tweets, short strings,\n# morphologically rich languages (Turkish, Finnish, Arabic)\nX_char = vec_char.fit_transform(corpus)"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Classification: N-grams vs Unigrams"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Adding bigrams to a text classifier reliably improves accuracy on tasks where word pairs carry meaning — sentiment, spam detection, intent classification. Here is a direct comparison on the 20 newsgroups dataset:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from sklearn.datasets import fetch_20newsgroups\nfrom sklearn.feature_extraction.text import TfidfVectorizer\nfrom sklearn.linear_model import LogisticRegression\nfrom sklearn.pipeline import Pipeline\nfrom sklearn.metrics import accuracy_score\n\ntrain = fetch_20newsgroups(subset='train', remove=('headers', 'footers', 'quotes'))\ntest  = fetch_20newsgroups(subset='test',  remove=('headers', 'footers', 'quotes'))\n\nfor label, ngram in [(\"Unigrams (1,1)\", (1, 1)), (\"Bigrams (1,2)\", (1, 2)), (\"Trigrams (1,3)\", (1, 3))]:\n    pipe = Pipeline([\n        ('vec', TfidfVectorizer(ngram_range=ngram, max_features=50000, sublinear_tf=True)),\n        ('clf', LogisticRegression(max_iter=1000, C=5)),\n    ])\n    pipe.fit(train.data, train.target)\n    acc = accuracy_score(test.target, pipe.predict(test.data))\n    print(f\"{label}: {acc:.3f}\")\n\n# Typical output:\n# Unigrams (1,1): 0.683\n# Bigrams  (1,2): 0.712\n# Trigrams (1,3): 0.710  ← marginal gain after bigrams"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Bigrams consistently beat unigrams. Trigrams add little on top while significantly increasing vector dimensionality — so "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "(1, 2)"
          },
          {
            "type": "text",
            "text": " is the standard practical default."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Language Model N-grams"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "N-grams also appear in statistical "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "language models"
          },
          {
            "type": "text",
            "text": " that estimate the probability of a word given the n-1 preceding words:"
          }
        ]
      },
      {
        "type": "blockMath",
        "attrs": {
          "latex": "P(w_t \\mid w_{t-1}, w_{t-2}, \\ldots, w_{t-n+1})"
        }
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A bigram language model estimates "
          },
          {
            "type": "inlineMath",
            "attrs": {
              "latex": "P(\\text{mat} \\mid \\text{the})"
            }
          },
          {
            "type": "text",
            "text": " by counting how often \"the\" is followed by \"mat\" in a training corpus. These models powered autocomplete, spell-check, and speech recognition before neural language models replaced them. The Markov assumption (only the last n-1 words matter) keeps them tractable but limits long-range understanding."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from collections import defaultdict, Counter\n\ndef build_bigram_lm(sentences):\n    \"\"\"Returns a dict mapping each word to a counter of following words.\"\"\"\n    lm = defaultdict(Counter)\n    for sent in sentences:\n        tokens = sent.lower().split()\n        for w1, w2 in zip(tokens, tokens[1:]):\n            lm[w1][w2] += 1\n    return lm\n\ncorpus = [\"the cat sat on the mat\", \"the cat ate the rat\", \"the rat sat on a mat\"]\nlm = build_bigram_lm(corpus)\n\n# Most likely word after \"the\"\nprint(lm['the'].most_common(3))\n# [('cat', 2), ('mat', 2), ('rat', 2)]\n\n# Conditional probability P(mat | the)\ntotal = sum(lm['the'].values())\nprint(f\"P(mat|the) = {lm['the']['mat'] / total:.2f}\")  # 0.29"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
