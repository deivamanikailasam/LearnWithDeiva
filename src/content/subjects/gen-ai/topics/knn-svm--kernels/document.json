ntent": [{"type": "paragraph", "content": [{"type": "text", "text": "Weighted sum of kernel similarities"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Majority vote of neighbors"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Sparsity"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Sparse"}, {"type": "text", "text": " (only support vectors matter)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Dense"}, {"type": "text", "text": " (uses all k neighbors)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Training"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Solve optimization (slow)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Just store data (fast)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Non-linear"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Yes (via kernels)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Yes (implicitly via proximity)"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Surprising connection"}, {"type": "text", "text": ": SVC (SVM with kernel) works like K-NN — both use similarity-based voting, but SVM is "}, {"type": "text", "marks": [{"type": "bold"}], "text": "sparse"}, {"type": "text", "text": " (only support vectors) while k-NN is "}, {"type": "text", "marks": [{"type": "bold"}], "text": "dense"}, {"type": "text", "text": " (all neighbors)."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Key Takeaways"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Kernel function"}, {"type": "text", "text": " "}, {"type": "inlineMath", "attrs": {"latex": "K(x_i, x_j)"}}, {"type": "text", "text": " computes dot product in higher-dimensional space "}, {"type": "text", "marks": [{"type": "bold"}], "text": "without explicit transformation"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Kernel trick"}, {"type": "text", "text": ": Enables SVM to handle non-linear data efficiently by implicit mapping"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Linear kernel"}, {"type": "text", "text": ": No transformation, best for linearly separable/high-dimensional data"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Polynomial kernel"}, {"type": "text", "text": ": "}, {"type": "inlineMath", "attrs": {"latex": "(x_i \\cdot x_j + c)^d"}}, {"type": "text", "text": ", good for curved boundaries"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "RBF kernel"}, {"type": "text", "text": ": "}, {"type": "inlineMath", "attrs": {"latex": "\\exp(-\\gamma \\|x_i - x_j\\|^2)"}}, {"type": "text", "text": ", most popular for non-linear problems"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "RBF is universal"}, {"type": "text", "text": ": Works for most non-linear patterns, default choice"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Sigmoid kernel"}, {"type": "text", "text": ": "}, {"type": "inlineMath", "attrs": {"latex": "\\tanh(\\alpha x_i \\cdot x_j + c)"}}, {"type": "text", "text": ", for multi-class problems"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Kernel matrix"}, {"type": "text", "text": ": "}, {"type": "inlineMath", "attrs": {"latex": "n \\times n"}}, {"type": "text", "text": " matrix of pairwise similarities, used in dual optimization"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Decision function"}, {"type": "text", "text": ": "}, {"type": "inlineMath", "attrs": {"latex": "f(x) = \\sum a_i y_i K(x_i, x) + b"}}, {"type": "text", "text": ", only support vectors contribute"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Sparse vs. Dense"}, {"type": "text", "text": ": SVM with kernel is sparse (only support vectors), k-NN is dense (all neighbors)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "ReLU"}, {"type": "text", "text": ": In deep learning, kernels are replaced by learned feature transformations [contextual knowledge]"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Kernels are the mathematical magic that lets SVM solve non-linear problems — by computing similarity in implicit high-dimensional space, they transform impossible separation tasks into easy linear ones, making RBF the go-to choice for complex patterns while linear kernels excel on high-dimensional sparse data like text."}]}]}}