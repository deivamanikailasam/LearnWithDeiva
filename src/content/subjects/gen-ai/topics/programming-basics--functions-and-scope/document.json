{"format":"tiptap/v1","updatedAt":"2026-06-21T09:03:01.730Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Functions: Self-Contained Blocks of Code"}]},{"type":"paragraph","content":[{"type":"text","text":"A "},{"type":"text","marks":[{"type":"bold"}],"text":"function"},{"type":"text","text":" is a block of code that performs a specific action or task in a program. It's like a "},{"type":"text","marks":[{"type":"bold"}],"text":"recipe"},{"type":"text","text":" that gives step-by-step instructions for your program to complete a task."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Function Concepts"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Concept"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Description"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Definition"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Block of code for a specific task"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Task Examples"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Adding two numbers, reading a file"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Calling"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Function won't run unless you \"call\" it"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Syntax"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"functionName()"},{"type":"text","text":" — always has parentheses"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Function Anatomy"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Function definition\ndef add_numbers(a, b):          # Parameters = ingredients\n    result = a + b\n    return result               # Return value = output\n\n# Function call\noutput = add_numbers(5, 3)      # Arguments = actual ingredients\nprint(output)                   # Output: 8"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Components:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Parameters/Arguments"},{"type":"text","text":": Ingredients passed to the function\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Return Value"},{"type":"text","text":": What the function gives back when used\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Function Body"},{"type":"text","text":": The code block that performs the task"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Scope: Where Variables Are Visible"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Scope"},{"type":"text","text":" refers to the visibility and accessibility of variables in different parts of your code. Think of scope as a "},{"type":"text","marks":[{"type":"bold"}],"text":"container"},{"type":"text","text":" — variables in one container may or may not be visible to code in other containers."}]},{"type":"paragraph","content":[{"type":"text","text":"More precisely: scope is the current context of execution where values and expressions are \"visible\" or can be referenced."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why Scope Matters"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Prevents naming conflicts between variables"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Manages memory by cleaning up unused variables"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Provides security by limiting variable access"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Types of Scope"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Global Scope"}]},{"type":"paragraph","content":[{"type":"text","text":"Variables declared "},{"type":"text","marks":[{"type":"bold"}],"text":"outside"},{"type":"text","text":" of any function have global scope."}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Global variable\nx = 10  # Global scope\n\ndef my_function():\n    print(x)  # Can access global variable\n\nmy_function()  # Output: 10\nprint(x)       # Output: 10 (accessible everywhere)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Characteristics:"},{"type":"text","text":"\n- Can be accessed from anywhere in your program\n- Defined in the main program body, not inside a function"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Local Scope"}]},{"type":"paragraph","content":[{"type":"text","text":"Variables declared "},{"type":"text","marks":[{"type":"bold"}],"text":"inside"},{"type":"text","text":" a function have local scope."}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"def add_numbers(a, b):\n    # Local variables\n    result = a + b\n    return result\n\noutput = add_numbers(5, 3)\nprint(output)  # Works: 8\n\n# print(result)  # ERROR! result is not accessible here"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Characteristics:"},{"type":"text","text":"\n- Can only be accessed within the function where declared\n- Variables like "},{"type":"text","marks":[{"type":"code"}],"text":"x"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"y"},{"type":"text","text":", and "},{"type":"text","marks":[{"type":"code"}],"text":"result"},{"type":"text","text":" belong only to that function\n- Cannot be used outside the function — would cause an error"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Function Scope Example (JavaScript):"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"function exampleFunction() {\n    const x = \"declared inside function\";\n    console.log(x);  // Works inside function\n}\n\nconsole.log(x);  // ERROR: x is not defined"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Block Scope"}]},{"type":"paragraph","content":[{"type":"text","text":"Variables declared inside a "},{"type":"text","marks":[{"type":"bold"}],"text":"block"},{"type":"text","text":" (loops, if statements) have block scope."}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"if True:\n    x = 5  # Block scope (in Python 3+)\n    print(x)  # Works: 5\n\nprint(x)  # Works in Python (functions don't create block scope)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"JavaScript difference:"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"if (true) {\n    let x = 5;  // Block scoped\n    const y = 10;\n}\nconsole.log(x);  // ERROR: x is not defined"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"let"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"code"}],"text":"const"},{"type":"text","text":" are "},{"type":"text","marks":[{"type":"bold"}],"text":"block-scoped"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"var"},{"type":"text","text":" is "},{"type":"text","marks":[{"type":"bold"}],"text":"function-scoped"},{"type":"text","text":" (not block-scoped)"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Scope Hierarchy: Parent-Child Relationship"}]},{"type":"paragraph","content":[{"type":"text","text":"Scopes can be layered in a hierarchy:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Global Scope (Parent)\n    ↓\nFunction Scope (Child)\n    ↓\nInner Function Scope (Grandchild)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key rule:"},{"type":"text","text":" Child scopes have access to parent scopes, but "},{"type":"text","marks":[{"type":"bold"}],"text":"not vice versa"},{"type":"text","text":"."}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Global scope\nx = \"global\"\n\ndef outer():\n    # Outer function scope (child of global)\n    y = \"outer\"\n    \n    def inner():\n        # Inner function scope (child of outer)\n        z = \"inner\"\n        print(x)  # ✅ Can access global\n        print(y)  # ✅ Can access outer\n        print(z)  # ✅ Can access inner\n    \n    inner()\n\nouter()"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Visual Comparison: Local vs Global Scope"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Local Scope"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Global Scope"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Where declared"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Inside a function"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Outside any function"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Accessibility"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Only within that function"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Everywhere in program"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Lifetime"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Exists while function runs"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Exists throughout program"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Memory"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Auto-cleaned after function"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Persists until program ends"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Best Practice"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Prefer local variables"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Avoid unless necessary"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common Scope Pitfalls"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Trying to Access Local Variable Outside Function"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"def my_function():\n    local_var = 42\n\nmy_function()\nprint(local_var)  # ❌ ERROR: local_var not defined"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Variable Name Conflicts"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"x = 10  # Global\n\ndef my_function():\n    x = 5  # Local (different variable)\n    print(x)  # Output: 5\n\nmy_function()\nprint(x)  # Output: 10 (global unchanged)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Functions Can't See Other Functions' Internal Variables"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"def add(a, b):\n    result = a + b\n    return result\n\ndef subtract(a, b):\n    # Can't see 'result' from add()\n    # print(result)  # ❌ ERROR\n    return a - b"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Analogy:"},{"type":"text","text":" Think of scope as "},{"type":"text","marks":[{"type":"bold"}],"text":"houses"},{"type":"text","text":" — each function is a neighbor's house. One function can't see what's inside another function's \"house\". You must pass arguments to share data."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Function Declaration vs. Function Call"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Action"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Syntax"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"When Code Runs"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Define"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"def my_func():"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Never runs automatically"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Call"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"my_func()"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Executes when called"}]}]}]}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Definition (doesn't run yet)\ndef greet():\n    print(\"Hello!\")\n\n# Call (runs the code)\ngreet()  # Output: \"Hello!\""}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prefer local variables"},{"type":"text","text":" over global variables"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Avoid global variables"},{"type":"text","text":" unless creating constants"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pass arguments"},{"type":"text","text":" to functions instead of relying on globals"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use meaningful parameter names"},{"type":"text","text":" for clarity"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Keep functions focused"},{"type":"text","text":" on one specific task"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Understanding functions and scope is essential for building "},{"type":"text","marks":[{"type":"bold"}],"text":"modules"},{"type":"text","text":", handling "},{"type":"text","marks":[{"type":"bold"}],"text":"error handling"},{"type":"text","text":", and writing clean, maintainable code in any programming language."}]}]}}
