{"format": "tiptap/v1", "updatedAt": "2026-06-22T04:20:15.873Z", "doc": {"type": "doc", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Multinomial Naive Bayes"}, {"type": "text", "text": " and "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Bernoulli Naive Bayes"}, {"type": "text", "text": " are two popular variants of the Naive Bayes classifier designed for "}, {"type": "text", "marks": [{"type": "bold"}], "text": "discrete data"}, {"type": "text", "text": ", particularly text classification — they differ in how they represent features (word counts vs. binary presence) and what distribution they assume for the data."}]}, {"type": "horizontalRule"}, {"type": "image", "attrs": {"src": "data:image/svg+xml;base64,", "alt": "Multinomial & Bernoulli Naive Bayes — concept overview"}}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "1. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Multinomial Naive Bayes"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "What It Is"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Definition"}, {"type": "text", "text": ": A Naive Bayes variant for "}, {"type": "text", "marks": [{"type": "bold"}], "text": "discrete count data"}, {"type": "text", "text": " that assumes features follow a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "multinomial distribution"}, {"type": "text", "text": "."}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Best for"}, {"type": "text", "text": ":\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Text classification"}, {"type": "text", "text": " where word frequencies matter\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Long documents"}, {"type": "text", "text": " where word repetition is significant\n- Data where features are "}, {"type": "tex