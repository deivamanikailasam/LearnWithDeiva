{"type": "paragraph", "content": [{"type": "text", "text": "Multinomial"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Binary features"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Bernoulli"}]}]}]}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Text Classification Example"}]}, {"type": "codeBlock", "attrs": {"language": "yaml"}, "content": [{"type": "text", "text": "Scenario: Spam detection\n\nSMS (short): \"FREE money NOW!!!\"\n→ Bernoulli: free=1, money=1, now=1\n→ Works well for short text\n\nEmail (long): \"free free free offer offer money money money\"\n→ Multinomial: free=3, offer=2, money=3\n→ Better accuracy with repetition"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Other Naive Bayes Variants (Quick Reference)"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Variant"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Data Type"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Best For"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Gaussian NB"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Continuous features"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Height, weight, temperature (Iris dataset)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Bernoulli NB"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Binary features"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Boolean attributes, short text"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Multinomial NB"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Discrete counts"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Word frequencies, long documents"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Key insight"}, {"type": "text", "text": ": The difference is the underlying distribution — you select the probability rule based on your data type."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Python Implementation"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "from sklearn.naive_bayes import MultinomialNB, BernoulliNB\nfrom sklearn.feature_extraction import CountVectorizer, HashingVectorizer\n\n# ===== Multinomial NB (word counts) =====\n# Step 1: Convert text to word counts\nvectorizer = CountVectorizer()\nX_counts = vectorizer.fit_transform(texts)  # Frequency matrix\n\n# Step 2: Train Multinomial NB\nmodel_mnb = MultinomialNB(alpha=1.0)  # alpha = smoothing parameter\nmodel_mnb.fit(X_counts, labels)\n\n# ===== Bernoulli NB (binary presence) =====\n# Step 1: Convert text to binary presence\nvectorizer_bin = HashingVectorizer(binary=True)  # Binary matrix\nX_binary = vectorizer_bin.fit_transform(texts)\n\n# Step 2: Train Bernoulli NB\nmodel_bnb = BernoulliNB(alpha=1.0)\nmodel_bnb.fit(X_binary, labels)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Parameters"}, {"type": "text", "text": ":\n- "}, {"type": "text", "marks": [{"type": "code"}], "text": "alpha"}, {"type": "text", "text": ": Smoothing parameter (Laplace smoothing), default = 1.0\n- "}, {"type": "text", "marks": [{"type": "code"}], "text": "binarize"}, {"type": "text", "text": ": Threshold for converting features to binary (for Bernoulli)"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Key Takeaways"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Multinomial NB"}, {"type": "text", "text": ": Uses "}, {"type": "text", "marks": [{"type": "bold"}], "text": "word frequencies"}, {"type": "text", "text": " (counts), considers repetition"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Bernoulli NB"}, {"type": "text", "text": ": Uses "}, {"type": "text", "marks": [{"type": "bold"}], "text": "binary presence"}, {"type": "text", "text": " (0/1), ignores repetition"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Multinomial distribution"}, {"type": "text", "text": ": Counts how often each outcome occurs"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Bernoulli distribution"}, {"type": "text", "text": ": Binary (yes/no) probability"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Repetition"}, {"type": "text", "text": ": Multinomial exploits it, Bernoulli ignores it"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Absence penalization"}, {"type": "text", "text": ": Bernoulli penalizes absence, Multinomial doesn't"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Short text"}, {"type": "text", "text": " (SMS, tweets): Use Bernoulli"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Long documents"}, {"type": "text", "text": ": Use Multinomial"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Word counts"}, {"type": "text", "text": ": Use Multinomial"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Binary features"}, {"type": "text", "text": ": Use Bernoulli"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Accuracy"}, {"type": "text", "text": ": Multinomial has higher accuracy in practice"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Speed"}, {"type": "text", "text": ": Bernoulli is faster (simpler)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Best for text"}, {"type": "text", "text": ": Both are popular for text classification"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Multinomial and Bernoulli Naive Bayes are the \"text classification specialists\" — Multinomial cares about "}, {"type": "text", "marks": [{"type": "bold"}], "text": "how often"}, {"type": "text", "text": " words appear (counts matter), making it better for long documents where repetition indicates importance, while Bernoulli only cares about "}, {"type": "text", "marks": [{"type": "bold"}], "text": "whether"}, {"type": "text", "text": " words appear (binary presence), making it faster and better for short texts where absence of a word is also informative, so choose Multinomial for word frequencies and long documents, and Bernoulli for binary features and short texts."}]}]}}