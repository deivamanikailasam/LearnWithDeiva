{"format":"tiptap/v1","updatedAt":"2026-06-21T17:44:02.689Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Common probability distributions"},{"type":"text","text":" are mathematical functions that describe how probabilities are assigned to the values of random variables. They are essential for modeling real-world phenomena, performing statistical inference (hypothesis testing, confidence intervals), and building machine learning models in Generative AI. Each distribution has specific parameters (like mean μ and standard deviation σ) that shape its behavior, and different distributions are used for different types of data (discrete vs. continuous) and scenarios."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What it is — Clear definition and context"}]},{"type":"paragraph","content":[{"type":"text","text":"A "},{"type":"text","marks":[{"type":"bold"}],"text":"probability distribution"},{"type":"text","text":" defines the probability that a random variable takes on each possible value."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Two main types"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Discrete distributions"},{"type":"text","text":": For countable outcomes (dice rolls, coin flips) → use "},{"type":"text","marks":[{"type":"bold"}],"text":"Probability Mass Function (PMF)"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Continuous distributions"},{"type":"text","text":": For infinite outcomes (height, temperature) → use "},{"type":"text","marks":[{"type":"bold"}],"text":"Probability Density Function (PDF)"}]},{"type":"paragraph","content":[{"type":"text","text":"[medium](https://medium.com/analytics-vidhya/probability-distributions-in-data-science-and-machine-learning-part-2-a907d84d3211)"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key discrete distributions"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Bernoulli Distribution"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it models"},{"type":"text","text":": Binary outcome (success/failure, yes/no, 1/0)."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": Single coin flip (heads = 1, tails = 0)."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Parameters"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"p"},{"type":"text","text":" = probability of success (X = 1)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PMF"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"P(X = 1) = p\nP(X = 0) = 1 - p"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Properties"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Mean"},{"type":"text","text":": E = p\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Variance"},{"type":"text","text":": Var(X) = p(1 - p)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"ML application"},{"type":"text","text":": Logistic regression for binary classification."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Binomial Distribution"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it models"},{"type":"text","text":": Number of successes in "},{"type":"text","marks":[{"type":"bold"}],"text":"n independent Bernoulli trials"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": Number of heads in 10 coin flips."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Parameters"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"n"},{"type":"text","text":" = number of trials\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"p"},{"type":"text","text":" = probability of success in each trial"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PMF"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"P(X = k) = C(n, k) · p^k · (1-p)^(n-k)"}]},{"type":"paragraph","content":[{"type":"text","text":"Where C(n, k) = n! / (k! · (n-k)!) = number of combinations."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Properties"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Mean"},{"type":"text","text":": E = n·p\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Variance"},{"type":"text","text":": Var(X) = n·p·(1-p)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"ML application"},{"type":"text","text":": Classification outputs, cross-entropy loss."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Poisson Distribution"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it models"},{"type":"text","text":": Number of events occurring in a "},{"type":"text","marks":[{"type":"bold"}],"text":"fixed time/space interval"},{"type":"text","text":" with constant average rate λ."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": Number of customers arriving per hour; number of emails received per day."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Parameters"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"λ"},{"type":"text","text":" = average rate (expected number of events)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PMF"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"P(X = k) = (λ^k · e^(-λ)) / k!"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Properties"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Mean"},{"type":"text","text":": E = λ\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Variance"},{"type":"text","text":": Var(X) = λ"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"ML application"},{"type":"text","text":": Modeling stochastic rewards in reinforcement learning."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Approximation"},{"type":"text","text":": When n is large and p is small (p < 0.05), Poisson approximates Binomial."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Geometric Distribution"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"What it models"},{"type":"text","text":": Number of trials needed for "},{"type":"text","marks":[{"type":"bold"}],"text":"first success"},{"type":"text","text":" in Bernoulli trials."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": How many coin flips until first heads."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Parameters"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"p"},{"type":"text","text":" = probability of success"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PMF"},{"type":"text","text":":"}]},{"type":"codeB