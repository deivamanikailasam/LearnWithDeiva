ph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Example"},{"type":"text","text":": Rolling a fair die; random number generator."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Parameters"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"a"},{"type":"text","text":" = minimum\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"b"},{"type":"text","text":" = maximum"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PDF"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"f(x) = 1 / (b - a) for a ≤ x ≤ b"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Properties"},{"type":"text","text":":\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Mean"},{"type":"text","text":": E = (a + b) / 2\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Variance"},{"type":"text","text":": Var(X) = (b - a)² / 4"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"ML application"},{"type":"text","text":": Initializing neural network weights randomly."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Distributions for hypothesis testing and confidence intervals"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why specific distributions are needed:"}]},{"type":"paragraph","content":[{"type":"text","text":"Different hypothesis tests require different distributions based on data characteristics./12:"},{"type":"text","marks":[{"type":"italic"}],"text":"Confidence_Intervals_and_Hypothesis_Tests/12.03:"},{"type":"text","text":"Steps_in_Hypothesis_Testing/12.3.03:"},{"type":"text","marks":[{"type":"italic"}],"text":"Distribution_Needed_for_Hypothesis_Testing)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align