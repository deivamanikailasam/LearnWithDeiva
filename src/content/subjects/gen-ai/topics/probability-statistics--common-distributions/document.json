:"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Testing population variance"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"F-test"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"F-distribution"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Comparing two population variances"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Proportion test"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Normal"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Testing population proportion (large n)/12:"},{"type":"text","marks":[{"type":"italic"}],"text":"Confidence_Intervals_and_Hypothesis_Tests/12.03:"},{"type":"text","text":"Steps_in_Hypothesis_Testing/12.3.03:"},{"type":"text","marks":[{"type":"italic"}],"text":"Distribution_Needed_for_Hypothesis_Testing)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key insight"},{"type":"text","text":": t-distribution approaches normal as sample size increases (df → ∞)./12:"},{"type":"text","marks":[{"type":"italic"}],"text":"Confidence_Intervals_and_Hypothesis_Tests/12.03:"},{"type":"text","text":"Steps_in_Hypothesis_Testing/12.3.03:"},{"type":"text","marks":[{"type":"italic"}],"text":"Distribution_Needed_for_Hypothesis_Testing)"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Python implementation"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Generating samples from distributions:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import numpy as np\n\n# Bernoulli: coin flip\nbernoulli_samples = np.random.binomial(n=1, p=0.5, size=1000)\n\n# Binomial: heads in 10 flips\nbinomial_samples = np.random.binomial(n=10, p=0.5, size=1000)\n\n# Poisson: customers per hour\npoisson_samples = np.random.poisson(lam=5, size=1000)\n\n# Normal: heights\nnormal_samples = np.random.normal(loc=170, scale=10, size=1000)  # μ=170cm, σ=10cm\n\n# Exponential: time until event\nexponential_samples = np.random.exponential(scale=1/0.5, size=1000)  # λ=0.5"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Computing probabilities:"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"from scipy import stats\n\n# Normal distribution\nmu, sigma = 170, 10\nx = 180\n\n# Probability density\npdf_val = stats.norm.pdf(x, mu, sigma)\n\n# Cumulative probability (P(X ≤ 180))\ncdf_val = stats.norm.cdf(x, mu, sigma)  # ≈ 0.84 (84% of people ≤ 180cm)\n\n# t-distribution for confidence intervals\nt_stat = stats.t.ppf(0.975, df=19)  # 95% CI, df=19"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key takeaways"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Bernoulli"},{"type":"text","text":": Binary outcome (success/failure); P(X=1) = p"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Binomial"},{"type":"text","text":": Successes in n trials; P(X=k) = C(n,k)·p^k·(1-p)^(n-k)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Poisson"},{"type":"text","text":": Events in time/space; P(X=k) = (λ^k·e^(-λ))/k!"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Normal (Gaussian)"},{"type":"text","text":": Bell-shaped; f(x) = (1/√(2πσ²))·e^(-(x-μ)²/(2σ²))"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Student's t"},{"type":"text","text":": Unknown variance, small samples; used in t-tests"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Exponential"},{"type":"text","text":": Time until event; f(x) = λ·e^(-λx); memoryless property"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Gamma"},{"type":"text","text":": Sum of exponentials; modeling waiting times"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Beta"},{"type":"text","text":": Probability of success (uncertain); Bayesian priors"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Uniform"},{"type":"text","text":": All outcomes equally likely; weight initialization"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Hypothesis testing"},{"type":"text","text":": z-test (normal), t-test (t), χ²-test (chi-square), F-test (F)"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"For Generative AI, probability distributions are fundamental: VAEs model data as Gaussian distributions, logistic regression uses Bernoulli/Binomial for classification, reinforcement learning uses Poisson/Exponential for rewards, and Bayesian methods use Beta/Gamma for priors. Understanding these distributions enables proper statistical inference, confidence interval construction, and hypothesis testing for model evaluation."}]}]}}
