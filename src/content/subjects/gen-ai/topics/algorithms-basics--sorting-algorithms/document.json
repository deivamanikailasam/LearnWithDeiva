,"attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n+k)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n+k)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n+k)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(k)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Yes"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ No"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Small integer ranges"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Timsort"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n log n)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n log n)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Yes"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ No"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Python's "},{"type":"text","marks":[{"type":"code"}],"text":"sorted()"},{"type":"text","text":", nearly sorted data"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How Major Sorting Algorithms Work"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Quick Sort"},{"type":"text","text":" ⭐ (Most Common, Fast in Practice)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Quick Sort: Divide-and-conquer, O(n log n) average\ndef quick_sort(arr):\n    if len(arr) <= 1:\n        return arr\n    \n    pivot = arr[len(arr) // 2]  # ✅ Choose middle element as pivot\n    left = [x for x in arr if x < pivot]  # ✅ Elements < pivot\n    middle = [x for x in arr if x == pivot]  # ✅ Elements = pivot\n    right = [x for x in arr if x > pivot]  # ✅ Elements > pivot\n    \n    return quick_sort(left) + middle + quick_sort(right)  # ✅ Recurse [web:178][web:180]\n\n# Example:\nquick_sort([3, 6, 1, 5, 2, 4])  # ✅ [1, 2, 3, 4, 5, 6]\n# Average: O(n log n) = 6 × log₂(6) ≈ 15 operations [web:178]\n# Worst: O(n²) = 36 operations (if pivot is smallest/largest) [web:178]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Merge Sort"},{"type":"text","text":" ⭐ (Stable, Guaranteed O(n log n))"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Merge Sort: Split → Sort → Merge, O(n log n) guaranteed\ndef merge_sort(arr):\n    if len(arr) <= 1:\n        return arr\n    \n    mid = len(arr) // 2  # ✅ Split in half\n    left = merge_sort(arr[:mid])  # ✅ Sort left half\n    right = merge_sort(arr[mid:])  # ✅ Sort right half\n    \n    return merge(left, right)  # ✅ Merge sorted halves [web:178][web:180]\n\ndef merge(left, right):\n    result = []\n    i, j = 0, 0\n    \n    while i < len(left) and j < len(right):  # ✅ Compare and merge\n        if left[i] < right[j]:\n            result.append(left[i])\n            i += 1\n        else:\n            result.append(right[j])\n            j += 1\n    \n    result.extend(left[i:])  # ✅ Add remaining left\n    result.extend(right[j:])  # ✅ Add remaining right\n    return result  # ✅ O(n log n) [web:178]\n\n# Example:\nmerge_sort([3, 6, 1, 5, 2, 4])  # ✅ [1, 2, 3, 4, 5, 6]\n# Guaranteed: O(n log n) = 6 × log₂(6) ≈ 15 operations [web:178]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Heap Sort"},{"type":"text","text":" ⭐ (Memory-Efficient, O(1) Space)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Heap Sort: Build max-heap → Extract max, O(n log n)\ndef heap_sort(arr):\n    n = len(arr)\n    \n    # Build max-heap: O(n)\n    for i in range(n // 2 - 1, -1, -1):\n        heapify(arr, n, i)\n    \n    # Extract elements: O(n log n)\n    for i in range(n - 1, 0, -1):\n        arr[0], arr[i] = arr[i], arr[0]  # ✅ Move max to end\n        heapify(arr, i, 0)  # ✅ Restore heap\n    \n    return arr  # ✅ O(n log n), O(1) space [web:178][web:180]\n\ndef heapify(arr, n, i):\n    largest = i\n    left = 2 * i + 1\n    right = 2 * i + 2\n    \n    if left < n and arr[left] > arr[largest]:\n        largest = left\n    if right < n and arr[right] > arr[largest]:\n        largest = right\n    \n    if largest != i:\n        arr[i], arr[largest] = arr[largest], arr[i]\n        heapify(arr, n, largest)  # ✅ Recurse [web:178]\n\n# Example:\nheap_sort([3, 6, 1, 5, 2, 4])  # ✅ [1, 2, 3, 4, 5, 6]\n# Guaranteed: O(n log n), O(1) space (in-place) [web:178][web:180]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Insertion Sort"},{"type":"text","text":" ⭐ (Best for Small/Nearly Sorted Data)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Insertion Sort: Insert each element into sorted portion, O(n) best case\ndef insertion_sort(arr):\n    for i in range(1, len(arr)):\n        key = arr[i]  # ✅ Current element\n        j = i - 1\n        \n        while j >= 0 and arr[j] > key:  # ✅ Shift larger elements right\n            arr[j + 1] = arr[j]\n            j -= 1\n        \n        arr[j + 1] = key  # ✅ Insert at correct position [web:178][web:180]\n    \n    return arr  # ✅ O(n) best, O(n²) worst\n\n# Example:\ninsertion_sort([3, 6, 1, 5, 2, 4])  # ✅ [1, 2, 3, 4, 5, 6]\n# Best: O(n) = 6 operations (already sorted) [web:178][web:180]\n# Worst: O(n²) = 36 operations (reverse sorted) [web:178][web:180]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Time Complexity Analysis"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Input Size"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n²) Sort (Bubble)"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n log n) Sort (Quick)"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Speedup"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"10"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"100 operations"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"30 operations"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"3x faster"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"100"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"10,000 operations"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"660 operations"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"15x faster"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"1,000"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"1,000,000 operations"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[