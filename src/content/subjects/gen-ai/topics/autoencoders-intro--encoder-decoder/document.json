bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Encoder"},{"type":"text","text":" = You read a 10-page story and write a 1-page summary"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Bottleneck"},{"type":"text","text":" = The 1-page summary (compressed representation)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Decoder"},{"type":"text","text":" = Someone else reads your summary and tries to tell the story back to you"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Goal"},{"type":"text","text":" = The reconstructed story should closely match the original"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Or think of it as a "},{"type":"text","marks":[{"type":"bold"}],"text":"ZIP file"},{"type":"text","text":":"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Encoder"},{"type":"text","text":" = Compressing a folder into a ZIP file (784 bytes → 32 bytes)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Bottleneck"},{"type":"text","text":" = The ZIP file (tiny but contains all essential info)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Decoder"},{"type":"text","text":" = Extracting the ZIP file back to original folder (32 bytes → 784 bytes)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Loss"},{"type":"text","text":" = Some files might be slightly corrupted during compression/decompression"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[