      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Job Data Model"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Store job state in Postgres so workers can update status atomically and clients can query progress:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "sql"
        },
        "content": [
          {
            "type": "text",
            "text": "-- jobs table\nCREATE TABLE jobs (\n    id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    user_id     TEXT         NOT NULL,\n    job_type    TEXT         NOT NULL,   -- 'summarise', 'rag_ingest', etc.\n    status      TEXT         NOT NULL DEFAULT 'pending',\n    payload     JSONB        NOT NULL,   -- input parameters\n    result      JSONB,                  -- output when completed\n    error       TEXT,                   -- error message when failed\n    attempt     INTEGER      NOT NULL DEFAULT 0,\n    created_at  TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    started_at  TIMESTAMPTZ,\n    completed_at TIMESTAMPTZ,\n    expires_at  TIMESTAMPTZ             -- TTL for result cleanup\n);\nCREATE INDEX ON jobs (user_id, status, created_at DESC);\nCREATE INDEX ON jobs (status, created_at) WHERE status = 'pending';\n"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from enum import StrEnum\nfrom datetime import datetime\nfrom typing import Any\nimport uuid\n\nclass JobStatus(StrEnum):\n    PENDING   = \"pending\"\n    RUNNING   = \"running\"\n    COMPLETED = \"completed\"\n    FAILED    = \"failed\"\n    RETRYING  = \"retrying\"\n    DEAD      = \"dead\"\n\nclass Job:\n    id:          str\n    user_id:     str\n    job_type:    str\n    status:      JobStatus\n    payload:     dict[str, Any]\n    result:      dict[str, Any] | None\n    error:       str | None\n    attempt:     int\n    created_at:  datetime\n    started_at:  datetime | None\n    completed_at: datetime | None\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Celery Worker Implementation"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Celery with a Redis broker is the most common Python background worker stack. Each task maps to a job type:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# workers/celery_app.py\nfrom celery import Celery\n\ncelery_app = Celery(\n    \"genai_workers\",\n    broker=\"redis://localhost:6379/1\",\n    backend=\"redis://localhost:6379/2\",\n    include=[\"workers.tasks\"],\n)\ncelery_app.conf.update(\n    task_serializer=\"json\",\n    result_serializer=\"json\",\n    accept_content=[\"json\"],\n    result_expires=3600,           # keep results in Redis for 1 hour\n    task_acks_late=True,           # ack after task completes, not on pickup\n    task_reject_on_worker_lost=True,\n    worker_prefetch_multiplier=1,  # one task per worker at a time (LLM calls are slow)\n)\n"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# workers/tasks.py\nimport asyncio\nfrom anthropic import Anthropic\nfrom workers.celery_app import celery_app\nfrom db import update_job_status, write_job_result\n\nclient = Anthropic()  # synchronous client inside sync Celery task\n\n@celery_app.task(\n    bind=True,\n    max_retries=3,\n    default_retry_delay=30,\n    queue=\"llm\",\n)\ndef summarise_document(self, job_id: str, user_id: str, document_text: str, model: str) -> dict:\n    \"\"\"Summarise a long document. Runs in a Celery worker process.\"\"\"\n    update_job_status(job_id, \"running\", attempt=self.request.retries + 1)\n    try:\n        response = client.messages.create(\n            model=model,\n            max_tokens=1024,\n            system=\"You are a concise technical summariser.\",\n            messages=[{\"role\": \"user\", \"content\": f\"Summarise this document:\\n\\n{document_text}\"}],\n        )\n        result = {\"summary\": response.content[0].text, \"tokens\": dict(response.usage)}\n        write_job_result(job_id, result)\n        return result\n    except Exception as exc:\n        # Retry on transient errors; give up after max_retries\n        raise self.retry(exc=exc)\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Async Worker Alternative (ARQ)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "ARQ runs async workers on asyncio \u2014 better suited if your task code already uses async libraries like AsyncAnthropic:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# workers/arq_workers.py\nfrom anthropic import AsyncAnthropic\nfrom arq import create_pool\nfrom arq.connections import RedisSettings\n\nanthropic = AsyncAnthropic()\n\nasync def summarise_document(ctx, job_id: str, user_id: str, text: str, model: str):\n    await update_job_status_async(job_id, \"running\")\n    response = await anthropic.messages.create(\n        model=model,\n        max_tokens=1024,\n        messages=[{\"role\": \"user\", \"content\": f\"Summarise:\\n\\n{text}\"}],\n    )\n    result = {\"summary\": response.content[0].text, \"tokens\": dict(response.usage)}\n    await write_job_result_async(job_id, result)\n    return result\n\nclass WorkerSettings:\n    functions = [summarise_document]\n    redis_settings = RedisSettings(host=\"localhost\", port=6379, database=1)\n    max_jobs = 10   # concurrency cap \u2014 how many LLM calls in parallel\n    job_timeout = 120\n    keep_result = 3600\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "API Endpoints: Submit, Poll, Cancel"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# api/jobs.py\nimport uuid\nfrom fastapi import APIRouter, Depends, HTTPException, BackgroundTasks\nfrom pydantic import BaseModel\n\nrouter = APIRouter(prefix=\"/v1/jobs\")\n\nclass SummariseRequest(BaseModel):\n    document_text: str\n    model: str = \"claude-haiku-4-5-20251001\"\n\n@router.post(\"/summarise\", status_code=202)\nasync def submit_summarise(\n    body: SummariseRequest,\n    auth: dict = Depends(get_current_user),\n):\n    \"\"\"Enqueue a summarisation job and return job_id immediately.\"\"\"\n    job_id = str(uuid.uuid4())\n    await create_job_record(job_id, auth[\"sub\"], \"summarise\", body.dict())\n\n    # Enqueue via Celery; ARQ equivalent: await redis_pool.enqueue_job(\"summarise_document\", ...)\n    summarise_document.apply_async(\n        kwargs={\"job_id\": job_id, \"user_id\": auth[\"sub\"],\n                \"document_text\": body.document_text, \"model\": body.model},\n        task_id=job_id,\n        queue=\"llm\",\n    )\n    return {\"job_id\": job_id, \"status\": \"pending\", \"poll_url\": f\"/v1/jobs/{job_id}\"}\n\n@router.get(\"/{job_id}\")\nasync def get_job(job_id: str, auth: dict = Depends(get_current_user)):\n    \"\"\"Poll job status. Returns result when completed.\"\"\"\n    job = await fetch_job(job_id)\n    if not job:\n        raise HTTPException(404, \"Job not found\")\n    if job[\"user_id\"] != auth[\"sub\"]:\n        raise HTTPException(404, \"Job not found\")  # 404, not 403 \u2014 no resource enumeration\n    return job\n\n@router.delete(\"/{job_id}\", status_code=204)\nasync def cancel_job(job_id: str, auth: dict = Depends(get_current_user)):\n    \"\"\"Cancel a pending job. Running jobs cannot be cancelled.\"\"\"\n    job = await fetch_job(job_id)\n    if not job or job[\"user_id\"] != auth[\"sub\"]:\n        raise HTTPException(404, \"Job not found\")\n    if job[\"status\"] not in (\"pending\", \"retrying\"):\n        raise HTTPException(409, f\"Cannot cancel job in state: {job['status']}\")\n    celery_app.control.revoke(job_id, terminate=False)\n    await update_job_status(job_id, \"dead\")\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Retry and Dead-Letter Handling"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "LLM APIs fail transiently (network blips, 529 overloaded). Design retry with "
          },
          {
            "type": "text",
            "text": "exponential back-off",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " and a dead-letter queue for exhausted jobs:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "@celery_app.task(\n    bind=True,\n    max_retries=3,\n    queue=\"llm\",\n)\ndef run_rag_pipeline(self, job_id: str, user_id: str, document_ids: list[str]):\n    from anthropic import APIStatusError\n\n    try:\n        result = _run_rag_sync(document_ids)\n        write_job_result(job_id, result)\n        return result\n    except APIStatusError as exc:\n        if exc.status_code in (429, 529):\n            # Transient \u2014 retry with exponential back-off\n            delay = 30 * (2 ** self.request.retries)  # 30s, 60s, 120s\n            raise self.retry(exc=exc, countdown=delay)\n        # Non-transient (400 bad request, 401 auth) \u2014 fail immediately\n        update_job_status(job_id, \"failed\", error=str(exc))\n        raise\n    except Exception as exc:\n        if self.request.retries < self.max_retries:\n            raise self.retry(exc=exc, countdown=30)\n        # All retries exhausted \u2192 mark dead and send to DLQ topic\n        update_job_status(job_id, \"dead\", error=str(exc))\n        notify_dead_letter(job_id, user_id, exc)\n\ndef notify_dead_letter(job_id: str, user_id: str, exc: Exception):\n    \"\"\"Log and optionally alert ops team.\"\"\"\n    import logging\n    logging.error(\"Job %s exhausted retries: %s\", job_id, exc, extra={\"job_id\": job_id})\n    # Publish to a monitoring queue or PagerDuty here\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Webhook Result Delivery"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Instead of polling, let workers push results to a client-supplied callback URL:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import httpx\n\nasync def deliver_webhook(job: dict) -> None:\n    callback_url = job[\"payload\"].get(\"callback_url\")\n    if not callback_url:\n        return\n\n    payload = {\n        \"job_id\":   job[\"id\"],\n        \"status\":   job[\"status\"],\n        \"result\":   job.get(\"result\"),\n        \"error\":    job.get(\"error\"),\n    }\n    # Sign the payload so the receiver can verify authenticity\n    signature = hmac.new(WEBHOOK_SECRET.encode(), json.dumps(payload).encode(), \"sha256\").hexdigest()\n\n    async with httpx.AsyncClient(timeout=10) as client:\n        try:\n            resp = await client.post(\n                callback_url,\n                json=payload,\n                headers={\"X-Signature-SHA256\": signature},\n            )\n            resp.raise_for_status()\n        except Exception as exc:\n            logging.warning(\"Webhook delivery failed for job %s: %s\", job[\"id\"], exc)\n            # Queue a retry for webhook delivery (separate from job retry)\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Worker Scaling and Concurrency"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Concurrency cap: "
                  },
                  {
                    "type": "text",
                    "text": "set worker_prefetch_multiplier=1 in Celery (or max_jobs in ARQ) \u2014 LLM calls are slow and CPU-light; high prefetch bloats memory without throughput gain.",
                    "marks": [
                      {
                        "type": "italic"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Separate queues: "
                  },
                  {
                    "type": "text",
                    "text": "run a 'llm' queue (slow tasks) and a 'fast' queue (webhooks, status updates) so a flood of summarise jobs doesn't block status polling.",
                    "marks": [
                      {
                        "type": "italic"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Horizontal scaling: "
                  },
                  {
                    "type": "text",
                    "text": "add worker pods independently of the API server. Workers are stateless; scale on queue depth metric in Kubernetes (KEDA with Redis queue length).",
                    "marks": [
                      {
                        "type": "italic"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Result TTL: "
                  },
                  {
                    "type": "text",
                    "text": "set expires_at on jobs (e.g. 24h for completed, 7d for dead) and run a daily cleanup to prevent Postgres from growing unboundedly.",
                    "marks": [
                      {
                        "type": "italic"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Idempotency: "
                  },
                  {
                    "type": "text",
                    "text": "if the same document is submitted twice, deduplicate by content hash in payload before enqueuing to avoid double-charging tokens.",
                    "marks": [
                      {
                        "type": "italic"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Testing Background Workers"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import pytest\nfrom unittest.mock import patch, MagicMock\n\ndef test_summarise_task_success():\n    mock_response = MagicMock()\n    mock_response.content = [MagicMock(text=\"Summary here.\")]\n    mock_response.usage.input_tokens  = 500\n    mock_response.usage.output_tokens = 80\n\n    with patch(\"workers.tasks.client.messages.create\", return_value=mock_response),          patch(\"workers.tasks.update_job_status\")                               as mock_status,          patch(\"workers.tasks.write_job_result\")                                as mock_result:\n\n        result = summarise_document.apply(\n            kwargs={\"job_id\": \"job-1\", \"user_id\": \"u1\",\n                    \"document_text\": \"A long doc.\", \"model\": \"claude-haiku-4-5-20251001\"}\n        ).get(timeout=5)\n\n        mock_status.assert_called_with(\"job-1\", \"running\", attempt=1)\n        mock_result.assert_called_once()\n        assert result[\"summary\"] == \"Summary here.\"\n\ndef test_summarise_task_retries_on_429():\n    from anthropic import APIStatusError\n    from httpx import Request, Response\n\n    error = APIStatusError(\"rate_limited\", request=Request(\"POST\", \"/\"), response=Response(429))\n    with patch(\"workers.tasks.client.messages.create\", side_effect=error):\n        task = summarise_document.apply(\n            kwargs={\"job_id\": \"job-2\", \"user_id\": \"u1\",\n                    \"document_text\": \"Doc.\", \"model\": \"claude-haiku-4-5-20251001\"}\n        )\n        # Task should retry, eventually raising after max_retries\n        with pytest.raises(Exception):\n            task.get(timeout=5)\n"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Background workers are the right abstraction whenever an LLM call might outlast a comfortable HTTP timeout. Design the state machine first (pending \u2192 running \u2192 completed/failed/dead), expose it clearly via a polling API and optional webhooks, and let the queue absorb burst load that would otherwise topple your API server."
              }
            ]
          }
        ]
      }
    ]
  }
}