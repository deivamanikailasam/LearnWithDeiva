          {
            "type": "text",
            "text": "Curriculum for Instruction Fine-Tuning"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "In supervised fine-tuning (SFT) on instruction-following datasets, curriculum ordering can improve reasoning skill acquisition. The simplest proxy for task difficulty is the number of reasoning steps in the response, or the response length for chain-of-thought tasks."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def estimate_task_difficulty(instruction: str, response: str) -> float:\n    \"\"\"\n    Estimate difficulty of an instruction-following example.\n    Combines multiple proxies into a single difficulty score.\n    \"\"\"\n    # Proxy 1: response length (longer responses = more complex tasks)\n    length_score = min(1.0, len(response.split()) / 500)\n\n    # Proxy 2: number of reasoning steps (count 'Step N:' or '\\n' delimited logic)\n    import re\n    step_count = len(re.findall(r'(?i)(step \\d|therefore|thus|hence|because)', response))\n    step_score = min(1.0, step_count / 10)\n\n    # Proxy 3: instruction complexity (number of distinct verbs / requirements)\n    import re as _re\n    verb_count = len(_re.findall(r'\\b(analyse|compare|derive|prove|implement|design|evaluate)\\b',\n                                  instruction.lower()))\n    complexity_score = min(1.0, verb_count / 5)\n\n    # Weighted combination\n    return 0.4 * length_score + 0.4 * step_score + 0.2 * complexity_score\n\n\ndef sort_sft_dataset(dataset: list[dict],\n                      instruction_field: str = 'instruction',\n                      response_field: str = 'output') -> list[dict]:\n    \"\"\"Return dataset sorted from easy to hard.\"\"\"\n    scored = [\n        (estimate_task_difficulty(item[instruction_field], item[response_field]), item)\n        for item in dataset\n    ]\n    scored.sort(key=lambda x: x[0])\n    return [item for _, item in scored]"
          }
        ]
