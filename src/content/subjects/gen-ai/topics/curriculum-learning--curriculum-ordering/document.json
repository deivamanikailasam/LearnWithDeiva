      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Competence-Based Curriculum"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The simplest and most studied form: sort the training set by difficulty and train on sorted batches. Competence function "
          },
          {
            "type": "inlineMath",
            "attrs": {
              "latex": "c(t)"
            }
          },
          {
            "type": "text",
            "text": " controls the fraction of the sorted dataset available at training step "
          },
          {
            "type": "inlineMath",
            "attrs": {
              "latex": "t"
            }
          },
          {
            "type": "text",
            "text": ":"
          }
        ]
      },
      {
        "type": "blockMath",
        "attrs": {
          "latex": "c(t) = \\min\\!\\left(1,\\, c_0 + (1 - c_0) \\cdot \\left(\\frac{t}{T}\\right)^\\lambda\\right)"
        }
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "where "
          },
          {
            "type": "inlineMath",
            "attrs": {
              "latex": "c_0"
            }
          },
          {
            "type": "text",
            "text": " is the starting fraction (e.g. 0.2 = easiest 20%), "
          },
          {
            "type": "inlineMath",
            "attrs": {
              "latex": "T"
            }
          },
          {
            "type": "text",
            "text": " is total steps, and "
          },
          {
            "type": "inlineMath",
            "attrs": {
              "latex": "\\lambda"
            }
          },
          {
            "type": "text",
            "text": " controls the growth rate. At each step, the current batch is sampled from the easiest "
          },
          {
            "type": "inlineMath",
            "attrs": {
              "latex": "c(t)"
            }
          },
          {
            "type": "text",
            "text": " fraction of the dataset."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import random\nimport math\nfrom torch.utils.data import Sampler\n\nclass CurriculumSampler(Sampler):\n    \"\"\"\n    DataLoader sampler that implements competence-based curriculum.\n    Assumes the dataset is pre-sorted from easy (index 0) to hard.\n    \"\"\"\n    def __init__(self, dataset_size: int, total_steps: int,\n                  c0: float = 0.2, lam: float = 2.0,\n                  batch_size: int = 32):\n        self.n          = dataset_size\n        self.T          = total_steps\n        self.c0         = c0\n        self.lam        = lam\n        self.batch_size = batch_size\n        self.step       = 0\n\n    def competence(self) -> float:\n        t = self.step / self.T\n        return min(1.0, self.c0 + (1 - self.c0) * (t ** self.lam))\n\n    def __iter__(self):\n        while True:\n            c   = self.competence()\n            n_available = max(self.batch_size, int(c * self.n))\n            batch = random.sample(range(n_available), self.batch_size)\n            yield from batch\n            self.step += 1\n            if self.step >= self.T:\n                break\n\n    def __len__(self):\n        return self.T * self.batch_size"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Empirical finding (Platanios et al. 2019):",
                "marks": [
                  {
                    "type": "bold"
                  }
                ]
              },
              {
                "type": "text",
                "text": " Setting "
              },
              {
                "type": "inlineMath",
                "attrs": {
                  "latex": "c_0 = 0.01"
                }
              },
              {
                "type": "text",
                "text": " (start with 1% of data) and "
              },
              {
                "type": "inlineMath",
                "attrs": {
                  "latex": "\\lambda = 2"
                }
              },
              {
                "type": "text",
                "text": " (square-root growth) consistently outperforms random ordering on NLP sequence-to-sequence tasks by 2–5 BLEU points, with no increase in total compute."
              }
            ]
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Self-Paced Learning"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Self-paced learning (Kumar et al. 2010) inverts the control: instead of pre-sorting by a fixed scorer, the model selects its own curriculum based on current training loss. At each step, only examples below a loss threshold "
          },
          {
            "type": "inlineMath",
            "attrs": {
              "latex": "\\\\tau"
            }
          },
          {
            "type": "text",
            "text": " are selected; "
          },
          {
            "type": "inlineMath",
            "attrs": {
              "latex": "\\\\tau"
            }
          },
          {
            "type": "text",
            "text": " grows over training:"
          }
        ]
      },
      {
        "type": "blockMath",
        "attrs": {
          "latex": "\\\\mathcal{L}_{\\\\text{SPL}}(\\\\mathbf{w}, v, \\\\tau) = \\\\sum_i v_i L(x_i, \\\\mathbf{w}) - \\\\tau \\\\sum_i v_i"
        }
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "where "
          },
          {
            "type": "inlineMath",
            "attrs": {
              "latex": "v_i \\\\in \\\\{0,1\\\\}"
            }
          },
          {
            "type": "text",
            "text": " is the selection variable and "
          },
          {
            "type": "inlineMath",
            "attrs": {
              "latex": "\\\\tau"
            }
          },
          {
            "type": "text",
            "text": " acts as a regulariser controlling the pace. Minimising over "
          },
          {
            "type": "inlineMath",
            "attrs": {
              "latex": "v_i"
            }
          },
          {
            "type": "text",
            "text": " gives the closed form: select example "
          },
          {
            "type": "inlineMath",
            "attrs": {
              "latex": "i"
            }
          },
          {
            "type": "text",
            "text": " if and only if "
          },
          {
            "type": "inlineMath",
            "attrs": {
              "latex": "L(x_i, \\\\mathbf{w}) < \\\\tau"
            }
          },
          {
            "type": "text",
            "text": "."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "class SelfPacedLoader:\n    \"\"\"\n    Self-paced curriculum: select examples below a growing loss threshold.\n    At each epoch, re-score the dataset and update the threshold.\n    \"\"\"\n    def __init__(self, dataset: list[dict], initial_tau: float = 1.0,\n                  tau_growth: float = 0.1, max_tau: float = float('inf')):\n        self.dataset     = dataset\n        self.tau         = initial_tau\n        self.tau_growth  = tau_growth\n        self.max_tau     = max_tau\n        self.losses      = [float('inf')] * len(dataset)\n\n    def update_losses(self, losses: list[float]):\n        \"\"\"Call after each epoch with per-example training losses.\"\"\"\n        self.losses = losses\n\n    def select(self) -> list[dict]:\n        \"\"\"Return examples whose last training loss was below tau.\"\"\"\n        selected = [\n            item for item, loss in zip(self.dataset, self.losses)\n            if loss < self.tau\n        ]\n        # Grow tau for next epoch\n        self.tau = min(self.max_tau, self.tau + self.tau_growth)\n        return selected if selected else self.dataset[:32]  # bootstrap\n\n\ndef train_self_paced(model, dataset: list[dict],\n                      n_epochs: int = 10):\n    \"\"\"Training loop with self-paced curriculum.\"\"\"\n    import torch\n    from torch.utils.data import DataLoader\n\n    spl = SelfPacedLoader(dataset, initial_tau=0.8, tau_growth=0.15)\n    optimizer = torch.optim.AdamW(model.parameters(), lr=3e-4)\n\n    for epoch in range(n_epochs):\n        selected = spl.select()\n        loader = DataLoader(selected, batch_size=32, shuffle=True)\n        epoch_losses = {i: float('inf') for i in range(len(dataset))}\n\n        for batch in loader:\n            loss = model(**batch).loss\n            loss.backward()\n            optimizer.step()\n            optimizer.zero_grad()\n\n        # Re-compute per-example losses\n        per_example_losses = []\n        with torch.no_grad():\n            for item in dataset:\n                loss = model(**{k: v.unsqueeze(0) for k,v in item.items()}).loss.item()\n                per_example_losses.append(loss)\n        spl.update_losses(per_example_losses)\n        print(f\"Epoch {epoch}: using {len(selected)}/{len(dataset)} examples, tau={spl.tau:.2f}\")"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Domain Mixing Schedule (Pre-Training)"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For large-scale pre-training, curriculum ordering takes the form of a "
          },
          {
            "type": "text",
            "text": "domain mixing schedule",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": ": the relative weights of different data sources (web text, books, code, scientific papers) change across training. This is used in Llama 2 (77% web / 13% code / 10% books), Phi-1 (100% textbook-quality code), and Falcon (predominantly refined web)."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Upsampling high-quality sources late in training"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A common pattern: use a broad mixture of web-scale data early (for language model breadth) then shift to higher-quality, more curated sources in the final 10–20% of training tokens. This has been shown to improve downstream benchmark performance without degrading perplexity:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass\nfrom typing import Optional\n\n@dataclass\nclass DomainSource:\n    name: str\n    dataset: list          # iterable of examples\n    weight: float = 1.0    # current sampling weight\n\nclass MixingScheduler:\n    \"\"\"\n    Time-varying domain mixing scheduler.\n    Adjusts domain weights at specified training checkpoints.\n    \"\"\"\n    def __init__(self, sources: list[DomainSource],\n                  schedule: list[tuple[float, dict[str, float]]]):\n        \"\"\"\n        schedule: list of (fraction_of_training, {domain_name: weight})\n        Example: [(0.0, {'web': 0.7, 'books': 0.2, 'code': 0.1}),\n                  (0.8, {'web': 0.3, 'books': 0.3, 'code': 0.4})]\n        \"\"\"\n        self.sources = {s.name: s for s in sources}\n        self.schedule = sorted(schedule, key=lambda x: x[0])\n\n    def update_weights(self, fraction_done: float):\n        \"\"\"Update domain weights based on current training progress.\"\"\"\n        # Find the last schedule entry that applies\n        current_weights = self.schedule[0][1]\n        for frac, weights in self.schedule:\n            if frac <= fraction_done:\n                current_weights = weights\n\n        for name, weight in current_weights.items():\n            if name in self.sources:\n                self.sources[name].weight = weight\n\n    def sample_batch(self, batch_size: int) -> list:\n        \"\"\"Sample a batch according to current weights.\"\"\"\n        import random\n        names   = list(self.sources.keys())\n        weights = [self.sources[n].weight for n in names]\n        total   = sum(weights)\n        probs   = [w / total for w in weights]\n\n        batch = []\n        for _ in range(batch_size):\n            src_name = random.choices(names, weights=probs)[0]\n            src = self.sources[src_name]\n            batch.append(random.choice(src.dataset))\n        return batch\n\n\n# Example schedule: shift from broad web to quality code\nschedule = [\n    (0.0,  {'web': 0.70, 'books': 0.20, 'code': 0.10}),\n    (0.50, {'web': 0.50, 'books': 0.25, 'code': 0.25}),\n    (0.80, {'web': 0.20, 'books': 0.30, 'code': 0.50}),\n]"
          }
        ]
