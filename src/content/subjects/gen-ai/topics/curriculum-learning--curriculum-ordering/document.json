      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Perplexity-based difficulty scorer"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Score difficulty of text examples using a small reference model\n# Lower perplexity = easier for the model; higher = harder\n\nimport torch, math\nfrom transformers import AutoTokenizer, AutoModelForCausalLM\n\nclass DifficultyScorer:\n    def __init__(self, model_name: str = 'gpt2', device: str = 'cuda'):\n        self.tokenizer = AutoTokenizer.from_pretrained(model_name)\n        self.model = AutoModelForCausalLM.from_pretrained(\n            model_name, torch_dtype=torch.float16\n        ).to(device).eval()\n        self.device = device\n\n    @torch.no_grad()\n    def score(self, text: str) -> float:\n        \"\"\"Return perplexity. Higher = more difficult.\"\"\"\n        enc = self.tokenizer(text, return_tensors='pt',\n                              truncation=True, max_length=512).to(self.device)\n        loss = self.model(**enc, labels=enc['input_ids']).loss\n        return math.exp(loss.item())\n\n    def score_dataset(self, examples: list[str],\n                       batch_size: int = 32) -> list[float]:\n        scores = []\n        for i in range(0, len(examples), batch_size):\n            batch = examples[i:i+batch_size]\n            scores.extend([self.score(ex) for ex in batch])\n        return scores\n\n\ndef build_curriculum(dataset: list[dict],\n                      scorer: DifficultyScorer,\n                      text_field: str = 'text') -> list[dict]:\n    \"\"\"Sort dataset from easy (low perplexity) to hard (high perplexity).\"\"\"\n    texts  = [item[text_field] for item in dataset]\n    scores = scorer.score_dataset(texts)\n    ranked = sorted(zip(scores, dataset), key=lambda x: x[0])\n    for score, item in ranked:\n        item['difficulty'] = score\n    return [item for _, item in ranked]"
          }
        ]
      },
      {
        "type": "horizontalRule"
