      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Idempotency Keys for Client-Side Dedup"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Request deduplication can also be driven by the client: the client sends an idempotency key with each request. The server uses the key \u2014 not a content hash \u2014 to identify duplicates. This is the pattern used by payment APIs and is useful when clients retry on network failure and the same logical request may arrive twice:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio, time\nimport redis.asyncio as aioredis\nfrom fastapi import FastAPI, Header, HTTPException\nfrom pydantic import BaseModel\n\nredis_client = aioredis.Redis(host=\"localhost\", port=6379)\napp = FastAPI()\n\nclass ChatRequest(BaseModel):\n    messages: list[dict]\n    model: str = \"gpt-4o-mini\"\n\n@app.post(\"/v1/chat\")\nasync def chat(\n    req: ChatRequest,\n    idempotency_key: str = Header(default=None),\n) -> dict:\n    if idempotency_key:\n        cache_key = f\"idem:{idempotency_key}\"\n        cached = await redis_client.get(cache_key)\n        if cached:\n            import json\n            return {**json.loads(cached), \"idempotent_replay\": True}\n\n    result = await _llm_call(req.model, req.messages, temperature=0.0)\n\n    if idempotency_key:\n        await redis_client.setex(cache_key, 86400, json.dumps(result))  # 24h\n\n    return result"
          }
        ]
      },
