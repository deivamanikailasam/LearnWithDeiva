al processing\""}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tuned via hyperparameters"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"128, 64, or 32 neurons"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output Layer"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Produces final prediction/classification"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Binary: 1 neuron<br>Multi-class: = # classes"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"10 neurons for 10-class classification"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"[sciencedirect](https://www.sciencedirect.com/topics/computer-science/multilayer-perceptron)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Visual structure:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Input Layer     Hidden Layer 1    Hidden Layer 2    Output Layer\n   (x₁)      →      (h₁)        →      (h₂)        →      (y)\n   (x₂)      →      (h₁)        →      (h₂)        →      (y)\n   ...       →       ...         →       ...         →      ...\n   (xₙ)      →      (h₁)        →      (h₂)        →      (y)"}]},{"type":"paragraph","content":[{"type":"text","text":"Every neuron connects to "},{"type":"text","marks":[{"type":"bold"}],"text":"every"},{"type":"text","text":" neuron in the next layer (fully connected)."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How MLP Works: The Process"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 1: Forward Propagation (Forward Pass)"}]},{"type":"paragraph","content":[{"type":"text","text":"[youtube](https://www.youtube.com/watch?v=zGvPiaXvU9M)"}]},{"type":"paragraph","content":[{"type":"text","text":"Data flows through the network layer by layer:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Input enters"},{"type":"text","text":": Raw data (features, pixels, etc.) enters input layer"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Weighted sum"},{"type":"text","text":": Each input multiplied by weights, bias added:"}]}]}]},{"type":"blockMath","attrs":{"latex":"z = \\mathbf{w} \\cdot \\mathbf{x} + b"}},{"type":"paragraph","content":[{"type":"text","text":"\n3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Activation applied"},{"type":"text","text":": Non-linear function (ReLU, sigmoid, tanh) transforms "},{"type":"inlineMath","attrs":{"latex":"z"}},{"type":"text","text":" into activation: \\[ a = \\phi(z) \\]\n4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Pass to next layer"},{"type":"text","text":": Activation becomes input for next layer\n5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Repeat"},{"type":"text","text":": Until output layer produces prediction"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key point"},{"type":"text","text":": Information moves in "},{"type":"text","marks":[{"type":"bold"}],"text":"one direction only"},{"type":"text","text":" (input → output)."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 2: Calculate Loss (Error)"}]},{"type":"paragraph","content":[{"type":"text","text":"After forward pass:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Compare MLP output to "},{"type":"text","marks":[{"type":"bold"}],"text":"true label"},{"type":"text","text":" (actual value)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Compute "},{"type":"text","marks":[{"type":"bold"}],"text":"loss"},{"type":"text","text":" = difference between predicted and actual:"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"- Binary classification: Binary cross-entropy - Multi-class: Categorical cross-entropy - Regression: Mean Squared Error (MSE)\n3. Goal: "},{"type":"text","marks":[{"type":"bold"}],"text":"Minimize this loss"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Step 3: Backpropagation (Backward Pass)"}]},{"type":"paragraph","content":[{"type":"text","text":"[sciencedirect](https://www.sciencedirect.com/topics/computer-science/multilayer-perceptron)"}]},{"type":"paragraph","content":[{"type":"text","text":"The network \"learns\" by adjusting weights:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Compute gradients"},{"type":"text","text":": Calculate derivative of loss w.r.t. each weight"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Propagate backward"},{"type":"text","text":": Error signal travels backward through layers"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Update weights"},{"type":"text","text":": Adjust weights using optimizer (SGD, Adam):"}]}]}]},{"typ