span": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Small image datasets"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Effective for simpler image tasks"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Binary/multi-class classification"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Maps to probabilities"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Regression tasks"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Predicts continuous values"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Learning neural network fundamentals"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Foundation for CNNs, RNNs"}]}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Not ideal for:"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Large image datasets"}, {"type": "text", "text": ": CNNs are better (capture spatial structure)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Sequential data"}, {"type": "text", "text": ": RNNs/Transformers are better (capture temporal patterns)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Very high-dimensional data"}, {"type": "text", "text": ": Can be computationally expensive"}]}]}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Mathematical Perspective"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "An MLP executes "}, {"type": "text", "marks": [{"type": "bold"}], "text": "nonlinear approximation"}, {"type": "text", "text": ":"}]}, {"type": "blockMath", "attrs": {"latex": "f(\\mathbf{x}) = \\phi^{(L)}\\left(\\mathbf{W}^{(L)} \\cdot \\phi^{(L-1)}\\left(\\mathbf{W}^{(L-1)} \\cdots \\phi^{(1)}(\\mathbf{W}^{(1)} \\mathbf{x} + \\mathbf{b}^{(1)}) + \\mathbf{b}^{(L-1)}\\right) + \\mathbf{b}^{(L)}\\right)"}}, {"type": "paragraph", "content": [{"type": "text", "text": "Where:\n- "}, {"type": "inlineMath", "attrs": {"latex": "\\mathbf{W}^{(l)}"}}, {"type": "text", "text": " = weight matrix for layer "}, {"type": "inlineMath", "attrs": {"latex": "l"}}, {"type": "text", "text": "\n- "}, {"type": "inlineMath", "attrs": {"latex": "\\mathbf{b}^{(l)}"}}, {"type": "text", "text": " = bias vector for layer "}, {"type": "inlineMath", "attrs": {"latex": "l"}}, {"type": "text", "text": "\n- "}, {"type": "inlineMath", "attrs": {"latex": "\\phi^{(l)}"}}, {"type": "text", "text": " = activation function for layer "}, {"type": "inlineMath", "attrs": {"latex": "l"}}, {"type": "text", "text": "\n- "}, {"type": "inlineMath", "attrs": {"latex": "L"}}, {"type": "text", "text": " = total number of layers"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Key"}, {"type": "text", "text": ": Each layer applies transformation + non-linearity, building up complex functions."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Training Process Summary"}]}, {"type": "codeBlock", "attrs": {"language": "text"}, "content": [{"type": "text", "text": "1. Initialize weights (random)\n2. For each epoch:\n   a. Forward pass: Input → Output\n   b. Calculate loss: Compare output vs. true label\n   c. Backward pass: Compute gradients (backpropagation)\n   d. Update weights: SGD/Adam optimizer\n3. Repeat until convergence (loss minimized)"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Mental Model"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Think of an MLP like a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "team of experts in an assembly line"}, {"type": "text", "text": ":"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Input layer"}, {"type": "text", "text": ": Raw material arrives"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Hidden layer 1"}, {"type": "text", "text": ": Junior experts detect basic patterns (edges)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Hidden layer 2"}, {"type": "text", "text": ": Intermediate experts combine patterns (shapes)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Hidden layer 3+"}, {"type": "text", "text": ": Senior experts recognize complex features (objects)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Output layer"}, {"type": "text", "text": ": Final decision made"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Each expert (neuron) passes findings to the next, and mistakes are corrected by going backward through the team."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Key Takeaways"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "MLP"}, {"type": "text", "text": " = fully connected, feedforward neural network with input + hidden + output layers"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "At least 1 hidden layer"}, {"type": "text", "text": " required; >1 hidden layers = deep neural network"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Forward propagation"}, {"type": "text", "text": ": Data flows input → output, layer by layer"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Backpropagation"}, {"type": "text", "text": ": Error propagates backward to update weights"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Non-linear activations"}, {"type": "text", "text": " (ReLU, sigmoid) enable learning complex patterns"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Fully connected"}, {"type": "text", "text": ": Every neuron connects to all neurons in next layer"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Solves perceptron's limitation"}, {"type": "text", "text": ": Can model non-linear boundaries"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Universal approximator"}, {"type": "text", "text": ": Can learn any nonlinear input-output mapping"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Foundation of deep learning"}, {"type": "text", "text": ": BaseModel for CNNs, RNNs, Transformers"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Training"}, {"type": "text", "text": ": Supervised learning with gradient descent + backpropagation"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Understanding MLPs is essential before diving into deep learning architectures used in Generative AI (like GPT, diffusion models, etc.)."}]}]}}