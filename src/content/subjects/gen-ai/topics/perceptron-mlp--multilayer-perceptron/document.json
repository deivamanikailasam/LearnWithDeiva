\\mathbf{w} \\cdot \\mathbf{x} + b"}}, {"type": "paragraph", "content": [{"type": "text", "text": "\n3. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Activation applied"}, {"type": "text", "text": ": Non-linear function (ReLU, sigmoid, tanh) transforms "}, {"type": "inlineMath", "attrs": {"latex": "z"}}, {"type": "text", "text": " into activation: \\[ a = \\phi(z) \\]\n4. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Pass to next layer"}, {"type": "text", "text": ": Activation becomes input for next layer\n5. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Repeat"}, {"type": "text", "text": ": Until output layer produces prediction"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Key point"}, {"type": "text", "text": ": Information moves in "}, {"type": "text", "marks": [{"type": "bold"}], "text": "one direction only"}, {"type": "text", "text": " (input → output)."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Step 2: Calculate Loss (Error)"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "After forward pass:"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Compare MLP output to "}, {"type": "text", "marks": [{"type": "bold"}], "text": "true label"}, {"type": "text", "text": " (actual value)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Compute "}, {"type": "text", "marks": [{"type": "bold"}], "text": "loss"}, {"type": "text", "text": " = difference between predicted and actual:"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "- Binary classification: Binary cross-entropy - Multi-class: Categorical cross-entropy - Regression: Mean Squared Error (MSE)\n3. Goal: "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Minimize this loss"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Step 3: Backpropagation (Backward Pass)"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "[sciencedirect](https://www.sciencedirect.com/topics/computer-science/multilayer-perceptron)"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The network \"learns\" by adjusting weights:"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Compute gradients"}, {"type": "text", "text": ": Calculate derivative of loss w.r.t. each weight"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Propagate backward"}, {"type": "text", "text": ": Error signal travels backward through layers"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Update weights"}, {"type": "text", "text": ": Adjust weights using optimizer (SGD, Adam):"}]}]}]}, {"type": "blockMath", "attrs": {"latex": "w_{\\text{new}} = w_{\\text{old}} - \\alpha \\cdot \\frac{\\partial \\text{loss}}{\\partial w}"}}, {"type": "paragraph", "content": [{"type": "text", "text": "where "}, {"type": "inlineMath", "attrs": {"latex": "\\alpha"}}, {"type": "text", "text": " = learning rate\n4. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Repeat"}, {"type": "text", "text": ": Over multiple "}, {"type": "text", "marks": [{"type": "bold"}], "text": "epochs"}, {"type": "text", "text": " (training iterations)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Mental model"}, {"type": "text", "text": ": Backpropagation is like \"going back through the layers and improving yourself all the way down to the input\"."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Why MLP Matters: Solving Perceptron's Limitation"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Single Perceptron"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Multilayer Perceptron (MLP)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Only 1 neuron, no hidden layers"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Multiple neurons + hidden layers"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Linear"}, {"type": "text", "text": " decision boundary only"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Non-linear"}, {"type": "text", "text": " decision boundaries"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Fails on non-linear problems (e.g., XOR)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "c