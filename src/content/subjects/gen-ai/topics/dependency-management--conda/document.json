tps://github.com/conda-forge/miniforge"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Alternative: Install Full Anaconda"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Full distribution with many pre-installed packages\n# Download from: https://www.anaconda.com/download"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Creating Conda Environments"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Create New Environment"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Create environment with Python 3.10\nconda create -n my_env python=3.10\n\n# Create environment with specific Python version\nconda create -n py39 python=3.9\n\n# Create without specifying Python (uses latest)\nconda create -n my_env\n\n# Confirm installation\nconda create -n my_env python=3.10\n# Press 'y' to confirm"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What Gets Created"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"conda_envs/\n├── my_env/\n    ├── bin/           # Python binaries\n    ├── lib/           # Libraries\n    ├── include/       # Header files\n    ├── python         # Python interpreter\n    └── conda-meta/    # Package metadata"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Managing Conda Environments"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"List Environments"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# List all environments\nconda env list\n\n# Or\nconda info --envs\n\n# Output:\n# # conda environments:\n# #\n# base                  *  /home/user/anaconda3\n# my_env              /home/user/anaconda3/envs/my_env"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Activate Environment"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Activate environment\nconda activate my_env\n\n# Shell prefix changes\n(my_env) $ python --version\nPython 3.10.0  # Uses environment's Python"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Deactivate Environment"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Exit current environment\nconda deactivate\n\n# Returns to base environment"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Remove Environment"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Remove environment\nconda remove -n my_env --all\n\n# Or\nconda env remove -n my_env"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Installing Packages with Conda"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Install Packages"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Install package from conda-forge channel\nconda install -c conda-forge requests\n\n# Install multiple packages\nconda install numpy pandas torch\n\n# Install specific version\nconda install numpy=1.26.4\n\n# Install version range\nconda install numpy>=1.24.0"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Install from Different Channels"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Install from conda-forge (community-maintained)\nconda config --add channels conda-forge\nconda install requests\n\n# Install from Anaconda main channel\nconda install -c anaconda requests\n\n# Use strict channel priority\nconda config --set channel_priority strict"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Update Packages"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Update specific package\nconda update numpy\n\n# Update all packages\nconda update --all\n\n# Show outdated packages\nconda list --outdated"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Remove Packages"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Remove single package\nconda remove numpy\n\n# Remove multiple packages\nconda remove numpy pandas\n\n# Remove with confirmation skip\nconda remove numpy --yes"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Managing Python Versions with Conda"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Install Different Python Versions"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Install Python 3.9 in new environment\nconda create -n py39 python=3.9\n\n# Install Python 3.11 in new environment\nconda create -n py311 python=3.11\n\n# Switch between environments\nconda activate py39\npython --version  # Python 3.9\n\nconda activate py311\npython --version  # Python 3.11"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Update Python in Environment"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# Update to latest Python version\nconda update python\n\n# Stay on specific minor version\nconda install python=3.10"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"code"}],"text":"environment.yml"},{"type":"text","text":" File"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What is "},{"type":"text","marks":[{"type":"code"}],"text":"environment.yml"},{"type":"text","text":"?"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"environment.yml"},{"type":"text","text":" is a "},{"type":"text","marks":[{"type":"bold"}],"text":"configuratio