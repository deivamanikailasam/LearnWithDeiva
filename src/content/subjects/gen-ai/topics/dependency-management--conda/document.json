ges (most dependencies)\nconda install numpy pandas torch\n\n# 4. Install pip packages (only conda-unavailable)\npip install requests python-dotenv"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Why:"},{"type":"text","text":" Conda handles binary dependencies better; use pip for conda-unavailable packages only."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Complete Workflow Example"}]},{"type":"codeBlock","attrs":{"language":"bash"},"content":[{"type":"text","text":"# 1. Create environment with Python 3.10\nconda create -n my_ai_env python=3.10\n\n# 2. Activate environment\nconda activate my_ai_env\n\n# 3. Install ML packages\nconda install numpy pandas torch transformers\n\n# 4. Install pip packages\npip install requests python-dotenv\n\n# 5. Export environment\nconda env export --no-builds > environment.yml\n\n# 6. On another machine\nconda env create -f environment.yml\nconda activate my_ai_env\n\n# 7. Verify installation\npython --version\nconda list"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Recommendation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use Conda"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Data science, ML, scientific computing"}]}]}]},{"type":"t