us segments"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Movement"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Independent or converge"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Right expands, left contracts"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Complexity"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n) single pass"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n) single pass"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Gen AI Applications ⭐"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Sliding Window Attention (LLMs)"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Sliding Window Attention: Process long sequences efficiently\ndef sliding_window_attention(tokens, window_size=128):\n    result = []\n    \n    for i in range(len(tokens)):  # ✅ Expand right\n        start = max(0, i - window_size + 1)  # ✅ Contract left\n        window = tokens[start:i + 1]  # ✅ Bounded window [web:249][web:255]\n        \n        attention = compute_attention(window)  # ✅ O(window_size) per token\n        result.append(attention)\n    \n    return result  # ✅ Efficient attention [web:249]\n\nsliding_window_attention(token_ids, window_size=128)  # ✅ Handles long contexts [web:249][web:255]\n# Time: O(n × window_size), Space: O(window_size) [web:249][web:255]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Token Duplicate Detection (Two Pointers)"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Two Pointers: Detect duplicates in sorted token IDs\ndef find_duplicate_tokens(sorted_token_ids):\n    left, right = 0, len(sorted_token_ids) - 1  # ✅ Opposite direction\n    duplicates = []\n    \n    while left < right:\n        if sorted_token_ids[left] == sorted_token_ids[right]:\n            duplicates.append(sorted_token_ids[left])\n            left += 1\n            right -= 1\n        elif sorted_token_ids[left] < sorted_token_ids[right]:\n            left += 1\n        else:\n            right -= 1\n    \n    return duplicates  # ✅ Duplicates found\n\nfind_duplicate_tokens([1, 1, 2, 3, 3, 4])  # ✅ [1, 3] [web:250][web:257]\n# Time: O(n), Space: O(d) [web:250]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"NLP Context Window Extraction (Sliding Window)"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Sliding Window: Extract context windows for NLP\ndef extract_context_windows(text, window_chars=500):\n    windows = []\n    left = 0\n    \n    for right in range(len(text)):  # ✅ Expand right\n        if right - left + 1 >= window_chars:  # ✅ Fixed window reached\n            windows.append(text[left:right + 1])  # ✅ Extract window\n            left += 1  # ✅ Contract left [web:249][web:255]\n    \n    return windows  # ✅ Context windows [web:249][web:255]\n\nextract_context_windows(\"Long article about AI...\", window_chars=500)  # ✅ Overlapping windows [web:249]\n# Time: O(n), Space: O(n / window_chars) [web:249][web:255]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Problem-Solving Pattern Recognition"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Identify Two Pointers ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Pattern clues:\n# - \"Sorted array\" + \"Find pair with sum X\" → Opposite direction [web:248][web:250]\n# - \"Remove duplicates\" + \"In-place\" → Fast/slow [web:248][web:250]\n# - \"Palindrome\" + \"Check symmetry\" → Opposite direction [web:248][web:250]\n# - \"Merge two sorted arrays\" → Independent pointers [web:248]\n\n# Example:\nproblem = \"Given sorted array, find pair with sum = target\"\n# → Two Pointers (opposite direction) [web:248][web:250]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Identify Sliding Window ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Pattern clues:\n# - \"Substring/Subarray\" + \"Contiguous\" → Sliding window [web:249][web:255]\n# - \"Max/Min length\" + \"With constraint\" → Variable window [web:249][web:255]\n# - \"Sum/Average of K consecutive\" → Fixed window [web:249][web:252]\n# - \"At-most K distinct\" → Variable window (at-most logic) [web:256]\n\n# Example:\nproblem = \"Longest substring without repeating characters\"\n# → Sliding Window (variable, expand/contract on duplicate) [web:249][web:255]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Common Pitfalls ⭐"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Pitfall"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Fix"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Two Pointers: Wrong direction"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use opposite for sorted pairs, same for in-place"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Two Pointers: Missing edge case"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Check left == right, handle empty array"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sliding Window: Resetting window"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Don't recompute sum, use O(1) update (add - remove)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sliding Window: Wrong contraction"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Contract only when condition violated, not every iteration"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sliding Window: Off-by-one"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use "},{"type":"text","marks":[{"type":"code"}],"text":"right - left + 1"},{"type":"text","text":" for length, not "},{"type":"text","marks":[{"type":"code"}],"text":"right - left"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Two Pointers"},{"type":"text","text":": Two indices for sorted arrays, pairs, palindromes"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sliding Window"},{"type":"text","text":": Bounded segment for substrings/subarrays"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Fixed vs Variable"},{"type":"text","text":": Fixed size k vs expand/contract on condition"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"O(n) efficiency"},{"type":"text","text":": Single pass replaces nested loops"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Gen AI uses"},{"type":"text","text":": Sliding window attention (LLMs), token duplicate detection, NLP context windows"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pattern recognition"},{"type":"text","text":": \"Sorted + pair\" → Two Pointers, \"Substring + constraint\" → Sliding Window"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Since you're a full-stack engineer working on Gen AI, two pointers and sliding window patterns are essential for implementing "},{"type":"text","marks":[{"type":"bold"}],"text":"sliding window attention"},{"type":"text","text":" in LLMs (efficient long-sequence processing), "},{"type":"text","marks":[{"type":"bold"}],"text":"token duplicate detection"},{"type":"text","text":" (finding repeated token IDs in sorted arrays), and "},{"type":"text","marks":[{"type":"bold"}],"text":"NLP context window extraction"},{"type":"text","text":" (extracting overlapping text segments for processing). Master opposite-direction two pointers for sorted pair problems and variable sliding window for substring constraint problems."}]}]}}
