dow"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Size k, shift one step each iteration"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Max sum of k consecutive, average"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Variable Window"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Expand right, contract left on condition"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Longest substring without repeating"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Window Update"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Add incoming, remove outgoing"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(1) update vs recompute"}]}]}]}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Template: Fixed Window ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Sliding Window: Fixed size k\ndef max_sum_fixed_window(arr, k):\n    max_sum = 0\n    current_sum = sum(arr[:k])  # ✅ Initial window sum [web:249][web:252]\n    max_sum = current_sum\n    \n    for i in range(k, len(arr)):  # ✅ Slide window\n        current_sum = current_sum - arr[i - k] + arr[i]  # ✅ O(1) update [web:255]\n        max_sum = max(max_sum, current_sum)\n    \n    return max_sum  # ✅ Maximum sum [web:249]\n\nmax_sum_fixed_window([1, 4, 2, 10, 5, 3], 3)  # ✅ 17 (10+5+3) [web:249][web:252]\n# Time: O(n), Space: O(1) [web:249][web:255]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Template: Variable Window ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Sliding Window: Variable size (expand/contract)\ndef longest_substring_no_repeating(s):\n    left = 0\n    max_length = 0\n    char_set = set()  # ✅ Track characters in window [web:249][web:255]\n    \n    for right in range(len(s)):  # ✅ Expand right\n        while s[right] in char_set:  # ✅ Contract if duplicate\n            char_set.remove(s[left])\n            left += 1  # ✅ Shrink from left [web:249][web:255]\n        \n        char_set.add(s[right])  # ✅ Add to window\n        max_length = max(max_length, right - left + 1)  # ✅ Update max [web:249]\n    \n    return max_length  # ✅ Longest substring [web:249]\n\nlongest_substring_no_repeating(\"abcabcbb\")  # ✅ 3 (\"abc\") [web:250]\n# Time: O(n), Space: O(k) [web:249][web:255]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Interview Problems ⭐"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Problem"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Pattern"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Solution"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":