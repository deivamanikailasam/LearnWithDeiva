    "content": [
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Async/Await for LLM Calls"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "An LLM call is almost entirely "
          },
          {
            "type": "text",
            "text": "I/O wait",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": ": the CPU sends an HTTP request, then sits idle for 2\u201320 seconds while the model generates tokens. Sequential code wastes this idle time; asyncio's event loop runs other coroutines while one LLM call waits for its response."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Async concurrency: sequential vs gather, and the asyncio event loop cycle",
          "title": null
        }
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "AsyncAnthropic Client"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The Anthropic Python SDK ships two clients: "
          },
          {
            "type": "text",
            "text": "Anthropic",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " (synchronous) and "
          },
          {
            "type": "text",
            "text": "AsyncAnthropic",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " (async). Use AsyncAnthropic in FastAPI and any async context:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from anthropic import AsyncAnthropic\n\n# Module-level singleton \u2014 created once, reused across requests.\n# AsyncAnthropic manages its own httpx.AsyncClient connection pool internally.\nclient = AsyncAnthropic()   # reads ANTHROPIC_API_KEY from environment\n\nasync def single_llm_call(prompt: str, model: str = \"claude-haiku-4-5-20251001\") -> str:\n    response = await client.messages.create(\n        model=model,\n        max_tokens=512,\n        messages=[{\"role\": \"user\", \"content\": prompt}],\n    )\n    return response.content[0].text\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Concurrent Calls with asyncio.gather"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When you need results from N independent LLM calls, "
          },
          {
            "type": "text",
            "text": "asyncio.gather",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " runs them concurrently. Total wall-clock time equals the "
          },
          {
            "type": "text",
            "text": "slowest single call",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": ", not the sum of all calls:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\n\nasync def parallel_summaries(documents: list[str]) -> list[str]:\n    \"\"\"Summarise all documents concurrently. Returns results in the same order.\"\"\"\n    tasks = [\n        client.messages.create(\n            model=\"claude-haiku-4-5-20251001\",\n            max_tokens=256,\n            messages=[{\"role\": \"user\", \"content\": f\"Summarise:\\n{doc}\"}],\n        )\n        for doc in documents\n    ]\n    responses = await asyncio.gather(*tasks)\n    return [resp.content[0].text for resp in responses]\n\n# 3 calls, each taking ~3s \u2192 total wall-clock \u2248 3s, not 9s\nresults = await parallel_summaries([\"doc 1\", \"doc 2\", \"doc 3\"])\n"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Error Isolation with return_exceptions"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "By default, if any task in "
          },
          {
            "type": "text",
            "text": "asyncio.gather",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " raises, the exception propagates immediately and remaining tasks are cancelled. Pass "
          },
          {
            "type": "text",
            "text": "return_exceptions=True",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " to collect both results and exceptions:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "async def parallel_with_errors(documents: list[str]) -> list[str | None]:\n    tasks = [\n        client.messages.create(\n            model=\"claude-haiku-4-5-20251001\",\n            max_tokens=256,\n            messages=[{\"role\": \"user\", \"content\": f\"Summarise:\\n{doc}\"}],\n        )\n        for doc in documents\n    ]\n    results = await asyncio.gather(*tasks, return_exceptions=True)\n    return [\n        resp.content[0].text if not isinstance(resp, Exception) else None\n        for resp in results\n    ]\n"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Semaphore: Bounding Concurrency"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Sending 500 LLM calls simultaneously will hit Anthropic's per-minute rate limit. A "
          },
          {
            "type": "text",
            "text": "semaphore",
            "marks": [
              {
                "type": "bold"
              }
            ]
          },
          {
            "type": "text",
            "text": " caps how many calls are in-flight at once:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import asyncio\n\n# Allow at most 10 concurrent LLM calls\n_sem = asyncio.Semaphore(10)\n\nasync def bounded_llm_call(prompt: str) -> str:\n    async with _sem:\n        response = await client.messages.create(\n            model=\"claude-haiku-4-5-20251001\",\n            max_tokens=256,\n            messages=[{\"role\": \"user\", \"content\": prompt}],\n        )\n    return response.content[0].text\n\nasync def process_batch(prompts: list[str]) -> list[str]:\n    \"\"\"Process 500 prompts with max 10 in-flight. Respects rate limits.\"\"\"\n    return await asyncio.gather(*[bounded_llm_call(p) for p in prompts])\n"
          }
        ]
      },
