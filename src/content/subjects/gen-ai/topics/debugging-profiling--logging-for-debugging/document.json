 "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "More complex than print"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Requires setup (logger, handlers, formatters)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Overhead"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "~1-5% slower than no logging (minimal)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Configuration needed"}, {"type": "text", "text": ": Need to set up logging levels, file paths"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": " "}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Not for quick scripts"}, {"type": "text", "text": ": Simple scripts don't need logging"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": " "}]}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "How it works — Underlying mechanics"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Three main components:"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Logger"}, {"type": "text", "text": ": The object you call methods on ("}, {"type": "text", "marks": [{"type": "code"}], "text": "logger.debug()"}, {"type": "text", "text": ", "}, {"type": "text", "marks": [{"type": "code"}], "text": "logger.info()"}, {"type": "text", "text": ")"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Handler"}, {"type": "text", "text": ": Where logs go (console, file, email)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Formatter"}, {"type": "text", "text": ": How logs look (timestamp, level, message format)"}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Logging flow:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# 1. Create logger\nlogger = logging.getLogger(__name__)\n\n# 2. Add handler (console or file)\nhandler = logging.FileHandler('app.log')  # or StreamHandler for console\n\n# 3. Set formatter (how logs look)\nformatter = logging.Formatter('%(asctime)s - %(levelname)s - %(message)s')\nhandler.setFormatter(formatter)\n\n# 4. Add handler to logger\nlogger.addHandler(handler)\n\n# 5. Set log level\nlogger.setLevel(logging.DEBUG)  # Capture all levels\n\n# 6. Log messages\nlogger.debug(\"Detailed diagnostic info\")\nlogger.info(\"Confirmation things work\")\nlogger.warning(\"Potential issue\")\nlogger.error(\"Serious problem\")\nlogger.critical(\"Program may stop\")"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "When to use it — Scenarios and decision criteria"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Use logging when:"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "✅ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Development"}, {"type": "text", "text": ": Need detailed DEBUG logs to trace execution"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "✅ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Production"}, {"type": "text", "text": ": Monitor INFO/WARNING events, capture errors"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "✅ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "AI applications"}, {"type": "text", "text": ": Track prompts, outputs, token usage for debugging"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "✅ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Long-running processes"}, {"type": "text", "text": ": Persistent logs for later analysis"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "✅ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Distributed systems"}, {"type": "text", "text": ": Centralized logging across services"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "✅ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Compliance"}, {"type": "text", "text": ": Audit logs for security/regulatory requirements"}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Use "}, {"type": "text", "marks": [{"type": "code"}], "text": "print()"}, {"type": "text", "text": " instead when:"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "❌ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Quick scripts"}, {"type": "text", "text": ": One-off scripts don't need logging overhead"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "❌ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Learning"}, {"type": "text", "text": ": Beginners can start with "}, {"type": "text", "marks": [{"type": "code"}], "text": "print()"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "❌ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Interactive CLI"}, {"type": "text", "text": ": Immediate output to user (not debugging)"}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "How to implement — Step-by-step guide"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Basic setup (recommended):"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Step 1: Import and create logger"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import logging\n\n# Create logger\nlogger = logging.getLogger(__name__)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Step 2: Configure logging"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Set up logging to console and file\nlogging.basicConfig(\n    level=logging.DEBUG,  # Capture all levels\n    format='%(asctime)s - %(levelname)s - %(message)s',\n    filename='app.log',  # Save to file\n    filemode='a'  # Append (default)\n)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Step 3: Log messages"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "logger.debug(\"Starting function\")\nlogger.info(\"Processing data\")\nlogger.warning(\"Low memory\")\nlogger.error(\"Failed to connect\")\nlogger.critical(\"System shutdown\")"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Step 4: Run"}]}, {"type": "codeBlock", "attrs": {"language": "bash"}, "content": [{"type": "text", "text": "python app.py"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Output in "}, {"type": "text", "marks": [{"type": "bold"}, {"type": "code"}], "text": "app.log"}, {"type": "text", "marks": [{"type": "bold"}], "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "text"}, "content": [{"type": "text", "text": "2026-06-22 02:55:00 - DEBUG - Starting function\n2026-06-22 02:55:01 - INFO - Processing data\n2026-06-22 02:55:02 - WARNING - Low memory\n2026-06-22 02:55:03 - ERROR - Failed to connect\n2026-06-22 02:55:04 - CRITICAL - System shutdown"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Logging with exceptions (best practice):"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import logging\n\nlogging.basicConfig(\n    level=logging.DEBUG,\n    format='%(asctime)s - %(levelname)s - %(message)s',\n    filename='app.log'\n)\n\nlogger = logging.getLogger(__name__)\n\ndef risky_operation():\n    try:\n        result = 10 / 0  # Division by zero\n    except Exception as e:\n        # Includes full stack trace\n        logger.exception(\"Operation failed\")\n        # or\n        logger.error(\"Operation failed\", exc_info=True)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Output:"}]}, {"type": "codeBlock", "attrs": {"language": "yaml"}, "content": [{"type": "text", "text": "2026-06-22 02:55:00 - ERROR - Operation failed\nTraceback (most recent call last):\n  File \"app.py\", line 10, in risky_operation\n    result = 10 / 0\nZeroDivisionError: division by zero"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Logging variable values:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import logging\n\nlogging.basicConfig(level=logging.DEBUG)\nlogger = logging.getLogger(__name__)\n\ndef process_data(items, threshold):\n    logger.debug(f\"Processing {len(items)} items with threshold {threshold}\")\n    \n    for item in items:\n        logger.debug(f\"Item: {item}, value: {item.value}\")\n        if item.value > threshold:\n            logger.info(f\"Item {item.id} exceeds threshold\")"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Examples — Simple working example"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Example 1: Debugging data pipeline"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# data_pipeline.py\nimport logging\n\nlogging.basicConfig(\n    level=logging.DEBUG,\n    format='%(asctime)s - %(levelname)s - %(message)s',\n    filename='pipeline.log'\n)\n\nlogger = logging.getLogger(__name__)\n\ndef load_data():\n    logger.info(\"Loading data from database\")\n    data = [1, 2, 3, 4, 5]\n    logger.debug(f\"Loaded {len(data)} records\")\n    return data\n\ndef transform_data(data):\n    logger.debug(\"Transforming data\")\n    transformed = [x * 2 for x in data]\n    logger.debug(f\"Transformed to {transformed}\")\n    return transformed\n\ndef save_data(data):\n    logger.info(\"Saving data to file\")\n    # Simulate save\n    logger.info(f\"Saved {len(data)} records\")\n\n# Pipeline\ndata = load_data()\ntransformed = transform_data(data)\nsave_data(transformed)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}, {"type": "code"}], "text": "pipeline.log"}, {"type": "text", "marks": [{"type": "bold"}], "text": " output:"}]}, {"type": "codeBlock", "attrs": {"language": "text"}, "content": [{"type": "text", "text": "2026-06-22 02:55:00 - INFO - Loading data from database\n2026-06-22 02:55:00 - DEBUG - Loaded 5 records\n2026-06-22 02:55:01 - DEBUG - Transforming data\n2026-06-22 02:55:01 - DEBUG - Transformed to [2, 4, 6, 8, 10]\n2026-06-22 02:55:02 - INFO - Saving data to file\n2026-06-22 02:55:02 - INFO - Saved 5 records"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Example 2: Production logging with levels"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# app.py\nimport logging\n\n# Production: only show WARNING and above\nlogging.basicConfig(\n    level=logging.WARNING,  # Production setting\n    format='%(asctime)s - %(levelname)s - %(message)s',\n    filename='app.log'\n)\n\nlogger = logging.getLogger(__name__)\n\ndef process():\n    logger.debug(\"Detailed debug info\")  # Not shown in production\n    logger.info(\"Processing started\")    # Not shown in production\n    logger.warning(\"Potential issue\")    # SHOWN\n    logger.error(\"Failed to connect\")    # SHOWN\n    logger.critical(\"System critical\")   # SHOWN\n\nprocess()"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Output (only WARNING and above):"}]}, {"type": "codeBlock", "attrs": {"language": "text"}, "content": [{"type": "text", "text": "2026-06-22 02:55:00 - WARNING - Potential issue\n2026-06-22 02:55:01 - ERROR - Failed to connect\n2026-06-22 02:55:02 - CRITICAL - System critical"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Real-world example — Generative AI audit logging"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Logging AI agent actions:"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# ai_agent.py\nimport logging\nimport json\nfrom datetime import datetime\n\n# Structured logging for AI (JSON format)\nlogging.basicConfig(\n    level=logging.INFO,\n    format='%(asctime)s - %(levelname)s - %(message)s',\n    filename='ai_agent.log'\n)\n\nlogger = logging.getLogger(__name__)\n\ndef log_agent_action(user_id, prompt, output, tokens_in, tokens_out):\n    \"\"\"Log AI agent action with audit trail\"\"\"\n    \n    log_entry = {\n        \"timestamp\": datetime.now().isoformat(),\n        \"user_id\": user_id,\n        \"prompt\": prompt,\n        \"output\": output,\n        \"tokens_input\": tokens_in,\n        \"tokens_output\": tokens_out,\n        \"total_tokens\": tokens_in + tokens_out,\n        \"cost_estimate\": (tokens_in + tokens_out) * 0.00001  # Example cost\n    }\n    \n    # JSON log for machine parsing\n    logger.info(json.dumps(log_entry))\n\ndef process_user_query(user_id, query):\n    logger.info(f\"User {user_id} started query\")\n    logger.debug(f\"Query: {query}\")  # Debug level\n    \n    # Simulate AI call\n    prompt = f\"Answer: {query}\"\n    output = \"Here is the answer based on AI analysis...\"\n    tokens_in = 100\n    tokens_out = 50\n    \n    log_agent_action(user_id, prompt, output, tokens_in, tokens_out)\n    \n    logger.info(f\"User {user_id} completed query\")\n\n# Usage\nprocess_user_query(\"user123\", \"What is quantum computing?\")"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}, {"type": "code"}], "text": "ai_agent.log"}, {"type": "text", "marks": [{"type": "bold"}], "text": " output:"}]}, {"type": "codeBlock", "attrs": {"language": "text"}, "content": [{"type": "text", "text": "2026-06-22 02:55:00 - INFO - User user123 started query\n2026-06-22 02:55:01 - INFO - {\"timestamp\": \"2026-06-22T02:55:01\", \"user_id\": \"user123\", \"prompt\": \"Answer: What is quantum computing?\", \"output\": \"Here is the answer based on AI analysis...\", \"tokens_input\": 100, \"tokens_output\": 50, \"total_tokens\": 150, \"cost_estimate\": 0.0000015}\n2026-06-22 02:55:02 - INFO - User user123 completed query"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Common mistakes — Pitfalls to avoid"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Mistake"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Correction"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Using "}, {"type": "text", "marks": [{"type": "bold"}, {"type": "code"}], "text": "print()"}, {"type": "text", "marks": [{"type": "bold"}], "text": " instead of logging"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use "}, {"type": "text", "marks": [{"type": "code"}], "text": "logging"}, {"type": "text", "text": " for production code"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Not setting log level"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use "}, {"type": "text", "marks": [{"type": "code"}], "text": "logging.basicConfig(level=logging.DEBUG)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Overusing DEBUG"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Don't log everything at DEBUG level"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Logging sensitive data"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Redact PII, passwords, tokens"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "No log rotation"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use "}, {"type": "text", "marks": [{"type": "code"}], "text": "RotatingFileHandler"}, {"type": "text", "text": " to manage disk"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Not including context"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Add user_id, request_id to logs"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Logging without stack traces"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use "}, {"type": "text", "marks": [{"type": "code"}], "text": "logger.exception()"}, {"type": "text", "text": " for errors"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Not using structured format"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use JSON for machine parsing"}]}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Best practices — Proven approaches"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "1. Use appropriate log levels"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Level"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "When to use"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Production setting"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "DEBUG"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Detailed diagnostics, variable values"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "No (dev only)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "INFO"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Confirm things work, milestones"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Yes"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "WARNING"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Potential issues, unexpected events"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Yes"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "ERROR"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Serious problems, function fails"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Yes"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "CRITICAL"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Unrecoverable errors, program stop"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Yes"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Development"}, {"type": "text", "text": ": Use DEBUG to capture execution flow\n"}, {"type": "text", "marks": [{"type": "bold"}], "text": "Production"}, {"type": "text", "text": ": Use INFO or WARNING to reduce noise"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "2. Structured logging (JSON)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import logging\nimport json\n\n# JSON format for machine parsing\nlogging.basicConfig(\n    level=logging.INFO,\n    format='{\"timestamp\": \"%(asctime)s\", \"level\": \"%(levelname)s\", \"message\": \"%(message)s\"}'\n)\n\nlogger = logging.getLogger(__name__)\n\nlogger.info(json.dumps({\"user_id\": \"user123\", \"action\": \"login\", \"success\": True}))"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "3. Include correlation/request IDs"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import logging\nimport uuid\n\nrequest_id = str(uuid.uuid4())\n\nlogging.basicConfig(\n    level=logging.INFO,\n    format=f'%(asctime)s - %(levelname)s - {request_id} - %(message)s'\n)\n\nlogger = logging.getLogger(__name__)\n\nlogger.info(\"Processing request\")  # Includes request_id in every log"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "4. Redact sensitive data"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import logging\nimport re\n\n# Redact patterns\ndef redact_sensitive(text):\n    patterns = [\n        (r'\\b[A-Za-z0-9._+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b', '[EMAIL]'),  # Email\n        (r'\\b\\d{3}-\\d{2}-\\d{4}\\b', '[SSN]'),  # SSN\n        (r'api[_-]?key', 'API_KEY'),  # API keys\n    ]\n    for pattern, replacement in patterns:\n        text = re.sub(pattern, replacement, text)\n    return text\n\nlogger.info(redact_sensitive(\"User email: user@example.com\"))"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "5. Log rotation to manage disk"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import logging\nfrom logging.handlers import RotatingFileHandler\n\n# Rotate logs: 5MB max, keep 3 backup files\nhandler = RotatingFileHandler('app.log', maxBytes=5*1024*1024, backupCount=3)\n\nlogging.basicConfig(\n    level=logging.DEBUG,\n    format='%(asctime)s - %(levelname)s - %(message)s',\n    handlers=[handler]\n)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "6. Log business events (milestones)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import logging\n\nlogging.basicConfig(level=logging.INFO)\nlogger = logging.getLogger(__name__)\n\ndef process_order(order_id, user_id):\n    logger.info(f\"Order {order_id} started\")  # Milestone\n    \n    # Process items\n    logger.debug(f\"Processing {len(items)} items\")  # Debug detail\n    \n    # Complete\n    logger.info(f\"Order {order_id} completed\")  # Milestone"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Senior Secret"}, {"type": "text", "text": ": Log \"milestones\" (start/end of operations) to narrow bug range"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "7. Use async logging for performance"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import logging\nimport asyncio\n\n# Async logging for high-throughput systems\nasync def log_async(message):\n    logger.info(message)\n\nasyncio.run(log_async(\"Processing request\"))"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "8. Log external calls"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import logging\n\nlogging.basicConfig(level=logging.INFO)\nlogger = logging.getLogger(__name__)\n\ndef fetch_api(url):\n    logger.info(f\"About to call API: {url}\")  # Before call\n    \n    try:\n        response = requests.get(url)\n        logger.info(f\"API call succeeded: {response.status_code}\")  # Success\n        logger.info(f\"Execution time: {response.elapsed.total_seconds()}s\")  # Timing\n    except Exception as e:\n        logger.exception(f\"API call failed: {e}\")  # Error with stack trace"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Key takeaways"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Logging is structured, persistent recording"}, {"type": "text", "text": " with timestamps, levels, and context"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Five levels"}, {"type": "text", "text": ": DEBUG(10), INFO(20), WARNING(30), ERROR(40), CRITICAL(50)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Default is WARNING"}, {"type": "text", "text": ": Shows WARNING, ERROR, CRITICAL only (not DEBUG/INFO)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use DEBUG for development"}, {"type": "text", "text": ", INFO/WARNING for production"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}, {"type": "code"}], "text": "logger.exception()"}, {"type": "text", "text": " includes full stack trace for errors"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Structured logging (JSON)"}, {"type": "text", "text": " enables machine parsing and AI analysis"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Include correlation IDs"}, {"type": "text", "text": " (request_id, user_id) for distributed tracing"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Redact sensitive data"}, {"type": "text", "text": " (PII, passwords, tokens)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Log rotation"}, {"type": "text", "text": " manages disk space (RotatingFileHandler)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Log milestones"}, {"type": "text", "text": " (start/end of operations) to narrow bug range"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "For Generative AI software engineering, logging is critical for audit trails, compliance, debugging complex AI pipelines, and tracking token usage/costs across user interactions."}]}]}}