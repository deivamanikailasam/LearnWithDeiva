{"format":"tiptap/v1","updatedAt":"2026-06-22T04:23:39.365Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Generative AI (Gen AI)"},{"type":"text","text":" is a field within AI that creates "},{"type":"text","marks":[{"type":"italic"}],"text":"new content"},{"type":"text","text":"—such as text, images, audio, video, and code—by learning patterns from massive datasets and generating novel outputs in response to prompts."}]},{"type":"paragraph","content":[{"type":"text","text":"It doesn’t just classify or predict; it "},{"type":"text","marks":[{"type":"italic"}],"text":"creates"},{"type":"text","text":" something that didn’t exist before, resembling the data it was trained on."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Generative AI in the hierarchy: AI → ML → DL → Gen AI"}]},{"type":"paragraph","content":[{"type":"text","text":"Generative AI sits at the top of the nested hierarchy:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"AI (Artificial Intelligence)\n └── ML (Machine Learning)\n      └── DL (Deep Learning)\n           └── Gen AI (Generative AI)"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"AI"},{"type":"text","text":": Any system that mimics human intelligence (rules, search, planning, ML, etc.)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"ML"},{"type":"text","text":": AI that learns patterns from data"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"DL"},{"type":"text","text":": ML using deep neural networks with many layers"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Gen AI"},{"type":"text","text":": AI that "},{"type":"text","marks":[{"type":"italic"}],"text":"generates new content"},{"type":"text","text":" using deep learning models (transformers, GANs, diffusion models)"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Key fact: "},{"type":"text","marks":[{"type":"bold"}],"text":"Generative AI is built on classical AI/ML concepts"},{"type":"text","text":", especially neural networks and deep learning; it’s not a separate technology but an advanced capability within AI."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What makes Generative AI different from Classical Machine Learning"}]},{"type":"paragraph","content":[{"type":"text","text":"The core distinction is "},{"type":"text","marks":[{"type":"bold"}],"text":"creation vs. analysis"},{"type":"text","text":":"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Classical Machine Learning"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Generative AI"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Goal"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Classify, predict, cluster, regress on existing data"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Generate "},{"type":"text","marks":[{"type":"italic"}],"text":"new"},{"type":"text","text":" data samples (text, image, audio, code)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Type"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Mostly "},{"type":"text","marks":[{"type":"bold"}],"text":"discriminative"},{"type":"text","text":" (learns decision boundaries)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Generative"},{"type":"text","text":" (learns full data distribution)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Output"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Label, score, or numeric prediction (e.g., “fraud”, price)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"New content: text, image, video, music, code"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Analogy"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Analyst / Judge"},{"type":"text","text":": classifies and predicts"}]}]},{"type":"tabl