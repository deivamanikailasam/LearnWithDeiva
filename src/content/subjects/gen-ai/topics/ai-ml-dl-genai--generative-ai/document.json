{"format": "tiptap/v1", "updatedAt": "2026-06-22T04:23:39.365Z", "doc": {"type": "doc", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Generative AI (Gen AI)"}, {"type": "text", "text": " is a field within AI that creates "}, {"type": "text", "marks": [{"type": "italic"}], "text": "new content"}, {"type": "text", "text": "—such as text, images, audio, video, and code—by learning patterns from massive datasets and generating novel outputs in response to prompts."}]}, {"type": "paragraph", "content": [{"type": "text", "text": "It doesn’t just classify or predict; it "}, {"type": "text", "marks": [{"type": "italic"}], "text": "creates"}, {"type": "text", "text": " something that didn’t exist before, resembling the data it was trained on."}]}, {"type": "horizontalRule"}, {"type": "image", "attrs": {"src": "data:image/svg+xml;base64,", "alt": "Generative AI — concept overview"}}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Generative AI in the hierarchy: AI → ML → DL → Gen AI"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Generative AI sits at the top of the nested hierarchy:"}]}, {"type": "codeBlock", "attrs": {"language": "text"}, "content": [{"type": "text", "text": "AI (Artificial Intelligence)\n └── ML (Machine Learning)\n      └── DL (Deep Learning)\n           └── Gen AI (Generative AI)"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "AI"}, {"type": "text", "text": ": Any system that mimics human intelligence (rules, search, planning, ML, etc.)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "ML"}, {"type": "text", "text": ": AI that learns patterns from data"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "DL"}, {"type": "text", "text": ": ML using deep neural networks with many layers"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Gen AI"}, {"type": "text", "text": ": AI that "}, {"type": "text", "marks": [{"type": "italic"}], "text": "generates new content"}, {"type": "text", "text": " using deep learning models (transformers, GANs, diffusion models)"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Key fact: "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Generative AI is built on classical AI/ML concepts"}, {"type": "text", "text": ", especially neural networks and deep learning; it’s not a separate technology but an advanced capability within AI."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "What makes Generative AI different from Classical Machine Learning"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The core distinction is "}, {"type": "text", "marks": [{"type": "bold"}], "text": "creation vs. analysis"}, {"type": "text", "text": ":"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Aspect"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Classical Machine Learning"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Generative AI"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Goal"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Classify, predict, cluster, regress on existing data"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Generate "}, {"type": "text", "marks": [{"type": "italic"}], "text": "new"}, {"type": "text", "text": " data samples (text, image, audio, code)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Type"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Mostly "}, {"type": "text", "marks": [{"type": "bold"}], "text": "discriminative"}, {"type": "text", "text": " (learns decision boundaries)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Generative"}, {"type": "text", "text": " (learns full data distribution)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Output"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Label, score, or numeric prediction (e.g., “fraud”, price)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "New content: text, image, video, music, code"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Analogy"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Analyst / Judge"}, {"type": "text", "text": ": classifies and predicts"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Artist / Creator"}, {"type": "text", "text": ": creates new content"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Probabilistic view"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Learns "}, {"type": "inlineMath", "attrs": {"latex": "P(\\text{label} \\mid \\text{data})"}}, {"type": "text", "text": " – “Given this image, what’s the label?”"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Learns "}, {"type": "inlineMath", "attrs": {"latex": "P(\\text{data})"}}, {"type": "text", "text": " or "}, {"type": "inlineMath", "attrs": {"latex": "P(\\text{data}, \\text{label})"}}, {"type": "text", "text": " – “What does all cat-like data look like?” and samples from it"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Data type"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Mostly "}, {"type": "text", "marks": [{"type": "bold"}], "text": "structured/tabular"}, {"type": "text", "text": " (spreadsheets)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Mostly "}, {"type": "text", "marks": [{"type": "bold"}], "text": "unstructured"}, {"type": "text", "text": " (text, images, audio)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Training"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Often "}, {"type": "text", "marks": [{"type": "bold"}], "text": "supervised"}, {"type": "text", "text": " (labeled data)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Often "}, {"type": "text", "marks": [{"type": "bold"}], "text": "unsupervised/self-supervised"}, {"type": "text", "text": " on massive data (e.g., internet text)"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Examples"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Spam filter, fraud detection, sales forecasting, churn prediction"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "ChatGPT, DALL·E, Midjourney, code generators, AI music"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Models"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Linear/logistic regression, SVM, Decision Trees, Random Forests, K-Means"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Transformers (LLMs), GANs, Diffusion models, VAEs"}]}]}]}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Classical AI "}, {"type": "text", "marks": [{"type": "bold"}], "text": "analyzes and predicts"}, {"type": "text", "text": "; Generative AI "}, {"type": "text", "marks": [{"type": "bold"}], "text": "creates and produces"}, {"type": "text", "text": "."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Classical AI "}, {"type": "text", "marks": [{"type": "bold"}], "text": "cannot create new content"}, {"type": "text", "text": "; it only classifies or predicts."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Generative AI can produce outputs "}, {"type": "text", "marks": [{"type": "bold"}], "text": "indistinguishable from human-created content"}, {"type": "text", "text": ", or slightly uncanny."}]}]}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "How Generative AI works (conceptually)"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Generative AI models:"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Learn patterns"}, {"type": "text", "text": " from massive pools of data (e.g., 45 terabytes of text for GPT-3)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Learn the data distribution"}, {"type": "text", "text": ": they model what “language” or “images of cats” look like overall"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Predict what comes next"}, {"type": "text", "text": ": given a prompt, they predict the next word, pixel, or sound in a pattern"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Sample from the distribution"}, {"type": "text", "text": ": they generate new content by sampling from the learned distribution, often with random elements to create variety"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Outputs are "}, {"type": "text", "marks": [{"type": "bold"}], "text": "calibrated combinations"}, {"type": "text", "text": " of the training data, not random copies; the randomness makes outputs varied and lifelike."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Generative AI vs Classical ML: technical distinction"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "The fundamental technical difference is "}, {"type": "text", "marks": [{"type": "bold"}], "text": "probabilistic"}, {"type": "text", "text": ":"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Discriminative models (classical ML)"}, {"type": "text", "text": ":"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Learn decision boundaries: "}, {"type": "inlineMath", "attrs": {"latex": "P(\\text{label} \\mid \\text{input})"}}, {"type": "text", "text": " Example: “Is this email spam or not?”"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Generative models (Gen AI)"}, {"type": "text", "text": ":"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Learn the full joint distribution: "}, {"type": "inlineMath", "attrs": {"latex": "P(\\text{input}, \\text{label})"}}, {"type": "text", "text": " or "}, {"type": "inlineMath", "attrs": {"latex": "P(\\text{data})"}}, {"type": "text", "text": " Example: “What is the distribution of all possible cat images?” then sample new ones"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "As the analogy:"}]}, {"type": "blockquote", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "“A discriminative model is a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "judge"}, {"type": "text", "text": " that classifies. A generative model is an "}, {"type": "text", "marks": [{"type": "bold"}], "text": "artist"}, {"type": "text", "text": " that creates.”"}]}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Key takeaways"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Generative AI"}, {"type": "text", "text": " creates new content (text, images, code, etc.) by learning patterns from massive datasets and sampling from the learned data distribution."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Classical ML"}, {"type": "text", "text": " classifies, predicts, and analyzes data; it does "}, {"type": "text", "marks": [{"type": "bold"}], "text": "not create"}, {"type": "text", "text": " new content."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Gen AI is "}, {"type": "text", "marks": [{"type": "bold"}], "text": "built on classical AI/ML and deep learning"}, {"type": "text", "text": "; it’s a nested capability, not a separate technology."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "The core difference is "}, {"type": "text", "marks": [{"type": "bold"}], "text": "discriminative vs generative"}, {"type": "text", "text": " (predicting labels vs. generating new data)."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Classical ML remains the "}, {"type": "text", "marks": [{"type": "bold"}], "text": "backbone"}, {"type": "text", "text": " of enterprise AI (fraud detection, forecasting, etc.), while Gen AI is a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "powerful enabler"}, {"type": "text", "text": " that adds creativity and adaptability."}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "The future is "}, {"type": "text", "marks": [{"type": "bold"}], "text": "hybrid"}, {"type": "text", "text": ": integrate classical ML with Gen AI for data augmentation, better predictions, and more adaptive systems."}]}]}]}]}}