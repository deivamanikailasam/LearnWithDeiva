,"attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Training"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Often "},{"type":"text","marks":[{"type":"bold"}],"text":"supervised"},{"type":"text","text":" (labeled data)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Often "},{"type":"text","marks":[{"type":"bold"}],"text":"unsupervised/self-supervised"},{"type":"text","text":" on massive data (e.g., internet text)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Examples"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Spam filter, fraud detection, sales forecasting, churn prediction"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"ChatGPT, DALL·E, Midjourney, code generators, AI music"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Models"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Linear/logistic regression, SVM, Decision Trees, Random Forests, K-Means"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Transformers (LLMs), GANs, Diffusion models, VAEs"}]}]}]}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Classical AI "},{"type":"text","marks":[{"type":"bold"}],"text":"analyzes and predicts"},{"type":"text","text":"; Generative AI "},{"type":"text","marks":[{"type":"bold"}],"text":"creates and produces"},{"type":"text","text":"."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Classical AI "},{"type":"text","marks":[{"type":"bold"}],"text":"cannot create new content"},{"type":"text","text":"; it only classifies or predicts."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Generative AI can produce outputs "},{"type":"text","marks":[{"type":"bold"}],"text":"indistinguishable from human-created content"},{"type":"text","text":", or slightly uncanny."}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How Generative AI works (conceptually)"}]},{"type":"paragraph","content":[{"type":"text","text":"Generative AI models:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Learn patterns"},{"type":"text","text":" from massive pools of data (e.g., 45 terabytes of text for GPT-3)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Learn the data distribution"},{"type":"text","text":": they model what “language” or “images of cats” look like overall"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Predict what comes next"},{"type":"text","text":": given a prompt, they predict the next word, pixel, or sound in a pattern"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sample from the distribution"},{"type":"text","text":": they generate new content by sampling from the learned distribution, often with random elements to create variety"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Outputs are "},{"type":"text","marks":[{"type":"bold"}],"text":"calibrated combinations"},{"type":"text","text":" of the training data, not random copies; the randomness makes outputs varied and lifelike."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Generative AI vs Classical ML: technical distinction"}]},{"type":"paragraph","content":[{"type":"text","text":"The fundamental technical difference is "},{"type":"text","marks":[{"type":"bold"}],"text":"probabilistic"},{"type":"text","text":":"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Discriminative models (classical ML)"},{"type":"text","text":":"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Learn decision boundaries: "},{"type":"inlineMath","attrs":{"latex":"P(\\text{label} \\mid \\text{input})"}},{"type":"text","text":" Example: “Is this email spam or not?”"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Generative models (Gen AI)"},{"type":"text","text":":"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Learn the full joint distribution: "},{"type":"inlineMath","attrs":{"latex":"P(\\text{input}, \\text{label})"}},{"type":"text","text":" or "},{"type":"inlineMath","attrs":{"latex":"P(\\text{data})"}},{"type":"text","text":" Example: “What is the distribution of all possible cat images?” then sample new ones"}]},{"type":"paragraph","content":[{"type":"text","text":"As the analogy:"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"“A discriminative model is a "},{"type":"text","marks":[{"type":"bold"}],"text":"judge"},{"type":"text","text":" that classifies. A generative model is an "},{"type":"text","marks":[{"type":"bold"}],"text":"artist"},{"type":"text","text":" that creates.”"}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Generative AI"},{"type":"text","text":" creates new content (text, images, code, etc.) by learning patterns from massive datasets and sampling from the learned data distribution."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Classical ML"},{"type":"text","text":" classifies, predicts, and analyzes data; it does "},{"type":"text","marks":[{"type":"bold"}],"text":"not create"},{"type":"text","text":" new content."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Gen AI is "},{"type":"text","marks":[{"type":"bold"}],"text":"built on classical AI/ML and deep learning"},{"type":"text","text":"; it’s a nested capability, not a separate technology."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"The core difference is "},{"type":"text","marks":[{"type":"bold"}],"text":"discriminative vs generative"},{"type":"text","text":" (predicting labels vs. generating new data)."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Classical ML remains the "},{"type":"text","marks":[{"type":"bold"}],"text":"backbone"},{"type":"text","text":" of enterprise AI (fraud detection, forecasting, etc.), while Gen AI is a "},{"type":"text","marks":[{"type":"bold"}],"text":"powerful enabler"},{"type":"text","text":" that adds creativity and adaptability."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"The future is "},{"type":"text","marks":[{"type":"bold"}],"text":"hybrid"},{"type":"text","text":": integrate classical ML with Gen AI for data augmentation, better predictions, and more adaptive systems."}]}]}]},{"type":"paragraph"}]}}
