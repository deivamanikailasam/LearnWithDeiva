{"format":"tiptap/v1","updatedAt":"2026-06-22T06:44:12.440Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Applying Activations"},{"type":"text","text":" is the second (and transformative) step in forward propagation where an "},{"type":"text","marks":[{"type":"bold"}],"text":"activation function"},{"type":"text","text":" is applied to the linear combination output to introduce "},{"type":"text","marks":[{"type":"bold"}],"text":"non-linearity"},{"type":"text","text":" into the neural network. This is the critical mechanism that allows neural networks to learn complex, non-linear patterns that pure linear transformations cannot capture."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What \"Applying Activations\" Means"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Mathematical definition:"}]},{"type":"paragraph","content":[{"type":"text","text":"For each layer "},{"type":"inlineMath","attrs":{"latex":"l"}},{"type":"text","text":":"}]},{"type":"blockMath","attrs":{"latex":"A^{[l]} = g^{[l]}(Z^{[l]})"}},{"type":"paragraph","content":[{"type":"text","text":"Where:\n- "},{"type":"inlineMath","attrs":{"latex":"Z^{[l]} = W^{[l]} A^{[l-1]} + b^{[l]}"}},{"type":"text","text":" = "},{"type":"text","marks":[{"type":"bold"}],"text":"linear combination"},{"type":"text","text":" output (also called pre-activation or logits)\n- "},{"type":"inlineMath","attrs":{"latex":"g^{[l]}"}},{"type":"text","text":" = "},{"type":"text","marks":[{"type":"bold"}],"text":"activation function"},{"type":"text","text":" for layer "},{"type":"inlineMath","attrs":{"latex":"l"}},{"type":"text","text":" (ReLU, GELU, sigmoid, tanh, softmax)\n- "},{"type":"inlineMath","attrs":{"latex":"A^{[l]}"}},{"type":"text","text":" = final output (activation) of layer "},{"type":"inlineMath","attrs":{"latex":"l"}},{"type":"text","text":", passed to the next layer"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Element-wise operation"},{"type":"text","text":": The activation function is applied to "},{"type":"text","marks":[{"type":"bold"}],"text":"each element independently"},{"type":"text","text":":"}]},{"type":"paragraph","content":[{"type":"text","text":"If "},{"type":"inlineMath","attrs":{"latex":"Z"}},{"type":"text","text":" is a matrix of size "},{"type":"inlineMath","attrs":{"latex":"m \\times n"}},{"type":"text","text":":"}]},{"type":"blockMath","attrs":{"latex":"A_{ij} = g(Z_{ij})"}},{"type":"paragraph","content":[{"type":"text","text":"Each element "},{"type":"inlineMath","attrs":{"latex":"A_{ij}"}},{"type":"text","text":" is obtained by applying function "},{"type":"inlineMath","attrs":{"latex":"g"}},{"type":"text","text":" to the corresponding element "},{"type":"inlineMath","attrs":{"latex":"Z_{ij}"}},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key insight"},{"type":"text","text":": The activation function transforms the raw weighted sum into a non-linear signal that can be passed forward."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why Applying Activations Is Critical"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"The fundamental problem without activation:"}]},{"type":"paragraph","content":[{"type":"text","text":"If you skip this step and pass "},{"type":"inlineMath","attrs":{"latex":"Z"}},{"type":"text","text":" directly to the next layer without any transformation:"}]},{"type":"blockMath","attrs":{"latex":"\\text{Stacked linear layers} = W_2(W_1 X + b_1) + b_2 = (W_2 W_1)X + (W_2 b_1 + b_2)"}},{"type":"paragraph","content":[{"type":"text","text":"This "},{"type":"text","marks":[{"type":"bold"}],"text":"simplifies to"},{"type":"text","text":":"}]},{"type":"blockMath","attrs":{"latex":"\\text{Stacked network} = W_{\\text{combined}} X + b_{\\text{combined}}"}},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Consequence"},{"type":"text","text":": No matter how many layers you stack, the entire network collapses to "},{"type":"text","marks":[{"type":"bold"}],"text":"a single linear function"},{"type":"text","text":"."}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Problem"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Explanation"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Can't model non-linear relationships"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Real data (images, text, complex patterns) is non-linear"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Limited expressiveness"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Network can only learn straight lines, planes, hyperplanes"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"No complex pattern learning"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Cannot learn curves, boundaries, or intricate structures like circles or XOR"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Solution"},{"type":"text","text":": Activation functions introduce "},{"type":"text","marks":[{"type":"bold"}],"text":"non-linearity"},{"type":"text","text":" after each linear combination, preventing this collapse."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"The Complete Two-Step Process in Each Layer"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Cycle for layer "},{"type":"inlineMath","attrs":{"latex":"l"}},{"type":"text","text":":"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 1: Linear Combination"},{"type":"text","text":" (weighted sum + bias)"}]},{"type":"blockMath","attrs":{"latex":"Z^{[l]} = W^{[l]} A^{[l-1]} + b^{[l]}"}},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Step 2: Apply Activation"},{"type":"text","text":" (non-linear transformation)"}]},{"type":"blockMath","attrs":{"latex":"A^{[l]} = g^{[l]}(Z^{[l]})"}},{"type":"paragraph","content":[{"type":"text","text":"[apxml](https://apxml.com/courses/introduction-to-neural-networks/chapter-3-forward-propagation/applying-activations)"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Then repeat:"}]},{"type":"paragraph","content":[{"type":"text","text":"The output "},{"type":"inlineMath","attrs":{"latex":"A^{[l]}"}},{"type":"text","text":" becomes the input "},{"type":"inlineMath","attrs":{"latex":"X^{[l+1]}"}},{"type":"text","text":" for the next layer "},{"type":"inlineMath","attrs":{"latex":"l+1"}},{"type":"text","text":", and the process repeats."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Visual flow through a layer:"}]},{"type":"codeBlock","attrs":{"language":"text"},"content":[{"type":"text","text":"Input X (or A from previous layer)\n    ↓\n┌─────────────────────────┐\n│  Step 1: Linear         │\n│  Combination            │\n│  Z = WX + b             │\n└─────────────────────────┘\n    ↓\n    Z (pre-activation)\n    ↓\n┌─────────────────────────┐\n│  Step 2: Apply          │\n│  Activation Function    │\n│  A = g(Z)               │\n└─────────────────────────┘\n    ↓\n    A (activation/output)\n    ↓\nPass to next layer as X_next"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How Activation Functions Work: Element-wise Example"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Example: ReLU applied to a matrix:"}]},{"type":"paragraph","content":[{"type":"text","text":"Given pre-activation matrix:"}]},{"type":"blockMath","attrs":{"latex":"Z = \\begin{bmatrix} \n2.0 & -1.5 & 0.3 \\\\\n-0.8 & 1.2 & -2.0\n\\end{bmatrix}"}},{"type":"paragraph","content":[{"type":"text","text":"Apply ReLU "},{"type":"inlineMath","attrs":{"latex":"g(z) = \\max(0, z)"}},{"type":"text","text":":"}]},{"type":"blockMath","attrs":{"latex":"A = \\begin{bmatrix} \n\\max(0, 2.0) & \\max(0, -1.5) & \\max(0, 0.3) \\\\\n\\max(0, -0.8) & \\max(0, 1.2) & \\max(0, -2.0)\n\\end{bmatrix} = \\begin{bmatrix} \n2.0 & 0 & 0.3 \\\\\n0 & 1.2 & 0\n\\end{bmatrix}"}},{"type":"paragraph","content":[{"type":"text","text":"Each element is transformed "},{"type":"text","marks":[{"type":"bold"}],"text":"independently"},{"type":"text","text":" without any interaction between elements."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common Activation Functions and Their Use Cases in Generative AI"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Activation Function"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rows