attrs": {"level": 2}, "content": [{"type": "text", "text": "Two ways to use Plotly"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "1. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Plotly Express"}, {"type": "text", "text": " (high-level API)"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "User-friendly, "}, {"type": "text", "marks": [{"type": "bold"}], "text": "streamlined approach"}, {"type": "text", "text": " for swift creation with "}, {"type": "text", "marks": [{"type": "bold"}], "text": "minimal code"}, {"type": "text", "text": "."}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import plotly.express as px\nimport pandas as pd\n\ndf = pd.read_csv('data.csv')\n\n# Scatter plot with single line\nfig = px.scatter(df, x='feature1', y='feature2', color='category')\nfig.show()"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Benefits"}, {"type": "text", "text": ":\n- Minimal code\n- Automatic semantic mapping (color, size, hover)\n- Beautiful defaults"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "2. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Plotly Graph Objects"}, {"type": "text", "text": " (low-level API)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Finer level of control"}, {"type": "text", "text": " and customization."}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import plotly.graph_objects as go\n\nfig = go.Figure()\nfig.add_trace(go.Scatter(x=df['feature1'], y=df['feature2'], mode='markers'))\nfig.update_layout(title='Plot Title', xaxis_title='X', yaxis_title='Y')\nfig.show()"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Benefits"}, {"type": "text", "text": ":\n- Full control over every element\n- Complex layouts, custom annotations"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Common plot types with Plotly"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "1. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Scatter Plot"}, {"type": "text", "text": " (relationships)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import plotly.express as px\n\nfig = px.scatter(df, x='feature1', y='feature2', color='category', hover_data=['value'])\nfig.show()"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Features"}, {"type": "text", "text": ":\n- Hover tooltips with exact values\n- Color by category\n- Zoom/pan"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "2. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Line Plot"}, {"type": "text", "text": " (trends)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "fig = px.line(df, x='time', y='value', color='category')\nfig.show()"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use case"}, {"type": "text", "text": ": Visualize training loss/accuracy over epochs."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "3. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Bar Plot"}, {"type": "text", "text": " (comparisons)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "fig = px.bar(df, x='category', y='value', color='category')\nfig.show()"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "4. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Histogram"}, {"type": "text", "text": " (distribution)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "fig = px.histogram(df, x='feature', color='category')\nfig.show()"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "5. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Heatmap"}, {"type": "text", "text": " (correlations)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import plotly.express as px\n\ncorr = df.corr()\nfig = px.imshow(corr, text_auto=True)\nfig.show()"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use case"}, {"type": "text", "text": ": See feature correlations, identify multicollinearity."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "6. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "3D Scatter Plot"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "fig = px.scatter_3d(df, x='x', y='y', z='z', color='category')\nfig.show()"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use case"}, {"type": "text", "text": ": Visualize 3D embeddings, spatial data."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "7. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Maps"}, {"type": "text", "text": " (geospatial)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "fig = px.scatter_geo(df, lon='longitude', lat='latitude', color='category')\nfig.show()"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use case"}, {"type": "text", "text": ": Location analytics, trip density visualization."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "8. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Parallel Coordinates Plot"}, {"type": "text", "text": " (multivariate)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "fig = px.parallel_coordinates(df, color='category', dimension_labels=['A', 'B', 'C'])\nfig.show()"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use case"}, {"type": "text", "text": ": Visualize high-dimensional relationships."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Interactive features"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Tooltips (hover)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "fig = px.scatter(df, x='x', y='y', hover_data=['value1', 'value2'])\nfig.show()"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Hover shows exact values for each point."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Zoom & Pan"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Click and drag on any Plotly chart to zoom. Use toolbar to pan/zoom."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Export"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "fig.write_image('plot.png')  # Export to PNG\nfig.write_html('plot.html')  # Save as standalone HTML"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Plotly vs. Matplotlib vs. Seaborn"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{