ingle line\nfig = px.scatter(df, x='feature1', y='feature2', color='category')\nfig.show()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits"},{"type":"text","text":":\n- Minimal code\n- Automatic semantic mapping (color, size, hover)\n- Beautiful defaults"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Plotly Graph Objects"},{"type":"text","text":" (low-level API)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Finer level of control"},{"type":"text","text":" and customization."}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import plotly.graph_objects as go\n\nfig = go.Figure()\nfig.add_trace(go.Scatter(x=df['feature1'], y=df['feature2'], mode='markers'))\nfig.update_layout(title='Plot Title', xaxis_title='X', yaxis_title='Y')\nfig.show()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Benefits"},{"type":"text","text":":\n- Full control over every element\n- Complex layouts, custom annotations"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common plot types with Plotly"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Scatter Plot"},{"type":"text","text":" (relationships)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import plotly.express as px\n\nfig = px.scatter(df, x='feature1', y='feature2', color='category', hover_data=['value'])\nfig.show()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Features"},{"type":"text","text":":\n- Hover tooltips with exact values\n- Color by category\n- Zoom/pan"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text"