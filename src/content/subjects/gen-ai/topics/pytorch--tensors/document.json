{"format":"tiptap/v1","updatedAt":"2026-06-22T08:39:06.476Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What Tensors Are"}]},{"type":"paragraph","content":[{"type":"text","text":"In PyTorch, "},{"type":"text","marks":[{"type":"bold"}],"text":"tensors"},{"type":"text","text":" are the central data abstraction: specialized N-dimensional arrays that hold numerical data and serve as the primary way to encode inputs, outputs, and parameters of neural networks. Conceptually, they're generalized matrices:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Dimension"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Name"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Example"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"0"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scalar"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"5.0"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"1"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Vector"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"[1, 2, 3]"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"2"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Matrix"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"[[1, 2], [3, 4]]"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"3+"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tensor"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Image data "},{"type":"text","marks":[{"type":"code"}],"text":"(channels, height, width)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"A PyTorch tensor is basically the same as a NumPy array but with critical extensions for deep learning."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why Tensors Matter in Generative AI"}]},{"type":"paragraph","content":[{"type":"text","text":"Tensors are fundamental because:"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Data representation"},{"type":"text","text":": All inputs to generative models (images, text embeddings, audio) are encoded as tensors"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"GPU acceleration"},{"type":"text","text":": PyTorch tensors can reside on CPU or GPU, enabling massive parallelization for training large generative models"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Gradient tracking"},{"type":"text","text":": Tensors can be marked with "},{"type":"text","marks":[{"type":"code"}],"text":"requires_grad=True"},{"type":"text","text":" to automatically track operations for backpropagation via Autograd"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Model parameters"},{"type":"text","text":": Neural network weights and biases are stored as tensors"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"How Tensors Work with Autograd and Modules"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Core Mechanics"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import torch\n\n# Create a tensor with gradient tracking\nx = torch.tensor([1.0, 2.0, 3.0], requires_grad=True)\ny = torch.tensor([4.0, 5.0, 6.0], requires_grad=True)\n\n# Autograd records this operation in a directed acyclic graph (DAG)\nz = x * y + 2  # z depends on x and y [web:1]\n\n# Compute gradients automatically\nz.backward()\nprint(x.grad)  # Gradient of z w.r.t. x"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Autograd"},{"type":"text","text":" keeps a record of:\n- Data (tensors)\n- All executed operations\n- Resulting new tensors"}]},{"type":"paragraph","content":[{"type":"text","text":"This forms a computational graph that enables automatic gradient computation."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Integration with Modules (Neural Networks)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"class Generator(torch.nn.Module):  # Used in GANs, diffusion models\n    def __init__(self):\n        super().__init__()\n        # Parameters are tensors automatically\n        self.fc1 = torch.nn.Linear(128, 256)  # weights/tensors\n        self.fc2 = torch.nn.Linear(256, 784)\n    \n    def forward(self, x):  # x is a tensor\n        return self.fc2(self.fc1(x))\n\nmodel = Generator()\ninput_tensor = torch.randn(32, 128)  # Batch of 32 samples\noutput = model(input_tensor)  # Output is also a tensor"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Operations"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# Creation\nx = torch.randn(3, 4)          # Random tensor\nx = torch.zeros(2, 3)          # Zero tensor\nx = torch.tensor([1, 2, 3])    # From data\n\n# Shape manipulation\nx.shape        # (3, 4)\nx.view(12)     # Reshape\nx.transpose(0, 1)  # Swap dimensions\n\n# Arithmetic\nx + y, x * y, x.matmul(y)\n\n# Device placement\nx_cpu = x.to('cpu')\nx_gpu = x.to('cuda')  # GPU acceleration [web:7]"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of tensors as "},{"type":"text","marks":[{"type":"bold"}],"text":"multi-dimensional spreadsheets"},{"type":"text","text":" where:\n- Each cell holds a number (float/int)\n- You can perform math on entire sheets at once\n- PyTorch automatically tracks how you modified them to compute gradients later\n- They can live on GPU for blazing-fast computation"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Tensors are "},{"type":"text","marks":[{"type":"bold"}],"text":"N-dimensional arrays"},{"type":"text","text":" (scalars → vectors → matrices → higher dims)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"They are the "},{"type":"text","marks":[{"type":"bold"}],"text":"core data structure"},{"type":"text","text":" encoding all model inputs/outputs/parameters"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"With "},{"type":"text","marks":[{"type":"code"}],"text":"requires_grad=True"},{"type":"text","text":", tensors enable "},{"type":"text","marks":[{"type":"bold"}],"text":"automatic differentiation"},{"type":"text","text":" via Autograd"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Tensors support "},{"type":"text","marks":[{"type":"bold"}],"text":"GPU acceleration"},{"type":"text","text":" critical for training large generative models"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"They integrate seamlessly with "},{"type":"text","marks":[{"type":"bold"}],"text":"Modules"},{"type":"text","text":" ("},{"type":"text","marks":[{"type":"code"}],"text":"torch.nn.Module"},{"type":"text","text":") to build neural networks"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Basic operations mirror NumPy but with deep learning extensions"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"This tensor-autograd-modules foundation enables PyTorch to build everything from simple classifiers to massive generative models like GPT, diffusion models, and GANs."}]}]}}
