{
  "format": "tiptap/v1",
  "doc": {
    "type": "doc",
    "content": [
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "What NER Does"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Named Entity Recognition (NER)"
          },
          {
            "type": "text",
            "text": " locates and classifies real-world entities mentioned in text — people, organisations, locations, dates, monetary values, and more. Unlike text classification (which assigns one label to the whole document), NER is a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "token-level"
          },
          {
            "type": "text",
            "text": " task: every token in the sentence gets a label. NER is a foundational building block for information extraction, knowledge graph construction, and search."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "NER tagging diagram showing 'Apple acquired Beats Electronics in 2014 for $3 billion' with BIO labels: B-ORG for Apple, B-ORG/I-ORG for Beats Electronics, B-DATE for 2014, B-MONEY/I-MONEY for $3 billion"
        }
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "The BIO Tagging Scheme"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "NER is modelled as a sequence labelling problem. Each token receives a tag in the "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "BIO"
          },
          {
            "type": "text",
            "text": " (Begin-Inside-Outside) format:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "B-TYPE"
                  },
                  {
                    "type": "text",
                    "text": " — the first token of a named entity of the given type."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "I-TYPE"
                  },
                  {
                    "type": "text",
                    "text": " — a continuation token inside the same entity (\"Beats Electronics\" → B-ORG, I-ORG)."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ],
                    "text": "O"
                  },
                  {
                    "type": "text",
                    "text": " — not part of any entity."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Standard CoNLL-2003 entity types are "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "PER"
          },
          {
            "type": "text",
            "text": " (person), "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "ORG"
          },
          {
            "type": "text",
            "text": " (organisation), "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "LOC"
          },
          {
            "type": "text",
            "text": " (location), and "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "MISC"
          },
          {
            "type": "text",
            "text": ". spaCy's models extend this to 18 types including "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "DATE"
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "MONEY"
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "GPE"
          },
          {
            "type": "text",
            "text": " (geo-political entity), and "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "PRODUCT"
          },
          {
            "type": "text",
            "text": "."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "NER with spaCy"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "spaCy ships pretrained pipelines that run NER as part of a full linguistic pipeline. The "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "en_core_web_trf"
          },
          {
            "type": "text",
            "text": " model is transformer-based and most accurate; "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "en_core_web_sm"
          },
          {
            "type": "text",
            "text": " is faster and CPU-friendly."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import spacy\n\n# pip install spacy && python -m spacy download en_core_web_sm\nnlp = spacy.load(\"en_core_web_sm\")\n\ntext = \"Apple acquired Beats Electronics in 2014 for $3 billion.\"\ndoc = nlp(text)\n\nfor ent in doc.ents:\n    print(f\"{ent.text!r:20} {ent.label_:10} {spacy.explain(ent.label_)}\")\n\n# 'Apple'             ORG        Companies, agencies, institutions...\n# 'Beats Electronics' ORG        Companies, agencies, institutions...\n# '2014'              DATE       Absolute or relative dates or periods\n# '$3 billion'        MONEY      Monetary values, including unit\n\n# Visualise in Jupyter:\nfrom spacy import displacy\ndisplacy.render(doc, style=\"ent\")"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "NER with Transformers (Hugging Face)"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from transformers import pipeline\n\n# Uses dslim/bert-base-NER by default — fine-tuned on CoNLL-2003\nner = pipeline(\"ner\", aggregation_strategy=\"simple\")\n\nresults = ner(\"Apple acquired Beats Electronics in 2014 for $3 billion.\")\nfor r in results:\n    print(f\"{r['word']:20} {r['entity_group']:8} score={r['score']:.2f}\")\n\n# Apple                ORG      score=1.00\n# Beats Electronics    ORG      score=1.00\n# 2014                 MISC     score=0.75  ← DATE may not appear in CoNLL types\n\n# aggregation_strategy=\"simple\" merges B-/I- tokens into spans automatically"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For domain-specific entities (medical, legal, biomedical), use a model fine-tuned on in-domain data. Hugging Face Hub has hundreds: "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "d4data/biomedical-ner-all"
          },
          {
            "type": "text",
            "text": ", "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "nlpaueb/legal-bert-base-uncased"
          },
          {
            "type": "text",
            "text": ", etc."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Fine-tuning a NER Model"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from datasets import load_dataset\nfrom transformers import (\n    AutoTokenizer,\n    AutoModelForTokenClassification,\n    TrainingArguments,\n    Trainer,\n    DataCollatorForTokenClassification,\n)\nimport numpy as np\nfrom seqeval.metrics import f1_score, classification_report\n\n# CoNLL-2003: tokens with PER, ORG, LOC, MISC labels in BIO format\ndataset = load_dataset(\"conll2003\")\nlabel_names = dataset[\"train\"].features[\"ner_tags\"].feature.names\n# ['O', 'B-PER', 'I-PER', 'B-ORG', 'I-ORG', 'B-LOC', 'I-LOC', 'B-MISC', 'I-MISC']\n\ntokenizer = AutoTokenizer.from_pretrained(\"distilbert-base-uncased\")\n\ndef tokenize_and_align(example):\n    tokenized = tokenizer(example[\"tokens\"], truncation=True, is_split_into_words=True)\n    labels = []\n    for i, word_id in enumerate(tokenized.word_ids()):\n        if word_id is None:\n            labels.append(-100)  # special tokens — ignored in loss\n        else:\n            # Only label the first sub-token of each word\n            labels.append(example[\"ner_tags\"][word_id] if tokenized.word_ids()[i] != tokenized.word_ids()[i-1] or i == 0 else -100)\n    tokenized[\"labels\"] = labels\n    return tokenized\n\ntokenized_ds = dataset.map(tokenize_and_align, batched=False)\n\nmodel = AutoModelForTokenClassification.from_pretrained(\n    \"distilbert-base-uncased\",\n    num_labels=len(label_names),\n    id2label={i: l for i, l in enumerate(label_names)},\n    label2id={l: i for i, l in enumerate(label_names)},\n)\n\ntraining_args = TrainingArguments(\n    output_dir=\"./ner-distilbert\",\n    num_train_epochs=3,\n    per_device_train_batch_size=16,\n    evaluation_strategy=\"epoch\",\n    learning_rate=2e-5,\n)\n\ntrainer = Trainer(\n    model=model,\n    args=training_args,\n    train_dataset=tokenized_ds[\"train\"],\n    eval_dataset=tokenized_ds[\"validation\"],\n    data_collator=DataCollatorForTokenClassification(tokenizer),\n)\ntrainer.train()\n# Typical CoNLL-2003 F1: ~90-91 after 3 epochs"
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Evaluating NER: Span-Level F1"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "NER is evaluated at the "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "span level"
          },
          {
            "type": "text",
            "text": ", not the token level. A predicted entity is correct only if both its boundaries and its type match the gold annotation exactly. The "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "seqeval"
          },
          {
            "type": "text",
            "text": " library handles this correctly."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from seqeval.metrics import classification_report\n\ngold = [[\"B-ORG\", \"I-ORG\", \"O\", \"B-PER\"]]\npred = [[\"B-ORG\", \"I-ORG\", \"O\", \"B-ORG\"]]  # last token wrong type\n\nprint(classification_report(gold, pred))\n#           precision    recall  f1-score   support\n# ORG           0.50      1.00      0.67         1\n# PER           0.00      0.00      0.00         1\n# micro avg     0.50      0.50      0.50         2\n\n# 'Beats Electronics' (2-token span) counts as ONE entity:\n# both tokens must match for it to be a true positive."
          }
        ]
      },
      {
        "type": "horizontalRule"
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Common Pitfalls"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Sub-word tokenisation."
                  },
                  {
                    "type": "text",
                    "text": " BERT splits \"Beats\" into [\"Beat\", \"##s\"]. Only label the first sub-token; set others to -100 so they don't contribute to the loss."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Domain mismatch."
                  },
                  {
                    "type": "text",
                    "text": " A model trained on news text will miss medical drug names or legal citations. Fine-tune on in-domain examples or use a specialist model."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Ambiguous entities."
                  },
                  {
                    "type": "text",
                    "text": " \"Apple\" is ORG in a tech context and not an entity in a recipe. Contextual transformer models handle this much better than rule-based systems."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Nested entities."
                  },
                  {
                    "type": "text",
                    "text": " Standard BIO does not support nesting (\"[Bank of [America]]\"). Span-based models (SpanBERT) or the BIOES tagging scheme address this."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
