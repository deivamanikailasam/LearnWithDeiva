ype":"text","marks":[{"type":"code"}],"text":"mul"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"sin"},{"type":"text","text":") to track operations"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Create "},{"type":"text","marks":[{"type":"code"}],"text":"Tensor"},{"type":"text","text":" objects with "},{"type":"text","marks":[{"type":"code"}],"text":".grad_fn"},{"type":"text","text":" (gradient function)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Build graph dynamically during forward pass"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pros"},{"type":"text","text":": Easy to use, Pythonic\n"},{"type":"text","marks":[{"type":"bold"}],"text":"Cons"},{"type":"text","text":": Runtime overhead from graph construction"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Graph Compilation (TensorFlow 1.x-style)"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Define graph symbolically first ("},{"type":"text","marks":[{"type":"code"}],"text":"tf.function"},{"type":"text","text":")"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Execute graph in optimized runtime"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Pre-compute gradients"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Pros"},{"type":"text","text":": Better performance, optimization\n"},{"type":"text","marks":[{"type":"bold"}],"text":"Cons"},{"type":"text","text":": Less flexible, harder debugging"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Hybrid (TensorFlow 2.x / PyTorch 2.x)"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Eager mode for debugging"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Graph compilation for performance ("},{"type":"text","marks":[{"type":"code"}],"text":"torch.compile"},{"type":"text","text":")"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Automatic gradient computation"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Properties of Autodiff"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Exactness"}]},{"type":"paragraph","content":[{"type":"text","text":"Autodiff computes "},{"type":"text","marks":[{"type":"bold"}],"text":"exact derivatives"},{"type":"text","text":" (unlike numerical differentiation):\n\\[\n\\text{Error} \\approx 0 \\text{ (only floating-point precision)}\n\\]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Computational Cost"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Forward pass"},{"type":"text","text":": 1 unit of work"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Backward pass"},{"type":"text","text":": ≤ 5 units of work (typically ~3× forward cost)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Total"},{"type":"text","text":": Constant factor overhead vs. forward pass alone"}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Memory Cost"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Cache intermediate values"},{"type":"text","text":" for backward pass"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Memory usage: "},{"type":"inlineMath","attrs":{"latex":"\\sim 2 \\times"}},{"type":"text","text":" forward pass (values + gradients)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Trade-off: more memory → faster computation"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of autodiff as a "},{"type":"text","marks":[{"type":"bold"}],"text":"smart calculator that remembers how you computed everything"},{"type":"text","text":":"}]},{"type":"blockMath","attrs":{"latex":"1. **Forward**: You compute \\( y = (x^{2} + 3x) \\cdot \\sin(x) \\)"}},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Autodiff records"},{"type":"text","text":": \"You did: square → add → multiply → sin\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Backward"},{"type":"text","text":": You ask \"what's "},{"type":"inlineMath","attrs":{"latex":"\\frac{dy}{dx}"}},{"type":"text","text":"?\""}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Autodiff applies"},{"type":"text","text":": chain rule through recorded steps → exact answer"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"The framework doesn't need to know the math—it just applies the chain rule mechanically."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Automatic Differentiation"},{"type":"text","text":" is a general framework for computing exact derivatives via chain rule on computation graphs"}]}]},{"type":"listItem","content":[{"typ