      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Run this audit on a 1-5 % sample of pairs with human labels before scaling the pipeline to millions of examples."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Cost and Throughput at Scale"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For a 70B-parameter instruction-tuned model, the typical recipe:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Judge model"
                  },
                  {
                    "type": "text",
                    "text": ": GPT-4o at $0.0025 per 1k input tokens; 300 tokens per comparison call = $0.00075 per call. Two calls per pair (debiased) = $0.0015 per pair."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Throughput"
                  },
                  {
                    "type": "text",
                    "text": ": 50 concurrent requests * 10 req/s = 500 pairs/sec = 1.8M pairs/hour per API account."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Target dataset"
                  },
                  {
                    "type": "text",
                    "text": ": 500k pairs for a 7B DPO run. At 1.8M pairs/hr, labeling takes ~17 minutes and costs ~$750."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Comparison"
                  },
                  {
                    "type": "text",
