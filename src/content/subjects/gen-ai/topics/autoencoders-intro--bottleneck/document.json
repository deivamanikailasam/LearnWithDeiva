":[{"type":"text","marks":[{"type":"bold"}],"text":"Constraint"},{"type":"text","text":": Only 32 liters forces you to choose what's most important"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Result"},{"type":"text","text":": You can't bring everything, but you bring what matters most"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Bottleneck"},{"type":"text","text":" is the "},{"type":"text","marks":[{"type":"bold"}],"text":"narrowest part of autoencoder"},{"type":"text","text":" between encoder and decoder, holding compressed latent representation "},{"type":"inlineMath","attrs":{"latex":"z"}}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Dimensionality "},{"type":"inlineMath","attrs":{"latex":"d"}},{"type":"text","text":" is a critical hyperparameter"},{"type":"text","marks":[{"type":"bold"}],"text":" that directly controls degree of compression"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Too small ("},{"type":"inlineMath","attrs":{"latex":"d"}},{"type":"text","text":" very small)"},{"type":"text","marks":[{"type":"bold"}],"text":": Network struggles to capture information, leading to high reconstruction loss"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Too large ("},{"type":"inlineMath","attrs":{"latex":"d"}},{"type":"text","text":" approaching "},{"type":"inlineMath","attrs":{"latex":"D"}},{"type":"text","text":")"},{"type":"text","marks":[{"type":"bold"}],"text":": Network learns identity function, copying input without learning structure"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Optimal "},{"type":"inlineMath","attrs":{"latex":"d"}},{"type":"text","marks":[{"type":"bold"}],"text":": Forces network to learn efficiently by capturing most salient features"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Also called"},{"type":"text","text":": Latent code, latent variables, embedding, coding layer"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Constraint forces learning"},{"type":"text","text":": Must prioritize essential features to minimize reconstruction error"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Enables generation"},{"type":"text","text":": Latent space can be sampled to generate new data samples"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"The bottleneck is the core mechanism that enables autoencoders to learn compact, meaningful representations of data, making it fundamental for dimensionality reduction, feature learning, and generative modeling."}]}]}}
