{"format":"tiptap/v1","updatedAt":"2026-06-22T11:18:17.012Z","doc":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"What Bottleneck Is"}]},{"type":"paragraph","content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"bold"}],"text":"bottleneck"},{"type":"text","text":" in Autoencoders is the "},{"type":"text","marks":[{"type":"bold"}],"text":"narrowest part of the network architecture"},{"type":"text","text":", situated between the encoder and decoder, where information from the high-dimensional input is "},{"type":"text","marks":[{"type":"bold"}],"text":"squeezed into a lower-dimensional latent space representation"},{"type":"text","text":" (also called \"latent code\", \"latent variables\", or \"embedding\"). It is the "},{"type":"text","marks":[{"type":"bold"}],"text":"central component where compression materializes"},{"type":"text","text":"."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Why Bottleneck Matters in Generative AI"}]},{"type":"paragraph","content":[{"type":"text","text":"The bottleneck is fundamental to autoencoder functionality because it:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Role"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Impact"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Enforces compression"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Forces network to learn efficient repres