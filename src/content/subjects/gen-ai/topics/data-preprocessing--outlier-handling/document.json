el":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Outliers"},{"type":"text","text":": Data points deviating significantly from general distribution"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Causes"},{"type":"text","text":": Entry errors, measurement errors, natural variation, anomalies, noise"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Problems"},{"type":"text","text":": Distorts analysis, degrades model performance, creates bias"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Visual detection"},{"type":"text","text":": Histogram, box plot, scatter plot"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Z-score"},{"type":"text","text":": |Z| > 3 → outlier (99.7% confidence)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"IQR"},{"type":"text","text":": Outside [Q1-1.5×IQR, Q3+1.5×IQR] → outlier"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Removal"},{"type":"text","text":": Delete rows with outliers (simple but loses data)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Capping/Flooring"},{"type":"text","text":": Replace with percentile values (preserves data)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Log transformation"},{"type":"text","text":": Compresses outliers, makes skewed data normal"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text