s true patterns in data"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Violation of assumptions"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Breaks normal distribution assumptions"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Overfitting"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Model learns outliers instead of general patterns"}]}]}]}]}, {"type": "horizontalRule"}, {"type": "image", "attrs": {"src": "data:image/svg+xml;base64,", "alt": "Outlier Handling — concept overview"}}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "How to Detect Outliers"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "1. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Visual Inspection"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Methods"}, {"type": "text", "text": ":\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Histogram"}, {"type": "text", "text": ": Look for extreme values far from main distribution\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Box plot"}, {"type": "text", "text": ": Identify points beyond whiskers (1.5×IQR)\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Scatter plot"}, {"type": "text", "text": ": See points far from cluster\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Q-Q plot"}, {"type": "text", "text": ": Compare quantiles to theoretical distribution"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Box plot example"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "text"}, "content": [{"type": "text", "text": "Outliers\n  ●\n  |\n  |← Upper whisker (Q3 + 1.5×IQR)\n[|] ← Box (Q1 to Q3)\n  |← Lower whisker (Q1 - 1.5×IQR)\n  |\n  ●\nOutliers"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "2. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Statistical Methods"}]}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Z-score Method"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Formula"}, {"type": "text", "text": ":\n$$Z = \\frac{x - \\mu}{\\sigma}$$"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Where:\n- "}, {"type": "inlineMath", "attrs": {"latex": "x"}}, {"type": "text", "text": " = data point\n- "}, {"type": "inlineMath", "attrs": {"latex": "\\mu"}}, {"type": "text", "text": " = mean\n- "}, {"type": "inlineMath", "attrs": {"latex": "\\sigma"}}, {"type": "text", "text": " = standard deviation"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Rule"}, {"type": "text", "text": ":\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Z > 3"}, {"type": "text", "text": " or "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Z < -3"}, {"type": "text", "text": " → outlier (99.7% confidence)\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Z > 2"}, {"type": "text", "text": " or "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Z < -2"}, {"type": "text", "text": " → potential outlier"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Python"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import numpy as np\n\nz_scores = np.abs((df['column'] - df['column'].mean()) / df['column'].std())\noutliers = df[z_scores > 3]"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 4}, "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "IQR Method"}, {"type": "text", "text": " (Interquartile Range)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Formula"}, {"type": "text", "text": ":\n$$\\text{IQR} = Q3 - Q1$$"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Bounds"}, {"type": "text", "text": ":\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Lower bound"}, {"type": "text", "text": ": "}, {"type": "inlineMath", "attrs": {"latex": "Q1 - 1.5 \\times \\text{IQR}"}}, {"type": "text", "text": "\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Upper bound"}, {"type": "text", "text": ": "}, {"type": "inlineMath", "attrs": {"latex": "Q3 + 1.5 \\times \\text{IQR}"}}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Rule"}, {"type": "text", "text": ": Values outside bounds → outliers"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Python"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "Q1 = df['column'].quantile(0.25)\nQ3 = df['column'].quantile(0.75)\nIQR = Q3 - Q1\n\nlower_bound = Q1 - 1.5 * IQR\nupper_bound = Q3 + 1.5 * IQR\n\noutliers = df[(df['column'] < lower_bound) | (df['column'] > upper_bound)]"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Outlier Handling Techniques"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "1. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Removal"}, {"type": "text", "text": " (Deleting Outliers)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "What it does"}, {"type": "text", "text": ": Remove rows containing outliers from dataset"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "When to use"}, {"type": "text", "text": ":\n- Outliers are "}, {"type": "text", "marks": [{"type": "bold"}], "text": "errors"}, {"type": "text", "text": " (data entry mistakes)\n- Outliers are "}, {"type": "text", "marks": [{"type": "bold"}], "text": "noise"}, {"type": "text", "text": " (measurement errors)\n- "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Large dataset"}, {"type": "text", "text": " where removing few rows won't hurt\n- Outliers are "}, {"type": "text", "marks": [{"type": "bold"}], "text": "not valuable"}, {"type": "text", "text": " for analysis"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Method"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Remove outliers based on IQR\ndf = df[(df['column'] >= lower_bound) & (df['column'] <= upper_bound)]"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Pros"}, {"type": "text", "text": ":\n- ✅ Simple and straightforward\n- ✅ Removes noise completely"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Cons"}, {"type": "text", "text": ":\n- ❌ Loses valuable data if outliers are valid\n- ❌ Reduces sample size\n- ❌ May bias results if outliers are not random"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "2. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Capping and Flooring"}, {"type": "text", "text": " (Binning/Trimming)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "What it does"}, {"type": "text", "text": ": Replace extreme values with values at certain percentiles (e.g., 5th and 95th)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Also called"}, {"type": "text", "text": ": Clipping, Bounding, Trimming"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Method"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Set upper and lower bounds\nlower = df['column'].quantile(0.05)\nupper = df['column'].quantile(0.95)\n\n# Cap values\ndf['column'] = df['column'].clip(lower=lower, upper=upper)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Alternative"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Using if-else\ndf['column'] = np.where(df['column'] > upper, upper, df['column'])\ndf['column'] = np.where(df['column'] < lower, lower, df['column'])"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Pros"}, {"type": "text", "text": ":\n- ✅ Preserves data while reducing outlier impact\n- ✅ Keeps sample size intact"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Cons"}, {"type": "text", "text": ":\n- ❌ May lose information about extreme values\n- ❌ Reduces discriminability of data"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "3. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Transformation"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "What it does"}, {"type": "text", "text": ": Apply mathematical transformations to make data more normalized and reduce outlier impact"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Log Transformation"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Formula"}, {"type": "text", "text": ":\n$$\\text{X}"}, {"type": "text", "marks": [{"type": "italic"}], "text": "{\\text{new}} = \\log(X + c)$$"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Where "}, {"type": "inlineMath", "attrs": {"latex": "c"}}, {"type": "text", "text": " = hyperparameter to ensure non-negative input"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "What it does"}, {"type": "text", "text": ": Compresses outliers into smaller range, significantly reducing their impact"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Python"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import numpy as np\n\ndf['column_log'] = np.log(df['column'] + 1)  # +1 to avoid log(0)"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Pros"}, {"type": "text", "text": ":\n- ✅ Compresses extreme values effectively\n- ✅ Makes skewed distributions more normal"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Cons"}, {"type": "text", "text": ":\n- ❌ Changes data interpretation\n- ❌ Only works for positive values"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Best for"}, {"type": "text", "text": ": Highly skewed data (income, population, sales)"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Box-Cox Transformation"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Formula"}, {"type": "text", "text": ":\n$$\\text{X}"}, {"type": "text", "marks": [{"type": "italic"}], "text": "{\\text{new}} = \\begin{cases} \\frac{(X^\\lambda - 1)}{\\lambda} & \\text{if } \\lambda \\neq 0 \\\\ \\log(X) & \\text{if } \\lambda = 0 \\end{cases}$$"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "What it does"}, {"type": "text", "text": ": Versatile power transformation that can change data distribution"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Python"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "from scipy.stats import boxcox\n\ndf['column_boxcox'], lambda_param = boxcox(df['column'])"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Pros"}, {"type": "text", "text": ":\n- ✅ In sensitive to outliers\n- ✅ Can adjust distribution by tuning λ"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Cons"}, {"type": "text", "text": ":\n- ❌ Changes original distribution\n- ❌ Doesn't guarantee specific range"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Other Transformations"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Transformation"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Formula"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Use Case"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Square Root"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "inlineMath", "attrs": {"latex": "\\sqrt{X}"}}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Moderate skew"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Inverse"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "$1/X$"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Strong skew"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Tanh"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "inlineMath", "attrs": {"latex": "\\tanh(X)"}}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Data with outliers, scales to [-1, 1]"}]}]}]}, {"type": "tableRow", "content": [{"type": "tab