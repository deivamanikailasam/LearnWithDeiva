{"format":"tiptap/v1","updatedAt":"2026-06-21T09:01:30.460Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Control flow"},{"type":"text","text":" is how a program decides what to do next and in what order code runs, based on conditions or repetition rules. It determines the execution path of your program beyond simple sequential top-to-bottom execution."}]},{"type":"paragraph","content":[{"type":"text","text":"There are two main types:\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Conditional Statements"},{"type":"text","text":" (branches) — Making decisions: \"if this, do that\"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Loops"},{"type":"text","text":" (iterative statements) — Repeating tasks multiple times"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Conditional Statements ("},{"type":"text","marks":[{"type":"code"}],"text":"if"},{"type":"text","text":"/"},{"type":"text","marks":[{"type":"code"}],"text":"else"},{"type":"text","text":")"}]},{"type":"paragraph","content":[{"type":"text","text":"Conditional statements let your program choose different actions based on certain conditions."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Basic "},{"type":"text","marks":[{"type":"code"}],"text":"if"},{"type":"text","text":" Statement"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"age = 18\nif age >= 18:\n    print(\"You are an adult.\")"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"if"},{"type":"text","text":" checks the condition"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Code inside the block runs only if the condition is "},{"type":"text","marks":[{"type":"code"}],"text":"True"}]}]}]},{"type":"heading","attrs":{"lev