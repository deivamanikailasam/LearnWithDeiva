bold"}], "text": "Gradient descent"}, {"type": "text", "text": " (logistic regression, neural networks)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "✅ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Yes"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Large magnitudes distort optimization path, slow convergence"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Linear models"}, {"type": "text", "text": " (linear regression, logistic regression)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "✅ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Yes"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Coefficients comparable when features scaled"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "PCA"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "✅ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Yes"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Assumes zero-centered data, works best with standardized"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Tree-based"}, {"type": "text", "text": " (Random Forest, XGBoost, LightGBM)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "❌ "}, {"type": "text", "marks": [{"type": "bold"}], "text": "No"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Split on thresholds, not distances"}]}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Rule"}, {"type": "text", "text": ": Tree-based models don't usually require scaling because they split on thresholds, not distances."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Key Takeaways"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Scaling"}, {"type": "text", "text": ": Transform features to common range so no feature dominates"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Min-Max Scaling"}, {"type": "text", "text": ": Scales to using formula (x - min)/(max - min)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Standardization (Z-score)"}, {"type": "text", "text": ": Centers at mean=0, std=1 using formula (x - mean)/std"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Min-Max"}, {"type": "text", "text": ": Preserves distribution shape, fixed interval"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Standardization"}, {"type": "text", "text": ": Rescales without distorting shape, zero-centered"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Distance-based algorithms"}, {"type": "text", "text": ": Need scaling (k-NN, k-means, SVM)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Gradient descent algorithms"}, {"type": "text", "text": ": Need scaling (neural networks, logistic regression)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Tree-based models"}, {"type": "text", "text": ": Don't need scaling (split on thresholds)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "L1 Normalization"}, {"type": "text", "text": ": Sums to 1, good for sparse data"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "L2 Normalization"}, {"type": "text", "text": ": Squared sum = 1, prevents overfitting"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Robust scaling"}, {"type": "text", "text": ": Uses median/quartiles, robust to outliers"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Log scaling"}, {"type": "text", "text": ": Handles skewed distributions"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Scaling and normalization are the \"fairness enforcers\" for ML — by transforming features to common scales (Min-Max to or Standardization to mean=0, std=1), they prevent features with larger magnitudes from dominating the model, enable faster gradient descent convergence, and ensure distance-based algorithms work properly, making them critical for most algorithms except tree-based models."}]}]}}