    "content": [
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "How BERT Represents Text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "BERT (Bidirectional Encoder Representations from Transformers, Devlin et al., 2018) produces contextual embeddings the same way ELMo does — a different vector per word occurrence — but uses a Transformer encoder instead of LSTMs. Every token attends to every other token simultaneously, so \"bank\" in \"banking rules\" sees \"rules\" in the same layer pass as it sees \"bank\", with no directionality constraint."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "BERT input construction: three embedding types (token, segment A/B, position 0–7) are summed for each of two sentences separated by [SEP]. Arrows show the signal passing through 12 Transformer layers. The [CLS] final vector is used for classification; individual token vectors are used for NER/tagging. Right panel shows which layer to extract for different use-cases."
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Input Construction"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "BERT's input is the sum of three learned embedding tables:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Token embeddings"
                  },
                  {
                    "type": "text",
                    "text": ": WordPiece vocabulary of ~30 000 sub-word tokens. Unknown words are split into known pieces: \"banking\" → [\"bank\", \"##ing\"]."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Segment embeddings"
                  },
                  {
                    "type": "text",
                    "text": ": vectors A or B identify which of the two input sentences each token belongs to. Used during next-sentence prediction pretraining."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "Position embeddings"
                  },
                  {
                    "type": "text",
                    "text": ": learned vectors for positions 0–511. Unlike sinusoidal PE in the original Transformer, these are trained from scratch."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Two special tokens are always present: "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "[CLS]"
          },
          {
            "type": "text",
            "text": " at position 0 (its final hidden state becomes the sentence-level representation) and "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "[SEP]"
          },
          {
            "type": "text",
            "text": " at the end of each sentence segment."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Extracting Embeddings with Hugging Face"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from transformers import BertTokenizer, BertModel\nimport torch\n\ntokenizer = BertTokenizer.from_pretrained(\"bert-base-uncased\")\nmodel     = BertModel.from_pretrained(\"bert-base-uncased\", output_hidden_states=True)\nmodel.eval()\n\nsentences = [\n    \"I went to the bank to deposit money.\",\n    \"The fox sat on the river bank.\",\n]\n\nfor sent in sentences:\n    inputs = tokenizer(sent, return_tensors=\"pt\")\n    with torch.no_grad():\n        outputs = model(**inputs)\n\n    # outputs.last_hidden_state: (1, seq_len, 768)\n    # outputs.hidden_states: tuple of 13 tensors (embedding + 12 layers)\n    last_hidden = outputs.last_hidden_state   # shape (1, seq_len, 768)\n    all_layers  = outputs.hidden_states       # tuple of 13 × (1, seq_len, 768)\n\n    tokens = tokenizer.convert_ids_to_tokens(inputs[\"input_ids\"][0])\n    for i, tok in enumerate(tokens):\n        print(f\"{tok:<12} {last_hidden[0, i, :4].tolist()}\")"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Polysemy check: same word, different vectors"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import torch\nimport torch.nn.functional as F\nfrom transformers import BertTokenizer, BertModel\n\ntokenizer = BertTokenizer.from_pretrained(\"bert-base-uncased\")\nmodel     = BertModel.from_pretrained(\"bert-base-uncased\")\nmodel.eval()\n\ndef get_token_vec(sentence, target_word):\n    inputs = tokenizer(sentence, return_tensors=\"pt\")\n    tokens = tokenizer.convert_ids_to_tokens(inputs[\"input_ids\"][0])\n    with torch.no_grad():\n        out = model(**inputs)\n    idx = next(i for i, t in enumerate(tokens) if t == target_word)\n    return out.last_hidden_state[0, idx]\n\nvec_finance = get_token_vec(\n    \"I went to the bank to deposit money.\", \"bank\"\n)\nvec_river   = get_token_vec(\n    \"The fox sat on the river bank.\", \"bank\"\n)\n\ncos_sim = F.cosine_similarity(vec_finance.unsqueeze(0),\n                               vec_river.unsqueeze(0)).item()\nprint(f\"Cosine similarity: {cos_sim:.3f}\")\n# ~0.72 — same word type, different contextual embeddings\n# (Word2Vec would give 1.0 — identical vectors)"
          }
        ]
      },
