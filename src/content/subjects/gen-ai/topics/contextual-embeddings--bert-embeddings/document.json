      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# Sum of last 4 hidden layers (common NER recipe)\nimport torch\nfrom transformers import BertTokenizer, BertModel\n\ntokenizer = BertTokenizer.from_pretrained(\"bert-base-uncased\")\nmodel     = BertModel.from_pretrained(\"bert-base-uncased\", output_hidden_states=True)\nmodel.eval()\n\ntext   = \"I went to the bank to deposit money.\"\ninputs = tokenizer(text, return_tensors=\"pt\")\n\nwith torch.no_grad():\n    outputs = model(**inputs)\n\nhidden_states = outputs.hidden_states  # tuple: 13 × (1, T, 768)\n\n# Stack last 4 layers and sum\ntoken_vecs = torch.stack(hidden_states[-4:]).sum(dim=0)  # (1, T, 768)\nprint(token_vecs.shape)   # torch.Size([1, 9, 768])"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Sentence Embeddings from BERT"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The raw "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "[CLS]"
          },
          {
            "type": "text",
            "text": " vector is not a good sentence embedding for semantic similarity — it was never trained for that directly. Mean-pooling all token vectors performs better. For production sentence embeddings, use a model fine-tuned with contrastive loss (e.g. Sentence-BERT):"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "# pip install sentence-transformers\nfrom sentence_transformers import SentenceTransformer\nimport numpy as np\n\n# all-MiniLM-L6-v2 is fast (80 MB) and strong on semantic similarity\nmodel = SentenceTransformer(\"all-MiniLM-L6-v2\")\n\nsentences = [\n    \"I went to the bank to deposit money.\",\n    \"She made a withdrawal at the ATM.\",\n    \"The fox sat on the river bank.\",\n]\n\nembeddings = model.encode(sentences)   # shape (3, 384)\n\nfrom sklearn.metrics.pairwise import cosine_similarity\nsim = cosine_similarity(embeddings)\nprint(sim.round(2))\n# [[1.   0.82 0.31]\n#  [0.82 1.   0.28]\n#  [0.31 0.28 1.  ]]\n# Financial sentences are closer together than financial vs. river"
          }
        ]
      },
