ype": "bold"}], "text": "overall structure"}, {"type": "text", "text": " rather than fitting training data as closely as possible."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "L1 Regularization (Lasso)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "What it is"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "L1 regularization"}, {"type": "text", "text": ", also called "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Lasso"}, {"type": "text", "text": " (Least Absolute Shrinkage and Selection Operator), adds a penalty equal to the "}, {"type": "text", "marks": [{"type": "bold"}], "text": "absolute value"}, {"type": "text", "text": " of the sum of coefficients."}]}, {"type": "paragraph", "content": [{"type": "text", "text": "L1 penalty formula:"}]}, {"type": "blockMath", "attrs": {"latex": "\\text{L1 Penalty} = \\lambda \\sum_{i=1}^{n} |w_i|"}}, {"type": "paragraph", "content": [{"type": "text", "text": "Where "}, {"type": "inlineMath", "attrs": {"latex": "w_i"}}, {"type": "text", "text": " are the model weights."}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "How it works"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Penalizes the "}, {"type": "text", "marks": [{"type": "bold"}], "text": "absolute value of weights"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Forces weights of uninformative features to become exactly zero"}, {"type": "text", "text": " over iterations"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Deducts a small amount from each weight at each step"}, {"type": "text", "text": ", eventually driving it to zero