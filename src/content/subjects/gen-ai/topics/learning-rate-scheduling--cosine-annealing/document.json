nt":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Very small models"},{"type":"text","text":": Simple linear decay may suffice"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Quick experiments"},{"type":"text","text":": Skip scheduling for speed"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"When you need exact LR values"},{"type":"text","text":": Cosine is non-linear"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common Mistakes to Avoid"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Mistake 1: Forbidding Warm Restarts Epoch Parameter"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# WRONG: Missing epoch parameter for restarts\nscheduler = CosineAnnealingWarmRestarts(optimizer, T_0=10)\nscheduler.step()  # ERROR! [web:196]\n\n# RIGHT: Pass epoch for restarts\nscheduler.step(epoch)  # Required [web:196]"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Mistake 2: Setting eta_min Too High"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# WRONG: Minimum LR too high\nscheduler = CosineAnnealingLR(optimizer, T_max=100, eta_min=0.01)  # Too high!\n\n# RIGHT: Minimum LR very low\nscheduler = CosineAnnealingLR(optimizer, T_max=100, eta_min=0.0)  # or 1e-6"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Mistake 3: Using with Small Models"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# For small models, linear decay may be simpler\n# Cosine annealing is best for large models"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Mental Model"}]},{"type":"paragraph","content":[{"type":"text","text":"Think of cosine annealing as "},{"type":"text","marks":[{"type":"bold"}],"text":"sliding down a smooth hill"},{"type":"text","text":":"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Start at top"},{"type":"text","text":": High learning rate (fast initial learning)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Slide smoothly"},{"type":"text","text":": Follow cosine curve downward"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Reach bottom"},{"type":"text","text":": Low learning rate (fine-tuning)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"No bumps"},{"type":"text","text":": Smooth curve prevents jerky movements"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Think of cosine annealing with warm restarts as "},{"type":"text","marks":[{"type":"bold"}],"text":"bouncing a ball down stairs"},{"type":"text","text":":"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"First bounce"},{"type":"text","text":": Roll down first stair (cosine decay)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Bounce back up"},{"type":"text","text":": Jump to top of next stair (warm restart)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Roll down again"},{"type":"text","text":": Continue cosine decay"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Approach ground"},{"type":"text","text":": Each bounce gets closer to minimum loss"}]}]}]},{"type":"heading","attrs":{"leve