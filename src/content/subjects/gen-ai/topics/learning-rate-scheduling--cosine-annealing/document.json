","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PyTorch restarts"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"CosineAnnealingWarmRestarts"},{"type":"text","text":" (with restarts)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"T_max"},{"type":"text","text":": Maximum epochs in cycle (typical: 50–300)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"eta_min"},{"type":"text","text":": Minimum learning rate (typical: 0 or 1e-6)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"T_0"},{"type":"text","text":": First cycle length for restarts (typical: 10–50)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"T_mult"},{"type":"text","text":": Multiplier for cycle length"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"PyTorch"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"CosineAnnealingLR(optimizer, T_max=100, eta_min=0.0)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"TensorFlow"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"CosineDecay(lr_max, decay_steps, alpha=lr_min/lr_max)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Transformers"},{"type":"text","text":": Standard scheduler for state-of-the-art models"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Vision models"},{"type":"text","text":": Excellent for ResNet, CNNs, object detection"}]}]},{"type":"listItem","content":[{"type":"paragraph","cont