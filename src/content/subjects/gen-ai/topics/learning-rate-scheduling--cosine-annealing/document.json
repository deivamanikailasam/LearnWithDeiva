tarts"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Yes (SGDR)"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "No"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "No"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "No"}]}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "When to Use Cosine Annealing"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Best Use Cases:"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Transformers/LLMs"}, {"type": "text", "text": ": Standard scheduler for state-of-the-art"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Vision models"}, {"type": "text", "text": ": ResNet, CNNs, object detection"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Diffusion models"}, {"type": "text", "text": ": Stable training"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Large batch training"}, {"type": "text", "text": ": Smooth decay prevents instability"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Mixed precision training"}, {"type": "text", "text": ": Stabilizes FP16/BF16 training"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "When you want minimal tuning"}, {"type": "text", "text": ": Works well with default values"}]}]}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "When Not to Use:"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Very small models"}, {"type": "text", "text": ": Simple linear decay may suffice"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Quick experiments"}, {"type": "text", "text": ": Skip scheduling for speed"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "When you need exact LR values"}, {"type": "text", "text": ": Cosine is non-linear"}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Common Mistakes to Avoid"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Mistake 1: Forbidding Warm Restarts Epoch Parameter"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# WRONG: Missing epoch parameter for restarts\nscheduler = CosineAnnealingWarmRestarts(optimizer, T_0=10)\nscheduler.step()  # ERROR! [web:196]\n\n# RIGHT: Pass epoch for restarts\nscheduler.step(epoch)  # Required [web:196]"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Mistake 2: Setting eta_min Too High"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# WRONG: Minimum LR too high\nscheduler = CosineAnnealingLR(optimizer, T_max=100, eta_min=0.01)  # Too high!\n\n# RIGHT: Minimum LR very low\nscheduler = CosineAnnealingLR(optimizer, T_max=100, eta_min=0.0)  # or 1e-6"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Mistake 3: Using with Small Models"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# For small models, linear decay may be simpler\n# Cosine annealing is best for large models"}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Mental Model"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Think of cosine annealing as "}, {"type": "text", "marks": [{"type": "bold"}], "text": "sliding down a smooth hill"}, {"type": "text", "text": ":"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Start at top"}, {"type": "text", "text": ": High learning rate (fast initial learning)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Slide smoothly"}, {"type": "text", "text": ": Follow cosine curve downward"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Reach bottom"}, {"type": "text", "text": ": Low learning rate (fine-tuning)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "No bumps"}, {"type": "text", "text": ": Smooth curve prevents jerky movements"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Think of cosine annealing with warm restarts as "}, {"type": "text", "marks": [{"type": "bold"}], "text": "bouncing a ball down stairs"}, {"type": "text", "text": ":"}]}, {"type": "orderedList", "attrs": {"start": 1, "type": null}, "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "First bounce"}, {"type": "text", "text": ": Roll down first stair (cosine decay)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Bounce back up"}, {"type": "text", "text": ": Jump to top of next stair (warm restart)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Roll down again"}, {"type": "text", "text": ": Continue cosine decay"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Approach ground"}, {"type": "text", "text": ": Each bounce gets closer to minimum loss"}]}]}]}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Key Takeaways"}]}, {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Cosine annealing"}, {"type": "text", "text": ": Smooth LR decay following cosine curve from η"}, {"type": "text", "marks": [{"type": "italic"}], "text": "max to η"}, {"type": "text", "text": "min"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Formula"}, {"type": "text", "text": ": "}, {"type": "inlineMath", "attrs": {"latex": "\\eta_t = \\eta_{\\min} + \\frac{1}{2}(\\eta_{\\max} - \\eta_{\\min})(1 + \\cos(\\frac{\\pi \\cdot T_{\\text{cur}}}{T_{\\max}}))"}}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Smooth curve"}, {"type": "text", "text": ": Continuous, smooth function (no abrupt jumps)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Fast convergence"}, {"type": "text", "text": ": Avoids abrupt changes that slow training"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Better generalization"}, {"type": "text", "text": ": Helps escape local minima"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "SGDR"}, {"type": "text", "text": ": Cosine Annealing with Warm Restarts (periodic resets)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Warm restarts benefit"}, {"type": "text", "text": ": Approaches minimal loss closer each cycle"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "PyTorch standard"}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "code"}], "text": "CosineAnnealingLR"}, {"type": "text", "text": " (no restarts)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "PyTorch restarts"}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "code"}], "text": "CosineAnnealingWarmRestarts"}, {"type": "text", "text": " (with restarts)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "T_max"}, {"type": "text", "text": ": Maximum epochs in cycle (typical: 50–300)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "eta_min"}, {"type": "text", "text": ": Minimum learning rate (typical: 0 or 1e-6)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "T_0"}, {"type": "text", "text": ": First cycle length for restarts (typical: 10–50)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "T_mult"}, {"type": "text", "text": ": Multiplier for cycle length"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "PyTorch"}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "code"}], "text": "CosineAnnealingLR(optimizer, T_max=100, eta_min=0.0)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "TensorFlow"}, {"type": "text", "text": ": "}, {"type": "text", "marks": [{"type": "code"}], "text": "CosineDecay(lr_max, decay_steps, alpha=lr_min/lr_max)"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Transformers"}, {"type": "text", "text": ": Standard scheduler for state-of-the-art models"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Vision models"}, {"type": "text", "text": ": Excellent for ResNet, CNNs, object detection"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Low-cost, high-impact"}, {"type": "text", "text": ": Minimal tuning, significant improvement"}]}]}, {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Mixed precision"}, {"type": "text", "text": ": Stabilizes FP16/BF16 training"}]}]}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Cosine annealing is one of the "}, {"type": "text", "marks": [{"type": "bold"}], "text": "most practical learning-rate schedules"}, {"type": "text", "text": " used in deep learning today, offering fast convergence, better generalization, and stable training with minimal tuning—making it ideal for Transformers, vision models, and large-scale training in 2025."}]}]}}