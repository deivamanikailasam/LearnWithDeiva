{"format": "tiptap/v1", "updatedAt": "2026-06-22T04:43:18.565Z", "doc": {"type": "doc", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Matplotlib"}, {"type": "text", "text": " is Python's foundational and most popular library for creating "}, {"type": "text", "marks": [{"type": "bold"}], "text": "static, animated, and interactive visualizations"}, {"type": "text", "text": ", widely used in ML engineering for plotting data distributions, tracking training progress, visualizing model performance, and exploring features."}]}, {"type": "blockquote", "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Simple definition:"}, {"type": "text", "text": " “Matplotlib is a comprehensive library for creating static, animated, and interactive visualizations in Python. It makes easy things easy and hard things possible.”"}]}]}, {"type": "horizontalRule"}, {"type": "image", "attrs": {"src": "data:image/svg+xml;base64,", "alt": "Matplotlib — concept overview"}}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "What Matplotlib is"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "Matplotlib is a "}, {"type": "text", "marks": [{"type": "bold"}], "text": "plotting library"}, {"type": "text", "text": " for Python built on top of "}, {"type": "text", "marks": [{"type": "bold"}], "text": "NumPy"}, {"type": "text", "text": ", meaning it can handle large datasets with ease and is integrated with Python's numerical computing stack."}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Key features"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Feature"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth