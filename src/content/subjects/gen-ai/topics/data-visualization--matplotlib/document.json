eading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "2. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Scatter Plot"}, {"type": "text", "text": " (relationships between variables)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import matplotlib.pyplot as plt\n\nx = [1, 2, 3, 4, 5]\ny = [2, 3, 5, 7, 11]\n\nplt.scatter(x, y)\nplt.show()"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use case"}, {"type": "text", "text": ": See correlations between features, cluster visualization."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "3. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Bar Plot"}, {"type": "text", "text": " (comparing categories)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import matplotlib.pyplot as plt\n\ncategories = ['A', 'B', 'C', 'D']\nvalues = [10, 20, 15, 25]\n\nplt.bar(categories, values)\nplt.show()"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use case"}, {"type": "text", "text": ": Compare class counts, feature importance."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "4. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Histogram"}, {"type": "text", "text": " (data distribution)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import matplotlib.pyplot as plt\nimport numpy as np\n\ndata = np.random.randn(1000)\n\nplt.hist(data, bins=30)\nplt.show()"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use case"}, {"type": "text", "text": ": Visualize feature distributions, check for normality."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "5. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Box Plot"}, {"type": "text", "text": " (summary statistics)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import matplotlib.pyplot as plt\nimport numpy as np\n\ndata = [np.random.normal(0, std, 100) for std in range(1, 4)]\n\nplt.boxplot(data)\nplt.show()"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use case"}, {"type": "text", "text": ": See median, quartiles, outliers in features."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "6. "}, {"type": "text", "marks": [{"type": "bold"}], "text": "Pie Plot"}, {"type": "text", "text": " (proportions)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import matplotlib.pyplot as plt\n\nsizes = [25, 35, 40]\nlabels = ['A', 'B', 'C']\n\nplt.pie(sizes, labels=labels)\nplt.show()"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use case"}, {"type": "text", "text": ": Show class distribution, feature proportions."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Customizing plots"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Add labels, title, legend"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "plt.plot(x, y)\nplt.xlabel('X-axis label')\nplt.ylabel('Y-axis label')\nplt.title('Plot Title')\nplt.legend(['Series 1'])\nplt.show()"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Style and colors"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "# Change color, line style, marker\nplt.plot(x, y, color='red', linestyle='--', marker='o')\n\n# Grid\nplt.grid(True)"}]}, {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Save figure"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "plt.savefig('plot.png')  # Save to disk"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Matplotlib's object-oriented API"}]}, {"type": "paragraph", "content": [{"type": "text", "text": "For advanced plots, use the "}, {"type": "text", "marks": [{"type": "bold"}], "text": "object-oriented API"}, {"type": "text", "text": ":"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import matplotlib.pyplot as plt\n\nfig, ax = plt.subplots(figsize=(8, 6))\n\nax.plot(x, y)\nax.set_xlabel('X-axis')\nax.set_ylabel('Y-axis')\nax.set_title('Plot Title')\nax.grid(True)\n\nplt.show()"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Benefits"}, {"type": "text", "text": ":\n- More control over figure/axes\n- Better for complex layouts (subplots)"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Subplots (multiple plots in one figure)"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import matplotlib.pyplot as plt\n\nfig, axes = plt.subplots(nrows=2, ncols=2, figsize=(10, 8))\n\naxes[0, 0].plot(x, y)\naxes[0, 0].set_title('Plot 1')\n\naxes[0, 1].scatter(x, y)\naxes[0, 1].set_title('Plot 2')\n\naxes[1, 0].hist(y)\naxes[1, 0].set_title('Plot 3')\n\naxes[1, 1].bar(categories, values)\naxes[1, 1].set_title('Plot 4')\n\nplt.tight_layout()\nplt.show()"}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "3D plots (with "}, {"type": "text", "marks": [{"type": "code"}], "text": "mpl_toolkits"}, {"type": "text", "text": ")"}]}, {"type": "codeBlock", "attrs": {"language": "python"}, "content": [{"type": "text", "text": "import matplotlib.pyplot as plt\nfrom mpl_toolkits.mplot3d import Axes3D\n\nfig = plt.figure()\nax = fig.add_subplot(111, projection='3d')\n\nax.scatter(x, y, z)\nplt.show()"}]}, {"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Use case"}, {"type": "text", "text": ": Visualize 3D embeddings, spatial data."}]}, {"type": "horizontalRule"}, {"type": "heading", "attrs": {"level": 2}, "content": [{"type": "text", "text": "Matplotlib vs. other visualization libraries"}]}, {"type": "table", "content": [{"type": "tableRow", "content": [{"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Library"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Strength"}]}]}, {"type": "tableHeader", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Relation to Matplotlib"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "marks": [{"type": "bold"}], "text": "Matplotlib"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Base library, full control, publication-quality"}]}]}, {"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Foundation"}]}]}]}, {"type": "tableRow", "content": [{"type": "tableCell", "attrs": {"colspan": 1, "rowspan": 1, "colwidth": null, "align": null}, "content": [{"type": "paragraph", "conte