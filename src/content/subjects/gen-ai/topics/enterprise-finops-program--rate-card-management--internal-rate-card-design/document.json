    "content": [
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "What an Internal Rate Card Is"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "An internal rate card translates external LLM provider prices into the rates your platform charges internal teams. It adds a structured markup to recover shared platform costs (observability, guardrails, fallback routing, infra) and introduces service tiers so teams can choose between shared capacity and higher-SLA dedicated capacity. The rate card is the interface between the provider billing layer and the internal chargeback system."
          }
        ]
      },
      {
        "type": "image",
        "attrs": {
          "src": "data:image/svg+xml;base64,",
          "alt": "Rate card structure"
        }
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "The markup is "
              },
              {
                "type": "text",
                "marks": [
                  {
                    "type": "bold"
                  }
                ],
                "text": "not profit"
              },
              {
                "type": "text",
                "text": " \u2014 it recovers the real platform costs of running a production LLM gateway safely. Without it, the platform team's costs become invisible subsidies absorbed by IT, while teams underestimate their true GenAI spend."
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Data Model"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The rate card data model has three layers: provider prices (external, versioned), a markup schedule (platform overhead components), and rate card entries (internal service rates by tier). Freezing "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "ProviderPrice"
          },
          {
            "type": "text",
            "text": " and "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "MarkupSchedule"
          },
          {
            "type": "text",
            "text": " with "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "frozen=True"
          },
          {
            "type": "text",
            "text": " prevents accidental mutation of historical records."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "from dataclasses import dataclass, field\nfrom datetime import date\nfrom enum import Enum\nfrom typing import Optional\n\nclass ServiceTier(Enum):\n    STANDARD = \"standard\"    # shared capacity, best-effort SLA\n    PRIORITY  = \"priority\"   # dedicated capacity, latency SLA\n    RESERVED  = \"reserved\"   # pre-committed throughput, discounted\n\nclass MarkupComponent(Enum):\n    OBSERVABILITY = \"observability\"\n    GUARDRAILS    = \"guardrails\"\n    FALLBACK      = \"fallback_routing\"\n    INFRA         = \"shared_infra\"\n\n@dataclass(frozen=True)\nclass MarkupSchedule:\n    component: MarkupComponent\n    rate: float              # fractional e.g. 0.06 = 6%\n    description: str\n\nDEFAULT_MARKUP: list[MarkupSchedule] = [\n    MarkupSchedule(MarkupComponent.OBSERVABILITY, 0.06, \"Logging, tracing, cost attribution pipeline\"),\n    MarkupSchedule(MarkupComponent.GUARDRAILS,    0.04, \"PII redaction, content filter, rate limiter\"),\n    MarkupSchedule(MarkupComponent.FALLBACK,      0.025,\"Fallback routing and retry orchestration\"),\n    MarkupSchedule(MarkupComponent.INFRA,         0.05, \"Shared compute, networking, secrets mgmt\"),\n]\n\n@dataclass(frozen=True)\nclass ProviderPrice:\n    model_id: str\n    input_per_million_usd: float\n    output_per_million_usd: float\n    effective_date: date\n\n@dataclass\nclass RateCardEntry:\n    service_name: str          # internal name e.g. \"sonnet-standard\"\n    provider_model: str        # upstream model id\n    tier: ServiceTier\n    input_rate_usd: float      # per million tokens, after markup\n    output_rate_usd: float\n    effective_date: date\n    version: int\n    notes: str = \"\"\n\n    @property\n    def blended_rate_usd(self) -> float:\n        \"\"\"Approximate blended cost assuming 3:1 output:input ratio.\"\"\"\"\n        return (self.input_rate_usd * 1 + self.output_rate_usd * 3) / 4\n\n@dataclass\nclass RateCard:\n    version: int\n    effective_date: date\n    review_date: date\n    entries: list[RateCardEntry] = field(default_factory=list)\n    markup_schedule: list[MarkupSchedule] = field(default_factory=list)\n\n    def get_entry(self, service_name: str) -> Optional[RateCardEntry]:\n        for e in self.entries:\n            if e.service_name == service_name:\n                return e\n        return None\n\n    @property\n    def total_markup_rate(self) -> float:\n        return sum(m.rate for m in self.markup_schedule)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Building the Rate Card from Provider Prices"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The rate card is computed mechanically: for each provider model and each service tier, apply the total markup and the tier premium. Priority tier carries a 20% surcharge for dedicated capacity; reserved tier gives a 10% discount for committed throughput. All rates are rounded to four decimal places."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def build_rate_card(\n    provider_prices: list[ProviderPrice],\n    markup_schedule: list[MarkupSchedule],\n    tier_premiums: dict[ServiceTier, float],\n    version: int,\n    effective_date: date,\n    review_date: date,\n) -> RateCard:\n    \"\"\"Compute internal rates from provider prices + markup + tier premium.\"\"\"\"\n    total_markup = sum(m.rate for m in markup_schedule)\n\n    entries: list[RateCardEntry] = []\n    for pp in provider_prices:\n        for tier, premium in tier_premiums.items():\n            multiplier = (1 + total_markup) * (1 + premium)\n            entry = RateCardEntry(\n                service_name=f\"{pp.model_id.split('/')[-1]}-{tier.value}\",\n                provider_model=pp.model_id,\n                tier=tier,\n                input_rate_usd=round(pp.input_per_million_usd * multiplier, 4),\n                output_rate_usd=round(pp.output_per_million_usd * multiplier, 4),\n                effective_date=effective_date,\n                version=version,\n            )\n            entries.append(entry)\n\n    return RateCard(\n        version=version,\n        effective_date=effective_date,\n        review_date=review_date,\n        entries=entries,\n        markup_schedule=markup_schedule,\n    )\n\n# Example usage\nPROVIDER_PRICES_V4 = [\n    ProviderPrice(\"claude-3-5-sonnet\", 3.00, 15.00, date(2025, 1, 1)),\n    ProviderPrice(\"claude-3-haiku\",    0.25,  1.25, date(2025, 1, 1)),\n    ProviderPrice(\"gpt-4o\",            2.50, 10.00, date(2025, 1, 1)),\n    ProviderPrice(\"text-embedding-3-small\", 0.02, 0.0, date(2025, 1, 1)),\n]\n\nTIER_PREMIUMS = {\n    ServiceTier.STANDARD: 0.00,   # no premium for shared capacity\n    ServiceTier.PRIORITY: 0.20,   # 20% premium for latency SLA\n    ServiceTier.RESERVED: -0.10,  # 10% discount for committed usage\n}\n\nrate_card_v4 = build_rate_card(\n    provider_prices=PROVIDER_PRICES_V4,\n    markup_schedule=DEFAULT_MARKUP,\n    tier_premiums=TIER_PREMIUMS,\n    version=4,\n    effective_date=date(2025, 1, 1),\n    review_date=date(2025, 4, 1),\n)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Computing Charges at Call Time"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "At API call time, the gateway looks up the service name in the current rate card and computes the charge from actual token counts. This charge is recorded in the usage ledger for monthly aggregation and chargeback."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def compute_charge(\n    rate_card: RateCard,\n    service_name: str,\n    input_tokens: int,\n    output_tokens: int,\n) -> float:\n    \"\"\"Compute the internal charge for a single LLM call.\"\"\"\"\n    entry = rate_card.get_entry(service_name)\n    if entry is None:\n        raise KeyError(f\"Service {service_name!r} not in rate card v{rate_card.version}\")\n    input_cost  = input_tokens  / 1_000_000 * entry.input_rate_usd\n    output_cost = output_tokens / 1_000_000 * entry.output_rate_usd\n    return round(input_cost + output_cost, 8)\n\n# Example\ncharge = compute_charge(rate_card_v4, \"claude-3-5-sonnet-standard\", 800, 320)\n# = (800/1e6 * 3.54) + (320/1e6 * 17.70)\n# = 0.002832 + 0.005664 = $0.008496"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Versioning and Historical Lookup"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Rate cards must be versioned with an effective date so that historical spend reports use the rate that was active at the time of each call. Storing each version as a JSON file in a directory enables "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "load_rate_card_for_date"
          },
          {
            "type": "text",
            "text": " to return the correct card for any past date."
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "import json\nfrom pathlib import Path\n\nRATE_CARD_STORE = Path(\"data/rate_cards\")\n\ndef save_rate_card(rc: RateCard) -> None:\n    path = RATE_CARD_STORE / f\"v{rc.version}.json\"\n    path.parent.mkdir(parents=True, exist_ok=True)\n    payload = {\n        \"version\": rc.version,\n        \"effective_date\": rc.effective_date.isoformat(),\n        \"review_date\": rc.review_date.isoformat(),\n        \"total_markup_rate\": rc.total_markup_rate,\n        \"markup_schedule\": [\n            {\"component\": m.component.value, \"rate\": m.rate, \"description\": m.description}\n            for m in rc.markup_schedule\n        ],\n        \"entries\": [\n            {\n                \"service_name\": e.service_name,\n                \"provider_model\": e.provider_model,\n                \"tier\": e.tier.value,\n                \"input_rate_usd\": e.input_rate_usd,\n                \"output_rate_usd\": e.output_rate_usd,\n                \"effective_date\": e.effective_date.isoformat(),\n                \"version\": e.version,\n            }\n            for e in rc.entries\n        ],\n    }\n    with open(path, \"w\") as f:\n        json.dump(payload, f, indent=2)\n\ndef load_rate_card_for_date(target_date: date) -> RateCard:\n    \"\"\"Return the rate card whose effective_date is <= target_date.\"\"\"\"\n    candidates = sorted(RATE_CARD_STORE.glob(\"v*.json\"))\n    result = None\n    for path in candidates:\n        rc_data = json.loads(path.read_text())\n        eff = date.fromisoformat(rc_data[\"effective_date\"])\n        if eff <= target_date:\n            result = rc_data\n    if result is None:\n        raise ValueError(f\"No rate card found for {target_date}\")\n    return result  # deserialise as needed"
          }
        ]
      },
