      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "For function-body completion you can check the indentation of the last returned line against the function definition's indentation level. If the generated code de-indents back to the function's base level, stop inserting even if the model continues generating:"
          }
        ]
      },
      {
        "type": "codeBlock",
        "attrs": {
          "language": "python"
        },
        "content": [
          {
            "type": "text",
            "text": "def trim_to_function_body(completion: str, base_indent: int) -> str:\n    \"\"\"\n    Truncate at the first line that de-indents back to or past the function\n    definition's base indentation level (i.e., the body is over).\n    \"\"\"\n    lines = completion.splitlines(keepends=True)\n    result: list[str] = []\n    for line in lines:\n        stripped = line.lstrip()\n        if not stripped:  # blank lines are fine inside the body\n            result.append(line)\n            continue\n        current_indent = len(line) - len(stripped)\n        if current_indent <= base_indent and result:  # body ended\n            break\n        result.append(line)\n    return \"\".join(result)"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Codebase Index: Incremental Updates"
          }
        ]
      },
