        "content": [
          {
            "type": "text",
            "text": "import asyncio\nfrom pathlib import Path\n\nclass IncrementalIndex:\n    def __init__(self):\n        # map from file path to list of (chunk, embedding)\n        self._store: dict[str, list[tuple[str, list[float]]]] = {}\n        self._queue: asyncio.Queue[Path] = asyncio.Queue()\n\n    async def on_file_saved(self, path: Path) -> None:\n        \"\"\"Called by the LSP server on textDocument/didSave.\"\"\"\n        await self._queue.put(path)\n\n    async def run_indexer(self) -> None:\n        \"\"\"Background task — processes one file at a time.\"\"\"\n        while True:\n            path = await self._queue.get()\n            try:\n                chunks = chunk_python_file(str(path))  # AST-aware chunker\n                embeddings = [\n                    (c.source, await embed_async(c.source))\n                    for c in chunks\n                ]\n                self._store[str(path)] = embeddings\n            except Exception as e:\n                print(f\"re-index failed for {path}: {e}\")\n            finally:\n                self._queue.task_done()\n\n    def retrieve(self, query: str, top_k: int = 5) -> list[str]:\n        import numpy as np\n        q = np.array(embed_sync(query))\n        scored: list[tuple[float, str]] = []\n        for chunks in self._store.values():\n            for source, emb in chunks:\n                e = np.array(emb)\n                sim = float(np.dot(q, e) / (np.linalg.norm(q) * np.linalg.norm(e) + 1e-9))\n                scored.append((sim, source))\n        scored.sort(reverse=True)\n        return [src for _, src in scored[:top_k]]"
          }
        ]
