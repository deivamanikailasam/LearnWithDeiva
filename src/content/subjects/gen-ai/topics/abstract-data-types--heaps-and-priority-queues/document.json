{"format":"tiptap/v1","updatedAt":"2026-06-21T14:04:32.529Z","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Heaps"},{"type":"text","text":" are specialized binary tree data structures where each node satisfies the "},{"type":"text","marks":[{"type":"bold"}],"text":"heap property"},{"type":"text","text":" (parent ≥ children for max-heap, or parent ≤ children for min-heap), and the tree is "},{"type":"text","marks":[{"type":"bold"}],"text":"complete"},{"type":"text","text":" (all levels filled except possibly the last, filled left-to-right). A "},{"type":"text","marks":[{"type":"bold"}],"text":"Priority Queue"},{"type":"text","text":" is an abstract data type that stores elements with priorities and always returns the highest-priority element first—typically implemented using heaps for O(log n) efficiency. In Gen AI, these enable efficient top-K selection, beam search, and task scheduling."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"What It Is"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Aspect"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Heap"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Priority Queue"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Array/List"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Type"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Concrete data structure (binary tree)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Abstract data type (ADT)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Concrete data structure"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Ordering"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Heap property: parent ≥ children (max) or parent ≤ children (min)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Priority-based: highest priority first"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Sequential (no ordering)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Structure"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Complete binary tree"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Any implementation (heap, BST, list)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Linear (sequential)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Access"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Root = highest/lowest priority"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Highest priority element first"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Index-based"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Insert/Delete"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(log n)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(log n) with heap impl"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n) (shift)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use case"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Efficient priority management"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Job scheduling, top-K selection"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"General storage"}]}]}]}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Why It Matters for Gen AI"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ❌ WITHOUT heap: O(n) top-K selection (slow)\nscores = [0.8, 0.3, 0.9, 0.5, 0.7]  # Token probabilities\n# Sort to find top 2: sorted(scores, reverse=True)[:2]  # ❌ O(n log n)\n# Result: [0.9, 0.8]  # Top 2 tokens\n\n# ✅ WITH heap: O(n) build + O(k log n) extract (fast)\nimport heapq\n\n# Build min-heap: O(n)\nheap = scores  # Heapify: O(n) [web:138]\n\n# Extract top 2: O(k log n) where k=2\ntop_2 = heapq.nlargest(2, scores)  # ✅ [0.9, 0.8]\n# Total: O(n) + O(2 log n) ≈ O(n) (vs O(n log n) for sort) [web:138]\nprint(top_2)  # [0.9, 0.8]\n\n# ✅ Gen AI: Beam search with priority queue\n# At each step, LLM generates 10 tokens with scores\n# Keep only top 3 (beam width = 3) with heap\ntoken_scores = [\n    (\"the\", 0.8), (\"cat\", 0.3), (\"sat\", 0.9), (\"on\", 0.5), (\"mat\", 0.7)\n]\n\n# Priority queue: Keep top 3 by score\nheap = []\nfor token, score in token_scores:\n    heapq.heappush(heap, (-score, token))  # ✅ Max-heap (negate for min-heap)\n    if len(heap) > 3:\n        heapq.heappop(heap)  # ✅ Remove lowest priority\n\ntop_3 = [token for _, token in heap]  # ✅ [\"sat\", \"mat\", \"the\"]\nprint(top_3)  # Beam search keeps only highest-scoring tokens [web:138][web:142]"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Key benefits:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Efficient top-K"},{"type":"text","text":": O(n) build + O(k log n) extract vs O(n log n) sort\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Priority scheduling"},{"type":"text","text":": CPU tasks, job queues, event-driven simulation\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Beam search"},{"type":"text","text":": Keep top-K tokens in LLM generation\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Graph algorithms"},{"type":"text","text":": Dijkstra's shortest path, MST (minimum spanning tree)"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"How It Works (Core Concepts)"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Max-Heap vs Min-Heap"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Max-Heap: Parent ≥ children (root = maximum)\n#       5\n#      / \\\n#     3   4\n#    /   /\n#   1   2\n# Root (5) is largest [web:139][web:142]\n\n# ✅ Min-Heap: Parent ≤ children (root = minimum)\n#       1\n#      / \\\n#     3   2\n#    /   /\n#   5   4\n# Root (1) is smallest [web:138][web:139]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Array Representation"},{"type":"text","text":" ⭐ (No pointers needed)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Heap stored in array (no tree pointers)\n# For A[i]:\n#   - left child = A[2*i]\n#   - right child = A[2*i + 1]\n#   - parent = A[i // 2]\n\nheap_array = [5, 3, 4, 1, 2]  # Max-heap [web:138]\n# Index 0: 5 (root)\n# Index 1: 3 (left child of 0)\n# Index 2: 4 (right child of 0)\n# Index 3: 1 (left child of 1)\n# Index 4: 2 (right child of 1) [web:138]\n\n# Access:\nleft_child = heap_array[2 * 0]  # heap_array[0] = 5 → left = heap_array [cs.cornell](https://www.cs.cornell.edu/courses/cs211/2000fa/materials/Oct26%20Priority%20Queues%20and%20Heaps.pdf) = 3\nright_child = heap_array[2 * 0 + 1]  # heap_array [cs.cornell](https://www.cs.cornell.edu/courses/cs211/2000fa/materials/Oct26%20Priority%20Queues%20and%20Heaps.pdf) = 4\nparent = heap_array[0 // 2]  # heap_array[0] = 5 (root has no parent) [web:138]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Heap Insert Operation"},{"type":"text","text":" (Bubble Up)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Insert: Add to end, bubble up while < parent (min-heap)\ndef insert(heap, value):\n    heap.append(value)  # ✅ Add to end\n    i = len(heap) - 1\n    \n    # Bubble up: Swap with parent if smaller (min-heap)\n    while i > 0 and heap[i] < heap[(i - 1) // 2]:\n        heap[i], heap[(i - 1) // 2] = heap[(i - 1) // 2], heap[i]\n        i = (i - 1) // 2\n\nheap = []\ninsert(heap, 5)  #  [codesignal](https://codesignal.com/learn/courses/interview-prep-the-last-mile-in-csharp/lessons/heaps-and-priority-queues-in-csharp)\ninsert(heap, 3)  # [3, 5] (3 < 5, swap)\ninsert(heap, 4)  # [3, 5, 4] (4 > 3, no swap)\ninsert(heap, 1)  # [1, 3, 4, 5] (1 < 3, swap) [web:138]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"4. "},{"type":"text","marks":[{"type":"bold"}],"text":"Heap Extract Operation"},{"type":"text","text":" (Bubble Down)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Extract min: Remove root, move last to root, bubble down\ndef extract_min(heap):\n    if len(heap) == 0:\n        return None\n    \n    min_val = heap[0]  # ✅ Root (minimum)\n    heap[0] = heap[-1]  # ✅ Move last to root\n    heap.pop()  # ✅ Remove last\n    \n    # Bubble down: Swap with smaller child\n    i = 0\n    while 2 * i + 1 < len(heap):  # ✅ Has left child\n        left = 2 * i + 1\n        right = 2 * i + 2\n        \n        # Find smaller child\n        smaller = left\n        if right < len(heap) and heap[right] < heap[left]:\n            smaller = right\n        \n        # Swap if current > smaller child\n        if heap[i] > heap[smaller]:\n            heap[i], heap[smaller] = heap[smaller], heap[i]\n            i = smaller\n        else:\n            break\n    \n    return min_val\n\nheap = [1, 3, 4, 5]\nextract_min(heap)  # ✅ Returns 1, heap = [3, 5, 4] [web:138]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"5. "},{"type":"text","marks":[{"type":"bold"}],"text":"Python's "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"heapq"},{"type":"text","marks":[{"type":"bold"}],"text":" Module"},{"type":"text","text":" ⭐ Built-in Min-Heap"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"import heapq\n\n# ✅ Create min-heap\nheap = []\nheapq.heappush(heap, 5)  # Push 5\nheapq.heappush(heap, 3)  # Push 3\nheapq.heappush(heap, 4)  # Push 4\n\n# ✅ Extract min: O(log n)\nmin_val = heapq.heappop(heap)  # ✅ Returns 3 (smallest)\nprint(min_val)  # 3 [web:138][web:140]\n\n# ✅ Get N smallest: O(n + k log n)\nsmallest_2 = heapq.nsmallest(2, [5, 3, 4, 1, 2])  # ✅ [1, 2]\nprint(smallest_2) [web:138][web:140]\n\n# ✅ Get N largest: O(n + k log n)\nlargest_2 = heapq.nlargargest(2, [5, 3, 4, 1, 2])  # ✅ [5, 4]\nprint(largest_2) [web:138][web:140]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"6. "},{"type":"text","marks":[{"type":"bold"}],"text":"Max-Heap with Negation"},{"type":"text","text":" (Python only has min-heap)"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Python: Min-heap only → negate for max-heap\nheap = []\nheapq.heappush(heap, -5)  # Push -5 (negated)\nheapq.heappush(heap, -3)  # Push -3 (negated)\nheapq.heappush(heap, -4)  # Push -4 (negated)\n\n# ✅ Extract max: Negate result\nmax_val = -heapq.heappop(heap)  # ✅ Returns 5 (largest)\nprint(max_val)  # 5 [web:142]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"When to Use (Decision Criteria)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Scenario"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Heap/PQ"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use Array"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Use BST"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Top-K selection"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ O(n) + O(k log n)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ O(n log n) (sort)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ O(log n) per query"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Priority scheduling"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Highest priority first"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ Sequential"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ O(log n) search"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Beam search (LLM)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Keep top-K tokens"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ O(n) per step"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ O(log n) per step"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Shortest path"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ Dijkstra's algorithm"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ O(n²)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ O(log n)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Range queries"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ No ordering"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ O(n) scan"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ O(log n + k)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Random access"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ O(n)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ O(1)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"⚠️ O(log n)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Sorted traversal"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ No"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"❌ O(n log n)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"✅ O(n)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Rule of thumb:"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Heap/PQ"},{"type":"text","text":": Top-K selection + priority scheduling + beam search (LLM)\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"Array"},{"type":"text","text":": Random access + static data "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://www.uvm.edu/~cbcafier/cs2240/content/02_c++_essentials/09_linked_lists.html","target":"_blank","rel":"noopener noreferrer nofollow","class":"text-brand-600 underline dark:text-brand-400","title":null}}],"text":"uvm"},{"type":"text","text":"\n- "},{"type":"text","marks":[{"type":"bold"}],"text":"BST"},{"type":"text","text":": Sorted data + range queries"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Key Gen AI Applications"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"1. "},{"type":"text","marks":[{"type":"bold"}],"text":"Beam Search for LLM Generation"},{"type":"text","text":" ⭐"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Beam search: Keep top-K tokens at each step\nimport heapq\n\ndef beam_search(prompt, beam_width=3, max_tokens=5):\n    # Initial beam: [sequence, score]\n    beam = [(\"\", 1.0)]  # ✅ Empty sequence, score 1.0\n    \n    for step in range(max_tokens):\n        candidates = []\n        \n        for sequence, score in beam:\n            # LLM generates next tokens\n            next_tokens = [\n                (\"the\", 0.8), (\"cat\", 0.3), (\"sat\", 0.9)\n            ]\n            \n            for token, token_score in next_tokens:\n                new_score = score * token_score\n                candidates.append((sequence + token, new_score))\n        \n        # Keep top-K with heap: O(k log n)\n        beam = heapq.nlargest(beam_width, candidates, key=lambda x: x [cs.cornell](https://www.cs.cornell.edu/courses/cs211/2000fa/materials/Oct26%20Priority%20Queues%20and%20Heaps.pdf))\n    \n    return beam[0][0]  # ✅ Best sequence\n\nresult = beam_search(\"The\")  # ✅ \"The sat the\" (highest-scoring) [web:138]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"2. "},{"type":"text","marks":[{"type":"bold"}],"text":"Top-K Token Sampling"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Top-K: Select highest-probability tokens\nimport heapq\n\ntoken_probs = [\n    (\"the\", 0.25), (\"and\", 0.20), (\"is\", 0.15), (\"it\", 0.10), (\"of\", 0.08)\n]\n\n# Top 3: O(n) + O(k log n)\ntop_3 = heapq.nlargest(3, token_probs, key=lambda x: x [cs.cornell](https://www.cs.cornell.edu/courses/cs211/2000fa/materials/Oct26%20Priority%20Queues%20and%20Heaps.pdf))\nprint(top_3)  # ✅ [(\"the\", 0.25), (\"and\", 0.20), (\"is\", 0.15)] [web:138][web:140]"}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"3. "},{"type":"text","marks":[{"type":"bold"}],"text":"Task Scheduling for AI Systems"}]},{"type":"codeBlock","attrs":{"language":"python"},"content":[{"type":"text","text":"# ✅ Priority queue: Schedule AI tasks by priority\nimport heapq\n\nclass TaskScheduler:\n    def __init__(self):\n        self.queue = []  # ✅ Min-heap (priority = smaller number = higher priority)\n    \n    def add_task(self, task, priority):\n        heapq.heappush(self.queue, (priority, task))  # ✅ Enqueue [web:138][web:142]\n    \n    def get_next_task(self):\n        if self.queue:\n            return heapq.heappop(self.queue) [cs.cornell](https://www.cs.cornell.edu/courses/cs211/2000fa/materials/Oct26%20Priority%20Queues%20and%20Heaps.pdf)  # ✅ Dequeue (highest priority)\n        return None\n\nscheduler = TaskScheduler()\nscheduler.add_task(\"User A: Explain quantum\", priority=1)  # ✅ Highest priority\nscheduler.add_task(\"User B: Explain photosynthesis\", priority=3)\nscheduler.add_task(\"User C: Explain neural networks\", priority=2)\n\nscheduler.get_next_task()  # ✅ \"User A: Explain quantum\" (priority 1) [web:138]"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Time Complexity"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Operation"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Heap (Array)"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Array (Sort)"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"BST"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Insert"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(log n)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(1) (append)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(log n)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Extract min/max"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(log n)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n) (search)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(log n)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Build heap"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n) (copy)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n log n)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Top-K"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n + k log n)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(n log n) (sort)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"O(k log n)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text