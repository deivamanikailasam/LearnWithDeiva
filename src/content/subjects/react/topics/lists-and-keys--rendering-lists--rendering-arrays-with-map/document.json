      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Use ",
                    "marks": []
                  },
                  {
                    "type": "text",
                    "text": ".map()",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " inside "
                  },
                  {
                    "type": "text",
                    "text": "{}",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " in JSX to turn a data array into an array of elements — React renders array contents in order."
