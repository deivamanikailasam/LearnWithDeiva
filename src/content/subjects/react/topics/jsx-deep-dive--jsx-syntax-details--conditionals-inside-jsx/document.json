                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Reusable or complex switch-like logic"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "tableCell",
                "attrs": {
                  "colspan": 1,
                  "rowspan": 1,
                  "colwidth": null
                },
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "Extra function definition overhead"
