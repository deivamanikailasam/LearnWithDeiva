{"format":"tiptap/v1","doc":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"When working with arrays in JavaScript, a very common task is locating a specific item by some condition — finding the user with a given ID, the product matching a search term, or the first item whose status is "},{"type":"text","marks":[{"type":"code"}],"text":"'pending'"},{"type":"text","text":". Two methods were built for exactly this: "},{"type":"text","marks":[{"type":"code"}],"text":"find()"},{"type":"text","text":" returns the matching element itself, and "},{"type":"text","marks":[{"type":"code"}],"text":"findIndex()"},{"type":"text","text":" returns its position in the array."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"find()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"Array.prototype.find()"},{"type":"text","text":" returns the "},{"type":"text","marks":[{"type":"bold"}],"text":"first element"},{"type":"text","text":" in an array that passes a test function. If no element passes, it returns "},{"type":"text","marks":[{"type":"code"}],"text":"undefined"},{"type":"text","text":". The original array is not modified."}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"const users = [\n  { id: 1, name: 'Alice', role: 'admin' },\n  { id: 2, name: 'Bob',   role: 'editor' },\n  { id: 3, name: 'Carol', role: 'admin' },\n];\n\n// Find the first user whose role is 'admin'\nconst firstAdmin = users.find(user => user.role === 'admin');\nconsole.log(firstAdmin); // { id: 1, name: 'Alice', role: 'admin' }\n\n// Not found → undefined\nconst missing = users.find(user => user.id === 99);\nconsole.log(missing); // undefined"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"find() stops immediately"},{"type":"text","text":" after the first match — it does not scan the rest of the array. This makes it efficient when you expect exactly one result."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"findIndex()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"Array.prototype.findIndex()"},{"type":"text","text":" works identically to "},{"type":"text","marks":[{"type":"code"}],"text":"find()"},{"type":"text","text":", but instead of returning the element, it returns its "},{"type":"text","marks":[{"type":"bold"}],"text":"zero-based index"},{"type":"text","text":". If no element matches, it returns "},{"type":"text","marks":[{"type":"code"}],"text":"-1"},{"type":"text","text":"."}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"const users = [\n  { id: 1, name: 'Alice' },\n  { id: 2, name: 'Bob' },\n  { id: 3, name: 'Carol' },\n];\n\nconst idx = users.findIndex(user => user.id === 2);\nconsole.log(idx); // 1\n\n// Not found → -1\nconst missing = users.findIndex(user => user.id === 99);\nconsole.log(missing); // -1"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Syntax & Parameters"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// find\narray.find((element, index, array) => booleanTest)\n\n// findIndex\narray.findIndex((element, index, array) => booleanTest)"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Parameter"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"What it is"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"element"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"The current element being tested"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"index"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Zero-based index of the current element (optional)"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"array"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"The original array (optional)"}]}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Return values: "},{"type":"text","marks":[{"type":"code"}],"text":"find()"},{"type":"text","text":" returns the element or "},{"type":"text","marks":[{"type":"code"}],"text":"undefined"},{"type":"text","text":". "},{"type":"text","marks":[{"type":"code"}],"text":"findIndex()"},{"type":"text","text":" returns the index or "},{"type":"text","marks":[{"type":"code"}],"text":"-1"},{"type":"text","text":"."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"find() vs indexOf()"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"indexOf()"},{"type":"text","text":" searches by exact reference equality ("},{"type":"text","marks":[{"type":"code"}],"text":"==="},{"type":"text","text":"), so it works for primitive values like strings and numbers but not for objects. "},{"type":"text","marks":[{"type":"code"}],"text":"find()"},{"type":"text","text":" accepts a callback, so it can test any condition — including properties of objects."}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"const names = ['Alice', 'Bob', 'Carol'];\n\n// indexOf works fine on primitives\nconsole.log(names.indexOf('Bob'));       // 1\n\nconst users = [{ id: 1 }, { id: 2 }];\n\n// indexOf compares by reference — objects are never ===\nconsole.log(users.indexOf({ id: 1 }));  // -1 ❌\n\n// find() uses a callback — checks properties\nconsole.log(users.find(u => u.id === 1)); // { id: 1 } ✅"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Method"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Returns"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Works on objects?"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Not-found value"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"find()"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Element"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Yes — tests by callback"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"undefined"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"findIndex()"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Index"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Yes — tests by callback"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"-1"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"indexOf()"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Index"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"No — equality by reference"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"-1"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"In React: Common Patterns"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Looking Up State Items by ID"}]},{"type":"paragraph","content":[{"type":"text","text":"The most frequent use in React is finding a specific item from a state array — for example, to display a selected item's details:"}]},{"type":"codeBlock","attrs":{"language":"jsx"},"content":[{"type":"text","text":"import { useState } from 'react';\n\nconst products = [\n  { id: 'p1', name: 'Keyboard', price: 79 },\n  { id: 'p2', name: 'Monitor',  price: 299 },\n  { id: 'p3', name: 'Webcam',   price: 59  },\n];\n\nfunction ProductDetail({ selectedId }) {\n  const product = products.find(p => p.id === selectedId);\n\n  if (!product) return <p>Select a product to see details.</p>;\n\n  return (\n    <div>\n      <h2>{product.name}</h2>\n      <p>${product.price}</p>\n    </div>\n  );\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Updating a Single Item in State"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"findIndex()"},{"type":"text","text":" is essential when you need to update one item in a state array without mutating it. The standard pattern is: find the index, create a new array with the item replaced using spread:"}]},{"type":"codeBlock","attrs":{"language":"jsx"},"content":[{"type":"text","text":"import { useState } from 'react';\n\nfunction TaskList() {\n  const [tasks, setTasks] = useState([\n    { id: 1, title: 'Buy groceries', done: false },\n    { id: 2, title: 'Write tests',   done: false },\n    { id: 3, title: 'Read book',     done: true  },\n  ]);\n\n  function toggleTask(id) {\n    const idx = tasks.findIndex(task => task.id === id);\n    if (idx === -1) return; // guard: not found\n\n    // Create a new array with the updated item\n    const updated = [\n      ...tasks.slice(0, idx),\n      { ...tasks[idx], done: !tasks[idx].done },\n      ...tasks.slice(idx + 1),\n    ];\n    setTasks(updated);\n  }\n\n  return (\n    <ul>\n      {tasks.map(task => (\n        <li key={task.id}>\n          <label>\n            <input\n              type=\"checkbox\"\n              checked={task.done}\n              onChange={() => toggleTask(task.id)}\n            />\n            {task.done ? <s>{task.title}</s> : task.title}\n          </label>\n        </li>\n      ))}\n    </ul>\n  );\n}"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Checking Whether an Item Exists"}]},{"type":"codeBlock","attrs":{"language":"jsx"},"content":[{"type":"text","text":"function WishlistButton({ productId, wishlist }) {\n  const isInWishlist = wishlist.find(item => item.id === productId) !== undefined;\n  // Or more concisely:\n  // const isInWishlist = wishlist.some(item => item.id === productId);\n\n  return (\n    <button>{isInWishlist ? 'Remove from Wishlist' : 'Add to Wishlist'}</button>\n  );\n}"}]},{"type":"paragraph","content":[{"type":"text","text":"When only checking existence (not needing the element itself), "},{"type":"text","marks":[{"type":"code"}],"text":"some()"},{"type":"text","text":" is more expressive. When you need the element's data, "},{"type":"text","marks":[{"type":"code"}],"text":"find()"},{"type":"text","text":" is the right choice."}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Replacing vs Mapping — When to Use findIndex()"}]},{"type":"paragraph","content":[{"type":"text","text":"An alternative to "},{"type":"text","marks":[{"type":"code"}],"text":"findIndex() + slice"},{"type":"text","text":" for updating one item is "},{"type":"text","marks":[{"type":"code"}],"text":"map()"},{"type":"text","text":":"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// Using map() — simpler for updating one property\nconst updated = tasks.map(task =>\n  task.id === id ? { ...task, done: !task.done } : task\n);\n\n// Using findIndex() + slice — useful when you need to know\n// the index for another reason (e.g., position-dependent logic)\nconst idx = tasks.findIndex(task => task.id === id);\nconst updated2 = [\n  ...tasks.slice(0, idx),\n  { ...tasks[idx], done: !tasks[idx].done },\n  ...tasks.slice(idx + 1),\n];"}]},{"type":"paragraph","content":[{"type":"text","text":"Both approaches are correct. The "},{"type":"text","marks":[{"type":"code"}],"text":"map()"},{"type":"text","text":" version is more concise and idiomatic for this specific task. Use "},{"type":"text","marks":[{"type":"code"}],"text":"findIndex()"},{"type":"text","text":" when you explicitly need the numeric position — for insertion, position-aware rendering, or splice-based operations."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Common Mistakes"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Not guarding against undefined"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// ❌ Crashes if find() returns undefined\nconst user = users.find(u => u.id === selectedId);\nconsole.log(user.name); // TypeError: Cannot read properties of undefined\n\n// ✅ Check before accessing properties\nconst user = users.find(u => u.id === selectedId);\nif (user) {\n  console.log(user.name);\n}\n\n// Or with optional chaining:\nconsole.log(user?.name); // undefined if not found, no crash"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Confusing -1 with a missing check on findIndex()"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// ❌ idx could be -1; updating tasks[-1] silently creates a property\nconst idx = tasks.findIndex(t => t.id === id);\nconst updated = [...tasks.slice(0, idx), newTask, ...tasks.slice(idx + 1)];\n// When idx === -1, slice(0, -1) removes the last element — wrong!\n\n// ✅ Guard against -1\nconst idx = tasks.findIndex(t => t.id === id);\nif (idx === -1) return; // not found, bail out\nconst updated = [\n  ...tasks.slice(0, idx),\n  newTask,\n  ...tasks.slice(idx + 1),\n];"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Using find() when some() is the right tool"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// ❌ Using find() just to check existence — more verbose than needed\nconst hasAdmin = users.find(u => u.role === 'admin') !== undefined;\n\n// ✅ some() says the intent directly\nconst hasAdmin = users.some(u => u.role === 'admin');"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Expecting find() to return all matches"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"// ❌ Only returns the FIRST match — subsequent admins are missed\nconst allAdmins = users.find(u => u.role === 'admin');\n\n// ✅ Use filter() to get all matching elements\nconst allAdmins = users.filter(u => u.role === 'admin');"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Choosing the Right Method"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Goal"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Method to use"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Get the first matching element"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"find()"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Get the index of the first match"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"findIndex()"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Get all matching elements"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"filter()"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Check if any element matches (boolean)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"some()"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Check if all elements match (boolean)"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"every()"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Find index of primitive by value"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null,"align":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"indexOf()"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Best Practices"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Always guard the result of find()."},{"type":"text","text":" Because it returns "},{"type":"text","marks":[{"type":"code"}],"text":"undefined"},{"type":"text","text":" when no match is found, accessing properties on the result without a null check causes a TypeError. Use an "},{"type":"text","marks":[{"type":"code"}],"text":"if"},{"type":"text","text":" guard or optional chaining ("},{"type":"text","marks":[{"type":"code"}],"text":"result?.property"},{"type":"text","text":")."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Always guard the result of findIndex()."},{"type":"text","text":" A return value of "},{"type":"text","marks":[{"type":"code"}],"text":"-1"},{"type":"text","text":" means no match. Using "},{"type":"text","marks":[{"type":"code"}],"text":"-1"},{"type":"text","text":" as an array index in "},{"type":"text","marks":[{"type":"code"}],"text":"slice(-1)"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"code"}],"text":"array[-1]"},{"type":"text","text":" produces incorrect behavior, not an error — making these bugs silent and hard to find."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Use the right method for the right question."},{"type":"text","text":" Existence check → "},{"type":"text","marks":[{"type":"code"}],"text":"some()"},{"type":"text","text":". First match element → "},{"type":"text","marks":[{"type":"code"}],"text":"find()"},{"type":"text","text":". First match position → "},{"type":"text","marks":[{"type":"code"}],"text":"findIndex()"},{"type":"text","text":". All matches → "},{"type":"text","marks":[{"type":"code"}],"text":"filter()"},{"type":"text","text":". Using "},{"type":"text","marks":[{"type":"code"}],"text":"find()"},{"type":"text","text":" for an existence check (then comparing to "},{"type":"text","marks":[{"type":"code"}],"text":"undefined"},{"type":"text","text":") works but is less readable than "},{"type":"text","marks":[{"type":"code"}],"text":"some()"},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Prefer map() for single-item updates in state."},{"type":"text","text":" For the common React pattern of updating one item in an array ("},{"type":"text","marks":[{"type":"code"}],"text":"task.id === id ? updated : task"},{"type":"text","text":"), "},{"type":"text","marks":[{"type":"code"}],"text":"map()"},{"type":"text","text":" is more concise. Reserve "},{"type":"text","marks":[{"type":"code"}],"text":"findIndex()"},{"type":"text","text":" for when you need the numeric position for another reason."}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Key Takeaways"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"find()"},{"type":"text","text":" returns the first element matching a callback test, or "},{"type":"text","marks":[{"type":"code"}],"text":"undefined"},{"type":"text","text":" if nothing matches."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"findIndex()"},{"type":"text","text":" returns the zero-based index of the first match, or "},{"type":"text","marks":[{"type":"code"}],"text":"-1"},{"type":"text","text":" if nothing matches."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Both stop at the first match"},{"type":"text","text":" — they do not scan the entire array after finding a result."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"find() vs indexOf()"},{"type":"text","text":": use "},{"type":"text","marks":[{"type":"code"}],"text":"find()"},{"type":"text","text":" for objects and complex conditions; "},{"type":"text","marks":[{"type":"code"}],"text":"indexOf()"},{"type":"text","text":" only for primitives by exact value."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"In React"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"find()"},{"type":"text","text":" retrieves items from state arrays by ID; "},{"type":"text","marks":[{"type":"code"}],"text":"findIndex()"},{"type":"text","text":" locates position for immutable state updates."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Always guard"},{"type":"text","text":" the "},{"type":"text","marks":[{"type":"code"}],"text":"undefined"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"code"}],"text":"-1"},{"type":"text","text":" not-found cases before using the result."}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Choose the right tool"},{"type":"text","text":": "},{"type":"text","marks":[{"type":"code"}],"text":"some()"},{"type":"text","text":" for existence, "},{"type":"text","marks":[{"type":"code"}],"text":"filter()"},{"type":"text","text":" for all matches, "},{"type":"text","marks":[{"type":"code"}],"text":"map()"},{"type":"text","text":" for updating one item in state."}]}]}]}]}}
